###########################################################################################
# CUSTOM SUB ROUTINES
# GET_CCE_DEFAULT_VALUE(CONTRA, NNOL)
# GH 22/08/14 - Hard-coded - need to work out how to obtain / set this dynamically.
# PARAM
# CONTRA = 1 Getting default values for account line
#          2 Getting default value for a contra line
# NNOL   = line number only used when processing a contra line
# TODO Consolidate code only using a contra switch because have to use NBLIG when
# processing a standard account line but NNOL when porcessing a contra type line
###########################################################################################
# TODO LIST
# SEARCH FOR TODO in source file for any outstanding questions issues
###########################################################################################

# Last Update 17th Sept 2014

$ACTION
    Case ACTION
        When "IMP_OUVRE"     : Gosub IMP_OUVRE      : # After opening the tables and screens
        When "IMPORT"        : Gosub IMPORT         : # After initializing class [M].
        When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE  : # Before the creation transaction
        When "FERME"         : Gosub FERME          : # Last executed action
    Endcase
Return


$IMP_OUVRE
    #########################################
    # Define variables
    Global Integer GNBPLAN                                        : # Number of charts of accounts managed by the company (max 10)
    Global Integer GNBAXE                                         : # Number of dimensions managed by the company (max 20)
    Global Char    GPLAN(GLONCOA)(1..max(len(mess(0,2644,1)),10)) : # Charts of accounts managed by the company
    Global Char    GAXE(GLONDIE)(1..max(GOPTCANA,20))             : # Dimensions types managed by the company
    Global Integer GOBLIG(1..max(GOPTCANA,20))                    : # Mandatory (O/N) ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬ÃƒÂ¢Ã¢â€šÂ¬Ã…â€œ perhaps you will not use, but the SETPLAN2 needs this parameter
    Global Integer GTYPLED(1..max(len(mess(0,2644,1)),10))        : # Ledger Types managed by the company - perhaps you will not use, but the SETPLAN2 needs this parameter

    Local  Char    ACCORG(GLONGAC)                                : # Source account to lookyp
    Local  Char    ACCDES(GLONGAC)                                : # Account found Safe X3 structure
    Local  Char    SCRACCDES(20)                                  : # Account found Syracuse structure ???
    Local  Char    COAORG(3)                                      : # Source Chart of Account
    Local  Char    COADES(3)                                      : # lookup Chart of Account
    Local  Char    CONTRA_ACC(20)                                 : # GH 13/08/2014 New global to hold contra account code from the site transcribe record
    Local  Integer NUM_LINES                                      : # GH 18/08/2014 New global to count number of lines generated
    Local  Char    CODDIM(30)
    #########################################

    # Create table objects
    If clalev([F:CUR])=0  : Local File TABCUR      [CUR]  : Endif    : # Currency
    If clalev([F:GDE])=0  : Local File GDIAENTRY   [GDE]  : Endif    : # Entry transactions
    If clalev([F:GDD])=0  : Local File GDIAENTRYD  [GDD]  : Endif    : # Entry transaction details
    If clalev([F:GDIE])=0 : Local File GDIE        [GDIE] : Endif    : # Dimension types
    #JOJAC - 2019-09-19 - X3-153852 - START
    If func AFNC.ACTIV("MUIMP")>0
    #JOJAC - 2019-09-19 - X3-153852 - END
      If clalev([F:KPT])=0  : Local File KPYIMPTRAN  [KPT]  : Endif    : # Sage 50 import transcribe
      If clalev([F:KPT2])=0 : Local File KPYIMPTRAN  [KPT2] : Endif    : # Sage 50 import transcribe
    #JOJAC - 2019-09-19 - X3-153852 - START
    Endif
    #JOJAC - 2019-09-19 - X3-153852 - END
    If clalev([F:LED])=0  : Local File GLED        [LED]  : Endif    : # Ledgers
    If clalev([F:GAC])=0  : Local File GACCOUNT    [GAC]  : Endif    : # Accounts
    If clalev([F:CPY])=0  : Local File COMPANY     [CPY]  : Endif    : # Companies
    If clalev([F:GCM])=0  : Local File GACM        [GCM]  : Endif    : # Account core model
Return


$IMPORT
    Case IMPFIC
        When "KPH" # Header Record
            # only process if creating a new record (not modification mode)
            If CHAINE <> "M"
                Call ECR_TRACE("------------------------------------",0) From GESECRAN
                Call ECR_TRACE(mess(2,3701,1) - [F:KPH]CPYNAM        ,0) From GESECRAN
                Call ECR_TRACE(mess(3,3701,1) - [F:KPH]RPONAM        ,0) From GESECRAN
                Call ECR_TRACE(mess(5,3701,1) - [F:KPH]REF           ,0) From GESECRAN
                Call ECR_TRACE(mess(6,3701,1) - [F:KPH]INTREF        ,0) From GESECRAN
                Call ECR_TRACE(mess(4,3701,1) - format$(GDEVFMT, [F:KPH]TOT)   ,0) From GESECRAN

                # Read transribe table to identify X3 sute code to use
                LOOKUP = [KPH]TMPFCY
                Read [KPT]KPYT0  = 1 ; LOOKUP

                # If X3 site found in transcribe table
                If fstat = 0
                    [M]GTE   = [KPT]GTE : [KPH]GTE = [KPT]GTE  : # set Document type
                    [M]FCY   = [KPT]FCY : [KPH]FCY = [KPT]FCY  : # set Site
                    [M]CDE   = [KPT]CDE : [KPH]CDE = [KPT]CDE  : # set Default dimension document (GESCDE)

                    [M:KPYH]TMPFCY = [KPH]TMPFCY  : [KPH]TMPFCY   = [KPH]TMPFCY  : # set source site value
                    [M:KPYM]TOT    = [F:KPH]TOT   : [M:KPYM]TOT   = [F:KPH]TOT  : # set value for source file

                    # set document date to use
                    # 2 (Yes) = Accounting date equal Report date
                    # 1 (No)  = Accounting date current date
                    If [KPT]ACCDAT  = 2
                       [M]ACCDAT = [F:KPH]RPODAT
                    Else
                        [M]ACCDAT  = datesyst
                    Endif

                     # Set offset account to use for selectd site
                     If ([KPT]CONTRA = 2)
                        CONTRA_ACC = [KPT]ACC
                     Else
                        CONTRA_ACC = ""
                     Endif

                    Call ECR_TRACE(mess(12,3701,1) - [F:KPH]FCY - mess(13,3701,1)- [KPH]TMPFCY ,0) From GESECRAN
                Endif

                 # If X3 site not found in transcribe table
                If fstat <> 0
                    Call ECR_TRACE(mess(14,3701,1)- mess(12,3701,1) - [KPH]TMPFCY, -1) From GESECRAN
                Endif

                ######################################
                # Get Chart of account codes for
                # selected site
                #
                Call GETSOC([F:KPH]FCY) From DEVSUB
                [M]CPY =  GSOCIETE : # Current company
                [M]LEG =  GCURLEG  : # Current legislation

                # GDEVSOC being set with wrong company curreny
                # Tempary workaround read currency from CPY record directly
                # [M]CUR =  GDEVSOC  : # Company accounting currency
                Read [CPY]CPY0 = GSOCIETE
                [M]CUR = [CPY]ACCCUR : # Company accounting currency

                Read[CPY]CPY0 = [M]CPY
                Call LEC_GCM([F:CPY]ACM) From CPTLEC
                Call SETPLAN2([F:CPY]ACM,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV

                #########################################
                # Load Dimension types onto header screen
                #
                For COUNTER = 0 To GNBAXE-1
                     [M:KPYH]DIE(COUNTER) = GAXE(COUNTER+1)
                Next COUNTER

                #########################################
                # Load Charts of Accounts onto
                # header screen
                #
                For COUNTER = 0 To GNBPLAN-1
                    [M:KPYH]COA(COUNTER) = GPLAN(COUNTER+1)
                Next COUNTER

                #########################################
                # load Chart of Account format string
                # onto header screen
                #
                Call GLOBVAR    From SETGLBCOA
                Call INIGLBCOA  From SETGLBCOA
                For COUNTER = 0 To GNBPLAN - 1
                    Call INIACCFMT([M:KPYH]COA(COUNTER)) From SETGLBCOA
                    FMT = "K:"+GFMTACC
                    Assign "[M:KPYH]FMTCOA("+num$(COUNTER)+")" With FMT
                Next COUNTER

                #########################################
                # Load Dimension type  format string
                # onto header screen
                #
                Call GLOBVAR    From SETGLBDIE
                Call INIGLBDIE  From SETGLBDIE
                For COUNTER = 0 To GNBAXE - 1
                    Call INICCEFMT([M:KPYH]DIE(COUNTER)) From SETGLBDIE
                    FMT = "K:"+GCCEFMT
                     Assign "[M:KPYH]FMTCCE("+num$(COUNTER)+")" With FMT
                Next COUNTER

                #########################################
                # Load Ledger codes
                # onto header screen
                #
                Local Char    MODELE(30)    : # ModÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¨le comptable
                Local Char    CODLED(30)(1..)
                Local Integer NLED

                Call SETGCM([F:KPH]FCY,MODELE) From CPTDIV
                IMOD= find(MODELE,GGCM(1..GGCMNBR))
                If !IMOD
                    Call GLOBVAR From SETGLBGCM
                    IMOD = find(MODELE,GGCM(1..GGCMNBR))
                Endif
                If IMOD
                    For IREF=1 To len(mess(0,2644,1))
                        REF = evalue("GLED"+num$(IREF)+"("+num$(IMOD)+")")
                        If REF<>"" & !find(REF,CODLED(1..10))
                            NLED+=1
                            CODLED(NLED) = REF
                        Endif
                    Next
                Endif

                For COUNTER = 0 To 9
                    Assign "[M:KPYH]LED("+num$(COUNTER)+")" With CODLED(COUNTER+1)
                Next COUNTER

            Endif

        When "KPD" # detail line
            # only process if creating a new record (not modification mode)
            If CHAINE <> "M"
                [M:KPYD]AMTCUR(NBLIG) = [F:KPD]AMTCUR       : # set ammount
                [M:KPYD]SNS(NBLIG)    = [F:KPD]SNS          : # set value sign

                # Load detail information into header
                # this is done to allow the GESCDE function to work
                [M:KPYH]DEPT       =  [F:KPD]DEPT
                [M:KPYH]COSTCENTRE =  [F:KPD]COSTCENTRE
                [M:KPYH]EMPLOYEE   =  [F:KPD]EMPLOYEE
                [M:KPYH]ACC_CODE   =  [F:KPD]ACC_CODE

                # Check to see if incoming employee value is transcribed
                # update header record done to allow the GESCDE function to work
                Filter [KPT2] Where TYP = 3 and INVALUE = [F:KPD]EMPLOYEE and FCY = [F:KPH]FCY
                For [KPT2]
                    [M:KPYD]CCEEMPLOYEE(NBLIG) = [KPT2]CCE
                    [M:KPYH]CCEEMPLOYEE       =  [KPT2]CCE
                Next

                # Check to see if incoming cost centre  value is transcribed
                # update header record done to allow the GESCDE function to work
                Filter [KPT2] Where TYP = 4 and INVALUE = [F:KPD]COSTCENTRE and FCY = [F:KPH]FCY
                For [KPT2]
                   [M:KPYD]CCECOSTCENTR(NBLIG) = [KPT2]CCE
                   [M:KPYH]CCECOSTCENTR   =  [KPT2]CCE
                Next

                # Check to see if incoming department value is transcribed
                # update header record done to allow the GESCDE function to work
                Filter [KPT2] Where TYP = 5 and INVALUE = [F:KPD]DEPT and FCY = [F:KPH]FCY
                For [KPT2]
                   [M:KPYD]CCEDEPT(NBLIG) = [KPT2]CCE
                   [M:KPYH]CCEDEPT   =  [KPT2]CCE
                Next

                # Check to see if incoming account code value is transcribed
                # update header record done to allow the GESCDE function to work
                Filter [KPT2] Where TYP = 6 and INVALUE = [F:KPD]ACC_CODE and FCY = [F:KPH]FCY
                For [KPT2]
                   [M:KPYD]CCEACC_CODE(NBLIG) = [KPT2]CCE
                   [M:KPYH]CCEACC_CODE   =  [KPT2]CCE
                Next


                # Read transcribe table to identify account to use
                Read [KPT]KPYT0 = 2; [KPD]TMPACC1 ; GPLAN(1);[F:KPH]FCY
                # if match found in transcribe table - fstat = 0
                # Else use incoming value in import file
                If fstat = 0
                    [M:KPYD]ACC1(NBLIG) = [KPT]ACC
                # No lookup account found
                Else
                # Ckeck if incoming value exists as a valid X3 Account code
                If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
                Read [GAC]GAC0 = [M:KPYH]COA(0);[F:KPD]TMPACC1
                    If fstat = 0
                        [M:KPYD]ACC1(NBLIG) = [F:KPD]TMPACC1
                    Else
                        Call ECR_TRACE("(" + mess(23,3701,1)-[F:KPD]SRC_LINE + ")" - mess(14,3701,1) - mess(15,3701,1) - [F:KPD]TMPACC1,-1) From GESECRAN
                    Endif
                Endif

                    ###########################################
                    # Use account value set in ACC1 to find and
                    # insert any default accounts for each
                    # Chart of account
                    #
                    # Only get sub leger accunts if a legal ledger account value has been set
                    # i.e account has not failed transcribe
                    If [M:KPYD]ACC1(NBLIG) <> ""
                    ACCORG = [KPT]ACC
                    COAORG = GPLAN(1)
                    If ACCORG <> ""
                        For COUNTER = 2 To GNBPLAN
                            COADES = GPLAN(COUNTER)
                            Call INIACC(COAORG,ACCORG,COADES,ACCDES,SCRACCDES) From CPTINI
                            If ACCDES = ""
                                Assign "[M:KPYD]ACC"+num$(COUNTER)+"(NBLIG)" With SCRACCDES
                            Else
                                Assign "[M:KPYD]ACC"+num$(COUNTER)+"(NBLIG)" With ACCDES
                            Endif
                            ACCDES     = ""       : # reset
                            SCRACCDES  = ""       : # reset
                        Next COUNTER
                    Endif
                    Endif


                # Set default dimension values
                # PARAM 1
                # CONTRA = 1 Getting default values for account line
                #          2 Getting default value for a contra line
                # PARAM 2
                # NNOL   = line number only used when processing a contra line
                Call GET_CCE_DEFAULT_VALUE(1,0)
                ###############################################################
                # count number of lines processed
                NUM_LINES = NUM_LINES + 1
            Endif
    Endcase
Return

$IMP_VERIF_CRE
    Local Decimal TCR      : # Total credit found on transaction
    Local Decimal TDB      : # Total debits found on transdctiom
    Local Decimal ADJ      : # Adjustment required to balance trnsaction
    Local Integer NNOL     : # new line

    ##########################################################
    # Add total Debits imported and total credits imported in
    # Local Decimal TCR
    # Local Decimal TDB
    For COUNTER = 0 To [M:KPYD]NBLIG-1
        If [M:KPYD]SNS(COUNTER) = 1
            TDB = TDB + [M:KPYD]AMTCUR(COUNTER)
        Endif
        If [M:KPYD]SNS(COUNTER) = -1
            TCR = TCR + [M:KPYD]AMTCUR(COUNTER)
        Endif
    Next

    ADJ = TDB - TCR        : # Calculate adjustment debits minus credits

    # If balance exists then create contra line
    If ADJ <> 0
        Insa NNOL,1,[M:KPYD]NBLIG [M:KPYD]NBLIG
        [M:KPYD]NBLIG += 1
        [M:KPYD]NARRATIVE(NNOL) =  mess(24,3701,1) - "(" + [M:KPYH]INTREF +")" - mess(25,3701,1)
        [M:KPYD]SRC_LINE(NNOL) = "0"

        # Set adjustment (contra) account from site default. Note this may not be set if the site
        # has not been marked as requiring contract accounts and will then need to be set through the transaction
        # entry program manually
        [M:KPYD]ACC1(NNOL) = CONTRA_ACC

        ###########################################
        # Use account value set in ACC1 to find and
        # insert any default account values for each
        # Chart of account
        #
        ACCORG = CONTRA_ACC
        COAORG = GPLAN(1)
        If ACCORG <> ""
            For COUNTER = 2 To GNBPLAN
                COADES = GPLAN(COUNTER)
                Call INIACC(COAORG,ACCORG,COADES,ACCDES,SCRACCDES) From CPTINI
                If ACCDES = ""
                    Assign "[M:KPYD]ACC"+num$(COUNTER)+"(NNOL)" With SCRACCDES
                Else
                    Assign "[M:KPYD]ACC"+num$(COUNTER)+"(NNOL)" With ACCDES
                Endif
                Raz ACCDES        : # reset
                Raz SCRACCDES     : # reset
            Next COUNTER
        Endif

        [M:KPYD]AMTCUR(NNOL) = abs(ADJ)
        If ADJ > 0 : [M:KPYD]SNS(NNOL) = -1 : Endif
        If ADJ < 0 : [M:KPYD]SNS(NNOL) =  1 : Endif
        Call LINNUM ("LINENO") From TABLEAUX            # generate new line number
        NUM_LINES = NUM_LINES + 1                       # GH 18/08/14 - Increment number of lines counter


        Call ECR_TRACE(mess(26,3701,1),0) From GESECRAN
        Call ECR_TRACE(mess(27,3701,1) - format$(GDEVFMT, TDB) + "," - mess(28,3701,1)
&       - format$(GDEVFMT, TCR) + "," - mess(29,3701,1) - format$(GDEVFMT, ADJ), 0) From GESECRAN
        Call ECR_TRACE(mess(30,3701,1) - CONTRA_ACC, 0) From GESECRAN

        # Set default dimension values
        # PARAM 1
        # CONTRA = 1 Getting default values for account line
        #          2 Getting default value for a contra line
        # PARAM 2
        # NNOL   = line number only used when processing a contra line
        Call GET_CCE_DEFAULT_VALUE(2,NNOL)
        ###############################################################
        # count number of lines processed
        NUM_LINES = NUM_LINES + 1
    Endif

    Call ECR_TRACE (mess(31, 3701, 1) - num$(NUM_LINES), 0) From GESECRAN
Return


$FERME
    # TODO check wuth french R&D team if cleanup  (KILL)
    # is required / best practice
    Close Local Mask
    Kill GNBPLAN
    Kill GNBAXE
    Kill GPLAN
    Kill GAXE
    Kill GOBLIG
    Kill GTYPLED
    Kill CONTRA_ACC
    Kill [CUR]
    Kill [GDE]
    Kill [GDD]
    Kill [GDIE]
    Kill [KPT]
    Kill [LED]
    Kill [GAC]
    Kill [CPY]
    Kill [GCM]
Return

Subprog GET_CCE_DEFAULT_VALUE(CONTRA, NNOL)
# GH 22/08/14 - Hard-coded - need to work out how to obtain / set this dynamically.
# PARAM
# CONTRA = 1 Getting default values for account line
#          2 Getting default value for a contra line
# NNOL   = line number only used when processing a contra line
# TODO Consolidate code only using a contra switch because have to use NBLIG when
# processing a standard account line but NNOL when porcessing a contra type line
    Local Integer IND
    Local Integer AXI
    Local Char DIMENSION(30)
    Local Integer LOOP_CNT

    For LOOP_CNT = 0 To (dim([F:KPD]DIE)-1)
        [F:KPD]DIE(LOOP_CNT) = [M:KPYH]DIE(LOOP_CNT)
    Next

    CODDIM = [M:KPYH]CDE   : # set defaut dimension document to use (GESCDE)

    # load dimension type codes into global variable GDIE
    # need for IDENT sub  call by Call INICCE(..) from CPTINI
    For COUNTER = 1 To 20
        GDIE(COUNTER) = [M:KPYH]DIE(COUNTER-1)
    Next COUNTER

    If CONTRA = 1
        For AXE=1 To GNBAXE
            For NLED = 1 To GNBPLAN
             DIMENSION = ""
             GCODLED(NLED) = [M:KPYH]LED(NLED-1)
             Call INDLED(GCODLED(NLED),GAXE(AXE),IND,AXI) From CPTDIV
             If IND>0 & GLEDFLGANA(IND)=2 & AXI
                  ACCOUNT = evalue ("[M:KPYD]ACC"+num$(NLED)+"("+num$(NBLIG)+")")
                  # TODO JAMCC - Using local copy of INICCE having to do this as standard version assume line variable (nolign-1)
                  # import need to use NBLIG
                  # see $IDENT - If instr(1,[F:CDE]FLD(TAB-1),"#")
                  # Not good approach need to review this with french R&D team
                  #Call INICCE(DIMENSION,GAXE(AXE),GCODLED(NLED), [L]ACCOUNT,CODDIM) From CPTINI
                  Call INICCE(DIMENSION,GAXE(AXE),GCODLED(NLED), [L]ACCOUNT,CODDIM)
                  If DIMENSION <> ""
                      IND2 = find(GAXE(AXE),[F:KPD]DIE(0..dim([F:KPD]DIE)-1))

                      If IND2 > 0
                          FIELD_NAME = "[M:KPYD]CCE"+num$(IND2)+"("+num$(NBLIG)+")"
                          Assign FIELD_NAME With DIMENSION
                      Endif
                  Endif
              Endif
          Next
        Next
    Endif

    # Get dault dimension values for contra(offset) type line
    If CONTRA = 2
       For AXE=1 To GNBAXE
          For NLED = 1 To GNBPLAN
           DIMENSION = ""
              GCODLED(NLED) = [M:KPYH]LED(NLED-1)
              Call INDLED(GCODLED(NLED),GAXE(AXE),IND,AXI) From CPTDIV
              If IND>0 & GLEDFLGANA(IND)=2 & AXI
                  ACCOUNT = evalue ("[M:KPYD]ACC"+num$(NLED)+"("+num$(NNOL)+")")
                  # Not using GESCDE document type when creating Contra line to set default dimension values
                  Call INICCE(DIMENSION,GAXE(AXE),GCODLED(NLED), [L]ACCOUNT,"")
                  If DIMENSION <> ""
                      IND2 = find(GAXE(AXE),[F:KPD]DIE(0..dim([F:KPD]DIE)-1))
                      If IND2 > 0
                          FIELD_NAME = "[M:KPYD]CCE"+num$(IND2)+"("+num$(NNOL)+")"
                          Assign FIELD_NAME With DIMENSION
                      Endif
                  Endif
              Endif
          Next
       Next
    Endif
End



Subprog INICCE(VALEUR,DIE,LED,ACC,SECDEF)
    Variable Char VALEUR : # Code section
    Value    Char DIE    : # Code axe
    Value    Char LED    : # Code rÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â©fÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â©rentiel
    Value    Char ACC    : # Compte
    Value    Char SECDEF : # Code section par dÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â©faut
    If !clalev([F:GAC]) : Local File =GTABCPT+"GACCOUNT" [GAC] : Endif
        Local Integer I, J
        Local Integer IND,AXI : Raz IND, AXI
        Local Libelle SUIVI
        If VALEUR<>"" | [L]ACC="" : End : Endif
        Call INDLED([L]LED,[L]DIE,IND,AXI) From CPTDIV
        If !IND or !AXI : End : Endif
        Call LECTURE("GAC",[L]ACC,GLEDCOA(IND)) From CONTOBJ
        SUIVI = find([L]DIE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
        If !SUIVI : End : Endif
        Call INISEC(VALEUR,SECDEF,DIE)
        If VALEUR = ""
        VALEUR = [F:GAC]CCEDEF(SUIVI-1)
    Endif
End

Subprog INISEC(VALEUR,CODE,CAXE)
    Variable Char    VALEUR()
    Value    Char    CODE
    Value    Char    CAXE
    Local Integer I, TAB, ISOC, D, RELIT, IND, INDAXE, INDAXE2, XX, XY
    Local Char    AXE(GLONDIE), IDENT(30), IDENT2(30), SITE(GLONFCY), ZONE(10), ABREV(5), WABREV(15), OLDID(30), OLDID2(30), WAXE(GLONDIE), WCCE(GLONCCE)
    AXE  = CAXE
    If clalev([F:CDE])=0 : Local File CACCEDEF [CDE] : Endif
    If clalev([F:CCE])=0 : Local File CACCE    [CCE] : Endif
    Call LECTURE("CDE",GSOCIETE,CODE) From CONTOBJ
    If fstat
        Call LECTURE("CDE","",CODE) From CONTOBJ
    Endif
    If !fstat
        VALEUR = "" : D=len(mess(0,693,1))
        INDAXE = find(AXE,[F:CDE]DIE(0..dim([F:CDE]DIE)-1))
        If INDAXE
            For I=1 To [F:CDE]NBLIG
                TAB = evalue("[F:CDE]CCE"+num$(INDAXE)+"("+num$(I-1)+")")
                GPOINT="INISEC" : Gosub ENTREE From EXEFNC
                If VALEUR<>""  : Break : Endif
                Gosub IDENT
            Next I
        Endif
    Endif
End

$IDENT
    If TAB=6 or TAB=20 : # PiÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¨ce / document d'origine  => cas particulier
        Onerrgo ERREUR
        If instr(1,[F:CDE]FLD(TAB-1),"func") | instr(1,[F:CDE]FLD(TAB-1),"evalue")
            VALEUR = evalue([F:CDE]FLD(TAB-1)) #F64268
            If [F:CDE]FLD(TAB-1)<>"" : VALEUR = evalue([F:CDE]FLD(TAB-1)): Endif
        Else
            Call ABREV([F:CDE]FLD(TAB-1),ABREV)
            If instr(1,[F:CDE]FLD(TAB-1),"[F")
                If ABREV<>""
                    WABREV = "[F:"+ABREV+"]"
                Else
                    WABREV  = "[F]"
                Endif
            Elsif instr(1,[F:CDE]FLD(TAB-1),"[M")
                If ABREV<>""
                    WABREV = "[M:"+ABREV+"]"
                Else
                    WABREV = "[M]"
                Endif
        Endif

        Raz INDAXE2
        For XX=1 To GOPTCANA
            If AXE = evalue(WABREV+"DIE("+num$(XX-1)+")") : INDAXE2=XX : Break :  Endif
        Next

        If INDAXE2>0 : VALEUR = evalue([F:CDE]FLD(TAB-1)+"("+num$(INDAXE2-1)+")") : Endif
    Endif

    Onerrgo

    Elsif TAB=21 # Sections prÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â©cÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â©dentes => cas particulier

    Onerrgo ERREUR
    OLDID = [F:CCE]CCE   : OLDID2 = [F:CCE]DIE

    Call ABREV([F:CDE]FLD(TAB-1),ABREV)
    If instr(1,[F:CDE]FLD(TAB-1),"[F")
        If ABREV<>""
            WABREV = "[F:"+ABREV+"]"
        Else
            WABREV  = "[F]"
        Endif
    Elsif instr(1,[F:CDE]FLD(TAB-1),"[M")
        If ABREV<>""
          WABREV = "[M:"+ABREV+"]"
        Else
          WABREV = "[M]"
        Endif
    Endif

    ABREV = "CCE"
    For XX=1 To GOPTCANA
        If evalue("dim("+WABREV+"DIE)")>0
            WAXE = evalue(WABREV+"DIE("+num$(XX-1)+")")
        Else
            WAXE = GDIE(XX)
        Endif
            WCCE = ""
            If WAXE <> ""
                If instr(1,[F:CDE]FLD(TAB-1),"#")
                    # WCCE = evalue(WABREV+"CCE"+num$(XX)+"("+num$(nolign-1)+")")
                    WCCE = evalue(WABREV+"CCE"+num$(XX)+"("+num$(NBLIG)+")")
                Else
                    WCCE = evalue(WABREV+"CCE("+num$(XX-1)+")")
                Endif
            Endif
        If WCCE<>""
            Call LECTURE(ABREV,WCCE,WAXE) From CONTOBJ
            If fstat=0
                Raz INDAXE2
                For XY=1 To GOPTCANA
                    If AXE=evalue("[F:CCE]OTHDIE("+num$(XY-1)+")") : INDAXE2=XY : Break : Endif
                Next
                If INDAXE2>0 : VALEUR = evalue("[F:CCE]DEFCCE("+num$(INDAXE2-1)+")") : Endif
            Endif
        Endif

        If VALEUR<>"" : Break : Endif
    Next

    Call LECTURE(ABREV,OLDID,OLDID2) From CONTOBJ
    Onerrgo
    Else
    If TAB>0 & TAB<>D & [F:CDE]FLD(TAB-1)<>"" : # D=aucune
  Onerrgo ERREUR
  IDENT = evalue([F:CDE]FLD(TAB-1))
  Onerrgo
 Endif
 If IDENT="" & TAB=7
  Gosub SETSOC
 Endif
 If IDENT<>""
  ABREV  = ""
  ZONE   = "CCE"
  IDENT2 = ""
  IND    = 0
  Case TAB
   When 1  : ABREV = "ITM" : TABLE = "ITMMASTER"
   When 2  : ABREV = "BPC" : TABLE = "BPCUSTOMER"
   When 3  : ABREV = "BPS" : TABLE = "BPSUPPLIER"
   When 4  : ABREV = "REP" : TABLE = "SALESREP"
   When 5  : ABREV = "AUS" : TABLE = "AUTILIS"
   When 6  : # PiÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¨ce, dÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â©jÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â  traitÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â©
   When 7  : ABREV = "CPY" : TABLE = "COMPANY"
   When 8  : ABREV = "FCY" : TABLE = "FACILITY"
   When 9  : ABREV = "TCU" : TABLE = "TABCUR"
   When 10 : ABREV = "TVT" : TABLE = "TABVAT"
   When 11 : ABREV = "SFI" : TABLE = "SFOOTINV"
   When 12 : ABREV = "TDA" : TABLE = "TABDEPAGIO"
   When 13 : ABREV = "BAN" : TABLE = "BANK"
   When 14 : ABREV = "GAC" : TABLE = "GACCOUNT"  : ZONE = "CCEDEF" : IDENT2 = [F:GAC]COA
   When 15 : ABREV = "FAS" : TABLE = "FIXASSET"
   When 16 : ABREV = "PFI" : TABLE = "PFOOTINV"
   When 17 : ABREV = "BPR" : TABLE = "BPARTNER"
   When 18 : ABREV = "MWC" : TABLE = "WORKCOST" : Onerrgo ERREUR  # zones de clÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â© inversÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â©es ! (18/12/01)
                                                  IDENT  = evalue([F:CDE]FLD(7)) # (TB 21/02/01)
                                                  IDENT2 = evalue([F:CDE]FLD(TAB-1))
                                                  Onerrgo
   When 19 : ABREV = "ONA" : TABLE = "OVENAT" :# nouvelle table# ZONE = "CCE"+num$(AXE)+"("+num$(IND)+")"
   When 20 : # PiÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¨ce bis, dÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â©jÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â  traitÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â©
   When 21 : # PiÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¨ce ter, dÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â©jÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â  traitÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â©
   When 22 : ABREV = "AUS" : TABLE = "AUTILIS"
   When 23 : ABREV = "FCS" : TABLE = "FRECST" # Issue 84130 - 2013-02-25 by MAE : Ajout des charges achat
  Endcase
  If ABREV<>""
   If evalue("clalev([F:"+ABREV+"])")=0
    RELIT = 0
    Local File =TABLE
   Else
    RELIT = 1 : Raz OLDID, OLDID2
    Case TAB
     When 1  : OLDID = [F:ITM]ITMREF
     When 2  : OLDID = [F:BPC]BPCNUM
     When 3  : OLDID = [F:BPS]BPSNUM
     When 4  : OLDID = [F:REP]REPNUM
     When 5  : OLDID = [F:AUS]USR
     When 7  : OLDID = [F:CPY]CPY
     When 8  : OLDID = [F:FCY]FCY
     When 9  : OLDID = [F:TCU]CUR
     When 10 : OLDID = [F:TVT]VAT
     When 11 : OLDID = num$([F:SFI]SFINUM)
     When 12 : OLDID = [F:TDA]DEP
     When 13 : OLDID = [F:BAN]BAN
     When 14 : OLDID = [F:GAC]ACC       : OLDID2 = [F:GAC]COA
     When 15 : OLDID = [F:FAS]FASNUM    : OLDID2 = [F:FAS]FASCOD  #CHECK IGNORE_LINE (Ligne 15 n'est plus accessible sous les identifiants)
     When 16 : OLDID = num$([F:PFI]PFINUM)
     When 17 : OLDID = [F:BPR]BPRNUM
     When 18 : OLDID = [F:MWC]VLTFCY    : OLDID2 = [F:MWC]VLTCCE
     When 19 : OLDID = [F:ONA]OVENAT
     When 22 : OLDID = [F:AUS]USR
     When 23 : OLDID = [F:FCS]FCSCOD # Issue 84130 - 2013-02-25 by MAE : Ajout des charges achat
    Endcase
   Endif

   If ABREV="TVT"
    Call LEC_TVT_LEG(GCURLEG,IDENT) From CPTLEC
    If fstat=0 :  Gosub INI_SEC : Endif #US223
   Elsif ABREV="TDA"
    Call LEC_TDA(GCURLEG,IDENT) From CPTLEC
    If fstat=0 :  Gosub INI_SEC : Endif #US223
   Elsif ABREV<>"GAC"
    Call LECTURE(ABREV,IDENT,IDENT2) From CONTOBJ
    If fstat=0 :  Gosub INI_SEC : Endif
   Elsif ABREV="GAC"
    If clalev([F:COA])=0 : Local File GCOA [COA] : Endif
    Local Integer OKINI : OKINI = 0
    If IDENT2<>""
     Call LECTURE("COA",IDENT2,"") From CONTOBJ
     If [F:COA]ANATRK = 2
      Call LECTURE(ABREV,IDENT,IDENT2) From CONTOBJ
      If fstat = 0
       Gosub INI_SEC
       OKINI=1
      Endif
     Endif
    Endif
    If !OKINI
     Local Char    MODELE(GLONGCM), PLAN(GLONCOA)(1..10)
     Local Integer NBPLAN, REFTYP(1..10), NPLAN
     Local Char    XIDENT2(20)
     XIDENT2 = IDENT2
     Call SETPLAN3(GSOCIETE,NBPLAN,PLAN,REFTYP) From CPTDIV
     For NPLAN=1 To NBPLAN
      If XIDENT2<>PLAN(NPLAN)
       Call LECTURE("COA",PLAN(NPLAN),"") From CONTOBJ
       If [F:COA]ANATRK = 2
        Call LECTURE(ABREV,IDENT,PLAN(NPLAN)) From CONTOBJ
        If fstat=0
         IDENT2 = PLAN(NPLAN)
         Call LECTURE(ABREV,IDENT,IDENT2) From CONTOBJ
         If fstat = 0
          Gosub INI_SEC
          Break
         Endif
        Endif
       Endif
      Endif
     Next
    Endif
   Endif
   If RELIT
    If ABREV="TVT"
     Call LEC_TVT_LEG(GCURLEG,OLDID) From CPTLEC
    Elsif ABREV="TDA"
     Call LEC_TDA(GCURLEG,OLDID) From CPTLEC
    Else
     Call LECTURE(ABREV,OLDID,OLDID2) From CONTOBJ
    Endif
   Endif
  Endif
 Endif
Endif
Return

    $ERREUR
    #Infbox "$ERREUR"
Resume

Subprog ABREV(CHAINE,ABREV)
    Value    Char CHAINE
    Variable Char ABREV
    Local Integer K1, K2
    ABREV  = ""
    CHAINE = toupper(CHAINE)
    K1 = instr(1,CHAINE,":")
    If !K1 : End : Endif
    K2 = instr(1,CHAINE,"]")
    ABREV = mid$(CHAINE,K1+1,K2-(K1+1))
End

$SETSOC
    If [F:CDE]FLD(TAB)<>""
      Onerrgo ERREUR
      SITE = evalue([F:CDE]FLD(TAB))
      Onerrgo
      If SITE<>""
          ISOC = find(SITE,GSITE(1..GNBSITE))
          If ISOC
              IDENT = GSOCSITE(ISOC)
          Endif
       Endif
    Endif
Return

$INI_SEC
    Onerrgo ERREUR
    Raz INDAXE2
    For XX=1 To GOPTCANA
        If AXE=evalue("[F:"+ABREV+"]DIE("+num$(XX-1)+")") : INDAXE2=XX : Break : Endif
    Next
    If INDAXE2>0 : VALEUR = evalue("[F:"+ABREV+"]"+ZONE+"("+num$(INDAXE2-1)+")") : Endif
    Onerrgo
Return
######################################################################################







