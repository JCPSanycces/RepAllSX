######################################################################################
#### Mantenimiento de la pantalla de Calidades Estadísticas
######################################################################################
$ACTION
    Gosub ACTION From YARYCS
Return
#######################################################################################
#######################################################################################
Subprog C_CODCALIDAD(VALEUR)
    Variable Char    VALEUR()
    Call UNICITE (VALEUR, [M:YCS]CODCALIDAD) From OBJDIV
End
