#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)7.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("XGC",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "SETBOUT"    : Gosub SETBOUT
 When "LIENS"      : Gosub LIENS
 When "CREATION"      : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "ANNULE"      : Gosub ANNULE
 When "APRES_CRE"      : Gosub APRES_CRE
 When "APRES_MOD"      : Gosub APRES_MOD
 When "INICRE_LIG"      : Gosub INICRE_LIG
 When "DEFLIG"      : Gosub DEFLIG
 When "FIN_MOD"    : Gosub FIN_MOD
Endcase
Return

$SETBOUT
#Call VIREBOUT(CHAINE,"CDAH") From GOBJET
CHAINE+="A"

Return

$CREATION
Gosub CREATION From TABLEAUX
Return

$OUVRE
If !clalev([F:XCD])  Local File XFGCD [XCD] Endif
Gosub DECLARE From TABLEAUX
Return

$ANNULE
Gosub ANNULE From TABLEAUX
Return

$APRES_CRE
Gosub LIENS From TABLEAUX
Return

$APRES_MOD
Gosub LIENS From TABLEAUX
Return

$INICRE_LIG
[F:XCD] = [M:XCS]
Return

$DEFLIG
Default Mask [M:XCD]
Default File [F:XCD]

CRIT = 'CPY = "'+ [M:XCS]CPY+'" & BPRNUM = "' + [M:XCS]BPRNUM+
& '" & TIPOFCY = ' + num$([M:XCS]TIPOFCY) +
& ' & NCICLO = ' + num$([M:XCS]NCICLO)

#& ' & EJERCICI = ' + num$([M:XCD]EJERCICI)


FICLIG = "XFGCD" : ABLIG = "XCD"
ZONLIG = "LIN"
Return

$LIENS
Gosub LIENS From TABLEAUX
Return

$MODIF
Gosub MODIF From TABLEAUX
Return

$FIN_MOD

   Local Integer NREG : NREG=0
   Filter [F:XCD] Where CPY=[M:XCS]CPY and BPRNUM=[M:XCS]BPRNUM and TIPOFCY=[M:XCS]TIPOFCY and NCICLO=[M:XCS]NCICLO
    For [F:XCD]
        NREG+=1
    Next
    Filter [F:XCD]
    If !NREG Then
        Infbox ("No hay líneas, se borrará la cabecera")
        Trbegin [F:XCS]
            Delete [F:XCS] Curr
            If !fstat Then
               Commit
               Raz [M:XCS]CPY
               Raz [M:XCS]BPRNUM
               Raz [M:XCS]TIPOFCY
               Raz [M:XCS]NCICLO
               Affzo [M:XCS]0-99
            Else
               Infbox ("No se ha podido eliminar la cabecera. Contacte con el Administrador")
               Rollback
            Endif
    Endif
Return

######################################################################################
