######################################################################################
Subprog AVANT_NBLIG
If [M]BPRNUM(nolign-1)<>""
 Call LECTURE("ARP",[M]BPRNUM(nolign-1),"") From CONTOBJ
Endif
End


######################################################################################

######################################################################################
## Etiqueta aÃ±adida por el supervisor (pantalla XPGCS) 28/09/2015 16:57:32 (TRECE)
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
End

Subprog C_BPRNUM(VALEUR)
Variable Char    VALEUR()
End

Subprog C_TIPOFCY(VALEUR)
Variable Integer VALEUR
Local Integer I , NOL
NOL = nolign-1
For I=0 To [M]NBLIG-1
 If I<>NOL & [M]BPRNUM(I)=[M]BPRNUM(NOL) & [M]TIPOFCY(I)=VALEUR
#  GMESSAGE = mess(24,123,1)-num$(I+1) : # Code dÃ©jÃ  existant en ligne
  mkstat = 2 : Break
 Endif
Next I
End

Subprog IB_NBLIG
End


