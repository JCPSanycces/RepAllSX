#<AdxTL>@(#)0.0.0.0 $Revision$
##v11 - XVT2019/04/03 - adaptación a v11
##VALPES - XVT2019/09/09 - Validación de una única pesada
##TRASIEGOS - XVT2019/12/02 - Validación de trasiegos (camiones)
##
##TIPO DE MOVIMIENTO - XVT2020/07/15 - AÑADIR LOS TIPOS DE MOVIMIENTO A TRSCOD
##SEGÚN LA PLANTA
######################################################################################
### ZIMPPES -- Importación de Pesadas
######################################################################################
$ACTION
#If GUSER="ADMIN" : Infbox "SPEZIP - ADMIN " + ACTION : Endif
    Case ACTION
        When "OUVRE_BATCH"  : Gosub OUVRE_BATCH_ZIMPPES
        When "INIT"         : Gosub INIT_ZIMPPES
        When "EXEC"         : Gosub EXEC_ZIMPPES
        When "TERMINE"      : Gosub TERMINE_ZIMPPES
        When "INIT_DIA"     : Gosub INIT_DIA_ZIMPPES
        When "OK"           : Gosub OK_ZIMPPES
        When "END"          : Gosub END_ZIMPPES
        When "FINREQ"       : Gosub FINREQ
    Endcase
Return
######################################################################################
$OUVRE_BATCH_ZIMPPES
    Gosub OPEN_FILE
Return
######################################################################################
$INIT_ZIMPPES
    Gosub OPEN_FILE
Return
######################################################################################
$OPEN_FILE
    Global Char RUTA(200)

    Global Char LSEP(1)    : LSEP = ';' #v11.n

    If clalev ([F:ADI])=0  : Local File ATABDIV    [ADI]  : Endif    #v11.n
    If clalev ([F:ZPE])=0  : Local File ZPESADAS   [ZPE]  : Endif
    If clalev ([F:XPE])=0  : Local File ZPESADAS   [XPE]  : Endif
    If clalev ([F:PTH])=0  : Local File PRECEIPT   [PTH]  : Endif
    If clalev ([F:ITM])=0  : Local File ITMMASTER  [ITM]  : Endif
    If clalev ([F:ITF])=0  : Local File ITMFACILIT [ITF]  : Endif
    If clalev ([F:PTR])=0  : Local File PURTRS     [PTR]  : Endif

    If clalev ([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif

    If clalev ([F:BPS])=0  : Local File BPSUPPLIER [BPS]  : Endif
    If clalev ([F:YPL])=0  : Local File YPLANTACI  [YPL]  : Endif
    If clalev ([F:YPS])=0  : Local File YPERSEC    [YPS]  : Endif
    If clalev ([F:STC])=0  : Local File STOLOC     [STC]  : Endif
    If clalev ([F:STK])=0  : Local File STOCK      [STK]  : Endif
#    If clalev ([F:YPN])=0  : Local File YPLANTPAR  [YPN]  : Endif
    If clalev ([F:BPR])=0  : Local File BPARTNER   [BPR]  : Endif
    If clalev ([F:SDH])=0  : Local File SDELIVERY  [SDH]  : Endif

    Local Char LFECHA(10)     #XVT2019/12/02.n
    Local Char LHORA(10)      #XVT2020/04/20.n
    LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,7,4)+mid$(LFECHA,4,2)+mid$(LFECHA,1,2) #XVT2019/12/02.n
    LHORA = ctrans(time$,":","")
    Local Char ZTRSCOD : ZTRSCOD = ""  #XVT2020/07/15.n

#V11.O    Read [APX]APX0 = 'REPIMPDEF'
    Read [ADI]CODE=6002;"2"

#V11.O    RUTA = [F:APX]DIRECTORY
#V11.o RUTA = left$(RUTA,len(RUTA)-1)

    RUTA = [F:ADI]A1  #V11.N

    If GSERVEUR
        #----- Ouverture fichier trace et écriture des sélections -----#
        Call ECR_TRACE(" ",0)                From GESECRAN
        Call ECR_TRACE(string$(88,"-"),0)    From GESECRAN
        Call PRTSCR("YLECPROD","YPR","",0,1) From ATRTX3
        Call ECR_TRACE(" ",0)                From GESECRAN
    Endif
Return
######################################################################################
$TERMINE_ZIMPPES
    If !GSERVEUR
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE   From LECFIC
        Return
    Endif
Return
######################################################################################
$INIT_DIA_ZIMPPES
    Raz [M:ZIP]
Return
######################################################################################
$OK_ZIMPPES
    FIN  = 1
    #v11.o Close Local File [APX]
Return
######################################################################################
$END_ZIMPPES
    Raz [M:ZIP]
    FIN = 1
    #v11.o Close Local File [APX]
Return
######################################################################################
######################################################################################
$EXEC_ZIMPPES
    Local     Char    ORI
    Local     Integer ZERROR
    Local     Integer ESTAT
    Local     Char    FICHEROPTH(GDIMFIC)
    Local     Char    ZPESADA
    Local     Integer EXISTE      : EXISTE = 0
    Local     Integer ZNUMF       : ZNUMF = 0
    Local     Integer ZINVEN      : ZINVEN = 0
    Local     Char    ZTRANS      : Raz ZTRANS
    Local     Char    NUM_CAL
    Local     Decimal ZQUANTI1    #v11.n
    Local     Decimal ZQUANTI2
    Local     Char    ZLOC        #V11.n
    Local     Char    TEXTO_ERROR(80)
    Local     Integer ZTERROR
    Local     Char    ZEXERCICI
    Local     Integer ZEJERCICIO  #v11.n
    Local     Char    VEPROVEEDOR(20)

    If GSERVEUR
        Onerrgo ERRBATCH
    Else
        Call OUVRE_TRACE("Importación Ficheros PESADAS")  From LECFIC

        #----- Ouverture fichier trace et écriture des sélections -----#
        Call ECR_TRACE(" ",0)                From GESECRAN
        Call ECR_TRACE(string$(88,"-"),0)    From GESECRAN
        Call PRTSCR("ZIMPPES","ZIP","",0,1) From ATRTX3
        Call ECR_TRACE(" ",0)                From GESECRAN
    Endif

    Call TEMPON("E") From GESECRAN

#    FICHEROPTH = RUTA +"PESADAS_"+num$(adxuid(1))+".TXT"  #V11.o
    FICHEROPTH = RUTA +"PESADAS_"+[F:ZPE]NUMPES+ "_" + LFECHA+LHORA + ".TXT"  #V11.N


    ## Comprovaremos que todos los errores esten solucionados.

     #VALPES.bn
     If [M:ZIP]NUMPES<>'' Then
     #  Infbox "Procesando pesada " + [M:ZIP]NUMPES
       Filter [ZPE] Where [ZPE]NUMPES=[M:ZIP]NUMPES and [ZPE]TIMP<>2 and [ZPE]TERROR<>2
&      and [ZPE]TRASIEGOS <> 2       #XVT2019/12/02.n
     Else #VALPES.en

     Filter [ZPE] Where [ZPE]FCY = [M:ZIP]FCY and [ZPE]FECHA <= [M:ZIP]FECHA
&    and [ZPE]TIMP <> 2 and [ZPE]TERROR <> 2
&      and [ZPE]TRASIEGOS <> 2
&      Order By FECHA; NUMPES
     Endif  #VALPES.n


    For [ZPE]
        ZTERROR = 1
        Raz TEXTO_ERROR
        Read [FCY]FCY0 = [M:ZIP]FCY : If fstat Raz [FCY] : Endif
        Read [ITM]ITM0 = [F:ZPE]VARIEDAD : If fstat : Raz [ITM] : ZTERROR = 2 : TEXTO_ERROR += "Articulo Inexistente |" : Endif
        Read [BPS]BPS0 = [F:ZPE]PROV     : If fstat : Raz [BPS] : ZTERROR = 2 : TEXTO_ERROR += "Provedor Inexistente |" : Endif

        If [F:BPS]BPSNUM <> ""
            Read [YPS]YPS1 = [F:ZPE]PROV;[F:FCY]YTIPOFCY;2
            If fstat
                Raz [YPS]
                ZTERROR = 2
                TEXTO_ERROR += "Proveedor no activo en " + mess([F:FCY]YTIPOFCY,1991,1) + " |"
            Endif
        Endif

        Read [ITF]ITF0 = [F:ZPE]VARIEDAD;[M:ZIP]FCY : If fstat : Raz [ITF] : ZTERROR = 2 : TEXTO_ERROR += "Articulo Planta Inexistente |" : Endif

        If [ITF]LOCMGTCOD = 2
            #Read [STC]STC3 = [M:ZIP]FCY;"DEP";[F:ZPE]DEPOSITO
            #Read [STC]STC0 = [M:ZIP]FCY;[F:ZPE]DEPOSITO
            Read [STC]STC0 = [F:ZPE]FCY;[F:ZPE]DEPOSITO
            If fstat Then
               Raz [STC]
               ZTERROR = 2
               TEXTO_ERROR += "Ubicación Inexistente |"
               ZLOC=""                #v11.bn
            Else
               ZLOC=[F:ZPE]DEPOSITO   #v11.en
            Endif
        Endif

        Call XINIEXEVAR([M:ZIP]FCY,[F:ZPE]FECHA,ZEXERCICI) From XCONTROLES

        If [F:ZPE]CATASTRO <> ""

            Read [YPL]YPL0 = [F:ZPE]CATASTRO  #v11.n
            If fstat
                Raz [YPL] : ZTERROR = 2 : TEXTO_ERROR += "Finca Inexistente |"
            Else

                Read [YPL]YPL5 = [F:ZPE]CATASTRO;[F:ZPE]PROV;[F:ITM]TSICOD(2);2   #v11.n
                If fstat

                        Read [YPL]YPL6 = [F:ZPE]CATASTRO;[F:ITM]TSICOD(2);2 #v11.n
                        If fstat : Raz [YPL] : ZTERROR = 2 : TEXTO_ERROR += "Finca - Variedad Incoherente |" : Endif

                Else

                    Read [YPL]YPL6 = [F:ZPE]CATASTRO;[F:ITM]TSICOD(2);2  #v11.n
                    If fstat : Raz [YPL] : ZTERROR = 2 : TEXTO_ERROR += "Finca - Variedad Incoherente |" : Endif
                Endif
            Endif
        Endif

        If ZTERROR = 2

            Update [XPE] Where [XPE]FCY=[M:ZIP]FCY
&            and [XPE]NUMPES=[F:ZPE]NUMPES and [XPE]EJERCICIO = ZEXERCICI  With TERROR = 2, MSGERROR = TEXTO_ERROR

            If fstat
                GOK=0 : Call FSTA("XPE") From GLOCK : Return
            Endif
        Else

            Update [XPE] Where [XPE]FCY=[M:ZIP]FCY
&            and [XPE]NUMPES=[F:ZPE]NUMPES and [XPE]EJERCICIO = ZEXERCICI With MSGERROR = ''


            If fstat
                GOK=0 : Call FSTA("XPE") From GLOCK : Return
            Endif
        Endif
    Next

    Filter [ZPE]



    Openo   FICHEROPTH ,0 Using [ZPTH]

    Read [FCY]FCY0 = [M:ZIP]FCY : If fstat Raz [FCY] : Endif

#v11 generar el fichero de importación de recepción
     If [M:ZIP]NUMPES <> "" Then   #VALPES.bn
      Filter [F:ZPE] Where [F:ZPE]NUMPES=[M:ZIP]NUMPES and [F:ZPE]TIMP<>2 and [F:ZPE]TERROR<>2 and [F:ZPE]TRASIEGOS <> 2 and [F:ZPE]FCY = [M:ZIP]FCY
# MAB.25/09/2019. Añado Planta al filtro
#      Call ECR_TRACE("1-Pesada: " + [M:ZIP]NUMPES + " - Reg Encontrados:" + num$(rowcount([ZPE])) ,1) From GESECRAN
     Else                         #VALPES.en
      Filter [F:ZPE] Where [F:ZPE]FCY = [M:ZIP]FCY and [F:ZPE]FECHA <= [M:ZIP]FECHA and [F:ZPE]TIMP <> 2 and [F:ZPE]TERROR <> 2 and [F:ZPE]TRASIEGOS <> 2 Order By [F:ZPE]FECHA;[F:ZPE]NUMPES
#      Call ECR_TRACE("2 - Reg Encontrados:" + num$(rowcount([ZPE])) ,1) From GESECRAN
     Endif                        #VALPES.n

#     Call ECR_TRACE("Pesada: " + [M:ZIP]NUMPES + " - Reg Encontrados:" + num$(rowcount([ZPE])) ,1) From GESECRAN
     Call ECR_TRACE("Planta:" + [M:ZIP]FCY  ,0) From GESECRAN

     For [ZPE]
            ZQUANTI1 = 0
            ZQUANTI2 = 0

            If [F:ZPE]TIPOFCY=4 Then   ##sólo para Bodega se actualiza la cantidad 1 con el grado
              Call B_UVA_GRADO2CANTIDAD1([F:ZPE]GRADO,[F:ZPE]NETO,ZQUANTI1) From ZGESCALIF
            Elsif [F:ZPE]TIPOFCY=2
               ZQUANTI1 =  func ZGESCALIF.C_HUMEDAD2CANTIDAD1([F:ZPE]ZHUMEDAD, "CER", [F:ZPE]NETO)
            Elsif [F:ZPE]TIPOFCY=7
               ZQUANTI1 =  func ZGESCALIF.FC_RENDIMIENTO2CANTIDAD1([F:ZPE]ZRENDIMIENTO, "FRU",  [F:ZPE]NETO)
               ZQUANTI2 =  func ZGESCALIF.FC_HUMEDAD2CANTIDAD2([F:ZPE]ZHUMEDAD, "FRU", [F:ZPE]NETO , ZQUANTI1)
            Endif

            Read [FCY]FCY0 = [M:ZIP]FCY : If fstat : Raz [FCY] : Endif

            If len([F:ZPE]NUMPES)>=14 Then
               VEPROVEEDOR=[F:ZPE]NUMPES
            Else
              VEPROVEEDOR=ZEXERCICI+"-"+[F:ZPE]NUMPES
            Endif

            #XVT2020/07/15.bn
            Case [F:FCY]YTIPOFCY
              When 2 ZTRSCOD="CER"
              When 3 ZTRSCOD="ALM"
              When 4 ZTRSCOD="BOD"
              When 7 ZTRSCOD="FRU"
              When Default ZTRSCOD=""
            Endcase

            #AÑADIMOS AL WRSEQ EL CAMPO ZTRSCOD
            #XVT2020/07/15.en

            Wrseq "E" + LSEP + [M:ZIP]FCY + LSEP + [F:ZPE]FECHA + LSEP + LSEP + LSEP + [F:ZPE]PROV + LSEP + VEPROVEEDOR +
&            LSEP + ZEXERCICI + LSEP + ZTRSCOD + LSEP +[F:ZPE]INCIDENCIA + chr$(013) Using [ZPTH]

#            Wrseq "L" + LSEP + [F:ZPE]VARIEDAD + LSEP + [F:ITM]STU +
#&            LSEP + num$([F:ZPE]NETO) + LSEP + num$(ZQUANTI1) + LSEP + num$(ZQUANTI2) +
#&            LSEP + [F:ZPE]CALIDAD + LSEP +  "0" + LSEP + num$([F:ZPE]GRADO) +
#&            LSEP + num$([F:ZPE]PH) + LSEP +  "0" + LSEP +  "0"
#&            + LSEP + num$([F:ZPE]BRUTO) + LSEP + num$([F:ZPE]TARA)
#&            + LSEP + [F:ZPE]CATASTRO
#&            +  chr$(013) Using [ZPTH]

#            Wrseq "L" + LSEP + [F:ZPE]VARIEDAD + LSEP + [F:ITM]STU +
#&            LSEP + num$([F:ZPE]NETO) + LSEP + num$(ZQUANTI1) + LSEP + num$(ZQUANTI2) +
#&            LSEP +  "0" + LSEP +  "0" + LSEP +  "0"
#&            + LSEP + num$([F:ZPE]BRUTO) + LSEP + num$([F:ZPE]TARA)
#&            + LSEP + [F:ZPE]CATASTRO + LSEP + [F:ZPE]CALIDAD + LSEP + num$([F:ZPE]GRADO) + LSEP + num$([F:ZPE]PH)
#&            +  chr$(013) Using [ZPTH]

            Wrseq "L" + LSEP + [F:ZPE]VARIEDAD + LSEP + [F:ITM]STU +
&            LSEP + num$([F:ZPE]NETO) + LSEP + num$(ZQUANTI1) + LSEP + num$(ZQUANTI2) +
&            LSEP +  num$([F:ZPE]ZRENDIMIENTO) + LSEP +  num$([F:ZPE]ZHUMEDAD) + LSEP + num$([F:ZPE]ZPESOESPE)
&            + LSEP + num$([F:ZPE]BRUTO) + LSEP + num$([F:ZPE]TARA)
&            + LSEP + [F:ZPE]CATASTRO + LSEP + [F:ZPE]CALIDAD + LSEP + num$([F:ZPE]GRADO) + LSEP + num$([F:ZPE]PH)
&            +  chr$(013) Using [ZPTH]

             If [ITM]LOTMGTCOD =1 : VEPROVEEDOR="" : Endif
             Wrseq "S" + LSEP + [F:ITM]STU + LSEP + num$([F:ZPE]NETO) + LSEP + ZLOC + LSEP + VEPROVEEDOR + chr$(013) Using [ZPTH]

    Next

    Filter [ZPE]
    Openo Using [ZPTH]

    Call IMPSILEN ('ZIMPPES',FICHEROPTH)
#COMPROBAR


    Call TEMPOFF From GESECRAN
Return

#xvt2019/12/02.bn
$EXEC_ZENTREGARECEPCION
    Local     Char    ORI
    Local     Integer ZERROR
    Local     Integer ESTAT
    Local     Char    FICHEROSDH(GDIMFIC)
    Local     Char    ZPESADA
    Local     Integer EXISTE      : EXISTE = 0
    Local     Integer ZNUMF       : ZNUMF = 0
    Local     Integer ZINVEN      : ZINVEN = 0
    Local     Char    ZTRANS      : Raz ZTRANS
    Local     Char    NUM_CAL
    Local     Decimal ZQUANTI1    #v11.n
    Local     Decimal ZQUANTI2
    Local     Char    ZLOC        #V11.n
    Local     Char    TEXTO_ERROR(80)
    Local     Integer ZTERROR
    Local     Char    ZEXERCICI
    Local     Integer ZEJERCICIO  #v11.n
    Local     Char    VEPROVEEDOR(20)
    Local     Decimal QTYACUMLOT

    #AQUI COMPROBAR SI ENTREGA YA CREADA PREVIAMENTE
    Filter [F:SDH] Where ZPESADA=[F:ZPE]NUMPES
    Read [F:SDH] First
    If !fstat Then
    #EXISTE LA ENTREGA PARA ESTA PESADA, NO SE PUEDE CREAR
      Call MESSAGE("Esta pesada ya tiene una entrega asociada: " + [F:SDH]SDHNUM) From GESECRAN
      Return
    Endif
    Filter [F:SDH]

    If GSERVEUR
        Onerrgo ERRBATCH
    Else
        Call OUVRE_TRACE("Importación Ficheros PESADAS")  From LECFIC

        #----- Ouverture fichier trace et écriture des sélections -----#
        Call ECR_TRACE(" ",0)                From GESECRAN
        Call ECR_TRACE(string$(88,"-"),0)    From GESECRAN
        Call PRTSCR("ZIMPPES","ZIP","",0,1) From ATRTX3
        Call ECR_TRACE(" ",0)                From GESECRAN
    Endif

    Call TEMPON("E") From GESECRAN

    ## Comprobaremos que todos los errores esten solucionados.

     If [M:ZIP]NUMPES<>'' and [M:ZIP]TRASIEGOS=2 Then
       Filter [ZPE] Where [ZPE]NUMPES=[M:ZIP]NUMPES and [ZPE]TIMP<>2 and [ZPE]TERROR<>2
&      and [ZPE]TRASIEGOS = 2       #XVT2019/12/02.n
     Endif

     For [ZPE]
        ZTERROR = 1
        Raz TEXTO_ERROR
        Read [FCY]FCY0 = [M:ZIP]FCY : If fstat Raz [FCY] : Endif
        Read [ITM]ITM0 = [F:ZPE]VARIEDAD : If fstat : Raz [ITM] : ZTERROR = 2 : TEXTO_ERROR += "Articulo Inexistente |" : Endif
        Read [BPS]BPS0 = [F:ZPE]PROV     : If fstat : Raz [BPS] : ZTERROR = 2 : TEXTO_ERROR += "Provedor Inexistente |" : Endif

         Read [ITF]ITF0 = [F:ZPE]VARIEDAD;[M:ZIP]FCY : If fstat : Raz [ITF] : ZTERROR = 2 : TEXTO_ERROR += "Articulo Planta Inexistente |" : Endif

        If [ITF]LOCMGTCOD = 2
            Read [STC]STC0 = [F:ZPE]FCY;[F:ZPE]DEPOSITO
            If fstat Then
               Raz [STC]
               ZTERROR = 2
               TEXTO_ERROR += "Ubicación Inexistente |"
               ZLOC=""                #v11.bn
            Else
               ZLOC=[F:ZPE]DEPOSITO   #v11.en
            Endif
        Endif

        Call XINIEXEVAR([M:ZIP]FCY,[F:ZPE]FECHA,ZEXERCICI) From XCONTROLES

        If [F:ZPE]CATASTRO <> ""

            Read [YPL]YPL0 = [F:ZPE]CATASTRO  #v11.n
            If fstat
                Raz [YPL] : ZTERROR = 2 : TEXTO_ERROR += "Finca Inexistente |"
            Else

                Read [YPL]YPL5 = [F:ZPE]CATASTRO;[F:ZPE]PROV;[F:ITM]TSICOD(2);2   #v11.n
                If fstat

                        Read [YPL]YPL6 = [F:ZPE]CATASTRO;[F:ITM]TSICOD(2);2 #v11.n
                        If fstat : Raz [YPL] : ZTERROR = 2 : TEXTO_ERROR += "Finca - Variedad Incoherente |" : Endif

                Else

                    Read [YPL]YPL6 = [F:ZPE]CATASTRO;[F:ITM]TSICOD(2);2  #v11.n
                    If fstat : Raz [YPL] : ZTERROR = 2 : TEXTO_ERROR += "Finca - Variedad Incoherente |" : Endif
                Endif
            Endif
        Endif

        If ZTERROR = 2

            Update [XPE] Where [XPE]FCY=[M:ZIP]FCY
&            and [XPE]NUMPES=[F:ZPE]NUMPES and [XPE]EJERCICIO = ZEXERCICI  With TERROR = 2, MSGERROR = TEXTO_ERROR

            If fstat
                GOK=0 : Call FSTA("XPE") From GLOCK : Return
            Endif
        Else

            Update [XPE] Where [XPE]FCY=[M:ZIP]FCY
&            and [XPE]NUMPES=[F:ZPE]NUMPES and [XPE]EJERCICIO = ZEXERCICI With MSGERROR = ''


            If fstat
                GOK=0 : Call FSTA("XPE") From GLOCK : Return
            Endif
        Endif
    Next

    Filter [ZPE]

    Read [FCY]FCY0 = [M:ZIP]FCY : If fstat Raz [FCY] : Endif

#v11 1º generar el fichero de importación de entrega     #xvt2019/12/02.n
#v11 2º generar el fichero de importación de recepción

     If [M:ZIP]NUMPES <> "" Then
      Filter [ZPE] Where [ZPE]NUMPES=[M:ZIP]NUMPES and [ZPE]TIMP<>2 and [ZPE]TERROR<>2
&     and [ZPE]TRASIEGOS = 2
&     and [ZPE]FCY = [M:ZIP]FCY
     Endif

     Call ECR_TRACE("Planta:" + [M:ZIP]FCY  ,0) From GESECRAN

     For [ZPE]
            ZQUANTI1 = 0
            ZQUANTI2 = 0

    ##1º - CREAR LA ENTREGA VALIDADA
    ##   - BUSCAR LA PLANTA DE VENTA
        Read [F:BPS]BPS0=[F:ZPE]PROV
        Read [F:BPR]BPR0=[F:ZPE]PROV
        Read [F:ITM]ITM0=[F:ZPE]VARIEDAD

        If [F:BPR]BETFCY=2 Then
          Filter [F:STK] Where [F:STK]STOFCY= [F:ZPE]PROV and [F:STK]ITMREF=[F:ZPE]VARIEDAD Order By [F:STK]STOCOU
          For [F:STK]
            QTYACUMLOT+=([F:STK]QTYSTU-[F:STK]CUMALLQTY)
          Next
          Filter [F:STK]
          If QTYACUMLOT < [F:ZPE]NETO Then
            Call MESSAGE("No hay stock disponible en la planta de origen para validar esta pesada.") From GESECRAN
            Filter [F:ZPE]
            Call TEMPOFF From GESECRAN
            Return
          Endif

          ##ES INTERPLANTA, HAY QUE GENERAR ENTREGA Y RECEPCIÓN POSTERIOR
#            FICHEROSDH = RUTA +"PESADAS_E"+num$(adxuid(1))+".TXT"  #V11.N
            FICHEROSDH = RUTA +"PESADASE_"+[F:ZPE]NUMPES+".TXT"  #V11.N

            adxirs = chr$(13)+chr$(10)
            Openo   FICHEROSDH ,0 Using [ZSDH]

            Wrseq "H" + LSEP + [F:BPS]BPSINV + LSEP + [ZPE]PROV + LSEP + LSEP + "SDH" + LSEP + [ZPE]FCY +
&           LSEP + [ZPE]FCY + LSEP + "EUR" + LSEP + LFECHA + LSEP + LFECHA + LSEP + "2;;" + [F:ZPE]NUMPES + ";;;;"
&           Using [ZSDH]

            Wrseq "L;;0;" + [ZPE]VARIEDAD + LSEP + [F:ITM]ITMDES1 + LSEP + [F:ITM]STU + LSEP +
&           num$([ZPE]NETO) + LSEP + LSEP  Using  [ZSDH]

            #TRAS LA CABECERA Y LÍNEA, SE BUSCA EL STOCK EN ORDEN FIFO HASTA COMPLETAR EL NETO DE LA PESADA,
            #BUSCANDO EN LA PLANTA ORIGEN.
            QTYACUMLOT = 0
            Filter [F:STK] Where [F:STK]STOFCY= [F:ZPE]PROV and [F:STK]ITMREF=[F:ZPE]VARIEDAD Order By [F:STK]STOCOU
            For [F:STK]
              If  [F:ZPE]NETO - QTYACUMLOT >= ([F:STK]QTYSTU-[F:STK]CUMALLQTY) Then
                QTYLINEA=([F:STK]QTYSTU-[F:STK]CUMALLQTY)
              Else
                QTYLINEA=[F:ZPE]NETO - QTYACUMLOT
              Endif
              QTYACUMLOT+=QTYLINEA
              Wrseq "S;A;KG;-" + num$(QTYLINEA) + LSEP + [F:STK]LOC + LSEP + [F:STK]LOT + LSEP Using [ZSDH]
              If QTYACUMLOT >= [F:ZPE]NETO Then
                Break
              Endif
            Next
            Filter [F:STK]

            Openo Using [ZSDH]
            Call IMPSILEN ('ZSDHTRASIE',FICHEROSDH)

            #AQUI COMPROBAR SI ENTREGA SE HA CREADO CORRECTAMENTE
            Filter [F:SDH] Where ZPESADA=[F:ZPE]NUMPES
            Read [F:SDH] First
            If !fstat Then
            #EXISTE LA ENTREGA PARA ESTA PESADA, SE PUEDE CREAR LA RECEPCIÓN
    #         Call MESSAGE("Entrega creada: " + [F:SDH]SDHNUM) From GESECRAN
              Gosub GET_PTH From ZTRTVENLIV
              ##COMPROBAR SI SE HA CREADO LA RECEPCIÓN Y ACTUALIZAR LA PESADA CON EL Nº RECEPCIÓN.
              Filter [F:PTH] Where [F:PTH]BPSNDE = [F:SDH]SDHNUM
              Read [F:PTH] First
              If !fstat Then
    #           Call MESSAGE("Recepción creada: " + [F:PTH]PTHNUM) From GESECRAN
                Update [F:ZPE] Where [F:ZPE]NUMPES = [M:ZPE0]NUMPES With [F:ZPE]PTHNUM = [F:PTH]PTHNUM,
&                    [F:ZPE]TIMP=2
                If !fstat Then
                  [M:ZPE0]PTHNUM=[F:PTH]PTHNUM
                  Affzo [M:ZPE0]PTHNUM
                Else
                  Call MESSAGE("Se ha producido un error al actualizar la pesada. No se puede actualizar el número de recepción " + [F:PTH]PTHNUM ) From GESECRAN
                Endif
              Else
                Update [F:ZPE] Where [F:ZPE]NUMPES = [M:ZPE0]NUMPES With [F:ZPE]TERROR=2,
&                  [F:ZPE]INCIDENCIA="NO SE CREÓ LA RECEPCIÓN. CONTACTE CON SOPORTE"
              Endif
              Filter [F:PTH]
            Else
                Update [F:ZPE] Where [F:ZPE]NUMPES = [M:ZPE0]NUMPES With [F:ZPE]TERROR=2,
&                  [F:ZPE]INCIDENCIA="NO SE CREÓ LA ENTREGA. CONTACTE CON SOPORTE"
              Call MESSAGE("No se ha podido crear la entrega-recepción para este trasiego") From GESECRAN
            Endif
            Filter [F:SDH]

       Endif  ##IF INTERPLANTA

    Next

    Filter [ZPE]


    Call TEMPOFF From GESECRAN
Return

######################################################################################
$ERRBATCH
    Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
######################################################################################
Subprog GENERAR_CALIDAD(ZNUM_CAL,ZTRANS_PTH,ZTIPDOC_PTH,ZFCY,ZPROV,ZFECHA,ZVARIEDAD,ZNETO,ZGRADO,ZPH)
    Variable    Char     ZNUM_CAL
    Variable    Char     ZTRANS_PTH
    Variable    Char     ZTIPDOC_PTH
    Variable    Char     ZFCY
    Variable    Char     ZPROV
    Variable    Date     ZFECHA
    Variable    Char     ZVARIEDAD
    Variable    Decimal  ZNETO
    Variable    Decimal  ZGRADO
    Variable    Decimal  ZPH

    Local       Char     TIPDOC, SERIEDOC
    Local       Integer  CLASEDOCUM
    Local       Char     GNUM
    Local       Char     ZEXERCICI
    Local       Char     FICHEROYC4(200)
    Local       Char     XCOD1,XCOD2,XCOD3,XPLANTA

    FICHEROYC4 = filpath(RUTA,"ZCALIDAD_"+num$(adxuid(1)),"TXT")

    TIPDOC = ZTIPDOC_PTH
    ##--- Buscaremos el Tipo de Documento ---###
    Call BUSCAR_TIPO_DOCUM("PTH", ZTRANS_PTH, "YC4", TIPDOC) From XCONTROLES

    If TIPDOC = ""
        GOK = 0
        GERR=1
        Call ECR_TRACE(mess(197,1986,1),-1) From GESECRAN
        End
    Endif

    Read [YTD]YTD0=TIPDOC  ###- Aqui tendremos que mirar que tipo documento corresponde
    If fstat
        GOK = 0
        End
    Endif
    SERIEDOC   = [F:YTD]SERIEDOCUM
    CLASEDOCUM = [F:YTD]CLASEDOCUM

    Call XINIEXEVAR(ZFCY,ZFECHA,ZEXERCICI) From XCONTROLES

    ###---- Opción de coger el contador de Documentos de Calidad ----###

    GOK = 1
    Call COGER_CONTADOR(TIPDOC,SERIEDOC,GNUM,ZFCY,ZEXERCICI) From XCONTROLES

    If GNUM = ""
        GOK = 0
        GERR=1
        ERROR=1
        GMESSAGE=mess(64,199,1)
        End
    Endif

    ###-----------

    Read [FCY]FCY0 = ZFCY      : If fstat : Raz [FCY] : Endif
    Read [ITM]ITM0 = ZVARIEDAD : If fstat : Raz [ITM] : Endif

    Openo   FICHEROYC4 ,0 Using [ZYC4]

    Wrseq "H" + LSEP + GNUM + LSEP + num$(GORDENDOC) + LSEP + ZFCY + LSEP + num$([F:FCY]YTIPOFCY) + LSEP + num$(CLASEDOCUM) +
&    LSEP + TIPDOC + LSEP + ZPROV + LSEP + ZFECHA + LSEP + ZEXERCICI + LSEP + [F:ITM]TSICOD(0) + LSEP + [F:ITM]TSICOD(1) +
&    LSEP + [F:ITM]TSICOD(2) + LSEP + ZVARIEDAD + LSEP + num$(ZNETO) + LSEP + [F:ITM]TSICOD(0) + LSEP + [F:ITM]TSICOD(1) +
&    LSEP + [F:ITM]TSICOD(2) + LSEP + num$(1) + LSEP + num$(1) + chr$(013) Using [ZYC4]

    ##---Añadiremos los parametros de Calidad ---###
    I = 1
    XCOD1 = [F:ITM]TSICOD(0)
    XCOD2 = [F:ITM]TSICOD(1)
    XCOD3 = [F:ITM]TSICOD(2)
    XPLANTA = ZFCY
    For NUM = 1 To 8
        For [YFS]YFS1 Where CODI1=XCOD1 and CODI2=XCOD2 and CODI3=XCOD3 and FCY = XPLANTA and TACTIU=2
           I = 0
           If I = 0 : Break : Endif
        Next
        If I = 0
            Break
        Endif
        Case NUM
            When 1
               XCOD1 = [F:ITM]TSICOD(0)
               XCOD2 = [F:ITM]TSICOD(1)
               XCOD3 = [F:ITM]TSICOD(2)
               XPLANTA =""
            When 2
               XCOD1 = [F:ITM]TSICOD(0)
               XCOD2 = [F:ITM]TSICOD(1)
               XCOD3 = ""
               XPLANTA = ZFCY
            When 3
               XCOD1 = [F:ITM]TSICOD(0)
               XCOD2 = [F:ITM]TSICOD(1)
               XCOD3 = ""
               XPLANTA =""
            When 4
               XCOD1 = [F:ITM]TSICOD(0)
               XCOD2 = ""
               XCOD3 = ""
               XPLANTA = ZFCY
            When 5
               XCOD1 = [F:ITM]TSICOD(0)
               XCOD2 = ""
               XCOD3 = ""
               XPLANTA =""
            When 6
               XCOD1 = [F:ITM]TSICOD(0)
               XCOD2 = ""
               XCOD3 = [F:ITM]TSICOD(2)
               XPLANTA = ZFCY
            When 7
               XCOD1 = [F:ITM]TSICOD(0)
               XCOD2 = ""
               XCOD3 = [F:ITM]TSICOD(2)
               XPLANTA =""
        Endcase
    Next

    #Recuperamos las calificaciones segun las familias del producto
    For [YFS]YFS1 Where CODI1=XCOD1 and CODI2=XCOD2 and CODI3=XCOD3 and FCY=XPLANTA and TACTIU=2

        Read [YCF]YCF0=[F:YFS]CODCALIFIC
        If fstat=0 and ([F:YCF]CLACALIFI<>2) Then

            If [F:YFS]CODCALIFIC = "B001"  ### GRADOS
                Wrseq "D" + LSEP + [F:YFS]CODCALIFIC + LSEP + num$(ZGRADO) + chr$(013) Using [ZYC4]
            Elsif [F:YFS]CODCALIFIC = "B002"  ### PH
                Wrseq "D" + LSEP + [F:YFS]CODCALIFIC + LSEP + num$(ZPH) + chr$(013) Using [ZYC4]
            Elsif [F:YFS]CODCALIFIC = "B003"  ### NETOS
                Wrseq "D" + LSEP + [F:YFS]CODCALIFIC + LSEP + num$(ZNETO) + chr$(013) Using [ZYC4]
            Elsif [F:YFS]CODCALIFIC = "F001"  ### RENDIMIENTO PEPITA
                Wrseq "D" + LSEP + [F:YFS]CODCALIFIC + LSEP + num$(ZGRADO) + chr$(013) Using [ZYC4]
            Elsif [F:YFS]CODCALIFIC = "F002"  ### HUMEDAD
                Wrseq "D" + LSEP + [F:YFS]CODCALIFIC + LSEP + num$(ZPH) + chr$(013) Using [ZYC4]
            Elsif [F:YFS]CODCALIFIC = "F003"  ### PEPITA
                Wrseq "D" + LSEP + [F:YFS]CODCALIFIC + LSEP + num$(ZPH) + chr$(013) Using [ZYC4]
            Else
                Wrseq "D" + LSEP + [F:YFS]CODCALIFIC + LSEP + num$(0) + chr$(013) Using [ZYC4]
            Endif
        Endif
    Next


    Openo Using [ZYC4]

    Call IMPSILEN ('ZYC40',FICHEROYC4)

    ### Comprovación que el documento de Calidad, se ha generado correctamente.
    Read [YC1]YC10 = GNUM;GORDENDOC
    If fstat
        Raz [YC1]
        ZNUM_CAL = ""
    Else
        ZNUM_CAL = GNUM
    Endif
    ### -------------------

End
######################################################################################
## Funcion de llamada a un modelo de import / export
######################################################################################
Subprog IMPSILEN (MODELE,NOMFICH)
    Value     Char     MODELE
    Value     Char     NOMFICH

    If !clalev([F:AOE])   : Local File AOBJEXT    [AOE]  : Endif
    If !clalev([F:AOD])   : Local File AOBJEXTD   [AOD]  : Endif
    If !clalev([F:ZAOB])  : Local File AOBJET     [ZAOB] : Endif
    If !clalev([F:ADW])   : Local File ADOVAL     [ADW]  : Endif
    If !clalev([F:ZATY])  : Local File ATYPE      [ZATY] : Endif
    If !clalev([F:ZAMK])  : Local File AMSK       [ZAMK] : Endif
    If !clalev([F:ZAMZ])  : Local File AMSKZON    [ZAMZ] : Endif
    If !clalev([F:ZATB])  : Local File ATABLE     [ZATB] : Endif
    If !clalev([F:ZATZ])  : Local File ATABZON    [ZATZ] : Endif
    If !clalev([F:ZATI])  : Local File ATABIND    [ZATI] : Endif
    If !clalev([F:ZAFC])  : Local File AFONCTION  [ZAFC] : Endif
#    If !clalev([F:APX])   : Local File APARIMPEXP [APX]  : Endif
    If !clalev([M:AOE0])  : Local Mask AOE0       [AOE0] : Endif
    If clalev ([F:ADI])=0  : Local File ATABDIV    [ADI]  : Endif    #v11.n
    If !clalev([M:AOE1])  : Local Mask AOE1       [AOE1] : Endif
    If !clalev([M:AOE2])  : Local Mask AOE2       [AOE2] : Endif
    If !clalev([M:IEX])   : Local Mask IMPTEST    [IEX]  : Endif
    If !clalev([M:DIA])   : Local Mask IMPENCH    [DIA]  : Endif
    If clalev([M:IMP2])=0 : Local Mask IMPOBJ2    [IMP2] : Endif
    Local Integer STAT : STAT = 0
    Local Char FICHIER(200) : FICHIER = filpath("BQR",NOMFICH,"")
    Local Char MESSAGE(100)

    Call IMPORTSIL(MODELE,FICHIER) From GIMPOBJ
    If GERRTRACE <> 0
        GYNUM=0
    Endif
End
######################################################################################
######################################################################################
$FINREQ
    If [F:ABR]TACHE = "ZIMPPES"
        If OKRQT <> 1 : OKRQT = 1 : Endif
    Endif
Return
######################################################################################
Subprog AM_FCY(VALEUR)
    Variable Char    VALEUR()

    Read [FCY]FCY0 = VALEUR
    If fstat : Raz [FCY] : Endif

    [M]TIPOFCY = [F:FCY]YTIPOFCY
    Affzo [M]TIPOFCY
End
######################################################################################
######################################################################################
Subprog BUSCAR_TIPO_DOCUM_T(EOBJETO, ETRANSAC, EOBJETOD, TIPDOC, TRANSAC)
    Value     Char     EOBJETO
    Value     Char     ETRANSAC
    Value     Char     EOBJETOD
    Variable  Char     TIPDOC()
    Variable  Char     TRANSAC
    Local     Char     ETIPODOCUM(4)
    Local     Char     TIPDOC_PARAM(4)

    TIPDOC_PARAM=TIPDOC
    TIPDOC=""
    #ETIPODOCUM=""
    If clalev([F:YRE])=0 : Local File YRELDOC    [YRE] : Endif

    For [YRE]YRE0 Where OBJETO = EOBJETO  & TIPDOC = TIPDOC_PARAM & OBJETO_D = EOBJETOD
        TIPDOC = [F:YRE]TIPDOC_D
        TRANSAC = [F:YRE]TRANSAC_D
    Next

End
######################################################################################

