$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog AV_ZBPRINV(VALEUR)
Variable Char    VALEUR()
    If !clalev ([PYD]) : Local File PAYMENTD [PYD]  : Endif
    Read [F:PYD]PYD0(1)=[M:FRM1]NUM(nolign-1)
    If !fstat Then
        VALEUR=[F:PYD]BPRINV
    Endif
End


