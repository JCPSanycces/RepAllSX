######################################################################################
######################################################################################
### Funcion de calculo del Digito de Control del EAN 128                           ###
######################################################################################
Subprog CALCULO_DC (EAN,DIGITO)
    Value Char EAN
    Variable Char DIGITO
    Local Char VALOR
    Local Integer NUMERO,I,NUM,A,TOTAL

    NUM = len(EAN)
    NUMERO = 0
    TOTAL = 0
    A= 3
    For I = 1 To NUM+1
        If A =3
            A=1
        Else
            A=3
        Endif

        VALOR = mid$(EAN,I,1)
        NUMERO = NUMERO + (val(VALOR) * A)

    Next
    TOTAL = val(left$(num$(NUMERO),1))
    I =0
    I = mod(NUMERO,10)
    If I >0
        TOTAL = (TOTAL +1) * 10
    Else
        TOTAL = NUMERO
    Endif

    DIGITO = num$(TOTAL - NUMERO)
End
######################################################################################
# Calcula el caracter de control del EAN 8/13/14/SSCC   05/11 - ASV / JGM - 18/08/2011
######################################################################################
Subprog CALCUL_DC_EAN(CODIEAN,DIGITO)
    Value Char CODIEAN
    Variable Char DIGITO
    Local Integer J , SS , CONT
    If (len(CODIEAN) = 7 or len(CODIEAN) = 12 or len(CODIEAN) = 13 or len(CODIEAN) = 17)
        SS = 1
        For J = len(CODIEAN) To 1 Step -1
            If SS = 1 Then SS = 3 Else SS = 1 Endif
            CONT = CONT + (val(mid$(CODIEAN, J, 1)) * SS)
        Next J
        CONT = mod(CONT,10)
        CONT = 10 - CONT
        If CONT = 10 Then CONT = 0 Endif
        DIGITO = num$(CONT)
    Else
        DIGITO = ""
    Endif
End
######################################################################################
#Si volem accedir amb el tipo de document, utilitzar el procediment: BUSCAR_TIPO_DOCUM2 de YARYRE
######################################################################################
Subprog BUSCAR_TIPO_DOCUM(EOBJETO, ETRANSAC, EOBJETOD, TIPDOC)
    Value     Char     EOBJETO
    Value     Char     ETRANSAC
    Value     Char     EOBJETOD
    Variable  Char     TIPDOC()
    Local     Char     TIPDOC_PARAM(5)

    TIPDOC_PARAM=TIPDOC
    TIPDOC=""
    #ETIPODOCUM=""
    If clalev([F:YRE])=0 : Local File YRELDOC    [YRE] : Endif

#Ramon 26/02/2009
    For [YRE]YRE0 Where OBJETO = EOBJETO & TRANSAC = ETRANSAC & TIPDOC = TIPDOC_PARAM & OBJETO_D = EOBJETOD
        TIPDOC = [F:YRE]TIPDOC_D
    Next
    If TIPDOC = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO & TRANSAC = ETRANSAC  & OBJETO_D = EOBJETOD
            TIPDOC = [F:YRE]TIPDOC_D
        Next
    Endif
    If TIPDOC = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO  & TIPDOC = TIPDOC_PARAM & OBJETO_D = EOBJETOD
            TIPDOC = [F:YRE]TIPDOC_D
        Next
    Endif
    If TIPDOC = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO  & OBJETO_D = EOBJETOD
            TIPDOC = [F:YRE]TIPDOC_D
        Next
    Endif
End
