######################################################################################
### Función de buscar el campo de Assignación de Lote            JGM -- 22/05/2009 ###
######################################################################################
Subprog BUSCAR_CAMPO_LOTE(XOPC,XCAMPO)
    Value       Integer    XOPC
    Variable    Char       XCAMPO

    Case XOPC
        When 0,1  ## Nº Documento Pesadas
            XCAMPO = "[M:YCI0]NUMDOC"
        When 2    ## Referencia Cabecera
            XCAMPO = "[M:YCI0]REFER"
        When 3    ## Referencia Linieas
            XCAMPO = "[M:YCI1]REFERL(I)"
        When 4    ## Nº Documento Pedido
            XCAMPO = "[M:YCI1]POHNUM(I)"
        When 5    ## Ejercicio
            XCAMPO = "[M:YCI0]EXERCICI"
        When Default
            XCAMPO = ""
    Endcase
End
######################################################################################
Subprog BUSCAR_CAMPO_LOTE_TABLA(XOPC,XCAMPO)
    Value       Integer    XOPC
    Variable    Char       XCAMPO

    Case XOPC
        When 0,1  ## Nº Documento Pesadas
            XCAMPO = "[F:YCI]NUMDOC"
        When 2    ## Referencia Cabecera
            XCAMPO = "[F:YCI]REFER"
        When 3    ## Referencia Linieas
            XCAMPO = "[F:YLI]REFERL"
        When 4    ## Nº Documento Pedido
            XCAMPO = "[F:YLI]POHNUM"
        When 5    ## Ejercicio
            XCAMPO = "[F:YCI]EXERCICI"
        When Default
            XCAMPO = ""
    Endcase
End
######################################################################################
Subprog BUSCAR_MODELO_YRELDOC(EOBJETO, ETRANSAC, ETIPDOC, EOBJETOD, MODELO)
    Value Char EOBJETO
    Value Char ETRANSAC
    Value Char ETIPDOC
    Value Char EOBJETOD
    Variable Char MODELO()

    If clalev([F:YRE])=0 : Local File YRELDOC    [YRE] : Endif
    MODELO=""
    Filter [YRE]

    ##--- Buscaremos el Tipo de Documento ---###
    For [YRE]YRE0 Where OBJETO = EOBJETO & TRANSAC = ETRANSAC & TIPDOC = ETIPDOC & OBJETO_D = EOBJETOD
        MODELO = [F:YRE]MODELOIMP
    Next

    If MODELO = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO & TRANSAC = ETRANSAC & TIPDOC = "" & OBJETO_D = EOBJETOD
            MODELO = [F:YRE]MODELOIMP
        Next
    Endif

    If MODELO = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO  & TRANSAC = "" & TIPDOC = ETIPDOC & OBJETO_D = EOBJETOD
            MODELO = [F:YRE]MODELOIMP
        Next
    Endif

    If MODELO = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO & TRANSAC = "" & TIPDOC = "" & OBJETO_D = EOBJETOD
            MODELO = [F:YRE]MODELOIMP
        Next
    Endif
End
######################################################################################
######################################################################################
Subprog YREPORTPAR (NOMREPORT, NOMPARAM, VALORPARAM, TBPAR, TBVAL)

    Value    Char NOMREPORT()
    Value    Char NOMPARAM()
    Value    Char VALORPARAM()
    Variable Char TBPAR()(1..50)
    Variable Char TBVAL()(1..50)

    Local    Shortint I
    Local    Char MISSATGE(200)

    If clalev([F:ARD])<=0 : Local File AREPORTD [ARD] : Endif  ## fichero definicion parametros informes


    ##--- Busqueda del indice del parametro "NOMPARAM" dentro del informe ---###
    Filter [ARD] Where RPTCOD = NOMREPORT and toupper(PARCOD) = toupper(NOMPARAM)
    Read [ARD] First
    If fstat <> 0
      MISSATGE = "El parámetro '" + NOMPARAM + "' no esta definido. No se asignará automáticamente. "
      MISSATGE += " El report volverá pedir el dato manualmente."
      Infbox MISSATGE
    Else
       I=[ARD]PARNUM
       TBPAR(I) = toupper([ARD]PARCOD)
       TBVAL(I)= VALORPARAM
    Endif
    Filter [ARD]

End
######################################################################################
######################################################################################
Subprog BUSCAR_TRANSD_YRELDOC(EOBJETO, ETRANSAC, EOBJETOD, TIPDOC_PARAM, ZTIPOFAC, TRANSD)
    Value     Char     EOBJETO
    Value     Char     ETRANSAC
    Value     Char     EOBJETOD
    Value     Char     TIPDOC_PARAM
    Value     Integer  ZTIPOFAC
    Variable  Char     TRANSD()
    Local     Char     TIPDOC

    Local     Char     XEOBJETO
    Local     Char     XETRANSAC
    Local     Char     XEOBJETOD

    TRANSD=""
    TIPDOC = TIPDOC_PARAM
    If clalev([F:YRE])=0 : Local File YRELDOC    [YRE] : Endif
    If clalev([F:SLT])=0 : Local File SALTRS     [SLT] : Endif

    Filter [YRE]

    For [YRE]YRE0 Where OBJETO = XEOBJETO & TRANSAC = XETRANSAC & TIPDOC = TIPDOC & OBJETO_D = XEOBJETOD
        TRANSD= [F:YRE]TRANSAC_D
        TIPDOC_PARAM = [F:YRE]TIPDOC_D
        If XEOBJETOD = 'SIH'
            Read [SLT]SLT0 =5;TRANSD
            If fstat
                Raz [SLT]
            Else
                If ZTIPOFAC = 5 and [F:SLT]INVTYP >=3
                    Break
                Elsif ZTIPOFAC <> 5 and [F:SLT]INVTYP <> 3
                    Break
                Endif
            Endif
        Endif
    Next
    If TRANSD = ""
        Filter [YRE]
        For [YRE]YRE0 Where OBJETO = XEOBJETO & TRANSAC = XETRANSAC  & OBJETO_D = XEOBJETOD
            TRANSD= [F:YRE]TRANSAC_D
            TIPDOC_PARAM = [F:YRE]TIPDOC_D
           If XEOBJETOD = 'SIH'
                Read [SLT]SLT0 =5;TRANSD
                If fstat
                    Raz [SLT]
                Else
                    If ZTIPOFAC = 5 and [F:SLT]INVTYP >=3
                        Break
                    Elsif ZTIPOFAC <> 5 and [F:SLT]INVTYP <> 3
                        Break
                    Endif
                Endif
            Endif
        Next
    Endif
    If TRANSD = ""
        Filter [YRE]
        For [YRE] Where OBJETO = XEOBJETO and TIPDOC = TIPDOC and OBJETO_D = XEOBJETOD
            TRANSD= [F:YRE]TRANSAC_D
            TIPDOC_PARAM = [F:YRE]TIPDOC_D
           If XEOBJETOD = 'SIH'
                Read [SLT]SLT0 =5;TRANSD
                If fstat
                    Raz [SLT]
                Else
                    If ZTIPOFAC = 5 and [F:SLT]INVTYP >=3
                        Break
                    Elsif ZTIPOFAC <> 5 and [F:SLT]INVTYP <> 3
                        Break
                    Endif
                Endif
            Endif
        Next
    Endif
    If TRANSD = ""
        Filter [YRE]
        For [YRE]YRE0 Where OBJETO = XEOBJETO  & OBJETO_D = XEOBJETOD
            TRANSD= [F:YRE]TRANSAC_D
            TIPDOC_PARAM = [F:YRE]TIPDOC_D
           If XEOBJETOD = 'SIH'
                Read [SLT]SLT0 =5;TRANSD
                If fstat
                    Raz [SLT]
                Else
                    If ZTIPOFAC = 5 and [F:SLT]INVTYP >=3
                        Break
                    Elsif ZTIPOFAC <> 5 and [F:SLT]INVTYP <> 3
                        Break
                    Endif
                Endif
            Endif
        Next
    Endif
End
######################################################################################
######################################################################################
Subprog BUSCAR_TIPO_DOCUM_TRANS(EOBJETO, ETRANSAC, EOBJETOD, ETRANSD, TIPDOC)
    Value Char EOBJETO
    Value Char ETRANSAC
    Value Char EOBJETOD
    Value Char ETRANSD
    Variable Char TIPDOC()
    Local Char TIPDOC_PARAM(5)

    TIPDOC_PARAM=TIPDOC
    TIPDOC=""
    If clalev([F:YRE])=0 : Local File YRELDOC    [YRE] : Endif

    For [YRE]YRE0 Where OBJETO = EOBJETO & TRANSAC = ETRANSAC & TIPDOC = TIPDOC_PARAM & OBJETO_D = EOBJETOD and TRANSAC_D = ETRANSD
        TIPDOC = [F:YRE]TIPDOC_D
    Next
    If TIPDOC = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO & TRANSAC = ETRANSAC  & OBJETO_D = EOBJETOD and TRANSAC_D = ETRANSD
            TIPDOC = [F:YRE]TIPDOC_D
        Next
    Endif
    If TIPDOC = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO  & TIPDOC = TIPDOC_PARAM & OBJETO_D = EOBJETOD and TRANSAC_D = ETRANSD
            TIPDOC = [F:YRE]TIPDOC_D
        Next
    Endif
    If TIPDOC = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO  & OBJETO_D = EOBJETOD and TRANSAC_D = ETRANSD
            TIPDOC = [F:YRE]TIPDOC_D
        Next
    Endif
End
######################################################################################
######################################################################################
###########################################################################################
$TARIF_COMIS

    ###--- Procès de busqueda si tenim activades les comisions per trams de preu

    If clalev([F:PRS])<=0 : Local File PRICSTRUCT  [PRS] : Endif  ## Estructura de Tarifas
    Local Integer I,Z
    I=0
    Z=0

    For I=0 To 8
        If [F:PRS]YTCLASE(I) = 2 and [F:PRS]YTIPOCAL(I) = 2
            Z +=1
        Endif
    Next

    If Z=0 : Return : Endif
    ###-------------------------------------------------------------

    Case GABREV
        When "SOH"
            Call TARIFA_PRECIOS([M:SOH0]ORDDAT,[M:SOH4]YPREU(NOL),[M:SOH1]REP,
&            [M:SOH0]BPCORD,[M:SOH4]ITMREF(NOL),NOL)

        When "SDH"
            Call TARIFA_PRECIOS([M:SDH1]SHIDAT,[M:SDH1]GROPRI(NOL),[M:SDH2]REP,
&            [M:SDH0]BPCORD,[M:SDH1]ITMREF(NOL),NOL)

        When "SIH"
            Call TARIFA_PRECIOS([M:SIH0]INVDAT,[M:SIH4]GROPRI(NOL),[M:SIH1]REP,
&            [M:SIH0]BPCINV,[M:SIH4]ITMREF(NOL),NOL)
    Endcase
Return
######################################################################################
######################################################################################
Subprog TARIFA_PRECIOS(XFECHA,XPREU,XREP,XCLI,XITM,XNOL)
    Value    Date       XFECHA
    Value    Decimal    XPREU
    Value    Char       XREP
    Value    Char       XCLI
    Value    Char       XITM
    Value    Shortint   XNOL

    ##----BUSQUEDA DE TARIFA ESPECIAL PARA ARAGONESA
    ##--- Variables necesarias para la busqueda de tarifas
    Local     Decimal  MONTANT   (0..10), MNTDES
    Local     Shortint MOTIF     (0..10), PRIORITE (0..10)
    Local     Char     PLI       (GLONSPC) (0..10)
    Local     Char     PLICRD    (GLONVCR) (0..10)
    Local     Integer  PLILIN              (0..10)
    Local     Char     FOCITMREF (GLONITM)
    Local     Char     FOCUOM    (GLONUOM)
    Local     Decimal  FOCQTY
    Local     Shortint FOCMOTIF
    Local     Date     PLISTRDAT, PLIENDDAT, DATREF
    Local     Libelle  INTERDIT,  ERR
    Local     Char     VAT       (GLONVAT)(3)
    Local     Integer  SPSTAT
    Local     Shortint WPRIREN
    Local     Char     PARAM_T (25) (0..5) : # indice 0 = coef. multiplicateur UV --> US

    Call TARIFCHGT(5) From TRTPRICE

    If clalev([F:SPK])<=0 : Local File SPRICLINK   [SPK] : Endif  ## Búsqueda tarifas venta (link)
    If clalev([F:REP])<=0 : Local File SALESREP    [REP] : Endif  ## Representates
    If clalev([F:PRS])<=0 : Local File PRICSTRUCT  [PRS] : Endif  ## Estructura de Tarifas

    PARAM_T(0) = "1"

    Call LECTURE ("REP",XREP,"") From CONTOBJ
    Call LECTURE ("ITM",XITM,"") From CONTOBJ
    Call LECTURE ("ITS",XITM,"") From CONTOBJ
    Call LECTURE ("BPR",XCLI,"") From CONTOBJ
    Call LECTURE ("BPC",XCLI,"") From CONTOBJ

    #----- Recherche du tarif pour les réceptions directes -----#
    Call TARIFRECH(5, 1, "", XFECHA, XPREU, "PR", 1,
&    GLOCALDEV, 1, VAT, PARAM_T,
&    MONTANT, MOTIF, PRIORITE,
&    PLI, PLICRD, PLILIN,
&    FOCITMREF, FOCQTY, FOCUOM, FOCMOTIF,
&    PLISTRDAT, PLIENDDAT, INTERDIT, ERR) From TRTPRICE

    ###----------------------------------
    I=2
    If MONTANT(I) <> 0   ### ---- Si es un porcentaje
        Assign "[M]DISCRGVAL"+num$(I)+"(XNOL)" With MONTANT(I)
        Assign "[M]DISCRGREN"+num$(I)+"(XNOL)" With MOTIF(I)
    Endif

    If MONTANT(I) = 0 and MONTANT(3) <> 0  ###---- Si es un tanto por kilo
        I = 3
        Assign "[M]DISCRGVAL"+num$(I)+"(XNOL)" With MONTANT(I)
        Assign "[M]DISCRGREN"+num$(I)+"(XNOL)" With MOTIF(I)
    Endif
    ##----------------------------------------------
End

######################################################################################
#--- Devuelve el coeficiente de la unidad de envasado de un artículo
#--- A partir de la unidad indicada
######################################################################################
Funprog COUE(ARTICLE, YUE)
    Value Char ARTICLE
    Value Char YUE
    Local Decimal QTY_COE
    Local Integer YNUC
    Local Integer I

    YNUC= func AFNC.ACTIV('NUC')

    If clalev([F:YITM])=0 : Local File ITMMASTER [YITM] : Endif
        Filter [YITM] Where ITMREF=ARTICLE
        Read [YITM]First
        Filter [YITM]

    For I=0 To YNUC-1
            If [F:YITM]PCU(I)=YUE Then
                QTY_COE=[F:YITM]PCUSTUCOE(I)
                Break
            Else
                QTY_COE=0
            Endif
    Next I

End QTY_COE
###########################################################################################
###########################################################################################
## Funcion de buscar ficheros para modelos de importacion             - JGM - 21/02/2011 ##
###########################################################################################
Subprog BUSCAR_FICHEROS(ZNOUFITXER,LISTEFIC,NBFIC,ZERROR)
    Value     Char    ZNOUFITXER
    Variable  Char    LISTEFIC()(1..1000)
    Variable  Integer ZERROR
    Variable  Integer NBFIC
    Local     Char    REPERT(GDIMFIC),FICHIER(GDIMFIC),FICBAS(GDIMFIC)
    Local     Char    OS(10),MACHINE(30)
    Local     Integer I,ER

    FICHIER = ZNOUFITXER

    Call MACHINE(FICHIER,MACHINE,REPERT) From ORDSYS
    Call GET_OS(MACHINE,OS) From ORDSYS
    I = instr(1,REPERT,"#")
    If I=0
        Call EXISTE(FICHIER,ER) From ORDSYS
        If ER=0
            GBIDC3 = FICHIER : ZERROR = 2 : End
        Endif
        NBFIC = 1 : LISTEFIC(1) = FICHIER
    Else
    If 1=2
        FICHIER = left$(REPERT,I-1)+"*"+right$(REPERT,I+1)
        Call REPERT(FICHIER,REPERT,FICBAS,OS) From SUBEXPOBJ

        FICBAS = '"'+FICBAS+'"'
        Call SYSTEME2(MACHINE,"lsadx"-REPERT-FICBAS,"",NBFIC,LISTEFIC) From ORDSYS
        NBFIC = min(NBFIC,dim(LISTEFIC))
        For I=1 To NBFIC
           Call SETFIC(REPERT,LISTEFIC(I),MACHINE,LISTEFIC(I)) From SUBEXPOBJ
        Next I
    Endif

 FICHIER = left$(REPERT,I-1)+"*"+right$(REPERT,I+1)
 Call REPERT(FICHIER,REPERT,FICBAS,OS) From SUBEXPOBJ
 If MACHINE="#"
  Local File (FICHE(GDIMFIC)) From System '#@cmd /c dir/b'-FICHIER As [FTR_]
  NBFIC = 0
  I = len(REPERT)
  If I=0
   I = 1
  Else
   I += 2
  Endif
  For [FTR_]
   If pat([F:FTR_]FICHE,right$(FICHIER,I))
    If NBFIC>=dim(LISTEFIC)-1 : Break : Endif
    NBFIC += 1
    LISTEFIC(NBFIC) = [FTR_]FICHE
    Call SETFIC(REPERT,LISTEFIC(NBFIC),MACHINE,LISTEFIC(NBFIC)) From SUBEXPOBJ
   Endif
  Next FTR_
 Else
  FICBAS = '"'+FICBAS+'"'
  Call SYSTEME2(MACHINE,"lsadx"-REPERT-FICBAS,"",NBFIC,LISTEFIC) From ORDSYS
  NBFIC = min(NBFIC,dim(LISTEFIC))
  For I=1 To NBFIC
   Call SETFIC(REPERT,LISTEFIC(I),MACHINE,LISTEFIC(I)) From SUBEXPOBJ
  Next I
 Endif

    Endif
End
###########################################################################################
## Función que remplaza un caracter por otro
###########################################################################################
Subprog REMPLAZAR_CAR(TEXTO,CAR1,CAR2)
    Variable    Char    TEXTO
    Value       Char    CAR1
    Value       Char    CAR2
    Local       Integer I
    Local       Char    TEXTO1

    For I=1 To len(TEXTO)
        If mid$(TEXTO,I,1) = CAR1
             TEXTO1 = TEXTO1 + CAR2
         Else
            TEXTO1 = TEXTO1 +  mid$(TEXTO,I,1)
        Endif
    Next

    TEXTO = TEXTO1
End
###########################################################################################
###########################################################################################
# Devuelve el campo importe línea AI para obtener la base y sumarle el IVA,
# (Indicada en la fórmula de la tasa retención), y calcular la retención agraria (REA)
# RPASC - 29/06/2011
# MF: Mejora futura: Obtener la tasa del iva desde la función, permitiendo utilizar un único código de tasa de retención
###########################################################################################
Funprog AMTNOTLIN
    If dim([M]AMTNOTLIN(nolign-1))>0   # Invoices  GFONC1 = "GESPIH"
        End [M]AMTNOTLIN(nolign-1)
    Else
        End [M]LINAMT(nolign-1)        # Orders/Receipts
    Endif
End
###########################################################################################
##SVR 03-11-11. Comprovem si no s'ha de copiar, generar, validar, etc. el document relacionat (qualitat, transport, ...)
###########################################################################################
Funprog GENERAR_DOCUMENT(EOBJETO, ETRANSAC, EOBJETOD, TIPDOC, EACCIO)
    Value     Char     EOBJETO()
    Value     Char     ETRANSAC()
    Value     Char     EOBJETOD()
    Value     Char     TIPDOC()
    Value     Char     EACCIO()    #NO_VALIDAC, COPIAR_NUM, etc.

    If clalev([F:YYRE])=0 : Local File YRELDOC [YYRE] : Endif

    For [YYRE]YRE0 Where MOSTRAR=3 and CAMPO = EACCIO and OBJETO = EOBJETO & TRANSAC = ETRANSAC & TIPDOC = TIPDOC & OBJETO_D = EOBJETOD
        End 0
    Next
    For [YYRE]YRE0 Where MOSTRAR=3 and CAMPO = EACCIO and OBJETO = EOBJETO & TRANSAC = ETRANSAC & TIPDOC = "" & OBJETO_D = EOBJETOD
        End 0
    Next
    For [YYRE]YRE0 Where MOSTRAR=3 and CAMPO = EACCIO and OBJETO = EOBJETO & TRANSAC = "" & TIPDOC = TIPDOC & OBJETO_D = EOBJETOD
        End 0
    Next
    For [YYRE]YRE0 Where MOSTRAR=3 and CAMPO = EACCIO and OBJETO = EOBJETO & TRANSAC = "" & TIPDOC = "" & OBJETO_D = EOBJETOD
        End 0
    Next
End 1
#####################################################################################
## FUNCIONS DE LAS SECCIONES ANALITICAS EN TIPOS DE DOCUMENTO - JGM - 07/08/2012   ##
#####################################################################################
#----------------------------------------------------------------#
# Initialisation tableau axes analytiques des tables de base     #
#              AppelÃ© par l'action RAZCRE                        #
# -------------------------------------------------------------- #
# ParamÃ¨tres Ã  passer au sous-programme :                        #
#   - WCODE    : NumÃ©ro de la table Ã  gÃ©rer (menu local 2230)    #
#   - WSOCIETE : SociÃ©tÃ© ("" = pas de dÃ©clinaison par sociÃ©tÃ©)   #
#   - WABRMSK  : AbrÃ©viation du masque Ã©cran                     #
#   - WBASTAB  : Nom de la variable de bas de tableau            #
#---------------------------------------------------------------#
    Subprog INIT_DIE(WCODE,WSOCIETE,WABRMSK,WBASTAB)
    Value    Integer WCODE
    Value    Char    WSOCIETE
    Value    Char    WABRMSK
    Value    Char    WBASTAB
    #-----
    Gosub TR_INIT_DIE
    #-----
End
#####################################################################################
#----------------------------------------------------------------#
# Chargement tableau axes analytiques des tables de base         #
#               AppelÃ© par l'action LIENS                        #
# ---------------------------------------------------------------#
# ParamÃ¨tres Ã  passer au sous-programme :                        #
#   - WCODE    : NumÃ©ro de la table Ã  gÃ©rer (menu local 2230)    #
#                Pour les catÃ©gories article, client, fournisseur#
#                faire +100 sur article, client, fournisseur     #
#   - WSOCIETE : SociÃ©tÃ© ("" = pas de dÃ©clinaison par sociÃ©tÃ©)   #
#   - WABRMSK  : AbrÃ©viation du masque Ã©cran                     #
#   - WBASTAB  : Nom de la variable de bas de tableau            #
#----------------------------------------------------------------#
Subprog CHARG_DIE(WCODE,WSOCIETE,WABRMSK,WBASTAB)
    Value    Integer WCODE
    Value    Char    WSOCIETE
    Value    Char    WABRMSK
    Value    Char    WBASTAB
    #-----
    Local    Integer J
    #----- Initialisation des codes axe analytique -----#
    Gosub TR_INIT_DIE
    #----- Chargement des sections analytiques -----#
    For [L]I=0 To [F:CDI]NBRDIE-1
      Case WCODE
        When  1 : # Tipo de documentos
          For [L]J=0 To dim([F:YTD]DIE)-1
            If evalue([L]ECRAN+"DIE([L]I)")=[F:YTD]DIE([L]J)
              Assign [L]ECRAN+"CCE([L]I)" With [F:YTD]CCE([L]J)
              Break
            Endif
          Next [L]J
      Endcase
    Next [L]I
    #-----
End
#####################################################################################
#---------------------------------------------------------#
# Traitement de l'initialisation des codes axe analytique #
#---------------------------------------------------------#
$TR_INIT_DIE
    Local    Char    ECRAN(10)
    Local    Char    BATAB(20)
    Local    Integer I, WWCODE
    #-----
    If !clalev([F:CDI])  Local File CADIEDEF [CDI] : Endif
    #-----
    WWCODE = WCODE
    If WWCODE>100 WWCODE-=100 Endif
    #-----
    If WABRMSK=""
      [L]ECRAN="[M]"
    Else
      [L]ECRAN="[M:"+WABRMSK+"]"
    Endif
    If WBASTAB=""
      [L]BATAB=[L]ECRAN+"NBAXE"
    Else
      [L]BATAB=[L]ECRAN+WBASTAB
    Endif
    #-----
    Read [CDI] CDI0=WWCODE
    If fstat  Raz [F:CDI] : Endif
    #-----
    For [L]I=0 To evalue("dim("+[L]ECRAN+"DIE)")-1
      Assign [L]ECRAN+"DIE([L]I)" With ""
      Assign [L]ECRAN+"CCE([L]I)" With ""
    Next [L]I
    #-----
    Assign [L]BATAB With [F:CDI]NBRDIE
    For [L]I=0 To [F:CDI]NBRDIE-1
      Assign [L]ECRAN+"DIE([L]I)" With [F:CDI]DIE([L]I)
    Next [L]I
Return
#####################################################################################
## Rutina para buscar analitica(CCE) en los pickings del VERTICAL - JGM - 21/08/2012#
#####################################################################################
Subprog BUSCAR_CCE(OBJETO,NUMDOC,NUMLIN,NUMSEQ,CCE)
    Value    Char    OBJETO
    Value    Char    NUMDOC
    Value    Integer NUMLIN
    Value    Integer NUMSEQ
    Variable Char    CCE()()

    If clalev([F:CAL])=0 : Local File CPTANALIN  [CAL] : Endif

    Filter [CAL]
    For [CAL] Where ABRFIC = OBJETO and VCRNUM = NUMDOC and VCRLIN= NUMLIN  and VCRSEQ = NUMSEQ

        For I=0 To 19
            CCE(I) = [F:CAL]CCE(I)
        Next
    Next
    Filter [CAL]
End
#####################################################################################
## Buscar tipo documento y devolver planta origen y destino       JGM - 02/04/2013 ##
#####################################################################################
Subprog BUSCAR_TIPO_DOCUM_S(EOBJETO, ETRANSAC, EOBJETOD, TIPDOC, TRANSAC, FCY_O, FCY_D)
    Value       Char    EOBJETO
    Value       Char    ETRANSAC
    Value       Char    EOBJETOD
    Variable    Char    TIPDOC()
    Variable    Char    TRANSAC
    Variable    Char    FCY_O
    Variable    Char    FCY_D
    Local       Char    TIPDOC_PARAM(4)

    TIPDOC_PARAM=TIPDOC
    TIPDOC=""
    FCY_O =""
    FCY_D =""
    If clalev([F:YRE])=0 : Local File YRELDOC    [YRE] : Endif

    For [YRE]YRE0 Where OBJETO = EOBJETO & TRANSAC = ETRANSAC & TIPDOC = TIPDOC_PARAM & OBJETO_D = EOBJETOD
        TIPDOC = [F:YRE]TIPDOC_D
        TRANSAC = [F:YRE]TRANSAC_D
        FCY_O  = [F:YRE]PLANTA
        FCY_D  = [F:YRE]PLANTA_D
    Next
    If TIPDOC = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO & TRANSAC = ETRANSAC  & OBJETO_D = EOBJETOD
            TIPDOC = [F:YRE]TIPDOC_D
            TRANSAC = [F:YRE]TRANSAC_D
            FCY_O  = [F:YRE]PLANTA
            FCY_D  = [F:YRE]PLANTA_D
        Next
    Endif
    If TIPDOC = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO  & TIPDOC = TIPDOC_PARAM & OBJETO_D = EOBJETOD
            TIPDOC = [F:YRE]TIPDOC_D
            TRANSAC = [F:YRE]TRANSAC_D
            FCY_O  = [F:YRE]PLANTA
            FCY_D  = [F:YRE]PLANTA_D
        Next
    Endif
    If TIPDOC = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO  & OBJETO_D = EOBJETOD
            TIPDOC = [F:YRE]TIPDOC_D
            TRANSAC = [F:YRE]TRANSAC_D
            FCY_O  = [F:YRE]PLANTA
            FCY_D  = [F:YRE]PLANTA_D
        Next
    Endif
End
