#<AdxTL>@(#)6.0.0.0 $Revision$
#v11 XVT02/04/2019 Migración v11
###########################################################################################
$ACTION
    Case ACTION
        When "OUVRE"           : Gosub OUVRE
        When "FONCTION"        : Gosub FONCTION
        When Default
    Endcase

#When "MODISSPAR"       : Gosub MODISSPAR    # Trasladada al TRT XTRTSTOSOR
#When "BEFWRISTO"       : Gosub BEFWRISTO    # Trasladada al TRT STKLIB
#When "BEFREWSTO"       : Gosub BEFREWSTO    # Trasladada al TRT STKLIB
#When "BEFWRISTJ"       : Gosub BEFWRISTJ    # Trasladada al TRT STKLIB
#When "RECHTARIF1"      : Gosub RECHTARIF1   # Trasladada al TRT XTRTVENTAR
#When "ALIMSKSOH"       : Gosub ALIMSKSOH    # Trasladada al TRT XTRTVENISOC
#When "RECHTARIF"       : Gosub RECHTARIF    # Trasladada al TRT XTRTVENTAR

Return
###########################################################################################
###########################################################################################
$OUVRE
#Tenemos un punto de entrada activo en GLOBSUP que nos permite crear variables globales
#para toda la connexión de x3
    Global Integer GYCREAR
    Global Integer  GYLIN
    Global Char     GYSPARAM(45)(1..5)
    Global Integer  GYSTIPO(1..5)
    Global Char     GYFILTRO(45)(1..3)
    Global Integer  GYTIPOFCY
    Global Integer  GACCESODOCREL
    Global Integer  LLICENCIAOK
    Global Integer  GYVALMESS

    Global Integer  XGPE
    Global Char  XGPOINT(40)

    #Asignamos la variable d'Adonix GDECPRI (Número de decimales cálculo precio, con el
    #valor del parámetro creado para poder modificar el valor para cada cliente: YDECPRI
    If dim(GYDECPRI)>0 Then : GDECPRI=GYDECPRI : Endif

    GFORREM="6.5"
#    Raz GYCREAR
    Raz GYLIN
    Raz GYSPARAM
    Raz GYSTIPO
    Raz GYFILTRO
    Raz GYTIPOFCY       #Almacenamos el tipo de planta al abrir los programas
    Raz GACCESODOCREL

    Raz XGPE, XGPOINT
Return
###########################################################################################
$FONCTION
#Se activa cada vez que entramos en la función
#    Raz GYCREAR
    Raz GYLIN
    Raz GYSPARAM
    Raz GYSTIPO
    Raz GYFILTRO
    Raz GYTIPOFCY
    If dim(LLICENCIAOK)>0 Then : Raz LLICENCIAOK : Endif

Return

    Gosub CONTROL_LLICENCIA
Return
###########################################################################################
$CONTROL_LLICENCIA
    Raz LLICENCIAOK

    If clalev([F:ACV])=0 : Local File ACTIV  [ACV] : Endif
    If clalev([F:XAFC])=0 : Local File AFONCTION  [XAFC] : Endif

    If clalev([F:AFC])>0 and [F:AFC]CODINT<>"" Then
        Read [F:XAFC]CODINT = [F:AFC]CODINT
    Else
        Read [F:XAFC]CODINT = GFONC1
        If GFONC1="" Then : Raz [F:XAFC] : Endif

    Endif

    If toupper(adxmac(-1)) = "NEWADONIX" or toupper(adxmac(-1)) = "ADONIX08" : Return : Endif


# Control de llicencies ARITMOS (En principi el punt d´entrada ja ha llegit la funció).
    If dim(GYLICPRIAGRO)<0 : Global Integer  GYLICPRIAGRO : GYLICPRIAGRO = 0 : Endif
    If dim(GYLICSECAGRO)<0 : Global Integer  GYLICSECAGRO : GYLICSECAGRO = 0 : Endif
    If dim(GYLICPRICRED)<0 : Global Integer  GYLICPRICRED : GYLICPRICRED = 0 : Endif
    If dim(GYLICSECCRED)<0 : Global Integer  GYLICSECCRED : GYLICSECCRED = 0 : Endif
    If dim(GYLICNOMSERV)<0 : Global Char     GYLICNOMSERV(50) : GYLICNOMSERV = "" : Endif
    If dim(GYLICDATAINI)<0 : Global Date     GYLICDATAINI : GYLICDATAINI = [00/00/00] : Endif
    If dim(GYLICDATAFI)<0  : Global Date     GYLICDATAFI  : GYLICDATAFI  = [00/00/00] : Endif
    If dim(GYLICSW)<0      : Global Integer  GYLICSW      : Endif
    If dim(GYLICMAC)<0     : Global Char     GYLICMAC     : Endif
    Local Char MAC(250)(10)
# Controls dels mòduls AGRO I CREDIT
    If [F:XAFC]MODULE=16 or [F:XAFC]MODULE=17 and GYLICMAC=""
        If GOS(1)="dos"
            System MAC="getmac /fo csv /nh"
            # En principi tendria que tenir el seguent format
            # "00-14-5E-B4-84-43" i que no sigui "Medios fuera de línea" (\Device\.... -->Ok)
            For I=0 To 9
                If mid$(MAC(I),4,1)="-" and mid$(MAC(I),19,1)='"' and mid$(MAC(I),22,1)="\"
                    GYLICMAC  = mid$(MAC(I),2,2)
                    GYLICMAC += mid$(MAC(I),5,2)
                    GYLICMAC += mid$(MAC(I),8,2)
                    GYLICMAC += mid$(MAC(I),11,2)
                    GYLICMAC += mid$(MAC(I),14,2)
                    GYLICMAC += mid$(MAC(I),17,2)
                    Break
                Endif
            Next
        Else
            GYLICMAC=""
        Endif

        Local Char PARAM(30)(1..2)
        Local Mask YDECRYPT [YLA]
        Call LECTU_FITXER From YARYLA
        GYLICDATAINI = [M:YLA]FECHAEXP
        GYLICDATAFI  = [M:YLA]FECHACAD
        GYLICNOMSERV = [M:YLA]NOMSERVER
        For I=0 To NBLIG -1
            If vireblc([M:YLA]MODULO(I),2)="1"
                GYLICPRIAGRO+=[M:YLA]NUMUSER(I)
            Endif
            If vireblc([M:YLA]MODULO(I),2)="2"
                GYLICSECAGRO+=[M:YLA]NUMUSER(I)
            Endif
            If vireblc([M:YLA]MODULO(I),2)="3"
                GYLICPRICRED+=[M:YLA]NUMUSER(I)
            Endif
            If vireblc([M:YLA]MODULO(I),2)="4"
                GYLICSECCRED+=[M:YLA]NUMUSER(I)
            Endif
        Next
        If GYLICMAC<>[M:YLA]MAC and GYLICMAC<>""
            Errbox "ARITMOS. MAC ADDRESS Incorrecta o Licencia Alterada "+ GYLICMAC
            GPE=1
            Return
        Endif
        Close Local Mask [YLA]

        Local Char PARAM(30)(1..2)
        Local Mask YLICENCIA [YLC]
        Gosub DEBUT From YARYLC
        If date$ < GYLICDATAINI or date$ > GYLICDATAFI
            Errbox "ARITMOS : Expiración de licencia"
            GPE=1
            Return
        Endif
        If vireblc(toupper(GYLICNOMSERV),4) <> vireblc(toupper(adxmac(-1)),4)
            Errbox "ARITMOS : Servidor de aplicaciones incorrecto o licencia alterada" + adxmac(-1)
            GPE=1
            Return
        Endif
     # CONTROL d´equivalencia de les llicencies ARITMOS amb les llicencies ADONIX
     # Comprovació del còdi d´activitat YSC (Crèdit)
        Read [ACV]CODACT="YSC"
        If fstat
            Raz [ACV]CODACT
        Endif
        If GYLICPRIAGRO<[M:YLC]MAX1
            Errbox "ARITMOS. Licencia no valida. Licencia: "+num$(GYLICPRIAGRO)+" Maquina: "+num$([M:YLC]MAX1)
            GPE=1
            Return
        Endif
        If GYLICPRICRED<[M:YLC]MAX1 and [F:ACV]FLACT=2
            Errbox "ARITMOS (Cred). Licencia no valida. Licencia: "+num$(GYLICPRICRED)+" Maquina: "+num$([M:YLC]MAX1)
            GPE=1
            Return
        Endif
        If GYLICSECAGRO<[M:YLC]MAX2
            Errbox "ARITMOS. Licencia no valida. Licencia: "+num$(GYLICSECAGRO)+" Maquina: "+num$([M:YLC]MAX2)
            GPE=1
            Return
        Endif
        If GYLICSECCRED<[M:YLC]MAX2 and [F:ACV]FLACT=2
            Errbox "ARITMOS (Cred). Licencia no valida. Licencia: "+num$(GYLICSECCRED)+" Maquina: "+num$([M:YLC]MAX2)
            GPE=1
            Return
        Endif
    # Control de la quantitat d´usuaris concurrents
    # Modul 17 = crèdit
        If [F:XAFC]MODULE=17
            If [M:YLC]CREDIT >= GYLICPRICRED and (adxtyp=1 or adxtyp=9)
                Errbox "ARITMOS (Cred.) Número máximo de sesiones primarias superado. Licencia: "+num$(GYLICPRICRED)+" Maquina: "+num$([M:YLC]CREDIT)
                GPE = 1
                Return
            Endif
            If [M:YLC]CREDIT2 >= GYLICSECCRED and (adxtyp=2 or adxtyp=10)
                Errbox "ARITMOS (Cred.) Número máximo de sesiones secundarias superado. Licencia: "+num$(GYLICSECCRED)+" Maquina: "+num$([M:YLC]CREDIT2)
                GPE=1
                Return
            Endif
        Else
            If  [M:YLC]AGRO >= GYLICPRIAGRO and (adxtyp=1 or adxtyp=9)
                Errbox "ARITMOS : Número máximo de sesiones primarias superado. Licencia: "+num$(GYLICPRIAGRO)+" Maquina: "+num$([M:YLC]AGRO)
                GPE=1
                Return
            Endif
            If  [M:YLC]AGRO2 >= GYLICSECAGRO and (adxtyp=2 or adxtyp=10)
                Errbox "ARITMOS : Número máximo de sesiones secundarias superado. Licencia: "+num$(GYLICSECAGRO)+" Maquina: "+num$([M:YLC]AGRO2)
                GPE=1
                Return
            Endif
        Endif
        Close Local Mask [YLC]
    Endif
    LLICENCIAOK = 1
Return
###########################################################################################
Subprog XCONTPLA(PLANTA,XEXERCICI)
    Variable Char    PLANTA()
    Variable Char    XEXERCICI()

    If clalev([F:YPY])=0 : Local File YPARANY [YPY] : Endif

    If XEXERCICI <> ""
       Read [F:YPY]YPY0=PLANTA;XEXERCICI
       If fstat
          mkstat = 2
          GMESSAGE=mess(7,1986,1)

          End
       Endif
    Endif
End
###########################################################################################
Subprog XINIEXE(XFCY,XFECHA)
    Value       Char    XFCY()
    Value       Date    XFECHA

    If XFCY = "" or XFECHA = [0/0/0] : End : Endif
    If clalev([F:YPY])=0 : Local File YPARANY [YPY] : Endif

    If dim([M]EXERCICI) = 1 Then
        Raz [M]EXERCICI
        Filter [YPY] Where FCY=XFCY and DATAINIEX <= XFECHA and DATAFIEX >=XFECHA and TESTMAESTR = 2
&       and TESTMOVIMI = 2
        Read [YPY] First
        If fstat = 0
            [M]EXERCICI  = [F:YPY]EXERCICI
            If dim([M]ZEXERCICI)=1 Then
               [M]ZEXERCICI = [F:YPY]DESEXERCIC
            Endif
        Else
            mkstat = 2
            GMESSAGE= mess(6,1986,1)
            GERR=1
        Endif
        Filter [YPY]
    Elsif dim([M]YEXERCICI) = 1 Then
        Raz [M]YEXERCICI
        Filter [YPY] Where FCY=XFCY and DATAINIEX <= XFECHA and DATAFIEX >=XFECHA and TESTMAESTR = 2
&       and TESTMOVIMI = 2
        Read [YPY] First
        If fstat = 0
            [M]YEXERCICI  = [F:YPY]EXERCICI
            If dim([M]ZYEXERCICI)=1 Then
                [M]ZYEXERCICI = [F:YPY]DESEXERCIC
            Endif
        Else
            mkstat = 2
            GMESSAGE=mess(6,1986,1)
            GERR=1
        Endif
        Filter [YPY]
    Endif

    If dim(GEXERCICI) = 1 Then
        Raz GEXERCICI
        Filter [YPY] Where FCY=XFCY and DATAINIEX <= XFECHA and DATAFIEX >=XFECHA and TESTMAESTR = 2
&       and TESTMOVIMI = 2
        Read [YPY] First
        If fstat = 0
            GEXERCICI  = [F:YPY]EXERCICI
        Endif
        Filter [YPY]
    Endif
End
###########################################################################################
Subprog XINIEXEMAES(XFCY,XFECHA)
    Value       Char    XFCY()
    Value       Date    XFECHA

    If XFCY = "" or XFECHA = [0/0/0] : End : Endif
    If clalev([F:YPY])=0 : Local File YPARANY [YPY] : Endif

    If dim([M]EXERCICI) = 1 Then
        Raz [M]EXERCICI
        Filter [YPY] Where FCY=XFCY and DATAINIEX <= XFECHA and DATAFIEX >=XFECHA and TESTMAESTR = 2
        Read [YPY] First
        If fstat = 0
            [M]EXERCICI  = [F:YPY]EXERCICI
            If dim([M]ZEXERCICI)=1 Then
               [M]ZEXERCICI = [F:YPY]DESEXERCIC
            Endif
        Else
            mkstat = 2
            GMESSAGE= mess(6,1986,1)
            GERR=1
        Endif
        Filter [YPY]
    Else
        Raz [M]YEXERCICI
        Filter [YPY] Where FCY=XFCY and DATAINIEX <= XFECHA and DATAFIEX >=XFECHA and TESTMAESTR = 2
        Read [YPY] First
        If fstat = 0
            [M]YEXERCICI  = [F:YPY]EXERCICI
            If dim([M]ZYEXERCICI)=1 Then
                [M]ZYEXERCICI = [F:YPY]DESEXERCIC
            Endif
        Else
            mkstat = 2
            GMESSAGE=mess(6,1986,1)
            GERR=1
        Endif
        Filter [YPY]
    Endif
End
###########################################################################################
Subprog XINIEXEVAR(XFCY,XFECHA,EXERCICI)
    Value       Char    XFCY()
    Value       Date    XFECHA
    Variable    Char    EXERCICI

    If XFCY = "" or XFECHA = [0/0/0] : End : Endif
    #v11.o If clalev([F:YPY])=0 : Local File YPARANY [YPY] : Endif
    If clalev([F:YPY])=0 : Local File ZCAMPANYA [YPY] : Endif   #v11.n
#v11.bn
    If clalev([F:ZFCY])=0 : Local File FACILITY [ZFCY] : Endif

    Read [F:ZFCY]FCY0=XFCY
    If fstat
      mkstat = 2
      GMESSAGE=mess(6,1986,1)
      GERR=1
      End
    Endif
#v11.en
    Raz EXERCICI
#V11.o    Filter [YPY] Where FCY=XFCY and DATAINIEX <= XFECHA and DATAFIEX >=XFECHA and TESTMAESTR = 2
#V11.o&    and TESTMOVIMI = 2

    Filter [YPY] Where INIDAT <= XFECHA and ENDDAT >=XFECHA and TIPOFCY=[F:ZFCY]YTIPOFCY   #v11.n
    Read [YPY] First
    If fstat = 0
        EXERCICI  = num$([F:YPY]EJERCICIO)
    Else
        mkstat = 2
        GMESSAGE= mess(6,1986,1)
        GERR=1
    Endif
    Filter [YPY]
End
###########################################################################################
Subprog XLECTUEXE(XFCY,XEXERCICI)
    Value       Char    XFCY()
    Value       Char    XEXERCICI

    If XFCY = "" or XEXERCICI = "" : End : Endif
    If clalev([F:YPY])=0 : Local File YPARANY [YPY] : Endif

    Filter [YPY] Where FCY=XFCY and EXERCICI = XEXERCICI
    Read [YPY] First
    If fstat<> 0
       mkstat = 2
       GMESSAGE= mess(6,1986,1)
       GERR=1
    Endif
    Filter [YPY]

End
###########################################################################################
Subprog COGER_CONTADOR(TIPDOC,SERIEDOC,NUMDOC,FCY,EXERCICI)
    Variable Char TIPDOC
    Variable Char SERIEDOC
    Variable Char NUMDOC
    Value Char FCY
    Value Char EXERCICI
    Local Integer STAT
    Local Char XCOMP(6)
    Local Char GNUM(20)
    Local Char CONT(20)
    Global Char GTIPDOC(5)
    Global Char GEXERCICI(4)

    If clalev([F:YTD])=0 : Local File YTIPDOC    [YTD] : Endif
    If clalev([F:TCA])=0 : Local File TABCOUAFF  [TCA] : Endif
    If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
    If clalev([F:YCD])=0 : Local File YCLASEDOC  [YCD] : Endif

    GOK = 1

    Read [YTD]YTD0=TIPDOC  ###- Aqui tendremos que mirar que tipo documento corresponde
    If fstat
        GERR=1
        GMESSAGE=mess(1,1986,1)
        GOK = 0
        End
    Endif

    Read [YTD]YTD0 = TIPDOC
    Read [F:TCA]TCA0=16
    If fstat
        GERR=1
        GMESSAGE=mess(2,1986,1)
        GOK = 0
        End
    Endif

    GTIPDOC=[F:YTD]CODITIPDOC
    GEXERCICI=EXERCICI

    Read [YCD]YCD0=[F:YTD]CLASEDOCUM
    If fstat
        GERR=1
        GMESSAGE=mess(84,1986,1)
        GOK = 0
        End
    Endif

    #SVR 200509. Cogemos como contador el definido en la clase de documento
    CONT = [F:YCD]CODNUM


    #Si la clase documento es inferior a o igual a 45 (Orden de Carga Compra), se hará otro acceso
    #a la asignación de contadores estandard
    ##WY26024 - SVR - 28/10/2013. Treiem el If pq no funcionava comptador Doc. 51 Compra/Venta

#    If CONT="" and [F:YTD]CLASEDOCUM<=45 Then
        CONT=[F:TCA]CODNUM([F:YCD]CONTADOR-1)
#    Endif

    #Si no se ha aconseguido contador, salimos
    If CONT="" Then
        GERR=1
        GMESSAGE=mess(84,1986,1)
        GOK = 0
        End
    Endif

    #Ya ha volcado los datos al buffer del fichero y vamos a llamar la rutina de contadores
    GOK=1
    Call NUMERO(CONT,FCY,date$,XCOMP,GNUM,STAT) From SUBANM

    If STAT=0
        NUMDOC = GNUM
    Else
        GERR=1 : GMESSAGE=mess(60,199,1): GOK=0 : End
    Endif

    If dim(GTIPDOC) > 0   : Kill GTIPDOC   : Endif
    If dim(GEXERCICI) > 0 : Kill GEXERCICI : Endif
End
###########################################################################################
Subprog COGER_CONTADOR_ORDEN(TIPDOC,SERIEDOC,NUMDOC,FCY,EXERCICI)
    Variable Char TIPDOC
    Variable Char SERIEDOC
    Variable Char NUMDOC
    Value Char FCY
    Value Char EXERCICI
    Local Integer STAT
    Local Char XCOMP(6)
    Local Char GNUM(20)

    If clalev([F:YTD])=0 : Local File YTIPDOC    [YTD] : Endif
    If clalev([F:TCA])=0 : Local File TABCOUAFF  [TCA] : Endif

    Read [YTD]YTD0=TIPDOC  ###- Aqui tendremos que mirar que tipo documento corresponde
    If fstat
        GERR=1
        GMESSAGE=mess(1,1986,1)
        GOK = 0
        End
    Endif

    Read [YTD]YTD0 = TIPDOC
    Read [F:TCA]TCA0=16
    If fstat
        GERR=1
        GMESSAGE=mess(2,1986,1)
        GOK = 0
        End
    Endif

    If [F:TCA]CODNUM([F:YTD]CLASEDOCUM-1)=""
        GERR=1
        GMESSAGE=mess(3,1986,1)
        GOK = 0
        End
    Endif

    XCOMP=EXERCICI+[F:YTD]SERIEDOCUM
    SERIEDOC = [F:YTD]SERIEDOCUM

    #NUMDOC = FCY+XCOMP+"-"
    NUMDOC = FCY+XCOMP
End
###########################################################################################
Subprog ASIGNACION_CAMPOS(NUMERO,CAMPO)
    Variable Char CAMPO
    Value Integer NUMERO

    Case NUMERO
        When 1      : CAMPO = CAMPO + "QUANTITAT1"                         ## Cantidad Estandar
        When 2      : CAMPO = CAMPO + "KGORIGEN"                           ## Kilos origen
        When 3      : CAMPO = CAMPO + "KGBRUTS"                            ## Kilos brutos
        When 4      : CAMPO = CAMPO + "KGVEHIC"                            ## Tara Vehiculo
        When 5      : CAMPO = CAMPO + "TARAENV"                            ## Tara Envase
        When 6      : CAMPO = CAMPO + "QUANTITAT0"                         ## Cantidad 0
        When 7      : CAMPO = CAMPO + "QUANTITAT1"                         ## Cantidad 1
        When 8      : CAMPO = CAMPO + "QUANTITAT2"                         ## Cantidad 2
        When 9      : CAMPO = CAMPO + "QUANTITAT3"                         ## Cantidad 3
        When 10     : CAMPO = CAMPO + "KGBRUTS" + "-" + CAMPO + "KGVEHIC"  ## Kilos brutos - Tara Vehiculo
        When 11     : CAMPO = CAMPO + "QTYSUP"                             ## Cantidad soportes
        When 12     : CAMPO = CAMPO + "QTYENV"                             ## Cantidad Envases
        When 13     : CAMPO = CAMPO + "QUANTITAT1"                         ## Importe Manual
        When 14     : CAMPO = CAMPO + "QUANTITAT1"                         ## Importe Directo
        When 15     : CAMPO = CAMPO + "QUANTITAT1"                         ## Cantidad Stock
        When 16     : CAMPO = CAMPO + "QUANTITAT1"                         ## Cantidad Stock / TM
        When 17     : CAMPO = CAMPO + "UNITATS1"                           ## Unidades
        When 18     : CAMPO = CAMPO + "KGORIGEN"                           ## Kilos origen / TM
        When Default
    Endcase
End
###########################################################################################
Subprog ASIGNACION_CAMPOS_FAC(NUMERO,CAMPO)
    Value Integer NUMERO
    Variable Char CAMPO

    Case NUMERO
        When 1      : CAMPO = CAMPO + "QTY"                                 ## Cantidad Estandar
        When 2      : CAMPO = CAMPO + "YKGORIGEN"                           ## Kilos origen
        When 3      : CAMPO = CAMPO + "YKGBRUTS"                            ## Kilos brutos
        When 4      : CAMPO = CAMPO + "YKGVEHIC"                            ## Tara Vehiculo
        When 5      : CAMPO = CAMPO + "YTARAENV"                            ## Tara Envase
        When 6      : CAMPO = CAMPO + "YQUANTI0"                            ## Cantidad 0
        When 7      : CAMPO = CAMPO + "YQUANTI1"                            ## Cantidad 1
        When 8      : CAMPO = CAMPO + "YQUANTI2"                            ## Cantidad 2
        When 9      : CAMPO = CAMPO + "YQUANTI3"                            ## Cantidad 3
        When 10     : CAMPO = CAMPO + "YKGBRUTS" + "-" + CAMPO + "YKGVEHIC" ## Kilos brutos - Tara Vehiculo
        When 11     : CAMPO = CAMPO + "YQTYSUP"                             ## Cantidad soportes
        When 12     : CAMPO = CAMPO + "YQTYENV"                             ## Cantidad Envases
        When 13     : CAMPO = CAMPO + "QTYSTU"                              ## Importe Manual
        When 14     : CAMPO = CAMPO + "QTYSTU"                              ## Importe Directo
        When 15     : CAMPO = CAMPO + "QTYSTU"                              ## Cantidad Stock
        When 16     : CAMPO = CAMPO + "QTYSTU"                              ## Cantidad Stock / TM
        When 17     : CAMPO = CAMPO + "YUNITATS1"                           ## Unidades
        When 18     : CAMPO = CAMPO + "YKGORIGEN"                           ## Kilos origen
        When Default
    Endcase
End
###########################################################################################
Subprog ASIGNACION_CAMPOS_PESADA(NUMERO,CAMPO)
    Variable Char CAMPO
    Value Integer NUMERO

    Case NUMERO
        When 1      : CAMPO = CAMPO + "XQ1"                                  ## Cantidad Estandar
        When 2      : CAMPO = CAMPO + "XKGORIGEN"                            ## Kilos origen
        When 3      : CAMPO = CAMPO + "XKGBRUTS"                             ## Kilos brutos
        When 4      : CAMPO = CAMPO + "XKGVEHIC"                             ## Tara Vehiculo
        When 5      : CAMPO = CAMPO + "XKGTARA"                              ## Tara Envase
        When 6      : CAMPO = CAMPO + "XQ0"                                  ## Cantidad 0
        When 7      : CAMPO = CAMPO + "XQ1"                                  ## Cantidad 1
        When 8      : CAMPO = CAMPO + "XQ2"                                  ## Cantidad 2
        When 9      : CAMPO = CAMPO + "XQ3"                                  ## Cantidad 3
        When 10     : CAMPO = CAMPO + "XKGBRUTS" + "-" + CAMPO + "XKGVEHIC"  ## Kilos brutos - Tara Vehiculo
        When 11     : CAMPO = CAMPO + "XQTYSUP"                              ## Cantidad soportes
        When 12     : CAMPO = CAMPO + "XQTYENV"                              ## Cantidad Envases
        When 13     : CAMPO = CAMPO + "XQ1"                                  ## Importe Manual
        When 14     : CAMPO = CAMPO + "XQ1"                                  ## Importe Directo
        When 15     : CAMPO = CAMPO + "XQ1"                                  ## Cantidad Stock
        When 16     : CAMPO = CAMPO + "XQ1"                                  ## Cantidad Stock / TM
        When 17     : CAMPO = CAMPO + "XUNITATS1"                            ## Unidades
        When 18     : CAMPO = CAMPO + "XKGORIGEN"                            ## Kilos origen / TM
        When Default
    Endcase
End
###########################################################################################
Subprog BUSCAR_CLASEDOC_OBJETO(TRANSAC, CLASEDOC)
    Variable Integer CLASEDOC
    Value Char TRANSAC

    If clalev([F:YCD])=0 : Local File YCLASEDOC  [YCD] : Endif

    GOK = 1
    Raz CLASEDOC
    Read [YCD]YCD1=TRANSAC
    If fstat
        GERR=1
        GMESSAGE=mess(84,1986,1)
        GOK = 0
        End
    Endif

    CLASEDOC = [F:YCD]CLASEDOC
End
###########################################################################################
Subprog BUSCAR_OBJETO_CLASEDOC(CLASEDOC,TRANSAC)
    Value    Integer CLASEDOC
    Variable Char    TRANSAC

    If clalev([F:YCD])=0 : Local File YCLASEDOC  [YCD] : Endif

    GOK = 1
    Raz TRANSAC
    Read [YCD]YCD0=CLASEDOC
    If fstat
        GERR=1
        GMESSAGE=mess(84,1986,1)
        GOK = 0
        End
    Endif

    TRANSAC = [F:YCD]OBJETO
End
###########################################################################################
Subprog COGER_CONTADOR_TRAZABILIDAD(TIPDOC,NUMDOC,FCY,EXERCICI)
    Variable Char TIPDOC
    Variable Char NUMDOC
    Value Char FCY
    Value Char EXERCICI
    Local Integer STAT
    Local Char XCOMP(6)
    Local Char GNUM(20)

    If clalev([F:YTD])=0 : Local File YTIPDOC    [YTD] : Endif

    Read [YTD]YTD0=TIPDOC  ###- Aqui tendremos que mirar que tipo documento corresponde
    If fstat
        GERR=1
        GMESSAGE=mess(1,1986,1)
        GOK = 0
        End
    Endif

    Read [YTD]YTD0 = TIPDOC

    XCOMP=EXERCICI+[F:YTD]SERIEDOCUM

    #Ya ha volcado los datos al buffer del fichero y vamos a llamar la rutina de contadores
    #El contador de Trazabilidad corresponde al YTZ
    Call NUMERO("YTZ",FCY,date$,XCOMP,GNUM,STAT) From SUBANM

    If STAT=0
        NUMDOC = GNUM
    Else
        GERR=1 : GMESSAGE=mess(60,199,1): GOK=0 : End
    Endif
End
###########################################################################
# Arrodonir calculs interns.
###########################################################################
Subprog ARRODONIR(QTY,UOM)
    Variable Decimal QTY
    Value Char UOM

    # lecture de l'unité
    If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
    If UOM <> ""
        Read [TUN]TUN0 = UOM
    Endif
    # le format est determiné par la variable globale GF..(7)
    # Arrondi de la quantité selon nb de décimales :
    If QTY <> 0 & fstat = 0
        Case [F:TUN]YUOMCALC
            When 0 : QTY = arr(QTY,1)
            When 1 : QTY = arr(QTY,0.1)
            When 2 : QTY = arr(QTY,0.01)
            When 3 : QTY = arr(QTY,0.001)
            When 4 : QTY = arr(QTY,0.0001)
            When 5 : QTY = arr(QTY,0.00001)
            When 6 : QTY = arr(QTY,0.000001)
        Endcase
    Endif
End
###########################################################################################
Subprog ARRDESC(XTYP,XDISC,XQTY,XCUR)
    Value    Integer    XTYP
    Value    Integer    XDISC
    Variable Decimal    XQTY
    Value    Char       XCUR
    Local    Integer    XLIN : XLIN =0
    Local    Integer    XVALOR

    If XQTY = 0 : End : Endif

    If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif

    ## XTYP = 1 - Ventas
    ## XTYP = 2 - Compras

    Call LECDEV (XCUR) From TRTDIV
    Call COLREM ("C",XTYP,"") From TRTPRICE

    If GFMTREM(XDISC-1)="M"
        XVALOR = ((val([F:TCU]CURFMT2) - int(val([F:TCU]CURFMT2))) * 10)

        Case XVALOR
            When 0 : XQTY = arr(XQTY,1)
            When 1 : XQTY = arr(XQTY,0.1)
            When 2 : XQTY = arr(XQTY,0.01)
            When 3 : XQTY = arr(XQTY,0.001)
            When 4 : XQTY = arr(XQTY,0.0001)
            When 5 : XQTY = arr(XQTY,0.00001)
            When 6 : XQTY = arr(XQTY,0.000001)
            When 7 : XQTY = arr(XQTY,0.0000001)
            When 8 : XQTY = arr(XQTY,0.00000001)
        Endcase
    Else
        XQTY = arr(XQTY,0.01)
    Endif
End
###########################################################################################
Funprog DIVISION_CERO(D1,D2)  #--- Control error division por cero
    Value Decimal D1
    Value Decimal D2

    If D2=0
      End 0
    Else
      End arr(D1/D2,0.0001)
    Endif
End
###########################################################################################
Funprog DC(D1,D2)   #--- Util para ser llamada desde editor formulas (MANEL-14/11/07)
    Value Decimal D1
    Value Decimal D2
End func DIVISION_CERO(D1,D2)
###########################################################################################
###########################################################################################
Funprog BUSCA_BASRET()
    Local Decimal QUANTITAT
    Local Decimal PREU
    Local Decimal BASE
    Local Decimal PERCENIVA
    Local Decimal ACUMIVA
    Local Decimal ELEMENTSFAC
    Local Decimal NOL
    Local Char REGIM
    Local Date DATADOC

    If !clalev([F:TRA])   : Local File TABRATVAT    [TRA]  : Endif
    If !clalev([F:TVT])   : Local File TABVAT       [TVT]  : Endif

    QUANTITAT=[M]QTYUOM(nolign-1)
    PREU=[M]NETPRI(nolign-1)

    If GFONC1="GESPTH"
## Recepcions
        REGIM=[M]VACBPR
        DATADOC=[M]RCPDAT
    Endif
    If GFONC1="GESPIH"
## Factures
        REGIM=[M]VAC
        DATADOC=[M]BPRDAT
        ELEMENTSFAC=[M]DISCRGAMT1(nolign-1) + [M]DISCRGAMT2(nolign-1) +
&                   [M]DISCRGAMT3(nolign-1) + [M]DISCRGAMT4(nolign-1)
    Endif
    If GFONC1="GESPOH"
## Comandes
        REGIM=[M]VACBPR
        DATADOC=[M]ORDDAT
    Endif
    If GFONC1="GESPNH"
## Devolucions
        REGIM=[M]VACBPR
        DATADOC=[M]RTNDAT
    Endif

    ACUMIVA=0
    If REGIM="REA"
        If [M]VAT1<>"" Then
            PERCENIVA=0
            Read [TVT]TVT0=[M]VAT1
            If fstat=0 and [F:TVT]VATTYP<3 Then
                Filter [TRA] Where VAT=[M]VAT1 and STRDAT<=DATADOC Order By STRDAT Desc
                Read [TRA] First
                If fstat = 0
                    PERCENIVA=[F:TRA]VATRAT
                Endif
            Endif
            ACUMIVA=ACUMIVA+PERCENIVA
        Endif
        If [M]VAT2<>"" Then
            PERCENIVA=0
            Read [TVT]TVT0=[M]VAT2
            If fstat=0 and [F:TVT]VATTYP<3 Then
                Filter [TRA] Where VAT=[M]VAT2 and STRDAT<=DATADOC Order By STRDAT Desc
                Read [TRA] First
                If fstat = 0
                    PERCENIVA=[F:TRA]VATRAT
                Endif
            Endif
            ACUMIVA=ACUMIVA+PERCENIVA
        Endif
        If [M]VAT3<>"" Then
            PERCENIVA=0
            Read [TVT]TVT0=[M]VAT3
            If fstat=0 and [F:TVT]VATTYP<3 Then
                Filter [TRA] Where VAT=[M]VAT3 and STRDAT<=DATADOC Order By STRDAT Desc
                Read [TRA] First
                If fstat = 0
                    PERCENIVA=[F:TRA]VATRAT
                Endif
            Endif
            ACUMIVA=ACUMIVA+PERCENIVA
        Endif
        ACUMIVA = (ACUMIVA / 100) + 1
        BASE=((([M]QTYUOM(nolign-1)*[M]NETPRI(nolign-1)) + ELEMENTSFAC) * ACUMIVA)
    Else
        BASE=([M]QTYUOM(nolign-1)*[M]NETPRI(nolign-1))
    Endif
End BASE
###########################################################################################
Subprog RETORNAR_DESC_MES(MES,DESCMES,ERROR)
    Value Char MES
    Variable Char DESCMES
    Variable Integer ERROR

    ERROR=0
    Case MES
        When "01" : DESCMES="Enero"
        When "02" : DESCMES="Febrero"
        When "03" : DESCMES="Marzo"
        When "04" : DESCMES="Abril"
        When "05" : DESCMES="Mayo"
        When "06" : DESCMES="Junio"
        When "07" : DESCMES="Julio"
        When "08" : DESCMES="Agosto"
        When "09" : DESCMES="Septiembre"
        When "10" : DESCMES="Octubre"
        When "11" : DESCMES="Noviembre"
        When "12" : DESCMES="Diciembre"
        When Default : ERROR=1
    Endcase
End
