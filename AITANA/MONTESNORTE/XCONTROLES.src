        TIPDOC = [F:YRE]TIPDOC_D
        TRANSAC = [F:YRE]TRANSAC_D
    Next
    If TIPDOC = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO & TRANSAC = ETRANSAC  & OBJETO_D = EOBJETOD
            TIPDOC = [F:YRE]TIPDOC_D
            TRANSAC = [F:YRE]TRANSAC_D
        Next
    Endif
    If TIPDOC = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO  & TIPDOC = TIPDOC_PARAM & OBJETO_D = EOBJETOD
            TIPDOC = [F:YRE]TIPDOC_D
            TRANSAC = [F:YRE]TRANSAC_D
        Next
    Endif
    If TIPDOC = ""
        For [YRE]YRE0 Where OBJETO = EOBJETO  & OBJETO_D = EOBJETOD
            TIPDOC = [F:YRE]TIPDOC_D
            TRANSAC = [F:YRE]TRANSAC_D
        Next
    Endif
End
######################################################################################
######################################################################################
### Control si el tercero está autorizado en una sección.      JGM - 04/06/07      ###
######################################################################################
Subprog YCTLSEC(BPRNUM,YTIPDOC)
    Variable Char    BPRNUM
    Variable Char    YTIPDOC
    Local Char CARAC : CARAC = GYCARSEC
    Local Integer EXISTE : EXISTE = 0
    Local Integer FILAS  : FILAS  = 0
    Local Integer DIREC  : DIREC  = 0

    If clalev([F:YIP])=0 : Local File YTIPDOT    [YIP] : Endif
    If clalev([F:YPE])=0 : Local File YPERSCAR   [YPE] : Endif

    For [YPE] Where CODIPERSON = BPRNUM and CODICARAC = CARAC
        DIREC = 1
        Filter [YIP] Where CODITABLA = 3 and CODITIPDOC = YTIPDOC and CODI2 = CARAC and CODICARVAL = [F:YPE]CODICARVAL
        FILAS = rowcount([YIP])
        If (FILAS>0)
            EXISTE = 1
            Filter [YIP]
            Break
        Endif
    Next

    If EXISTE = 0 and DIREC = 1
        GERR=1
        GMESSAGE=BPRNUM-mess(106,1986,1)
        mkstat=2
        End
    Endif
End
######################################################################################
######################################################################################
Subprog BUSCAR_TAXA(VAT1,SOC,DAT,TXTAX)
    Value    Char    VAT1
    Value    Char    SOC
    Value    Date    DAT
    Variable Decimal TXTAX

    If clalev([F:TRA]) = 0  Local File TABRATVAT [TRA]  Endif

    TXTAX=0
    # Cas particulier sociÃ©tÃ© ??
    Filter [TRA] Where CPY=SOC & VAT=VAT1 & STRDAT<=DAT
    Read [TRA]TRA0 Last
    If fstat>2
    # sinon on se rabat sur le code dossier
     Filter [TRA] Where CPY="" & VAT=VAT1 & STRDAT<=DAT
     Read [TRA]TRA0 Last
     If fstat>2 : End : Endif
    Endif

    TXTAX = [F:TRA]VATRAT
    If dim([F:TRA]VATEXEFLG)>0 & [F:TRA]VATEXEFLG=2 : TXTAX=0 : Endif

    Filter [TRA]
End
######################################################################################
######################################################################################
Subprog CALCULAR_TARIFA(GRUPVEHIC,GRUPTERCE,GRUPPROD,GRUPTRANS,QUANT,DATA,PREU1,PREU2,CLASE,FCY,TIPDOC)
    Value    Char    GRUPVEHIC
    Value    Char    GRUPTERCE
    Value    Char    GRUPPROD
    Value    Char    GRUPTRANS
    Value    Decimal QUANT
    Value    Date    DATA
    Variable Decimal PREU1,PREU2
    Value    Integer CLASE
    Value    Char    FCY
    Value    Char    TIPDOC
    Local    Char    CRITERE(250),CRITERE2(250),CRITERE3(250)
    Local    Char    NOM_TAULA

    # CLASE = 1 : TRANSPORTE
    # CLASE = 2 : COMISION
    # CLASE = 3 : DESCUENTO
    # CLASE = 4 : RECOLECCION

    If clalev([F:YLR])=0 : Local File YLINPREU  [YLR] : Endif
    If clalev([F:YCP])=0 : Local File YCABPREU  [YCP] : Endif
    If clalev([F:YTD])=0 : Local File YTIPDOC   [YTD] : Endif

    If GYTRANTIP = 2 and TIPDOC <> "" and (CLASE = 1 or CLASE = 4)
        Read [YTD]YTD0=TIPDOC
        If fstat
            GERR=2
            GMESSAGE=mess(1,1986,1)
            GOK=0
            End
        Else
            NOM_TAULA = [F:YTD]PRODTRANS
        Endif
    Endif

    CRITERE  = "[F:YLR]GRUPVEHICL=GRUPVEHIC and [F:YLR]GRUPTERCE = GRUPTERCE"
    CRITERE += " and [F:YLR]GRUPPROD = GRUPPROD and [F:YLR]GRUPREPRE = GRUPTRANS"

    CRITERE2  = " [F:YLR]QUANT_INI <= QUANT and [F:YLR]QUANT_FI >= QUANT"
    CRITERE2 += " and [F:YLR]DATA_INI <= DATA and [F:YLR]DATA_FI >= DATA"

    CRITERE3 = " [F:YCP]TCLASE = CLASE and [F:YCP]TACTIU = 2 and [F:YLR]FCY = FCY"

    If GYTRANTIP = 2 and TIPDOC <> "" and (CLASE = 1 or CLASE = 4)
        CRITERE3 += " and [F:YCP]CODITAULA = NOM_TAULA"
    Endif

    Link [YCP] With [YLR]YLR0=CODITAULA As [XXX] Where evalue(CRITERE) & evalue(CRITERE2) & evalue(CRITERE3)

    For [XXX]
        PREU1 = [F:YLR]PREU1
        PREU2 = [F:YLR]PREU2
        TIPO_CALC = [F:YLR]TIPOCALC
    Next

End
######################################################################################
######################################################################################
Subprog YCTLITV (LITM,LBPC)
    Variable Char  LITM
    Value    Char  LBPC


    If LITM="" & (instr(1,dbgstr(1),"SRH1")|instr(1,dbgstr(1),"SRL1")) End Endif

    If clalev ([F:ITM]) <= 0 Local File ITMMASTER [ITM] : Endif
    If clalev ([F:ITS]) <= 0 Local File ITMSALES  [ITS] : Endif
    If clalev ([F:ITU]) <= 0 Local File ITMBPC    [ITU] : Endif

    Read [ITM]YITM0 = LITM
    If !fstat
       LITM=[F:ITM]ITMREF
    Else
       LITM=toupper(LITM)
    Endif

    Read [ITU]ITU1 = LBPC;LITM
    If !fstat
       LITM=[F:ITU]ITMREF
    Else
       LITM=toupper(LITM)
    Endif

    Read [ITS]ITS0 = LITM
    If fstat mkstat=2 : GMESSAGE=mess(5,192,1) Endif

End
######################################################################################
Subprog YAVIBPT(VALEUR,XFECHA,XCLASE,XTIPOFCY)
    Variable  Char    VALEUR()
    Value     Date    XFECHA
    Value     Char    XCLASE
    Value     Integer XTIPOFCY
    Local     Integer RESP : RESP = 2

    If clalev([F:YPE])=0 : Local File YPERSCAR  [YPE] : Endif
    If clalev([F:XPE])=0 : Local File YPERSCAR  [XPE] : Endif
    If clalev([F:AXX])=0 : Local File ATEXTRA   [AXX] : Endif

    ##-- Avisos de terceros caracteristicas --- ##

    For [YPE] Where [F:YPE]CODIPERSON = VALEUR and (left$([F:YPE]CODICARAC,2) = 'A0'
&    or left$([F:YPE]CODICARAC,2) = 'A' + num$(XTIPOFCY))
&    and [F:YPE]FECHAINI<= XFECHA and [F:YPE]FECHAFIN>= XFECHA
&    and ([F:YPE]MODALITAT = 3 or [F:YPE]MODALITAT = val(XCLASE))
&    and [F:YPE]TEST = 2

        Read [AXX]AXX0='ATABDIV';'LNGDES';'SPA';'1004';[F:YPE]CODICARAC
        If fstat  Raz [F:AXX] : Endif


        If [F:YPE]CODICARVAL = 'AP'
            Qstbox [F:AXX]TEXTE Using RESP Sleep 10

            If RESP = 1
                Trbegin [XPE]
                Update [XPE] Where CODIPERSON=[F:YPE]CODIPERSON and NUMLINEA1 = [F:YPE]NUMLINEA1 With TEST = 1
                If fstat
                    GOK=0 : Rollback : Call FSTA("XPE") From GLOCK : Return
                Endif
                Commit
            Endif
        Elsif [F:YPE]CODICARVAL = 'AI'
            GERR = 2
            GMESSAGE += [F:AXX]TEXTE + chr$(013)
        Endif

    Next
End
###########################################################################################
###########################################################################################
Subprog XEXERINIFI(XFCY,XFECHA,DINICI,DFI)
    Value       Char    XFCY()
    Value       Date    XFECHA
    Variable    Date    DINICI
    Variable    Date    DFI

    If XFCY = "" or XFECHA = [0/0/0] : End : Endif
    If clalev([F:YPY])=0 : Local File YPARANY [YPY] : Endif

    Filter [YPY] Where FCY=XFCY and DATAINIEX <= XFECHA and DATAFIEX >=XFECHA and TESTMAESTR = 2
&    and TESTMOVIMI = 2
    Read [YPY] First
    If fstat = 0
        DINICI=[F:YPY]DATAINIEX
        DFI=[F:YPY]DATAFIEX
    Else
        mkstat = 2
        GMESSAGE= mess(6,1986,1)
        GERR=1
    Endif
    Filter [YPY]
End
###########################################################################################
######################################################################################
### Funcio que ens retornara si existeix algun resgistre a documentos relacionados ###
### corresponent al OBJETE y TRANSACCIO, que li pasem         JGM 22/11/2007       ###
######################################################################################
Subprog BUSCAR_YRELDOC(EOBJETO, ETRANSAC, EOBJETOD, EXISTE)
    Value Char EOBJETO
    Value Char ETRANSAC
    Value Char EOBJETOD
    Variable Integer EXISTE

    EXISTE = 1

    If clalev([F:YRE])=0 : Local File YRELDOC    [YRE] : Endif

    ##--- Buscaremos el Tipo de Documento ---###
    For [YRE]YRE0 Where OBJETO = EOBJETO & TRANSAC = ETRANSAC & OBJETO_D = EOBJETOD
        EXISTE = 2
    Next
    ##----------------------------------------##

End
######################################################################################
### Funcio que ens retornara si existeix algun resgistre a documentos relacionados ###
### corresponent al OBJETE y TIPO DOCUMENT, que li pasem            JGM 06/02/2012 ###
######################################################################################
Subprog BUSCAR_YRELDOC2(EOBJETO, ETIPDOC, EOBJETOD, EXISTE)
    Value Char EOBJETO
    Value Char ETIPDOC
    Value Char EOBJETOD
    Variable Integer EXISTE

    EXISTE = 1

    If clalev([F:YRE])=0 : Local File YRELDOC    [YRE] : Endif

    For [YRE]YRE0 Where OBJETO = EOBJETO & TIPDOC = ETIPDOC & OBJETO_D = EOBJETOD
        EXISTE = 2
    Next
End
######################################################################################
#--- Devuelve el precio estandard actualizado en función de la planta, artículo y fecha de cálculo de tarifa
#--- Se puede llamar desde la parametrización de tarifas de venta
######################################################################################
Funprog UPEA(DA)
    Value Date DA
    Local Decimal PREU

    If clalev([F:YITC])=0 : Local File ITMCOST [YITC] : Endif

    Filter [YITC] Where STOFCY=[F:ITC]STOFCY and ITMREF=[F:ITC]ITMREF and CSTTYP=2 and DA>=ITCDAT
    Read [YITC]Last
    PREU = [F:YITC]MATTOT
    Filter [YITC]
End PREU
###########################################################################################
#Per a poder simular la instrucció IF en les funcions d'Adonix
#Retorna valor numeric
###########################################################################################
Funprog NSI(CONDICIO,VALORCERT,VALORFALS)
    Value Decimal CONDICIO
    Value Decimal VALORCERT
    Value Decimal VALORFALS

    If CONDICIO
        End VALORCERT
    Else
        End VALORFALS
    Endif
End
###########################################################################################
#Per a poder simular la instrucció IF en les funcions d'Adonix
#Retorna valor char
###########################################################################################
Funprog CSI(CONDICIO,VALORCERT,VALORFALS)
    Value Decimal CONDICIO
    Value Char VALORCERT
    Value Char VALORFALS

    If CONDICIO
        End VALORCERT
    Else
        End VALORFALS
    Endif
End
###########################################################################################
###########################################################################################
### PANTALLA = Li pasarem el nom de la pantalla que volem buscar el camp
### CAMP     = Nom del camp a buscar dins de la pantalla
### TROBAT   = TROBAT = 0 El camp o la pantalla no existeixen
###            TROBAT = 1 El camp esta mostrado o Entrada
###            TROBAT = 2 El camp esta invisible
###########################################################################################
Subprog BUSCAR_CAMP_INV(PANTALLA,CAMP,TROBAT)
    Value    Char    PANTALLA
    Value    Char    CAMP
    Variable Integer TROBAT

    If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif

    Read [AMZ]CODE = PANTALLA;CAMP
    If fstat
        Raz [F:AMZ]
        TROBAT = 0
    Else
        If [F:AMZ]SAIAFF = 3
            TROBAT = 2
        Else
            TROBAT = 1
        Endif
    Endif
End
