#<AdxTL>@(#)0.0.0.0 $Revision$
#XVT18-05-2020 - En entregas a cuenta (desarrollo de liquidaciones), la planta de línea
#debe ser la planta en la que se ha hecho la recepción al agricultor, de forma que la
#analítica caiga también en la sección correspondiente a dicha planta
#se usará el campo [M:PIH3]ZFCYLIN(NOL) en el modelo import, para indicar
#dicha planta y calcular la analítica.


$ACTION
  Case ACTION
  When "ALILIGFAC" :  Gosub ALILIGFAC
  Endcase
Return

#XVT18-05-2020.bn
$ALILIGFAC
  #Infbox [M:PIH0]PIVTYP

  If ([M:PIH0]PIVTYP="ELQ" or [M:PIH0]PIVTYP="FLQ") and [M:PIH3]TYPORI(NOL)=5 Then
    #sólo para entregas a cuenta, porque las liquidaciones, como vienen de recepción
    #el campo FCYLIN y su correspondiente CCE, vienen de la recepción
    If !clalev([F:ZFCY]) : Local File FACILITY [ZFCY] : Endif
    Read [ZFCY]FCY0=[M:PIH3]ZFCYLIN(NOL)
    If fstat : Return : Endif

    [M:PIH3]FCYLIN(NOL) =  [M:PIH3]ZFCYLIN(NOL) # = "01B02"
    [M:PIH3]CCE2(NOL)   =  [ZFCY]CCE(1)

  Endif

Return
#XVT18-05-2020.en

