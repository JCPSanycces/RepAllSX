#$CHK_SDH
#  SDHESPERA=0
#  Call TEMPON("Generación de entrega a cliente en curso. Espere por favor.") From GESECRAN
#
#  If !clalev ([ZSDD]) : Local File SDELIVERYD [ZSDD] : Endif
