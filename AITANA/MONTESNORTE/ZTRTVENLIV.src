#########################################################
# Creación de JOB para la importación del SDH
$GEN_JOB_SDH
  Call CREAR_JOB([F:SDH]SDHNUM+"_SDH_"+LFECHA+".txt",'ZSDHCALI' )
Return

########################################################
$OPEN_FILE

  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openo LFILE,0 Using [ZIMP]

Return


########################################################
$CLOSE_FILE
  Openo Using [ZIMP]
Return

##################################################
Subprog GEN_REC
  #XVT070120 - información adicional: este subprog se llama desde
  #la acción ZDIVVALLIV, que se llama desde el botón GEN_REC de la ventana OSDH (entregas de venta)
   If !clalev ([ZPTH]) : Local File PRECEIPT [ZPTH] : Endif

   Read [ZPTH]PTH1=[F:SDH]SDHNUM
   If  !fstat Then
     Call MESSAGE("La recepción ya se ha creado " + [ZPTH]PTHNUM) From GESECRAN
   Else
     If [F:SDH]CFMFLG=2 Then
        #La recepción no debe estar ya creada y debe estar validada la entrega
        Gosub PROCESA_VALIDACION
        #Call LEC_TRACE From LECFIC
     Else
      Call MESSAGE("Primero debe validar la entrega") From GESECRAN
     Endif
   Endif
End

#**
#* CREAR_JOB(PFICHERO)
#*
#* @param PFICHERO
#*
#* Es necesario tener parámetrizado X3 para que funcionen los JOBs
#*!
Subprog CREAR_JOB(PDIRIMPORT, PDIRJOB, PJOB, PFICHERO, PMODELO, PVOLFIL)
  Value Char PDIRIMPORT
  Value Char PDIRJOB
  Value Char PJOB
  Value Char PFICHERO
  Value Char PMODELO
  Value Char PVOLFIL

  Local Char NOMBRE_AUX(250)
  NOMBRE_AUX = PDIRIMPORT + PFICHERO

  Openo PDIRJOB + PJOB

  Wrseq 'DOSSIER='+[S]nomap(0)
  Wrseq 'LAN=SPA'
  Wrseq 'UTIL=ADMIN'
  Wrseq 'PASSE=BAABAA'
  Wrseq 'GRP='
  Wrseq 'TACHE=IMPORT'
  Wrseq 'DATE=20180101'
  Wrseq 'HEURE=0001'
  Wrseq 'MODIMP=' + PMODELO
  Wrseq 'NOMIMP=' + NOMBRE_AUX
  Wrseq 'TYPEXP=2'
  Wrseq 'VOLFIL=' + PVOLFIL + PFICHERO
  Wrseq 'ZMODIMP=Import desde JOB'
  Openo

End

