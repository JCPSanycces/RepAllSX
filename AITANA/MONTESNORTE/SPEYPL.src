######################################################################################
# Gestión de la máscara YPLANPROD  -- Plantaciones --
######################################################################################
$ACTION
    Case ACTION
        When "INICRE"         : Gosub INICRE
        When Default
    Endcase
Return
#######################################################################################
$INICRE
    Local   Char    GNUM
    Local   Char    CONTADOR
    Local   Char    CONT(20)
    Global  Char    GEXERCICI(4)
    Local   Integer STAT
    Local   Char    XCOMP(6)

    If (GREP="C" or GREP="D" ) and [M:YPL0]CODIPLANTA="" Then
        GEXERCICI=[M:YPL0]EXERCICI
        GOK = 1   
        
        If [M:YPL0]FCY = "01B" : CONTADOR ="ZP1" : Endif
        If [M:YPL0]FCY = "01A" : CONTADOR ="ZP2" : Endif
         
        Call NUMERO(CONTADOR,[M:YPL0]FCY,date$,XCOMP,GNUM,STAT) From SUBANM
        If STAT=0 
            [F:YPL]CODIPLANTA = GNUM
            [M:YPL0]CODIPLANTA = GNUM
            Affzo [M:YPL0]CODIPLANTA 
            Actzo [M:YPL0]CODIPLANTA
        Else 
            GERR=1 : GMESSAGE=mess(60,199,1): GOK=0 : Return
        Endif

        GPV = 1      
    Endif
Return
#######################################################################################
######################################################################################
## Etiqueta añadida por el supervisor (pantalla YPL0) 14/08/2014 11:33:35 (JGAYA)
######################################################################################
Subprog C_CODIPLANTA(VALEUR)
Variable Char    VALEUR()
End


######################################################################################

