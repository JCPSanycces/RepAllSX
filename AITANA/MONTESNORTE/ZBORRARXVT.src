If clalev([F:ZPRL])=0 : Local File ZPRELIQ  [ZPRL] : Endif
LOCAL DECIMAL MYRND : MYRND=20.0

For [F:ZPRL] where [F:ZPRL]NUMDOC='01A0019TP-00004' and ITMREF='70001' and CALIDAD='01' AND GRDINI<=MYRND AND
& GRDFIN>=MYRND
  infbox [F:ZPRL]NUMDOC + " " + NUM$([F:ZPRL]PRECIO)
Next
