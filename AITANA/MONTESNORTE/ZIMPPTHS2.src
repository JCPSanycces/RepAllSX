$ACTION
  Case ACTION
    When "AP_IMPORT" : Gosub AP_IMPORT
    When "IMP_FERME" : Gosub IMP_FERME
  Endcase
Return

$OUVRE
  Gosub OUVRE From IMPPTHS
Return

$RAZCRE
  Gosub RAZCRE From IMPPTHS
Return

$VALID
  Gosub VALID From IMPPTHS
Return

$SAIMSK
  Gosub SAIMSK From IMPPTHS
Return

$IMP_FERME
  # SE AÑADE ESTE CÓDIGO, YA QUE NO FUNCIONA LA VARIABLE GIMP PARA LOS CAMPOS ZXXXXX
  # BUSCAR LÍNEAS DE RECEPCIÓN CREADA SI LA IMPORTACIÓN SE ESTÁ HACIENDO DESDE UNA ENTREGA
  # Y ACTUALIZAR LOS CAMPOS Z DE LAS LÍNEAS DE LA RECEPCIÓN.
  If clalev([M:SDH0]) Then # Si estoy dentro de la pantalla de Entregas
      #Infbox "IMP_FERME - Recepción creada:" + [F:PTH]PTHNUM
      #Infbox "Entrega:" + [M:SDH0]SDHNUM
      If !clalev([F:ZPTHD]) Then : Local File PRECEIPTD [ZPTHD] : Endif
      For I=0 To [M:SDH1]NBLIG
          Filter [ZPTHD] Where SDHNUM = [M:SDH0]SDHNUM and SDDLIN = [M:SDH1]SDDLIN(I) and ITMREF = [M:SDH1]ITMREF(I)
          #Infbox "REGSITROS ENCONTRADOS: " + num$(rowcount([ZPTHD])) +  " - Linea: " + num$([M:SDH1]SDDLIN(I)) + " - " +  [M:SDH1]ITMREF(I) + " - " + [M:SDH0]SDHNUM
          Read [ZPTHD] First
          If !fstat Then
            [F:ZPTHD]ZCANT1 = [M:SDH1]ZCANT1(I)
            [F:ZPTHD]ZCANT2 = [M:SDH1]ZCANT2(I)
            [F:ZPTHD]ZCALIDAD = [M:SDH1]ZCALIDAD(I)
            [F:ZPTHD]ZDENSIDAD = [M:SDH1]ZDENSIDAD(I)
            [F:ZPTHD]ZGLUCONICO = [M:SDH1]ZGLUCONICO(I)
            [F:ZPTHD]ZGRADO = [M:SDH1]ZGRADO(I)
            [F:ZPTHD]ZHUMEDAD = [M:SDH1]ZHUMEDAD(I)
            [F:ZPTHD]ZPESOESPE = [M:SDH1]ZPESOESPE(I)
            [F:ZPTHD]ZPH = [M:SDH1]ZPH(I)
            [F:ZPTHD]ZPOTASIO = [M:SDH1]ZPOTASIO(I)
            [F:ZPTHD]ZPUNTOS = [M:SDH1]ZPUNTOS(I)
            [F:ZPTHD]ZRENDIMIENTO = [M:SDH1]ZRENDIMIENTO(I)
            [F:ZPTHD]ZTARAVEHI = [M:SDH1]ZTARAVEHI(I)
            Rewrite
          Endif
      Next I
      Close File [ZPTHD]
  Endif



