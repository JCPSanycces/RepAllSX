$AP_IMPORT

  Case [L]IMPFIC
    When "PTH"
      If GIMP(98)<>'' Then
        [F:PTH]ZAIN = GIMP(98)
        [M:PTH9]ZAIN = GIMP(98)
      Endif

      If GIMP(97) <> '' Then
        [F:PTH]ZAINNAM = GIMP(97)
        [M:PTH9]ZAINNAM = GIMP(97)
      Endif

      If GIMP(96) <> '' Then
        [F:PTH]TRLLICPLATE = GIMP(96)
        [M:PTH9]TRLLICPLATE = GIMP(96)
      Endif

      If GIMP(95) <> '' Then
        [F:PTH]LICPLATE = GIMP(95)
        [M:PTH9]LICPLATE = GIMP(95)
      Endif
   When "PTD"
    #  Infbox "ZIMPPTHS - IMPORTACIÓN DESDE ENTREGAS"

      If GIMP(94)<>'' Then
        [M:PTH1]ZCANT1(nolign-1) = val(GIMP(94))
      Endif

      If GIMP(93) <> '' Then
        [M:PTH1]ZCANT2(nolign-1) = val(GIMP(93))
      Endif

      If GIMP(92) <> '' Then
        [M:PTH1]ZCALIDAD(nolign-1) = GIMP(92)
      else
        [M:PTH1]ZCALIDAD(nolign-1) = '0'     
      Endif

      If GIMP(91) <> '' Then
        [M:PTH1]ZRENDIMIENTO(nolign-1) = val(GIMP(91))
      Endif

      If GIMP(90) <> '' Then
        [M:PTH1]ZGRADO(nolign-1) = val(GIMP(90))
      Endif

      If GIMP(89) <> '' Then
        [M:PTH1]ZPH(nolign-1) = val(GIMP(89))
      Endif

      If GIMP(88) <> '' Then
        [M:PTH1]ZHUMEDAD(nolign-1) = val(GIMP(88))
      Endif

      If GIMP(87) <> '' Then
        [M:PTH1]ZPESOESPE(nolign-1) = val(GIMP(87))
      Endif

      If GIMP(86) <> '' Then
        [M:PTH1]ZGLUCONICO(nolign-1) = val(GIMP(86))
      Endif

      If GIMP(85) <> '' Then
        [M:PTH1]ZPOTASIO(nolign-1) = val(GIMP(85))
      Endif

      If GIMP(84) <> '' Then
        [M:PTH1]ZPUNTOS(nolign-1) = val(GIMP(84))
      Endif

      If GIMP(83) <> '' Then
        [M:PTH1]ZDENSIDAD(nolign-1) = val(GIMP(83))
      Endif
   When Default
  Endcase

Return



