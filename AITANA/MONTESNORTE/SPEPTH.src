######################################################################################
## Etiqueta añadida por el supervisor (pantalla PTH1) 05/06/2019 15:08:13 (ADMIN)
######################################################################################
Subprog AM_ITMREF(VALEUR)
  Variable Char    VALEUR()
  Local Char LTIPOPRODUCTO

  LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM(VALEUR)
  # CONTROLAR QUE EL TIPO DE ARTICULO PERTENECE A LA TRANSACCIÓN EN LA QUE ESTAMOS

  If !clalev([ADI]) Then : Local File ATABDIV [ADI] : Endif

  Filter [F:ADI] Where NUMTAB = 6006 and A1 = GFLAG
  Read [F:ADI] First
  If !fstat Then
    Filter [F:ADI] Where NUMTAB = 6006 and A1 = GFLAG and A2 = LTIPOPRODUCTO
    Read [F:ADI] First
    If fstat Then # SI NO ENCONTRAMOS EL ARTICULO, MOSTRAR MENSAJE
      Infbox "No es posible introducir el artículo " + [M:PTH1]ITMREF(nolign-1) + " en la transacción " + GFLAG + ". Revise la Tabla de Transacciones y Tipos de Producto 6006."
      # mkstat = 2
    Endif
  Endif
  Filter [F:ADI]



End


######################################################################################

Subprog AS_ZNBLIC
  If nolign-1>[M:PTH1]NBLIG Then
    mkstat=2
  Endif
End



######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZPTH1) 10/07/2019 11:30:25 (ADMIN)
######################################################################################
Subprog AM_ZCALIDAD(VALEUR)
    Variable Char    VALEUR()
    Local Integer ESTAT

    If (VALEUR<>"")
        Call MODIF_CALIDAD(VALEUR, [M:PTH1]TSICOD1(nolign-1), [M:PTH1]TSICOD2(nolign-1),
&            [M:PTH1]TSICOD3(nolign-1), 2, ESTAT) From YSELAGRO
        If ESTAT=0 Then
            GERR=1
            # GMESSAGE=mess(12,1986,1)
            Infbox "Calidad no contemplada para el artículo seleccionado"
            mkstat=2
            EXISTE=1
        Endif
    Endif
    [M:PTH1]ZCALIDAD(nolign-1) = VALEUR
    Affzo [M:PTH1]ZCALIDAD(nolign-1)
End


