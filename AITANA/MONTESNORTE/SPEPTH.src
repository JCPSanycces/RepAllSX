## Etiqueta añadida por el supervisor (pantalla PTH1) 07/09/2019 08:35:47 (ADMIN)
######################################################################################
Subprog AM_ZBRUTOVEHI(VALEUR)
Variable Decimal VALEUR
  If VALEUR >=0 Then
    If [M:PTH1]ZTARAVEHI(nolign-1) > 0 and
&     [M:PTH1]ZTARAVEHI(nolign-1) < VALEUR Then
      [M:PTH1]QTYUOM(nolign-1) = VALEUR-[M:PTH1]ZTARAVEHI(nolign-1)
      Affzo [M:PTH1]QTYUOM(nolign-1)
    Else
      [M:PTH1]QTYUOM(nolign-1) = 1
      Affzo [M:PTH1]QTYUOM(nolign-1)
    Endif
  Endif

End


######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla PTH1) 07/09/2019 08:38:35 (ADMIN)
######################################################################################
Subprog AM_ZTARAVEHI(VALEUR)
Variable Decimal VALEUR

 If VALEUR >=0 and [M:PTH1]ZBRUTOVEHI(nolign-1) >= 0 and
&   [M:PTH1]ZBRUTOVEHI(nolign-1) > VALEUR Then
    [M:PTH1]QTYUOM(nolign-1) = [M:PTH1]ZBRUTOVEHI(nolign-1) - VALEUR
    Affzo [M:PTH1]QTYUOM(nolign-1)
  Endif
End


