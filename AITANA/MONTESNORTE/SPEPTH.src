#<AdxTL>@(#)0.0.0.0 $Revision$ Recepciones
#FRUTOS CÁSCARA - SUPPORT-3571 - XVT19082020 - RECÁLCULOS SEGÚN INDICACIONES ELENA
$ACTION
  Case ACTION
    When "AFFMASK" : Gosub AFFMASK
    When "LIENS" : Gosub LIENS
    When "APRES_CRE" : Gosub APRES_CRE
    When "APRES_ANNULE" : Gosub APRES_ANNULE
  Endcase
Return

###################################################################################
$LIENS
  Gosub LIENS_ZPTH1
  Gosub TITCOL_ZPTH1
Return

# 50 - FRU
# 21 - CER
# 70 - ALMAZARA
# 80 - 81 - BOG
# 90 - BOD

###################################################################################
$LIENS_ZPTH1
  If !clalev([ZPTD]) : Local File PRECEIPTD[ZPTD] : Endif
  Raz nolign
  nolign=0

  For [ZPTD]PTD0 Where PTHNUM=[M:PTH0]PTHNUM
      nolign+=1
      [M:ZPTH1] = [F:ZPTD]
  Next
  [M:ZPTH1]ZNBLIC = nolign
  nolign=0
  Affzo [M:ZPTH1]
Return


###################################################################################
$TITCOL_ZPTH1
  Call OCULTA_CAMPOS("PTH") From ZSPEMASKL
  Affzo [M:ZPTH1]

Return

###################################################################################
$AFFMASK
#ocultar calificaciones que no aplican por transacción
  If GFLAG="ALL" : Return : Endif

  Call OCULTA_CAMPOS("PTH") From ZSPEMASKL
  Affzo [M:ZPTH1]

#  If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif
#
#  Filter [F:ADI] Where NUMTAB=6100 and A1 = "PTH" and A2=GFLAG and A3="ZCANT1"
#  Read [F:ADI] First
#  If fstat : Chgfmt [M:PTH1]ZCANT1 With "-K:10" : Endif
#
#  Filter [F:ADI] Where NUMTAB=6100 and A1 = "PTH" and A2=GFLAG and A3="ZCANT2"
#  Read [F:ADI] First
#  If fstat : Chgfmt [M:PTH1]ZCANT2 With "-K:10" : Endif
#
#  Filter [F:ADI] Where NUMTAB=6100 and A1 = "PTH" and A2=GFLAG and A3="ZCALIDAD"
#  Read [F:ADI] First
#  If fstat : Chgfmt [M:PTH1]ZCALIDAD With "-K:10" : Endif
#
#  Filter [F:ADI] Where NUMTAB=6100 and A1 = "PTH" and A2=GFLAG and A3="ZGRADO"
#  Read [F:ADI] First
#  If fstat : Chgfmt [M:PTH1]ZGRADO With "-K:10" : Endif
#
#  Filter [F:ADI] Where NUMTAB=6100 and A1 = "PTH" and A2=GFLAG and A3="ZHUMEDAD"
#  Read [F:ADI] First
#  If fstat : Chgfmt [M:PTH1]ZHUMEDAD With "-K:10" : Endif
#
#  Filter [F:ADI] Where NUMTAB=6100 and A1 = "PTH" and A2=GFLAG and A3="ZRENDIMIENTO"
#  Read [F:ADI] First
#  If fstat : Chgfmt [M:PTH1]ZRENDIMIENTO With "-K:10" : Endif
#
#  Filter [F:ADI] Where NUMTAB=6100 and A1 = "PTH" and A2=GFLAG and A3="ZPESOESPE"
#  Read [F:ADI] First
#  If fstat : Chgfmt [M:PTH1]ZPESOESPE With "-K:10" : Endif
#
#  Filter [F:ADI] Where NUMTAB=6100 and A1 = "PTH" and A2=GFLAG and A3="ZPH"
#  Read [F:ADI] First
#  If fstat : Chgfmt [M:PTH1]ZPH With "-K:10" : Endif
#
#  Filter [F:ADI]


Return

$APRES_CRE
    ##---- Si la recepcion procede de una pesada, marcaremos la pesada como validada
    If [M:PTH0]BPSNDE <> "" and GIMPORT=1
        If clalev([F:XPE])=0 : Local File ZPESADAS    [XPE] : Endif

        Update [XPE] Where [XPE]FCY=[M:PTH0]PRHFCY and [XPE]PROV=[M:PTH0]BPSNUM
&        and [XPE]NUMPES=[M:PTH0]BPSNDE and [XPE]EJERCICIO=[M:PTH0]ZEJERCICIO
&        With TIMP = 2, PTHNUM = [M:PTH0]PTHNUM

        If fstat
            GOK=0 : Call FSTA("XPE") From GLOCK : Return
        Endif

        If clalev([F:XPE])>0 : Close Local File [XPE] : Endif
    Endif
    ##------------------------------------------------------------------------------
#    #----Si se trata de una recepción interplanta procedente de una entrega con Proyecto, eliminamos la referencia al proyecto EAP080720
#    Local Integer I
#    If [M:PTH0]BETCPY = 2
# For I=0 To [M]NBLIG-1
#          [M:PTH1]PJT(I)= ""
# Next I
#    Endif
Return

$APRES_ANNULE
  ##---- Si la recepcion procede de una pesada, marcaremos la pesada como NO validada
    If [M:PTH0]BPSNDE <> ""
        Local Char P_NUMPES : P_NUMPES=""
        If mid$([M:PTH0]BPSNDE,1,2)='20' Then
          P_NUMPES=right$([M:PTH0]BPSNDE,6)
        Else
          P_NUMPES=[M:PTH0]BPSNDE
        Endif
        If clalev([F:XPE])=0 : Local File ZPESADAS    [XPE] : Endif

        Update [XPE] Where [XPE]FCY=[M:PTH0]PRHFCY and [XPE]PROV=[M:PTH0]BPSNUM
&        and [XPE]NUMPES=P_NUMPES and [XPE]EJERCICIO=[M:PTH0]ZEJERCICIO
&        With TIMP = 1, PTHNUM = ""

        If fstat
            GOK=0 : Call FSTA("XPE") From GLOCK : Return
        Endif

        If clalev([F:XPE])>0 : Close Local File [XPE] : Endif
    Endif
    ##------------------------------------------------------------------------------
Return

######################################################################################
Subprog C_RCPDAT(VALEUR)
Variable Date    VALEUR
  Local Integer VEJERCICIO : VEJERCICIO=0
  Call GET_EJERCICIO("",[F:FCY]YTIPOFCY,VALEUR,VEJERCICIO) From ZLIBMONTES

  [M:PTH0]ZEJERCICIO=VEJERCICIO
  Affzo [M:PTH0]ZEJERCICIO
End
######################################################################################
Subprog C_ZEJERCICIO(VALEUR)
Variable Decimal VALEUR
  Local Integer POK : POK=0
  If VALEUR<>0 Then
     Call CHECK_EJERCICIO("",[F:FCY]YTIPOFCY,VALEUR,POK) From ZLIBMONTES
     If POK=0 Then
      Call MESSAGE ("Campaña no definida para este tipo de planta.") From GESECRAN
      VALEUR=0
     Endif
  Endif
End

