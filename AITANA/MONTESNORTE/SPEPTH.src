Subprog AM_ZHUMEDAD(VALEUR)
Variable Decimal VALEUR
  Local Char LTIPOPRODUCTO
  #If VALEUR <> 0 Then
    LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:PTH1]ITMREF(nolign-1))
    If LTIPOPRODUCTO = "21" Then # If GFLAG = "CER" Then # Transacción de CEREAL
      [M:ZPTH1]ZCANT1(nolign-1) =  func ZGESCALIF.C_HUMEDAD2CANTIDAD1(VALEUR, GFLAG, [M:PTH1]QTYSTU(nolign-1))
      Affzo [M:ZPTH1]ZCANT1
      [M:PTH1]ZCANT1(nolign-1) = [M:ZPTH1]ZCANT1(nolign-1)
      Affzo [M:PTH1]ZCANT1(nolign-1)
    Endif

    If LTIPOPRODUCTO = "50" Then # If GFLAG = "FRU" Then # Transacción de FRUTOS CON CASCARA
#XVT19082020.o      [M:ZPTH1]ZCANT2(nolign-1) =  func ZGESCALIF.FC_HUMEDAD2CANTIDAD2(VALEUR, GFLAG, [M:ZPTH1]QTYSTU(nolign-1) , [M:ZPTH1]ZCANT1(nolign-1))
#XVT19082020.bn
      [M:ZPTH1]ZCANT2(nolign-1) =  func ZGESCALIF.FC_HUMEDAD2CANTIDAD2(VALEUR, GFLAG, [M:ZPTH1]QTYSTU(nolign-1) , [M:ZPTH1]ZCANT1(nolign-1),[M:ZPTH1]ZRENDIMIENTO(nolign-1) )
#XVT19082020.en
      Affzo [M:ZPTH1]ZCANT2
      [M:PTH1]ZCANT2(nolign-1) = [M:ZPTH1]ZCANT2(nolign-1)
      Affzo [M:PTH1]ZCANT2(nolign-1)
    Endif
  #Endif
  [M:PTH1]ZHUMEDAD(nolign-1) = VALEUR
  Affzo [M:PTH1]ZHUMEDAD(nolign-1)
End


