######################################################################################
Subprog AM_ZCANT1(VALEUR)
Variable Decimal VALEUR
Local Char LTIPOPRODUCTO
  LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:PTH1]ITMREF(nolign-1))
  If VALEUR <> 0 Then
    If LTIPOPRODUCTO = "50" Then # If GFLAG = "FRU" Then # Transacción de FRUTOS CON CASCARA
#XVT19082020.o      [M:ZPTH1]ZCANT2(nolign-1) =  func ZGESCALIF.FC_HUMEDAD2CANTIDAD2([M:ZPHT1]ZHUMEDAD(nolign-1), GFLAG, [M:PTH1]QTYSTU(nolign-1) , VALEUR)
#xvt19082020.bn
      [M:ZPTH1]ZCANT2(nolign-1) = func ZGESCALIF.FC_HUMEDAD2CANTIDAD2([M:ZPHT1]ZHUMEDAD(nolign-1), GFLAG, [M:PTH1]QTYSTU(nolign-1) , VALEUR, [M:PTH1]ZRENDIMIENTO(nolign-1))
#XVT19082020.en
      Affzo [M:ZPTH1]ZCANT2
      [M:PTH1]ZCANT2(nolign-1) = [M:ZPTH1]ZCANT2(nolign-1)
      Affzo [M:PTH1]ZCANT2(nolign-1)
    Endif
    If LTIPOPRODUCTO = "81" Then
      [M:ZPTH1]ZCANT2(nolign-1) = func ZGESCALIF.U_CANTIDAD12CANTIDAD2(VALEUR, [M:ZPTH1]ZGRADO(nolign-1))
      Affzo [M:ZPTH1]ZCANT2
      [M:PTH1]ZCANT2(nolign-1) = [M:ZPTH1]ZCANT2(nolign-1)
      Affzo [M:PTH1]ZCANT2(nolign-1)
    Endif
  Endif
  [M:PTH1]ZCANT1(nolign-1) = VALEUR
  Affzo [M:PTH1]ZCANT1(nolign-1)

End


