######################################################################################
Subprog AM_ZGLUCONICO(VALEUR)
Variable Decimal VALEUR
Local Decimal LPUNTOS
Local Char LRES
Local Char LTIPOUVA
Local Decimal S_GRADO
 # HACER LOS CALCULOS QUE CORRESPONDAN AUNQUE EL VALOR DEL GLUCÓNICO SEA CERO
 # If VALEUR <> 0 Then

    If func ZLIBMONTES.GET_TIPOITEM([M:PTH1]ITMREF(nolign-1)) = "90" Then  # If GFLAG = "BOD" Then # Transacción de BODEGA
      LRES = func ZGESCALIF.U_PUNTOS2CALIDAD([M:ZPTH1]ZPH(nolign-1),[M:ZPTH1]ZPOTASIO(nolign-1),VALEUR, GFLAG, [M:ZPTH1]ZCALIDAD(nolign-1), LPUNTOS)
      If LRES <> '' Then
          [M:ZPTH1]ZCALIDAD(nolign-1) = LRES
          [M:ZPTH1]ZPUNTOS(nolign-1) = LPUNTOS
      Endif
      Affzo [M:ZPTH1]ZCALIDAD
      Affzo [M:ZPTH1]ZPUNTOS
      [M:PTH1]ZCALIDAD(nolign-1) = [M:ZPTH1]ZCALIDAD(nolign-1)
      [M:PTH1]ZPUNTOS(nolign-1) = [M:ZPTH1]ZPUNTOS(nolign-1)
      Affzo [M:PTH1]ZCALIDAD(nolign-1)
      Affzo [M:PTH1]ZPUNTOS(nolign-1)
    Endif
    If func ZLIBMONTES.GET_TIPOITEM([M:PTH1]ITMREF(nolign-1)) = "90" Then # If GFLAG = "BOD" Then
      # COMO SABEMOS SI ES UVA BLANCA O TINTA ?????
      LTIPOUVA = func ZLIBMONTES.GET_TIPOUVA([M:PTH1]ITMREF(nolign-1))
      S_GRADO = func ZGESCALIF.U_GLUCONICO2GRADO(VALEUR ,LTIPOUVA, GFLAG)
      If S_GRADO>0 Then
        [M:ZPTH1]ZGRADO(nolign-1)=S_GRADO
      Endif
      Affzo [M:ZPTH1]ZGRADO
      [M:PTH1]ZGRADO(nolign-1) = [M:ZPTH1]ZGRADO(nolign-1)
      Affzo [M:PTH1]ZGRADO(nolign-1)
    Endif
#  Endif
  [M:PTH1]ZGLUCONICO(nolign-1) = VALEUR
  Affzo [M:PTH1]ZGLUCONICO(nolign-1)
End
######################################################################################
Subprog AM_ZGRADO(VALEUR)
Variable Decimal VALEUR
Local Char LTIPOPRODUCTO

  LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:PTH1]ITMREF(nolign-1))
  If VALEUR <> 0 Then
    If LTIPOPRODUCTO = "90" or LTIPOPRODUCTO = "81" Then # "BOD"
      Call B_UVA_GRADO2CANTIDAD1(VALEUR,[M:PTH1]QTYSTU(nolign-1),[M:ZPTH1]ZCANT1(nolign-1)) From ZGESCALIF
      Affzo [M:ZPTH1]ZCANT1(nolign-1)
      [M:PTH1]ZCANT1(nolign-1) = [M:ZPTH1]ZCANT1(nolign-1)
      Affzo [M:PTH1]ZCANT1(nolign-1)
    Endif
    # Infbox LTIPOPRODUCTO
    If LTIPOPRODUCTO = "81"  Then # MOSTO
      [M:ZPTH1]ZDENSIDAD(nolign-1) = func ZGESCALIF.U_GRADO2DENSIDAD(VALEUR)
      # Infbox num$([M:PTH1]ZDENSIDAD(nolign-1))
      Affzo [M:ZPTH1]ZDENSIDAD
      [M:PTH1]ZDENSIDAD(nolign-1) = [M:ZPTH1]ZDENSIDAD(nolign-1)
      Affzo [M:PTH1]ZDENSIDAD(nolign-1)
    Endif
    # AL MODIFICAR ZCANT1, TAMBIEN MODIFICO LA ZCANT2
    If LTIPOPRODUCTO = "80" or LTIPOPRODUCTO = "81" Then # VINO Y MOSTO
      [M:ZPTH1]ZCANT2(nolign-1) = func ZGESCALIF.U_CANTIDAD12CANTIDAD2([M:ZPTH1]ZCANT1(nolign-1), VALEUR)
      Affzo [M:ZPTH1]ZCANT2(nolign-1)
      [M:PTH1]ZCANT2(nolign-1) = [M:ZPTH1]ZCANT2(nolign-1)
      Affzo [M:PTH1]ZCANT2(nolign-1)
    Endif
  Endif
  [M:PTH1]ZGRADO(nolign-1)=VALEUR
  Affzo [M:PTH1]ZGRADO(nolign-1)
End
######################################################################################
Subprog AM_ZPESOESPE(VALEUR)
Variable Decimal VALEUR
  [M:PTH1]ZPESOESPE(nolign-1)=VALEUR
  Affzo [M:PTH1]ZPESOESPE(nolign-1)
End
######################################################################################
Subprog AM_ZPH(VALEUR)
Variable Decimal VALEUR
Local Decimal LPUNTOS
Local Char LRES
# If VALEUR <> 0 Then # AUNQUE EL PH SEA CERO TAMBIEN DEBE DE SUMAR LOS PUNTOS
    If func ZLIBMONTES.GET_TIPOITEM([M:PTH1]ITMREF(nolign-1)) = "90" Then # If GFLAG = "BOD" Then # Transacción de BODEGA
      LRES = func ZGESCALIF.U_PUNTOS2CALIDAD(VALEUR,[M:ZPTH1]ZPOTASIO(nolign-1),[M:ZPTH1]ZGLUCONICO(nolign-1), GFLAG, [M:ZPTH1]ZCALIDAD(nolign-1), LPUNTOS)
      If LRES <> '' Then
          [M:ZPTH1]ZCALIDAD(nolign-1) =  LRES
          [M:ZPTH1]ZPUNTOS(nolign-1) = LPUNTOS
          Affzo [M:ZPTH1]ZCALIDAD
          Affzo [M:ZPTH1]ZPUNTOS
          [M:PTH1]ZCALIDAD(nolign-1) =  LRES
          [M:PTH1]ZPUNTOS(nolign-1) = LPUNTOS
          Affzo [M:PTH1]ZCALIDAD
          Affzo [M:PTH1]ZPUNTOS
      Endif
    Endif
#  Endif
  [M:PTH1]ZPH(nolign-1)=VALEUR
  Affzo [M:PTH1]ZPH(nolign-1)

End
######################################################################################
Subprog AM_ZPOTASIO(VALEUR)
Variable Decimal VALEUR
Local Decimal LPUNTOS
Local Char LRES
# If VALEUR <> 0 Then # AUNQUE EL POTASIO SEA CERO TAMBIEN DEBE DE SUMAR LOS PUNTOS
    If func ZLIBMONTES.GET_TIPOITEM([M:PTH1]ITMREF(nolign-1)) = "90" Then # Transacción de BOD
      LRES =  func ZGESCALIF.U_PUNTOS2CALIDAD([M:ZPTH1]ZPH(nolign-1),VALEUR,[M:ZPTH1]ZGLUCONICO(nolign-1), GFLAG, [M:ZPTH1]ZCALIDAD(nolign-1), LPUNTOS)
      If LRES <> '' Then
        [M:ZPTH1]ZCALIDAD(nolign-1) = LRES
        [M:PTH1]ZCALIDAD(nolign-1) = LRES

        [M:ZPTH1]ZPUNTOS(nolign-1) = LPUNTOS
        [M:PTH1]ZPUNTOS(nolign-1) = LPUNTOS
      Endif
      Affzo [M:ZPTH1]ZCALIDAD
      Affzo [M:ZPTH1]ZPUNTOS
    Endif
#  Endif
  [M:PTH1]ZPOTASIO(nolign-1)=VALEUR
  Affzo [M:PTH1]ZDENSIDAD(nolign-1)
End


######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla PTH1) 04/06/2019 17:19:22 (ADMIN)
######################################################################################
Subprog AM_ZDENSIDAD(VALEUR)
Variable Decimal VALEUR
Local Char LTIPOPRODUCTO
  If VALEUR <> 0 Then
    LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:PTH1]ITMREF(nolign-1))
    If LTIPOPRODUCTO = '81' or LTIPOPRODUCTO = '80' Then
      [M:ZPTH1]ZCANT1(nolign-1) = func ZGESCALIF.U_DENSIDAD2CANT1([M:PTH1]QTYUOM(nolign-1), VALEUR)
      [M:PTH1]ZCANT1(nolign-1) = [M:ZPTH1]ZCANT1(nolign-1)
      Affzo [M:ZPTH1]ZCANT1
      Affzo [M:PTH1]ZCANT1
    Endif
    If LTIPOPRODUCTO = "80" or LTIPOPRODUCTO = "81" Then # VINO Y MOSTO
      [M:ZPTH1]ZCANT2(nolign-1) = func ZGESCALIF.U_CANTIDAD12CANTIDAD2([M:ZPTH1]ZCANT1(nolign-1), VALEUR)
      Affzo [M:ZPTH1]ZCANT2(nolign-1)
      [M:PTH1]ZCANT2(nolign-1) = [M:ZPTH1]ZCANT2(nolign-1)
      Affzo [M:ZPTH1]ZCANT2(nolign-1)
      Affzo [M:PTH1]ZCANT2(nolign-1)
    Endif
  Endif
  [M:PTH1]ZDENSIDAD(nolign-1)=VALEUR
  Affzo [M:PTH1]ZDENSIDAD(nolign-1)
End


