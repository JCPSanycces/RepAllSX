#<AdxTL>@(#)12.0.0.0 $Revision$
######################################################################################
### ZLECREND -- Lectura Ficheros Pesadas
######################################################################################
$ACTION
    Case ACTION
        When "OUVRE_BATCH"  : Gosub OUVRE_BATCH_ZLECREND
        When "INIT"         : Gosub INIT_ZLECREND
        When "EXEC"         : Gosub EXEC_ZLECREND
        When "TERMINE"      : Gosub TERMINE_ZLECREND
        When "INIT_DIA"     : Gosub INIT_DIA_ZLECREND
        When "OK"           : Gosub OK_ZLECREND
        When "END"          : Gosub END_ZLECREND
        When "FINREQ"       : Gosub FINREQ
    Endcase
Return
######################################################################################
$OUVRE_BATCH_ZLECREND
    Gosub OPEN_FILE
Return
######################################################################################
$INIT_ZLECREND
    Gosub OPEN_FILE
Return
######################################################################################
$OPEN_FILE
    If clalev ([F:ZRA])<=0  : Local File ZRENDACE   [ZRA] : Endif
    If clalev ([F:PTH])<=0  : Local File PRECEIPT   [PTH] : Endif
    If clalev ([F:PTD])<=0  : Local File PRECEIPTD  [PTD] : Endif
    If clalev ([F:FCY])<=0  : Local File FACILITY   [FCY] : Endif
    If clalev ([F:ZPTH])<=0 : Local File ZPRECEIPT  [ZPTH]: Endif

    If GSERVEUR
        #----- Ouverture fichier trace et écriture des sélections -----#
        Call ECR_TRACE(" ",0)                From GESECRAN
        Call ECR_TRACE(string$(88,"-"),0)    From GESECRAN
        Call PRTSCR("ZLECREND","DIA","",0,1) From ATRTX3
        Call ECR_TRACE(" ",0)                From GESECRAN
    Endif
Return
######################################################################################
$TERMINE_ZLECREND
    If !GSERVEUR
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE   From LECFIC
        Return
    Endif
Return
######################################################################################
$INIT_DIA_ZLECREND
    Raz [M:DIA]
Return
######################################################################################
$OK_ZLECREND
Infbox "ok"
    FIN  = 1
Return
######################################################################################
$END_ZLECREND
    Raz [M:DIA]
    FIN = 1
Return
######################################################################################
######################################################################################
$EXEC_ZLECREND

    Local Char    ORI
    Local Integer ZERROR_IMP
    Local Integer ESTAT
    Local Char    FICHERO_DES(GDIMFIC)

    If GSERVEUR
        Onerrgo ERRBATCH
    Else
        Call OUVRE_TRACE("Importación Ficheros RENDIMIENTOS")  From LECFIC

        #----- Ouverture fichier trace et écriture des sélections -----#
        Call ECR_TRACE(" ",0)                From GESECRAN
        Call ECR_TRACE(string$(88,"-"),0)    From GESECRAN
        Call PRTSCR("ZLECREND","DIA","",0,1) From ATRTX3
        Call ECR_TRACE(" ",0)                From GESECRAN
    Endif

    Call TEMPON("E") From GESECRAN

    ###--- Aqui haremos el bucle de los ficheros
    Local Char    LISTEFIC(GDIMFIC)(1..3000)
    Local Integer ZERROR  : ZERROR  = 0
    Local Integer ZNUMFIC : ZNUMFIC = 0
    Call BUSCAR_FICHEROS([M:DIA]FICHERO,LISTEFIC,ZNUMFIC,ZERROR) From ZFICEXPIMP
    For ZNUMF=1 To ZNUMFIC
        ZERROR_IMP = 0

        Raz FICHERO_DES
        Call BUSCAR_NOM(LISTEFIC(ZNUMF),FICHERO_DES)

        Call GENERAR_FICHERO(LISTEFIC(ZNUMF),FICHERO_DES,ZERROR_IMP)

        If ZERROR_IMP = 0
            Raz FICHERO_DES
            Call BUSCAR_NOM(LISTEFIC(ZNUMF),FICHERO_DES)

            Read [ZRA]ZRA1 = FICHERO_DES
            If fstat
                Raz [ZRA]
                Call ECR_TRACE("Fichero " +  FICHERO_DES + " processado incorrectamente.",1) From GESECRAN

                FICHERO_DES = [M:DIA]DIRECERR + FICHERO_DES
                Call MOVE(LISTEFIC(ZNUMF),[M:DIA]DIRECERR,ESTAT) From ORDSYS
                If ESTAT Then : Return : Endif

            Else
                Call ECR_TRACE("Fichero " +  FICHERO_DES + " processado correctamente.",0) From GESECRAN

                FICHERO_DES = [M:DIA]DIRECFIN + FICHERO_DES
                Call MOVE(LISTEFIC(ZNUMF),[M:DIA]DIRECFIN,ESTAT) From ORDSYS
                If ESTAT Then : Return : Endif
            Endif
        Else
            Call ECR_TRACE("Fichero " +  FICHERO_DES + " processado incorrectamente.",1) From GESECRAN
        Endif
    Next

    Call TEMPOFF From GESECRAN
Return
######################################################################################
Subprog GENERAR_FICHERO(FICHERO,ZNOM_FICHERO,ZERROR_IMP)
    Value    Char     FICHERO()
    Value    Char     ZNOM_FICHERO
    Variable Integer  ZERROR_IMP

    Local    Char     FICHEROORI(200)
    Local    Char     PR(GDIMFIC)
    Local    Integer  L
    Local    Integer  ZFSTAT

    Local    Char     ZTEXTO(100)
    Local    Char     ZNUMDOC(20)
    Local    Decimal  ZREND

    Local    Integer  ANT,SIG
    Local    Char     TEXTO_ERROR(80)

    Local    Integer  ZTMOD
    Local    Integer  ZTERROR
    Local    Integer  ZTIMP
    Local    Char     ZPTHNUM

    FICHEROORI = FICHERO

    Openi   FICHEROORI,0 Using [CON]
    Iomode  adxifs chr$(13)+chr$(10) Using [CON]
    Iomode  adxium 50 Using [CON]

    Repeat
        Rdseq PR Using [CON]
        Raz ZFSTAT
        ZFSTAT = fstat

        L=len(PR)
        If PR<>'' & L>1
            Raz ZTEXTO,ZNUMDOC,TEXTO_ERROR
            Raz ZREND

            TEXTO_ERROR = " "
            I = find(";", PR)
            ANT = 1
            SIG = instr(ANT, PR, ';')

            ZTEXTO     = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = len(PR)
            ZNUMDOC    = vireblc(mid$(ZTEXTO,I+1,len(ZTEXTO)-I),2)

            ZTEXTO     = vireblc(mid$(PR,ANT,SIG-ANT+1),2) : ANT = SIG+1 : SIG = len(PR)
            Call REMPLAZAR_CAR(ZTEXTO,',','.') From XCONTROLES
            ZREND   = val(ZTEXTO)

            Read [ZPTH]ZPTH0= [M:DIA]TIPOFCY;val([M:DIA]EXERCICI);ZNUMDOC
            If !fstat Then
               Read [PTH]PTH0= [F:ZPTH]PTHNUM
               If fstat : Raz[PTH] : Endif
            Else
              Raz [ZPTH]
              Raz [PTH]
            Endif
#           Read [PTH]ZPTH1 = [M:DIA]TIPOFCY;[M:DIA]EXERCICI;ZNUMDOC  : If fstat Raz [PTH] : Endif
#XVT20190515.bo   EL SIGUIENTE CÓDIGO BUSCA PESADAS A NIVEL DE LÍNEAS DE RECEPCIÓN Y NO LO VAMOS A USAR
#           If [F:PTH]PTHNUM = ""
#                Raz [PTD]
#                For [PTD] Where YTIPOFCY = [M:DIA]TIPOFCY and YEXERCICI = [M:DIA]EXERCICI and YNUMPESAD = ZNUMDOC
#                    ZPTHNUM = [F:PTD]PTHNUM
#                    Break
#                Next
#                Read [PTH]PTH0 = ZPTHNUM : If fstat Raz [PTH] : Endif
#            Endif
#XVT20190515.eo
            Read [FCY]FCY0  = [F:PTH]PRHFCY
            If fstat : Raz [FCY] : Endif

            If [F:PTH]PTHNUM <> "" or ZREND <> 0

            Read [ZRA]ZRA0 = [F:PTH]PRHFCY;[F:PTH]PTHNUM
                If fstat
                    Raz [ZRA]
                    [F:ZRA]FCY     = [F:PTH]PRHFCY
                    [F:ZRA]NUMPES  = ZNUMDOC
                    [F:ZRA]NUMDOC  = [F:PTH]PTHNUM
                    [F:ZRA]FECHA   = [F:PTH]RCPDAT
                    [F:ZRA]REND    = ZREND
                    [F:ZRA]FICHERO = ZNOM_FICHERO
                    [F:ZRA]TGEN    = 1

                    Write [ZRA]
                    If fstat
                        GOK=0
                        ZERROR_IMP = 1
                        Call FSTA("ZRA") From GLOCK
                        Call ECR_TRACE("   Pesada " +  ZNUMDOC + " processada incorrectamente.",1) From GESECRAN
                    Else
                        Call ECR_TRACE("   Pesada " +  ZNUMDOC + " processada correctamente.",0) From GESECRAN
                    Endif
                Else
                    Call ECR_TRACE("   Pesada " +  ZNUMDOC + " ya processada anteriormente",1) From GESECRAN
                Endif
            Else
                If [F:PTH]PTHNUM = ""
                    Call ECR_TRACE("   Pesada " +  ZNUMDOC + " no econtrada en el sistema.",1) From GESECRAN
                Else
                    Call ECR_TRACE("   Pesada " +  ZNUMDOC + " rendimiento a 0.",1) From GESECRAN
                Endif
            Endif
       Endif
    Until ZFSTAT <> 0 #fstat <> 0

    Openi Using [CON]
End
######################################################################################
$ERRBATCH
    Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
######################################################################################
$FINREQ
    If [F:ABR]TACHE = "ZLECREND"
        If OKRQT <> 1 : OKRQT = 1 : Endif
    Endif
Return
######################################################################################
Subprog BUSCAR_NOM(ZFICHERO,ZNOM)
    Value    Char    ZFICHERO
    Variable Char    ZNOM
    Local    Char    ZNOM2

    For I=0 To len(ZFICHERO)
        If mid$(ZFICHERO,I,1) = "\"
            Raz ZNOM2
        Else
            ZNOM2 += mid$(ZFICHERO,I,1)
        Endif
    Next

    For I=0 To len(ZNOM2)
        If mid$(ZNOM2,I,1) = "."
            Break
        Else
            ZNOM += mid$(ZNOM2,I,1)
        Endif
    Next
End
######################################################################################
Subprog AM_FCY(VALEUR)
    Variable Char    VALEUR()

    Read [FCY]FCY0 = VALEUR
    If fstat : Raz [FCY] : Endif

    [M]TIPOFCY = [F:FCY]YTIPOFCY
    Affzo [M]TIPOFCY

End
######################################################################################

