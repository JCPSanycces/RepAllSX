#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)7.0.0.0 $Revision$
######################################################################################
### YCALLIQ - Calculo de Liquidaciones    -- Ultima revisión 24/03/2008 JGM --     ###
######################################################################################
#XVT2019/05/19 adaptacion a v11
#v11
#XVT15-05-2020 - Las líneas de anticipo deben agruparse por planta de recepción, además
#de los criterios actuales. Este desarrollo se combina con punto de entrada ZSUBPIHB
#y el campo PINVOICED.ZFCYLIN
#XVT22-05-2020 S3501 - Validación con representación recibo agrario
#XVT09-06-2020 S3467 - En simulación añadir tercero
$ACTION
  #  If GUSER="ADMIN" : Infbox "YARYCQ : Admin " + ACTION : Endif
    Case ACTION
        When "OUVRE"            : Gosub OUVRE
        When "DEBUT"            : Gosub DEBUT
   #     When "OK"               : Gosub OK
        When Default
    Endcase
Return
######################################################################################
$OUVRE
    Global Char     RUTA(200)
    Global Char     FICHERODESTINO(200)
    Global Char     GDOCORIGEN
    Global Integer  GDOCDESTI
    Global Char     GTRANSORIGEN

#v11.o    If clalev([F:YTD])=0 : Local File YTIPDOC    [YTD] : Endif
    If clalev([F:YT0])=0 : Local File YTPCABEC   [YT0] : Endif
    If clalev([F:YT1])=0 : Local File YTPLINEAS  [YT1] : Endif
    If clalev([F:YLC])=0 : Local File YTPLINPER  [YLC] : Endif
    If clalev([F:PTH])=0 : Local File PRECEIPT   [PTH] : Endif
    If clalev([F:PTD])=0 : Local File PRECEIPTD  [PTD] : Endif
    If clalev([F:PTX])=0 : Local File PRECEIPTD  [PTX] : Endif
    If clalev([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif
    If clalev([F:PID])=0 : Local File PINVOICED  [PID] : Endif
    If clalev([F:YLQ])=0 : Local File YACLINLIQ  [YLQ] : Endif
    If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
    If clalev([F:APX])=0 : Local File APARIMPEXP [APX] : Endif
    If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
    If clalev([F:PNH])=0 : Local File PRETURN    [PNH] : Endif
    If clalev([F:PND])=0 : Local File PRETURND   [PND] : Endif
    If clalev([F:XT0])=0 : Local File YTPCABEC   [XT0] : Endif
    If clalev([F:XT1])=0 : Local File YTPLINEAS  [XT1] : Endif
    If clalev([F:ITP])=0 : Local File ITMBPS     [ITP] : Endif
    If clalev([F:ITX])=0 : Local File ITMMASTER  [ITX] : Endif
    If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
    If clalev([F:YVC])=0 : Local File YTAUVALOR  [YVC] : Endif
    If clalev([F:YVL])=0 : Local File YLINVALOR  [YVL] : Endif
    If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
    If clalev([F:POQ])=0 : Local File PORDERQ    [POQ] : Endif
    If clalev([F:YPL])=0 : Local File YPLANTACI  [YPL] : Endif
    If clalev([F:CAL])=0 : Local File CPTANALIN  [CAL] : Endif
    If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
    If clalev([F:ZPL])=0 : Local File ZPRELIQ    [ZPL] : Endif
    If clalev([F:YPS])=0 : Local File YPERSEC    [YPS] : Endif  #XVT22-05-2020.n


#v11.o    If clalev([F:ZYC1])=0 : Local File YACCABCAL  [ZYC1] : Endif

    ##---Punto de entrada para poder añadir las lineas.
    GPOINT = "OUVRE" : Gosub ENTREE From EXEFNC
Return
######################################################################################
$DEBUT
    Raz [M:YCQ]

    Affzo [M:YCQ]
#v11.bo
#    If [M:YCQ]MULTIFCY = 1
#        Grizo [M:YCQ]TIPOFCY
#        Raz [M:YCQ]TIPOFCY
#        Actzo [M:YCQ]FCY
#    Else
#        Grizo [M:YCQ]FCY
#        Raz [M:YCQ]FCY
#        Actzo [M:YCQ]TIPOFCY
#    Endif
#v11.eo
Return
######################################################################################
$OK
 #Infbox "OK"
    Local Integer RESP,ERROR_LIQ
    RESP =2
    Qstbox mess(285,9139,1) Using RESP Sleep 10

    If RESP = 1
        Call TEMPON("E") From GESECRAN
        ###--- Funcion de crear el fichero con la liquidacion/anticipo ---###
        Call CREAR_LIQUIDACION
        Kill LINEA_YLQ
        Call TEMPOFF From GESECRAN
    Endif

Return
######################################################################################
######################################################################################
## Proceso de Creación de Liquidaciones.
######################################################################################
Subprog CREAR_LIQUIDACION
    Global   Integer LINEA_YLQ : LINEA_YLQ = 0
    Global   Integer LINEA     : LINEA = 0
    Local    Integer CREA_CAB,CREA_LIN,TIPOFCY
    Local    Decimal PRECIO,IMPORTE,IMPORTE_R,IMP,IMPORTE_DEV,CANTIDAD,CANTIDAD_DEV
    Local    Decimal KGORIGEN,KGBRUTS,KGVEHIC,KGTARA,QUANT1,QUANT2,QUANT3
    Local    Decimal KGORIGEN_DEV,KGBRUTS_DEV,KGVEHIC_DEV,KGTARA_DEV,QUANT1_DEV,QUANT2_DEV,QUANT3_DEV
    Local    Decimal DISC1,DISC2,DISC3,DISC3,DISC4,DISC5,DISC6,DISC7,DISC8,DISC9
    Local    Decimal INV(0..8),INV_IMP(0..8)
    Local    Char    SEP,IVA,RETEN,RETEN1,CLASIFIC,PLANTACIO,VAC,TEST,FCY_LIQ,PLANTA_LIQ,TESTANT
    Local    Char    VAT(GLONVAT)(3)
    Local    Char    GNUM,PLANTA_REC,TIPODOC_F,DOCU,CALIDAD,PTE
    Local    Integer STAT
    Local    Integer ERROR
    Local    Decimal DISCRGVAL(0..8), NETPRI
    Local    Decimal DTO_AI,DTO_II,REC_AI,REC_II
    Local    Char    CRITERE(250),CRITERE2(250),CRITERE3(250)
    Local    Char    CRITEREO(250)
    Local    Decimal IMPORTE_TOT
    Local    Char    CCE1_R,CCE2_R,CCE3_R,CCE4_R,CCE5_R,CCE6_R,CCE7_R,CCE8_R,CCE9_R
    Local    Char    CCE1_A,CCE2_A,CCE3_A,CCE4_A,CCE5_A,CCE6_A,CCE7_A,CCE8_A,CCE9_A
    Local    Char    CCE_R(15)(1..20)
    Local    Char    CCE_A(15)(1..20)
    Local    Char    PROVEEDOR, RECEPCION, PEDIDO,PROV_PAG
    Local    Integer RECEP_LIN,PEDIDO_POP,PEDIDO_POQ
    Local    Integer LINEA_ANT
    Local    Integer LINEA_INS
    Local    Char    PROV_VAT, CAMPO
    Local    Char    CALIDAD_LIN, RECOLL_LIN
    Local    Decimal CALIFPRI_LIN,CALIFSEC_LIN
    Local    Integer EXISTE_CALIDAD
    Local    Char    CRIT_TIPLIQ
    Local    Integer ZMODFCY
    Local    Char    PTHNUM_LIN
    Local    Integer PTDLIN_LIN
    Local    Integer MODALIT_PREU
    Local    Char    STA(1)     #V11.N
    Local    Char    TYPORI(1)  #V11.N  ##2 RECEPCION   -   5 VARIO
    Local    Char    NUMORI(20) #V11.N  ##NÚMERO DE RECEPCIÓN
    Local    Char    LINORI(10) #V11.N  ##LÍNEA DE RECEPCIÓN
    Local    Char    VFCYDEB(5), VFCYFIN(5)
    Local    Char    FORMULAPRECIO(200)
    Local    Integer POSZ
    Local    Decimal ZRENDIMIENTO
    Local    Char    ANTFCY(5)    #XVT15-05-2020.N
    Local    Char    ZFCYLIN(5)   #XVT15-05-2020.N
    Local    Decimal ZIMPORTESIMUL : ZIMPORTESIMUL=0
    Local    Char    ZREPRECAG(1) #XVT22-05-2020.n

    ERROR = 0

    Call OUVRE_TRACE("Generación de Factura de Liquidaciones") From LECFIC
    RUTA = "E:\IMPORTEXPORT\LIQUIDACIONES\"+nomap
    LSEP = '|'

    Local Decimal NUM_VEN,  TOTAL_VEN
    Local Integer INTE_VEN

    Call OUVRE_BOITE("Calculo de liquidaciones", TOTAL_VEN) From GESECRAN
    Filter [YLC] Where NUMDOC=[M:YCQ]NUMDOC and TESTACTIU = 2 and TFACGEN <> 2
    TOTAL_VEN = rowcount([F:YLC])
    Filter [YLC]

    If TOTAL_VEN =0 : TOTAL_VEN = 1: Endif
    Call SET_BOITE("Calculo de liquidaciones", TOTAL_VEN) From GESECRAN

    #leer la cabecera de liquidación
     Read [YT0]YT00 = [M:YCQ]NUMDOC
      If fstat
          Raz [F:YT0]
          ERROR = 1
          End
      Endif

    ## --- Bucle de proveedores de precios de liquidaciones --- ##
    For [YLC]YLC0 Where NUMDOC=[M:YCQ]NUMDOC and TFACGEN <> 2
    NUM_VEN += 100/TOTAL_VEN
    If ERROR : Break : Endif
    Call AFF_BOITE("Procesando tercero : " + [F:YLC]CODIPERSON , NUM_VEN, INTE_VEN) From GESECRAN

        PROV = [F:YLC]CODIPERSON
        PLANTA_LIQ = ""
        CREA_CAB = 0
        LINEA_YLQ = 0

#XVT22-05-2020.bn
#TRATAMIENTO DE FACTURAS DE SOCIOS CON FIRMA DELEGADA (VALIDAR POR PROCESO A POSTERIORI)
        ZREPRECAG="1"
        Read [F:FCY]FCY0=[YT0]FCY
        If !fstat Then
          Read [F:YPS]YPS0=[YLC]CODIPERSON;[F:FCY]YTIPOFCY;[F:FCY]LEGCPY
          If !fstat Then
            ZREPRECAG=num$([F:YPS]REPRECAG)
          Endif
        Endif
#XVT22-05-2020.en

        STA="1"  ## NO VALIDADA

        If [M:YCQ]SIMULADO <> 2 Then
          FICHERODESTINO = filpath(RUTA,num$(adxuid(1))+"_LQ" + num$([F:YLC]NUMLIN),"TXT")
          Openo FICHERODESTINO,0 Using [LIQ]

        ##CREACIÓN DEL FICHERO DE FACTURA
        ##CREACIÓN DE LA CABECERA DE FACTURA, EN CUALQUIER CASO.
#XVT22-05-2020.n AÑADO LA REPRESENTACIÓN EN RECIBO AGRARIO DESPUÉS DE STA
           Wrseq "E" + LSEP + [YT0]FCY + LSEP + [M:YCQ]PIVTYP + LSEP + "" + LSEP + format$("D:YYYYMMDD",[M:YCQ]DATAFAC) + LSEP +
&         [YLC]CODIPERSON + LSEP + num$([YT0]EJERCICIO) + LSEP + format$("D:YYYYMMDD",[M:YCQ]DATAFAC) + LSEP +
&         [YT0]NUMDOC + LSEP + [YLC]CODIPERSON + LSEP + "EUR" + LSEP + format$("D:YYYYMMDD",[M:YCQ]DATAFAC) + LSEP +
&         [M:YCQ]PTE + LSEP + STA + LSEP + ZREPRECAG +  chr$(13)
&         Using [LIQ]
        Endif
         LSEP=";"
         Call ECR_TRACE ("L" + LSEP + "TIPO_ORIGEN" + LSEP + "ENTREGA_CTA" + LSEP + "LINEA" + LSEP + "PLANTA_REC" + LSEP + "RECEPCION" + LSEP + "ARTICULO" + LSEP + "UNIDAD" + LSEP
&                + "CANTIDAD" + LSEP + "PRECIO" + LSEP + "CALIDAD"
&                + LSEP + "IMPORTE" + LSEP + "TERCERO" ,0)
&                From GESECRAN
         LSEP="|"

        ## --- Bucle de resta de entregas a cuenta sólo para liquidaciones --- ##
        If [YT0]ANTILIQ <> 1 Then
          ##SÓLO LIQUIDACIONES - BUCLE 1

           Gosub INIT_BUCLE_ARTI
           ##se crea las líneas en negativo de todas las entregas a cuenta
           ## del artículo / calidad actual, en  la planta actual.
           ##RESTA## HAY QUE BUSCAR LAS FACTURAS (LINEAS) DE ARTÍCULOS QUE APARECEN EN ESTE PRECIOS LIQUIDACIONES
           ## PARA ELLO USAREMOS UN LINK CON LA [YT1]
            Link [PID] With [PIH]PIH0=NUM, [YT1]YT11=[YT0]FCY;[YT0]EJERCICIO;[PID]ITMREF;[PID]ZCALIDAD;[YT0]NUMDOC As [ECTA]
&           Where [PIH]BPR=[YLC]CODIPERSON
&           and [PIH]PIVTYP="ELQ" and [PIH]ZEJERCICIO=[YT0]EJERCICIO
&           and [PIH]FCY=[YT0]FCY
            For [ECTA]
              CANTIDAD = [ECTA]QTYSTU
              TYPORI = "5" ## VARIO
              NUMORI = ""
              LINORI = "0"
              #SE INDICA EN LA LÍNEA EL Nº DE ENTREGA A CUENTA QUE ESTÁ RESTANDO


#XVT15-05-2020.n añadido el nuevo campo planta recepción CCE:   " + [ECTA]ZFCYLIN + LSEP"
              If [M:YCQ]SIMULADO <> 2 Then
                Wrseq "L" + LSEP + TYPORI + LSEP + "" + LSEP + LINORI + LSEP + [ECTA]ZFCYLIN + LSEP + [ECTA]NUM + LSEP + [ECTA]ITMREF + LSEP + [ECTA]STU + LSEP
&                + num$(CANTIDAD) + LSEP + num$(-[ECTA]GROPRI) + LSEP + [ECTA]ZCALIDAD
&                + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + chr$(13)
&                Using [LIQ]
              Endif

              #traza
              LSEP=";"
              ZIMPORTESIMUL+=CANTIDAD*(-[ECTA]GROPRI)
              Call ECR_TRACE ("L" + LSEP + TYPORI + LSEP + "" + LSEP + LINORI + LSEP + [ECTA]ZFCYLIN + LSEP + [ECTA]NUM + LSEP + [ECTA]ITMREF + LSEP + [ECTA]STU + LSEP
&                + num$(CANTIDAD) + LSEP + num$(-[ECTA]GROPRI) + LSEP + [ECTA]ZCALIDAD
&                + LSEP + num$(-[ECTA]GROPRI*CANTIDAD) + LSEP + [YLC]CODIPERSON ,0)
&                From GESECRAN
              LSEP="|"
            Next

        Endif # sólo en liquidaciones

        ## --- Bucle normal de articulos de precios de liquidaciones --- ##
        For [YT1]YT10 Where NUMDOC=[M:YCQ]NUMDOC

          Gosub INIT_BUCLE_ARTI

          #link de todas las recepciones del artículo/calidad actual
          Link [PTD] With [FCY]FCY0=[F:PTD]PRHFCY, [PTH]PTH0=[PTD]PTHNUM
&         As [RES2]
&         Where [PTH]ZEJERCICIO = [YT0]EJERCICIO
&         and [PTH]BPSNUM = [YLC]CODIPERSON
&         and [FCY]FINRSPFCY=[YT0]FCY
&         and [FCY]YTIPOFCY=[YT0]TIPOFCY
&         and [PTD]ITMREF = ART and [PTD]ZCALIDAD=[YT1]CALIDAD
&         and [PTD]PRHFCY>=VFCYDEB and [PTD]PRHFCY<=VFCYFIN and [PTD]RCPDAT>=[YT0]FECHAINI
&         and [PTD]RCPDAT<=[YT0]FECHAFIN and [F:PTD]LININVFLG<2
&         Order With "PRHFCY Asc"
#XVT15-05-2020.n AÑADIDA LÍNEA Order With "PRHFCY Asc"


          ##CABE DISTINGUIR SI ES ENTREGA A CUENTA O LIQUIDACIÓN
          If [YT0]ANTILIQ = 1 Then
             ##ENTREGA A CUENTA: AGRUPACIÓN DE RECEPCIONES
             CANTIDAD=0
             ANTFCY=""    #XVT15-05-2020.n
             For [RES2]
             #registros de recepción no facturados, del proveedor actual, del artículo actual y calidad actual.
#XVT15-05-2020.BN
               If [RES2]PRHFCY<>ANTFCY Then

                 If !ERROR and CANTIDAD Then
                  #ENTRARÁ EN ESTE PUNTO A PARTIR DEL SEGUNDO REGISTRO, SIEMPRE QUE CAMBIE LA PLANTA
                  TYPORI = "5"
                  NUMORI = ""
                  LINORI = ""
                  ZFCYLIN= [RES2]PRHFCY   #XVT15-05-2020.n

#XVT1505-2020.n añadido el nuevo campo ZFCYLIN: "+ ZFCYLIN + LSEP"
                  If [M:YCQ]SIMULADO <> 2 Then
                    Wrseq "L" + LSEP + TYPORI + LSEP + NUMORI + LSEP + LINORI + LSEP + ZFCYLIN + LSEP + NUMORI + LSEP + [YT1]ITMREF + LSEP + [F:ITM]STU + LSEP
&                   + num$(CANTIDAD) + LSEP + num$([YT1]PREU1) + LSEP + [YT1]CALIDAD
&                   + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + chr$(13)
&                   Using [LIQ]
                  Endif
                  LSEP=";"
                  ZIMPORTESIMUL+=CANTIDAD*[YT1]PREU1
                  Call ECR_TRACE ("L" + LSEP + TYPORI + LSEP + NUMORI + LSEP + LINORI + LSEP + ZFCYLIN + LSEP + NUMORI + LSEP + [YT1]ITMREF + LSEP + [F:ITM]STU + LSEP
&                   + num$(CANTIDAD) + LSEP + num$([YT1]PREU1) + LSEP + [YT1]CALIDAD
&                   + LSEP + num$(CANTIDAD*[YT1]PREU1) + LSEP + [YLC]CODIPERSON ,0)
&                 From GESECRAN
                  LSEP="|"
                 Endif

                 CANTIDAD=0
               Endif
               ANTFCY=[RES2]PRHFCY
#XVT15-05-2020.EN

               If [YT1]TIPO=1 Then
                 Case [YT1]QTYFAC
                    When 1 Then CANTIDAD+=sum([RES2]QTYSTU)
                    When 2 Then CANTIDAD+=sum([RES2]ZCANT1)
                    When 3 Then CANTIDAD+=sum([RES2]ZCANT2)
                 Endcase
                 PRECIO=[YT1]PREU1
                 If PRECIO=0 Then
                    ##error, no se puede crear una ECTA sin precio.
                    Call MESSAGE ("Entrega a cuenta no puede tener precio cero. No se puede crear") From GESECRAN
                    ERROR=1
                    Break
                 Endif
               Else
                  ##cuando tipo cálculo es "tabla", sólo en liquidaciones, no en entregas a cuenta
                  Call MESSAGE ("Entrega a cuenta no puede calcular precios de tabla") From GESECRAN
                  ERROR=1
                  Break
               Endif
               If ERROR : Break : Endif
             Next

             If !ERROR and CANTIDAD Then
              TYPORI = "5"
              NUMORI = ""
              LINORI = ""
              ZFCYLIN= [RES2]PRHFCY   #XVT15-05-2020.n

#XVT1505-2020.n añadido el nuevo campo ZFCYLIN: "+ ZFCYLIN + LSEP"
              If [M:YCQ]SIMULADO <> 2 Then
                Wrseq "L" + LSEP + TYPORI + LSEP + NUMORI + LSEP + LINORI + LSEP + ZFCYLIN + LSEP + NUMORI + LSEP + [YT1]ITMREF + LSEP + [F:ITM]STU + LSEP
&                + num$(CANTIDAD) + LSEP + num$([YT1]PREU1) + LSEP + [YT1]CALIDAD
&                + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + chr$(13)
&               Using [LIQ]
              Endif
              LSEP=";"
              ZIMPORTESIMUL+=CANTIDAD*[YT1]PREU1
              Call ECR_TRACE ("L" + LSEP + TYPORI + LSEP + NUMORI + LSEP + LINORI + LSEP + ZFCYLIN + LSEP + NUMORI + LSEP + [YT1]ITMREF + LSEP + [F:ITM]STU + LSEP
&                + num$(CANTIDAD) + LSEP + num$([YT1]PREU1) + LSEP + [YT1]CALIDAD
&                + LSEP + num$(CANTIDAD*[YT1]PREU1) + LSEP + [YLC]CODIPERSON ,0)
&               From GESECRAN
              LSEP="|"
             Endif
          Else
            ##LIQUIDACIÓN: NO AGRUPA RECEPCIONES Y, COMO EL PROCESO IMPORT X3 DE ZLIQ NO PERMITE INDICAR EL CAMPO "ZNUMECTA" SI ESTÁN
            ##MEZCLADAS LAS LÍNEAS CON TIPO DE ORIGEN 2 Y TIPO DE ORIGEN 5, PRIMERO SE GENERAN TODAS LAS LÍNEAS
            ##CORRESPONDIENTES A LOS "ABONOS" POR ENTREGAS A CUENTA Y LUEGO TODAS LAS LÍNEAS DE RECEPCIÓN. ESTO
            ##SE HA REALIZADO EN EL BUCLE 1
             CANTIDAD=0
             For [RES2]
             #registros de recepción no facturados, del proveedor actual, del artículo actual y calidad actual.

              ZRENDIMIENTO=[RES2]ZRENDIMIENTO
              Case [YT1]QTYFAC
                  When 1 Then CANTIDAD=[RES2]QTYSTU
                  When 2 Then CANTIDAD=[RES2]ZCANT1
                  When 3 Then CANTIDAD=[RES2]ZCANT2
              Endcase
              If [YT1]TIPO=1 Then
                 #Cuando el precio es por recepción
                 PRECIO=[YT1]PREU1
                 If PRECIO=0 Then
                    ##error, no se puede crear una ECTA sin precio.
                    Call MESSAGE ("Entrega a cuenta no puede tener precio cero. No se puede crear") From GESECRAN
                    ERROR=1
                    Break
                 Endif
              Else
              ##pendiente: tratar tabla fórmulas de almazara
              ##cuando tipo cálculo es "tabla"

                 Filter [F:ZPL] Where NUMDOC=[M:YCQ]NUMDOC and ITMREF=[YT1]ITMREF and CALIDAD=[YT1]CALIDAD and GRDINI<=[RES2]ZRENDIMIENTO
&                and GRDFIN >=[RES2]ZRENDIMIENTO
                 Read [F:ZPL] First
                 If !fstat Then
                   # Infbox num$([F:ZPL]PRECIO) + " " + [F:ZPL]FORPRE
                    If [F:ZPL]PRECIO<>0 Then
                      PRECIO=[F:ZPL]PRECIO
                    Else
                      FORMULAPRECIO=ctrans([F:ZPL]FORPRE,",",".")
                      PRECIO = evalue(FORMULAPRECIO)
                #      Infbox "ZRENDIMIENTO=" + num$(ZRENDIMIENTO) + "   PRECIO=" + num$(PRECIO)
                      If PRECIO=0 Then
                        ##error, no se puede crear una ECTA sin precio.
                          Call MESSAGE ("Entrega a cuenta no puede tener precio cero. No se puede crear " + FORMULAPRECIO) From GESECRAN
                          ERROR=1
                      Break
                      Endif
                    Endif
                Endif
                Filter [F:ZPL]
              Endif  ##TIPO 1 / TIPO 2 (RECEPCIÓN O TABLA)
              If !ERROR and CANTIDAD and PRECIO Then
                   TYPORI = "2" #recepción
                   NUMORI = [RES2]PTHNUM
                   LINORI = num$([RES2]PTDLIN)
                   ZFCYLIN= ""  #XVT15-05-2020.n

#XVT1505-2020.n añadido el nuevo campo ZFCYLIN: "+ ZFCYLIN + LSEP"
                   If [M:YCQ]SIMULADO <> 2 Then
                     Wrseq "L" + LSEP + TYPORI + LSEP + NUMORI + LSEP + LINORI + LSEP + ZFCYLIN + LSEP + "" + LSEP + [YT1]ITMREF + LSEP + [F:ITM]STU + LSEP
&                    + num$(CANTIDAD) + LSEP + num$(PRECIO) + LSEP + [YT1]CALIDAD
&                    + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + LSEP + "0" + chr$(13)
&                    Using [LIQ]
                   Endif
                   LSEP=";"
                   ZIMPORTESIMUL+=CANTIDAD*PRECIO
                   Call ECR_TRACE ("L" + LSEP + TYPORI + LSEP + NUMORI + LSEP + LINORI + LSEP + ZFCYLIN + LSEP + "" + LSEP + [YT1]ITMREF + LSEP + [F:ITM]STU + LSEP
&                    + num$(CANTIDAD) + LSEP + num$(PRECIO) + LSEP + [YT1]CALIDAD
&                   + LSEP + num$(CANTIDAD*PRECIO) + LSEP + [YLC]CODIPERSON ,0)
&                    From GESECRAN
                   LSEP="|"
                Endif
              If ERROR = 1 : Break : Endif
             Next
          Endif
      If ERROR = 1 : Break : Endif
      CREA_CAB = 1

     Next ## -- Final del bucle de articulos

        Call ECR_TRACE("Importe total simulado: " + num$(ZIMPORTESIMUL),0) From GESECRAN
        If [M:YCQ]SIMULADO <> 2 Then
          Openo  Using [LIQ]

          If !ERROR and CREA_CAB <> 0
              NUM_VEN = 99
              Call AFF_BOITE("Importar fac.: "+ [F:YLC]CODIPERSON , NUM_VEN, INTE_VEN) From GESECRAN

              ###--- Función de llamada al modelo de importación ---###
              Call IMPSILEN ('ZLIQ',FICHERODESTINO)

              NUM_VEN += 1
              Call AFF_BOITE("Marcar reg.: "+ [F:YLC]CODIPERSON , NUM_VEN, INTE_VEN) From GESECRAN

              ## Función de marcar los registros como procesados
          #v11.o    Call MARCAR_REC_DOC(DOCU,[F:YLC]NUMDOC,[F:YLC]NUMLIN)
              Read [PIH]PIH1=[F:YLC]CODIPERSON;[YT0]NUMDOC
              If !fstat
                # Update [YLC] Where [YLC]CODIPERSON=PROV and [YLC]NUMDOC=[YT0]NUMDOC  # MAB.28102019.OLD
                # MAB.28102019.NEW
                Update [YLC] Where CODIPERSON=PROV and NUMDOC=[YT0]NUMDOC and NUMLIN = [YLC]NUMLIN
&               With TFACGEN=2,
&               ZNUMFAC=[PIH]NUM
              Endif
          Else
              NUM_VEN += 100
          Endif
        Endif
    ##---------------------------------------------
    Next   ## -- Final del bucle de personal
    Call FERME_BOITE From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
End

$INIT_BUCLE_ARTI
  Read [F:ITM]ITM0=[F:YT1]ITMREF
  ART = [F:YT1]ITMREF
  CREA_LIN = 0
  CANTIDAD = 0

  PRECIO = 0
  IMPORTE = 0

  CLASIFIC = ""
  CALIDAD = ""
  PLANTACIO = ""

  VFCYDEB="" : VFCYFIN="ZZZZZ"
  If [YT0]FCYDEB<>"" and [YT0]FCYFIN<>"" : VFCYDEB=[YT0]FCYDEB : VFCYFIN=[YT0]FCYFIN : Endif

Return



######################################################################################
## Proceso de duplicar las clasificaciones originales de precios.
######################################################################################
Subprog DUPLICAR_CLASIFIC(NUMERO_CLA,ORDEN_CLA,CLAS,PROV,ERROR_CLA)
    Value     Char     NUMERO_CLA
    Value     Char     ORDEN_CLA
    Variable  Char     CLAS
    Variable  Integer  ERROR_CLA
    Variable  Char     PROV
    Local     Char     GNUM
    Local     Char     TIPDOC, SERIEDOC
    Local     Integer  CLASEDOCUM
#v11.bo
#    If clalev([F:YC2])=0 : Local File YACCABCLA  [YC2] : Endif
#    If clalev([F:YL2])=0 : Local File YACLINCLA  [YL2] : Endif
#    If clalev([F:XC2])=0 : Local File YACCABCLA  [XC2] : Endif
#    If clalev([F:XL2])=0 : Local File YACLINCLA  [XL2] : Endif
#    If clalev([F:YTD])=0 : Local File YTIPDOC    [YTD] : Endif
#v11.eo

    Raz [F:YC2]
    Raz [F:YL2]
    Raz [F:XC2]
    Raz [F:XL2]

    ERROR_CLA = 0

    Read [YC2] YC20=NUMERO_CLA;ORDEN_CLA : If fstat Raz [F:YC2] : ERROR = 1 : End : Endif

    Raz TIPDOC

    Call BUSCAR_TIPO_DOCUM("PIH","", "YC2", TIPDOC) From XCONTROLES
    If TIPDOC = ""
        GOK = 0
        GERR=1
        Call ERREUR(mess(117,1986,1)) From GESECRAN
        End
    Endif

    Read [YTD]YTD0=TIPDOC  ###- Aqui tendremos que mirar que tipo documento corresponde
    If fstat
        GOK = 0
        End
    Endif

    SERIEDOC = [F:YTD]SERIEDOCUM
    CLASEDOCUM = [F:YTD]CLASEDOCUM

    Call COGER_CONTADOR(TIPDOC,SERIEDOC,GNUM,[F:YC2]FCY,[F:YC2]EXERCICI) From XCONTROLES

    [F:XC2] = [F:YC2]
    [F:XC2]CODIPERSON = PROV
    [F:XC2]SERIE      = SERIEDOC
    [F:XC2]TIPDOC     = TIPDOC
    [F:XC2]CLASEDOC   = CLASEDOCUM
    [F:XC2]CQUANTI1   = 0
    [F:XC2]DATA       = [M:YCQ]DATAFAC
    [F:XC2]DESDOCUM   = "Liquidaciones"
    [F:XC2]YDOCLIN    = "1"
    [F:XC2]YDOCREL    = GNUM
    [F:XC2]REFERENCIA = NUMERO_CLA
    [F:XC2]TESTP      = 2
    [F:XC2]TESTE      = 2
    [F:XC2]CREUSR     = GUSER
    [F:XC2]CREDAT     = date$
    [F:XC2]UPDUSR     = GUSER
    [F:XC2]UPDDAT     = date$
    CLAS = GNUM

    Trbegin[XC2],[XL2]

    Write [XC2]
    If fstat
         GOK=0 : Rollback : Call FSTA("XC2") From GLOCK : ERROR_CLA = 1 : End
    Endif

    For [YL2]YL20 Where YDOCREL=NUMERO_CLA and YDOCLIN=ORDEN_CLA
        [F:XL2] = [F:YL2]
        [F:XL2]SERIE      = SERIEDOC
        [F:XL2]TIPDOC     = TIPDOC
        [F:XL2]CLASEDOC   = CLASEDOCUM
        [F:XL2]YDOCLIN    = "1"
        [F:XL2]YDOCREL    = GNUM
        [F:XL2]CREUSR     = GUSER
        [F:XL2]CREDAT     = date$
        [F:XL2]UPDUSR     = GUSER
        [F:XL2]UPDDAT     = date$

        Write [XL2]
        If fstat
             GOK=0 : Rollback : Call FSTA("XL2") From GLOCK : ERROR_CLA = 1 : End
        Endif
    Next

    Commit
End
######################################################################################
## Proceso de acumular cantidades en las clasificaciones
######################################################################################
Subprog ACUMULAR_CLASIFIC(ORIGINAL,LECTURA,IMP,ERROR_CLA)
    Value    Char     ORIGINAL
    Value    Char     LECTURA
    Variable Decimal  IMP
    Variable Integer  ERROR_CLA

#v11.bo
#    If clalev([F:YC2])=0 : Local File YACCABCLA  [YC2] : Endif
#    If clalev([F:YL2])=0 : Local File YACLINCLA  [YL2] : Endif
#    If clalev([F:XL2])=0 : Local File YACLINCLA  [XL2] : Endif
#v11.eo


    IMP = 0
    ERROR = 0

    Trbegin [XL2],[YC2]

    For [YL2]YL20 Where YDOCREL = LECTURA
        For [XL2]YL20 Where YDOCREL = ORIGINAL and CODCALIBRE = [F:YL2]CODCALIBRE
            [F:XL2]QUANTITAT1 = [F:XL2]QUANTITAT1 + [F:YL2]QUANTITAT1
            [F:XL2]IMPORT     = [F:XL2]QUANTITAT1 * [F:XL2]PREU
            Call ARRDEV([F:XL2]IMPORT,GLOCALDEV) From TRTDIV

            Rewrite [XL2]
            If fstat
                 GOK=0 : Rollback : Call FSTA("XL2") From GLOCK : ERROR_CLA = 1 : End
            Endif

            ## -- Aqui incrementamos la cantidad del documento de cabecera.
            Read [YC2]YC20 = ORIGINAL

            [F:YC2]CQUANTI1 = [F:YC2]CQUANTI1 + [F:YL2]QUANTITAT1

            Rewrite [YC2]
            If fstat
                 GOK=0 : Rollback : Call FSTA("YC2") From GLOCK : ERROR_CLA = 1 : End
            Endif
        Next
    Next

    Raz IMP
    For [XL2]YL20 Where YDOCREL = ORIGINAL
        IMP = IMP + [F:XL2]IMPORT
    Next

    Commit
End
######################################################################################
## Proceso de restar cantidades en las clasificaciones
######################################################################################
Subprog RESTAR_CLASIFIC(ORIGINAL,LECTURA,IMP,ERROR_CLA)
    Value    Char     ORIGINAL
    Value    Char     LECTURA
    Variable Decimal  IMP
    Variable Integer  ERROR_CLA


#v11.bo
#    If clalev([F:YC2])=0 : Local File YACCABCLA  [YC2] : Endif
#    If clalev([F:YL2])=0 : Local File YACLINCLA  [YL2] : Endif
#    If clalev([F:XL2])=0 : Local File YACLINCLA  [XL2] : Endif
#v11.eo

    IMP = 0
    ERROR = 0

    Trbegin [XL2],[YC2]

    For [YL2]YL20 Where YDOCREL = LECTURA
        For [XL2]YL20 Where YDOCREL = ORIGINAL and CODCALIBRE = [F:YL2]CODCALIBRE
            [F:XL2]QUANTITAT1 = [F:XL2]QUANTITAT1 - [F:YL2]QUANTITAT1
            [F:XL2]IMPORT     = [F:XL2]QUANTITAT1 * [F:XL2]PREU
            Call ARRDEV([F:XL2]IMPORT,GLOCALDEV) From TRTDIV
            IMP = IMP + [F:XL2]IMPORT

            Rewrite [XL2]
            If fstat
                 GOK=0 : Rollback : Call FSTA("XL2") From GLOCK : ERROR_CLA = 1 : End
            Endif

            ## -- Aqui incrementamos la cantidad del documento de cabecera.
            Read [YC2]YC20 = ORIGINAL

            [F:YC2]CQUANTI1 = [F:YC2]CQUANTI1 - [F:YL2]QUANTITAT1

            Rewrite [YC2]
            If fstat
                 GOK=0 : Rollback : Call FSTA("YC2") From GLOCK : ERROR_CLA = 1 : End
            Endif

        Next
    Next

    Commit
End
######################################################################################
## Proceso de busqueda de anticipos.
######################################################################################
Subprog BUSCAR_ANT(A_PROV,A_ART,A_FCY,A_CALIDAD,A_RECOLL,A_PLANTA,A_PRHFCY,A_EXERCICI,A_DOCU,A_LINEA,A_IVA,A_RETEN,A_RETEN1)
    Value     Char     A_PROV
    Value     Char     A_ART
    Value     Char     A_FCY
    Value     Char     A_CALIDAD
    Value     Char     A_RECOLL
    Value     Char     A_PLANTA
    Value     Char     A_PRHFCY
    Value     Char     A_EXERCICI
    Value     Char     A_DOCU
    Value     Char     A_IVA
    Value     Char     A_RETEN
    Value     Char     A_RETEN1
    Variable  Integer  A_LINEA

    Local     Char     TEST
    Local     Decimal  CANTIDAD2
    Local     Char     TESTANT2
    Local     Char     CRITANT1(250)
    Local     Char     CRITANT2(250)
    Local     Char     CRITANT3(250)
    Local     Char     CCE_ANT(15)(1..20)
    Local     Integer  NCCE : NCCE = 0

    LSEP     = '|'
    TEST     = "2"
    TESTANT2 = "2"

    If [M:YCQ]NBLIG = 0 : End : Endif

    ## Preparamos los criterios de filtro

    CRITANT1 =  "[YAN]BPSNUM=A_PROV & [YAN]ITMREF=A_ART & [YAN]FCYLIN=A_PRHFCY"
    CRITANT1 += "& [YAN]YEXELIN=A_EXERCICI"

    CRITANT2 =  "[YAN]ACCDAT>=[M:YCQ]DATAINI & [YAN]ACCDAT<=[M:YCQ]DATAFI"
    If [M:YCQ]TPLANTA = 2
        CRITANT2 += " & [YAN]YPLANTA=A_PLANTA"
    Endif

    CRITANT3 = ""
    For I=0 To [M:YCQ]NBLIG
        If [M:YCQ]STATUS1(I) = 2
            If CRITANT3 <> ""
                CRITANT3 += " OR"
            Endif
            CRITANT3 += " [YAN]YTIPDOC ='" + [M:YCQ]TIPDOC_LIN(I) + "'"
        Endif
    Next
    ## ------------------------------

    ZCRITANT ="1=1"

    ##---Punto de entrada para poder imprimir documentos.
    GPOINT = "XANTCRIT" : Gosub ENTREE From EXEFNC

    If clalev([F:PIHA])=0 : Local File PINVOICE   [PIHA] : Endif
    If clalev([F:PIDA])=0 : Local File PINVOICED  [PIDA] : Endif
    If clalev([F:YAN]) =0 : Local File YANTICIP   [YAN]  : Endif

    For [YAN]YAN0 Where evalue(CRITANT1) and evalue(CRITANT2) and evalue(CRITANT3) and evalue(ZCRITANT)

        Read [PIHA]PIH0 = [F:YAN]NUM : If fstat : Raz [PIHA] : Endif
        Read [PIDA]PID0 = [F:YAN]NUM;[F:YAN]PIDLIN : If fstat : Raz [PIDA] : Endif

        Read [YLQ]YLQ1 =  A_DOCU;[F:PIDA]NUM;[F:PIDA]PIDLIN
        If fstat
            If [F:PIDA]INVTYP = 1
                If [F:PIDA]QTYUOM > 0
                    CANTIDAD2 = (([F:PIDA]QTYUOM * -1) * [F:PIHA]SNS)
                Else
                   CANTIDAD2 = [F:PIDA]QTYUOM
                Endif
            Elsif [F:PIDA]INVTYP = 2
                CANTIDAD2 = [F:PIDA]QTYUOM
            Endif

            PLANTACIO = ""
            If [M:YCQ]TPLANTA = 2
                PLANTACIO = [F:PIDA]YPLANTA
            Else
                PLANTACIO = ""
            Endif

            ##---Punto de entrada para poder modificar anticipos.
            GPOINT = "XANTMOD" : Gosub ENTREE From EXEFNC

            Wrseq 'L|'+ '5' + LSEP + [F:PIDA]NUM + LSEP + num$([F:PIDA]PIDLIN) + LSEP + [F:PIDA]ITMREF + LSEP + [F:PIDA]UOM + LSEP +
&          num$(CANTIDAD2) + LSEP + num$([F:PIDA]NETPRI) + LSEP + A_IVA + LSEP + A_RETEN +
&          LSEP + A_RETEN1 + LSEP + LSEP + LSEP + [F:PIDA]YCALIDAD + LSEP + [F:PIDA]YRECOLL + LSEP +
&          [F:PIDA]FCYLIN + LSEP + [F:PIDA]YEXELIN + LSEP + TEST + LSEP + PLANTACIO + LSEP +
&          num$([F:PIDA]DISCRGVAL1) + LSEP + num$([F:PIDA]DISCRGVAL2) + LSEP + num$([F:PIDA]DISCRGVAL3) + LSEP+
&          num$([F:PIDA]DISCRGVAL4) + LSEP + num$([F:PIDA]DISCRGVAL5) + LSEP + num$([F:PIDA]DISCRGVAL6) + LSEP+
&          num$([F:PIDA]DISCRGVAL7) + LSEP + num$([F:PIDA]DISCRGVAL8) + LSEP + num$([F:PIDA]DISCRGVAL9) + LSEP+
&          [F:PIDA]YCODTRAZA + LSEP + num$([F:PIDA]YKGORIGEN) + LSEP + num$([F:PIDA]YKGBRUTS) + LSEP +
&          num$([F:PIDA]YKGVEHIC) + LSEP + num$([F:PIDA]YKGTARA) + LSEP + num$([F:PIDA]YQUANTI1) + LSEP +
&          num$([F:PIDA]YQUANTI2) + LSEP + num$([F:PIDA]YQUANTI3) + LSEP +
&          num$([F:PIDA]GROPRI) + LSEP + '' + LSEP + [M:YCQ]NUMDOC + LSEP + [F:PIDA]YMODALIT + LSEP +
&           '' + LSEP + num$(0) + LSEP + num$(0) + LSEP + '' + LSEP + '' +
&          LSEP + TESTANT2 + LSEP + A_PROV + LSEP + num$(2) + chr$(013) Using [LIQ]


            ##-- LECTURA DE LA TABLA CPTANALIN PARA OBTENER LA ANALITICA DE LA LINEA -----##
            For [CAL] Where ABRFIC = 'PID' and VCRNUM = [F:PIDA]NUM and VCRLIN = [F:PIDA]PIDLIN
              For NCCE=1 To 20
                  CCE_ANT(NCCE) = [F:CAL]CCE(NCCE-1)
              Next
            Next

            Wrseq 'LC' + LSEP + CCE_ANT(1) + LSEP + CCE_ANT(2) + LSEP + CCE_ANT(3) + LSEP + CCE_ANT(4) + LSEP + CCE_ANT(5) +
&            LSEP + CCE_ANT(6) + LSEP + CCE_ANT(7) + LSEP + CCE_ANT(8) + LSEP + CCE_ANT(9) + LSEP + CCE_ANT(10) +
&            LSEP + CCE_ANT(11) + LSEP + CCE_ANT(12) + LSEP + CCE_ANT(13) + LSEP + CCE_ANT(14) + LSEP + CCE_ANT(15) +
&            LSEP + CCE_ANT(16) + LSEP + CCE_ANT(17) + LSEP + CCE_ANT(18) + LSEP + CCE_ANT(19) + LSEP + CCE_ANT(20) + chr$(013) Using [LIQ]

            ##----------------------------------------------------------------------------##

            ##--- Aqui guardamos en la tabla de relacion de liquidaciones ------##
            LINEA_YLQ = LINEA_YLQ + 1000
            [F:YLQ]NUMLIN  = LINEA_YLQ
            [F:YLQ]PTHNUM  = ""
            [F:YLQ]PTDLIN  = 0
            [F:YLQ]PNHNUM  = ""
            [F:YLQ]PNDLIN  = 0
            [F:YLQ]NUMDOC  = [F:PIDA]NUM
            [F:YLQ]LINEA   = [F:PIDA]PIDLIN
            [F:YLQ]PIHNUM  = A_DOCU
            [F:YLQ]PIDLIN  = A_LINEA
            [F:YLQ]TEST1   = 1
            [F:YLQ]NUMIDENT= adxuid(1)
            [F:YLQ]CREUSR  = GUSER
            [F:YLQ]CREDAT  = date$

            Trbegin[YLQ]

            Write [YLQ]
            If fstat
                 GOK=0 : Rollback : Call FSTA("YLQ") From GLOCK : Openo : Break : End
            Endif
            Commit

            A_LINEA = A_LINEA + 1000
            ##------------------------------------------------------------------##
            Endif
        Next

    ##---Punto de entrada para poder imprimir documentos.
    GPOINT = "XANTICIP" : Gosub ENTREE From EXEFNC
End
######################################################################################
## Funcion de llamada a un modelo de import / export
######################################################################################
Subprog IMPSILEN (MODELE,NOMFICH)
    Value Char MODELE
    Value Char NOMFICH

    If !clalev([F:AOE])   : Local File AOBJEXT    [AOE]  : Endif
    If !clalev([F:AOD])   : Local File AOBJEXTD   [AOD]  : Endif
    If !clalev([F:ZAOB])  : Local File AOBJET     [ZAOB] : Endif
    If !clalev([F:ADW])   : Local File ADOVAL     [ADW]  : Endif
    If !clalev([F:ZATY])  : Local File ATYPE      [ZATY] : Endif
    If !clalev([F:ZAMK])  : Local File AMSK       [ZAMK] : Endif
    If !clalev([F:ZAMZ])  : Local File AMSKZON    [ZAMZ] : Endif
    If !clalev([F:ZATB])  : Local File ATABLE     [ZATB] : Endif
    If !clalev([F:ZATZ])  : Local File ATABZON    [ZATZ] : Endif
    If !clalev([F:ZATI])  : Local File ATABIND    [ZATI] : Endif
    If !clalev([F:ZAFC])  : Local File AFONCTION  [ZAFC] : Endif
    If !clalev([F:APX])   : Local File APARIMPEXP [APX]  : Endif
    If !clalev([M:AOE0])  : Local Mask AOE0       [AOE0] : Endif
    If !clalev([M:AOE1])  : Local Mask AOE1       [AOE1] : Endif
    If !clalev([M:AOE2])  : Local Mask AOE2       [AOE2] : Endif
    If !clalev([M:IEX])   : Local Mask IMPTEST    [IEX]  : Endif
    If !clalev([M:DIA])   : Local Mask IMPENCH    [DIA]  : Endif
    If clalev([M:IMP2])=0 : Local Mask IMPOBJ2    [IMP2] : Endif
    Local Integer STAT : STAT = 0
    Local Char MESSAGE(100)
    Local Char FICHIER(200) : FICHIER = filpath("BQR",NOMFICH,"")

    Call IMPORTSIL(MODELE,FICHIER) From GIMPOBJ

    If GERRTRACE <> 0
        GYNUM=0
    Endif
End
######################################################################################
## Funcion para llenar los tipos de documentos de Anticipos
######################################################################################
Subprog OMPLIR_TIPDOC(CLASE)
    Value Integer CLASE

    For I=0 To [M]NBLIG-1
        Dela I,1,[M]NBLIG-1 [M]NBLIG
        [M]NBLIG-=1
    Next

    Affzo [M:YCQ]15

    If CLASE = 15  or ( CLASE = 14 and  [M:YCQ]RESTANT = 1)
        NUM = 0
        For [YTD] Where CLASEDOCUM = 14 and TIPOFCY = [M:YCQ]YTIPOFCY
            [M:YCQ]STATUS1(NUM) = 2
            [M:YCQ]TIPDOC_LIN(NUM) = [F:YTD]CODITIPDOC
            NUM += 1
        Next

        [M:YCQ]NBLIG = NUM
        Actzo [M:YCQ]15
        Affzo [M:YCQ]15
    Else
        Grizo [M:YCQ]15
    Endif
End
######################################################################################
## Funcion para buscar las devoluciones
######################################################################################
Subprog BUSCAR_DEVOLUCIONES(D_PROV,D_ART,D_FCY,D_CALIDAD,D_RECOLL,D_PLANTA,D_DATAINI,
& D_DATAFI,D_TIPO,D_CLASIFIC,D_PREU,D_CANT,D_IMP,D_DOCU,D_LINEA,D_KGORI,D_KGBRUT,
& D_KGVEHIC,D_KGTARA,D_QUANT1,D_QUANT2,D_QUANT3)

    Value Char D_PROV
    Value Char D_ART
    Value Char D_FCY
    Value Char D_CALIDAD
    Value Char D_RECOLL
    Value Char D_PLANTA
    Value Date D_DATAINI
    Value Date D_DATAFI
    Value Integer D_TIPO
    Value Char    D_CLASIFIC
    Value Decimal D_PREU
    Value Char D_DOCU
    Value Integer D_LINEA
    Variable Decimal D_CANT
    Variable Decimal D_IMP
    Variable Decimal D_KGORI
    Variable Decimal D_KGBRUT
    Variable Decimal D_KGVEHIC
    Variable Decimal D_KGTARA
    Variable Decimal D_QUANT1
    Variable Decimal D_QUANT2
    Variable Decimal D_QUANT3

#Pendent SONIA 06-09-07 (CALIDAD-RECOLL)

  ##---- Aqui crearemos el criterio para filtrar los documentos de recepcion ----##
    CRITERE  = " [PNH]BPSNUM=D_PROV and [PND]ITMREF=D_ART"
    CRITERE += " and [PND]YCALIDAD=D_CALIDAD and [PND]YRECOLL=D_RECOLL"
    CRITERE += " and [PNH]RTNDAT>=D_DATAINI and [PNH]RTNDAT<=D_DATAFI"

    If D_TIPO = 2
         CRITERE += ' and [PND]YDOCCLA <> ""'
    Endif

    CRITERE += " and [PND]LININVFLG = 2"

    CRITERE2 = " and [PNH]PNHFCY = D_FCY"

    Link [PNH] With [PND]PND0=PNHNUM As [YPN1] Where evalue(CRITERE+CRITERE2)
& Order By [PND]YPLANTA Desc;[PNH]PNHFCY Desc

  ##-----------------------------------------------------------------------------##
    ##-- Bucle para acumular las cantidades de las devoluciones --##
    For [YPN1]

        Read [YTD]YTD0 = [F:PNH]YTIPDOC
        If fstat
            Raz [F:YTD]
            ERROR = 1
            Call ERREUR(mess(1,1986,1) + " " + [F:PNH]YTIPDOC) From GESECRAN
            End
        Endif

        CAMPO = "[F:PND]"
        Call ASIGNACION_CAMPOS_FAC([F:YTD]QTYFAC,CAMPO) From XCONTROLES
        If [F:YTD]QTYFAC = 1 : CAMPO = "[F:PND]QTYUOM" : Endif

        ##--- Aqui acumularemos la cantidad --------- ##
        D_CANT = D_CANT + evalue(CAMPO)

        D_KGORI   = D_KGORI   + [F:PND]YKGORIGEN
        D_KGBRUT  = D_KGBRUT  + [F:PND]YKGBRUTS
        D_KGVEHIC = D_KGVEHIC + [F:PND]YKGVEHIC
        D_KGTARA  = D_KGTARA  + [F:PND]YKGTARA
        D_QUANT1  = D_QUANT1  + [F:PND]YQUANTI1
        D_QUANT2  = D_QUANT2  + [F:PND]YQUANTI2
        D_QUANT3  = D_QUANT3  + [F:PND]YQUANTI3

        If D_TIPO = 2
            ##-- Aqui si la cantidad es superior a 0 acumularemos las cantidades --##
            ##-- en el documento de clasificacion nuevo ---------------------------##
            If D_CANT > 0
                Call RESTAR_CLASIFIC(D_CLASIFIC,[F:PND]YDOCCLA,IMP)
            Endif

            ##--- Aqui acumularemos los importes -------------------- ##
            If [F:PND]NETPRI <> 0
                VALOR = (D_CANT * [F:PND]GROPRI)
                Call ARRDEV(VALOR,[F:PND]NETCUR) From TRTDIV
                D_IMP = D_IMP + VALOR
                VALOR = 0
            Else
                D_IMP = D_IMP + IMP
            Endif
            ##--------------------------------------------------------##
        Else
            If [F:PTD]NETPRI <> 0
                VALOR = (evalue(CAMPO) * [F:PND]GROPRI)
                Call ARRDEV(VALOR,[F:PND]NETCUR) From TRTDIV
                D_IMP = D_IMP + VALOR
                VALOR = 0
            Else
                VALOR = (evalue(CAMPO) * D_PREU)
                Call ARRDEV(VALOR,[F:PND]NETCUR) From TRTDIV
                D_IMP = D_IMP + VALOR
                VALOR = 0
            Endif
        Endif

        ##--- Aqui guardamos en la tabla de relacion de liquidaciones ------##
        LINEA = LINEA + 1000
        LINEA_YLQ = LINEA_YLQ + 1000
        [F:YLQ]NUMLIN  = LINEA_YLQ
        [F:YLQ]PTHNUM  = ""
        [F:YLQ]PTDLIN  = 0
        [F:YLQ]PNHNUM  = [F:PND]PNHNUM
        [F:YLQ]PNDLIN  = [F:PND]PNDLIN
        [F:YLQ]NUMDOC  = ""
        [F:YLQ]LINEA   = 0
        [F:YLQ]PIHNUM  = D_DOCU
        [F:YLQ]PIDLIN  = LINEA
        [F:YLQ]YDOCCLA = D_CLASIFIC
        [F:YLQ]TEST1   = 1
        [F:YLQ]NUMIDENT= adxuid(1)
        [F:YLQ]CREUSR  = GUSER
        [F:YLQ]CREDAT  = date$

        Trbegin[YLQ]

        Write [YLQ]
        If fstat
             GOK=0 : Rollback : Call FSTA("YLQ") From GLOCK : Openo : Break : End
        Endif
        Commit
        ##------------------------------------------------------------------##
    Next

###SVR 281209
    Filter [PNH]
    Filter [PND]
    Filter [YPN1]
    Raz [PNH]
    Raz [PND]
    Raz [YPN1]
End
######################################################################################
## Proceso de duplicar los documentos de calidades originales de recepciones
######################################################################################
Subprog DUPLICAR_CALIDAD(NUMERO_ORI,NUMERO_CAL,ORDEN_CAL,CALI,DTOAI,DTOII,RECAI,RECII,ERROR_CAL)
    Value    Char     NUMERO_ORI
    Value    Char     NUMERO_CAL
    Value    Char     ORDEN_CAL
    Variable Char     CALI
    Variable Decimal  DTOAI
    Variable Decimal  DTOII
    Variable Decimal  RECAI
    Variable Decimal  RECII
    Variable Integer  ERROR_CAL

    Local    Char     GNUM
    Local    Decimal  BASE
    Local    Decimal  IMPORTE
    Local    Decimal  PARCIAL
    Local    Decimal  TACUMU
    Local    Decimal  TACUMQ1
    Local    Decimal  TACUMQ2
    Local    Decimal  TACUMQ3
    Local    Decimal  TACUMPAI
    Local    Decimal  TACUMPII
    Local    Decimal  TACUMBAI
    Local    Decimal  TACUMBII
    Local    Char     TROBAT

#v11.bo
#    If clalev([F:YC1])=0 : Local File YACCABCAL  [YC1] : Endif
#    If clalev([F:YL1])=0 : Local File YACLINCAL  [YL1] : Endif
#    If clalev([F:XC1])=0 : Local File YACCABCAL  [XC1] : Endif
#    If clalev([F:XL1])=0 : Local File YACLINCAL  [XL1] : Endif
#    If clalev([F:ZL1])=0 : Local File YACLINCAL  [ZL1] : Endif
#v11.eo


    Raz [F:YC1]
    Raz [F:YL1]
    Raz [F:XC1]
    Raz [F:XL1]

    ERROR_CAL = 0
    DTOAI = 0
    DTOII = 0
    RECAI = 0
    RECII = 0

    Read [YC1] YC10=NUMERO_ORI;"1"
    If fstat
        Raz [F:YC1]
        ERROR_CAL = 1
        End
    Endif

    Call COGER_CONTADOR([F:YC1]TIPDOC,[F:YC1]SERIE,GNUM,[F:YC1]FCY,[F:YC1]EXERCICI) From XCONTROLES

    Trbegin[XC1],[XL1]

    [F:XC1] = [F:YC1]
    [F:XC1]DATA     = [M:YCQ]DATAFAC
    [F:XC1]DESDOCUM = "Liquidaciones"
    [F:XC1]YDOCLIN  = "1"
    [F:XC1]YDOCREL  = GNUM
    If [M:YCQ]TPRECIO = 2
        [F:XC1]TPRECIO = 2
    Else
        [F:XC1]TPRECIO = 1
    Endif
    CALI = GNUM

    [F:XC1]CALIFPRI = 0
    [F:XC1]CALIFSEC = 0

    If mid$(mess(0,1991,1), [F:XC1]TIPOFCY, 1) = "C"  # CEREALS
        TACUMQ2 = [F:XC1]CQUANTI1
        TACUMQ3 = 0
    Elsif mid$(mess(0,1991,1), [F:XC1]TIPOFCY, 1) = "G"  # NO ES GRANJA
        TACUMQ2 = 0
        TACUMQ3 = 0
    Endif

    TACUMU  = [F:XC1]UNITATS
    TACUMQ1 = [F:XC1]CQUANTI1
    TACUMPAI = 0
    TACUMPII = 0
    TACUMBAI = 0
    TACUMBII = 0

    Write [XC1]
    If fstat
         GOK=0 : Rollback : Call FSTA("XC1") From GLOCK : ERROR_CAL = 1 : End
    Endif

    For [YL1]YL10 Where YDOCREL=NUMERO_ORI and YDOCLIN="1"
        [F:XL1] = [F:YL1]

        BASE = 0
        PARCIAL = 0

        If [F:XL1]CODCALIFIC<>"" Then
            Call ASSIGNAR_BASE(TACUMU, TACUMQ1, TACUMQ2, TACUMQ3, TACUMPAI, TACUMPII,
&            TACUMBAI, TACUMBII,BASE)

            #Resultat de la linia segons el TOPERACIO, la base (QUANTITAT1) i el valor
            #(1-No afecta, 2-Percentatge, 3-Multiplicació, 4-Divisió)
            If [F:XL1]TOPERACIO=2 Then
                PARCIAL = ([F:XL1]QUANTITAT1 * BASE)/100
            Elsif [F:XL1]TOPERACIO=3 Then
                PARCIAL = [F:XL1]QUANTITAT1 * BASE
            Elsif [F:XL1]TOPERACIO=4 Then
                If [F:XL1]QUANTITAT1<>0 Then
                    If (BASE<>0) Then
                        PARCIAL = [F:XL1]QUANTITAT1 / BASE
                    Else
                        PARCIAL = 0
                    Endif
                Else
                    PARCIAL = 0
                Endif
            Else
                PARCIAL = [F:XL1]QUANTITAT1
            Endif

            Call ARRODONIR(PARCIAL,"KG") From XCONTROLES

            Call ASIGNAR_DESTI(TACUMU, TACUMQ1, TACUMQ2, TACUMQ3, TACUMPAI, TACUMPII,
&            TACUMBAI, TACUMBII,PARCIAL)
        Endif

        Filter [ZL1] Where YDOCREL = NUMERO_CAL and YDOCLIN = ORDEN_CAL and CODCALIFIC = [F:XL1]CODCALIFIC
&        and QUANTITAT2 <= [F:XL1]VALOR and QUANTITAT3 >= [F:XL1]VALOR

        Read [ZL1]First

        If fstat=0
            [F:XL1]PREU       = [F:ZL1]PREU
            [F:XL1]IMPORT     = BASE * [F:ZL1]PREU
            Call ARRDEV([F:XL1]IMPORT,GLOCALDEV) From TRTDIV
            If [F:YL1]TDESTI = 4
                DTOAI = DTOAI + [F:XL1]IMPORT
                Call ARRDEV(DTOAI,GLOCALDEV) From TRTDIV
            Elsif [F:YL1]TDESTI = 5
                DTOII = DTOII + [F:XL1]IMPORT
                Call ARRDEV(DTOII,GLOCALDEV) From TRTDIV
            Elsif [F:YL1]TDESTI = 6
                RECAI = RECAI + [F:XL1]IMPORT
                Call ARRDEV(RECAI,GLOCALDEV) From TRTDIV
            Elsif [F:YL1]TDESTI = 7
                RECII = RECII + [F:XL1]IMPORT
                Call ARRDEV(DTOAI,GLOCALDEV) From TRTDIV
            Endif
        Endif

        [F:XL1]YDOCLIN    = "1"
        [F:XL1]YDOCREL    = GNUM

        Filter [ZL1]

        Write [XL1]
        If fstat
             GOK=0 : Rollback : Call FSTA("XL1") From GLOCK : ERROR_CAL = 1 : End
        Endif
    Next

    Commit
End
######################################################################################
######################################################################################
Subprog ASSIGNAR_BASE(TACUMU, TACUMQ1, TACUMQ2, TACUMQ3, TACUMPAI, TACUMPII, TACUMBAI, TACUMBII,BASE)
    Variable Decimal TACUMU
    Variable Decimal TACUMQ1
    Variable Decimal TACUMQ2
    Variable Decimal TACUMQ3
    Variable Decimal TACUMPAI
    Variable Decimal TACUMPII
    Variable Decimal TACUMBAI
    Variable Decimal TACUMBII
    Variable Decimal BASE

    #El campo TORIGEN contiene el campo origen del valor para el cálculo
    #1-Unidad, 2-Cantidad 1, 3-Cantidad 2, 4-Cantidad 3, 5-Pen.A.I., 6-Pen.I.I.
    #7-Bon.A.I., 8-Bon.I.I., 9=Valor

    #1-Unidad
    If [F:XL1]TORIGEN = 1 Then
        #Decidim quina és la base segons el TCASCADA (1-No cascada, 2-Cascada)
        If [F:XL1]TCASCADA=1 Then
            BASE = [F:XC1]UNITATS
        Else
            BASE = TACUMU
        Endif

    #2-Cantidad 1
    Elsif [F:XL1]TORIGEN = 2 Then
        #Decidim quina és la base segons el TCASCADA (1-No cascada, 2-Cascada)
        If [F:XL1]TCASCADA=1 Then
            BASE = [F:XC1]CQUANTI1
        Else
            BASE = TACUMQ1
        Endif

    #3-Cantidad 2
    Elsif [F:XL1]TORIGEN = 3 Then
        #Decidim quina és la base segons el TCASCADA (1-No cascada, 2-Cascada)
        If [F:XL1]TCASCADA=1 Then
            BASE = [F:XC1]CQUANTI2
        Else
            BASE = TACUMQ2
        Endif

    #4-Cantidad 3
    Elsif [F:XL1]TORIGEN = 4 Then
        #Decidim quina és la base segons el TCASCADA (1-No cascada, 2-Cascada)
        If [F:XL1]TCASCADA=1 Then
            BASE = [F:XC1]CQUANTI3
        Else
            BASE = TACUMQ3
        Endif

    #5-Importe Pen. A.I.
    Elsif [F:XL1]TORIGEN = 5 Then
        #Decidim quina és la base segons el TCASCADA (1-No cascada, 2-Cascada)
        If [F:XL1]TCASCADA=1 Then
            BASE = [F:XC1]PENAI
        Else
            BASE = TACUMPAI
        Endif

    #6-Importe Pen. I.I.
    Elsif [F:XL1]TORIGEN = 6 Then
        #Decidim quina és la base segons el TCASCADA (1-No cascada, 2-Cascada)
        If [F:XL1]TCASCADA=1 Then
            BASE = [F:XC1]PENII
        Else
            BASE = TACUMPII
        Endif

    #7-Importe Bon. A.I.
    Elsif [F:XL1]TORIGEN = 7 Then
        #Decidim quina és la base segons el TCASCADA (1-No cascada, 2-Cascada)
        If [F:XL1]TCASCADA=1 Then
            BASE = [F:XC1]BONAI
        Else
            BASE = TACUMBAI
        Endif

    #8-Importe Bon. I.I.
    Elsif [F:XL1]TORIGEN = 8 Then
        #Decidim quina és la base segons el TCASCADA (1-No cascada, 2-Cascada)
        If [F:XL1]TCASCADA=1 Then
            BASE = [F:XC1]BONII
        Else
            BASE = TACUMBII
        Endif

    #9-Valor
    Elsif [F:XL1]TORIGEN = 9 Then
        BASE = [F:XL1]VALOR
    Endif
End
######################################################################################
Subprog ASIGNAR_DESTI(TACUMU, TACUMQ1, TACUMQ2, TACUMQ3, TACUMPAI, TACUMPII, TACUMBAI, TACUMBII,PARCIAL)
    Variable Decimal TACUMU
    Variable Decimal TACUMQ1
    Variable Decimal TACUMQ2
    Variable Decimal TACUMQ3
    Variable Decimal TACUMPAI
    Variable Decimal TACUMPII
    Variable Decimal TACUMBAI
    Variable Decimal TACUMBII
    Variable Decimal PARCIAL

    If [F:XL1]TDESTI=1 Then
       Call RECALCULAR_ACUM(TACUMU,TACUMQ1,TACUMQ2,TACUMQ3,TACUMPAI,TACUMPII,TACUMBAI,TACUMBII,"TACUMQ1",PARCIAL)
    Elsif [F:XL1]TDESTI=2 Then
       Call RECALCULAR_ACUM(TACUMU,TACUMQ1,TACUMQ2,TACUMQ3,TACUMPAI,TACUMPII,TACUMBAI,TACUMBII,"TACUMQ2",PARCIAL)
    Elsif [F:XL1]TDESTI=3 Then
       Call RECALCULAR_ACUM(TACUMU,TACUMQ1,TACUMQ2,TACUMQ3,TACUMPAI,TACUMPII,TACUMBAI,TACUMBII,"TACUMQ3",PARCIAL)
    Elsif [F:XL1]TDESTI=4 Then
       Call RECALCULAR_ACUM(TACUMU,TACUMQ1,TACUMQ2,TACUMQ3,TACUMPAI,TACUMPII,TACUMBAI,TACUMBII,"TACUMPAI",PARCIAL)
    Elsif [F:XL1]TDESTI=5 Then
       Call RECALCULAR_ACUM(TACUMU,TACUMQ1,TACUMQ2,TACUMQ3,TACUMPAI,TACUMPII,TACUMBAI,TACUMBII,"TACUMPII",PARCIAL)
    Elsif [F:XL1]TDESTI=6 Then
       Call RECALCULAR_ACUM(TACUMU,TACUMQ1,TACUMQ2,TACUMQ3,TACUMPAI,TACUMPII,TACUMBAI,TACUMBII,"TACUMBAI",PARCIAL)
    Elsif [F:XL1]TDESTI=7 Then
       Call RECALCULAR_ACUM(TACUMU,TACUMQ1,TACUMQ2,TACUMQ3,TACUMPAI,TACUMPII,TACUMBAI,TACUMBII,"TACUMBII",PARCIAL)
    Endif
End
######################################################################################
Subprog RECALCULAR_ACUM(TACUMU, TACUMQ1, TACUMQ2, TACUMQ3, TACUMPAI, TACUMPII, TACUMBAI,
& TACUMBII,CAMPAFECTAT,PARCIAL)
    Variable Decimal TACUMU
    Variable Decimal TACUMQ1
    Variable Decimal TACUMQ2
    Variable Decimal TACUMQ3
    Variable Decimal TACUMPAI
    Variable Decimal TACUMPII
    Variable Decimal TACUMBAI
    Variable Decimal TACUMBII
    Value    Char    CAMPAFECTAT
    Variable Decimal PARCIAL

    #Si la calificación es de ventas, no afecta
    If ([F:XL1]TAPLICA=2) : End : Endif

    #Resultat de la linia segons el TAFECTACIO i el resultat parcial
    #(1-No afecta, 2-Suma, 3-Resta, 4-Mateix valor)
    If [F:XL1]TAFECTACIO=2 Then
        Assign CAMPAFECTAT With evalue(CAMPAFECTAT) + PARCIAL
    Elsif [F:XL1]TAFECTACIO=3 Then
        Assign CAMPAFECTAT With evalue(CAMPAFECTAT) - PARCIAL
    Elsif [F:XL1]TAFECTACIO=4 Then
        Assign CAMPAFECTAT With PARCIAL
    Endif
End
######################################################################################
### Función de añadir costes a las lineas de factura                               ###
######################################################################################
Subprog INSERTAR_COSTES(SOCIO,FCY,FCY_LIN)
    Value Char     SOCIO,FCY,FCY_LIN
    Local Char     UOM
    Local Char     VAC
    Local Char     VAT(GLONVAT)(3)
    Local Decimal  DISC1,DISC2,DISC3,DISC3,DISC4,DISC5,DISC6,DISC7,DISC8,DISC9
    Local Char     CODTRAZA
    Local Char     LSEP,TEST,PLANTACIO

    DISC1 = 0
    DISC2 = 0
    DISC3 = 0
    DISC4 = 0
    DISC5 = 0
    DISC6 = 0
    DISC7 = 0
    DISC8 = 0
    DISC9 = 0
    LSEP = '|'
    TEST = "2"

    ##-- Bucle de la tabla de cabeceras de Precios Liquidaciones

    For [XT0]YT00 Where NUMPREC = [M:YCQ]NUMDOC and TACTIU = 2 and CLASEDOC = 29

        ##-- Bucle de la tabla de lineas de Precios de Liquidaciones
        For [XT1]YT10 Where NUMDOC = [F:XT0]NUMDOC and CODIPERSON = SOCIO

            ###--- Buscar UOM,VAT

            Read [ITX]ITM0 = [F:XT1]ITMREF : If fstat : Raz [F:ITM] : Endif
            If [F:ITP]ITMREF <> [F:XT1]ITMREF | [F:ITP]BPSNUM <> SOCIO
              Read [ITP]ITP0 = [F:XT1]ITMREF;SOCIO
              If fstat : Raz [F:ITP] : Endif
            Endif
            If [F:ITP]ITMREF=[F:XT1]ITMREF & [F:ITP]BPSNUM=SOCIO
              UOM = [F:ITP]PUU
            Else
              UOM = [F:ITX]PUU
            Endif
            ###---------------

            ###--- Buscar regimenes de impuestos
            Call INIT_REGIME(SOCIO,FCY,"F",VAC) From CPTSUB

            Call ALITAXE(VAC,[F:ITX]VACITM,VAT) From TRTX3
            ###---------------

            Wrseq 'L|'+ '5' + LSEP + "" + LSEP + num$(0) + LSEP + [F:XT1]ITMREF + LSEP + UOM + LSEP + num$([F:XT1]QUANTITAT1) +
&           LSEP + num$([F:XT1]PREU1) + LSEP + VAT(0) + LSEP + VAT(1) + LSEP +
&           VAT(2) + LSEP + LSEP + LSEP + [F:XT1]CALIDAD + LSEP + [F:XT1]RECOLL + LSEP +
&           FCY_LIN + LSEP + [F:PID]YEXELIN + LSEP + TEST + LSEP + PLANTACIO  + LSEP +
&           num$(DISC1) + LSEP + num$(DISC2) + LSEP + num$(DISC3) + LSEP +
&           num$(DISC4) + LSEP + num$(DISC5) + LSEP + num$(DISC6) + LSEP +
&           num$(DISC7) + LSEP + num$(DISC8) + LSEP + num$(DISC9) + LSEP +
&           CODTRAZA + chr$(013) Using [LIQ]

        Next
    Next
End
######################################################################################
## Proceso de duplicar los documentos de calidades originales de recepciones
######################################################################################
Subprog DUPLICAR_CALIDAD_VALOR(NUMERO_ORI,CALI,DTOAI,DTOII,RECAI,RECII,NUMERA,DENOMINA,ERROR_CAL)
    Variable Char     NUMERO_ORI
    Variable Char     CALI
    Variable Integer  ERROR_CAL
    Variable Decimal  DTOAI,DTOII,RECAI,RECII
    Variable Decimal  NUMERA,DENOMINA
    Local    Decimal  IMPORTE
    Local    Char     SENTENCIA(50)
    Local    Char     GNUM
    Local    Char     XDOCLIN
    Local    Char     LSEP : LSEP = "|"
    Local    Decimal  CQUANT1,CQUANT2,CQUANT3,UNITATS
    Local    Char     FICHEROYC1(250),RUTA(250)
    Local    Integer  ERROR
    Local    Char     TIPDOC, SERIEDOC
    Local    Integer  CLASEDOCUM
    Local    Char     OBJDESTI
    Local    Char     TROBAT
    Local    Decimal  PREU, VALOR2

    #-------------------------
    If clalev([F:APX])=0 : Local File APARIMPEXP [APX] : Endif
 #v11.bo
#    If clalev([F:YC1])=0 : Local File YACCABCAL  [YC1] : Endif
#    If clalev([F:YL1])=0 : Local File YACLINCAL  [YL1] : Endif
#    If clalev([F:YTD])=0 : Local File YTIPDOC    [YTD] : Endif
#    If clalev([F:YTT])=0 : Local File YTRANSAC   [YTT] : Endif
#    If clalev([F:YT2])=0 : Local File YTRANSAC2  [YT2] : Endif
#v11.eo

    ##-- Buscaremos la ruta de los ficheros por defecto y crearemos la ruta final --##
    Read [APX]APX0 = 'REPIMPDEF'

    RUTA = [F:APX]DIRECTORY
    If RUTA = ""
        Call ERREUR(mess(121,141,1)) From GESECRAN
        ERROR_CAL = 1
        End
    Endif

    RUTA = left$(RUTA,len(RUTA)-1)

    FICHEROYC1 = filpath(RUTA,num$(adxuid(1))+"YC1YCQ","TXT")
    #-----------

    Openo FICHEROYC1,0 Using [YC1]

    ERROR_CAL = 0

    Read [YC1] YC10=NUMERO_ORI;"1"
    If fstat
        Raz [F:YC1]
        ERROR_CAL = 1
        End
    Endif

    Call COGER_CONTADOR([F:YC1]TIPDOC,[F:YC1]SERIE,GNUM,[F:YC1]FCY,[F:YC1]EXERCICI) From XCONTROLES

    For [YC1]YC10 Where YDOCREL=NUMERO_ORI

        XDOCLIN = [F:YC1]YDOCLIN

        Wrseq "H" + LSEP + GNUM + LSEP + num$([F:YC1]YDOCLIN) + LSEP + [F:YC1]FCY + LSEP +
&        num$([F:YC1]TIPOFCY) + LSEP + num$([F:YC1]CLASEDOC) + LSEP + [F:YC1]TIPDOC + LSEP +
&        [F:YC1]CODIPERSON + LSEP + [F:PTD]RCPDAT + LSEP + num$([F:YC1]EXERCICI) + LSEP +
&        [F:YC1]TSICOD(0) + LSEP + [F:YC1]TSICOD(1) + LSEP + [F:YC1]TSICOD(2) + LSEP +
&        [F:YC1]ITMREF + LSEP + [F:YC1]CODTRAZA + LSEP + [F:YC1]PLANTA + LSEP + [F:YC1]POHNUM + LSEP +
&        num$([F:YC1]POPLIN) + LSEP + [F:YC1]YDOCCLA + LSEP + [F:YC1]YDOCCLAL + LSEP +
&        num$([F:YC1]CQUANTI1) + LSEP + num$([F:YC1]CQUANTI2) + LSEP + num$([F:YC1]CQUANTI3) + LSEP +
&        num$([F:YC1]UNITATS) + LSEP + [F:YC1]TSICOD(0) + LSEP + [F:YC1]TSICOD(1) + LSEP +
&        [F:YC1]TSICOD(2) + LSEP + num$(NUMERA) + LSEP + num$(DENOMINA) + LSEP + num$([M:YCQ]TPRECIO) + chr$(013) Using [YC1]

        For [YL1]YL10 Where YDOCREL=NUMERO_ORI and YDOCLIN=[F:YC1]YDOCLIN

            Wrseq "D"+ LSEP + [F:YL1]CODCALIFIC + LSEP + num$([F:YL1]QUANTITAT1) + LSEP +
&            num$([F:YL1]QUANTITAT2) + LSEP + num$([F:YL1]QUANTITAT3) + LSEP + num$([F:YL1]VALOR) + LSEP +
&            num$([F:YL1]PREU) + LSEP + num$([F:YL1]IMPORT) + LSEP + num$([F:YL1]TAFECTACIO) + LSEP +
&            num$([F:YL1]TAPLICA) + LSEP + num$([F:YL1]TCALCULO) + LSEP + num$([F:YL1]TCASCADA) + LSEP +
&            num$([F:YL1]TDESTI) + LSEP + num$([F:YL1]TOPERACIO) + LSEP + num$([F:YL1]TORIGEN) + LSEP +
&            num$([F:YL1]NIVELL) + LSEP + num$([F:YL1]ORDRE) + LSEP + [F:YL1]CALIFICASO + LSEP +
&            num$([F:YL1]TPRIMSEC) + LSEP + num$([F:YL1]TREPVALOR) + LSEP +
&            num$([F:YL1]TTIPOVAL) + LSEP + num$([F:YL1]TMOSTRADO) + LSEP +
&            num$([F:YL1]VALOR2) + chr$(013) Using [YC1]

        Next
    Next

    Openo Using [YC1]

    Filter [YC1]
    Filter [YL1]

    If clalev([F:YC1])>0 : Close Local File [YC1] : Endif
    If clalev([F:YL1])>0 : Close Local File [YL1] : Endif

    Call IMPSILEN ('YC40',FICHEROYC1)

#v11.o    If clalev([F:YC1])=0 : Local File YACCABCAL  [YC1] : Endif
    Read [YC1]YC10 = GNUM;XDOCLIN
    If fstat
        Raz [F:YC1]
        Raz CALI
        ERROR_CAL = 1
    Else
        CALI = GNUM
        DTOAI = [F:YC1]PENAI
        DTOII = [F:YC1]PENII
        RECAI = [F:YC1]BONAI
        RECII = [F:YC1]BONII
        ERROR_CAL = 0
    Endif
End
######################################################################################
#SONIA 20-09-07
#Accede a las tablas de gastos para aplicar las bonificaciones/penalizaciones
######################################################################################
$TRACTAR_DESPESES
    Local Char     SENTENCIA1(254)
    Local Char     SENTENCIA2(254)
    Local Integer  TROBAT
    Local Decimal  QUANTITATL
    Local Integer  I

    If clalev([F:YP0])=0 : Local File YTPCABEC   [YP0] : Endif
    If clalev([F:YP1])=0 : Local File YTPLINPER  [YP1] : Endif
    If clalev([F:YP2])=0 : Local File YTPLINEAS  [YP2] : Endif
    If clalev([F:YP3])=0 : Local File YTPLINGRUP [YP3] : Endif

    #Mirem si existeix alguna taula de despeses
    Filter [YP0] Where [YP0]TACTIU=2 and [YP0]CLASEDOC=29 and [YP0]TIPOGASTO=1 and [YP0]NUMPREC=[M:YCQ]NUMDOC Order By [YP0]NUMDOC
    For [YP0]

        Raz TROBAT
        #Mirem si existeix el tercer a la taula de despeses
        Read [YP1]YLC1=[YP0]NUMDOC;PROV

        If fstat=0 Then
            #Mirem com està definida la taula (per producte o grup estadístic).
            If [F:YP0]PRODUCTO=2 Then
                SENTENCIA1 = "[YP2]NUMDOC=[YP0]NUMDOC and [YP2]ITMREF=[F:PTD]ITMREF"
                SENTENCIA2 = "[YP2]CODIPERSON=PROV"

                Filter [YP2]
                Filter [YP2] Where evalue(SENTENCIA1) and evalue(SENTENCIA2)
                Read [YP2]YT10 First : If fstat  Raz [F:YP2] : Endif
                Default File [YP2]

                If rowcount([F:YP2])>0 Then
                    Raz I
                    While I<rowcount([F:YP2]) and not TROBAT
                        If [F:YP2]CALIDAD="" or ([F:YP2]CALIDAD<>"" and [F:YP2]CALIDAD=[F:YT1]CALIDAD) Then
                            TROBAT=1
                        Else
                            Read [YP2]YT10 Next
                            I+=1
                        Endif
                    Wend
                Endif
            Else
                SENTENCIA1 = "[YP3]NUMDOC=[YP0]NUMDOC and [YP3]GRUPO=[F:ITM]TSICOD([F:YP0]GRUPESTAD-1)"
                SENTENCIA2 = "[YP3]CODIPERSON=PROV"

                Filter [YP3]
                Filter [YP3] Where evalue(SENTENCIA1) and evalue(SENTENCIA2)
                Read [YP3]YTG0 First : If fstat  Raz [F:YP3] : Endif
                Default File [YP3]

                If rowcount([F:YP3])>0 Then
                    Raz I
                    While I<rowcount([F:YP3]) and not TROBAT
                        If [F:YP3]CALIDAD="" or ([F:YP3]CALIDAD<>"" and [F:YP3]CALIDAD=[F:YT1]CALIDAD) Then
                            TROBAT=1
                        Else
                            Read [YP3]YTG0 Next
                            I+=1
                        Endif
                    Wend
                Endif
            Endif

            If TROBAT Then
                #El producte-soci existeix a la taula YTPLINEAS o YTPLINGRUP

                #Aplicamos bonificación (+) o penalización (-)
                If [F]TCALCULO=1 Then
                    QUANTITATL=CANTIDAD
                Else
                    QUANTITATL=-CANTIDAD
                Endif

                Wrseq 'L|'+'5' + LSEP + "" + LSEP + num$(0) + LSEP + [F:PTD]ITMREF + LSEP + [F:PTD]UOM + LSEP + num$(QUANTITATL) +
& LSEP + num$([F]PREU1) + LSEP + IVA + LSEP + RETEN + LSEP + RETEN1 + LSEP + LSEP + CALIDAD + LSEP +
& [F]CALIDAD + LSEP + [F]RECOLL + LSEP + PLANTA_REC + LSEP + [F:PTH]YEXERCICI + LSEP + TEST +
& LSEP + PLANTACIO  + LSEP + num$(DISCRGVAL(0)) + LSEP + num$(DISCRGVAL(1)) + LSEP + num$(DISCRGVAL(2)) +
& LSEP + num$(DISCRGVAL(3)) + LSEP + num$(DISCRGVAL(4)) + LSEP + num$(DISCRGVAL(5)) +
& LSEP + num$(DISCRGVAL(6)) + LSEP + num$(DISCRGVAL(7)) + LSEP + num$(DISCRGVAL(8)) +
& LSEP + [F:PTD]YCODTRAZA + LSEP + num$(KGORIGEN) + LSEP + num$(KGBRUTS) + LSEP + num$(KGVEHIC) +
& LSEP + num$(KGTARA) + LSEP + num$(QUANT1) + LSEP + num$(QUANT2) + LSEP + num$(QUANT3) +
& LSEP + num$([F]PREU1) + LSEP + [F:YP0]DESCRIPCIO + LSEP + [F:YP0]NUMDOC + LSEP + "" + LSEP + "" + LSEP + num$(0) +
& LSEP + num$(0) + LSEP + "" + LSEP + "" + LSEP + "" + LSEP + PROV + chr$(013) Using [LIQ]


                Wrseq 'LC' + LSEP + CCE_R(1) + LSEP + CCE_R(2) + LSEP + CCE_R(3) + LSEP + CCE_R(4) + LSEP + CCE_R(5) +
& LSEP + CCE_R(6) + LSEP + CCE_R(7) + LSEP + CCE_R(8) + LSEP + CCE_R(9) + LSEP + CCE_R(10) +
& LSEP + CCE_R(11) + LSEP + CCE_R(12) + LSEP + CCE_R(13) + LSEP + CCE_R(14) + LSEP + CCE_R(15) +
& LSEP + CCE_R(16) + LSEP + CCE_R(17) + LSEP + CCE_R(18) + LSEP + CCE_R(19) + LSEP + CCE_R(20) + chr$(013) Using [LIQ]

            Else
                #No hem trobat el producte-soci. Busquem si existeix el producte sense soci
                #Mirem com està definida la taula (per producte o grup estadístic)
                If [F:YP0]PRODUCTO=2 Then
                    SENTENCIA2 = "[YP2]CODIPERSON=''"
                    Filter [YP2]
                    Filter [YP2] Where evalue(SENTENCIA1) and evalue(SENTENCIA2)
                    Read [YP2]YT10 First : If fstat  Raz [F:YP2] : Endif
                    Default File [YP2]

                    If rowcount([F:YP2])>0 Then
                        Raz I
                        While I<rowcount([F:YP2]) and not TROBAT
                            If [F:YP2]CALIDAD="" or ([F:YP2]CALIDAD<>"" and [F:YP2]CALIDAD=[F:YT1]CALIDAD) Then
                                TROBAT=1
                            Else
                                Read [YP2]YT10 Next
                                I+=1
                            Endif
                        Wend
                    Endif
                Else
                    SENTENCIA2 = "[YP3]CODIPERSON=''"
                    Filter [YP3]
                    Filter [YP3] Where evalue(SENTENCIA1) and evalue(SENTENCIA2)
                    Read [YP3]YTG0 First : If fstat  Raz [F:YP3] : Endif
                    Default File [YP3]

                    If rowcount([F:YP3])>0 Then
                        Raz I
                        While I<rowcount([F:YP3]) and not TROBAT
                            If [F:YP3]CALIDAD="" or ([F:YP3]CALIDAD<>"" and [F:YP3]CALIDAD=[F:YT1]CALIDAD) Then
                                TROBAT=1
                            Else
                                Read [YP3]YTG0 Next
                                I+=1
                            Endif
                        Wend
                    Endif
                Endif

                If TROBAT Then
                    #El producte-sense soci existeix a la taula YTPLINEAS o YTPLINGRUP
                    #Aplicamos bonificación (+) o penalización (-)
                    If [F]TCALCULO=1 Then
                        QUANTITATL=CANTIDAD
                    Else
                        QUANTITATL=-CANTIDAD
                    Endif

                    Wrseq 'L|'+'5' + LSEP + "" + LSEP + num$(0) + LSEP + [F:PTD]ITMREF + LSEP + [F:PTD]UOM + LSEP + num$(QUANTITATL) +
& LSEP + num$([F]PREU1) + LSEP + IVA + LSEP + RETEN + LSEP + RETEN1 + LSEP + LSEP + CALIDAD + LSEP +
& [F]CALIDAD + LSEP + [F]RECOLL + LSEP + PLANTA_REC + LSEP + [F:PTH]YEXERCICI + LSEP + TEST +
& LSEP + PLANTACIO  + LSEP + num$(DISCRGVAL(0)) + LSEP + num$(DISCRGVAL(1)) + LSEP + num$(DISCRGVAL(2)) +
& LSEP + num$(DISCRGVAL(3)) + LSEP + num$(DISCRGVAL(4)) + LSEP + num$(DISCRGVAL(5)) +
& LSEP + num$(DISCRGVAL(6)) + LSEP + num$(DISCRGVAL(7)) + LSEP + num$(DISCRGVAL(8)) +
& LSEP + [F:PTD]YCODTRAZA + LSEP + num$(KGORIGEN) + LSEP + num$(KGBRUTS) + LSEP + num$(KGVEHIC) +
& LSEP + num$(KGTARA) + LSEP + num$(QUANT1) + LSEP + num$(QUANT2) + LSEP + num$(QUANT3) +
& LSEP + num$([F]PREU1) + LSEP + [F:YP0]DESCRIPCIO + LSEP + [F:YP0]NUMDOC + LSEP + "" + LSEP + "" + LSEP + num$(0) +
& LSEP + num$(0) + LSEP + "" + LSEP + "" + LSEP + "" + LSEP + PROV + chr$(013) Using [LIQ]

                    Wrseq 'LC' + LSEP + CCE_R(1) + LSEP + CCE_R(2) + LSEP + CCE_R(3) + LSEP + CCE_R(4) + LSEP + CCE_R(5) +
& LSEP + CCE_R(6) + LSEP + CCE_R(7) + LSEP + CCE_R(8) + LSEP + CCE_R(9) + LSEP + CCE_R(10) +
& LSEP + CCE_R(11) + LSEP + CCE_R(12) + LSEP + CCE_R(13) + LSEP + CCE_R(14) + LSEP + CCE_R(15) +
& LSEP + CCE_R(16) + LSEP + CCE_R(17) + LSEP + CCE_R(18) + LSEP + CCE_R(19) + LSEP + CCE_R(20) + chr$(013) Using [LIQ]

                Endif
            Endif
        Endif
    Next
    Filter [YP0]
    Filter [YP2]
    Filter [YP3]
Return
######################################################################################
Subprog CREAR_CLASIFIC(NUMERO_CLA,ORDEN_CLA,CLAS,PROV,ERROR_CLA)
    Value     Char     NUMERO_CLA
    Value     Char     ORDEN_CLA
    Variable  Char     CLAS
    Variable  Char     PROV
    Variable  Integer  ERROR_CLA
    Local     Char     GNUM
    Local     Char     TIPDOC, SERIEDOC
    Local     Integer  CLASEDOCUM
#V11BO
#    If clalev([F:YC2])=0 : Local File YACCABCLA  [YC2] : Endif
#    If clalev([F:YL2])=0 : Local File YACLINCLA  [YL2] : Endif
#    If clalev([F:XC2])=0 : Local File YACCABCLA  [XC2] : Endif
#    If clalev([F:XL2])=0 : Local File YACLINCLA  [XL2] : Endif
#    If clalev([F:YTD])=0 : Local File YTIPDOC    [YTD] : Endif
#v11.eo
    Raz [F:YC2]
    Raz [F:YL2]
    Raz [F:XC2]
    Raz [F:XL2]

    ERROR_CLA = 0
    Read [YC2] YC20=NUMERO_CLA;ORDEN_CLA : If fstat Raz [F:YC2] : ERROR = 1 : End : Endif

    Raz TIPDOC

    TIPDOC = [M:YCQ]TIPDOC

    Call BUSCAR_TIPO_DOCUM("PIH","", "YC2", TIPDOC) From XCONTROLES
    If TIPDOC = ""
        GOK = 0
        GERR=1
        Call ERREUR(mess(117,1986,1)) From GESECRAN
        End
    Endif

    Read [YTD]YTD0=TIPDOC  ###- Aqui tendremos que mirar que tipo documento corresponde
    If fstat
        GOK = 0
        End
    Endif

    SERIEDOC = [F:YTD]SERIEDOCUM
    CLASEDOCUM = [F:YTD]CLASEDOCUM

    Call COGER_CONTADOR(TIPDOC,SERIEDOC,GNUM,[F:YC2]FCY,[F:YC2]EXERCICI) From XCONTROLES

    [F:XC2] = [F:YC2]
    [F:XC2]CODIPERSON = PROV
    [F:XC2]SERIE      = SERIEDOC
    [F:XC2]TIPDOC     = TIPDOC
    [F:XC2]CLASEDOC   = CLASEDOCUM
    [F:XC2]CQUANTI1   = 0
    [F:XC2]DATA       = [M:YCQ]DATAFAC
    [F:XC2]DESDOCUM   = "Liquidaciones"
    [F:XC2]YDOCLIN    = "1"
    [F:XC2]YDOCREL    = GNUM
    [F:XC2]TESTP      = 2
    [F:XC2]TESTE      = 2
    [F:XC2]CREUSR     = GUSER
    [F:XC2]CREDAT     = date$
    [F:XC2]UPDUSR     = GUSER
    [F:XC2]UPDDAT     = date$
    CLAS = GNUM

    Trbegin[XC2],[XL2]

    Write [XC2]
    If fstat
         GOK=0 : Rollback : Call FSTA("XC2") From GLOCK : ERROR_CLA = 1 : End
    Endif

    For [YL2]YL20 Where YDOCREL=NUMERO_CLA and YDOCLIN=ORDEN_CLA
        [F:XL2] = [F:YL2]

        [F:XL2]SERIE      = SERIEDOC
        [F:XL2]TIPDOC     = TIPDOC
        [F:XL2]CLASEDOC   = CLASEDOCUM
        [F:XL2]QUANTITAT1 = 0
        [F:XL2]IMPORT     = 0
        [F:XL2]YDOCLIN    = "1"
        [F:XL2]YDOCREL    = GNUM
        [F:XL2]CREUSR     = GUSER
        [F:XL2]CREDAT     = date$
        [F:XL2]UPDUSR     = GUSER
        [F:XL2]UPDDAT     = date$

        Write [XL2]
        If fstat
             GOK=0 : Rollback : Call FSTA("XL2") From GLOCK : ERROR_CLA = 1 : End
        Endif
    Next

    Commit
End
######################################################################################
Subprog BUSCAR_ELEMENTOS(DOCU)
    Value Char DOCU
    Local Decimal IMPORTE
    Local Char DOCU1 : DOCU1 = DOCU

    For I=0 To [M:YCQ]NBINV -1
        Raz IMPORTE
        DOCU1 = DOCU
        Call BUSCAR_ELEMENTOS_LIQ(DOCU1,IMPORTE,[M:YCQ]INVDTA(I))
        [M:YCQ]INVDTAAMT(I) = IMPORTE
    Next
End
######################################################################################
Subprog BUSCAR_ELEMENTOS_LIQ(DOCU,IMP,ELEM)
    Variable  Char     DOCU
    Variable  Decimal  IMP
    Value     Integer  ELEM

    Local     Char     DOCUMENTO
    Local     Integer  I : I=0

    If clalev([F:YLQ])=0 : Local File YACLINLIQ  [YLQ] : Endif
    If clalev([F:PIV])=0 : Local File PINVOICEV  [PIV] : Endif

    Local Char REQUETE(255)

    While I=0

        REQUETE="SELECT DISTINCT(NUMDOC_0) FROM YACLINLIQ Where NUMDOC_0 <> '' and PIHNUM_0 ='" + DOCU + "'"
        Raz DOCU
        For (Char DOCUMENTO) From "5" Sql REQUETE As [XXX]
            Read [PIV]PIV0 = [F:XXX]DOCUMENTO : If fstat Raz [F:PIV] : Break : End : Endif
            For X=0 To 14
                If [F:PIV]INVDTA(X) = ELEM
                    IMP = IMP + [F:PIV]INVDTAAMT(X)
                    DOCU = [F:XXX]DOCUMENTO
                    Call BUSCAR_ELEMENTOS_LIQ(DOCU,IMP,ELEM)
                    Break
                Endif
            Next
        Next

        If DOCU = "" : I=1 : Endif
    Wend
End
######################################################################################
Subprog BUSCAR_ELEMENTOS_ANT(DOCU,IMP,ELEM)
    Variable Char DOCU
    Variable Decimal IMP
    Value Integer ELEM
    Local    Char DOCUMENTO

    If clalev([F:YLQ])=0 : Local File YACLINLIQ  [YLQ] : Endif
    If clalev([F:PIV])=0 : Local File PINVOICEV  [PIV] : Endif

    Local Char REQUETE(255)

    REQUETE="SELECT DISTINCT(NUMDOC_0) FROM YACLINLIQ Where NUMDOC_0 <> '' and PIHNUM_0 ='" + DOCU + "'"
    Raz DOCU
    For (Char DOCUMENTO) From "5" Sql REQUETE As [XXX]
        Read [PIV]PIV0 = [F:XXX]DOCUMENTO : If fstat Raz [F:PIV] : Break : End : Endif
        For X=0 To 14
            If [F:PIV]INVDTA(X) = ELEM
                IMP = IMP + [F:PIV]INVDTAAMT(X)
                DOCU = [F:XXX]DOCUMENTO
                Break
            Endif
        Next
    Next
End
######################################################################################
#SONIA 27-06-08
#Accede a las tablas de gastos para aplicar las bonificaciones/penalizaciones
######################################################################################
$TRACTAR_DESPESES_DIRECTES
    Local Char     SENTENCIA1(254)
    Local Char     SENTENCIA2(254)
    Local Integer  TROBAT
    Local Decimal  QUANTITATL
    Local Char     ARTICLE_DESP
    Local Char     LSEC
    Local Integer  I
#ESTA PENDENT DE TRACTAR ELS CAMPS DE QUALITAT I RECOLECCIO

    If clalev([F:YP0])=0 : Local File YTPCABEC   [YP0] : Endif
    If clalev([F:YP1])=0 : Local File YTPLINPER  [YP1] : Endif
    If clalev([F:YP2])=0 : Local File YTPLINEAS  [YP2] : Endif
    If clalev([F:YP3])=0 : Local File YTPLINGRUP [YP3] : Endif

    #Mirem si existeix alguna taula de despeses per import directe
    #Aquestes han d'estar definides per producte
    #Amb una mateixa taula, no barrejar mai despeses a nivell de soci i a nivell general (crear dos taules)
    Filter [YP0] Where [YP0]TACTIU=2 and [YP0]CLASEDOC=29 and [YP0]TIPOGASTO=2 and [YP0]NUMPREC=[M:YCQ]NUMDOC and [F:YP0]PRODUCTO=2 Order By [YP0]NUMDOC

    For [YP0]

        #Mirem si existeix el tercer a la taula de despeses
        Read [YP1]YLC1=[YP0]NUMDOC;PROV
        If fstat=0 Then

            Raz TROBAT
            #Mirem com estÃ  definida la taula (per producte o grup estadÃ­stic).
            SENTENCIA1 = "[YP2]NUMDOC=[YP0]NUMDOC"
            SENTENCIA2 = "[YP2]CODIPERSON=PROV"
            Filter [YP2]
            Filter [YP2] Where evalue(SENTENCIA1) and evalue(SENTENCIA2)

            Read [YP2]YT10 First : If fstat  Raz [F:YP2] : Endif
            If rowcount([F:YP2])>0 Then : TROBAT=1 : ARTICLE_DESP=[F:YP2]ITMREF : Default File [YP2] : Endif

            If TROBAT Then
                #El producte-soci existeix a la taula YTPLINEAS o YTPLINGRUP

                For [YP2]
                    TROBAT=1
                    Default File [YP2]
                    ARTICLE_DESP=[F]ITMREF

                    #Aplicamos bonificaciÃ³n (+) o penalizaciÃ³n (-)
                    If [F]TCALCULO=1 Then
                        QUANTITATL=[F]QUANTITAT1
                    Else
                        QUANTITATL=-[F]QUANTITAT1
                    Endif

                    #Llegim el producte per anar a buscar la seva unitat de compra
                    Read [ITX]ITM0 = ARTICLE_DESP

                    Call ALITAXE(VAC,[F:ITX]VACITM,VAT) From TRTX3
                    IVA = VAT(0)
                    RETEN = VAT(1)
                    RETEN1 = VAT(2)

                    If TIVA = 1       : IVA = "00R"   : Endif
                    If TRETENCION = 1 : RETEN = "IR0" : RETEN1 = "" : Endif

                    For I=1 To GOPTCANA
                        Call INISEC (LSEC, "YLIQ", num$(I)) From SUBCDE
                        Assign "CCE"+num$(I)+"_R" With LSEC
                    Next

                    Wrseq 'L|'+'5' + LSEP + "" + LSEP + num$(0) + LSEP + ARTICLE_DESP + LSEP + [F:ITX]PUU + LSEP + num$(QUANTITATL) +
& LSEP + num$([F]PREU1) + LSEP + IVA + LSEP + RETEN + LSEP + RETEN1 + LSEP + LSEP + LSEP +
& [F]CALIDAD + LSEP + [F]RECOLL + LSEP + [F:YP0]FCY + LSEP + [F:YP0]EXERCICI + LSEP + TEST +
& LSEP + LSEP + num$(0) + LSEP + num$(0) + LSEP + num$(0) +
& LSEP + num$(0) + LSEP + num$(0) + LSEP + num$(0) +
& LSEP + num$(0) + LSEP + num$(0) + LSEP + num$(0) +
& LSEP + LSEP + num$(0) + LSEP + num$(QUANTITATL) + LSEP + num$(0) +
& LSEP + num$(0) + LSEP + num$(QUANTITATL) + LSEP + num$(0) + LSEP + num$(0) +
& LSEP + num$([F]PREU1) + LSEP + [F:YP0]DESCRIPCIO + LSEP + [F:YP0]NUMDOC + LSEP + "" + LSEP + "" + LSEP + num$(0) +
& LSEP + num$(0) + LSEP + "" + LSEP + "" + LSEP + "" + LSEP + PROV + chr$(013) Using [LIQ]

                    Wrseq 'LC' + LSEP + CCE_R(1) + LSEP + CCE_R(2) + LSEP + CCE_R(3) + LSEP + CCE_R(4) + LSEP + CCE_R(5) +
& LSEP + CCE_R(6) + LSEP + CCE_R(7) + LSEP + CCE_R(8) + LSEP + CCE_R(9) + LSEP + CCE_R(10) +
& LSEP + CCE_R(11) + LSEP + CCE_R(12) + LSEP + CCE_R(13) + LSEP + CCE_R(14) + LSEP + CCE_R(15) +
& LSEP + CCE_R(16) + LSEP + CCE_R(17) + LSEP + CCE_R(18) + LSEP + CCE_R(19) + LSEP + CCE_R(20) + chr$(013) Using [LIQ]

                Next
            Else
                #No hem trobat el producte-soci. Busquem si existeix el producte sense soci
                #Mirem com estÃ  definida la taula (per producte o grup estadÃ­stic)
                SENTENCIA2 = "[YP2]CODIPERSON=''"
                Filter [YP2]
                Filter [YP2] Where evalue(SENTENCIA1) and evalue(SENTENCIA2)
                Read [YP2]YT10 First : If fstat  Raz [F:YP2] : Endif
                If rowcount([F:YP2])>0 Then : TROBAT=1 : ARTICLE_DESP=[F:YP2]ITMREF : Default File [YP2] : Endif

                If TROBAT Then
                    #El producte-sense soci existeix a la taula YTPLINEAS o YTPLINGRUP
                    #Aplicamos bonificaciÃ³n (+) o penalizaciÃ³n (-)

                    For [YP2]
                        TROBAT=1
                        Default File [YP2]
                        ARTICLE_DESP=[F]ITMREF

                        If [F]TCALCULO=1 Then
                            QUANTITATL=[F]QUANTITAT1
                        Else
                            QUANTITATL=-[F]QUANTITAT1
                        Endif

                        #Llegim el producte per anar a buscar la seva unitat de compra
                        Read [ITX]ITM0 = ARTICLE_DESP

                        Call ALITAXE(VAC,[F:ITX]VACITM,VAT) From TRTX3
                        IVA = VAT(0)
                        RETEN = VAT(1)
                        RETEN1 = VAT(2)

                        If TIVA = 1       : IVA = "00R"   : Endif
                        If TRETENCION = 1 : RETEN = "IR0" : RETEN1 = "" : Endif

                        For I=1 To GOPTCANA
                            Call INISEC (LSEC, "YLIQ", num$(I)) From SUBCDE
                            Assign "CCE"+num$(I)+"_R" With LSEC
                        Next

                        Wrseq 'L|'+'5' + LSEP + "" + LSEP + num$(0) + LSEP + ARTICLE_DESP + LSEP + [F:ITX]PUU + LSEP + num$(QUANTITATL) +
& LSEP + num$([F]PREU1) + LSEP + IVA + LSEP + RETEN + LSEP + RETEN1 + LSEP + LSEP + LSEP +
& [F]CALIDAD + LSEP + [F]RECOLL + LSEP + [F:YP0]FCY + LSEP + [F:YP0]EXERCICI + LSEP + TEST +
& LSEP + LSEP + num$(0) + LSEP + num$(0) + LSEP + num$(0) +
& LSEP + num$(0) + LSEP + num$(0) + LSEP + num$(0) +
& LSEP + num$(0) + LSEP + num$(0) + LSEP + num$(0) +
& LSEP + LSEP + num$(0) + LSEP + num$(QUANTITATL) + LSEP + num$(0) +
& LSEP + num$(0) + LSEP + num$(QUANTITATL) + LSEP + num$(0) + LSEP + num$(0) +
& LSEP + num$([F]PREU1) + LSEP + [F:YP0]DESCRIPCIO + LSEP + [F:YP0]NUMDOC + LSEP + "" + LSEP + "" + LSEP + num$(0) +
& LSEP + num$(0) + LSEP + "" + LSEP + "" + LSEP + "" + LSEP + PROV + chr$(013) Using [LIQ]

                        Wrseq 'LC' + LSEP + CCE_R(1) + LSEP + CCE_R(2) + LSEP + CCE_R(3) + LSEP + CCE_R(4) + LSEP + CCE_R(5) +
& LSEP + CCE_R(6) + LSEP + CCE_R(7) + LSEP + CCE_R(8) + LSEP + CCE_R(9) + LSEP + CCE_R(10) +
& LSEP + CCE_R(11) + LSEP + CCE_R(12) + LSEP + CCE_R(13) + LSEP + CCE_R(14) + LSEP + CCE_R(15) +
& LSEP + CCE_R(16) + LSEP + CCE_R(17) + LSEP + CCE_R(18) + LSEP + CCE_R(19) + LSEP + CCE_R(20) + chr$(013) Using [LIQ]

                    Next

                Endif
            Endif
        Endif
    Next
    Filter [YP0]
    Filter [YP2]
    Filter [YP3]
Return
######################################################################################
Subprog CALNET (PARTNER,STRUCTURE,BRUT,MAJREM,QTE,NET,CUR)
    Value    Integer PARTNER
    Value    Char    STRUCTURE
    Value    Decimal BRUT, QTE
    Value    Decimal MAJREM(0..8)
    Variable Decimal NET
    Value    Char    CUR

    Local    Decimal WREM(0..8) : Raz WREM
    Local    Integer I

    If dim(GCALNETLIN)<=0 : Global Integer GCALNETLIN : Endif
    If dim(GCALNETABR)<=0 : Global Char    GCALNETABR : Endif

    If clalev ([F:PRS])<=0 : Local File PRICSTRUCT [PRS] : Endif
    #Call LECTURE ("PRS",STRUCTURE,num$(PARTNER)) From CONTOBJ
    Read [PRS]PRS0=PARTNER;STRUCTURE
    If fstat
       NET = 0 : Raz GCALNETLIN,GCALNETABR
       End
    Endif
    If QTE = 0  QTE = 1  Endif
    NET = BRUT
    For I = 0 To 8
       If [F:PRS]NPRNOTFLG(I) = 2
          If [F:PRS]INCDCR(I) = 1
             If [F:PRS]VALTYP(I) = 1
                If [F:PRS]CLCRUL(I) <> 1
                   NET += MAJREM(I)/QTE      : WREM(I) = MAJREM(I)/QTE
                Else
                   NET += MAJREM(I)          : WREM(I) = MAJREM(I)
                Endif
             Elsif [F:PRS]VALTYP(I) = 2
                WREM(I) = (BRUT*MAJREM(I))/100 : NET += (BRUT*MAJREM(I))/100
             Else
                WREM(I) = (NET*MAJREM(I))/100  : NET += (NET*MAJREM(I))/100
             Endif
          Else
             If [F:PRS]VALTYP(I) = 1
                If [F:PRS]CLCRUL(I) <> 1
                   NET -= MAJREM(I)/QTE      : WREM(I) = -MAJREM(I)/QTE
                Else
                   NET -= MAJREM(I)          : WREM(I) = -MAJREM(I)
                Endif
             Elsif [F:PRS]VALTYP(I) = 2
                WREM(I) = -(BRUT*MAJREM(I))/100 : NET -= (BRUT*MAJREM(I))/100
             Else
                WREM(I) = -(NET*MAJREM(I))/100  : NET -= (NET*MAJREM(I))/100
             Endif
          Endif
       Endif
    Next I

    # Point d'entrÃ©e pour intervenir sur le calcul du prix net
    Local Integer GPE_RND
    GPOINT="CALNET" : Gosub ENTREE From EXEFNC

    GPURNEGPRI=2
    #---------------------#
    # arrondi du prix net #
    #---------------------#
    If !GPE_RND
       If (PARTNER = 1 & GSALRND = 2) | (PARTNER = 2 & GPURRND = 2)
          Call ARRDEV(NET,CUR) From TRTDIV
       Else
          NET = arr(NET,10^-GDECPRI)
       Endif
    Endif
    Raz GPE_RND

    #----- Test si prix net nÃ©gatif alors GMESSAGE et raz -----#
    #If NET<0  GMESSAGE=mess(216,199,1) : GERR=2 Else Raz GMESSAGE : Endif
    #--------------------------------------------------------#
    # Point d'entrÃ©e NEGPRI pour autoriser les prix nÃ©gatifs #
    # ------------------------------------------------------ #
    # Ce point d'entrÃ©e n'est appelÃ© que pour les achats,    #
    # si l'article concernÃ© n'est pas gÃ©rÃ© en stock.         #
    # AppelÃ© dans les ventes (05/08/03) pour dem.modif 18577 #
    # mais non documentÃ© pour rester ponctuel(trop dangereux)#
    #                                                        #
    # Variables utilisables par le point d'entrÃ©e            #
    # PARTNER   : Business partner (2=Fournisseur)           #
    # STRUCTURE : Code structure tarif                       #
    # BRUT      : Prix unitaire brut                         #
    # NET       : Prix unitaire net                          #
    # GMESSAGE  : Est renseignÃ© si le prix est nÃ©gatif       #
    # ------------------------------------------------------ #
    # Variable modifiable par le point d'entrÃ©e              #
    # Effacer GMESSAGE pour autoriser le prix nÃ©gatif        #
    #--------------------------------------------------------#
    If PARTNER=2 & dim(GPURNEGPRI)>0 & GPURNEGPRI=2
      GPOINT="NEGPRI" : Gosub ENTREE From EXEFNC
      Raz GPURNEGPRI
    Endif
    If PARTNER=1
      GPOINT="NEGPRI" : Gosub ENTREE From EXEFNC
    Endif
    #-----
    If GMESSAGE<>""  Raz NET : Endif
    Raz GCALNETLIN, GCALNETABR
End
######################################################################################
## Función que busca si la calidad de la recepción ya la hemos tratado en alguna
## linea de la liquidación    - JGM - 02/05/2012
######################################################################################
Subprog BUSCAR_CALIDAD(NUMDOC_C,CALIDAD_T,CALIDAD_C,ITMREF_C,EXISTE_C)
    Variable    Char    NUMDOC_C
    Variable    Char    CALIDAD_T
    Variable    Char    CALIDAD_C
    Variable    Char    ITMREF_C
    Variable    Integer EXISTE_C

    If clalev([F:ZYT1])=0 : Local File YTPLINEAS  [ZYT1] : Endif

    EXISTE_C = 0
    If CALIDAD_T = CALIDAD_C : End : Endif

    For [ZYT1]YT10 Where NUMDOC=NUMDOC_C and ITMREF = ITMREF_C and CALIDAD = CALIDAD_C
        EXISTE_C = 2
        Break
    Next
End
######################################################################################
## Funcion de marcar las recepciones como facturadas
######################################################################################
Subprog MARCAR_REC_DOC(DOCU,NUMLIQ,LINLIQ)
    Variable    Char    DOCU
    Variable    Char    NUMLIQ
    Variable    Integer LINLIQ

#v11.bo
#    If clalev([F:YC2])=0 : Local File YACCABCLA  [YC2] : Endif
#    If clalev([F:YL2])=0 : Local File YACLINCLA  [YL2] : Endif
#    If clalev([F:YC1])=0 : Local File YACCABCAL  [YC1] : Endif
#    If clalev([F:YL1])=0 : Local File YACLINCAL  [YL1] : Endif
#v11.eo

    If clalev([F:YQX])=0 : Local File YACLINLIQ  [YQX] : Endif
    If clalev([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif
    If clalev([F:PID])=0 : Local File PINVOICED  [PID] : Endif
    If clalev([F:XLC])=0 : Local File YTPLINPER  [XLC] : Endif

    #24026 - Faltava parentesis (RPASC 24-9-13)
    Filter [YLQ] Where (TEST1 = 1 or TEST1) = 3 and [F:YLQ]PIHNUM = DOCU and NUMIDENT = adxuid(1) Order By NUMLIN

    For [YLQ]
        Raz [PIH]
        Filter [PIH]

        Read [PIH]YPIH0 = [F:YLQ]PIHNUM
        If fstat
            Raz [F:PIH]
            Read [PIH]PIH0 = [F:YLQ]PIHNUM
            If fstat Raz [F:PIH] : Endif
        Endif

        If [F:PIH]NUM <> ""

            If [M:YCQ]CLASEDOC = 15
                If [F:YLQ]PTHNUM <> ""
                    ##--- Aqui marcamos el albaran como facturado ----------------------##
                    Trbegin [PTD]
                    Update [PTD] Where PTHNUM = [F:YLQ]PTHNUM With LININVFLG = 2
                    If fstat
                        GOK=0 : Rollback : Call FSTA("PTD") From GLOCK : Filter [YLQ] : Filter [PIH] : End
                    Endif
                    Commit

                    Trbegin [PTH]
                    Update [PTH] Where PTHNUM = [F:YLQ]PTHNUM With INVFLG = 3
                    If fstat
                        GOK=0 : Rollback : Call FSTA("PTH") From GLOCK : Filter [YLQ] : Filter [PIH] : End
                    Endif
                    Commit
                    ##------------------------------------------------------------------##
                Endif
               # If [F:YLQ]PNHNUM <> ""
               #     ##--- Aqui marcamos la devolución como facturada -------------------##
               #     Trbegin [PND]
               #     Update [PND] Where PNHNUM = [F:YLQ]PNHNUM With LININVFLG = 2
               #     If fstat
               #         GOK=0 : Rollback : Call FSTA("PND") From GLOCK : End
               #     Endif
               #     Commit
               #     ##------------------------------------------------------------------##
               # Endif
                If [F:YLQ]NUMDOC <> ""
                    ##--- Aqui marcamos el anticipo como incluido en una liquidacion----##
                    Trbegin [PID]
                    Update [PID] Where NUM = [F:YLQ]NUMDOC and PIDLIN = [F:YLQ]LINEA With YTEST2L = '2'
                    If fstat
                        GOK=0 : Rollback : Call FSTA("PID") From GLOCK : Filter [YLQ] : Filter [PIH] : End
                    Endif
                    Commit
                    ##------------------------------------------------------------------##
                Endif
            Endif

            If [M:YCQ]CLASEDOC = 14 and [M:YCQ]RESTANT = 1
                If [F:YLQ]NUMDOC <> ""
                    ##--- Aqui marcamos el anticipo como incluido en una liquidacion----##
                    Trbegin [PID]
                    Update [PID] Where NUM = [F:YLQ]NUMDOC and PIDLIN = [F:YLQ]LINEA With YTEST2L = '2'
                    If fstat
                        GOK=0 : Rollback : Call FSTA("PID") From GLOCK : Filter [YLQ] : Filter [PIH] : End
                    Endif
                    Commit
                    ##------------------------------------------------------------------##
                Endif
            Endif

            If [F:YLQ]PTHNUM <> ""
                ##-- Aqui relaciona el albaran con el numero final de factura ------##
                Trbegin [YQX]
                Update [YQX] Where PTHNUM = [F:YLQ]PTHNUM and TEST1 = 1 With PIHNUM = [F:PIH]NUM,TEST1 = 2
                If fstat
                    GOK=0 : Rollback : Call FSTA("YQX") From GLOCK : Filter [YLQ] : Filter [PIH] : End
                Endif
                Commit
                ##------------------------------------------------------------------##
                ##-- Aqui relaciona el albaran con el numero final de factura ------##

                ##-- JGM 04/02/2013
                ##-- No actualitzem els de tipo TEST1 = 3, ja que mes endavant els eliminem
                #Trbegin [YQX]
                #Update [YQX] Where PTHNUM = [F:YLQ]PTHNUM and TEST1 = 3 With PIHNUM = [F:PIH]NUM
                #If fstat
                #    GOK=0 : Rollback : Call FSTA("YQX") From GLOCK : Filter [YLQ] : Filter [PIH] : End
                #Endif
                #Commit
                ##------------------------------------------------------------------##
            Endif
          #  If [F:YLQ]PNHNUM <> ""
          #      ##-- Aqui relaciona la devolucion con el numero final de factura ------##
          #      Trbegin [YQX]
          #      Update [YQX] Where PNHNUM = [F:YLQ]PNHNUM and TEST1 = 1 With PIHNUM = [F:PIH]NUM,TEST1 = 2
          #      If fstat
          #          GOK=0 : Rollback : Call FSTA("YQX") From GLOCK : End
          #      Endif
          #      Commit
          #      ##------------------------------------------------------------------##
          #      ##-- Aqui relaciona la devolucion con el numero final de factura ------##
          #      Trbegin [YQX]
          #      Update [YQX] Where PNHNUM = [F:YLQ]PNHNUM and TEST1 = 3 With PIHNUM = [F:PIH]NUM
          #      If fstat
          #          GOK=0 : Rollback : Call FSTA("YQX") From GLOCK : End
          #      Endif
          #      Commit
          #      ##------------------------------------------------------------------##
          #  Endif
            If [F:YLQ]NUMDOC <> ""
                ##-- Aqui relaciona el anticipo con el numero final de factura ------##
                Trbegin [YQX]
                Update [YQX] Where NUMDOC = [F:YLQ]NUMDOC and LINEA = [F:YLQ]LINEA and TEST1 = 1 With PIHNUM = [F:PIH]NUM,TEST1 = 2
                If fstat
                    GOK=0 : Rollback : Call FSTA("YQX") From GLOCK :Filter [YLQ] : Filter [PIH] : End
                Endif
                Commit
                ##------------------------------------------------------------------##
                ##-- Aqui relaciona el anticipo con el numero final de factura ------##

                ##-- JGM 04/02/2013
                ##-- No actualitzem els de tipo TEST1 = 3, ja que mes endavant els eliminem
                #Trbegin [YQX]
                #Update [YQX] Where NUMDOC = [F:YLQ]NUMDOC and LINEA = [F:YLQ]LINEA and TEST1 = 3 With PIHNUM = [F:PIH]NUM
                #If fstat
                #    GOK=0 : Rollback : Call FSTA("YQX") From GLOCK :Filter [YLQ] : Filter [PIH] : End
                #Endif
                #Commit
                ##------------------------------------------------------------------##
            Endif


            ##-- Aqui marquem el registre de la taula YTPLINPER com a procesat ------##
            Trbegin [XLC]
            Update [XLC] Where NUMDOC = NUMLIQ and NUMLIN = LINLIQ With TFACGEN = 2
            If fstat
                GOK=0 : Rollback : Call FSTA("XLC") From GLOCK : Filter [YLQ] : Filter [PIH] : End
            Endif
            Commit
            ##------------------------------------------------------------------##

        Else
            Read [PID]YPID6 = [F:YLQ]YDOCCLA
            If fstat
                Trbegin [YL2],[YC2]
                Delete [YL2] Where YDOCREL = [F:YLQ]YDOCCLA
                If fstat=1  : GOK=-1 : Call RSTA("YL2",[F:YLQ]YDOCCLA) From GLOCK : Rollback : Break : Filter [YLQ] : Filter [PIH] : End : Endif

                Delete [YC2] Where YDOCREL = [F:YLQ]YDOCCLA
                If fstat=1  : GOK=-1 : Call RSTA("YC2",[F:YLQ]YDOCCLA) From GLOCK : Rollback : Break : Filter [YLQ] : Filter [PIH] : End : Endif

                Commit
            Else
                ##-- Aqui relaciona el albaran con el numero final de factura ------##
                Trbegin [YQX]
                Update [YQX] Where PIHNUM = [F:YLQ]PIHNUM and TEST1 = 1 With PIHNUM = [F:PID]NUM,TEST1 = 2
                If fstat
                    GOK=0 : Rollback : Call FSTA("YQX") From GLOCK : Filter [YLQ] : Filter [PIH] : End
                Endif
                Commit
                ##------------------------------------------------------------------##
            Endif

            Read [PID]YPID5 = [F:YLQ]YDOCCAL
            If fstat
                Trbegin [YL1],[YC1]
                Delete [YL1] Where YDOCREL = [F:YLQ]YDOCCAL
                If fstat=1  : GOK=-1 : Call RSTA("YL1",[F:YLQ]YDOCCAL) From GLOCK : Rollback : Break : Filter [YLQ] : Filter [PIH] : End : Endif

                Delete [YC1] Where YDOCREL = [F:YLQ]YDOCCAL
                If fstat=1  : GOK=-1 : Call RSTA("YC1",[F:YLQ]YDOCCAL) From GLOCK : Rollback : Break : Filter [YLQ] : Filter [PIH] : End : Endif

                Commit
            Else
                ##-- Aqui relaciona el albaran con el numero final de factura ------##
                Trbegin [YQX]
                Update [YQX] Where PIHNUM = [F:YLQ]PIHNUM and TEST1 = 1 With PIHNUM = [F:PID]NUM,TEST1 = 2
                If fstat
                    GOK=0 : Rollback : Call FSTA("YQX") From GLOCK : Filter [YLQ] : Filter [PIH] : End
                Endif
                Commit
                ##------------------------------------------------------------------##
            Endif
        Endif

    Next

    ##---Punto de entrada para poder marcar documentos.
    GPOINT = "XMARCAR" : Gosub ENTREE From EXEFNC

    ##-- Aqui borraremos todos los registros que no se hayan traspasado correctamente.
    Trbegin[YLQ]
    Delete [YLQ] Where TEST1 = 1 and [F:YLQ]PIHNUM = DOCU and NUMIDENT = adxuid(1)
    If fstat
        GOK=0 : Rollback : Call FSTA("YLQ") From GLOCK : Filter [YLQ] : Filter [PIH] : End
    Endif
    Commit

    Raz [YLQ]
    Filter [YLQ]
    Filter [PIH]

    For [YLQ] Where TEST1 = 3 and [F:YLQ]PIHNUM = DOCU and NUMIDENT = adxuid(1)
        If [F:YLQ]PTHNUM <> ""
            Call ECR_TRACE("Error recepcion nº " + [F:YLQ]PTHNUM + " sin escandallar",1) From GESECRAN
        Endif
        If [F:YLQ]PNHNUM <> ""
            Call ECR_TRACE("Error devolución nº " + [F:YLQ]PNHNUM + " sin escandallar",1) From GESECRAN
        Endif
    Next

    ##-- Aqui borraremos todos los registros que no se hayan traspasado correctamente.
    Trbegin[YLQ]
    Delete [YLQ] Where TEST1 = 3 and [F:YLQ]PIHNUM = DOCU and NUMIDENT = adxuid(1)
    If fstat
        GOK=0 : Rollback : Call FSTA("YLQ") From GLOCK : End
    Endif
    Commit
    ##---------------------------------------------------------------##

    Trbegin [YLQ]
    Update [YLQ] Where [YLQ]NUMIDENT = adxuid(1) With TEST1 = 0, NUMIDENT = 0
    If fstat
        GOK=0 : Rollback : Call FSTA("YLQ") From GLOCK : End
    Endif
    Commit
End
