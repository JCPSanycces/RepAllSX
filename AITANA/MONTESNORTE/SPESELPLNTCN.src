#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "SEL_TABLE"     : Gosub SEL_TABLE
 When Default
Endcase
Return

#########################################################################
#    CHOIX DANS LES TABLES                                              #
#########################################################################
$SEL_TABLE
Case TABLE
    When "SELZPLNTCN"    : Gosub S_ZPLANTACION
Endcase
Return


$S_ZPLANTACION
#SELECCIÓN PLANTACION SEGÚN EL PROVEEDOR

  ##TABLAS QUE PARTICIPARÁN EN LA SELECCIÓN
  If clalev([F:YPL])=0 : Local File YPLANTACI[YPL] : Endif

  ##PARA QUE LA SELECCIÓN FUNCIONE DESDE CUALQUIER PANTALLA, POR PARÁMETRO SE
  ##DEBERÁ PASAR EL CÓDIGO A FILTRAR
  Local Char ZCODI1 : ZCODI1=PARAM(1)

  #SI HAY QUE ENLAZAR LAS TABLAS, EL LINK SE HARÁ INDICANDO PRIMERO LA
  #TABLA SOBRE LA CUAL SE DESEA MOSTRAR LAS COLUMNAS, SIENDO EL RESTO DE TABLAS
  #LAS QUE SIRVEN COMO CRITERIO SOBRE LA PRIMERA
  Default File [YPL]

  ORDRE = "CODIPLANTA"  #SE INDICA QUÉ COLUMNA VA A SERVIR DE ORDENACIÓN
  START = "CODIPLANTA" #SE INDICA QUÉ COLUMNA SE DEVUELVE EN LA SELECCIÓN
  SENS =1
  DEFPAG = 5
  SIZCOL = 100
  SIZLIG = 150

  #APLICACIÓN DE LOS CRITERIOS SOBRE EL DEFAULT FILE, EN ESTE CASO EL LINK
  #If GFONCTION="GESZPE"
    CRITERE='[F:YPL]CODIPROPI=ZCODI1'
  #Endif

  TIT(0) = "Selección Plantación"
  NBCOL = 0
  NBCOL +=1 : COL(NBCOL) = "CODIPLANTA" : TIT(NBCOL)="Plantación"
  NBCOL +=1 : COL(NBCOL) = "NOMPLANTA" : TIT(NBCOL)="Nombre"
  NBCOL +=1 : COL(NBCOL) = "VARIETAT" : TIT(NBCOL)="Variedad"
  NBCOL +=1 : COL(NBCOL) = "POLIGONO" : TIT(NBCOL)="Polígono"
  NBCOL +=1 : COL(NBCOL) = "PARCELA" : TIT(NBCOL)="Parcela"

Return

