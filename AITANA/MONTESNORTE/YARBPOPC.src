######################################################################################
######################################################################################
$GRABACIO_DADES
    Local    Integer TIPUS_ACCIO

#    Local    Char    PANT_YTR
#    Local    Char    PANT_YPE
#    Local    Char    PANT_YTA
    Local    Char    PANT_YPS
    Local    Char    TERCERO

#    PANT_YTR = func CODI_PANT_YTR()
#    PANT_YPE = func CODI_PANT_YPE()
#    PANT_YTA = func CODI_PANT_YTA()
    PANT_YPS = func CODI_PANT_YPS()

    Local Integer NL

    #Chep
    Local Decimal YTOTALABSOR

    If ACTION = "CREATION"
        TIPUS_ACCIO = 0
    Elsif ACTION = "MODIF"
        TIPUS_ACCIO = 1
    Endif

#    If TIPUS_ACCIO<>0
#        Gosub MODIFICAR_BPR_YTA1
#    Endif

    Case GABREV
        When "BPC" : Gosub ACTION From SUBBPC
        When "BPS" : Gosub ACTION From SUBBPS
        When "BPR" : Gosub ACTION From SUBBPR
    Endcase

    GPE =1

#   TERCERO = func CODI_TERCER()

#    If (GABREV = "BPC" or GABREV ="BPS")
