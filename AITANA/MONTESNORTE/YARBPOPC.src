#            [F:BPA]YMARCAOFI  = [M]YMARCAOFI(NL)
#
#            #Comprobamos si el código de actividad YGC está activo
#            If func XCONTROLES.CODACT_ACTIVO("YGC") Then
#                [F:BPA]YMARCASAN  = [M]YMARCASAN(NL)
#                [F:BPA]YREGA      = [M]YREGA(NL)
#            Endif
#
#            #Comprobamos si el código de actividad YCHEP está activo
#            If func XCONTROLES.CODACT_ACTIVO("YCHEP") and GFONC1 = "GESBPC" Then
#                [F:BPA]YCHEPFLG  = [M]YCHEPFLG(NL)
#                [F:BPA]YABSOR    = [M]YABSOR(NL)
#                [F:BPA]YNUMCHEP  = [M]YNUMCHEP(NL)
#                If [M]YCHEPFLG(NL) = 2
#                    YTOTALABSOR += [M]YABSOR(NL)
#                Endif
#            Endif
#
#            Rewrite[BPA]
#        Endif
#    Next NL

#    #Chep
#    If YTOTALABSOR <> 0 and YTOTALABSOR <> 100
#        Infbox "Atención: El total del valor de ABSORCIÓN suma: " + num$(YTOTALABSOR)
#    Endif

    TERCERO = func CODI_TERCER()

    If TIPUS_ACCIO = 0
        Read [BPR]BPR0 = TERCERO
        If fstat
            Raz [BPR]
        Else
            TIPUS_ACCIO =1
        Endif
    Endif

    #--- Terceros secciones
    #   If clalev([F:YPS])=0 : Local File YPERSEC[YPS] : ENDIF

    If TIPUS_ACCIO<>0
        Assign (PANT_YPS+"OBSERVACIO(LINANT)") With evalue(PANT_YPS+"YOBS")
        Delete [YPS] Where [F:YPS]CODIPERSON=TERCERO
    Endif

    For NL=0 To evalue(PANT_YPS+"NBLIG-1")
        [F:YPS]CODIPERSON = TERCERO
        [F:YPS]NUMLINEA1 = NL+1
        [F:YPS]CPY = evalue(PANT_YPS+"CPY(NL)")        #MNORTE-61.n
        [F:YPS]TIPOREL = evalue(PANT_YPS+"TIPOREL(NL)")#MNORTE-61.n
        [F:YPS]TIPOFCY = evalue(PANT_YPS+"TIPOFCY(NL)")
        [F:YPS]FECHAINI = evalue(PANT_YPS+"FECHAINI(NL)")
        [F:YPS]FECHAFIN = evalue(PANT_YPS+"FECHAFIN(NL)")
        [F:YPS]FECHASOLB = evalue(PANT_YPS+"FECHASOLB(NL)")
        [F:YPS]ACTIVO = evalue(PANT_YPS+"ACTIVO(NL)")
        [F:YPS]OBSERVACIO = evalue(PANT_YPS+"OBSERVACIO(NL)")
        [F:YPS]GRUPOPOR = evalue(PANT_YPS+"GRUPOPOR(NL)")
        [F:YPS]REPRECAG = evalue(PANT_YPS+"REPRECAG(NL)") #XVT210520.n
      #  [F:YPS]UPDDAT = date$
      #  [F:YPS]UPDUSR = toupper(adxusr)

