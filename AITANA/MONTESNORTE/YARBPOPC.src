#             Endif
#             [F:BPR]YTABTRANS = evalue(PANT_YTA+"YTABTRANS")
#             [F:BPR]YTABCOMIS = evalue(PANT_YTA+"YTABCOMIS")
#             [F:BPR]YTABDTE   = evalue(PANT_YTA+"YTABDTE")
#             [F:BPR]YTIPSOC   = evalue(PANT_YTA+"YTIPSOC")
#             [F:BPR]YNUMSOC   = evalue(PANT_YTA+"YNUMSOC")
#             [F:BPR]YQTYTRA   = evalue(PANT_YTA+"YQTYTRA")
#             [F:BPR]YACTIVOPDA  = evalue(PANT_YTA+"YACTIVOPDA")
#             [F:BPR]YCLASEPER = evalue(PANT_YTA+"YCLASEPER")
#             [F:BPR]YPREUESP  = evalue(PANT_YTA+"YPREUESP")
#             [F:BPR]YTIPTAR   = evalue(PANT_YTA+"YTIPTAR")
#             [F:BPR]YGENFAC   = evalue(PANT_YTA+"YGENFAC")
#
#            #Comprobamos si el código de actividad YGC está activo
#            If func XCONTROLES.CODACT_ACTIVO("YGC") Then
#                [F:BPR]YTIPDOC     = evalue(PANT_YTA+"YTIPDOC")
#                [F:BPR]YOPERESTAD  = evalue(PANT_YTA+"YOPERESTAD")
#            Endif
#
#
#             Rewrite [BPR]
#        Endif
#    Endif

    #Chep
    YTOTALABSOR = 0

#    For NL=0 To [M]NBADR -1
#        Readlock [BPA]BPA0 = 1;TERCERO;[M]CODADR(NL)
#        If fstat
#            Raz [F:BPA]
#        Else
#            [F:BPA]YGPORT1    = [M]YGPORT1(NL)
#            [F:BPA]YGPORT2    = [M]YGPORT2(NL)
