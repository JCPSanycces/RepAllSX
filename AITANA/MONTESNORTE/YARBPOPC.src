######################################################################################
Funprog CODI_PANT_YPS()
    Local    Char    PANT_YPS

    Case GABREV
        When "BPC"
            PANT_YPS = "[M:YPSC]"
        When "BPS"
            PANT_YPS = "[M:YPSC]"
        When "BPR"
            PANT_YPS = "[M:YPSR]"
    Endcase
End PANT_YPS
