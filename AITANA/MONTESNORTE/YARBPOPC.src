Return
######################################################################################
$CREATION

    Gosub GRABACIO_DADES

Return
######################################################################################
$MODIF

    Gosub GRABACIO_DADES

Return
######################################################################################
$ANNULE
    Local Char TERCERO

    If clalev([F:CBB])=0 : Local File CBLOB      [CBB] : Endif

    TERCERO = func CODI_TERCER()

    If GOK < 1  Return  Endif
#    Delete [YTR] Where [F:YTR]BPRNUM=TERCERO
#    Delete [YPE] Where [F:YPE]CODIPERSON=TERCERO
    Delete [YPS] Where [F:YPS]CODIPERSON=TERCERO
#    Delete [CBB] Where CODBLB="BPR" & IDENT1=TERCERO
Return
######################################################################################
######################################################################################
#
# Aquesta funcio ens retornara el codi de client, proveïdor ó tercer segons l'objecte
# que l'hagi trucat BPC, BPS, BPR
#
######################################################################################
Funprog CODI_TERCER()

    Local Char TERCER

    Case GABREV
        When "BPC"
            TERCER = [M:BPC0]BPCNUM
        When "BPS"
            TERCER = [M:BPS0]BPSNUM
        When "BPR"
            TERCER = [M:BPR0]BPRNUM
    Endcase

End TERCER
