######################################################################################
#
#    Aquest codi fa el tractament de proveïdors i clients
#    que abans estava ubicat al YARBPR.
#
######################################################################################
# SR481 - XVT 2015/05/13 observaciones de relaciones no se guardan/muestran.
#         realizo copia del fuente vertical al dossier ACTIVO/MONTES para corregir el
#         problema
# MNORTE-61 Añadir sociedad y tipoasociado a "terceros secciones"
#XVT210520 - S3501 - Añadir Representación recibo agrario REPRECAG
######################################################################################
$ACTION
    Case ACTION
        When "OUVRE"         : Gosub OUVRE
        When "LIENS"         : Gosub LIENS
        When "CREATION"      : Gosub CREATION
        When "MODIF"         : Gosub MODIF
        When "ANNULE"        : Gosub ANNULE
        When Default
    Endcase
Return
######################################################################################
$OUVRE
#    If clalev([F:YPE])=0 : Local File YPERSCAR   [YPE] : Endif
#    If clalev([F:YTR])=0 : Local File YTERRELA   [YTR] : Endif
    If clalev([F:YPS])=0 : Local File YPERSEC    [YPS] : Endif
#    If clalev([F:YPH])=0 : Local File YPERSOCH   [YPH] : Endif
Return
######################################################################################
$LIENS

    Case GABREV
        When "BPC"
            Gosub ACTION From SUBBPC : GPE =1
        When "BPS"
            Gosub ACTION From SUBBPS : GPE =1
        When "BPR"
            Gosub ACTION From SUBBPR : GPE =1
    Endcase

    Gosub CHARG_LIN From YARBPOPC
Return
######################################################################################
$CHARG_LIN
