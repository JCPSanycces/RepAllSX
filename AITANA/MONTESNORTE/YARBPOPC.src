    PANT_YPS = func CODI_PANT_YPS()

    If clalev([F:XBPR])=0 : Local File BPARTNER  [XBPR] : Endif

# -- Generación de líneas TERCEROS SECCIONES
    Raz nolign
    nolign=0
    For [YPS]YPS0 Where CODIPERSON=TERCERO
        nolign += 1
        Assign (PANT_YPS + "NUMLINEA1(nolign-1)")   With [F:YPS]NUMLINEA1
        Assign (PANT_YPS + "CPY(nolign-1)")         With [F:YPS]CPY        #MNORTE-61.n
        Assign (PANT_YPS + "TIPOREL(nolign-1)")     With [F:YPS]TIPOREL    #MNORTE-61.n
        Assign (PANT_YPS + "TIPOFCY(nolign-1)")     With [F:YPS]TIPOFCY
        Assign (PANT_YPS + "FECHAINI(nolign-1)")    With [F:YPS]FECHAINI
        Assign (PANT_YPS + "FECHAFIN(nolign-1)")    With [F:YPS]FECHAFIN
        Assign (PANT_YPS + "FECHASOLB(nolign-1)")   With [F:YPS]FECHASOLB
        Assign (PANT_YPS + "ACTIVO(nolign-1)")      With [F:YPS]ACTIVO
        Assign (PANT_YPS + "OBSERVACIO(nolign-1)")  With [F:YPS]OBSERVACIO
        Assign (PANT_YPS + "GRUPOPOR(nolign-1)")    With [F:YPS]GRUPOPOR
        Assign (PANT_YPS + "REPRECAG(nolign-1)")    With [F:YPS]REPRECAG  #XVT210520.n
        Assign (PANT_YPS + "NBLIG")                 With nolign
    Next
    #[M:YPS0]NBLIG = min(nolign,dim([M:YPS0]NUMLINEA1))

    nolign=0

    #--- Campo OBSERVACIONES
    Assign (PANT_YPS + "YOBS")  With evalue(PANT_YPS + "OBSERVACIO(LINANT)")

# -- Generación de líneas en la tabla
