#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

Case ACTION
  When "LOAD_CTN" : Gosub LOAD_CTN
  When "REMP_CTN" : Gosub REMP_CTN
  When "ALFAIN_CTN" : Gosub ALFAIN_CTN
  When Default
Endcase
Return


$LOAD_CTN
  # CAMPOS DE LA PANTALLA TRANSPORTISTA/CONTACTOS
  # MAB.12092019.NEW
  If GFONCTION = 'GESBPT' Then
    [M]ZDNI(nolign-1) = [F:AIN]ZDNI
  Endif
Return


$REMP_CTN
  # CAMPOS DE LA PANTALLA TRANSPORTISTA/CONTACTOS
  # MAB.12092019.NEW
  If GFONCTION = 'GESBPT' Then
    [M]KZDNI = [M]ZDNI(NOL)
  Endif
  # CAMPOS DE LA PANTALLA TRANSPORTISTA/CONTACTOS
  # MAB.09052019.NEW
Return


$ALFAIN_CTN
  # CAMPOS DE LA PANTALLA TRANSPORTISTA/CONTACTOS
  # MAB.12092019.NEW
  If GFONCTION = 'GESBPT' Then
    [F:AIN]ZDNI = [M]ZDNI(nolign-1)
  Endif
  # CAMPOS DE LA PANTALLA TRANSPORTISTA/CONTACTOS
  # MAB.12092019.NEW
Return





End

