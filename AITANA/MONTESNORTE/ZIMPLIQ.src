#XVT220520 S3501 - validación terceros con representación recibo agrario

$ACTION
Case ACTION
When "AP_IMPORT" : Gosub AP_IMPORT
Endcase
Return


#https://www.greytrix.com/blogs/sagex3/2014/05/26/how-to-conditionally-restrict-the-import-update/

$AP_IMPORT
#XVT220520.bn
#  If [L]IMPFIC="PIH" Then
#Infbox "ZIMPLIQ - AP_IMPORT - PIH " + GIMP(93)
#    [M:PIH0]ZREPRECAG=val(GIMP(93))
#    [F:PIH]ZREPRECAG=val(GIMP(93))
#  Endif
#XVT220520.bn

If GUSER ='ADMIN' and !GSERVEUR Then
  Infbox "AP_IMPORT " + [L]IMPFIC + " " + GIMP(90) + " "+ GIMP(91) + " "+ GIMP(92) + " "
  Endif

  If [L]IMPFIC="PID" Then

### ms  02/07/2020
    [M:PIH3]ZCALIDAD(nolign-1)  = GIMP(90)
    [F:PID]ZCALIDAD  = GIMP(90)
    [M:PIH3]ZCANT1(nolign-1)  = val(GIMP(91))
    [F:PID]ZCANT1 = val(GIMP(91))
    [M:PIH3]ZCANT2(nolign-1) = val(GIMP(92))
    [F:PID]ZCANT2 = val(GIMP(92))
  Endif

Return

