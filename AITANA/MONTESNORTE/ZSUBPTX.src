#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# Variables that can be used by the PURTRS entry point                  #
#                                                                       #
#    PACTION    : Action GOBJET at the origin of the call               #
#    PVERSION   : Numeric value of the X3 version number                #
#    FJL        : Type of transaction in progress                       #
#    MFROM      : Code for the entry screen                             #
#                                                                       #
#########################################################################
$ACTION
Case ACTION
  When "PURTRS"
    Case FJL
      When "PTF"                    : Gosub PURTRS_PTF # Invoice transaction
    Endcase
  When Default:
Endcase
Return

$PURTRS_PTF
 Case PACTION
    When "CREATION", "MODIF", "ANNULE","EXEBOUT","MASSE"
      If MFROM="PIH0"
        If [M:PTF0]PTRNUM="ALL" Then
          TZONE(IZON)="ZREPRECAG"
          TMOD (IZON)=1
          IZON +=1
        Else
          TZONE(IZON)="ZREPRECAG"
          TMOD (IZON)=3
          IZON +=1
        Endif
      Endif
      If MFROM="PIH3"
        If [M:PTF0]PTRNUM="ALL" Then   # GESTIONAR AQUI: TODOS LOS CAMPOS Z INVISIBLES EN TRANSACCIONES <> "ALL"
          TZONE(IZON)="ZCALIDAD"
          TMOD (IZON)=1
          IZON +=1

          TZONE(IZON)="ZCANT1"
          TMOD (IZON)=1
          IZON +=1

          TZONE(IZON)="ZCANT2"
          TMOD (IZON)=1
          IZON +=1

          TZONE(IZON)="ZGLUCONICO"
          TMOD (IZON)=1
          IZON +=1

          TZONE(IZON)="ZGRADO"
          TMOD (IZON)=1
          IZON +=1

          TZONE(IZON)="ZHUMEDAD"
          TMOD (IZON)=1
          IZON +=1

          TZONE(IZON)="ZPESOESPE"
          TMOD (IZON)=1
          IZON +=1

          TZONE(IZON)="ZPOTASIO"
          TMOD (IZON)=1
          IZON +=1

          TZONE(IZON)="ZPH"
          TMOD (IZON)=1
          IZON +=1

          TZONE(IZON)="ZRENDIMIENTO"
          TMOD (IZON)=1
          IZON +=1

          TZONE(IZON)="ZPUNTOS"
          TMOD (IZON)=1
          IZON +=1

          TZONE(IZON)="ZDENSIDAD"
          TMOD (IZON)=1
          IZON +=1
        Else
          TZONE(IZON)="ZCALIDAD"
          TMOD (IZON)=3
          IZON +=1

          TZONE(IZON)="ZCANT1"
          TMOD (IZON)=3
          IZON +=1

          TZONE(IZON)="ZCANT2"
          TMOD (IZON)=3
          IZON +=1

          TZONE(IZON)="ZGLUCONICO"
          TMOD (IZON)=3
          IZON +=1

          TZONE(IZON)="ZGRADO"
          TMOD (IZON)=3
          IZON +=1

          TZONE(IZON)="ZHUMEDAD"
          TMOD (IZON)=3
          IZON +=1

          TZONE(IZON)="ZPESOESPE"
          TMOD (IZON)=3
          IZON +=1

          TZONE(IZON)="ZPOTASIO"
          TMOD (IZON)=3
          IZON +=1

          TZONE(IZON)="ZPH"
          TMOD (IZON)=3
          IZON +=1

          TZONE(IZON)="ZRENDIMIENTO"
          TMOD (IZON)=3
          IZON +=1

          TZONE(IZON)="ZPUNTOS"
          TMOD (IZON)=3
          IZON +=1

          TZONE(IZON)="ZDENSIDAD"
          TMOD (IZON)=3
          IZON +=1
        Endif

      Endif
    When Default :
  Endcase

Return

