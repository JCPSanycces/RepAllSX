## biblioteca general Montes
#**
#*
#*
#* @param PFCY
#* @param PTIPOFCY
#* @param PDATE
#* @param PEJERCICIO
#*!
Subprog GET_EJERCICIO(PFCY, PTIPOFCY, PDATE, PEJERCICIO)
Value Char    PFCY()
Value Integer PTIPOFCY
Value Date    PDATE
Variable Integer PEJERCICIO
#LA LLAMADA A ESTE PROCEDIMIENTO SE PUEDE HACER CON LA PLANTA O EL TIPO DE PLANTA.
#Y, EN CUALQUIER CASO, LA FECHA.
#DEVUELVE EL EJERCICIO (CAMPAÑA) O CERO, SI NO LA ENCUENTRA
#EN LA TABLA DE CAMPAÑAS

PEJERCICIO = 0 #valor de retorno si no encuentra campaña para el tipo de planta.

If !clalev ([F:ZCAM]): Local File ZCAMPANYA[ZCAM] : Endif
If PTIPOFCY=0 Then
  If !clalev ([F:ZFCY]): Local File FACILITY [ZFCY] : Endif
  Read [ZFCY]FCY0=PFCY
  If !fstat Then
    PTIPOFCY=[F:ZFCY]YTIPOFCY
  Endif
Endif
Filter [F:ZCAM] Where TIPOFCY=PTIPOFCY and INIDAT <= PDATE and ENDDAT >= PDATE
Read [F:ZCAM] First
If !fstat Then
  PEJERCICIO=[F:ZCAM]EJERCICIO
Endif
End

#**
#*
#*
#* @param PFCY
#* @param PTIPOFCY
#* @param PEJERCICIO
#* @param POK
#*!
Subprog CHECK_EJERCICIO(PFCY, PTIPOFCY, PEJERCICIO, POK)
Value Char    PFCY()
Value Integer PTIPOFCY
Value Integer PEJERCICIO
Variable Integer POK
#LA LLAMADA A ESTE PROCEDIMIENTO SE PUEDE HACER CON LA PLANTA O EL TIPO DE PLANTA.
#Y, EN CUALQUIER CASO, LA CAMPAÑA A COMPROBAR.
#DEVUELVE 0 SI NO LA ENCUENTRA
#EN LA TABLA DE CAMPAÑAS Y 1 SI ES CORRECTA.

POK = 0 #valor de retorno si no encuentra campaña para el tipo de planta.
#Infbox "1.ZLIBMONTES - Planta: " + PFCY + " - Tipo planta: "  + num$(PTIPOFCY) + " - Ejercicio:" + num$(PEJERCICIO)
If !clalev ([F:ZCAM]): Local File ZCAMPANYA[ZCAM] : Endif
If PTIPOFCY=0 Then
  If !clalev ([F:ZFCY]): Local File FACILITY [ZFCY] : Endif
  Read [ZFCY]FCY0=PFCY
  If !fstat Then
    PTIPOFCY=[F:ZFCY]YTIPOFCY
  Endif
Endif
#Infbox "2.ZLIBMONTES - Planta: " + PFCY + " - Tipo planta: "  + num$(PTIPOFCY) + " - Ejercicio:" + num$(PEJERCICIO)
Filter [F:ZCAM] Where TIPOFCY=PTIPOFCY and EJERCICIO=PEJERCICIO
Read [F:ZCAM] First
If !fstat Then
  POK=1
Endif
End


#**
#* Función que nos devuelve la categoria del artículo
#*
#* @param PITMREF - Código del artículo
#*!
Funprog GET_TIPOITEM(PITMREF)
  Local Char LRES
  If !clalev ([ZITM]) : Local File ITMMASTER [ZITM] : Endif
  Read [ZITM]ITM0=PITMREF
  If !fstat Then
    LRES = [F:ZITM]TSICOD(0)
  Endif

End LRES

#**
#* Función que nos devuelve el tipo de UVA. B (Blanca) T (Tinta)
#*
#* @param PITEMREF
#*!
Funprog GET_TIPOUVA(PITMREF)
  Local Char LRES

  If !clalev ([ZITM]) : Local File ITMMASTER [ZITM] : Endif
  Read [ZITM]ITM0=PITMREF
  If !fstat Then
    If [F:ZITM]TSICOD(1) = "801" Then
      LRES = "B"
    Else
      LRES = "T"
    Endif
  Endif


End LRES

#**
#* Función para añadir texto a la tabla de Texto de manera estandar
#* Esta función devuelve el código de texto
#* @param YABRFIC -- Objeto donde se va a añadir el texto
#* @param YTEXTE  -- Texto a añadir
#*!
Funprog  F_CRELOB(YABRFIC,YTEXTE)
Value Char YABRFIC
Value Char YTEXTE

    Local Char XXRTFTXT(250)(3)
    XXRTFTXT(0) = "{\rtf1\ansi\ansicpg1252\deff0\deflang1033{\fonttbl{\f0\fswiss\fprq2\fcharset0 MS Sans Serif;}}\viewkind4\uc1\pard\f0\fs17 "
    XXRTFTXT(1) = YTEXTE
    XXRTFTXT(2) = "\par}"

    Local Char X_RET
    Local Integer XXOK
    Local Char XCHAMPLIEN : XCHAMPLIEN = "YYYY"
    Global Char YYYY : YYYY = YABRFIC
    Local Clbfile WWCLOB
    Local Mask ACLOB [M:ACL]
    Setlob   WWCLOB  With XXRTFTXT
    [M:ACL]CLOB = WWCLOB
    Call CRE_CLOB_ACL(XCHAMPLIEN,XXOK) From TRTX3TEX
    Close Local Mask [M:ACL]
    X_RET = YYYY
    Kill YYYY


End X_RET

