#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)4.0.0.0 $Revision$
######################################################################################
$ACTION
    Case ACTION
        When "OUVRE"      : Gosub OUVRE
        When "SETBOUT"    : Gosub SETBOUT
        When "APRES_CHOI" : Gosub APRES_CHOI
        When "FERME"      : Gosub FERME
        When Default
    Endcase
Return
#######################################################################################
$FERME
    If dim(YRETORN)>0 Then : YRETORN = [M:YCS]CODCALIDAD(nolign-1) : Endif
Return
#######################################################################################
$OUVRE
    If clalev([F:YCA]) =0 : Local File YCALIDAD [YCA] : Endif
Return
############################ ACTIONS ##################################
$SETBOUT
    #--- Objet à 6 éléments de clé : ajout de la touche suppression  si autorisé ---#
    If CLECUR CHAINE+="A" : Endif
    #--- Si suppression non autorisée, grisage du bouton -----#
    If GREP<>"C"
        GBIDC2="S" : Gosub AUTORIS_OPT From CONTX3
        If !GBIDI2
            Call VIREBOUT(CHAINE,"A") From GOBJET
        Endif
    Endif
Return
########################################################################
$APRES_CHOI
Return
########################################################################
#Esta rutina se llama desde la acción YANUCOD (que sirve para mostrar la ventana ANUCOD
#de cancelación de código de Adonix) que se utilitza con el botón añadido BORRAR
Subprog BORRAR_REGISTROS()
    #--- Début de la transaction de suppression
    Call DEBTRANS From GLOCK
    $TR_ANNUL
    GOK=1
    Trbegin [YCS]

    For [F:YCS]YCS0 Where CODI1=[M:YCS]CODI1 and CODI2=[M:YCS]CODI2 and CODI3 = [M:YCS]CODI3
        Readlock [YCS]YCS0 Curr
        If fstat=1
           GOK=-1
           GLOCK="$YCS"-[M:YCS]CODI1-[M:YCS]CODI2-[M:YCS]CODI3
           Break
        Elsif fstat
           GOK=0
           Call RSTA("YCS",[M:YCS]CODI1-[M:YCS]CODI2-[M:YCS]CODI3) From GLOCK
           Break
        Endif
        #--- Suppression de l'enregistrement (DEB)
        Delete [YCS]
        If fstat GOK=0 : Break :  Endif
    Next

    If GOK = -1 : Goto TR_ROLL  : Endif
    If GOK = 0  : Goto AB_ANNUL : Endif

    Commit
    CLECUR = 0
    Effzo [M:YCS]
    Goto FIN_ANNUL

    $TR_ROLL
    Rollback
    Call ROLL From GLOCK
    If GROLL Goto FIN_ANNUL Else Goto TR_ANNUL : Endif

    $AB_ANNUL
    Rollback

    $FIN_ANNUL
    OK=0
End
######################################################################################

