#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################################################	
### ZLECPES -- Lectura Ficheros Pesadas	
######################################################################################	
## #610623 - XVT Trece 03/09/2015 - Corregir código de socio de 7 dígitos	
## #912266 - XVT Trece 10/11/2015 - Anular #610623	
## MIGRACIÓN V11	
##         - XVT Sistel 20/08/2020 - Incorporar en fichero potasa, glucónico y nº puntos para bodega	
##                                 - la plantación no requiere ningún tratamiento. Vendrá con 5 caracteres	
##         - CBG Sistel 06/11/2020 - Incorporar transportista y Matricula	
$ACTION	
    Case ACTION	
        When "OUVRE"        : Gosub OUVRE	
        When "OUVRE_BATCH"  : Gosub OUVRE_BATCH_ZLECPES	
        When "INIT"         : Gosub INIT_ZLECPES	
        When "EXEC"         : Gosub EXEC_ZLECPES	
        When "TERMINE"      : Gosub TERMINE_ZLECPES	
        When "INIT_DIA"     : Gosub INIT_DIA_ZLECPES	
        When "OK"           : Gosub OK_ZLECPES	
        When "END"          : Gosub END_ZLECPES	
        When "FINREQ"       : Gosub FINREQ	
    Endcase	
Return	
######################################################################################	
$OUVRE	
#   [M:ZLP]FICHERO= "E:\IMPORTEXPORT\BASCULASROMERO\pes201901281910.txt"	
#   [M:ZLP]DIRECFIN="E:\IMPORTEXPORT\BASCULASROMERO\FIN\"	
#   [M:ZLP]DIRECFIN="E:\IMPORTEXPORT\BASCULASROMERO\ERROR\"	
Return	
$OUVRE_BATCH_ZLECPES	
    Gosub OPEN_FILE	
Return	
######################################################################################	
$INIT_ZLECPES	
    Gosub OPEN_FILE	
Return	
######################################################################################	
$OPEN_FILE	
    If clalev ([F:ZPE])=0  : Local File ZPESADAS   [ZPE]  : Endif	
    If clalev ([F:ITM])=0  : Local File ITMMASTER  [ITM]  : Endif	
    If clalev ([F:ITF])=0  : Local File ITMFACILIT [ITF]  : Endif	
    If clalev ([F:BPS])=0  : Local File BPSUPPLIER [BPS]  : Endif	
    If clalev ([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif	
    If clalev ([F:YPL])=0  : Local File YPLANTACI  [YPL]  : Endif	
    If clalev ([F:YPS])=0  : Local File YPERSEC    [YPS]  : Endif	
    If clalev ([F:STC])=0  : Local File STOLOC     [STC]  : Endif	
    ##V11.o If clalev ([F:YPN])=0  : Local File YPLANTPAR  [YPN]  : Endif	
    If GSERVEUR	
        #----- Ouverture fichier trace et écriture des sélections -----#	
        Call ECR_TRACE(" ",0)                From GESECRAN	
        Call ECR_TRACE(string$(88,"-"),0)    From GESECRAN	
        Call PRTSCR("YLECPROD","YPR","",0,1) From ATRTX3	
        Call ECR_TRACE(" ",0)                From GESECRAN	
    Endif	
Return	
######################################################################################	
$TERMINE_ZLECPES	
    If !GSERVEUR	
        Call FERME_TRACE From LECFIC	
        Call LEC_TRACE   From LECFIC	
        Return	
    Endif	
Return	
######################################################################################	
$INIT_DIA_ZLECPES	
    Raz [M:ZLP]	
Return	
######################################################################################	
$OK_ZLECPES	
    FIN  = 1	
Return	
######################################################################################	
$END_ZLECPES	
    Raz [M:ZLP]	
    FIN = 1	
Return	
######################################################################################	
######################################################################################	
$EXEC_ZLECPES	
    Local Char    ORI	
    Local Integer ZERROR_IMP	
    Local Integer ESTAT	
    Local Char    FICHERO_DES(GDIMFIC)	
    Local Char    RUTA(250), RUTAFIN(250), RUTAERR(250)	
    If GSERVEUR	
        Onerrgo ERRBATCH	
    Else	
        Call OUVRE_TRACE("Importación Ficheros PESADAS")  From LECFIC	
        #----- Ouverture fichier trace et écriture des sélections -----#	
        Call ECR_TRACE(" ",0)                From GESECRAN	
        Call ECR_TRACE(string$(88,"-"),0)    From GESECRAN	
        Call PRTSCR("ZLECPES","ZLP","",0,1)  From ATRTX3	
        Call ECR_TRACE(" ",0)                From GESECRAN	
    Endif	
    Call TEMPON("E") From GESECRAN	
    ###--- Aqui haremos el bucle de los ficheros	
    Local Char    LISTEFIC(GDIMFIC)(1..3000)	
    Local Integer ZERROR  : ZERROR  = 0	
    Local Integer ZNUMFIC : ZNUMFIC = 0	
    RUTA = [M:ZLP]FICHERO + [M:ZLP]SUBDIR + "\"	
    RUTAFIN=[M:ZLP]DIRECFIN+[M:ZLP]SUBDIR + "\"	
    RUTAERR=[M:ZLP]DIRECERR+[M:ZLP]SUBDIR + "\"	
    Call BUSCAR_FICHEROX(RUTA,LISTEFIC,ZNUMFIC,ZERROR) From ZFICEXPIMP	
#    Infbox "NUMFIC: " + num$(ZNUMFIC)	
#    Infbox "ERROR: " + num$(ZERROR)	
    #Call BUSCAR_FICHEROX([M:ZLP]FICHERO,LISTEFIC,ZNUMFIC,ZERROR) From ZFICEXPIMP	
    For ZNUMF=1 To ZNUMFIC	
        ZERROR_IMP = 0	
        Raz FICHERO_DES	
        Call BUSCAR_NOM(LISTEFIC(ZNUMF),FICHERO_DES)	
        Call GENERAR_FICHERO(LISTEFIC(ZNUMF),FICHERO_DES,ZERROR_IMP)	
        If ZERROR_IMP = 0	
            Raz FICHERO_DES	
            Call BUSCAR_NOM(LISTEFIC(ZNUMF),FICHERO_DES)	
#v11.o            Read [ZPE]ZPE1 = [M:ZLP]FCY;[M:ZLP]TIPDOC;FICHERO_DES	
            Read [ZPE]ZPE1 = [M:ZLP]FCY;FICHERO_DES   #v11.n	
            If fstat	
                Raz [ZPE]	
                Call ECR_TRACE("Fichero " +  FICHERO_DES + " processado incorrectamente.",1) From GESECRAN	
                FICHERO_DES = RUTAERR + FICHERO_DES	
                Call MOVE(LISTEFIC(ZNUMF),RUTAERR,ESTAT) From ORDSYS	
                If ESTAT Then : Return : Endif	
            Else	
                Call ECR_TRACE("Fichero " +  FICHERO_DES + " processado correctamente.",0) From GESECRAN	
                FICHERO_DES = RUTAFIN + FICHERO_DES	
                Call MOVE(LISTEFIC(ZNUMF),RUTAFIN,ESTAT) From ORDSYS	
                If ESTAT Then : Return : Endif	
            Endif	
        Else	
            Call ECR_TRACE("Fichero " +  FICHERO_DES + " processado incorrectamente.",1) From GESECRAN	
        Endif	
    Next	
    Call TEMPOFF From GESECRAN	
Return	
######################################################################################	
Subprog GENERAR_FICHERO(FICHERO,ZNOM_FICHERO,ZERROR_IMP)	
    Value    Char     FICHERO()	
    Value    Char     ZNOM_FICHERO	
    Variable Integer  ZERROR_IMP	
    Local    Char     FICHEROORI(200)	
    Local    Char     PR(GDIMFIC)	
    Local    Integer  L	
    Local    Char     ZNUMPES(20)	
    Local    Date     FECHA	
    Local    Char     ZPROV(20)	
    Local    Char     ZTERMINO(20)	
    Local    Char     ZVARIEDAD(20)	
    Local    Char     ZCALIDAD(20)	
    Local    Char     ZDEPOSITO(20)	
    Local    Char     ZINCIDEN(250)	
    Local    Char     ZPESADOR(20)	
    Local    Decimal  ZGRADO	
    Local    Decimal  ZBRUTO	
    Local    Decimal  ZTARA	
    Local    Decimal  ZNETO	
    Local    Decimal  ZPH	
    Local    Decimal  ZQUANTI2	
    Local    Decimal  ZQUANTI3	
    Local    Char     ZCATASTRO	
    Local    Char     ZFECHA_TMP	
    Local    Integer  ANT,SIG	
    Local    Char     TEXTO_ERROR(80)	
    Local    Decimal  ZPOTASIO, ZGLUCONICO    #XVT20/08/2020.bn	
    Local    Integer  ZPUNTOS	
    Local    Char     ZDUMMY                  #XVT20/08/2020.en	
    Local    Integer  ZTMOD	
    Local    Integer  ZTERROR	
    Local    Integer  ZTIMP	
    Local    Char     ZPTHNUM	
    Local    Char     ZEXERCICI	
    Local    Integer  ZEJERCICIO	
    Local Char ZTRANSPORTISTA #CBG06/11/2020	
    Local Char ZMATRICULA #CBG06/11/2020	
    FICHEROORI = FICHERO	
    Openi   FICHEROORI,0 Using [CON]	
    Iomode  adxifs chr$(13)+chr$(10) Using [CON]	
    Iomode  adxium 50 Using [CON]	
    Repeat	
        Rdseq PR Using [CON]	
        L=len(PR)	
        If PR<>'' & L>1	
            Raz ZNUMPES,ZPROV,ZTERMINO,ZVARIEDAD,ZCATASTRO,ZFECHA_TMP,ZDEPOSITO,ZINCIDEN,ZPESADOR,TEXTO_ERROR	
            Raz ZGRADO,ZBRUTO,ZTARA,ZNETO,ZPH,ZCATASTRO,ZQUANTI2,ZQUANTI3	
            Raz ZFECHA_TMP	
            Raz ZDUMMY, ZGLUCONICO, ZPOTASIO, ZPUNTOS #XVT20/08/2020.n	
            Raz ZTRANSPORTISTA, ZMATRICULA #CBG06/11/2020	
            TEXTO_ERROR = " "	
            I = find("#", PR)	
            ANT = 1	
            SIG = instr(ANT, PR, '#')	
            Read [FCY]FCY0 = [M:ZLP]FCY : If fstat Raz [FCY] : Endif	
#EJEMPLO FICHERO	
##          4576#28012019#01100914#13052#01#70001####489##0#ATL04###PEDRO#S#4	
##          60422#03082020#01101871#13052#13#90008#12.40#100#99#1#0.00#1770#BA004#M###99100004	
##XVT20/08/2020.n 196#06092019#01411108#13052#13#90002#13.55#21460#10180#11280#3.25#13469#BA011# ##VICTOR#99100004#1275#0.20#6	
            ZNUMPES    = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZFECHA_TMP = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
             ZFECHA     = gdat$(val(mid$(ZFECHA_TMP,1,2)),val(mid$(ZFECHA_TMP,3,2)),val(mid$(ZFECHA_TMP,5,4)))	
            ZPROV      = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZTERMINO   = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZCALIDAD   = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZVARIEDAD  = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZGRADO     = val(vireblc(mid$(PR,ANT,SIG-ANT),2)) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZBRUTO     = val(vireblc(mid$(PR,ANT,SIG-ANT),2)) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZTARA      = val(vireblc(mid$(PR,ANT,SIG-ANT),2)) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZNETO      = val(vireblc(mid$(PR,ANT,SIG-ANT),2)) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZPH        = val(vireblc(mid$(PR,ANT,SIG-ANT),2)) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZCATASTRO  = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZDEPOSITO  = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            #XVT20/08/2020.o ZFECHA_TMP = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZDUMMY     = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')  #XVT20/08/2020.n	
#XVT20/08/2020.BO           If mid$(mess(0,1991,1), [F:FCY]YTIPOFCY, 1) <> "O"	
#               ZINCIDEN   = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = len(PR)	
#                If ANT <> SIG	
#                    ZPESADOR   = vireblc(mid$(PR,ANT,SIG-ANT+1),2)	
#                Endif	
#            Else	
#XVT20/08/2020.EO	
                ZINCIDEN   = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
                ZPESADOR   = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
#XVT20/08/2020.EO Endif	
            ZDUMMY   = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')        #XVT20/08/2020.bn	
            ZPOTASIO = val(vireblc(mid$(PR,ANT,SIG-ANT),2)) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZGLUCONICO=val(vireblc(mid$(PR,ANT,SIG-ANT),2)) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            #If ANT<=SIG Then	
            #  ZPUNTOS  = val(vireblc(mid$(PR,ANT,SIG-ANT),2))	
            #Endif                                                                                       #XVT20/08/2020.en	
            ZPUNTOS  = val(vireblc(mid$(PR,ANT,SIG-ANT),2)) : ANT = SIG+1 : SIG = instr(ANT, PR, '#')	
            ZTRANSPORTISTA = vireblc(mid$(PR,ANT,SIG-ANT),2) : ANT = SIG+1 : SIG = len(PR)+1	
            #Infbox "ZTRANSPORTISTA ES " + ZTRANSPORTISTA	
            #Infbox "ANT ES " + num$(ANT) + " y SIG ES " + num$(SIG)	
            ZMATRICULA  = vireblc(mid$(PR,ANT,SIG-ANT),2) #: ANT = SIG+1 : SIG = len(PR)+1                                                                                     #CBG06/11/2020	
            Read [FCY]FCY0 = [M:ZLP]FCY : If fstat Raz [FCY] : Endif	
#91226.bo --> no hacer ningún tratamiento, ya que vienen los 8 dígitos del código socio	
#                                                        #610623.bn	
##            If left$(ZPROV,1)="9" and len(ZPROV)=7 Then # 610623.old --> XVT:finalmente no es así, únicamente que debe contar con ceros	
##                                                                             a la izquierda	
#            If  len(ZPROV)=7 Then                       #610623.new --> si el código es de 7 es porque ha perdido el cero a la izq.	
##                ZPROV = "9" + ZPROV                     # 610623.old -- por tanto le concatenaremos un cero, no un 9	
#                ZPROV = "0" + ZPROV                     # 610623.new	
#            Else                                        #610623.en	
#            ZPROV = "000000" + ZPROV	
#            ZPROV = right$(ZPROV,len(ZPROV)-5)	
#            ZPROV = [F:FCY]LEGCPY + ZPROV	
#            Endif                                       #610623.n	
#912266.eo	
            If ZCATASTRO <> "0"	
#XVT20/08/2020.bo : no se realiza tratamiento sobre este campo	
#                ZCATASTRO = "000000" + ZCATASTRO	
#                ZCATASTRO = right$(ZCATASTRO,len(ZCATASTRO)-5)	
#                #ZCATASTRO = [F:FCY]LEGCPY + ZCATASTRO	
#                ZCATASTRO = "01" + ZCATASTRO	
#XVT20/08/2020.eo	
            Else	
                Raz ZCATASTRO	
            Endif	
            Call XINIEXEVAR([M:ZLP]FCY,ZFECHA,ZEXERCICI) From XCONTROLES	
            ZEJERCICIO=val(ZEXERCICI) #v11.n	
            If ZNUMPES <> ""	
#v11.o                Read [ZPE]ZPE0 = [M:ZLP]FCY;[M:ZLP]TIPDOC;ZEXERCICI;ZNUMPES	
#XVT02032020.o           Read [ZPE]ZPE0 = [M:ZLP]FCY;ZEJERCICIO;ZNUMPES #v11.n	
           Read [ZPE]ZPE0 = ZEJERCICIO;ZNUMPES #XVT02032020.n	
                If fstat	
                    ZTMOD   = 1	
                    ZPTHNUM = ""	
                    ZTIMP   = 1	
                Else	
                    If [F:ZPE]TIMP =2	
                        ZTMOD   = 2	
                        ZPTHNUM = [F:ZPE]PTHNUM	
                        ZTIMP   = 2	
                    Else	
                        ZTMOD   = 1	
                        ZPTHNUM = ""	
                        ZTIMP   = 1	
                    Endif	
                    ## Eliminar el registro actual de la tabla de pesadas.	
#v11.o                    Delete [ZPE] Where [F:ZPE]FCY=[M:ZLP]FCY and [F:ZPE]NUMPES = ZNUMPES and [F:ZPE]TIPDOC = [M:ZLP]TIPDOC and EXERCICI = ZEXERCICI	
                    Delete [ZPE] Where [F:ZPE]FCY=[M:ZLP]FCY and [F:ZPE]NUMPES = ZNUMPES and EJERCICIO = ZEJERCICIO  #v11.n	
                    If fstat<>0	
                        GOK=-1 : Call RSTA("ZPE") From GLOCK : ZERROR_IMP : End	
                    Endif	
                Endif	
                ZTERROR = 1	
                Read [ITM]ITM0 = ZVARIEDAD : If fstat : Raz [ITM] : ZTERROR = 2 : TEXTO_ERROR += "Articulo Inexistente |" : Endif	
                Read [BPS]BPS0 = ZPROV     : If fstat : Raz [BPS] : ZTERROR = 2 : TEXTO_ERROR += "Provedor Inexistente |" : Endif	
                If [F:BPS]BPSNUM <> ""	
                    #cbg 05-11-2020 - MNORTE-463: Cambio Read a Incide YPS2 para comprobar que el proveedor esta activo en la sociedad	
                    #en la tabla YPS la sociedad son los dos primeros digitos de la planta	
                    #Read [YPS]YPS1 = ZPROV;[F:FCY]YTIPOFCY;2	
                    Read [YPS]YPS2 = ZPROV;[F:FCY]YTIPOFCY;2;left$([F:FCY]FCY,2)	
                    If fstat	
                        Raz [YPS]	
                        ZTERROR = 2	
                        TEXTO_ERROR += "Proveedor no activo en " + mess([F:FCY]YTIPOFCY,1991,1) + " |"	
                    Endif	
                Endif	
                Read [ITF]ITF0 = ZVARIEDAD;[M:ZLP]FCY : If fstat : Raz [ITF] : ZTERROR = 2 : TEXTO_ERROR += "Articulo Planta Inexistente |" : Endif	
                If [ITF]LOCMGTCOD = 2	
                    #Read [STC]STC3 = [M:ZLP]FCY;"DEP";ZDEPOSITO	
                    Read [STC]STC0 = [M:ZLP]FCY;ZDEPOSITO	
                    If fstat : Raz [STC] : ZTERROR = 2 : TEXTO_ERROR += "Ubicación Inexistente |": Endif	
                Endif	
                If ZCATASTRO <> ""	
#v11.o                    Read [YPL]YPL0 = ZEXERCICI;ZCATASTRO	
                    Read [YPL]YPL0 = ZCATASTRO   #v11.n	
                    If fstat	
                        Raz [YPL] : ZTERROR = 2 : TEXTO_ERROR += "Finca Inexistente |"	
                    Else	
                        ## Si estamos en Almazara y la finca tiene la variedad 79999, actualizaremos la finca.	
                        If mid$(mess(0,1991,1), [F:FCY]YTIPOFCY, 1) = "O" and [F:YPL]VARIETAT = "79999"	
#v11.o                            Update [YPL] Where [YPL]EXERCICI=ZEXERCICI and [YPL]CODIPLANTA=ZCATASTRO With VARIETAT = [F:ITM]TSICOD(2)	
                            Update [YPL] Where [YPL]CODIPLANTA=ZCATASTRO With VARIETAT = [F:ITM]TSICOD(2)    #V11.n	
                            If fstat	
                                GOK=0 : Call FSTA("XPE") From GLOCK : Return	
                            Endif	
#v11.o                            Read [YPL]YPL0 = ZEXERCICI;ZCATASTRO : If fstat : Raz [YPL] : Endif	
                            Read [YPL]YPL0 = ZCATASTRO : If fstat : Raz [YPL] : Endif   #v11.n	
                        Endif	
#v11.o                        Read [YPL]YPL5 = ZEXERCICI;ZCATASTRO;ZPROV;[F:ITM]TSICOD(2);2	
                        Read [YPL]YPL5 = ZCATASTRO;ZPROV;[F:ITM]TSICOD(2);2  #v11.n	
                        If fstat	
#v11.o                            Read [YPN]YPN1 = ZEXERCICI;ZCATASTRO;ZPROV	
#v11.o                            If fstat	
#v11.o                                Raz [YPL] : ZTERROR = 2 : TEXTO_ERROR += "Finca - Proveedor Inexistente |"	
#v11.o                            Else	
#v11.o                                Read [YPL]YPL6 = ZEXERCICI;ZCATASTRO;[F:ITM]TSICOD(2);2	
                                      Read [YPL]YPL6 = ZCATASTRO;[F:ITM]TSICOD(2);2  #v11.n	
                                If fstat : Raz [YPL] : ZTERROR = 2 : TEXTO_ERROR += "Finca - Variedad Incoherente |" : Endif	
#v11.o                            Endif	
                        Else	
#v11.o                            Read [YPL]YPL6 = ZEXERCICI;ZCATASTRO;[F:ITM]TSICOD(2);2	
                            Read [YPL]YPL6 = ZCATASTRO;[F:ITM]TSICOD(2);2 #v11.n	
                            If fstat : Raz [YPL] : ZTERROR = 2 : TEXTO_ERROR += "Finca - Variedad Incoherente |" : Endif	
                        Endif	
                    Endif	
                Endif	
                Raz [ZPE]	
                [F:ZPE]FCY        = [M:ZLP]FCY	
                [F:ZPE]TIPOFCY    = [F:FCY]YTIPOFCY	
#v11.o                [F:ZPE]TIPDOC     = [M:ZLP]TIPDOC	
#v11.o                [F:ZPE]EJERCICIO  = ZEXERCICI	
                [F:ZPE]EJERCICIO  = ZEJERCICIO  #v11.n	
                [F:ZPE]NUMPES     = ZNUMPES	
                [F:ZPE]FECHA      = ZFECHA	
                [F:ZPE]PROV       = ZPROV	
                [F:ZPE]TERMINO    = ZTERMINO	
                [F:ZPE]VARIEDAD   = ZVARIEDAD	
                [F:ZPE]CALIDAD    = ZCALIDAD	
                [F:ZPE]GRADO      = ZGRADO	
                [F:ZPE]BRUTO      = ZBRUTO	
                [F:ZPE]TARA       = ZTARA	
                [F:ZPE]NETO       = ZNETO	
                [F:ZPE]PH         = ZPH	
                [F:ZPE]CATASTRO   = ZCATASTRO	
                [F:ZPE]DEPOSITO   = ZDEPOSITO	
                [F:ZPE]INCIDENCIA = ZINCIDEN	
                [F:ZPE]PESADOR    = ZPESADOR	
                [F:ZPE]TIMP       = ZTIMP	
                [F:ZPE]TMOD       = ZTMOD	
                [F:ZPE]TERROR     = ZTERROR	
                [F:ZPE]PTHNUM     = ZPTHNUM	
                [F:ZPE]DOCCAL     = ""	
                [F:ZPE]FICHERO    = ZNOM_FICHERO	
                [F:ZPE]MSGERROR   = TEXTO_ERROR	
                [F:ZPE]ZPOTASIO   = ZPOTASIO    #XVT20/08/2020.bn	
                [F:ZPE]ZGLUCONICO = ZGLUCONICO	
                [F:ZPE]ZPUNTOS    = ZPUNTOS   #XVT20/08/2020.en	
                [F:ZPE]BPTNUM = ZTRANSPORTISTA #CBG06/11/2020.bn	
                [F:ZPE]MATRICULA = ZMATRICULA #CBG06/11/2020.en	
                Write [ZPE]	
                If fstat	
                    GOK=0	
                    ZERROR_IMP = 1	
                    Call FSTA("ZPE") From GLOCK	
                    Call ECR_TRACE("   Pesada " +  ZNUMPES + " processada incorrectamente.",1) From GESECRAN	
                Else	
                    Call ECR_TRACE("   Pesada " +  ZNUMPES + " processada correctamente.",0) From GESECRAN	
                Endif	
            Endif	
       Endif	
    Until fstat <> 0	
    Openi Using [CON]	
End	
######################################################################################	
$ERRBATCH	
    Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN	
End	
######################################################################################	
$FINREQ	
    If [F:ABR]TACHE = "ZLECPES"	
        If OKRQT <> 1 : OKRQT = 1 : Endif	
    Endif	
Return	
######################################################################################	
Subprog BUSCAR_NOM(ZFICHERO,ZNOM)	
    Value    Char    ZFICHERO	
    Variable Char    ZNOM	
    Local    Char    ZNOM2	
    For I=0 To len(ZFICHERO)	
        If mid$(ZFICHERO,I,1) = "\"	
            Raz ZNOM2	
        Else	
            ZNOM2 += mid$(ZFICHERO,I,1)	
        Endif	
    Next	
    For I=0 To len(ZNOM2)	
        If mid$(ZNOM2,I,1) = "."	
            Break	
        Else	
            ZNOM += mid$(ZNOM2,I,1)	
        Endif	
    Next	
End	
######################################################################################	
Subprog AM_FCY(VALEUR)	
    Variable Char    VALEUR()	
    Read [FCY]FCY0 = VALEUR	
    If fstat : Raz [FCY] : Endif	
    [M]TIPOFCY = [F:FCY]YTIPOFCY	
    Affzo [M]TIPOFCY	
End	
