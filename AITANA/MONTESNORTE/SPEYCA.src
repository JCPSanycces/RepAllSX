#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Gestión de la máscara YCALIDAD
######################################################################################
$ACTION
    Case ACTION
        When Default
    Endcase
Return
######################################################################################
Subprog AS_CODCALIDAD(VALEUR)
    Variable Char    VALEUR()

    If VALEUR <> ""
            Look [YCA]YCA0=VALEUR
            If !fstat : mkstat=2 : Endif
    Endif
End
######################################################################################
Subprog C_CODCALIDAD(VALEUR)
    Variable Char    VALEUR()

    Call UNICITE (VALEUR, [M]CODCALIDAD) From OBJDIV
End
######################################################################################

