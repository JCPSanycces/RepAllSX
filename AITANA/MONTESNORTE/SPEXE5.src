#<AdxTL>@(#)6.0.0.0 $Revision$
$ACTION
    Case ACTION
        When "OUVRE"  Gosub OUVRE
        When "DEBUT"  Gosub DEBUT
        When "BOUTON" Gosub BOUTON
    
    Endcase

Return

$OUVRE
    If !clalev ([F:APX]) : Local File APARIMPEXP [APX] : Endif
#    If !clalev ([F:GAC]) : Local File GACCENTRY  [GAC] : Endif
#    If !clalev ([F:GAD]) : Local File GACCENTRYD [GAD] : Endif
#    If !clalev ([F:PYH]) : Local File PAYMENTH   [PYH] : Endif
#    If !clalev ([F:BPR]) : Local File BPARTNER   [BPR] : Endif
    If !clalev ([F:FCY]) : Local File FACILITY   [FCY] : Endif
    If !clalev ([F:VE5]) : Local File XMOD544    [VE5] : Endif
    If !clalev ([F:VT5]) : Local File XMOD544T   [VT5] : Endif ## vista totalizada (ya no se usa con la tabla temporal)
    If !clalev ([F:PRO]) : Local File ATABDIV    [PRO] : Endif
    If !clalev ([F:X5H]) : Local File XMOD544H   [X5H] : Endif
    If !clalev ([F:X5D]) : Local File XMOD544D   [X5D] : Endif

    Local Char    WFIL(250)
    Local Integer CONTADOR 
    Local Char    MENSAJE(250)
    Local Char    PYHNUM(20)
    Local Char    LINEA(165)
    Local Integer NUMLIN
    Local Integer NUMLINDET
    Local Integer NUMLINRES

    Local Integer TOTBANCO
    Local Integer TOTTOT
    Local Integer LINBANCO
    Local Integer LINTOT
    Local Integer NUMBANCOS

    Local Char    BANCOANT(4) 
    Local Char    PROV(2)

    Local Integer NUMERRORES

Return

$DEBUT
    Raz [M:XE5]
    CONTADOR = 0
    LINEA=""
    NUMLIN = 0
    NUMLINDET=0
    NUMLINDRES=0
    PROV=""
    [M:XE5]ENTIDAD="7314"
Return


$BOUTON
  Case BOUT
      When "x" : Gosub EXPORTAR
      When "c" : Gosub CARGATABLA
  Endcase
Return

$EXPORTAR

    Gosub COMPROBACIONES
    Gosub INIT_EXP
    Gosub READDATA
    Gosub FINALIZAR
    
    Gosub DEBUT
Return

$CARGATABLA

    Gosub COMPROBACIONES
    Gosub READDATACT  
    #LLAMADA A READDATACT PARA CARGA DE TABLA TEMPORAL Y EDICIÓN DE DATOS ANTES DE GENERAR EL FICHERO

Return

$INIT_EXP
    #-- variables

        #-- variables diversas
        Local Char    RUTA(GDIMFIC), FICHERO(GDIMFIC)
        Local Char    NOM_FICH(50)

        #-- variables de fichero, inicializacion
        adxifs = ";"                     #-- adxifs, separador de campo 
        adxirs = chr$(13)+chr$(10)       #-- adxirs, separador de registro
        adxium = 50                      #-- adxium, modo 50 = ASCII
        EXT    = "txt"                   #-- extension del fichero
        NOM_FICH = "MOD544_"+[M:XE5]CPY+"_"+date$

        RUTA=""
        Read [APX]APX0="REPEXPDEF"
        If !fstat Then
            RUTA=[F:APX]DIRECTORY
        Endif
        If RUTA=""        
           Call MESSAGE('Directorio de exportación no encontrado. Revise parámetros de import/export') From  GESECRAN 
           End
        Endif
        FICHERO = filpath(RUTA,NOM_FICH,EXT,"","","")
        Openo FICHERO,0 Using [YFIC]
Return

$COMPROBACIONES
    TOTBANCO=0
    TOTTOT=0
    LINBANCO=0
    LINTOT=0
    NUMLINDET=0
    NUMLINRES=0
    NUMBANCOS=0
    BANCOANT=""
  
    CONTADOR = 0
    LINEA=""
    NUMLIN = 0
    NUMERRORES=0
Return

$FINALIZAR
    Openo Using [YFIC]
    Call MESSAGE ("Proceso terminado") From GESECRAN
Return

$READDATA

    Filter [VT5] Where CPY=[M:XE5]CPY & FCY=[M:XE5]FCY & LACCDAT >= [M:XE5]DATDEB & LACCDAT <= [M:XE5]DATFIN Order By BID
    For [VT5]
        #NUMLIN += 1
        CONTADOR += 1

        If CONTADOR < 2 Then
                Gosub LINEA_E1
        Endif
        
        If BANCOANT <> [F:VT5]BANCO THEN
            If BANCOANT<>"" Then
                Gosub LINEA_E8        #subtotales banco
            Endif 
            Gosub LINEA_E2            #nuevo grupo banco
        Endif
        Gosub LINEA_E6 ##detalle

    Next
    Filter [VT5]

    If CONTADOR > 1 Then
        #AL ACABAR,
        #rematar el último E8 y la E9
        Gosub LINEA_E8
        Gosub LINEA_E9
    Endif
        
    MENSAJE = "Recuento: " + num$(CONTADOR) + " líneas de detalle"
    Infbox (MENSAJE)

Return

$READDATACT

    Filter [VE5] Where CPY=[M:XE5]CPY & FCY=[M:XE5]FCY & LACCDAT >= [M:XE5]DATDEB & LACCDAT <= [M:XE5]DATFIN Order By BID
    For [VE5]
        #NUMLIN += 1
        CONTADOR += 1

 #        If CONTADOR < 2 Then
 #               Gosub LINEA_E1
 #       Endif
        
 #       If BANCOANT <> [F:VE5]BANCO THEN
 #           If BANCOANT<>"" Then
 #               Gosub LINEA_E8        #subtotales banco
 #           Endif 
 #           Gosub LINEA_E2            #nuevo grupo banco
 #       Endif
       If CONTADOR = 1 Then
            Gosub GENERA_HEADER
       Endif 
       Gosub LINEA_E6CT ##detalle

    Next
    Filter [VE5]

 #   If CONTADOR > 1 Then
        #AL ACABAR,
        #rematar el último E8 y la E9
 #       Gosub LINEA_E8
 #       Gosub LINEA_E9
 #   Endif
        
    MENSAJE = "Recuento: " + num$(CONTADOR) + " líneas de detalle"
    Call MESSAGE(MENSAJE) From GESECRAN
    If NUMERRORES Then
        Call MESSAGE("No se ha podido insertar " + num$(NUMERRORES) + " registros") From GESECRAN
    Endif

Return


$LINEA_E1
    NUMLIN += 1
    LINEA = "E1"
    LINEA += format$("N0:2",year([M:XE5]DATFIN)-2000)+format$("N0:2",month([M:XE5]DATFIN))+format$("N0:2",day([M:XE5]DATFIN))
    LINEA += space$(6)
    LINEA += format$("N0:4",[M:XE5]ENTIDAD)
    LINEA += space$(140)
    LINEA += format$("N0:7",NUMLIN)  
    Gosub ESCRIBE_LINEA  
Return


$LINEA_E2
    NUMLIN+=1
    NUMLINRES+=1
    NUMBANCOS+=1
    TOTBANCO=0
    LINBANCO=0

    LINEA = "E2"
    LINEA += space$(12)
    LINEA += format$("N0:4",[M:XE5]ENTIDAD)
    LINEA += [F:VE5]BANCO 
    LINEA += space$(136)
    LINEA += format$("N0:7",NUMLIN)  
    Gosub ESCRIBE_LINEA  
Return


$LINEA_E6     
#detalles
    Gosub LEERPROV

    NUMLIN+=1
    NUMLINDET+=1
    LINBANCO+=1
    TOTBANCO+=[F:VE5]IMPORTE

    LINEA = "E6"
    LINEA += [F:VE5]CIF + " T "
    LINEA += [F:VE5]BANCO
    LINEA += [F:VE5]OFICINA
    LINEA += [F:VE5]CUENTA
    LINEA += PROV    
    LINEA += format$("N0:12",[F:VE5]IMPORTE)
    LINEA += left$([F:VE5]NOMBRE,36)
    If len([F:VE5]NOMBRE)<36 : LINEA += space$(36-len([F:VE5]NOMBRE)) : Endif
    LINEA += left$([F:VE5]DIRECCION,36)
    If len([F:VE5]DIRECCION)<36 : LINEA += space$(36-len([F:VE5]DIRECCION)) : Endif
    LINEA += left$([F:VE5]CODPOSTAL,5) + " "
    If len([F:VE5]CODPOSTAL)<5 : LINEA += space$(5-len([F:VE5]CODPOSTAL)) : Endif
    LINEA += left$([F:VE5]CIUDAD,30)
    If len([F:VE5]CIUDAD)<30 : LINEA += space$(30-len([F:VE5]CIUDAD)) : Endif
    LINEA += [F:VE5]DC + "  "
    LINEA += format$("N0:7",NUMLIN)  

    Gosub ESCRIBE_LINEA
    BANCOANT = [F:VE5]BANCO 
    
Return

$LINEA_E6CT     
#detalles - carga tabla temporal para edición
    
    Gosub LEERPROV

    NUMLINDET+=1000
    
    [F:X5D]IDENT = IDENT
    [F:X5D]LINEA = NUMLINDET
    [F:X5D]BANCO = [F:VE5]BANCO 
    [F:X5D]OFICINA = [F:VE5]OFICINA
    [F:X5D]CUENTA  = [F:VE5]CUENTA
    [F:X5D]DC      = [F:VE5]DC
    [F:X5D]BID     = [F:VE5]BID
    [F:X5D]PROV    = PROV
    [F:X5D]SOCIO   = [F:VE5]SOCIO   
    [F:X5D]NOMSOCIO= [F:VE5]NOMBRE 
    [F:X5D]DIRECCION = [F:VE5]DIRECCION
    [F:X5D]CODPOSTAL = [F:VE5]CODPOSTAL
    [F:X5D]CIUDAD  = [F:VE5]CIUDAD
    [F:X5D]IMPORTE = [F:VE5]IMPORTE
    [F:X5D]CIF     = [F:VE5]CIF
    [F:X5D]PAYNUM  = [F:VE5]PAYNUM
    [F:X5D]ACCDAT  = [F:VE5]ACCDAT
    [F:X5D]EXCLUIR = 1

    Trbegin [F:X5D]
    Write [F:X5D]
    If fstat Then
        Rollback
        NUMERRORES+=1
    Else
        Commit
    Endif
        
Return

$LINEA_E8     
#subtotal
    NUMLIN+=1
    NUMLINRES+=1
    TOTTOT+=TOTBANCO
    LINEA = "E8"
    LINEA += space$(12)
    LINEA += BANCOANT
    LINEA += space$(16)
    LINEA += format$("N0:12",TOTBANCO) 
    LINEA += format$("N0:10",LINBANCO)
    LINEA += format$("N0:10",LINBANCO+2)
    LINEA += space$(92)
    LINEA += format$("N0:7",NUMLIN)  

    Gosub ESCRIBE_LINEA
    TOTBANCO = 0
    LINBANCO = 0
Return

$LINEA_E9
#detalles
    NUMLIN+=1
    LINEA = "E9"
    LINEA += space$(32)
    LINEA += format$("N0:12",TOTTOT) 
    LINEA += format$("N0:10",NUMLINDET)
    LINEA += format$("N0:10",NUMLINRES+NUMLINDET)
    LINEA += format$("N0:3",NUMBANCOS)
    LINEA += space$(89)
    LINEA += format$("N0:7",NUMLIN)  

    Gosub ESCRIBE_LINEA
Return

$GENERA_HEADER
    Local Char IDENT(50) 
    IDENT = [M:XE5]FCY + "_" + date$ + "_" + time$ + "_" + GUSER

    [F:X5H]IDENT=IDENT
    [F:X5H]CPY=[M:XE5]CPY
    [F:X5H]FCY=[M:XE5]FCY
    [F:X5H]LACCDAT=[M:XE5]DATFIN
    [F:X5H]ENTIDAD=[M:XE5]ENTIDAD
    [F:X5H]FILEGEN=1
    Trbegin [F:X5H]
    Write [F:X5H]
    If fstat Then
        Rollback
    Else
        Commit
    Endif
    
    
Return

$ESCRIBE_LINEA
    Wrseq LINEA Using [YFIC]
    LINEA=""
    LINTOT += 1  
Return

$LEERPROV
    PROV="##"
    Filter [PRO] Where NUMTAB=6001 & A1=[F:VE5]BANCO & A2=[F:VE5]OFICINA
        
        If !fstat 
        For [PRO]
            If [F:PRO]N1>0 Then
                PROV=format$("N0:2",[F:PRO]N1)
            Endif
        Next
        Endif       
    Filter [PRO]
Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla XEXPM544) 16/10/2015 09:52:20 (TRECE)
######################################################################################
Subprog AM_DATFIN(VALEUR)
Variable Date    VALEUR

    Local Integer MESDEB
    Local Integer MESFIN
    Local Integer YEARFIN
    
    MESFIN = month(VALEUR)
    YEARFIN= year(VALEUR)
    If MESFIN=3 or MESFIN=6 or MESFIN=9 or MESFIN=12 Then
        MESDEB =  MESFIN-2
        [M:XE5]DATDEB = gdat$(1,MESDEB,YEARFIN)
        Affzo [M:XE5]DATDEB 
    Else
        Call MESSAGE("Introduzca una fecha de fin de período correcta") From GESECRAN
    Endif    

End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()    
    Read [FCY]FCY0=VALEUR
    If !fstat Then
        [M:XE5]CPY=[F:FCY]LEGCPY
        Affzo [M:XE5]CPY
    Endif
End


######################################################################################



