######################################################################################
#XVT20190515 - Migración v11
##Migración a v11: la lectura de rendimientos de aceituna sólo modifica el dato "rendimento"
#de la recepción. Todas las línas de dicha recepción se cargarán con el mismo rendimiento.
#La pesada está informada a nivel cabecera de recepción.
$ACTION
    Case ACTION
        When "OUVRE"             : Gosub OUVRE
        When "DEBUT"             : Gosub DEBUT
        When "OK"                : Gosub OK
        When "FIN"               : Gosub FIN
   Endcase
Return
######################################################################################
$OUVRE
 #   If clalev ([F:APX])<=0  : Local File APARIMPEXP [APX] : Endif
    If clalev ([F:ZRA])<=0  : Local File ZRENDACE   [ZRA] : Endif
 #   If clalev ([F:XRA])<=0  : Local File ZRENDACE   [XRA] : Endif
    If clalev ([F:PTH])<=0  : Local File PRECEIPT   [PTH] : Endif
    If clalev ([F:PTD])<=0  : Local File PRECEIPTD  [PTD] : Endif
 #   If clalev ([F:ITM])<=0  : Local File ITMMASTER  [ITM] : Endif
 #   If clalev ([F:YC1])<=0  : Local File YACCABCAL  [YC1] : Endif
 #   If clalev ([F:YFS])<=0  : Local File YCAFSTAD   [YFS] : Endif
 #   If clalev ([F:YTD])<=0  : Local File YTIPDOC    [YTD] : Endif

    Global Integer YERROR
    Global Char    FICHDES(250),RUTA(250),LSEP
Return
######################################################################################
$DEBUT
    Raz [M:DIA]
Return
######################################################################################
$OK
#XVT20190515.bo
#    ##-- Buscaremos la ruta de los ficheros por defecto y crearemos la ruta final --##
#    Read [APX]APX0 = 'REPIMPDEF'
#
#    RUTA = [F:APX]DIRECTORY
#    If RUTA = ""
#        Call ERREUR(mess(121,141,1)) From GESECRAN
#        End
#    Endif
#    LSEP = "|"
#
#    RUTA = left$(RUTA,len(RUTA)-1)
#    FICHDES = filpath(RUTA,num$(adxuid(1))+"_ZIMPCAL","TXT")
#
#    Call CREAR_FICHERO
  Call ACT_RENDIMIENTO_ACEITUNA
Return
######################################################################################
$FIN

Return
######################################################################################
Subprog C_DATAD(VALEUR)
    Variable Date    VALEUR
    If VALEUR = [00/00/00]
        Raz [M:DIA]DATAH
        Grizo [M:DIA]DATAH
    Else
        Actzo [M:DIA]DATAH
    Endif
End
######################################################################################
Subprog C_DATAH(VALEUR)
    Variable Date    VALEUR
    If [M:DIA]DATAD <> [00/00/00] and VALEUR = [00/00/00]
        GERR = 1
        GMESSAGE = mess(10,123,1)
        mkstat = 2
    Endif
End
