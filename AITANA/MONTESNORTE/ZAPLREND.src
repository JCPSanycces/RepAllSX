Subprog ACT_RENDIMIENTO_ACEITUNA
    Call OUVRE_TRACE("Aplicación Rendimientos")  From LECFIC

    #----- Ouverture fichier trace et écriture des sélections -----#
    Call ECR_TRACE(" ",0)                From GESECRAN
    Call ECR_TRACE(string$(88,"-"),0)    From GESECRAN
    Call PRTSCR("ZAPLREND","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(" ",0)                From GESECRAN

    Call TEMPON("E") From GESECRAN

    For [ZRA]ZRA0 Where FECHA >=[M:DIA]DATAD and FECHA <=[M:DIA]DATAH and [ZRA]TGEN <> 2 and REND <> 0
      Trbegin [PTD],[ZRA]
      Readlock [PTD]PTD0 = [F:ZRA]NUMDOC : If fstat : Raz [PTD] : Endif
      If !fstat Then
        [PTD]ZRENDIMIENTO=[ZRA]REND
        Rewrite [PTD]
        [ZRA]TGEN=2
        Rewrite [ZRA]
        Unlock [PTD]
        Commit
        Call ECR_TRACE("Actualizado: " + [ZRA]NUMDOC ,0)  From GESECRAN
      Else
        Rollback
        Call ECR_TRACE("Error actualizando: " + [ZRA]NUMDOC ,1) From GESECRAN
      Endif
    Next

    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC

End

