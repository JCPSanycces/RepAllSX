######################################################################################
Subprog AM_ZDENSIDAD(VALEUR)
Variable Decimal VALEUR
Local Char LTIPOPRODUCTO
  If VALEUR <> 0 Then
    LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:SDH1]ITMREF(nolign-1))
    If LTIPOPRODUCTO = '81' or LTIPOPRODUCTO = '80' Then
      [M:ZSDH2]ZCANT1(nolign-1) = func ZGESCALIF.U_DENSIDAD2CANT1([M:SDH1]QTY(nolign-1), VALEUR)
      Affzo [M:ZSDH2]ZCANT1(nolign-1)
      [M:SDH1]ZCANT1(nolign-1) = [M:ZSDH2]ZCANT1(nolign-1)
    Endif
    # AL MODIFICAR ZCANT1, TAMBIEN MODIFICO LA ZCANT2
    If LTIPOPRODUCTO = "80" or LTIPOPRODUCTO = "81" Then # VINO Y MOSTO
      [M:ZSDH2]ZCANT2(nolign-1) = func ZGESCALIF.U_CANTIDAD12CANTIDAD2([M:ZSDH2]ZCANT1(nolign-1), [M:ZSDH2]ZGRADO(nolign-1))
      Affzo [M:ZSDH2]ZCANT2(nolign-1)
      [M:SDH1]ZCANT2(nolign-1) = [M:ZSDH2]ZCANT2(nolign-1)
      Affzo [M:SDH1]ZCANT2(nolign-1)
    Endif
  Endif
  [M:SDH1]ZDENSIDAD(nolign-1) = VALEUR
  Affzo [M:SDH1]ZDENSIDAD(nolign-1)
 [M:SDH1]UPDFLG(nolign-1) = 1
End
######################################################################################
Subprog AM_ZGLUCONICO(VALEUR)
Variable Decimal VALEUR
Local Decimal LPUNTOS
Local Char LRES
Local Char LTIPOUVA
# If VALEUR <> 0 Then
    If func ZLIBMONTES.GET_TIPOITEM([M:SDH1]ITMREF(nolign-1)) = "90" Then  # If GFLAG = "BOD" Then # Transacción de BODEGA
      LRES = func ZGESCALIF.U_PUNTOS2CALIDAD([M:ZSDH2]ZPH(nolign-1),[M:ZSDH2]ZPOTASIO(nolign-1),VALEUR, GFLAG, [M:ZSDH2]ZCALIDAD(nolign-1), LPUNTOS)
      If LRES <> '' Then
          [M:ZSDH2]ZCALIDAD(nolign-1) = LRES
          [M:ZSDH2]ZPUNTOS(nolign-1) = LPUNTOS
      Endif
      Affzo [M:ZSDH2]ZCALIDAD
      Affzo [M:ZSDH2]ZPUNTOS
      [M:SDH1]ZCALIDAD(nolign-1) = [M:ZSDH2]ZCALIDAD(nolign-1)
      [M:SDH1]ZPUNTOS(nolign-1) = [M:ZSDH2]ZPUNTOS(nolign-1)
      Affzo [M:SDH1]ZCALIDAD(nolign-1)
      Affzo [M:SDH1]ZPUNTOS(nolign-1)
    Endif
    If func ZLIBMONTES.GET_TIPOITEM([M:SDH1]ITMREF(nolign-1)) = "90" Then # If GFLAG = "BOD" Then
      # COMO SABEMOS SI ES UVA BLANCA O TINTA ?????
      LTIPOUVA = func ZLIBMONTES.GET_TIPOUVA([M:SDH1]ITMREF(nolign-1))
      [M:ZSDH2]ZGRADO(nolign-1) = func ZGESCALIF.U_GLUCONICO2GRADO([M:ZSDH2]ZGLUCONICO(nolign-1) ,LTIPOUVA, GFLAG)
      Affzo [M:ZSDH2]ZGRADO
      [M:SDH1]ZGRADO(nolign-1) = [M:ZSDH2]ZGRADO(nolign-1)
      Affzo [M:SDH1]ZGRADO(nolign-1)
    Endif
#  Endif
  [M:SDH1]ZGLUCONICO(nolign-1) = VALEUR
  Affzo [M:SDH1]ZGLUCONICO(nolign-1)
   [M:SDH1]UPDFLG(nolign-1) = 1
End
######################################################################################
Subprog AM_ZGRADO(VALEUR)
Variable Decimal VALEUR
Local Char LTIPOPRODUCTO

  LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:SDH1]ITMREF(nolign-1))
  If VALEUR <> 0 Then
    If LTIPOPRODUCTO = "90" Then # "BOD"
      Call B_UVA_GRADO2CANTIDAD1(VALEUR,[M:SDH1]QTYSTU(nolign-1),[M:ZSDH2]ZCANT1(nolign-1)) From ZGESCALIF
      Affzo [M:ZSDH2]ZCANT1(nolign-1)
      [M:SDH1]ZCANT1(nolign-1) = [M:ZSDH2]ZCANT1(nolign-1)
      Affzo [M:SDH1]ZCANT1(nolign-1)
    Endif
    If LTIPOPRODUCTO = "81"  Then # MOSTO
      [M:ZSDH2]ZDENSIDAD(nolign-1) = func ZGESCALIF.U_GRADO2DENSIDAD(VALEUR)
      Affzo [M:ZSDH2]ZDENSIDAD
      [M:SDH1]ZDENSIDAD(nolign-1) = [M:ZSDH2]ZDENSIDAD(nolign-1)
      Affzo [M:SDH1]ZDENSIDAD(nolign-1)
      #al actualizar la densidad, se actualiza la ZCANT1
      [M:ZSDH2]ZCANT1(nolign-1) = func ZGESCALIF.U_DENSIDAD2CANT1([M:SDH1]QTY(nolign-1), [M:ZSDH2]ZDENSIDAD(nolign-1))
      Affzo [M:ZSDH2]ZCANT1(nolign-1)
      [M:SDH1]ZCANT1(nolign-1) = [M:ZSDH2]ZCANT1(nolign-1)
    Endif
    # AL MODIFICAR ZCANT1, TAMBIEN MODIFICO LA ZCANT2
    If LTIPOPRODUCTO = "80" or LTIPOPRODUCTO = "81" Then # VINO Y MOSTO
      [M:ZSDH2]ZCANT2(nolign-1) = func ZGESCALIF.U_CANTIDAD12CANTIDAD2([M:ZSDH2]ZCANT1(nolign-1), VALEUR)
      Affzo [M:ZSDH2]ZCANT2(nolign-1)
      [M:SDH1]ZCANT2(nolign-1) = [M:ZSDH2]ZCANT2(nolign-1)
      Affzo [M:SDH1]ZCANT2(nolign-1)
    Endif
  Endif
  [M:SDH1]ZGRADO(nolign-1) = VALEUR
  Affzo [M:SDH1]ZGRADO(nolign-1)
   [M:SDH1]UPDFLG(nolign-1) = 1
End
######################################################################################
Subprog AM_ZHUMEDAD(VALEUR)
Variable Decimal VALEUR
Local Char LTIPOPRODUCTO
If VALEUR <> 0 Then
    LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:SDH1]ITMREF(nolign-1))
    If LTIPOPRODUCTO = "21" Then # If GFLAG = "CER" Then # Transacción de CEREAL
      [M:ZSDH2]ZCANT1(nolign-1) =  func ZGESCALIF.C_HUMEDAD2CANTIDAD1(VALEUR, GFLAG, [M:SDH1]QTY(nolign-1))
      Affzo [M:ZSDH2]ZCANT1
      [M:SDH1]ZCANT1(nolign-1) = [M:ZSDH2]ZCANT1(nolign-1)
      Affzo [M:SDH1]ZCANT1(nolign-1)
    Endif

  # AL MODIFICAR ZCANT1, TAMBIEN MODIFICO LA ZCANT2
   If LTIPOPRODUCTO = "50" Then # If GFLAG = "FRU" Then # Transacción de FRUTOS CON CASCARA
      [M:ZSDH2]ZCANT2(nolign-1) =  func ZGESCALIF.FC_HUMEDAD2CANTIDAD2(VALEUR, GFLAG, [M:ZSDH2]QTYSTU(nolign-1) , [M:ZSDH2]ZCANT1(nolign-1))
      Affzo [M:ZSDH2]ZCANT2
      [M:SDH1]ZCANT2(nolign-1) = [M:ZSDH2]ZCANT2(nolign-1)
      Affzo [M:SDH1]ZCANT2(nolign-1)
    Endif
   If LTIPOPRODUCTO = "81" Then # MOSTO
      [M:ZSDH2]ZCANT2(nolign-1) = func ZGESCALIF.U_CANTIDAD12CANTIDAD2([M:ZSDH2]ZCANT1(nolign-1), [M:ZSDH2]ZGRADO(nolign-1))
      Affzo [M:ZSDH2]ZCANT2
      [M:SDH1]ZCANT2(nolign-1) = [M:ZSDH2]ZCANT2(nolign-1)
      Affzo [M:SDH1]ZCANT2(nolign-1)
   Endif

Endif
    [M:SDH1]ZHUMEDAD(nolign-1) = VALEUR
    Affzo [M:SDH1]ZHUMEDAD(nolign-1)
    [M:SDH1]UPDFLG(nolign-1) = 1

End
######################################################################################
Subprog AM_ZPESOESPE(VALEUR)
Variable Decimal VALEUR
  [M:SDH1]ZPESOESPE(nolign-1) = VALEUR
  Affzo [M:SDH1]ZPESOESPE(nolign-1)
   [M:SDH1]UPDFLG(nolign-1) = 1
End

######################################################################################
Subprog AM_ZPOTASIO(VALEUR)
Variable Decimal VALEUR
Local Decimal LPUNTOS
Local Char LRES
# If VALEUR <> 0 Then
    If func ZLIBMONTES.GET_TIPOITEM([M:SDH1]ITMREF(nolign-1)) = "90" Then # Transacción de BOD
      LRES =  func ZGESCALIF.U_PUNTOS2CALIDAD([M:ZSDH2]ZPH(nolign-1),VALEUR,[M:ZSDH2]ZGLUCONICO(nolign-1), GFLAG, [M:ZSDH2]ZCALIDAD(nolign-1), LPUNTOS)
      If LRES <> '' Then
        [M:ZSDH2]ZCALIDAD(nolign-1) = LRES
        [M:ZSDH2]ZPUNTOS(nolign-1) = LPUNTOS
      Endif
      Affzo [M:SDH1]ZCALIDAD
      Affzo [M:SDH1]ZPUNTOS
      [M:SDH1]ZCALIDAD(nolign-1) = [M:ZSDH2]ZCALIDAD(nolign-1)
      [M:SDH1]ZPUNTOS(nolign-1) = [M:ZSDH2]ZPUNTOS(nolign-1)
      Affzo [M:SDH1]ZCALIDAD
      Affzo [M:SDH1]ZPUNTOS
    Endif
 # Endif
  [M:SDH1]ZPOTASIO(nolign-1) = VALEUR
  Affzo [M:SDH1]ZPOTASIO(nolign-1)
   [M:SDH1]UPDFLG(nolign-1) = 1
End
######################################################################################
Subprog AM_ZRENDIMIENTO(VALEUR)
Variable Decimal VALEUR
 If VALEUR <> 0 Then
    If func ZLIBMONTES.GET_TIPOITEM([M:SDH1]ITMREF(nolign-1)) = "50" Then # If GFLAG = "FRU" Then # Transacción de FRUTOS CON CASCARA
      [M:ZSDH2]ZCANT1(nolign-1) =  func ZGESCALIF.FC_RENDIMIENTO2CANTIDAD1(VALEUR, GFLAG, [M:SDH1]QTY(nolign-1))
      Affzo [M:ZSDH2]ZCANT1
      [M:SDH1]ZCANT1(nolign-1) = [M:ZSDH2]ZCANT1(nolign-1)
      Affzo [M:SDH1]ZCANT1(nolign-1)
    Endif
  Endif
  [M:SDH1]ZRENDIMIENTO(nolign-1) = VALEUR
  Affzo [M:SDH1]ZRENDIMIENTO(nolign-1)
   [M:SDH1]UPDFLG(nolign-1) = 1
End


