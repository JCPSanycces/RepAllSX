Subprog AM_ZAIN(VALEUR)
Variable Char    VALEUR()
  If !clalev ([AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev ([CNT]) : Local File CONTACT [CNT] : Endif

  Read [AIN]AIN0=VALEUR
  If !fstat Then
    [M:SDH3]ZAINNAM=[AIN]CNTLNA + ' ' + [AIN]CNTFNA
    Affzo [M:SDH3]ZAINNAM
  Endif
  If VALEUR <> '' Then
    #If [M:SDH3]ZZAINCRN = '' Then
      [M:SDH3]ZZAINCRN = func GET_CRN_CONTACTO(VALEUR)
      Affzo [M:SDH3]ZZAINCRN
    #Endif
  Endif

End

