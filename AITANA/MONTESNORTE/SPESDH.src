## Etiqueta añadida por el supervisor (pantalla SDH1) 10/06/2019 16:40:07 (ADMIN)
######################################################################################
Subprog AM_ZPH(VALEUR)
Variable Decimal VALEUR
Local Decimal LPUNTOS
Local Char LRES
# If VALEUR <> 0 Then
    If func ZLIBMONTES.GET_TIPOITEM([M:SDH1]ITMREF(nolign-1)) = "90" Then # If GFLAG = "BOD" Then # Transacción de BODEGA
      LRES = func ZGESCALIF.U_PUNTOS2CALIDAD(VALEUR,[M:ZSDH2]ZPOTASIO(nolign-1),[M:ZSDH2]ZGLUCONICO(nolign-1), GFLAG, [M:ZSDH2]ZCALIDAD(nolign-1), LPUNTOS)
      If LRES <> '' Then
          [M:ZSDH2]ZCALIDAD(nolign-1) =  LRES
          [M:ZSDH2]ZPUNTOS(nolign-1) = LPUNTOS
          Affzo [M:ZSDH2]ZCALIDAD(nolign-1)
          Affzo [M:ZSDH2]ZPUNTOS(nolign-1)
          [M:SDH1]ZCALIDAD(nolign-1) =  [M:ZSDH2]ZCALIDAD(nolign-1)
          [M:SDH1]ZPUNTOS(nolign-1) = [M:ZSDH2]ZPUNTOS(nolign-1)
          Affzo [M:SDH1]ZCALIDAD
          Affzo [M:SDH1]ZPUNTOS
      Endif
    Endif
#  Endif
  [M:SDH1]ZPH(nolign-1) = VALEUR
  Affzo [M:SDH1]ZPH
  [M:SDH1]QTY(nolign-1) = [M:SDH1]QTY(nolign-1)
  [M:SDH1]UPDFLG(nolign-1) = 1
End



