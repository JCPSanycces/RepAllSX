######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SDH1) 09/09/2019 15:51:45 (ADMIN)
######################################################################################
Subprog AM_ZTARAVEHI(VALEUR)
Variable Decimal VALEUR
 #Infbox num$([M:SDH1]ZBRUTOVEHI(nolign-1))
  If VALEUR <> 0 and [M:SDH1]ZBRUTOVEHI(nolign-1) = 0 Then
     [M:SDH1]QTY(nolign-1) = 1
     Affzo [M:SDH1]QTY(nolign-1)
     [M:SDH1]QTYSTU(nolign-1)=[M:SDH1]QTY(nolign-1)
     Affzo [M:SDH1]QTYSTU(nolign-1)
     If dim([M:ZSDH2]QTYSTU(nolign-1))>0 Then
       [M:ZSDH2]QTYSTU(nolign-1) =  [M:SDH1]QTY(nolign-1)
       Affzo [M:ZSDH2]QTYSTU(nolign-1)
     Endif
  Elsif VALEUR <> 0  and [M:SDH1]ZBRUTOVEHI(nolign-1) <> 0 Then
      [M:SDH1]QTY(nolign-1) = [M:SDH1]ZBRUTOVEHI(nolign-1) - VALEUR
      Affzo [M:SDH1]QTY(nolign-1)
      [M:SDH1]QTYSTU(nolign-1)=[M:SDH1]QTY(nolign-1)
      Affzo [M:SDH1]QTYSTU(nolign-1)
      If dim([M:ZSDH2]QTYSTU(nolign-1))>0 Then
        [M:ZSDH2]QTYSTU(nolign-1) =  [M:SDH1]QTY(nolign-1)
        Affzo [M:ZSDH2]QTYSTU(nolign-1)
      Endif
  Endif

End

Subprog AM_ZBRUTOVEHI(VALEUR)
Variable Decimal VALEUR
  If VALEUR <> 0  and [M:SDH1]ZTARAVEHI(nolign-1) <> 0  Then
      If VALEUR > [M:SDH1]ZTARAVEHI Then
        [M:SDH1]QTY(nolign-1) = VALEUR - [M:SDH1]ZTARAVEHI(nolign-1)
        Affzo [M:SDH1]QTY(nolign-1)
        [M:SDH1]QTYSTU(nolign-1)=[M:SDH1]QTY(nolign-1)
        Affzo [M:SDH1]QTYSTU(nolign-1)
        If dim([M:ZSDH2]QTYSTU(nolign-1))>0 Then
         [M:ZSDH2]QTYSTU(nolign-1) =  [M:SDH1]QTY(nolign-1)
         Affzo [M:ZSDH2]QTYSTU(nolign-1)
        Endif
#XVT240220.bn
        If GREP="M" Then #XVT260220.bn

          If dim([M:ZSDH2]ZCANT1(nolign-1))>0 Then
            Call AM_ZGRADO([M:ZSDH2]ZGRADO(nolign-1))
            Call AM_ZDENSIDAD([M:ZSDH2]ZDENSIDAD(nolign-1))
          Endif

        Elsif GREP="C" Then   #XVT260220.Bn
          Call ACTUALIZA_ZCANTX()
        Endif #DEL GREP="M"   #XVT260220.En
#XVT240220.en
      Else
        mkstat=2
      Endif
  Endif
End


######################################################################################

Funprog GET_CRN_TRANSPORTISTA(PTRANSPORTISTA, LBPTNAM)
  Variable Char LBPTNAM
  Local Char RES


  If !clalev([ZBPA]) Then : Local File BPARTNER [ZBPA] : Endif

  Filter [F:ZBPA] Where BPRNUM = PTRANSPORTISTA
  Read [F:ZBPA] First
  If !fstat Then
    RES = [F:ZBPA]CRN
    LBPTNAM = [F:ZBPA]BPRNAM
  Else
    RES = ''
    LBPTNAM = ''
  Endif
  Close File [ZBPA]

End RES


######################################################################################

Funprog GET_CRN_CONTACTO(PCONTACTO)
  Local Char RES

  If !clalev([ZCON]) Then : Local File CONTACTCRM [ZCON] : Endif

  Filter [F:ZCON] Where CNTNUM = PCONTACTO

  Read [F:ZCON] First
  If !fstat Then
    RES = [F:ZCON]ZDNI
  Else
    RES = ''
  Endif
  Close File [ZCON]

End RES
######################################################################################
## Etiqueta añadida por el supervisor (pantalla SDH2) 12/09/2019 12:18:32 (ADMIN)
######################################################################################
Subprog AM_BPTNUM(VALEUR)
Variable Char    VALEUR()
Local Char PBPTNAM
Local  Char LRES
  LRES = func GET_CRN_TRANSPORTISTA(VALEUR, PBPTNAM)
#  If VALEUR <> '' Then  #XVT07012020.o El transportista ha de borrarse en la pantalla
#  complementario si se borra en la pantalla GESTION .
    [M:SDH3]BPTNUM = VALEUR
#  Endif                #XVT07012020.o
  If LRES <> '' Then
    #If [M:SDH3]ZCRN = '' Then
      [M:SDH3]ZCRN = LRES
    #Endif
  Else
    [M:SDH3]ZCRN = ''
  Endif
  If PBPTNAM <> '' Then
    [M:SDH3]ZBPTNAM = PBPTNAM
  Else
    [M:SDH3]ZBPTNAM = ''
  Endif

  Affzo [M:SDH3]ZCRN
  Affzo [M:SDH3]BPTNUM
  Affzo [M:SDH3]ZBPTNAM

 #XVT07012020.bn
  #si el transportista se queda vacío, el conductor no puede tener código, se introducirá
  #únicamente el nombre del conductor a mano.
  [M:SDH3]ZAIN=''
  Affzo [M:SDH3]ZAIN
  If [M:SDH2]BPTNUM <> VALEUR Then
    Call MESSAGE ("Ha cambiado el transportista. Compruebe los datos de conductor y matrículas") From GESECRAN
  Endif
  #XVT07012020.en

End


######################################################################################

Subprog ACT_CANTIDAD_LIG()
Local Char LTIPOPRODUCTO
LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([F:SDD]ITMREF)
If LTIPOPRODUCTO = '81' or LTIPOPRODUCTO = '80' Then
  If LTIPOPRODUCTO = "81"  Then # MOSTO
    [F:SDD]ZDENSIDAD = func ZGESCALIF.U_GRADO2DENSIDAD([F:SDD]ZGRADO)
  Endif

  [F:SDD]ZCANT1 = func ZGESCALIF.U_DENSIDAD2CANT1([F:SDD]QTY, [F:SDD]ZDENSIDAD)
  [F:SDD]ZCANT2 = func ZGESCALIF.U_CANTIDAD12CANTIDAD2([F:SDD]ZCANT1, [F:SDD]ZGRADO)

Endif
# [M:SDH1]UPDFLG(nolign-1) = 1
End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SDH1) 24/02/2020 18:56:29 (ADMIN)
######################################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
#XVT240220.bn
        If dim([M:ZSDH2]ZCANT1(nolign-1))>0 Then
          If dim([M:ZSDH2]QTYSTU(nolign-1))>0 Then
            [M:ZSDH2]QTYSTU(nolign-1) =  [M:SDH1]QTY(nolign-1)
            Affzo [M:ZSDH2]QTYSTU(nolign-1)
          Endif
          Call AM_ZGRADO([M:ZSDH2]ZGRADO(nolign-1))
          Call AM_ZDENSIDAD([M:ZSDH2]ZDENSIDAD(nolign-1))
        Endif
#XVT240220.en
End


######################################################################################
Subprog ACTUALIZA_ZCANTX()
Local Char LTIPOPRODUCTO
    LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:SDH1]ITMREF(nolign-1))
    If LTIPOPRODUCTO = '81' or LTIPOPRODUCTO = '80' Then
      [M:ZSDH2]ZCANT1(nolign-1) = func ZGESCALIF.U_DENSIDAD2CANT1([M:SDH1]QTY(nolign-1), [M:SDH1]ZDENSIDAD(nolign-1))
      [M:SDH1]ZCANT1(nolign-1) = [M:ZSDH2]ZCANT1(nolign-1)
    Endif
    # AL MODIFICAR ZCANT1, TAMBIEN MODIFICO LA ZCANT2
    If LTIPOPRODUCTO = "80" or LTIPOPRODUCTO = "81" Then # VINO Y MOSTO
      [M:ZSDH2]ZCANT2(nolign-1) = func ZGESCALIF.U_CANTIDAD12CANTIDAD2([M:ZSDH2]ZCANT1(nolign-1), [M:ZSDH2]ZGRADO(nolign-1))
      [M:SDH1]ZCANT2(nolign-1) = [M:ZSDH2]ZCANT2(nolign-1)
    Endif

    [M:SDH1]UPDFLG(nolign-1) = 1
End


