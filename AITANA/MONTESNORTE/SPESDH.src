#<AdxTL>@(#)0.0.0.0 $Revision$ Entregas
#XVT170220 para permitir la impresión del albarán de cliente final estando situado en el albarán insersociedad de
# la cooperativa base. Como ambos están relacionados, cargamos el nº de albarán de cliente final, si lo hubiera.
# El listado de albarán podrá alimentarse de este nuevo campo si está informado.
#XVT240220 cuando se modifica el bruto o la cantidad estándar, hay que recalcular zcant1 y zcant2 en función del grado
#y la densidad en bodega graneles
#XVT110320 Autoconsumos: el flag BETFCY debe desmarcarse antes de introducir los artículos en líneas.
#XVT060420 Graneles: la validación de la entrega sólo se puede producir en los siguientes supuestos:
# (esto aplica a las transacciones BOG, ALG, FRU, CER, SEC)
# Campo contrato origen: siempre informado
# Campo entrega origen: informado siempre que la entrega no sea interplanta, es decir, para entregas a cliente final

$ACTION
  Case ACTION
    When "LIENS"    : Gosub LIENS
    When "AFFMASK"  : Gosub AFFMASK
    When "SETBOUT"  : Gosub SETBOUT
    When "INICRE"   : Gosub INICRE
    When "FIN_PICK" : Gosub FIN_PICK
    When "INICRE_LIG" : Gosub INICRE_LIG
    When "EXEBOUT"  : Gosub EXEBOUT
  Endcase
Return

###################################################################################
$LIENS
  Gosub LIENS_ZSDH2
  Gosub TITCOL_ZSDH2
  Gosub BUSCA_ALBARAN_CLIENTE_FINAL
Return

# 50 - FRU
# 21 - CER
# 70 - ALMAZARA
# 80 - 81 - BOG
# 90 - BOD

$SETBOUT
    If GFLAG="ZAIM" Then
      #en entregas de autoconsumo, no se puede generar recepción
      Call VIREBOUT (CHAINE,"Z") From GOBJET
    Endif

    #Comprobación: si es interplanta y ya ha generado recepción, desactivar
    If [M:SDH1]BETFCY=2 and [M:SDH1]CFMFLG=2 Then
      If !clalev ([ZPTH]) : Local File PRECEIPT [ZPTH] : Endif
      Read [ZPTH]PTH1=[F:SDH]SDHNUM
      If !fstat Then
        #RECEPCIÓN YA CREADA, DESACTIVAR
        Call VIREBOUT(CHAINE,"O") From GOBJET
      Else
        CHMEN+="O"
      Endif
    Else
      #NO ES INTERPLANTA O NO ESTÁ VALIDADO, DESACTIVAR
      Call VIREBOUT(CHAINE,"O") From GOBJET
    Endif

    #XVT060420.bn
    Case GFLAG
      When "ALG" : Gosub BLQ_VALIDACION
      When "BOG" : Gosub BLQ_VALIDACION
      When "FRU" : Gosub BLQ_VALIDACION
      When "CER" : Gosub BLQ_VALIDACION
      When "SEC" : Gosub BLQ_VALIDACION
    When Default
    Endcase
    #XVT060420.en
Return

    #XVT060420.bn
$BLQ_VALIDACION
  If [M:SDH2]ZOPPORI="" or ([M:SDH2]ZSDHORI="" and [M:SDH1]BETFCY<>2) Then
    Call VIREBOUT(CHAINE,"1") From GOBJET
  Endif

Return
    #XVT060420.en

$EXEBOUT

    Case BOUT
      When "O" : Gosub PROCESA_VALIDACION_NOIMPORT From ZTRTVENLIV
    Endcase

Return

$INICRE
    If GFLAG="ZAIM" Then
        [F:SDH]BETFCY=1
    Endif
Return

$INICRE_LIG
 Call ACT_CANTIDAD_LIG()
Return


###################################################################################
$FIN_PICK
# DESARROLLO PARA AÑADIR AL TEXTO DE CABECERA DE LA ENTREGA EL TEXTO DEL PROYECTO QUE TIENE ASOCIADO
# EL PEDIDO QUE SE ESTÁ ENTREGANDO
# NO SE CONTROLA SI SE SELECCIONAN MÁS DE UN PEDIDO, YA QUE SOLO SE VA A REALIZAR DE UN PEDIDO.
# MONTESNORT-66
  Local Char COD_TEXTO

  If !clalev([ZOPP]) Then : Local File OPPOR [ZOPP] : Endif
  #Infbox [F:SOH]SOHNUM
  Read [ZOPP]OPP0=[F:SOH]PJT
  If !fstat Then
     # Infbox "dentro"
     # Infbox [F:SOH]PJT
     If [F:ZOPP]ZREFERENCIA(0) <> '' Then
      COD_TEXTO = func  ZLIBMONTES.F_CRELOB("SDH",[F:ZOPP]ZREFERENCIA(0))
      [M:SDH1]SDDTEX(nolign-1) =  COD_TEXTO
     # Infbox [M:SDH1]SDDTEX(nolign-1)

     Endif
  Endif

  Close File [ZOPP]


Return




###################################################################################
$LIENS_ZSDH2
  Local Char LBPTNAM
  If !clalev([ZSDE]) : Local File SDELIVERYD[ZSDE] : Endif
  Raz nolign
  nolign=0
  Filter [ZSDE] Where SDHNUM=[M:SDH0]SDHNUM
  For [ZSDE]
      nolign+=1
      [M:ZSDH2] = [F:ZSDE]
  Next
  [M:ZSDH2]ZNBLIC = nolign
  nolign=0
  Affzo [M:ZSDH2]
  # MAB.12092019.NEW
  If [M:SDH3]ZCRN = '' Then
    [M:SDH3]ZCRN = func GET_CRN_TRANSPORTISTA([M:SDH2]BPTNUM, LBPTNAM)
    If [M:SDH3]ZBPTNAM = '' Then
       [M:SDH3]ZBPTNAM  = LBPTNAM
    Endif
  Endif
Return


###################################################################################
$TITCOL_ZSDH2
  Call OCULTA_CAMPOS("SDH") From ZSPEMASKL
  Affzo [M:ZSDH2]

Return


$AFFMASK
  #ocultar calificaciones que no aplican por transacción
  If GFLAG="ALL" : Return : Endif

  Call OCULTA_CAMPOS("SDH") From ZSPEMASKL
  Affzo [M:ZSDH2]
Return


######################################################################################
#XVT170220.bn
$BUSCA_ALBARAN_CLIENTE_FINAL
#  If GUSER='ADMIN' Then
#    Infbox "SPESDH - ADMIN: BUSCAR ALBARÁN CLIENTE FINAL"
#  Endif
  If dim([M:SDH2]ZSDHCLIFIN)>=0  Then
    If !clalev ([ZSDHCF]) : Local File SDELIVERY [ZSDHCF] : Endif
    Filter [ZSDHCF] Where [ZSDHCF]ZSDHORI=[M:SDH0]SDHNUM
      Read [ZSDHCF] First
      If !fstat Then
        [M:SDH2]ZSDHCLIFIN=[F:ZSDHCF]SDHNUM
        [M:SDH2]ZPRNNDECF =[F:ZSDHCF]PRNNDE
      Else
        [M:SDH2]ZSDHCLIFIN=[M:SDH0]SDHNUM
        [M:SDH2]ZPRNNDECF =[M:SDH1]PRNNDE
      Endif
    Filter [ZSDHCF]
  #  Infbox [M:SDH2]ZSDHCLIFIN
  Endif
Return
#XVT170220.en


######################################################################################
## Etiqueta añadida por el supervisor (pantalla SDH1) 14/05/2019 13:06:55 (ADMIN)
######################################################################################
Subprog AM_ZCALIDAD(VALEUR)
  Variable Char    VALEUR()
  Local Integer ESTAT

    If (VALEUR<>"")
        Call MODIF_CALIDAD(VALEUR, [M:SDH1]TSICOD1(nolign-1), [M:SDH1]TSICOD2(nolign-1),
&            [M:SDH1]TSICOD3(nolign-1), 2, ESTAT) From YSELAGRO
        If ESTAT=0 Then
            GERR=1
            # GMESSAGE=mess(12,1986,1)
            Infbox "Calidad no contemplada para el artículo seleccionado"
            mkstat=2
            EXISTE=1
        Endif
    Endif
    [M:SDH1]ZCALIDAD(nolign-1) = VALEUR
    Affzo [M:SDH1]ZCALIDAD(nolign-1)
    [M:SDH1]UPDFLG(nolign-1) = 1
End


######################################################################################
######################################################################################
## Etiqueta añadida por el supervisor (pantalla SDH0) 12/07/2019 12:39:31 (ADMIN)
######################################################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
  Local Integer VEJERCICIO : VEJERCICIO=0
  Call GET_EJERCICIO(VALEUR,0,[M:SDH1]SHIDAT,VEJERCICIO) From ZLIBMONTES

  [M:SDH0]ZEJERCICIO=VEJERCICIO
  Affzo [M:SDH0]ZEJERCICIO
End
######################################################################################
Subprog C_SHIDAT(VALEUR)
Variable Date    VALEUR
  Local Integer VEJERCICIO : VEJERCICIO=0
  Call GET_EJERCICIO([M:SDH0]STOFCY,0,VALEUR,VEJERCICIO) From ZLIBMONTES

  [M:SDH0]ZEJERCICIO=VEJERCICIO
  Affzo [M:SDH0]ZEJERCICIO
End
######################################################################################
Subprog C_ZEJERCICIO(VALEUR)
Variable Decimal VALEUR
  Local Integer POK : POK=0
  If VALEUR<>0 Then
     Call CHECK_EJERCICIO([M:SDH0]STOFCY,0,VALEUR,POK) From ZLIBMONTES
     If POK=0 Then
      Call MESSAGE ("Campaña no definida para este tipo de planta.") From GESECRAN
      VALEUR=0
     Endif
  Endif
End


