######################################################################################
Subprog AP_BPCORD(VALEUR)
Variable Char    VALEUR()
#En transacciones de autoconsumo
  If GFLAG="ZAIM" Then
    If !clalev([ZBPC]) : Local File BPCUSTOMER [ZBPC] : Endif
    Read [ZBPC]BPC0=VALEUR
    If !fstat Then
      [M:SDH0]ZCCECLI = [ZBPC]CCE(1)
