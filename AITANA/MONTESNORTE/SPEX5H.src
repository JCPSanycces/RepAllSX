#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("X5H",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
#If ACTION<>"LIENS" and ACTION<>"LIENS_LIG" Then
#Infbox(ACTION)
#Endif
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "SETBOUT"   : Gosub SETBOUT
 When "LIENS"     : Gosub LIENS
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "ANNULE"    : Gosub ANNULE
 When "APRES_CRE" : Gosub APRES_CRE
 When "APRES_MOD" : Gosub APRES_MOD
 When "INICRE_LIG": Gosub INICRE_LIG
 When "DEFLIG"    : Gosub DEFLIG
 When "FILTRE"    : Gosub FILTRE
 When "AVANTBOUT"   Gosub BOUTON
Endcase
Return

$SETBOUT
    CHMEN+="x1x2"
Return

$BOUTON
    Case BOUT
        When "1" : Gosub EXPORTDETABLA
    Endcase
Return

$CREATION
    Gosub CREATION From TABLEAUX
Return

$OUVRE
    If !clalev ([F:APX]) : Local File APARIMPEXP [APX] : Endif
    If !clalev ([F:FCY]) : Local File FACILITY   [FCY] : Endif
    If !clalev ([F:VE5]) : Local File XMOD544DT  [VE5] : Endif
    If !clalev ([F:PRO]) : Local File ATABDIV    [PRO] : Endif
    If !clalev ([F:X5H]) : Local File XMOD544H   [X5H] : Endif
    If !clalev ([F:X5D]) : Local File XMOD544D   [X5D] : Endif

    Local Char    WFIL(250)
    Local Integer CONTADOR
    Local Char    MENSAJE(250)
    Local Char    PYHNUM(20)
    Local Char    LINEA(165)
    Local Integer NUMLIN
    Local Integer NUMLINDET
    Local Integer NUMLINRES

    Local Integer TOTBANCO
    Local Integer TOTTOT
    Local Integer LINBANCO
    Local Integer LINTOT
    Local Integer NUMBANCOS

    Local Char    BANCOANT(4)
    Local Char    PROV(2)

    Local Integer NUMERRORES

    Gosub DECLARE From TABLEAUX
Return

$DEBUT
    CONTADOR = 0
    LINEA=""
    NUMLIN = 0
    NUMLINDET=0
    NUMLINDRES=0
    PROV=""
Return


$ANNULE
    Gosub ANNULE From TABLEAUX
Return

$APRES_CRE
    Gosub LIENS From TABLEAUX
Return

$APRES_MOD
    Gosub LIENS From TABLEAUX
Return

$INICRE_LIG
    [F:X5D]IDENT = [M:X5H0]IDENT
Return

$DEFLIG
    Default Mask [M:X5H1]
    Default File [F:X5D]

    CRIT = 'IDENT = "'+ [M:X5H0]IDENT+'"'

    FICLIG = "XMOD544D"
    ABLIG = "X5D"
    ZONLIG = "LINEA"
Return

$FILTRE
    Default File [F:X5H]
Return

$LIENS
    Gosub LIENS From TABLEAUX
Return

$MODIF
    Gosub MODIF From TABLEAUX
Return


$EXPORTDETABLA

    Gosub COMPROBACIONES
    Gosub INIT_EXP
    Gosub READDATA
    Gosub FINALIZAR

    Gosub DEBUT
Return

$COMPROBACIONES
    TOTBANCO=0
    TOTTOT=0
    LINBANCO=0
    LINTOT=0
    NUMLINDET=0
    NUMLINRES=0
    NUMBANCOS=0
    BANCOANT=""

    CONTADOR = 0
    LINEA=""
    NUMLIN = 0
    NUMERRORES=0
Return


$INIT_EXP
    #-- variables

        #-- variables diversas
        Local Char    RUTA(GDIMFIC), FICHERO(GDIMFIC)
        Local Char    NOM_FICH(50)

        #-- variables de fichero, inicializacion
        adxifs = ";"                     #-- adxifs, separador de campo
        adxirs = chr$(13)+chr$(10)       #-- adxirs, separador de registro
        adxium = 50                      #-- adxium, modo 50 = ASCII
        EXT    = "txt"                   #-- extension del fichero
        NOM_FICH = "MOD544_"+[M:X5H0]CPY+"_"+date$

        RUTA="E:\IMPORTEXPORT\MOD544"
       # Read [APX]APX0="REPEXPDEF"
       # If !fstat Then
       #     RUTA=[F:APX]DIRECTORY+"MOD544"
       # Endif
       # If RUTA=""
       #    Call MESSAGE('Directorio de exportación no encontrado. Revise parámetros de import/export') From  GESECRAN
       #    End
       # Endif
        FICHERO = filpath(RUTA,NOM_FICH,EXT,"","","")
        Openo FICHERO,0 Using [YFIC]
Return

$READDATA

    Filter [VE5] Where IDENT=[M:X5H0]IDENT Order By BID #& EXCLUIR=1 XVT220719.o "excluir" no está en la vista, la vista ya está
                                                        #filtrada para los registros que no están excluidos.
    For [VE5]
        CONTADOR += 1
        If CONTADOR < 2 Then
                Gosub LINEA_E1
        Endif

        If BANCOANT <> [F:VE5]BANCO Then
            If BANCOANT<>"" Then
                Gosub LINEA_E8        #subtotales banco
            Endif
            Gosub LINEA_E2            #nuevo grupo banco
        Endif
        Gosub LINEA_E6 ##detalle

    Next
    Filter [VE5]

    If CONTADOR >= 1 Then
        #AL ACABAR,
        #rematar el último E8 y la E9
        Gosub LINEA_E8
        Gosub LINEA_E9
        Gosub ACTUALIZA_HEADER

    Endif

    MENSAJE = "Recuento: " + num$(CONTADOR) + " líneas de detalle"
    Infbox (MENSAJE)


Return

$ACTUALIZA_HEADER
    Trbegin [X5H]
    Readlock [X5H]X5H0=[M:X5H0]IDENT
    [F:X5H]FILEGEN=2
    Rewrite [X5H]
     Unlock [X5H]
    Commit
    [M:X5H0]FILEGEN=2
    Affzo [M:X5H0]FILEGEN
Return

$LINEA_E1
    NUMLIN += 1
    LINEA = "E1"
    LINEA += format$("N0:2",year([M:X5H0]LACCDAT)-2000)+format$("N0:2",month([M:X5H0]LACCDAT))+format$("N0:2",day([M:X5H0]LACCDAT))
    LINEA += space$(6)
    LINEA += format$("N0:4",[M:X5H0]ENTIDAD)
    LINEA += space$(140)
    LINEA += format$("N0:7",NUMLIN)
    Gosub ESCRIBE_LINEA
Return

$LINEA_E2
    NUMLIN+=1
    NUMLINRES+=1
    NUMBANCOS+=1
    TOTBANCO=0
    LINBANCO=0

    LINEA = "E2"
    LINEA += space$(12)
    LINEA += format$("N0:4",[M:X5H0]ENTIDAD)
    LINEA += [F:VE5]BANCO
    LINEA += space$(136)
    LINEA += format$("N0:7",NUMLIN)
    Gosub ESCRIBE_LINEA
Return

$LINEA_E6
#detalles
    NUMLIN+=1
    NUMLINDET+=1
    LINBANCO+=1
    TOTBANCO+=[F:VE5]IMPORTE

    LINEA = "E6"
    LINEA += [F:VE5]CIF + " T "
    LINEA += [F:VE5]BANCO
    LINEA += [F:VE5]OFICINA
    LINEA += [F:VE5]CUENTA
    LINEA += [F:VE5]PROV
    LINEA += format$("N0:12",[F:VE5]IMPORTE)
    LINEA += left$([F:VE5]NOMSOCIO,36)
    If len([F:VE5]NOMSOCIO)<36 : LINEA += space$(36-len([F:VE5]NOMSOCIO)) : Endif
    LINEA += left$([F:VE5]DIRECCION,36)
    If len([F:VE5]DIRECCION)<36 : LINEA += space$(36-len([F:VE5]DIRECCION)) : Endif
    LINEA += left$([F:VE5]CODPOSTAL,5) + " "
    If len([F:VE5]CODPOSTAL)<5 : LINEA += space$(5-len([F:VE5]CODPOSTAL)) : Endif
    LINEA += left$([F:VE5]CIUDAD,30)
    If len([F:VE5]CIUDAD)<30 : LINEA += space$(30-len([F:VE5]CIUDAD)) : Endif
    LINEA += [F:VE5]DC + "  "
    LINEA += format$("N0:7",NUMLIN)

    Gosub ESCRIBE_LINEA
    BANCOANT = [F:VE5]BANCO

Return



$LINEA_E8
#subtotal
    NUMLIN+=1
    NUMLINRES+=1
    TOTTOT+=TOTBANCO
    LINEA = "E8"
    LINEA += space$(12)
    LINEA += BANCOANT
    LINEA += space$(16)
    LINEA += format$("N0:12",TOTBANCO)
    LINEA += format$("N0:10",LINBANCO)
    LINEA += format$("N0:10",LINBANCO+2)
    LINEA += space$(92)
    LINEA += format$("N0:7",NUMLIN)

    Gosub ESCRIBE_LINEA
    TOTBANCO = 0
    LINBANCO = 0
Return

$LINEA_E9
#detalles
    NUMLIN+=1
    LINEA = "E9"
    LINEA += space$(32)
    LINEA += format$("N0:12",TOTTOT)
    LINEA += format$("N0:10",NUMLINDET)
    LINEA += format$("N0:10",NUMLINRES+NUMLINDET)
    LINEA += format$("N0:3",NUMBANCOS)
    LINEA += space$(89)
    LINEA += format$("N0:7",NUMLIN)

    Gosub ESCRIBE_LINEA
Return


$ESCRIBE_LINEA
    Wrseq LINEA Using [YFIC]
    LINEA=""
    LINTOT += 1
Return

$FINALIZAR
    Openo Using [YFIC]
    Call MESSAGE ("Proceso terminado") From GESECRAN

Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla X5H1) 05/01/2016 12:26:14 (TRECE)
######################################################################################
Subprog IB_CUENTABANCO
End


