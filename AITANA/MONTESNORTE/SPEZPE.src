Return
#

Funprog GET_TIPOFCY(PFCY)
Value Char PFCY
  If !clalev ([F:ZFCY]) : Local File FACILITY [ZFCY] : Endif
  Read [F:ZFCY]FCY0 = PFCY
  If !fstat Then
    End [F:ZFCY]YTIPOFCY
  Else
    End 0
  Endif

End

