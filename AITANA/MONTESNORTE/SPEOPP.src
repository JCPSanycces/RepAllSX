# Gestión de la máscara ZOPP1 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZOPP1) 08/11/2019 12:43:04 (ADMIN)
######################################################################################
$ACTION
##Infbox ACTION
Case ACTION
 When "APRES_MOD" : Gosub APRES_MOD

 When Default
Endcase
Return
#When "LIENS"     : Gosub LIENS

$APRES_MOD
  Local Integer I
  Trbegin [F:OPP]
  Readlock [F:OPP]OPP0=[M:OPP0]OPPNUM
  If !fstat Then
    [F:OPP]ZITMREF=[M:ZOPP1]ZITMREF
    [F:OPP]ZGRADO =[M:ZOPP1]ZGRADO
    #[F:OPP]ZIME   =[M:ZOPP1]ZIME
    [F:OPP]ZSTOFCY=[M:ZOPP1]ZSTOFCY
    [F:OPP]ZLOC   =[M:ZOPP1]ZLOC
    [F:OPP]ZPRECIO=[M:ZOPP1]ZPRECIO
    [F:OPP]ZPTE   =[M:ZOPP1]ZPTE
    [F:OPP]ZQTYSTU=[M:ZOPP1]ZQTYSTU
    [F:OPP]ZSTU   =[M:ZOPP1]ZSTU
    [F:OPP]ZSAU   =[M:ZOPP1]ZSAU
    [F:OPP]ZOPPAMT=[M:ZOPP1]ZOPPAMT
    For I=0 To 9
     [F:OPP]ZREFERENCIA(I)=[M:ZOPP1]ZREFERENCIA(I)
    Next
    Rewrite [F:OPP]
    Commit

  Else
    Rollback
  Endif

Return

LIENS
#  If !clalev ([F:ITM]) : Local File ITMMASTER [ITM] : Endif
#  Read [F:ITM]ITM0=[M:ZOPP1]ZITMREF
#  [M:ZOPP1]ZSTU=[F:ITM]STU
#  Affzo [M:ZOPP1]ZSTU
#  [M:ZOPP1]OPPAMT=[M:OPP1]OPPAMT
#  Affzo [M:ZOPP1]OPPAMT
#  Gosub LIENS From SUBOPPA
Return

Subprog AM_ZITMREF(VALEUR)
Variable Char    VALEUR()
  If !clalev ([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  Read [F:ITM]ITM0=VALEUR
  [M:ZOPP1]ZSTU=[F:ITM]STU
  Affzo [M:ZOPP1]ZSTU
End

######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZOPP1) 08/11/2019 12:49:02 (ADMIN)
######################################################################################
Subprog AM_ZQTYSTU(VALEUR)
Variable Decimal VALEUR
  If [M:ZOPP1]ZSAU=[M:ZOPP1]ZSTU Then
    [M:ZOPP1]ZOPPAMT=VALEUR*ZPRECIO
    Affzo [M:ZOPP1]ZOPPAMT
    [M:OPP1]OPPAMT=[M:ZOPP1]ZOPPAMT
    Affzo [M:OPP1]OPPAMT
  Endif
End

Subprog AM_ZPRECIO(VALEUR)
Variable Decimal VALEUR
  If [M:ZOPP1]ZSAU=[M:ZOPP1]ZSTU Then
    [M:ZOPP1]ZOPPAMT=ZQTYSTU*VALEUR
    Affzo [M:ZOPP1]ZOPPAMT
    [M:OPP1]OPPAMT=[M:ZOPP1]ZOPPAMT
    Affzo [M:OPP1]OPPAMT
  Endif
End


