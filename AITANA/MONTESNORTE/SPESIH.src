######################################################################################
Subprog CAMBIO_DLQ()
  If [M:SIH1]TRSFAM="SUM" and [M:SIH2]PTE <> "DLQ" Then
    #control: si hay productos de aceite (categoría PT01) y el cliente es socio de almazara, se cambia el modo de pago a DLQ
    Local Integer I, ENCONTRADO : ENCONTRADO=0
    If !clalev ([YPS])  : Local File YPERSEC[YPS] : Endif
    If !clalev ([ZITM]) : Local File ITMMASTER[ZITM] : Endif
    For I=1 To [M:SIH4]NBLIG
      Read [ZITM]ITM0=[M:SIH4]ITMREF(I-1)
      If !fstat Then
         If [ZITM]TCLCOD='PT01' Then
           ENCONTRADO+=1
           Break
         Endif
      Endif
    Next
    If ENCONTRADO Then
      Filter [YPS] Where [YPS]CODIPERSON=[M:SIH0]BPCINV and [YPS]TIPOFCY=3 and [YPS]ACTIVO=2 and [YPS]FECHAINI<=date$
&      and ([YPS]FECHAFIN>=date$ or [YPS]FECHAFIN<gdat$(1,1,2000)) and [YPS]TIPOREL=1
      Read [YPS] First
      If !fstat Then
        I=2
        Call OUINON("El cliente es socio de almzara. Cambiar modo de pago a DLQ?", I ) From GESECRAN
        If I=2 Then
          [M:SIH2]PTE="DLQ"
          Affzo [M:SIH2]PTE
          Call AM_PTE([M:SIH2]PTE) From SUBSIH
        Endif
      Endif
      Filter [YPS]
    Endif
  Endif
End



