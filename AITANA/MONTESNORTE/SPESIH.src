######################################################################################
## Etiqueta añadida por el supervisor (pantalla SIH2) 29/06/2020 14:51:32 (ADMIN)
######################################################################################
#CBG 01072020
#En este evento de campo tras modificar o introducir la forma de pago, se comprueba si es GSD
#Si es así se buscan las cuentas BID del tercero para que si hay alguna con PAB2 con O
#Caso de ser así se cambia el Tercero Pagador de la Factura a 01O
Subprog AM_PTE(VALEUR)
Variable Char    VALEUR()
#Infbox "After Modify"
Local Char TERCERO  : TERCERO = ""
Local Char TERCEROPAGADOR : TERCEROPAGADOR = "01O"
Local Char SPAB2 : SPAB2 = "O"
Local Char FACTURA : FACTURA = ""
Local Char FPAGO : FPAGO = "GSD"
Local Char TRANSACCION : TRANSACCION = "ALL"
Local Integer I : I = 0
Local Integer TIENEO : TIENEO = 0


#Infbox "La forma de pago de la factura es " + VALEUR  + " Y EL TERCERO " + [M:SIH0]BPCINV
    #If [M:SIH2]PTE = FPAGO Then
    If VALEUR = FPAGO Then
      TERCERO = [M:SIH0]BPCINV
      #Infbox "Vamos a buscar la cuenta O del tercero " + [M:SIH0]BPCINV
      # Ahora buscamos las cuentas del tercero buscando una O (si es que tiene) - Si no tiene no hacemos hada
      If clalev([BID])  = 0   Local File BID  [BID] : Endif
      Filter [BID] Where BPANUM = TERCERO #and PAB2 = SPAB2
      Read [BID] First
      If !fstat Then
       TIENEO = 0
       For[BID]BID0
        I = 0
        #Infbox "SI QUE tiene cuenta y es " + [BID]BIDNUM
        I = instr(0,[BID]PAB2,"O")
        Infbox "I es " + num$(I)
        If I <> 0 Then
         If left$([BID]BIDNUM, 4) = "0001"
           #Infbox "tiene cuenta con O "
           TIENEO = 1
         Endif
        Endif
       Next
       If TIENEO <> 0
        #Infbox "El cliente tiene una cuenta con O"
        [M:SIH1]BPRPAY = TERCEROPAGADOR
        Affzo [M:SIH1]BPRPAY
       Endif
      Else
        #Infbox "No tiene cuenta con O "
      Endif
      Close File [BID]
    Else
      #Infbox "La factura no tiene la forma de pago requerida"
    Endif
End





