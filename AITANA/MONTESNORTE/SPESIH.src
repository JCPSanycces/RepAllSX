Subprog AM_BPCINV(VALEUR)
Variable Char    VALEUR()
  If [M:SIH1]TRSFAM="SUM" Then
      [M:SIH1]PRITYP = 2    # MAB.24012020.NEW
     Affzo [M:SIH1]PRITYP  # MAB.24012020.NEW
  Endif
#    [M:SIH1]ZCARFIT =    [F:BPC]ZCARFIT
#    [M:SIH1]ZCARFITDAT = [F:BPC]ZCARFITDAT
#    [M:SIH1]ZAPLICFIT  = [F:BPC]ZAPLICFIT
#    [M:SIH1]ZDNIFIT    = [F:BPC]ZDNIFIT
