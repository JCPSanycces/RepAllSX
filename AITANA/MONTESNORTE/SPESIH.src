Subprog AM_ZDENSIDAD(VALEUR)
Variable Decimal VALEUR
Local Char LTIPOPRODUCTO
  If VALEUR <> 0 Then
    LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:SIH4]ITMREF(nolign-1))
    If LTIPOPRODUCTO = '81' or LTIPOPRODUCTO = '80' Then
      [M:ZSIH4]ZCANT1(nolign-1) = func ZGESCALIF.U_DENSIDAD2CANT1([M:SIH4]QTY(nolign-1), VALEUR)
      Affzo [M:ZSIH4]ZCANT1(nolign-1)
      [M:SIH4]ZCANT1(nolign-1) = [M:ZSIH4]ZCANT1(nolign-1)
    Endif
    # AL MODIFICAR ZCANT1, TAMBIEN MODIFICO LA ZCANT2
    If LTIPOPRODUCTO = "80" or LTIPOPRODUCTO = "81" Then # VINO Y MOSTO
      [M:ZSIH4]ZCANT2(nolign-1) = func ZGESCALIF.U_CANTIDAD12CANTIDAD2([M:ZSIH4]ZCANT1(nolign-1), [M:ZSIH4]ZGRADO)
      Affzo [M:ZSIH4]ZCANT2(nolign-1)
      [M:SIH4]ZCANT2(nolign-1) = [M:ZSIH4]ZCANT2(nolign-1)
      Affzo [M:SIH4]ZCANT2(nolign-1)
    Endif
  Endif
  [M:SIH4]ZDENSIDAD(nolign-1) = VALEUR
  Affzo [M:SIH4]ZDENSIDAD(nolign-1)
 [M:SIH4]UPDFLG(nolign-1) = 1
End
######################################################################################
Subprog AM_ZGLUCONICO(VALEUR)
Variable Decimal VALEUR
Local Decimal LPUNTOS
Local Char LRES
Local Char LTIPOUVA
 # If VALEUR <> 0 Then
    If func ZLIBMONTES.GET_TIPOITEM([M:SIH4]ITMREF(nolign-1)) = "90" Then  # If GFLAG = "BOD" Then # Transacción de BODEGA
      LRES = func ZGESCALIF.U_PUNTOS2CALIDAD([M:ZSIH4]ZPH(nolign-1),[M:ZSIH4]ZPOTASIO(nolign-1),VALEUR, GFLAG, [M:ZSIH4]ZCALIDAD(nolign-1), LPUNTOS)
      If LRES <> '' Then
          [M:ZSIH4]ZCALIDAD(nolign-1) = LRES
          [M:ZSIH4]ZPUNTOS(nolign-1) = LPUNTOS
      Endif
      Affzo [M:ZSIH4]ZCALIDAD
      Affzo [M:ZSIH4]ZPUNTOS
      [M:SIH4]ZCALIDAD(nolign-1) = [M:ZSIH4]ZCALIDAD(nolign-1)
      [M:SIH4]ZPUNTOS(nolign-1) = [M:ZSIH4]ZPUNTOS(nolign-1)
      Affzo [M:SIH4]ZCALIDAD(nolign-1)
      Affzo [M:SIH4]ZPUNTOS(nolign-1)
    Endif
    If func ZLIBMONTES.GET_TIPOITEM([M:SIH4]ITMREF(nolign-1)) = "90" Then # If GFLAG = "BOD" Then
      # COMO SABEMOS SI ES UVA BLANCA O TINTA ?????
      LTIPOUVA = func ZLIBMONTES.GET_TIPOUVA([M:SIH4]ITMREF(nolign-1))
      [M:ZSIH4]ZGRADO(nolign-1) = func ZGESCALIF.U_GLUCONICO2GRADO([M:ZSIH4]ZGLUCONICO(nolign-1) ,LTIPOUVA, GFLAG)
      Affzo [M:ZSIH4]ZGRADO
      [M:SIH4]ZGRADO(nolign-1) = [M:ZSIH4]ZGRADO(nolign-1)
      Affzo [M:SIH4]ZGRADO(nolign-1)
    Endif
 #f Endif
  [M:SIH4]ZGLUCONICO(nolign-1) = VALEUR
  Affzo [M:SIH4]ZGLUCONICO(nolign-1)
   [M:SIH4]UPDFLG(nolign-1) = 1
End
######################################################################################
Subprog AM_ZGRADO(VALEUR)
Variable Decimal VALEUR
Local Char LTIPOPRODUCTO

  LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:SIH4]ITMREF(nolign-1))
  If VALEUR <> 0 Then
    If LTIPOPRODUCTO = "90" Then # "BOD"
      Call B_UVA_GRADO2CANTIDAD1(VALEUR,[M:SIH4]QTY(nolign-1),[M:ZSIH4]ZCANT1(nolign-1)) From ZGESCALIF
      Affzo [M:ZSIH4]ZCANT1(nolign-1)
      [M:SIH4]ZCANT1(nolign-1) = [M:ZSIH4]ZCANT1(nolign-1)
      Affzo [M:SIH4]ZCANT1(nolign-1)
    Endif
    If LTIPOPRODUCTO = "81"  Then # MOSTO
      [M:ZSIH4]ZDENSIDAD(nolign-1) = func ZGESCALIF.U_GRADO2DENSIDAD(VALEUR)
      Affzo [M:ZSIH4]ZDENSIDAD
      [M:SIH4]ZDENSIDAD(nolign-1) = [M:ZSIH4]ZDENSIDAD(nolign-1)
      Affzo [M:SIH4]ZDENSIDAD(nolign-1)
      [M:ZSIH4]ZCANT1(nolign-1) = func ZGESCALIF.U_DENSIDAD2CANT1([M:SIH1]QTY(nolign-1), [M:ZSIH4]ZDENSIDAD(nolign-1))
      Affzo [M:ZSIH4]ZCANT1(nolign-1)
      [M:SIH4]ZCANT1(nolign-1) = [M:ZSIH4]ZCANT1(nolign-1)
    Endif
    # AL MODIFICAR ZCANT1, TAMBIEN MODIFICO LA ZCANT2
    If LTIPOPRODUCTO = "80" or LTIPOPRODUCTO = "81" Then # VINO Y MOSTO
      [M:ZSIH4]ZCANT2(nolign-1) = func ZGESCALIF.U_CANTIDAD12CANTIDAD2([M:ZSIH4]ZCANT1(nolign-1), VALEUR)
      Affzo [M:ZSIH4]ZCANT2(nolign-1)
      [M:SIH4]ZCANT2(nolign-1) = [M:ZSIH4]ZCANT2(nolign-1)
      Affzo [M:SIH4]ZCANT2(nolign-1)
    Endif
  Endif
  [M:SIH4]ZGRADO(nolign-1) = VALEUR
  Affzo [M:SIH4]ZGRADO(nolign-1)
  [M:SIH4]UPDFLG(nolign-1) = 1
End
