######################################################################################
Subprog AS_ZNBLIG
  If nolign-1>[M:SIH4]NBLIG Then
    mkstat=2
  Endif
End

######################################################################################

Subprog C_ZCARFIT(VALEUR)
Variable Char    VALEUR()
##control de carné fitosanitario (familia estadística 05 )
  Local Integer NOL
  For NOL=0 To [M:SIH4]NBLIG-1
    If [M:SIH4]TSICOD1(NOL) = "05" Then
      If VALEUR="" Then
   #   Call MESSAGE ("Atención, hay productos fitosanitarios y se requiere informar el carné") From GESECRAN
        GMESSAGE ="Atención, hay productos fitosanitarios y se requiere informar el carné"
        GERR=1
        OK=0
        Break
      Endif
    Endif
  Next
End

Subprog OBTENER_ZCARFIT()
  Local Integer NOL
  If [M:SIH1]ZCARFIT = "" Then

  For NOL=0 To [M:SIH4]NBLIG-1
    If [M:SIH4]TSICOD1(NOL) = "05" Then

      If !clalev([F:ZBPC]) : Local File BPCUSTOMER [ZBPC] : Endif
      Read [F:ZBPC]BPC0 = [M:SIH0]BPCINV

      [M:SIH1]ZCARFIT    = [F:ZBPC]ZCARFIT
      [M:SIH1]ZCARFITDAT = [F:ZBPC]ZCARFITDAT
      [M:SIH1]ZAPLICFIT  = [F:ZBPC]ZAPLICFIT
      [M:SIH1]ZDNIFIT    = [F:ZBPC]ZDNIFIT
      Affzo [M:SIH1]ZCARFIT
      Affzo [M:SIH1]ZCARFITDAT
      Affzo [M:SIH1]ZAPLICFIT
      Affzo [M:SIH1]ZDNIFIT

      Break
   Endif
  Next
  Endif
End

