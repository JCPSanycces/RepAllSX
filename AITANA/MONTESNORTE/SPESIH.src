#<AdxTL>@(#)0.0.0.0 $Revision$ Facturas
# Gestión de la máscara SIH0 (Especifico)
######################################################################################
## Etiqueta añadida por el supervisor (pantalla SIH0) 08/05/2019 17:29:56 (ADMIN)
######################################################################################
#XVT170220 - Los abonons de suministro no tienen una transacción por planta
#por tanto no deben hacer la comprobación del cliente ticket por defecto
#XVT170220.1 - Cuando se modifica el precio bruto por código ha de ejecutarse el AM_GROPRI para
#el recálculo del NETO y la valorización de la factura
#XVT030320 - Para gestionar el granel de campañas anteriores, se debe poder ver
#el lote de la entrega en la línea de la factura
#XVT 230320 - AÑADIR PANTALLA CAMBIO
#xvt010420 - Para que los abonos de tiendas puedan tener automáticamente la planta de venta
#se usará, en lugar de GFLAG para asignar la planta de stock, el TRSCOD
#XVT060420 - Si se vende un producto aceite (PT01) a un socio de almazara, cambiar
#el modo de pago a DLQ
$ACTION
Case ACTION
  When "OUVRE"    : Gosub OUVRE
  When "LIENS"    : Gosub LIENS
  When "AFFMASK" : Gosub AFFMASK
  When "VERIF_CRE" : Gosub VERIF_CRE
  When "VERIF_MOD" : Gosub VERIF_MOD
  When "FILTRE"   : Gosub FILTRE
  When "SETBOUT"  : Gosub SETBOUT
  When Default
Endcase
Return
###################################################################################
$OUVRE
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([F:ZLT]) : Local File SALTRS  [ZLT] : Endif
Return

#XVT230320.bn
$SETBOUT
  LLAMARCAMBIO=1  #xvt230320.n
  If [F:SLT]TRSFAM <> "SUM" Then
     Call VIREBOUT (CHAINE,"q") From GOBJET
  Else
    If [M:SIH1]INVSTA<>1 or GREP="C" or [M:SIH2]PTE<>"CON" Then
       Call VIREBOUT (CHAINE,"q") From GOBJET
    Endif
  Endif
Return
#XVT230320.en

$LIENS
  Gosub LIENS_ZSIH4
  Gosub TITCOL_ZSIH4
Return

FILTRE
  Read [F:ZLT]SLT0=5;GFLAG
  If !fstat Then
    If [F:ZLT]TRSFAM='SUM' Then
       CRITERE =" [F:SIV]STOFCY = [F:ZLT]TRSCOD"
    Endif
  Endif
Return

###################################################################################
$LIENS_ZSIH4
  If !clalev([ZSID]) : Local File SINVOICED[ZSID] : Endif
  Raz nolign
  nolign=0
  Filter [ZSID] Where NUM=[M:SIH0]NUM
  For [ZSID]
      nolign+=1
      [M:ZSIH4] = [F:ZSID]
  Next
  [M:ZSIH4]ZNBLIG = nolign
  nolign=0
  Affzo [M:ZSIH4]
Return
###################################################################################
$TITCOL_ZSIH4
  Call OCULTA_CAMPOS("SIH") From ZSPEMASKL
  Affzo [M:ZSIH4]

Return
######################################################################################
$AFFMASK
  #ocultar calificaciones que no aplican por transacción
 If GFLAG="ALL" : Return : Endif
 Call OCULTA_CAMPOS("SIH") From ZSPEMASKL
 Affzo [M:SIH4]
Return
######################################################################################

$VERIF_CRE
  Call OBTENER_ZCARFIT ()
  Call C_ZCARFIT ([M:SIH1]ZCARFIT)
  Call CAMBIO_DLQ () #XVT060420.n
Return

$VERIF_MOD
  Call OBTENER_ZCARFIT ()
  Call C_ZCARFIT ([M:SIH1]ZCARFIT)
  Call CAMBIO_DLQ () #XVT060420.n
Return



Subprog C_INVDAT(VALEUR)
Variable Date    VALEUR
  #EN LAS FACTURAS SIN CAMPAÑA SE INICIALIZARÁ EL CAMPO ZEJERCICIO
  #AL AÑO NATURAL
  #PENDIENTE APLICARLO A ABONOS
  #If [M:SIH0]SIVTYP<>"FACMN" : End : Endif

  Local Integer VEJERCICIO : VEJERCICIO=0
  Call GET_EJERCICIO("",[F:FCY]YTIPOFCY,VALEUR,VEJERCICIO) From ZLIBMONTES

#  If VEJERCICIO=0 Then
#  ESTE CÓDIGO NO APLICA YA QUE, SI NO ENCUENTRA UNA CAMPAÑA, DEVUELVE EL AÑO NATURAL DE LA
#  FECHA DE DOCUMENTO
#    Call GMESSAGE("Campaña no encontrada") From GESECRAN
#    mkstat=2
#  Else
    [M:SIH0]ZEJERCICIO=VEJERCICIO
    Affzo [M:SIH0]ZEJERCICIO
#  Endif

End
