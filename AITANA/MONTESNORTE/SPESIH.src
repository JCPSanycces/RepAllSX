######################################################################################
Subprog AM_ZCANT1(VALEUR)
Variable Decimal VALEUR
Local Char LTIPOPRODUCTO
  LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:SIH4]ITMREF(nolign-1))
  If VALEUR <> 0 Then
    If LTIPOPRODUCTO = "50" Then # If GFLAG = "FRU" Then # Transacción de FRUTOS CON CASCARA
      [M:ZSIH4]ZCANT2(nolign-1) =  func ZGESCALIF.FC_HUMEDAD2CANTIDAD2([M:ZSIH4]ZHUMEDAD(nolign-1), GFLAG, [M:ZSIH4]QTY(nolign-1) , VALEUR)
      Affzo [M:ZSIH4]ZCANT2
      [M:SIH4]ZCANT2(nolign-1) = [M:ZSIH4]ZCANT2(nolign-1)
      Affzo [M:SIH4]ZCANT2(nolign-1)
    Endif
    If LTIPOPRODUCTO = "81" Then
      [M:ZSIH4]ZCANT2(nolign-1) = func ZGESCALIF.U_CANTIDAD12CANTIDAD2(VALEUR, [M:ZSIH4]ZGRADO(nolign-1))
      Affzo [M:ZSIH4]ZCANT2
      [M:SIH4]ZCANT2(nolign-1) = [M:SIH4]ZCANT2(nolign-1)
      Affzo [M:SIH4]ZCANT2(nolign-1)
    Endif
  Endif

  [M:SIH4]ZCANT1(nolign-1) = VALEUR
  Affzo [M:SIH4]ZCANT1(nolign-1)
   [M:SIH4]UPDFLG(nolign-1) = 1
End
######################################################################################
Subprog AM_ZCANT2(VALEUR)
Variable Decimal VALEUR
 [M:SIH4]ZCANT2(nolign-1) = VALEUR
 Affzo [M:SIH4]ZCANT2(nolign-1)
 [M:SIH4]UPDFLG(nolign-1) = 1
End
