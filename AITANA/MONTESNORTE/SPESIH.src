######################################################################################
## Etiqueta añadida por el supervisor (pantalla SIH4) 14/05/2019 13:17:19 (ADMIN)
######################################################################################
Subprog AM_ZCALIDAD(VALEUR)
    Variable Char    VALEUR()
    Local Integer ESTAT

    If (VALEUR<>"")
        Call MODIF_CALIDAD(VALEUR, [M:SIH4]TSICOD1(nolign-1), [M:SIH4]TSICOD2(nolign-1),
&            [M:SIH4]TSICOD3(nolign-1), 2, ESTAT) From YSELAGRO
        If ESTAT=0 Then
            GERR=1
            # GMESSAGE=mess(12,1986,1)
            Infbox "Calidad no contemplada para el artículo seleccionado"
            mkstat=2
            EXISTE=1
        Endif
    Endif
    [M:SIH4]ZCALIDAD(nolign-1) = VALEUR
    Affzo [M:SIH4]ZCALIDAD(nolign-1)
    [M:SIH4]UPDFLG(nolign-1) = 1
End


