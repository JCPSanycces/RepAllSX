#**
#* Antes de entrada
#*
#* @param VALEUR
#*!
Subprog AS_BPCINV(VALEUR)
Variable Char    VALEUR()
 #XVT010420.o If [M:SIH0]INVTYP =1 or [M:SIH0]INVTYP = 3 Then    #XVT170220.n

    If [M:SIH1]TRSFAM ="SUM" Then
      If VALEUR = "" Then # SI ES LA PRIMERA VEZ QUE ENTRO, TENGO LA VARIABLE VALUER A NULO.
#xvt010420.o        Filter [F:ADI] Where NUMTAB=6050 and [ADI]A1=GFLAG
#        If GUSER="ADMIN" : Infbox "SPESIH AS_BPCINV " + GFLAG + " TRSCOD=" + [M:SIH0]TRSCOD + "." : Endif
        Filter [F:ADI] Where NUMTAB=6050 and [ADI]A1=[M:SIH0]TRSCOD  #xvt010420.n
        Read [F:ADI] First
        If !fstat Then
          VALEUR=[F:ADI]A2
          Call AM_BPCINV(VALEUR) From SUBSIH
          Call AM_BPCINV(VALEUR) From SPESIH #
          [M:SIH1]BPRPAY=VALEUR
          Affzo [M:SIH1]BPRPAY
          [M:SIH1]BPCGRU=VALEUR
          Affzo [M:SIH1]BPCGRU
        Else
#xvt010420.o          Call MESSAGE ("Cliente no definido para la planta " + GFLAG ) From GESECRAN
          Call MESSAGE ("Cliente no definido para la planta " + [M:SIH0]TRSCOD) From GESECRAN  #xvt010420.n
        Endif
        Filter [F:ADI]
      Endif
    Endif

#XVT010420.o  Endif #XVT170220.n

End

