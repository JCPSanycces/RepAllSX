# Gestión de la máscara ZSOH4 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZSOH4) 17/12/2019 13:05:20 (ADMIN)
######################################################################################
$ACTION
Case ACTION
      When "LIENS"    : Gosub LIENS
      When Default
Endcase
Return
######################################################################################
$LIENS
 # Infbox "LIENS"
  Gosub LIENS_ZSOH4
Return
######################################################################################
###################################################################################
$LIENS_ZSOH4
  Local Char LBPTNAM
  If !clalev([ZSOHP]) : Local File SORDERP[ZSOHP] : Endif
  Raz nolign
  nolign=0
  Filter [ZSOHP] Where SOHNUM=[M:SOH0]SOHNUM
  For [ZSOHP]
      nolign+=1
      [M:ZSOH4] = [F:ZSOHP]
  Next
  [M:ZSOH4]ZNBLIG = nolign
  nolign=0
  Affzo [M:ZSOH4]
Return
###################################################################################
Subprog AM_ZGRADO(VALEUR)
Variable Decimal VALEUR
Local Char LTIPOPRODUCTO

  LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:SOH4]ITMREF(nolign-1))
  If VALEUR <> 0 Then
#    If LTIPOPRODUCTO = "90" Then # "BOD"
#      Call B_UVA_GRADO2CANTIDAD1(VALEUR,[M:SDH1]QTYSTU(nolign-1),[M:ZSDH2]ZCANT1(nolign-1)) From ZGESCALIF
#      Affzo [M:ZSDH2]ZCANT1(nolign-1)
#      [M:SDH1]ZCANT1(nolign-1) = [M:ZSDH2]ZCANT1(nolign-1)
#      Affzo [M:SDH1]ZCANT1(nolign-1)
#    Endif
    If LTIPOPRODUCTO = "81"  Then # MOSTO
      [M:ZSOH4]ZDENSIDAD(nolign-1) = func ZGESCALIF.U_GRADO2DENSIDAD(VALEUR)
      Affzo [M:ZSOH4]ZDENSIDAD
      [M:SOH4]ZDENSIDAD(nolign-1) = [M:ZSOH4]ZDENSIDAD(nolign-1)
      Affzo [M:SOH4]ZDENSIDAD(nolign-1)
    Endif
#    # AL MODIFICAR ZCANT1, TAMBIEN MODIFICO LA ZCANT2
#    If LTIPOPRODUCTO = "80" or LTIPOPRODUCTO = "81" Then # VINO Y MOSTO
#      [M:ZSDH2]ZCANT2(nolign-1) = func ZGESCALIF.U_CANTIDAD12CANTIDAD2([M:ZSDH2]ZCANT1(nolign-1), VALEUR)
#      Affzo [M:ZSDH2]ZCANT2(nolign-1)
#      [M:SDH1]ZCANT2(nolign-1) = [M:ZSDH2]ZCANT2(nolign-1)
#      Affzo [M:SDH1]ZCANT2(nolign-1)
#    Endif
  Endif
  [M:SOH4]ZGRADO(nolign-1) = VALEUR
  Affzo [M:SOH4]ZGRADO(nolign-1)
   [M:SOH4]UPDFLG(nolign-1) = 1
End

Subprog AM_ZDENSIDAD(VALEUR)
Variable Decimal VALEUR

  [M:SOH4]ZDENSIDAD(nolign-1) = VALEUR
  Affzo [M:SOH4]ZDENSIDAD(nolign-1)
 [M:SOH4]UPDFLG(nolign-1) = 1
End


