#<AdxTL>@(#)0.0.0.0 $Revision$ 
# CONTADORES CON CAMPAĆ‘A POR TIPO DE PLANTA
# ENTREGAS     --    SDH  - IMPORTANTE QUE SE VEA LA PLANTA ENTERA - PLANTA 5 CAMPAĆ‘A 2
# ENTREGAS IS  --    SDI  - IMPORTANTE QUE SE VEA LA PLANTA ENTERA - PLANTA 5 CAMPAĆ‘A 2
# RECEPCIONES  --    PTHG  - IMPORTANTE QUE SE VEA LA PLANTA ENTERA - PLANTA 5 CAMPAĆ‘A 2
# RECEPCIONES IS --  PTI  - IMPORTANTE QUE SE VEA LA PLANTA ENTERA - PLANTA 5 CAMPAĆ‘A 2
# RECIBOS AGRARIOS - FLQ  - COMPLEMENTO 5 - PLANTA 3 CAMPAĆ‘A 2
# RECIBOS AGRARIOS - ELQ  - COMPLEMENTO 5 - PLANTA 3 CAMPAĆ‘A 2
# RECIBOS AGRARIOS - ALQ  - COMPLEMENTO 5 - PLANTA 3 CAMPAĆ‘A 2
# PRECIOS DE LIQUIDACION - ZPRLI - COMPLEMENTO 7 - PLANTA 5 CAMPAĆ‘A 2

#EN EL RESTO DE DOCUMENTOS EL AĆ‘O VIENE DEL EJERCICIO FISCAL.
# PRESUPUESTOS VT
# PEDIDOS CP
# PEDIDOS VT
# FACTURAS DE COMPRA   - ZSPFA
# FACTURAS VENTA       - SPFAG
# PAGOS
# COBROS
# REMESAS
# ASIENTOS

$ACTION
#If GUSER = "ADMIN" : Infbox "ZSUBANM - ADMIN " + ACTION + " CONTADOR: " + COMPTEUR :  Endif
  Case ACTION
    When "NUMERO" : Gosub NUMERO
    When "NUMEROCHG" : Gosub NUMEROCHG
  Endcase
Return

$NUMERO
  #BUSQUEDA CONTADORES CON CAMPAĆ‘A
  Local Integer LCAMPANYA

  Case COMPTEUR
    When 'FLQ'   Then Gosub ZFLQ
    When 'ELQ'   Then Gosub ZFLQ
    When 'ALQ'   Then Gosub ZFLQ
    When 'ZPRLI' Then Gosub ZPRLI
    When 'PTHG'   Then Gosub PTHG
    When 'PTI'   Then Gosub PTHG
    When 'ZPES'  Then Gosub ZPES
    When 'SDH'   Then Gosub SDH
    When 'SDI'   Then Gosub SDH
  Endcase

#When 'SPFAG' Then Gosub SPFAG No es por campaĆ±a, es por ejercicio
#When 'ZSPFA' Then Gosub ZSPFA No es por campaĆ±a, es por ejercicio
Return

$NUMEROCHG
  #CORRECCIĆ“N CONTADORES CON EJERCICIO

  Local Integer ZI
  Local Integer ZEJERPOS
  Local Integer ZENCONTRADO : ZENCONTRADO=0

  If !clalev([ZANM]) : Local File ACODNUM[ZANM]:Endif
  Read [ZANM]ANM0=COMPTEUR
  ZEJERPOS=0
  For ZI=0 To 9

    If [ZANM]POSTYP(ZI)=10 Then
     ZENCONTRADO=1
     Break
    Else
     ZEJERPOS+=[ZANM]POSLNG(ZI)
    Endif

  Next

  If ZENCONTRADO Then
    ZEJERPOS+=1
    Gosub CONEJERCICIO
  Else
    Return
  Endif
Return

$ZSPFA
 # Contador Facturas de Compra
    Call GET_EJERCICIO("", [F:FCY]YTIPOFCY, [M:PIH0]ACCDAT, LCAMPANYA) From ZLIBMONTES
    If LCAMPANYA <> 0 Then
   #    COMP = left$([F:PIH]FCY,5) + right$(num$(LCAMPANYA),3)
       COMP = right$(num$(LCAMPANYA),3)
    Else
       STAT = 1 # error
    Endif
Return

$ZFLQ
# CONTADOR CON CAMPAĆ‘A FLQ, ELQ, ALQ
    COMP =  left$([F:PIH]FCY,3) +  right$(num$([M:PIH0]ZEJERCICIO),3)
#   COMP =  left$([F:PIH]FCY,3) +  right$(num$([M:PIH0]ZEJERCICIO),3)
#   COMP =  right$(num$([M:PIH0]ZEJERCICIO),3)
Return

$ZPRLI
 # Contador Precios Liquidaciones - Con campaĆ±a
 If !clalev([M:YT00]) : STAT=1 : Endif
 COMP = left$([M:YT00]FCY,5) + right$(num$([M:YT00]EJERCICIO),3)
 #COMP = right$(num$([M:YT00]EJERCICIO),3)
Return

$PTHG
    # Contador Recepciones de compra - PTHG PLANTA 5 DĆ¨GITOS, CAMPAĆ‘A 2
    #Call GET_EJERCICIO([M:PTH0]PRHFCY, 0 , [M:PTH0]RCPDAT, LCAMPANYA) From ZLIBMONTES
    LCAMPANYA = [M:PTH0]ZEJERCICIO
    If LCAMPANYA=0 Then
      STAT = 1
      Return
    Endif
    If LCAMPANYA <> 0 Then
       COMP = left$([M:PTH0]PRHFCY,5) + right$(num$(LCAMPANYA),3)
       #COMP = right$(num$(LCAMPANYA),3)
    Else
       STAT = 1 # error
    Endif
Return

$ZPES
  # Contador PESADAS de compra
    #Call GET_EJERCICIO([M:PTH0]PRHFCY, 0 , [M:PTH0]RCPDAT, LCAMPANYA) From ZLIBMONTES

    LCAMPANYA = [M:ZPE0]EJERCICIO
    If LCAMPANYA=0 Then
      STAT = 1
      Return
    Endif
    If LCAMPANYA <> 0 Then
       COMP = left$([M:ZPE0]FCY,5) + right$(num$(LCAMPANYA),3)
    Else
       STAT = 1 # error
    Endif
Return

$SDH
    # Contador Entregas de venta - CON CAMPAĆ‘A - PLANTA 5 DIGITOS Y CAMPAĆ‘A 2
    #Call GET_EJERCICIO([M:PTH0]PRHFCY, 0 , [M:PTH0]RCPDAT, LCAMPANYA) From ZLIBMONTES

    LCAMPANYA = [M:SDH0]ZEJERCICIO
    If LCAMPANYA=0 Then
      STAT = 1
      Return
    Endif
    If LCAMPANYA <> 0 Then
       COMP = left$([M:SDH0]STOFCY,5) + right$(num$(LCAMPANYA),3)
       #COMP = right$(num$(LCAMPANYA),3)
    Else
       STAT = 1 # error
    Endif
Return


$SPFAG
  # Contador Facturas de venta (de GMN, manteniendo SPFAC para MNE)

    # Call GET_EJERCICIO([M:SIH0]SALFCY, 0 , [M:SIH0]INVDAT, LCAMPANYA) From ZLIBMONTES
    LCAMPANYA = [M:SIH0]ZEJERCICIO
    If LCAMPANYA=0 Then
      STAT = 1
      Return
    Endif
    If LCAMPANYA <> 0 Then
       #COMP = left$([M:SIH0]SALFCY,5) + right$(num$(LCAMPANYA),3)
       COMP = right$(num$(LCAMPANYA),3)
    Else
       STAT = 1 # error
    Endif
Return


$CONEJERCICIO
  Local Integer VEJERCICIO
  VEJERCICIO=val(mid$(VALEUR, ZEJERPOS, 2))
  VEJERCICIO+=17
  VALEUR = mid$(VALEUR,1,ZEJERPOS-1) + num$(VEJERCICIO) + right$(VALEUR,ZEJERPOS+2)
Return

