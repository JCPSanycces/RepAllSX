#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
 When "SEL_TABLE"     : Gosub SEL_TABLE
 When Default
Endcase
Return

#########################################################################
#    CHOIX DANS LES TABLES                                              #
#########################################################################
$SEL_TABLE
Case TABLE
    When "SELZCALIDA"    : Gosub S_ZCALI
Endcase
Return

$S_ZCALI
#SELECCIÓN CALIDAD ESTADÍSTICA SEGÚN LA FAMILIA DEL ARTÍCULO DE LÍNEA

  ##TABLAS QUE PARTICIPARÁN EN LA SELECCIÓN
  If clalev([F:YCS])=0 : Local File YCALSTAD[YCS] : Endif
  If clalev([F:YCA])=0 : Local File YCALIDAD[YCA]  : Endif
  ##PARA QUE LA SELECCIÓN FUNCIONE DESDE CUALQUIER PANTALLA, POR PARÁMETRO SE
  ##DEBERÁ PASAR EL CÓDIGO A FILTRAR
  Local Char ZCODI1 : ZCODI1=PARAM(1)

  #SI HAY QUE ENLAZAR LAS TABLAS, EL LINK SE HARÁ INDICANDO PRIMERO LA
  #TABLA SOBRE LA CUAL SE DESEA MOSTRAR LAS COLUMNAS, SIENDO EL RESTO DE TABLAS
  #LAS QUE SIRVEN COMO CRITERIO SOBRE LA PRIMERA
  Link [YCA] With [YCS]YCS3=CODCALIDAD As [ZSEL]
  Default File [ZSEL]

  ORDRE = "CODCALIDAD"  #SE INDICA QUÉ COLUMNA VA A SERVIR DE ORDENACIÓN
  START = "CODCALIDAD" #SE INDICA QUÉ COLUMNA SE DEVUELVE EN LA SELECCIÓN
  SENS =1
  DEFPAG = 5
  SIZCOL = 100
  SIZLIG = 150

  #APLICACIÓN DE LOS CRITERIOS SOBRE EL DEFAULT FILE, EN ESTE CASO EL LINK
  If GFONCTION="GESPTH"
    # CRITERE='[F:YCS]CODI1=[M:PTH1]TSICOD1(nolign-1)'
    CRITERE='[F:YCS]CODI1=ZCODI1'
  Endif

  TIT(0) = "Selección Calidad"
  NBCOL = 0
  NBCOL +=1 : COL(NBCOL) = "CODCALIDAD" : TIT(NBCOL)="Calidad"
  NBCOL +=1 : COL(NBCOL) = "NOMCALIDA2" : TIT(NBCOL)="Descripción"


Return

