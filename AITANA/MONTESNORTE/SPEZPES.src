#<AdxTL>@(#)0.0.0.0 $Revision$ Pesadas de recepción
##TRASIEGOS - XVT2019/12/02 - Validación de trasiegos (camiones)
# PESACAMIONES - XVT090320 - Nueva función pesacamiones. Impedirá realizar cualquier acción
# si está marcada la pesada como "pesacamiones"
#FRUTOS CÁSCARA - SUPPORT-3571 - XVT19082020 - RECÁLCULOS SEGÚN INDICACIONES ELENA
#SUPPORT-3713 - XVT27082020 - LA CANTIDAD2 EN FC SE TIENE QUE IGUALAR A CANTIDAD1 SI NO HAY
# CORRECCIONES DE HUMEDAD
$ACTION
#If GUSER ="ADMIN" Then
#  If instr(1,ACTION,"VARIANTE")=0 Then Infbox "SPEZPES " + ACTION : Endif : Endif
  Case ACTION
        When "OUVRE"            : Gosub OUVRE
        When "FILTRE"           : Gosub FILTRE
        When "INICRE"           : Gosub INICRE
        When "INIMOD"           : Gosub INIMOD
        When "VERIF_CRE"        : Gosub VERIF_CRE
        When "SETBOUT"          : Gosub SETBOUT
        When "EXEBOUT"          : Gosub EXEBOUT
        When "LIENS"            : Gosub LIENS
        When "APRES_MOD"        : Gosub APRES_MOD   #XVT090320.N
        When "APRES_CRE"        : Gosub APRES_CRE   #XVT090320.N
        When Default
    Endcase
Return

$OUVRE
  If !clalev ([F:ZFCY]) : Local File FACILITY [ZFCY] : Endif

Return


$SETBOUT
  If [M:ZPE0]TIMP=2 or [M:ZPE0]PTHNUM<>"" Then
   Call VIREBOUT(CHAINE, "V" ) From GOBJET
   Call VIREBOUT(CHAINE, "A" ) From GOBJET
  Else
    CHMEN+="V"
    CHMEN+="A"
  Endif
  Diszo [M:ZPE0]PTHNUM

  #xvt090320.bn
  If [M:ZPE0]ZFLGPESACAM=2 Then
    Call VIREBOUT(CHAINE, "V" ) From GOBJET
  Endif
  #xvt090320.en
  #Raz GBOUT20

Return

$FILTRE

   # CRITERE = "[F:ZPE]TIMP <> 2" # and [F:ZPE]FECHA <= date$-1"
  If GFLAG <> "ALL" Then
    CRITERE =" [F:ZPE]FCY = GFLAG "
  Endif
Return

$VERIF_CRE
  Read [ZFCY]FCY0=GFLAG
  If !fstat Then
    [M:ZPE0]TIPOFCY=[ZFCY]YTIPOFCY
    [M:ZPE0]FCY=GFLAG
#    Infbox [M:ZPE0]FCY + ' ' + num$([M:ZPE0]TIPOFCY)
  Else
    Call MESSAGE("Tipo de planta no encontrado") From GESECRAN
    FIN=1
  Endif
  Local Integer CONTSTAT : CONTSTAT = 0
#  Infbox [M:ZPE0]NUMPES
  Call NUMERO("ZPES", [M:ZPE0]FCY, [M:ZPE0]FECHA, "", [M:ZPE0]NUMPES, CONTSTAT ) From SUBANM
  #Infbox [M:ZPE0]NUMPES
  If CONTSTAT Then
    Call MESSAGE("Error en la obtención del número de pesada") From GESECRAN
  Endif
  Affzo [M:ZPE0]NUMPES

  [M:ZPE1]PESADOR=GUSER
Return

$INICRE
  Gosub ACTUALIZA_ZCANT
Return

$INIMOD
  Gosub ACTUALIZA_ZCANT
Return


#XVT090320.BN
$APRES_MOD
  If !GSERVEUR Then
    Gosub RELIT From GOBJSUB
  Endif
Return

$APRES_CRE
  If !GSERVEUR Then
    Gosub RELIT From GOBJSUB
  Endif
Return
#XVT090320.EN

$EXEBOUT
  Case BOUT
  When "V" Then Gosub VALIDAR
  Endcase
Return


$LIENS
  If [M:ZPE0]PTHNUM <> '' Then
    Diszo [M:ZPE0]0-99
    Diszo [M:ZPE1]0-99
  Else
    Actzo [M:ZPE0]0-99
    Actzo [M:ZPE1]0-99
  Endif

  #xvt090320.bn
    If [M:ZPE0]ZFLGPESACAM=2 Then
      Diszo [M:ZPE0]1-99
      Diszo [M:ZPE1]1-99
      Actzo [M:ZPE0]ZFLGPESACAM
    Endif

  #xvt090320.en


Return

$VALIDAR
#
If !clalev([M:ZIP]) : Local Mask ZIMPPES [ZIP] : Endif
Default Mask [M:ZIP]

[M:ZIP]FCY=[M:ZPE0]FCY
[M:ZIP]FECHA=[M:ZPE0]FECHA
[M:ZIP]TIPOFCY=[M:ZPE0]TIPOFCY
[M:ZIP]NUMPES=[M:ZPE0]NUMPES
[M:ZIP]TRASIEGOS=[M:ZPE0]TRASIEGOS  #xvt2019/12/02.n

Gosub OPEN_FILE From SPEZIP
#Infbox "open file efectuado"
If [M:ZPE0]TRASIEGOS<>2 Then   #XVT2019/12/02.n
  Gosub EXEC_ZIMPPES From SPEZIP
Else                          #XVT2019/12/02.bn
  #Infbox "TRASIEGOS"
  #en el caso de los trasiegos:
  Gosub EXEC_ZENTREGARECEPCION From SPEZIP
Endif                         #XVT2019/12/02.en
#Infbox "exec_imppes efectuado"
Gosub TERMINE_ZIMPPES From SPEZIP
#Infbox "termine immpes efectuado"

Close Local Mask [M:ZIP]


Affzo [M:ZPE0]0-99
Affzo [M:ZPE0]PTHNUM

Default Mask [M:ZPE0]
Gosub RELIT From GOBJSUB

Return


$ACTUALIZA_ZCANT
            If [M:ZPE0]TIPOFCY=4 Then   ##sólo para Bodega se actualiza la cantidad 1 con el grado
              Call B_UVA_GRADO2CANTIDAD1([M:ZPE1]GRADO,[M:ZPE1]NETO,[F:ZPE]ZCANT1) From ZGESCALIF
            Elsif [F:ZPE]TIPOFCY=2
               [F:ZPE]ZCANT1 =  func ZGESCALIF.C_HUMEDAD2CANTIDAD1([M:ZPE1]ZHUMEDAD, "CER", [M:ZPE1]NETO)
            Elsif [F:ZPE]TIPOFCY=7
               [F:ZPE]ZCANT1 =  func ZGESCALIF.FC_RENDIMIENTO2CANTIDAD1([M:ZPE1]ZRENDIMIENTO, "FRU",  [M:ZPE1]NETO)
#XVT19082020.o               [F:ZPE]ZCANT2 =  func ZGESCALIF.FC_HUMEDAD2CANTIDAD2([M:ZPE1]ZHUMEDAD, "FRU", [M:ZPE1]NETO , [M:ZPE1]ZCANT1)
#XVT27082020.o [F:ZPE]ZCANT2 =  func ZGESCALIF.FC_HUMEDAD2CANTIDAD2([M:ZPE1]ZHUMEDAD, "FRU", [M:ZPE1]NETO , [M:ZPE1]ZCANT1 , [M:ZPE1]ZRENDIMIENTO) #XVT19082020.n
               [F:ZPE]ZCANT2 =  func ZGESCALIF.FC_HUMEDAD2CANTIDAD2([M:ZPE1]ZHUMEDAD, "FRU", [M:ZPE1]NETO , [F:ZPE]ZCANT1 , [M:ZPE1]ZRENDIMIENTO) #27082020.n
            Endif
            [M:ZPE1]ZCANT1=[F:ZPE]ZCANT1
            [M:ZPE1]ZCANT2=[F:ZPE]ZCANT2
            Affzo [M:ZPE1]ZCANT1
            Affzo [M:ZPE1]ZCANT2
Return



######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZPESADAS0) 07/09/2019 17:19:14 (ADMIN)
######################################################################################
Subprog AM_TARA(VALEUR)
Variable Decimal VALEUR
  If VALEUR >= [M:ZPE1]BRUTO Then
    Call MESSAGE("Atención: TARA mayor que BRUTO") From GESECRAN
    mkstat=2
  Elsif VALEUR = 0 Then
    [M:ZPE1]NETO = 0
    Affzo  [M:ZPE1]NETO
  #  Call AM_NETO([M:ZPE1]NETO)    #XVT19082020.n
  Else
    [M:ZPE1]NETO = [M:ZPE1]BRUTO - VALEUR
    Affzo  [M:ZPE1]NETO
  #  Call AM_NETO([M:ZPE1]NETO)    #XVT19082020.n
  Endif
End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZPESADAS1) 07/09/2019 19:22:41 (ADMIN)
######################################################################################
Subprog AM_VARIEDAD(VALEUR)
Variable Char    VALEUR()
  If !clalev([F:ZITF]):Local File ITMFACILIT[ZITF] : Endif
  If !clalev([F:ZITM]):Local File ITMMASTER[ZITM] : Endif

  Read [F:ZITM]ITM0=VALEUR
  If !fstat Then
    If [F:ZITM]LOTMGTCOD = 1 Then
      Diszo [M:ZPE1]LOTE
    Else
      Actzo  [M:ZPE1]LOTE
    Endif

  Else
    Call MESSAGE("Artículo no encontrado") From GESECRAN
    mkstat=2
    Return
  Endif


  Read [F:ZITF]ITF0=VALEUR;GFLAG
  If !fstat Then
    If [F:ZITF]LOCMGTCOD <> 2 Then
      Diszo [M:ZPE1]DEPOSITO
    Else
      Actzo  [M:ZPE1]DEPOSITO
    Endif
  Else
    Call MESSAGE("Artículo-planta no encontrado") From GESECRAN
    mkstat=2
  Endif
End


######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZPESADAS0) 09/09/2019 08:33:20 (ADMIN)
######################################################################################
Subprog AM_FECHA(VALEUR)
Variable Date    VALEUR
Local Integer VEJERCICIO : VEJERCICIO=0
 #If GUSER="ADMIN" Then Infbox("SPEZPES " + num$([M:ZPE0]TIPOFCY)) Endif
 If GREP="C" or GREP="D" and FLAG<>"ALL" Then
    Read [ZFCY]FCY0=GFLAG
    If !fstat Then
      [M:ZPE0]TIPOFCY=[ZFCY]YTIPOFCY
      [M:ZPE0]FCY=GFLAG
      Affzo [M:ZPE0]FCY
      Affzo [M:ZPE0]TIPOFCY
  #    Infbox [M:ZPE0]FCY + ' ' + num$([M:ZPE0]TIPOFCY)
    Else
      Call MESSAGE("Tipo de planta no encontrado") From GESECRAN
      FIN=1
    Endif
  Endif

  Call GET_EJERCICIO("",[M:ZPE0]TIPOFCY,VALEUR,VEJERCICIO) From ZLIBMONTES

  [M:ZPE0]EJERCICIO=VEJERCICIO
  Affzo [M:ZPE0]EJERCICIO
End

Subprog C_EJERCICIO(VALEUR)
Variable Decimal VALEUR
 Local Integer POK : POK=0
  If VALEUR<>0 Then
     Call CHECK_EJERCICIO("",[M:ZPE0]TIPOFCY,VALEUR,POK) From ZLIBMONTES
     If POK=0 Then
      Call MESSAGE ("Campaña no definida para este tipo de planta.") From GESECRAN
      VALEUR=0
     Endif
  Endif
End


######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZPESADAS0) 05/12/2019 16:47:57 (ADMIN)
######################################################################################
#XVT2019/12/02.bn
Subprog AM_PROV(VALEUR)
Variable Char    VALEUR()
  Read [F:ZFCY]FCY0=VALEUR
  If !fstat Then
     #si el proveedor es una planta: es un trasiego
     [M:ZPE0]TRASIEGOS=2
     Affzo [M:ZPE0]TRASIEGOS
     Diszo [M:ZPE0]CATASTRO
     Diszo [M:ZPE1]LOTE
  Else
     [M:ZPE0]TRASIEGOS=1
     Affzo [M:ZPE0]TRASIEGOS
     Actzo [M:ZPE0]CATASTRO
     Actzo [M:ZPE1]LOTE
  Endif
End
#XVT2019/12/02.en


######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZPESADAS1) 20/12/2019 15:02:51 (ADMIN)
######################################################################################
Subprog AM_ZAIN(VALEUR)
Variable Char    VALEUR()
  If !clalev ([AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev ([CNT]) : Local File CONTACT [CNT] : Endif

  Read [AIN]AIN0=VALEUR
  If !fstat Then
    [M]ZAINNAM=[AIN]CNTLNA + ' ' + [AIN]CNTFNA
    Affzo [M]ZAINNAM
  Endif
End


######################################################################################
#XVT090320.BN
######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZPESADAS0) 09/03/2020 16:57:51 (ADMIN)
######################################################################################
Subprog AM_ZFLGPESACAM(VALEUR)
Variable Integer VALEUR
  Local Integer VYN : VYN=1
  If VALEUR=2 Then
     Call OUINON("¿Desea marcar esta pesada como PESACAMIONES?."
&      + " No podrá realizar más acciones sobre la pesada", VYN) From GESECRAN
      If VYN=1 Then
        mkstat=2
      Else
           If [M:ZPE0]ZFLGPESACAM=2 Then
             Diszo [M:ZPE0]1-99
             Diszo [M:ZPE1]1-99
             Actzo [M:ZPE0]ZFLGPESACAM
           Endif
      Endif
  Endif
End

#XVT090320.EN
