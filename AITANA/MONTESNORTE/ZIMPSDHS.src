#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "AP_IMPORT" : Gosub AP_IMPORT
  Endcase
Return

$OUVRE
    Gosub OUVRE From IMPSDHS
Return

$RAZCRE
  Gosub RAZCRE From IMPSDHS
Return

$VALID
  Gosub VALID From IMPSDHS
Return

$SAIMSK
  Gosub SAIMSK From IMPSDHS
Return



$AP_IMPORT

  Case [L]IMPFIC
    When "SDD"


      If GIMP(64)<>'' Then
        [M:SDH1]ZCANT1(nolign-1) = val(GIMP(64))
      Endif

      If GIMP(63) <> '' Then
        [M:SDH1]ZCANT2(nolign-1) = val(GIMP(63))
      Endif

      If GIMP(62) <> '' Then
        [M:SDH1]ZCALIDAD(nolign-1) = GIMP(62)
      Endif

      If GIMP(61) <> '' Then
        [M:SDH1]ZRENDIMIENTO(nolign-1) = val(GIMP(61))
      Endif

      If GIMP(60) <> '' Then
        [M:SDH1]ZGRADO(nolign-1) = val(GIMP(60))
      Endif

      If GIMP(59) <> '' Then
        [M:SDH1]ZPH(nolign-1) = val(GIMP(59))
      Endif

      If GIMP(58) <> '' Then
        [M:SDH1]ZHUMEDAD(nolign-1) = val(GIMP(58))
      Endif

      If GIMP(57) <> '' Then
        [M:SDH1]ZPESOESPE(nolign-1) = val(GIMP(57))
      Endif

      If GIMP(56) <> '' Then
        [M:SDH1]ZGLUCONICO(nolign-1) = val(GIMP(56))
      Endif

      If GIMP(55) <> '' Then
        [M:SDH1]ZPOTASIO(nolign-1) = val(GIMP(55))
      Endif

      If GIMP(54) <> '' Then
        [M:SDH1]ZPUNTOS(nolign-1) = val(GIMP(54))
      Endif

      If GIMP(53) <> '' Then
        [M:SDH1]ZDENSIDAD(nolign-1) = val(GIMP(53))
      Endif
   When Default
  Endcase

Return

