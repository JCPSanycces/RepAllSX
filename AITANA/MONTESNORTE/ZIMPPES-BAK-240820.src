#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "AP_IMPORT" : Gosub AP_IMPORT
    When "IMP_FERME" : Gosub IMP_FERME
  Endcase
Return

$OUVRE
    If !clalev([F:ZPE]) : Local File ZPESADAS[ZPE] : Endif
    Gosub OUVRE From IMPPTHS
Return

$RAZCRE
  Gosub RAZCRE From IMPPTHS
Return

$VALID
  Gosub VALID From IMPPTHS
Return

$SAIMSK
  Gosub SAIMSK From IMPPTHS
Return



$AP_IMPORT
  #LOS DATOS DE LA PRIMERA RECEPCIÓN ESTÁN DISPONIBLES EN LA SEGUNDA PASADA, ES DECIR, CUANDO YA
  #SE HA LLEVADO A CABO LA PRIMERA RECEPCIÓN. POR ESO SE COMPRUEBA QUE, SI TENEMOS LOS DATOS
  #DE Nº DE RECEPCIÓN Y DE Nº DE PESADA, ACTUALIZAMOS LA TABLA ZPESADAS.
  If IMPFIC="PTH" and [M:PTH0]PTHNUM <> "" and [M:PTH0]BPSNDE <> "" Then

  Gosub ACTUALIZA_ZPESADAS

  Endif

  Case [L]IMPFIC
    When "PTD"
      If GIMP(98)<>'' Then
        [M:PTH1]ZCALIDAD(nolign-1) = GIMP(98)
      Endif

      If GIMP(97) <> '' Then
        [M:PTH1]ZGRADO(nolign-1) = val(GIMP(97))
      Endif

      If GIMP(96) <> '' Then
        [M:PTH1]ZPH(nolign-1) = val(GIMP(96))
      Endif

      If GIMP(95) <> '' Then
        [M:PTH1]ZCANT1(nolign-1) = val(GIMP(95))
      Endif

      If GIMP(93) <> '' Then
        [M:PTH1]ZCANT2(nolign-1) = val(GIMP(93))
      Endif

      If GIMP(90) <> '' Then
        [M:PTH1]ZRENDIMIENTO(nolign-1) = val(GIMP(90))
      Endif

      If GIMP(91) <> '' Then
        [M:PTH1]ZHUMEDAD(nolign-1) = val(GIMP(91))
      Endif

      If GIMP(92) <> '' Then
        [M:PTH1]ZPESOESPE(nolign-1) = val(GIMP(92))
      Endif

   When Default
  Endcase

Return

$IMP_FERME
  #LOS DATOS DE LA ÚLTIMA RECEPCIÓN ESTÁN DISPONIBLES EN EL CIERRE DE PROGRAMA, ES DECIR, CUANDO YA
  #SE HA LLEVADO A CABO LA ÚLTIMA RECEPCIÓN, PERO A POSTERIORI. POR ESO SE COMPRUEBA QUE, SI TENEMOS LOS DATOS
  #DE Nº DE RECEPCIÓN Y DE Nº DE PESADA, ACTUALIZAMOS LA TABLA ZPESADAS DEL ÚLTIMO REGISTRO PROCESADO
  If [M:PTH0]PTHNUM <> "" and [M:PTH0]BPSNDE <> "" Then

  Gosub ACTUALIZA_ZPESADAS

  Endif

Return



$ACTUALIZA_ZPESADAS
  Trbegin [F:ZPE]
#    Read [F:ZPE]ZPE0=[M:PTH0]PRHFCY;[M:PTH0]ZEJERCICIO;right$([M:PTH0]BPSNDE,6) #XVT02032020.o
    Read [F:ZPE]ZPE0=[M:PTH0]ZEJERCICIO;right$([M:PTH0]BPSNDE,6) #XVT02032020.n
    If !fstat Then
      [F:ZPE]TIMP=2
      [F:ZPE]PTHNUM=[M:PTH0]PTHNUM
      Rewrite [F:ZPE]
      If !fstat Then
        Commit
      Endif
    Endif
    If fstat : Rollback : Endif
Return

