#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
When "AP_IMPORT" : Gosub AP_IMPORT
Endcase
Return


$OUVRE
  Gosub OUVRE From IMPPIH
Return

$RAZCRE
  Gosub RAZCRE From IMPPIH
Return

$VALID
  Gosub VALID From IMPPIH
Return

$SAIMSK
  Gosub SAIMSK From IMPPIH
Return

$AP_IMPORT

  If IMPFIC="PID" Then
  Infbox "ZIMPLIQPLAN CALIDAD=" + GIMP(90)
    [M:PIH3]FCYLIN = '01B01'
    [F:PID]FCYLIN='01B01'
    [M:PIH3]ZCALIDAD = GIMP(90)
    [F:PID]ZCALIDAD  = GIMP(90)
    [M:PIH3]ZCANT1 = val(GIMP(91))
    [F:PID]ZCANT1 = val(GIMP(91))
    [M:PIH3]ZCANT2 = val(GIMP(92))
    [F:PID]ZCANT2 = val(GIMP(92))
  Endif

Return

