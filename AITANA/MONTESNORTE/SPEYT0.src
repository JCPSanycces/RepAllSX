######################################################################################
Subprog AM_TIPOFCY(VALEUR)
    Variable Integer VALEUR

    GYTIPOFCY = VALEUR
End
######################################################################################
Subprog C_GRUPO(VALEUR)
    Variable Char    VALEUR()

    If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif

    Read [AXX]AXX0="ATABDIV";"LNGDES";"SPA";num$([M:YT01]GRUPESTAD+19);VALEUR
    If fstat=0 Then
        [M:YT04]DESGRUPO(nolign-1) = [F:AXX]TEXTE
    Else
        mkstat = 2
    Endif

    #Si el valor no se ha modificado, salimos
    If [M:YT04]GRUPO(nolign-1)=VALEUR Then : End : Endif

    For [ITM]ITM0 Where TSICOD([M:YT01]GRUPESTAD-1)=VALEUR and ([F:ITM]YTPROD=1 or [F:ITM]YTPROD=8)

        [M:YT04]ITMREF(nolign-1) = [F:ITM]ITMREF
        # Call LECTU_PROD([F:ITM]ITMREF) From YARYT0 MAB16102019. LA FUNCION ESTÁ COMENTADA EN LA LIBRERIA

        [M:YT04]CODI1(nolign-1)=[F:ITM]TSICOD(0)
        [M:YT04]CODI2(nolign-1)=[F:ITM]TSICOD(1)
        [M:YT04]CODI3(nolign-1)=[F:ITM]TSICOD(2)
        Break
    Next
End
######################################################################################
Subprog AV_GRUPESTAD(VALEUR)
    Variable Integer VALEUR

    If [M:YT04]NBGRP>0 Then
        GOK=0
        mkstat = 2
    Endif
End
######################################################################################
Subprog AM_PRODUCTO(VALEUR)
    Variable Integer VALEUR

    If [M:YT00]CLASEDOC <> 29 : End : Endif

    If [M:YT01]PRODUCTO=2 and [M:YT02]NBLIG>0 Then
        GOK=0
        mkstat = 2
        End
    Elsif [M:YT01]PRODUCTO=1 and [M:YT04]NBGRP>0 Then
        GOK=0
        mkstat = 2
        End
    Endif

    If VALEUR=1 Then
        Actzo [M:YT01]GRUPESTAD
    Else
        Grizo [M:YT01]GRUPESTAD
    Endif
    Affzo [M:YT01]GRUPESTAD
End
