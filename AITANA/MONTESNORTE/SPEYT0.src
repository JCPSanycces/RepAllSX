######################################################################################
Subprog C_TIPDOC(VALEUR)
    Variable Char    VALEUR()

    Read [YTD]YTD0=VALEUR
    If (fstat=0 and ([F:YTD]CLASEDOCUM<>29 & [F:YTD]CLASEDOCUM<>34)
& or [F:YTD]TIPOCLASE <> 1)
        GERR=2
        GMESSAGE=mess(1,1986,1)
        GOK=0
        mkstat = 2
    Else
        [M:YT00]CLASEDOC=[F:YTD]CLASEDOCUM
        [M:YT00]SERIE=[F:YTD]SERIEDOCUM
        If [M:YT00]CLASEDOC=34 Then
            Grizo [M:YT01]NUMPREC
        Else
            Actzo [M:YT01]NUMPREC
        Endif
    Endif
End
######################################################################################
Subprog C_CUR(VALEUR)
    Variable Char    VALEUR()
    If VALEUR=""
        GMESSAGE=mess(10,123,1) : mkstat=1 : # Zone obligatoire !
    Endif
End
######################################################################################
Subprog AM_CUR(VALEUR)
    Variable Char     VALEUR
    Local    Integer  I

    GCUR=VALEUR
    Call COURSITE(CUR,[M:YT00]FCY,[M:YT01]CHGTYP,[M:YT00]DATAC,[M:YT01]CHGCOE,I) From TRTDEV
    If !GIMPORT Affzo [YT01]CHGCOE : Endif
    #----- Chargement formats colonnes tarif -----#
    Call FMTREM("YT01",CUR) From TRTPRICE
    If VALEUR=GLOCALDEV Diszo [YT01]CHGTYP Else Actzo [YT01]CHGTYP : Endif
End
######################################################################################
Subprog AM_CHGTYP(VALEUR)
    Variable Integer  VALEUR
    Local    Integer  I
    Call COURSITE(CUR,[M:YT00]FCY,VALEUR,[M:YT00]DATAC,[M:YT01]CHGCOE,I) From TRTDEV
    If !GIMPORT Affzo [YT01]CHGCOE : Endif
End
######################################################################################
Subprog AM_ITMREF(VALEUR)
    Variable Char    VALEUR()
    # Call LECTU_PROD(VALEUR) From YARYT0 # MAB. LA FUNCION ESTÁ COMENTADA EN LA LIBRERIA YARYT0
End
######################################################################################
Subprog AM_CALIDAD(VALEUR)
    Variable Char    VALEUR()
    Local Integer ESTAT

    If (VALEUR<>"")
        Call MODIF_CALIDAD(VALEUR, [M]CODI1(nolign-1), [M]CODI2(nolign-1),
&            [M]CODI3(nolign-1), 2, ESTAT) From YSELAGRO
        If ESTAT=0 Then
            GERR=1
            GMESSAGE=mess(12,1986,1)
            mkstat=2
            EXISTE=1
        Endif
    Endif
End
######################################################################################
Subprog AM_CALIBRE(VALEUR)
    Variable Char    VALEUR()
    If (VALEUR<>"")
        Read [YCC]YCC2=[M]CODI1(nolign-1);[M]CODI2(nolign-1);[M]CODI3(nolign-1);VALEUR
        If (fstat<>0)
            GERR=1
            GMESSAGE=mess(13,1986,1)
            mkstat=2
            EXISTE=1
        Else
            If ([F:YCC]TACTIU=1)
                GERR=1
                GMESSAGE=mess(14,1986,1)
                mkstat=2
                EXISTE=1
            Else
                Read [YCL]YCL0=VALEUR
                If ([F:YCL]CLACALIBRE=2)
                    GERR=1
                    GMESSAGE=mess(13,1986,1)
                    mkstat=2
                    EXISTE=1
                Endif
            Endif
        Endif
    Endif
End
######################################################################################
Subprog IB_NBLIG
    If (NBLIG<>0 | [M:YT02]ITMREF(nolign-1)<>"")
        GBOUT1=""
    Else
        GBOUT1=mess(31,1986,1)
        GBOU2=""
    Endif
    Call FORMATEJAR_TIPO From YARYT0
End
######################################################################################
Subprog IB_NBPER
    If (NBPER<>0 | [M:YT03]CODIPERSON(nolign-1)<>"")
        GBOUT1=""
    Else
        GBOUT1=mess(46,1986,1)
    Endif
End
######################################################################################
Subprog AM_DATAINI(VALEUR)
    Variable Date    VALEUR
    Local    Integer RESP

    Call XLECTUEXE([M]FCY,[M]EXERCICI) From XCONTROLES
    If (VALEUR<[F:YPY]DATAINIEX)
        RESP =2
        Qstbox mess(73,104,1) + mess(205,100,1) Using RESP Sleep 10
        If RESP = 2
            mkstat=2
        Endif
       # VALEUR=[F:YPY]DATAINIEX
       # [M:YST2]DATAINI=[F:YPY]DATAINIEX
    Endif
    Affzo [M:YST2]DATAINI
End
######################################################################################
Subprog AM_DATAFI(VALEUR)
    Variable Date    VALEUR
    Local    Integer RESP
    Call XLECTUEXE([M]FCY,[M]EXERCICI) From XCONTROLES
    If (VALEUR>[F:YPY]DATAFIEX)
        RESP =2
        Qstbox mess(14,101,1) + mess(205,100,1) Using RESP Sleep 10
        If RESP = 2
            mkstat=2
        Endif
       # VALEUR=[F:YPY]DATAFIEX
       # [M:YST2]DATAFI=[F:YPY]DATAFIEX
    Endif
    Affzo [M:YST2]DATAFI
End
######################################################################################
Subprog AM_TIPO(VALEUR)
    Variable Integer VALEUR
    Local Char PANTALLA(15) : PANTALLA = maskcou()

    If clalev([F:AMK])=0 : Local File AMSK    [AMK] : Endif
    Read [AMK]CODMSK = PANTALLA : If fstat Raz [F:AMK] : Endif
    PANTALLA = [F:AMK]ABRMSK
    If PANTALLA = "YT04" :
        [M:YT04]TIPO(nolign-1)=VALEUR
         Call FORMATEJAR_TIPO_YT04 From YARYT0
    Else
        [M:YT02]TIPO(nolign-1)=VALEUR
        Call FORMATEJAR_TIPO From YARYT0
    Endif
    #Si existeix, eliminar nº doc. classificacions
End
######################################################################################
Subprog AM_PREU1(VALEUR)
    Variable Decimal VALEUR
#v11.bo    Read [YTD]YTD0=[F:YT0]TIPDOC
#    If !fstat
#        If [F:YTD]QTYFAC<7 or [F:YTD]QTYFAC>9 Then
#            [M]IMPORTE1(nolign-1)=VALEUR
#        Elsif [F:YTD]QTYFAC=7
#            [M]IMPORTE1(nolign-1)=VALEUR*[M]QUANTITAT1(nolign-1)
#        Elsif [F:YTD]QTYFAC=8
#            [M]IMPORTE1(nolign-1)=VALEUR*[M]QUANTITAT2(nolign-1)
#        Elsif [F:YTD]QTYFAC=9
#            [M]IMPORTE1(nolign-1)=VALEUR*[M]QUANTITAT3(nolign-1)
#        Endif
    Case [M:YT02]QTYFAC(nolign-1)
      When 1 Then [M:YT02]IMPORTE1(nolign-1)=VALEUR*[M:YT02]QTYSTU(nolign-1)
      When 2 Then [M:YT02]IMPORTE1(nolign-1)=VALEUR*[M:YT02]ZCANT1(nolign-1)
      When 3 Then [M:YT02]IMPORTE1(nolign-1)=VALEUR*[M:YT02]ZCANT2(nolign-1)
    Endcase
    Call GETDEV(GFCY) From DEVSUB
    Call ARRDEV([M:YT02]IMPORTE1(nolign-1), GLOCALDEV) From TRTDIV
    Affzo [M:YT02]IMPORTE1(nolign-1)
#v11.eo    Endif
End
######################################################################################
Subprog C_INVDTA(VALEUR)
    Variable Decimal VALEUR
    If find(VALEUR,[M:YT01]INVDTA) & find(VALEUR,[M:YT01]INVDTA)<>nolign
      GMESSAGE=mess(102,194,1) : mkstat=1
    Endif
End
######################################################################################
Subprog AM_QUANTITAT1(VALEUR)
    Variable Decimal VALEUR
    Read [YTD]YTD0=[F:YT0]TIPDOC
    If !fstat
        If [F:YTD]QTYFAC=7 : [M]IMPORTE1(nolign-1)=[M]PREU1 * VALEUR : Endif
        Call GETDEV(GFCY) From DEVSUB
        Call ARRDEV(IMPORTE1(nolign-1), GLOCALDEV) From TRTDIV
        Affzo [M]IMPORTE1(nolign-1)
    Endif
End
######################################################################################
Subprog AM_QUANTITAT2(VALEUR)
    Variable Decimal VALEUR
    Read [YTD]YTD0=[F:YT0]TIPDOC
    If !fstat
        If [F:YTD]QTYFAC=8 : [M]IMPORTE1(nolign-1)=[M]PREU1 * VALEUR : Endif
        Call GETDEV(GFCY) From DEVSUB
        Call ARRDEV(IMPORTE1(nolign-1), GLOCALDEV) From TRTDIV
        Affzo [M]IMPORTE1(nolign-1)
    Endif
End
######################################################################################
Subprog AM_QUANTITAT3(VALEUR)
    Variable Decimal VALEUR
    Read [YTD]YTD0=[F:YT0]TIPDOC
    If !fstat
        If [F:YTD]QTYFAC=9 : [M]IMPORTE1(nolign-1)=[M]PREU1 * VALEUR : Endif
        Call GETDEV(GFCY) From DEVSUB
        Call ARRDEV(IMPORTE1(nolign-1), GLOCALDEV) From TRTDIV
        Affzo [M]IMPORTE1(nolign-1)
    Endif
End
