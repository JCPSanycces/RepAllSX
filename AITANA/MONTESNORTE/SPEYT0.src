######################################################################################
Subprog C_ANTILIQ(VALEUR)
Variable Integer VALEUR
  # Si estoy modificando no permitir modificar este campo
  If VALEUR <> [M:YT00]ANTILIQ and (varmode([M:YT00]FCY)=1 and [M:YT00]NUMDOC <> '') or GREP = 'M' Then
      # mkstat = 2
      VALEUR = [M:YT00]ANTILIQ
      [M:YT00]ANTILIQ = VALEUR
      Affzo [M:YT00]ANTILIQ
      #Grizo [M:YT00]ANTILIQ
  Endif
End


