#MNORTE-62.bn
#Subprog C_FCYDEB(VALEUR) XVT2020-05-08.o
Subprog AM_FCYDEB(VALEUR) #XVT2020-05-08.n
Variable Char    VALEUR()
  If VALEUR="" Then
    [M:YT00]FCYFIN=""
    Diszo [M:YT00]FCYFIN
    Affzo [M:YT00]FCYFIN
  Else
      If !clalev([FCY]) : Local File FACILITY[FCY] : Endif
      Read [F:FCY]FCY0 = VALEUR
      If [F:FCY]FINRSPFCY <> [M:YT00]FCY Then
        mkstat = 2
        Call MESSAGE("Planta de stock no pertenece a planta financiera") From GESECRAN
      Else
        Actzo [M:YT00]FCYFIN
        [M:YT00]FCYFIN = VALEUR
        Affzo [M:YT00]FCYFIN
      Endif
  Endif
End

#Subprog C_FCYFIN(VALEUR)  XVT2020-05-08.o
Subprog AM_FCYFIN(VALEUR)  #XVT2020-05-08.N
Variable Char    VALEUR()
  If VALEUR<>"" Then
      If !clalev([FCY]) : Local File FACILITY[FCY] : Endif
      Read [F:FCY]FCY0 = VALEUR
      If [F:FCY]FINRSPFCY <> [M:YT00]FCY Then
        mkstat = 2
        Call MESSAGE("Planta de stock no pertenece a planta financiera") From GESECRAN
      Endif
  Else
    If [M:YT00]FCYDEB <> "" Then
       Call MESSAGE("Introduzca una planta válida") From GESECRAN
       mkstat=2
    Endif
  Endif
End

#MNORTE-62.en
