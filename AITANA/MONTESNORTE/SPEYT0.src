######################################################################################
## Etiqueta añadida por el supervisor (pantalla YT00) 06/07/2020 17:24:48 (ADMIN)
######################################################################################
Subprog AM_EJERCICIO(VALEUR)
Variable Decimal VALEUR
 Local Integer POK : POK = 0
    Call CHECK_EJERCICIO([M]FCY, 0, VALEUR, POK) From ZLIBMONTES
    If POK=1 Then
      [M:YT00]FECHAINI=[F:ZCAM]INIDAT
      [M:YT00]FECHAFIN=[F:ZCAM]ENDDAT
      Affzo [M:YT00]FECHAINI
      Affzo [M:YT00]FECHAFIN
    Endif
End
