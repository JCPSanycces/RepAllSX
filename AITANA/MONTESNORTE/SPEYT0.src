Subprog C_PREU1(VALEUR)
    Variable Decimal VALEUR
    Local Char PANTALLA(15) : PANTALLA = maskcou()

    If clalev([F:AMK])=0 : Local File AMSK    [AMK] : Endif
    Read [AMK]CODMSK = PANTALLA : If fstat Raz [F:AMK] : Endif
    PANTALLA = [F:AMK]ABRMSK
    If PANTALLA = "YT02"
        If [M:YT02]TIPO(nolign-1)=5 and VALEUR = 0
            GERR=2
            GMESSAGE = mess(10,123,1)
            GOK=0
            mkstat = 2
        Endif
    Elsif PANTALLA = "YT04"
        If [M:YT04]TIPO(nolign-1)=5 and VALEUR = 0
            GERR=2
            GMESSAGE = mess(10,123,1)
            GOK=0
            mkstat = 2
        Endif
    Endif
End
