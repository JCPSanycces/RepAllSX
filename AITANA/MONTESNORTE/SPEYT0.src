######################################################################################

##v11.bn traspasar del programa vertical al SPE
Subprog C_FCY(VALEUR)
    Variable Char    VALEUR()
    Local Integer POK : POK=0

    Read [FCY]FCY0=VALEUR
    If fstat
        GERR=2
        GMESSAGE=mess(39,1986,1)
        GOK=0
        mkstat = 2
    Else
        If [F:FCY]FINFLG<>2 Then
          Call MESSAGE("La planta seleccionada no es financiera") From GESECRAN
          mkstat=2
          End
        Endif
        [M:YT00]TIPOFCY=[F:FCY]YTIPOFCY
        Affzo  [M:YT00]TIPOFCY
        If [M]EJERCICIO<>0 Then
          Call CHECK_EJERCICIO("", [FCY]YTIPOFCY, [M]EJERCICIO, POK) From ZLIBMONTES
          If POK<>1 Then
            Call MESSAGE("Campaña no existe para esta planta") From GESECRAN
            mkstat=2
          Endif
        Endif
    Endif
End
