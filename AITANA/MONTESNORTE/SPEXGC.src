######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla XPGCD) 23/11/2016 09:50:30 (EBERN)
######################################################################################

Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
    [M:XCD]AMNTAPOR(nolign-1) = ar2(VALEUR * [M:XCD]INDCORR(nolign-1))
    Affzo [M:XCD]AMNTAPOR(nolign-1)
    [M:XCD]AMNTBASE(nolign-1) = [M:XCD]AMNTCPDEV(nolign-1) - [M:XCD]AMNTAPOR(nolign-1)
    Affzo [M:XCD]AMNTBASE(nolign-1)
End

###########

Subprog AM_INDCORR(VALEUR)
Variable Decimal VALEUR
    [M:XCD]AMNTAPOR(nolign-1) = ar2(VALEUR * [M:XCD]QTY(nolign-1))
    Affzo [M:XCD]AMNTAPOR(nolign-1)
    [M:XCD]AMNTBASE(nolign-1) = [M:XCD]AMNTCPDEV(nolign-1) - [M:XCD]AMNTAPOR(nolign-1)
    Affzo [M:XCD]AMNTBASE(nolign-1)
End

###########

Subprog AM_AMNTCPDEV(VALEUR)
Variable Decimal VALEUR
    [M:XCD]AMNTBASE(nolign-1) = VALEUR - [M:XCD]AMNTAPOR(nolign-1)
    Affzo [M:XCD]AMNTBASE(nolign-1)
End

