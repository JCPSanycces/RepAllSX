# Gestión de la máscara PTH9 (Especifico)

Subprog AM_ZAIN(VALEUR)
Variable Char    VALEUR()
  If !clalev ([AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev ([CNT]) : Local File CONTACT [CNT] : Endif

  Read [AIN]AIN0=VALEUR
  If !fstat Then
    [M:PTH9]ZAINNAM=[AIN]CNTLNA + ' ' + [AIN]CNTFNA
    Affzo [M:PTH9]ZAINNAM
  Endif
End

######################################################################################

