#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
    Case ACTION
        When "IMP_OUVRE"  : Gosub IMP_OUVRE
        When "IMP_INICRE" : Gosub IMP_INICRE
    Endcase
Return

$IMP_OUVRE
     Global  Char STMOCTO(8): STMOCTO="01O"  ##SANTÍSIMO CRISTO - PAGADOR
Return

$IMP_INICRE
    If !clalev([F:BID])   : Local File BID [BID]  : Endif  ##CUENTAS BANCARIAS

    If [F:SIH]PTE="002005" or [F:SIH]PTE="002005B" Then
    # EN ESTE CASO, HAY QUE BUSCAR LA C.C.C. DEL CLIENTE PARA GASÓLEOS, MARCADA COMO "O" EN LAS CUENTAS DEL CLIENTE
    # SI ES DE SECCIÓN DE CRÉDITO DE STMO. CTO., EL TERCERO PAGADOR SERÁ STMO. CTO.
         Filter [F:BID] Where BPANUM=[F:SIV]BPCINV and instr(1,[F:BID]PAB2,"O")
         For [F:BID]
           If left$([F:BID]BIDNUM,4)="0001" Then
             [F:SIH]BPRPAY=STMOCTO
             [F:SIV]BPRPAY=STMOCTO
           Endif
         Next
         Filter [F:BID]
    Endif
Return


