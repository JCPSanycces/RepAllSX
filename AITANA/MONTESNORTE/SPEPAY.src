#<AdxTL>@(#)0.0.0.0 $Revision$ Pagos
#xvt11-05-2020 Ajuste: para emisión de pagos a socios (liquidaciones)
#En este caso, para el resto de sociedades, aplica a cobros y pagos y la cuenta depende del tipo
#de planta, siempre que sea GRANELES.


$ACTION
  Case ACTION
  When "CREPYH" : Gosub CREPYH
  Endcase
Return


$CREPYH
#Desarrollo para cobros de carburante
#XVT20190516: sólo debe aplicar a cobros, no a pagos. Comprobaremos el sentido de la transacción.
#además sólo aplica a la sociedad 97
#If [F:PYH]CPY <> '97' : Return : Endif #aplica sólo a MNE - sociedad 97  #xvt11-05-2020.O
#If [M:DIA]SNS = 1 : Return : Endif  #XVT20190516.n (si es GASTO, salir)  #xvt11-05-2020.O
If [F:PYH]CPY = '97' and [M:DIA]SNS = 1  : Return : Endif #aplica sólo a MNE - sociedad 97 #xvt11-05-2020.N

If !clalev([ZBID]) : Local File BID[ZBID] : Endif
Local Char CUENTA_O(30), ZPAB2(30)

If [F:PYH]CPY = '97' Then   #xvt11-05-2020.N
  CUENTA_O=""
  ZPAB2=""
  #PENDIENTE AÑADIR EL RESTO DE POSBILES MODOS DE PAGO (GSB, ETC.) DE UNA TABLA VARIA
  #O ASOCIAR A LOS DIFERENTES MÉTODOS LAS LETRAS A BUSCAR EN PAM2, ESTO PARA LA FASE II DEL PROYECTO
  If [F:PYH]PAM = "GSA" or [F:PYH]PAM = "GSB" or [F:PYH]PAM = "GSD" or [F:PYH]PAM = "GAS" or [F:PYH]PAM = "DOM" Then
    For [ZBID] Where BPATYP=[F:PYH]BPRTYP and BPANUM=[F:PYH]BPR
      If instr(1,[ZBID]PAB2,"O") > 0 Then
        CUENTA_O = [ZBID]BIDNUM
        ZPAB2    = [ZBID]PAB2
      Endif
    Next
    If CUENTA_O<>"" Then
      [F:PYH]BID=CUENTA_O
      [F:PYH]PAB2=ZPAB2
    Else
      #SI NO TIENE CUENTA DE CARBURANTES "O" ASOCIADA, NO PUEDE CREAR EL PAGO
      Call ECR_TRACE([F:PYH]BPR + " sin cuenta carburantes",1) From GESECRAN
      GOK=2
    Endif
  Endif
Else    #xvt11-05-2020.BN
#liquidaciones
#1) comprobar que se trata de entregas a cuenta o liquidaciones (planta es de tipo graneles: almazara, bodega, cereal, frutos c.)
  If !clalev([F:ZFCY]) : Local File FACILITY [ZFCY] : Endif
  Local Char TIPOCUENTA(1) : TIPOCUENTA=""

  Read [F:ZFCY]FCY0=[F:PYH]FCY
  If !fstat  Then
    Case [F:ZFCY]YTIPOFCY
    When 2 : TIPOCUENTA="C"
    When 3 : TIPOCUENTA="A"
    When 4 : TIPOCUENTA="B"
    When 7 : TIPOCUENTA="F"
    Endcase
  Endif
    If TIPOCUENTA<>"" Then
      For [ZBID] Where BPATYP=1 and BPANUM=[F:PYH]BPR
        If instr(1,[ZBID]PAB2,TIPOCUENTA) > 0 Then
          [F:PYH]BID = [ZBID]BIDNUM
          [F:PYH]PAB2 = [ZBID]PAB2
        Endif
      Next
    Endif
    #xvt11-05-2020.EN
Endif
Return

