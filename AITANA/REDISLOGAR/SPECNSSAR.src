Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()

If !clalev([ZVITBPC]) : Local File YVITMBPC [ZVITBPC] : Endif

Read [ZVITBPC]YIB0 = VALEUR;[M:SAR1]YCLIENTE
If !fstat
  [M:SAR1]YITMDESSTR = [ZVITBPC]ITMDESBPC
Endif
Affzo [M:SAR1]YITMDESSTR

End

Subprog AM_ITMREFEND(VALEUR)
Variable Char    VALEUR()

If !clalev([ZVITBPC]) : Local File YVITMBPC [ZVITBPC] : Endif

Read [ZVITBPC]YIB0 = VALEUR;[M:SAR1]YCLIENTE
If !fstat
  [M:SAR1]YITMDESEND = [ZVITBPC]ITMDESBPC
Endif
Affzo [M:SAR1]YITMDESEND


End


