#<AdxTL>@(#)12.0.0.0 $Revision:   1.18  $ Gestion du masque GFO1
#ACV#X11
#TIT#gestion formule de dimensionnement GAS
Call OBJET("GFO",GBIDC1,GBIDC2)From GOBJET
End

$ACTION
Case ACTION
    When "OUVRE"   : Gosub OUVRE From SPVOBJGFO
    When "FERME"   : Gosub FERME From SPVOBJGFO
    When "LIENS2"  : Gosub LIENS0 From SPVOBJGFO
    When "SETBOUT" : Gosub SETBOUT From SPVOBJGFO
    When "EXEBOUT" : Gosub EXEBOUT From SPVOBJGFO
    When Default
Endcase
Return

########################################
Subprog AM_FORDIM(VALEUR)
Variable Char    VALEUR()
[M:GFO1]RESULT(nolign-1)=evalue(VALEUR)
End

########################################
Subprog AV_FICENR(VALEUR)
Variable Decimal VALEUR

If !clalev([F:ATB]) : Local File ATABLE : Endif
Read [ATB]CODFIC=[M:GFO1]CODFIC(nolign-1)
If !fstat & [F:ATB]NBENREG<>VALEUR
    VALEUR=[F:ATB]NBENREG
    NEWENREG=1
Endif    
End

########################################
Subprog S_FORDIM(VALEUR)
Variable Char    VALEUR()

Local Char TMPVAL

Call SELECT("GDM","",[L]TMPVAL,"")From SELOBJ

VALEUR+=[L]TMPVAL
End

########################################
Subprog C_FORDIM(VALEUR)
Variable Char    VALEUR()

If evalue([L]VALEUR)<100
    [V]GMESSAGE=mess(177,[V]GXMSGPSA,1)
    mkstat=2
Endif

End

