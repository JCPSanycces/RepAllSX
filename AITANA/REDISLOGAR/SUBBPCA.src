$OUVRE

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#----- Chargement du GSOCIETE en fonction du site par défaut "Tronc commun" -----#
GCUR=GLOCALDEV
GFCYDEF(0)=GFCYDEF(9)
If GFONC1="GESBPC"
  If GFCYDEF(0)<>""
    Call GETDEV(GFCYDEF(0)) From DEVSUB : GCUR=GLOCALDEV
  Else
    Raz GSOCIETE : GLOCALDEV=GSYSCUR : GCUR=GSYSCUR
  Endif

  # Si multi-législation, ne pas charger de société et législation par défaut
  #If GNBLEG>1     # FGR 01/09/2016 : X3SUIVI118096 A faire dans tous les cas
     Raz GSOCIETE, GCURLEG
  #Endif

Endif
#-----

Global Integer GIBPCEXIST
GIBPCEXIST = 0

Global Integer GIOBPC_MODIF
GIOBPC_MODIF=0

# Pour ne pas filtrer le régime de taxe sur une société bidon
#Raz GSOCIETE

Local Integer WBPATYP : WBPATYP = 1
If GMODU(7)=2
  GLOCSEL = "[F:STC]LOCCAT=3"
Endif
Local Integer SPSTAT
Local Char    SYMBOLE2 (20)   : # cg le 28/01/98
#---- positionnement sur écran 2 (bpc1) si on vient du tiers #
If clalev ([M:BPR0])
    PRMASK = 3
Endif

If !clalev([F:MVC])  : Local File BPCUSTMVT [MVC]  : Endif
If !clalev([F:DIE])  : Local File GDIE     [DIE]  : Endif
If !clalev([F:CDI])  : Local File CADIEDEF [CDI]  : Endif

# Ouverture du fichier client sous une autre abréviation pour la recherche tiers risque
If !clalev([F:BPC1]) : Local File BPCUSTOMER [BPC1] : Endif
If !clalev([F:BPD1]) : Local File BPDLVCUST  [BPD1] : Endif
If !clalev([F:BPR1]) : Local File BPARTNER   [BPR1] : Endif  # FGR 19/02/2010 : X3SUIVI62660

# OUVERTURE DES TABLES POUR LA GESTION DES ARTICLES CLIENT.
If !clalev([F:ITU])   Local File ITMBPC     [ITU]   : Endif
If !clalev([F:ITM])   Local File ITMMASTER  [ITM]   : Endif
If !clalev([F:ITG])   Local File ITMCATEG   [ITG]   : Endif
#MAE: bg 73682: classe de sauvegarde de BPCUSTOMER
If !clalev([F:BPCS])  Local File BPCUSTOMER  [BPCS]  : Endif

# FGR 14/10/2014 : X3SUIVI101807 : On ne conserve que le mode optimisé.
## FGR 29/07/2014 : X3SUIVI100229 (début)
#  If !clalev([F:ADW])  Local File ADOVAL  [ADW]  : Endif
#  Read [F:ADW]ADW0="";"";"BPCADDOPT"
#  If !fstat Then
#    If [F:ADW]VALEUR = "2" Then
#      Global Integer GBPCADDOPT
#
#      GBPCADDOPT = 2
#    Else
#      If dim(GBPCADDOPT) >= 0 Then
#        Kill GBPCADDOPT
#      Endif
#    Endif
#  Endif
## FGR 29/07/2014 : X3SUIVI100229 (fin)

  #---------------------------------------------------#
  #Modif CRM 09/02/2004
  #Vérification de l'activation de la gestion des jetons
Global Char GBPC2TITTOK(50)

  Raz GBPC2TITTOK
  If GMODU(12) = 2 Then
    # FGR 23/01/2009 : X3SUIVI41698
    If func CRMUTIL150.GET_CODE_ACTIVITE("FTC") = 2 Then
      # Le code activité "FTC" détermine la présence de ce bloc
      If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 and func CRMUTIL150.GET_CODE_ACTIVITE("TOK") = 2 Then
        #Gestion des points et jetons
        Call TEXTE(24301, GBPC2TITTOK) From OBJDIV
      Elsif func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
        #Gestion des points
        Call TEXTE(22384, GBPC2TITTOK) From OBJDIV
      Endif
    Endif
  Endif
  #---------------------------------------------------#

#-----------------------------------------------------#
# récupération devise société                         #
#-----------------------------------------------------#
Local Char WLEGCPY (GLONCPY)
Local Char WFINRSPFCY (GLONFCY)

WFINRSPFCY = GFCYDEF(9)
WLEGCPY = ""
#---- devise site alimentée par devise dossier ----#
GCUR= GSYSCUR
#---- lecture du site par défaut ----#
If GFCYDEF (9) <> ""
   If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
   Read [FCY]FCY0 = GFCYDEF(9)
   If fstat = 0
      WLEGCPY    = [F:FCY]LEGCPY
      WFINRSPFCY = [F:FCY]FINRSPFCY
   Endif
Endif
#---- lecture société correspondant au site ----#
If clalev([F:CPY]) = 0 : Local File COMPANY [CPY] : Endif
If WLEGCPY <> ""
   Read [CPY]CPY0 = WLEGCPY
   If fstat = 0 : GCUR = [F:CPY]ACCCUR : Endif
Endif

#-- si pas de cours entre devise dossier et devise affichage
#-- la devise affichage devient la devise de reporting
#-- cg le 14 septembre 99 demande numéro ????

GBIDD1 = 0
GBIDD2 = 0

Call CONVERT(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,GBIDD1,GBIDD2,SPSTAT) From TRTDEV
If SPSTAT <> 0
   GCUR = GSYSCUR
Endif

#-----------------------#
# decimal de la devise  #
#-----------------------#
Local Decimal WDECIMAL
WDECIMAL = 0
Read [TCU]TCU0= GCUR
If fstat = 0
    WDECIMAL = [F:TCU]CURRND
Endif

#---- alimentation variables globales ventes
Call GLOBVAR(WFINRSPFCY) From WWGLOBVEN

#---- Initialisation du code comptable par défaut
#MAE, le 06/01/09, SUP_GACCCOD
#Call INITACCCOD(GACCCOD,2) From TRTX3

#Récupération de la famille statistique de produit
#Call USEFAMCIA From CRM_UTIL

Local  Integer  WNBGAUCHE
WNBGAUCHE = GNBGAUCHE
If !clalev([F:ADI])  Local File ATABDIV [ADI] : Endif

#Initialisation CRM
Gosub OUVRE_CRM From TRTBPCRM
GSZCRMOBJET="BPC"

# FGR 03/02/2010 : X3SUIVI62170 (début)
Local Char SZOBPP(GLONFEN)

  Raz SZOBPP
  If GNAVIG(max(GPILNAV-1,1)) = "GESBPP" Then
    SZOBPP = GNAVIG(max(GPILNAV-1,1))
  Endif
# FGR 03/02/2010 : X3SUIVI62170 (fin)

Local Integer VII
VII=func AFNC.ACTIV("VII")

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
Local Integer J
#94635 RICAR 2014/04/21 - CASH VAT - END

# Issue 110700
If clalev([F:TPM]) = 0 : Local File TABPRTMOD [TPM] : Endif
# End issue 110700

Return

#########################################################################
$BOITE

If GNAVIG(max(GPILNAV-1,1)) = "GESBPP" | GORITRFBPP<>"" : GNBGAUCHE = 0 : Endif

Return

#########################################################################
$AFFMASK
  Gosub GRIZE_BPC1  # FGR 20/04/2012 : X3SUIVI81311
#If GACTFTC=2
#   If dim(GNOTATI)>0 & GNOTATI=2
#      Actzo [M:BPC1]PRITYP
#   Else
#      Diszo [M:BPC1]PRITYP
#   Endif
#   If dim([M:BPC1]COMCAT)>0
#      If GCOMCAT=0
#         Grizo [M:BPC1]COMCAT
#      Else
#         Actzo [M:BPC1]COMCAT
#      Endif
#   Endif
#Endif

  #--- Issue 106137
  If GACTFTC=2
    #LSE 05/10/2006 FQ36055
    If func AFNC.ACTIV("RED")<2
      Chgfmt [M:BPC4]XREP1 With "-K:" + num$(GLONREP) + "x"
    Endif
    If func AFNC.ACTIV("RED")<1
      Chgfmt [M:BPC4]XREP0 With "-K:" + num$(GLONREP) + "x"
    Endif
  #--- Issue 106137
  Endif

Return

####################################################################
$FERME
## FGR 14/10/2014 : X3SUIVI101807 : On ne conserve que le mode optimisé.
## FGR 29/07/2014 : X3SUIVI100229 (début)
#  If dim(GBPCADDOPT) >= 0 Then
#    Kill GBPCADDOPT
#  Endif
## FGR 29/07/2014 : X3SUIVI100229 (fin)


  If GFONC1="GESBPC" Raz GFONC1 : Endif

  # FGR 27/12/2007 X3SUIVI43576 : en import on passe pas par $OUVRE alors tester
  #                l'existance des variables
  If dim(WNBGAUCHE) >= 0 Then
    GNBGAUCHE = WNBGAUCHE
  Endif

  #Nettoie les infos relative à la famille statistique de produits
  #Call UNUSEFAMCIA From CRM_UTIL

  #CRM
  Gosub FERME_CRM From TRTBPCRM

  # FGR 27/12/2007 X3SUIVI43576 : en import on passe pas par $OUVRE alors tester
  #                l'existance des variables
  If dim(GORITRFBPP) >= 0 Then
    Raz GORITRFBPP
  Endif
  If dim(GIBPCEXIST) >= 0 Then
    Kill GIBPCEXIST
  Endif
  If dim(GBPC2TITTOK) >= 0 Then
    Kill GBPC2TITTOK
  Endif
  #----- Restitution variables globales -----#
  Gosub REST_GLOB From TRTX3GLOB
  #-----
Return

####################################################################
$SETBOUT
Local Integer FL_ITU

  # Si on vient de la gestion des prospects : On veut transformer le prospect en client
  # Si on veut transformer le prospect en client depuis les commandes
  # --> Il faut forcer le bouton enregistrer et rendre les masques invalides
  # --> Il faut supprimer les accès aux autres enregistrements
  If (GNAVIG(max(GPILNAV-1,1)) = "GESBPP" & GREP="" & [F:BPC]BPCTYP = 4) | GORITRFBPP <> ""
    # 45030 : Interdire la tranformation si l'utilisateur n'a pas le droit de creer des clients
    If instr(1,CHAINE,"C")<>0
      REP = "M"
      GREP = "M"
      Setmok [M:BPC0] With 0
      Setmok [M:BPC1] With 0
      Setmok [M:BPC2] With 0
      Setmok [M:BPC3] With 0
      Setmok [M:BPC4] With 0
      #Grizo [BPC0]BPCNUM      # FGR 13/02/2015 : X3SUIVI101747 (début) : dans tous les cas la clé n'est pas modifiable dans ce contexte
    Else
      Call ERREUR(mess(7,123,1)) From GESECRAN : # Modification impossible
      Return
    Endif
    # on active le bouton article-clients que si des articles sont dipsonibles.
  Endif
  # FGR 13/02/2015 : X3SUIVI101747 (début) : dans tous les cas la clé n'est pas modifiable dans ce contexte
  If (GNAVIG(max(GPILNAV-1,1)) = "GESBPP" & GREP="") | GORITRFBPP <> ""
    Grizo [BPC0]BPCNUM
  Endif
  # FGR 13/02/2015 : X3SUIVI101747 (fin)

  # ------------------------------------------------------------------------------------- #
  # Suppression des boutons                                                               #
  # ------------------------------------------------------------------------------------- #
  #     H : Changement de code                                                            #
  #     A : Supprimer                                                                     #
  #     2 : Tarif      : Si aucun enr. courant ou si pas le module vente                  #
  #                      Si écran visu tarif déjà ouvert                                  #
  #                      Si client en cours de saisie                                     #
  # ------------------------------------------------------------------------------------- #
  If GNAVIG(max(GPILNAV-1,1)) = "GESBPP" | GORITRFBPP<>""
    #Call VIREBOUT(CHAINE,"ARCDHM<>09") From GOBJET  # FGR 13/02/2015 : X3SUIVI101747
    Call VIREBOUT(CHAINE,"ARCDH<>09") From GOBJET    # FGR 13/02/2015 : X3SUIVI101747 : on doit pouvoir modifier le client une fois enregistré
    Call VIREBOUT(CHAINE,"S") From GOBJET
    Call VIREBOUT(CHAINE,"2") From GOBJET
    Return
  Endif
  If !CLECUR
    Call VIREBOUT(CHAINE,"2") From GOBJET
  Endif
  If GMODU(5) <>2 | clalev([M:SPV1])>0
    Call VIREBOUT(CHAINE,"2") From GOBJET
  Endif
  If GREP<>""
    Call VIREBOUT(CHAINE,"2") From GOBJET
  Endif

  # ---------------------------------------------------------------------------------------#
  # Activation/Désactivation des menus                                                     #
  # ---------------------------------------------------------------------------------------#
  # F,H : Texte                 : Actif si client en ligne ou création ou duplication      #
  #   J : Effets non echu1      : Actif si client en ligne                                 #
  #   K : Effets non echu2      : Actif si client en ligne                                 #
  #   L : Effets non echu3      : Actif si client en ligne                                 #
  #   M : Impayés               : Actif si client en ligne                                 #
  #   R : Prorogations          : Actif si client en ligne                                 #
  #   T : Consultation devis    : Actif si client en ligne                                 #
  #   è : Consultation commande : Actif si client en ligne                                 #
  #   0 : Consultation livraison: Actif si client en ligne                                 #
  #   9 : Consultation facture  : Actif si client en ligne                                 #
  #   [ : Consultation retour   : Actif si client en ligne                                 # SYMEU 27/10/2008
  #   I : Consultation compte   : Actif si client en ligne                                 #
  #   N : Consultation parc     : Actif si rien en cours, module support client            #
  #   ù : Consultation parc/adresse: Actif si rien en cours, module support client         #
  #   O : Consult Situation client : Actif client en ligne                                 #
  #   Q : Consult Analyse risque   : Actif client en ligne                                 #
  #   S : Consult Dern Opération   : Actif client en ligne                                 #
  #   U : Consult Balance âgée  : Actif client en ligne                                    #
  #   P : Associer donneur ordre: Actif si rien en cours, module support client            #
  #   5 : Secteurs de marché    : Actif si rien en cours, module action commerciale        #
  #   X : Historique            : Actif si rien en cours                                   #
  #                                                                                        #
  #   D : affaires client                                                                  #
  #   E : commandes                                                                        #
  #   G : devis                                                                            #
  # ---------------------------------------------------------------------------------------#
  If func AFNC.ACTIV("SEPP") and dim([M:BPC3]SEBPC) > 0                             #SEPP.sn
    If find(GREP,"C","D") or (CLECUR and [M:BPC2]BPCTYP=2)
      Grizo [M:BPC3]SEBPC
    Else
      Actzo [M:BPC3]SEBPC
    Endif
  Endif                                                                             #SEPP.en
  If GACTFTC=2 & (find(GREP,"C","D")|CLECUR)
    CHMEN += "FH"
  Endif
  #--CPO 79235 En modification on désactive les menus
  If GREP<>"M"
    If CLECUR
      CHMEN += "JKLMRIOQSU"
    Endif
    If CLECUR & GACTFTC=2
      CHMEN += "Tè09D["
    Endif    #MAE, EVOL_ERGO, ajout de D et E et G; SYMEU ajout [
    If CLECUR & GACTFTC=2 & [M:BPC0]BPCSTA =2
      CHMEN += "EG1"
    Endif
    If CLECUR & GACTFTC=2
      CHMEN += "ABV§]"
    Endif    #MAE, bg 84102 remplacement de C par §

    #Support client
    If REP="" & GMODU(12)=2 & GACTFTC=2
      CHMEN += "ZùP%?µàç"   # FGR 24/11/2014 : X3SUIVI60482 : "Z" pour consultation contrats de service.
    Endif

    # FGR 08/04/2010 : X3SUIVI63854 : on active c'est une autre fonction
    #Historique
    # FGR 10/08/2009 : X3SUIVI56700 : Toujours actif qq soit le module
    If REP = "" Then
      CHMEN += "X"
    Endif

    #Menu Actions   Module Action Co
    # } : Enregistrer un rendez-vous
    # { : Enregistrer un appel
    # ~ : Enregistrer une tâche
    # ! : Enregistrer une affaire
    # ) : Planifier un rendez-vous
    # ( : Planifier un appel
    # £ : Planifier une tâche

    If REP="" & GMODU(13)=2 & GACTFTC=2
      CHMEN += "}{~!)(£5"
    Endif
  Endif #--/CPO

  # STANT on grise le bouton articles-client si le client n'a pas d'article.
  If !clalev([F:ITU])Then
    Local File ITMBPC [ITU] Where BPCNUM =[M:BPC0]BPCNUM
    FL_ITU =1
  Else
    Filter [F:ITU] Where BPCNUM =[M:BPC0]BPCNUM
  Endif
  If rowcount([F:ITU]) = 0 Then
    Call VIREBOUT(CHAINE,"7") From GOBJET
  Endif
  If FL_ITU
    Close File [F:ITU]
  Endif
  Filter[F:ITU]

  #-------------------------------------
  Gosub SET_BOUT_SPE From GSAISIE
  Call VIREBOUT (CHAINE,"AH") From GOBJET
Return

