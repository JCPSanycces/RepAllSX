Gosub GRIZE_LIENS

#---- lecture des contacts et chargement CNT                      #
#Call CHARG_CNT (GABREV,[M:BPC0]BPCNUM,1,[F:BPR]CNTNAM) From TRTADR
If !GIMPORT Gosub RELIT From GOBJSUB : Endif

#MAE, bg62889 Mise à jour du client dont l'enregistrement est tiers risque
If WMAJRISK = 1
   If !clalev([F:BPC1]) : Local File BPCUSTOMER [BPC1] : Endif
   # Recherche si le client est un tiers risque
   Filter [BPC1] Where [F:BPC1]BPCRSK=[M]BPCNUM & [F:BPC1]BPCNUM<>[M]BPCNUM
   For[BPC1]
    Update [BPC] Where [F:BPC]BPCNUM = [F:BPC1]BPCNUM With OSTCTL=[M:BPC2]OSTCTL, OSTAUZ = [M:BPC2]WOSTAUZ,
&        CDTISR = [M:BPC2]WCDTISR,CDTISRDAT =[M:BPC2]CDTISRDAT
       If fstat
        GOK = 0 : Call FSTA("BPC") From GLOCK
       Endif
    Next
    Filter [BPC1]
Endif

Gosub FIN_GILOCKBPR  # FGR 16/03/2012 : X3SUIVI81335
Return

