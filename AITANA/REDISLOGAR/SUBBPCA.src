# FGR 29/07/2014 : X3SUIVI100229 (début)
########################################
$ANNBPD
Local Integer WRET
#MAE, bg 70777
Local Char CLE_TO_DEL(GLONBPC+GLONADR)
Local Integer ILINBPD

  # Suppression des clients livrés avec test des locks
  For [BPD]BPD0 Where [F:BPD]BPCNUM=[M:BPC0]BPCNUM
    #- Si le client livré n'existe plus, suppression des textes associés
    ILINBPD = find([F:BPD]BPAADD,[M]BPAADD(0..[M]NBDLV-1))
    If GREP <> "M" | !ILINBPD
      If [F:BPD]PRPTEX <> ""
        Call SUP_CLOB([F:BPD]PRPTEX,WRET) From TRTX3TEX
      Endif
      If [F:BPD]DLVTEX <> ""
        Call SUP_CLOB([F:BPD]DLVTEX,WRET) From TRTX3TEX
      Endif
      # ------------------------------------------------
      #If GREP  = "M" and dim(GBPCADDOPT) >= 0 and !ILINBPD Then
      If GREP  = "M" and !ILINBPD Then   # FGR 14/10/2014 : X3SUIVI101807 : On ne conserve que le mode optimisé.
        # Si on est en modification, en mode optimisé et que l'adresse n'est plus à l'écran : on la supprime
        Gosub DELETE_BPD1
        If GOK < 0 Then
          Break
        Endif
      Endif
    Endif
    # FGR 14/10/2014 : X3SUIVI101807 : On ne conserve que le mode optimisé.
    #      If dim(GBPCADDOPT) < 0 Then
    #        #- Suppression du client livré : Toujours en cas de suppression
    #        Gosub DELETE_BPD1
    #        If GOK < 0 Then
    #          Break
    #        Endif
    #      Endif
  Next
Return

########################################
$DELETE_BPD1
  #- Suppression du client livré
  Delete [BPD1] Where [F:BPD1]BPCNUM=[F:BPD]BPCNUM & [F:BPD1]BPAADD=[F:BPD]BPAADD
  If fstat = 1 Then
    CLE_TO_DEL = [F:BPD]BPCNUM + [F:BPD]BPAADD
    GOK = -1
    GLOCK = "$BPDLVCUST"-CLE_TO_DEL
    Return
  Endif
Return
# FGR 29/07/2014 : X3SUIVI100229 (fin)

########################################
$VERIFCRE_MOD
Local  Integer  MATCH_BPAADD
Local  Integer I
Local Integer NE # FGR 21/08/2015 : X3SUIVI110041

MATCH_BPAADD = 1

  # FGR 16/07/2008 : X3SUIVI48366 : La catégorie est obligatoire
  If [M:BPC0]BCGCOD = "" and find(GREP,"C","D") Then
    GERR = 1
    GMESSAGE = mess(535,199,1)
    OK = 0
    zonsui = "BCGCOD"
    Return
  Endif
  If [M:BPC0]BCGCOD <> [F:BPR1]BRGCOD & [M:BPC0]BCGCOD <>"" & [F:BPR1]BRGCOD <> "" and find(GREP,"C","D")
          Call AVERTIR(mess(104,187,1)+" "+[F:BPR1]BRGCOD + ". "+mess(623,196,1),OK) From GESECRAN
          If OK<>2
            zonsui ="BCGCOD"
          Endif
   Endif

  # FGR 22/07/2013 : X3SUIVI87923 (début)
  If func SUBBPC.CTRL_PTE_SEPA([M:BPC3]PTE) = 1 Then
    GERR = 1
    OK = 0
    Return
  Endif
  # FGR 22/07/2013 : X3SUIVI87923 (fin)

  #----------------------------------#
  # on verifie qu'une adresse existe #
  #----------------------------------#
  If [M:BPAC]NBADR = 0
    GERR=1: GMESSAGE = mess(31,199,1) : OK = 0 : Return
  Endif
  #---------------------------------------------------#
  # on verifie qu une adresse est désignée par défaut #
  #---------------------------------------------------#
  If find (2,[M:BPAC]BPAADDFLG (0..[M:BPAC]NBADR -1)) = 0
    GERR=1 : GMESSAGE = mess(110,199,1) : OK = 0 : Return
  Endif
  #---------------------------------------------------------------------#
  # verif code adresse existe pour tous les clients livrés en dupli     #
  #---------------------------------------------------------------------#
  If GACTFTC=2
    If GREP="D"
      For NOL = 0 To [M:BPC4]NBDLV-1
        MATCH_BPAADD = find([M:BPC4]BPAADD(NOL),[M:BPAC]CODADR(0..[M:BPAC]NBADR-1))
        If MATCH_BPAADD = 0
          GERR=1 : GMESSAGE = mess(42,191,1)-":"-mess(16,199,1) : OK = 0 : Return
        Endif
      Next NOL
    Endif
    # Si le tiers est un site
    If [M:BPRC]FCY <> ""
      # --> on vérifie que les sites réceptions sont renseignés dans les clts livrés
      # --------------------------------------
      # FGR 21/08/2015 : X3SUIVI110041 (debut)
      #      #MAE, bg 70408
      #      #If find("",[M:BPC4]RCPFCY(0..[M:BPC4]NBDLV-1))
      #      I = find("",[M:BPC4]RCPFCY(0..[M:BPC4]NBDLV-1))
      #        # Bug 33874
      #        #           Local Integer WOK : WOK=1
      #        #           Call AVERTIR(mess(485,199,1),WOK) From GESECRAN
      #        #           If WOK=1 OK=0 : Return Endif
      #      If [M:BPC4]ENAFLG(I) & I<>0
      #        GERR=1 : GMESSAGE = mess(485,199,1) : OK = 0 : Return
      #      Endif
      I = 0
      Repeat
        NE = I
        I = find("",[M:BPC4]RCPFCY(NE..[M:BPC4]NBDLV-1))
        If I > 0 Then
          I = I + NE
          If [M:BPC4]ENAFLG(I-1) = [V]CST_AYES Then
            GERR = 1
            GMESSAGE = mess(485,199,1) - "(" + mess(3,61,1) - num$(I) - mess(33,102,1) - ": '" + [M:BPC4]BPAADD(I-1) + "'" + ")"
            OK = 0
            Break
          Endif
        Endif
      Until I <= 0
      If GERR = 1 Then
        Return
      Endif
      # FGR 21/08/2015 : X3SUIVI110041 (fin)
      # --------------------------------------
      # --> on va réécrire les adresses les RIB et les contacts du site
      GERR=3:GMESSAGE=mess(178,196,1)
    Endif
  Endif
  #--------------------------------------------------------------------#
  # En import, on verifie que l'adresse client facture est renseignée  #
  #            on verifie que l'adresse tiers  payeur  est renseignée  #
  #--------------------------------------------------------------------#
  If GIMPORT
    #--------------------------------------
    # FGR 19/02/2010 : X3SUIVI62660 (début)
    # 1°) si le code adresse n'est pas alimenté et qu'on a identité avec [M:BPC0]BPCNUM
    #                    =>on prend l'adresse par défaut
    MATCH_BPAADD = find (2, [M:BPAC]BPAADDFLG (0..[M:BPAC]NBADR-1)) # Rang de l'adresse par défaut
    If [M:BPC3]BPAINV = "" Then
      If [M:BPC3]BPCINV = [M:BPC0]BPCNUM Then
        [M:BPC3]BPAINV = [M:BPAC]CODADR(MATCH_BPAADD-1)
      Endif
    Endif
    If [M:BPC3]BPAPYR = "" Then
      If [M:BPC3]BPCPYR = [M:BPC0]BPCNUM Then
        [M:BPC3]BPAPYR = [M:BPAC]CODADR(MATCH_BPAADD-1)
      Endif
    Endif
    # 2°) si le code adresse n'est pas alimenté et qu'on n'a pas identité avec [M:BPC0]BPCNUM
    #                    =>on prend l'adresse par défaut du CLIENT INDIQUE
    #     Note FGR : c'est normalement traité en action sur champ. Mais si les deux rubriques (ei BPCINV/BPAINV) figurent
    #                dans le fichie importé est que l'adresse est "", alors on se retrouverait dans ce cas.
    #                C'est pour ça que je le "retraite" ici.
    If [M:BPC3]BPAINV = "" Then
      If [M:BPC3]BPCINV <> [M:BPC0]BPCNUM Then
        Read [BPC1]BPC0=[M:BPC3]BPCINV
        [M:BPC3]BPAINV = [F:BPC1]BPAADD
      Endif
    Endif
    If [M:BPC3]BPAPYR = "" Then
      If [M:BPC3]BPCPYR <> [M:BPC0]BPCNUM Then
        Read [BPC1]BPC0=[M:BPC3]BPCPYR
        [M:BPC3]BPAPYR = [F:BPC1]BPAADD
      Endif
    Endif
    # FGR 19/02/2010 : X3SUIVI62660 (fin)
    #-------------------------------------
    #MATCH_BPAADD = find([M:BPC3]BPAINV,[M:BPAC]CODADR(0..[M:BPAC]NBADR-1))
    If [M:BPC3]BPAINV = "" : MATCH_BPAADD = 0 : Endif
    If MATCH_BPAADD = 0 GERR=1 : GMESSAGE = mess(521,199,1) : OK = 0 : Return : Endif
    #MATCH_BPAADD = find([M:BPC3]BPAPYR,[M:BPAC]CODADR(0..[M:BPAC]NBADR-1))
    If [M:BPC3]BPAPYR = "" : MATCH_BPAADD = 0 : Endif
    If MATCH_BPAADD = 0 GERR=1 : GMESSAGE = mess(522,199,1) : OK = 0 : Return : Endif
  Endif
  #Modif CRM    24 Septembre 2003
  #Gestion des points
  If type([M:BPC2]PITCDT) > 0 & dim([M:BPC2]PITCPT)>0
    [M:BPC2]TOTPIT = [M:BPC2]PITCDT + [M:BPC2]PITCPT
    Affzo [M:BPC2]TOTPIT
  Endif
 #MAE, bg 73682, sauvegarde de BPCUSTOMER pr remettre les champs de travail dans BPC
# [F:BPCS]=[F:BPC]   # hcb 106448
Return

########################################
$TRT_FOOT
Local Integer NBPOSTE
If GACTFTC=2
   If [M:BPC1]NBFAC = 0
      NBPOSTE = dim ([M:BPC1]INVDTA)
      Call  SAISFOOT (1,"BPC1",NBPOSTE,[M:BPC2]CHGTYP,GSYSCUR,[M:BPRC]CUR,"NON") From SUBSFIT
      [M:BPC1]NBFAC = NBPOSTE
   Endif
   # chargement devise client sur ligne montant
   For nolign = 0 To [M:BPC1]NBFAC-1
      If [M:BPC1]AMTCOD(nolign) = 2
         [M:BPC1]WWCUR(nolign)  = [M:BPRC]CUR
      Endif
   Next
Endif
Return

####################################################################
$FILTRE
Default File [BPC]
# Dans la gestion des devis, il faut avoir accès aux prospects
# Dans la gestion des prospects, il faut avoir accès aux prospects pour la transformation
# Dans la gestion des commandes, il faut avoir accès aux prospects
# FGR 12/03/2014 : X3SUIVI69847
#If !find(GFONCTION,"GESSPL","GESSQH","GESBPP","CONSCSQ") & GFONC1 <> "GESSOH"
#Gbn-103035-Add CONCSL/FUNGRHSQH1/FUNGRHSQ3 in the scope.
If !find(GFONCTION,"GESSPL","GESSQH","GESBPP","CONSCSQ","CONSCSL","FUNGRHSQH1","FUNGRHSQH3") & GFONC1 <> "GESSOH" and (GFONC1 <> "GESSQH" and GORITRFBPP <> "GESSQH")
    FILTSUP = "BPCTYP <> 4"
Endif
If GPILNAV>1 & GPILNAV<dim(GNAVIG)+1
    If GNAVIG(max(GPILNAV-1,1)) = "GESBPP"
        FILTSUP = "1=1"
    Endif
Endif
Return

####################################################################
$FILGAUCHE
FILGAUCHE = "BPCTYP <> 4"

If GNAVIG(max(GPILNAV-1,1)) = "GESBPP"
    FILTSUP = "1=1"
Endif

Return

