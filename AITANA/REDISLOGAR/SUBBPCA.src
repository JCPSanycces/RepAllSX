Gosub ALIM_OST
#---- chargt tableau des elements de facturation
Gosub TRT_FOOT

#-----------------------------#
# Chargement tableau des axes #
#-----------------------------#
If dim([M:BPC3]NBAXE)>0
  #If dim([M:BPC0]SOC)>0 & [M:BPC0]SOC<>""
  #  Call CHARG_DIE(2,[M:BPC0]SOC,"BPC3","NBAXE") From TRTX3CPT
  #Else
  #  Call CHARG_DIE(2,"","BPC3","NBAXE") From TRTX3CPT
  #Endif
  Call CHARG_DIE(2,GSOCIETE,"BPC3","NBAXE") From TRTX3CPT
Endif


Default Mask [BPAC]
Call CHARG_BPA(WBPATYP,[M:BPC0]BPCNUM,[F:BPC]BPAADD) From TRTBPA
Default Mask [BIDC]
Call CHARG_RIB(WBPATYP,[M:BPC0]BPCNUM,"~") From TRTBPA
Default Mask [CNTC]
Call CHARG_CNT(WBPATYP,[M:BPC0]BPCNUM,[F:BPC]CNTNAM) From TRTBPA
Gosub DEFAUT

If GACTFTC=2
   #---- lecture des clients livrés et chargement BPC4
   Raz [M:BPC4]
   # chargement du tableau
   nolign = 0
   For [BPD]BPD0 Where [F]BPCNUM = [M:BPC0]BPCNUM
         ## SAM 118404 - Gestion du nombre d'adresses en fiche clients LC-23/11/16
      If nolign>=dim([M:BPC4]FLMOD)
          Break
      Endif
      ## End SAM 118404
      nolign            += 1
      [M:BPC4]           = [F:BPD]
      [M:BPC4]FLMOD(nolign-1) = 0      # FGR 04/05/2014 : X3SUIVI108031 : pas ([M]XNUMLIG) # FGR 21/12/2010 : X3SUIVI70104
      [M:BPC4]BPDNAM0(nolign-1) = [F:BPD]BPDNAM(0)
      [M:BPC4]BPDNAM1(nolign-1) = [F:BPD]BPDNAM(1)
      [M:BPC4]VACBPD(nolign-1)  = [F:BPD]VACBPR
      If dim([M:BPC4]SSTENTCOD) > 0 [M:BPC4]SSTENTCOD(nolign-1) = [F:BPD]SSTENTCOD Endif

      If [M:BPC4]LAN(nolign-1)="" [M:BPC4]LAN(nolign-1)=[M:BPRC]LAN Endif
      # Le régime de taxe ne doit pas être initialisé à partir du client
      #If [M:BPC4]VACBPD(nolign-1)="" [M:BPC4]VACBPD(nolign-1)=[M:BPC3]VACBPR Endif
      If dim([M:BPC4]REP0) > 0 [M:BPC4]REP0(nolign-1) = [F:BPD]REP(0) Endif
      If dim([M:BPC4]REP1) > 0 [M:BPC4]REP1(nolign-1) = [F:BPD]REP(1) Endif
      I=find([M:BPC4]BPAADD(nolign-1),[M:BPAC]CODADR(0..[M:BPAC]NBADR-1))
      If I<>0
          [M]BPADES(nolign-1)=[M:BPAC]BPADES(I-1)
          [M]BPDCRY(nolign-1)=[M:BPAC]BPACRY(I-1) : [M]BPDPOSCOD(nolign-1)=[M:BPAC]POSCOD(I-1)
      Endif
      [M:BPC4]BPDADDFLG(nolign-1)= 1
      If [F:BPD]BPAADD=[F:BPC]BPDADD [M:BPC4]BPDADDFLG(nolign-1)= 2 Endif
   Next
   [M:BPC4]NBDLV          = nolign

   # chargement de la fiche
   [M]XENAFLG      = [M]ENAFLG(0)
   [M]XBPDADDFLG   = [M]BPDADDFLG(0)
   [M]XBPAADD      = [M]BPAADD(0)
   [M]XBPADES      = [M]BPADES(0)
#  #LSE 05/10/2006 FQ36055
#  #[M]XBPDNAM(0)    = [M]BPDNAM0(0)
   [M]XBPDNAM0     = [M]BPDNAM0(0)
#  #[M]XBPDNAM(1)   = [M]BPDNAM1(0)
   [M]XBPDNAM1     = [M]BPDNAM1(0)

   [M]XVACBPR      = [M]VACBPD(0)

   If dim([M]XSSTENTCOD) > 0
     [M]XSSTENTCOD = [M]SSTENTCOD(0)
     #When ENTCOD field exists, hide it and ShortDescript if the country is unsupported by SST
     If !(func TRTADRLIB.CHKADR_CRY([M]BPDCRY(0)))
       Chgfmt [M:BPC4]XSSTENTCOD  With "-K:5B" # Hide an enterable field {specify M:BPC4 for chgfmt}
       Chgfmt [M:BPC4]ZXSSTENTCOD With "-KP:12X"
     Else
       Chgfmt [M:BPC4]XSSTENTCOD  With "K:5B" # Show and enterable field
       Chgfmt [M:BPC4]ZXSSTENTCOD With "KP:12X" # Protected
     Endif
   Endif

   [M]XLAN         = [M]LAN(0)

   [M]XSTOFCY      = [M]STOFCY(0)
   [M]XRCPFCY      = [M]RCPFCY(0)
   If dim([M]XBPCLOC)>0
     [M]XBPCLOC    = [M]BPCLOC(0)
   Endif
   If dim([M]XSCOLOC)>0
     [M]XSCOLOC    = [M]SCOLOC(0)
   Endif
   [M]XDRN         = [M]DRN(0)
   [M]XDLVPIO      = [M]DLVPIO(0)
   [M]XBPTNUM      = [M]BPTNUM(0)
   [M]XMDL         = [M]MDL(0)
   [M]XDAYLTI      = [M]DAYLTI(0)

   [M]XEECICT      = [M]EECICT(0)
   [M]XICTCTY      = [M]ICTCTY(0)
   [M]XBPDCRY      = [M]BPDCRY(0)  : [M]XBPDPOSCOD = [M]BPDPOSCOD(0)
   [M]XFFWNUM      = [M]FFWNUM(0)  : [M]XFFWADD    = [M]FFWADD(0)

   [M]XUVYDAY1     = [M]UVYDAY1(0) : [M]XUVYDAY2     = [M]UVYDAY2(0)
   [M]XUVYDAY3     = [M]UVYDAY3(0) : [M]XUVYDAY4     = [M]UVYDAY4(0)
   [M]XUVYDAY5     = [M]UVYDAY5(0) : [M]XUVYDAY6     = [M]UVYDAY6(0)
   [M]XUVYDAY7     = [M]UVYDAY7(0)
   [M]XUVYCOD      = [M]UVYCOD(0)
   # Bloc soumis au code activité DEB
   If dim([M]XEECLOC)>0
      [M]XEECLOC      = [M]EECLOC(0)
      [M]XEECINCRAT   = [M]EECINCRAT(0)
      [M]XEECNUM      = [M]EECNUM(0)
   Endif
   [M]XNPRFLG      = [M]NPRFLG(0) : [M]XNDEFLG      = [M]NDEFLG(0)
   [M]XPRPTEX      = [M]PRPTEX(0) : [M]XDLVTEX      = [M]DLVTEX(0)
#MAE, bg 51481
   #[M]WPRPTEX = 2
   #If [M]XPRPTEX = "" [M]WPRPTEX = 1 Endif
   #[M]WDLVTEX = 2
   #If [M]XDLVTEX = "" [M]WDLVTEX = 1 Endif
   [M]TWPRPTEX = 2
   If [M]XPRPTEX = "" [M]TWPRPTEX = 1 Endif
   [M]TWDLVTEX = 2
   If [M]XDLVTEX = "" [M]TWDLVTEX = 1 Endif


#  #LSE 05/10/2006 FQ36055
   # Particularité pour le représentant (nb par code activité)
#  #If dim([M:BPC4]XREP(0)) > 0 [M:BPC4]XREP(0) = [M:BPC4]REP0(0) Endif
#  #If dim([M:BPC4]XREP(1)) > 1 [M:BPC4]XREP(1) = [M:BPC4]REP1(0) Endif
   If func AFNC.ACTIV("RED")>0
       [M:BPC4]XREP0 = [M:BPC4]REP0(0)
   Endif
   If func AFNC.ACTIV("RED")>1
       [M:BPC4]XREP1 = [M:BPC4]REP1(0)
   Endif

Endif

#LSE 02/03/2007
#Gosub GRIZE_LIENS

# Si on vient des prospects, transformation du prospect en client
# FGR 03/02/2010 : X3SUIVI62170
#If GNAVIG(max(GPILNAV-1,1)) = "GESBPP" | GORITRFBPP<>""
If (GNAVIG(max(GPILNAV-1,1)) = "GESBPP" and SZOBPP = "GESBPP") | GORITRFBPP<>""
    Call TRSF_BPP_BPC([M:BPC0]BPCNUM,"") From SUBBPCB
Endif

#LSE 02/03/2007
##---------------------------------------------------#
##Modif CRM 10/01/2002
#If GACTFTC=2 & GMODU(13) = 2
#    Call SETPREREP("BPC") From TRTMST4
#Endif
##---------------------------------------------------#

#---------------------------------------------------#
#Modif CRM 01/07/2003
If GACTFTC=2 & GMODU(13) = 2
    #Affichage de la présence de représentants secondaires.
    [M:BPC1]MORREP = ""
    Filter [RSE] Where [F:RSE]BPCNUM = [M:BPC0]BPCNUM
    For [RSE]
        [M:BPC1]MORREP = "+"
        Break
    Next
    Filter [RSE]
    Affzo [M:BPC1]MORREP
Endif
#---------------------------------------------------#

#---------------------------------------------------#
#Modif CRM 25/09/2003
#Charge les points à débiter
Call LOADPIT([M:BPC0]BPCNUM) From SUBBPCB

## Localisations Argentines
If dim([M:BPC3]NBPRV) >= 0
 Local Integer VU
 If [M:BPC3]NBPRV = 0
  [M:BPC3]NBPRV = len(mess(0,8500,1))
 Endif
 Filter [ADI] Where NUMTAB = 364
 nolign = 0
 For [ADI]CODE
  nolign += 1
  [M:BPC3]SATTAX(nolign-1) = [F:ADI]CODE
  Call LECTEXTRA([M]DESSAT(nolign-1),"ATABDIV","LNGDES",num$(364),[F:ADI]CODE) From ATEXTRA
  [M:BPC3]XTYPAPL(nolign-1) = [F:ADI]N1
  [M:BPC3]TYPAPL(nolign-1) = mess([F:ADI]N1,8500,1)
  VU = find([F:ADI]CODE,[F:BPC]SATTAX(0..dim([F:BPC]SATTAX)-1))
  If VU
   [M:BPC3]FLGSATTAX(nolign-1) = [F:BPC]FLGSATTAX(VU-1)
  Endif
 Next
 Filter [ADI]
 If [F:BPC]AGTSATTAX <> 2
  Grizo [M:BPC3]NBPRV : Grizo [M:BPC3]SATTAX : Grizo [M:BPC3]DESSAT : Grizo [M:BPC3]TYPAPL : Grizo [M:BPC3]FLGSATTAX
 Else
  Actzo [M:BPC3]NBPRV : Actzo [M:BPC3]SATTAX : Actzo [M:BPC3]DESSAT : Actzo [M:BPC3]TYPAPL : Actzo [M:BPC3]FLGSATTAX
 Endif
Endif

If dim([M:BPC3]GRP)>0
  ## Champs relances
  [M:BPC3]FUPCUR = GCUR
  If [M:BPC3]GRP=""
    Raz [M:BPC3]FUPMINAMT : Raz [M:BPC3]FUPCUR
    [M]FUPTYP=1
    Grizo [M:BPC3]FUPTYP, FUPMINAMT
    Affzo [M:BPC3]FUPTYP, FUPMINAMT
  Else
    Actzo [M:BPC3]FUPTYP, FUPMINAMT
    Affzo [M:BPC3]FUPTYP, FUPMINAMT
  Endif

Endif

#MAE, lecture du tiers pour les workflows, ne pas écraser, bg 67131
If !GIMPORT & GWEBSERV<>1
  If !clalev([F:BPRW]) : Local File BPARTNER [BPRW] : Endif
  If [M:BPC0]BPCNUM <> ""
    Read [BPRW]BPR0 = [M:BPC0]BPCNUM
    If fstat Raz [F:BPRW] Endif
  Endif
Endif


#Initialisation CRM
Gosub LIENS_CRM From TRTBPCRM

# 09/07/12 Payment days in customer function SAM #82280
Gosub LIENS From TRTPDCLIB

Gosub GRIZE_LIENS

For nolign=1 To [M:BIDC]NBRIB
 [M:BIDC]OBIDBPAADD(nolign-1) = [M:BIDC]BIDBPAADD(nolign-1)
 [M:BIDC]OBIDNUM(nolign-1) = [M:BIDC]BIDNUM(nolign-1)
 If [L]VII : [M:BIDC]OBICCOD(nolign-1) = [M:BIDC]BICCOD(nolign-1) : Endif
Next

#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
If func AFNC.ACTIV("KPO")
  J = 0
  For I = 0 To dim([F:BPC]CSHVATRGM)-1
    If [F:BPC]CSHVATRGM(I) <> 0
      J += 1
    Endif
  Next
  [M:BPC3]NBVAT = max(J,0)

  Call VALIDATE_CSHVATRGM_CRY ([M:BPRC]CRY) From PORLEGLIB
Endif
#94635 RICAR 2014/04/21 - CASH VAT - END
Return

####################################################################
#------------------------------------------------------------#
# Alimentation des champs relatifs à l'encours               #
#------------------------------------------------------------#
$ALIM_OST
Local Decimal ENCOURS : Raz ENCOURS

# L'en-cours est géré sur le tiers risque
[M:BPC2]XCUR = GCUR
If [M]BPCRSK<>[M]BPCNUM
    # Le client n'est pas le tiers risque
    If [F:BPC1]BPCNUM<>[M]BPCRSK
        Read [BPC1]BPC0=[M]BPCRSK
        If fstat Raz [F:BPC1] Endif
    Endif
    [M:BPC2]OSTCTL=[F:BPC1]OSTCTL
    #---- conversion en-cours autorisé de devise dossier vers devise affichage (société ou société du site par défaut)
    WMONTORG (0) = [F:BPC1]OSTAUZ
    Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG (0),WMONTDES (0),SPSTAT) From TRTDEV
    If SPSTAT = 0
       [M:BPC2]WOSTAUZ    = arr(WMONTDES (0),WDECIMAL)
    Else
       [M:BPC2]WOSTAUZ    = [F:BPC1]OSTAUZ
    Endif
    If dim([M:BPC2]WCDTISR) <> -1
       #---- conversion assurance crédit de devise dossier vers devise affichage (société ou société du site par défaut)
       WMONTORG (0) = [F:BPC1]CDTISR
       Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG (0),WMONTDES (0),SPSTAT) From TRTDEV
       If SPSTAT = 0
          [M:BPC2]WCDTISR = arr(WMONTDES (0),WDECIMAL)
       Else
          [M:BPC2]WCDTISR = [F:BPC1]CDTISR
       Endif
    Endif
    [M:BPC2]CDTISRDAT=[F:BPC1]CDTISRDAT
Else
    # Le client est le tiers risque
    #---- conversion en-cours autorisé de devise dossier vers devise affichage (société ou société du site par défaut)
    WMONTORG (0) = [F:BPC]OSTAUZ
    Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG (0),WMONTDES (0),SPSTAT) From TRTDEV
    If SPSTAT = 0
       [M:BPC2]WOSTAUZ    = arr(WMONTDES (0),WDECIMAL)
    Else
       [M:BPC2]WOSTAUZ    = [F:BPC]OSTAUZ
    Endif
    If dim([M:BPC2]WCDTISR) <> -1
       #---- conversion assurance crédit de devise dossier vers devise affichage (société ou société du site par défaut)
       WMONTORG (0) = [F:BPC]CDTISR
       Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG (0),WMONTDES (0),SPSTAT) From TRTDEV
       If SPSTAT = 0
          [M:BPC2]WCDTISR = arr(WMONTDES (0),WDECIMAL)
       Else
          [M:BPC2]WCDTISR = [F:BPC]CDTISR
       Endif
    Endif
    [M:BPC2]CDTISRDAT=[F:BPC]CDTISRDAT
Endif
#MAE, bg 99911
[M:BPC2]WOSTAUZSAV=[M:BPC2]WOSTAUZ

# Calcul de l'en-cours
# FGR 05/02/2015 : X3SUIVI106017 : Annulation de la 103681. c'est faux.
## FGR 30/10/2014 : X3SUIVI103681 : Le calcul de l'encours ne doit pas être restreint à GSOCIETE. Il doit être global
#Local Char SVGSOCIETE(type(GSOCIETE)-10)
#
#SVGSOCIETE = GSOCIETE
#Raz GSOCIETE
#Call CALENC([M]BPCRSK, datesyst, ENCOURS) From TRTBPMVT
#GSOCIETE = SVGSOCIETE
#Raz SVGSOCIETE
Call CALENC([M]BPCRSK, datesyst, ENCOURS) From TRTBPMVT
[M]XOST=ENCOURS
Return

####################################################################
$DEFAUT
For MA=0 To NBMASK
 If AMA(MA)
  Gosub SETMASK From="WGO"+GABREV
 Endif
Next MA
Return

####################################################################
$GRIZE_BPC1
  # FGR 20/04/2012 : X3SUIVI81311
  If GACTFTC = 2 Then
     If dim(GNOTATI)>0 & GNOTATI=2 Then
        Actzo [M:BPC1]PRITYP
     Else
        Diszo [M:BPC1]PRITYP
     Endif
     If dim([M:BPC1]COMCAT)>0 Then
        If GCOMCAT=0
           Grizo [M:BPC1]COMCAT
        Else
           Actzo [M:BPC1]COMCAT
        Endif
     Endif
  Endif
Return

####################################################################
$GRIZE_LIENS
#------------------------------------------------------------#
# Activation/Desactivation des zones en fonction du contexte #
#------------------------------------------------------------#
  Gosub GRIZE_BPC1  # FGR 20/04/2012 : X3SUIVI81311
If GACTFTC=2
   If [M:BPRC]BETFCY = 2
      Actzo [M:BPRC]FCY
      Actzo [M:BPC4]XRCPFCY
   Else
      Grizo [M:BPRC]FCY
      Grizo [M:BPC4]XRCPFCY
   Endif
   If [M:BPC4]XFFWNUM="" Diszo [M:BPC4]XFFWADD Else Actzo [M:BPC4]XFFWADD Endif

    If [M:BPC4]XSTOFCY=""
        If dim([M:BPC4]XBPCLOC)>0 : Diszo [M:BPC4]XBPCLOC  : Endif
        If dim([M:BPC4]XSCOLOC)>0 : Diszo [M:BPC4]XSCOLOC  : Endif
    Else
        If dim([M:BPC4]XBPCLOC)>0 : Actzo [M:BPC4]XBPCLOC  : Endif
        If dim([M:BPC4]XSCOLOC)>0 : Actzo [M:BPC4]XSCOLOC  : Endif
    Endif
Endif


# Si le client est un tiers risque activation des champs concernant l'en-cours
# Si le client n'est pas un tiers risque désactivation des champs concernant l'en-cours
If [M]BPCNUM=[M]BPCRSK
    Actzo [M:BPC2]10
Else
    # Recherche si le client est un tiers risque
    Filter [BPC1] Where [F:BPC1]BPCRSK=[M]BPCNUM
    Look [BPC1]BPC0 First
    If fstat=0 Actzo [M:BPC2]10 Else Diszo [M:BPC2]10 Endif
    Filter [BPC1]
Endif

Diszo [M:BPC2]XOST

Return

###################################################################
$RAZCRE
# Issue 114621 - 2016-10-10 by MAE : si on vient du tiers, avec une catégorie client renseignée=>affectation de la catégorie
If GNAVIG(max(GPILNAV-1,1)) = "GESBPR" & (GREP = "" | GREP="C") and !GIMPORT Then
  If [M:BPR0]BRGCOD<>"" & [M:BPR0]BRGOBJ="BPC"
    [M:BPC0]BCGCOD = [M:BPR0]BRGCOD
  Endif
Endif
# End issue 114621
If [M:BPC0]BCGCOD<>"" & [M:BPRC]LAN=""
   Call INI_BCGCATEG([M:BPC0]BCGCOD) From SUBBPC
Endif

#If dim([M:BPR0]SOC)>0
#    GSOCIETE = [M:BPR0]SOC
#Endif

# Ne pas écraser les zones qui ont pu venir du tiers
If [M:BPRC]CRY = ""
   [M:BPRC]CRY = GPAYS
   If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
   If [F:TCY]CRY <> GPAYS
      Read [TCY]TCY0 = GPAYS
      If fstat Raz [F:TCY] Endif
   Endif
   [M:BPRC]LAN = [F:TCY]LAN
   [M:BPRC]CUR = [F:TCY]CUR
Endif

# Raz des zones mémoire de stockage des textes
Call RAZ_CLOB From ACLOB

If GACTFTC=2
   If GMODU(5)=2 [M:BPC1]PRITYP = GPRITYP Endif : # Bug 64308
   If [M:BPC1]PRITYP=0 [M:BPC1]PRITYP=1 Endif
   [M:BPC1]WORDTEX = 1
   [M:BPC1]WINVTEX = 1
   [M:BPC1]ORDTEX  = ""
   [M:BPC1]INVTEX  = ""
   #Affzo [M:BPC1]5,20
Endif

[M:BPC0]BPCSTA = 2
If dim([M:BPC2]BPCSNCDAT) >= 0 Then  # FGR 19/02/2015 : X3SUIVI106383 : Soumis à CA
  [M:BPC2]BPCSNCDAT = date$   # FGR 03/06/2010 : X3SUIVI64450
Endif
#---------------------------------------------------#
# init.  type entité en création pour le subbpa     #
#---------------------------------------------------#
[F:BPA]BPATYP = WBPATYP

#---------------------------------#
# Initialisation tableau des axes #
#---------------------------------#
If dim([M:BPC3]NBAXE)>0
  #If dim([M:BPC0]SOC)>0 & [M:BPC0]SOC<>""
  #  Call INIT_DIE(2,[M:BPC0]SOC,"BPC3","NBAXE") From TRTX3CPT
  #Else
  #  Call INIT_DIE(2,"","BPC3","NBAXE") From TRTX3CPT
  #Endif
  Call CHARG_DIE(2,GSOCIETE,"BPC3","NBAXE") From TRTX3CPT
Endif

## Localisations Argentines
If dim([M:BPC3]NBPRV) >= 0
 If [M:BPC3]NBPRV = 0
  [M:BPC3]NBPRV = len(mess(0,8500,1))
 Endif
 Filter [ADI] Where NUMTAB = 364
 nolign = 0
 For [ADI]CODE
  nolign += 1
  [M:BPC3]SATTAX(nolign-1) = [F:ADI]CODE
  Call LECTEXTRA([M]DESSAT(nolign-1),"ATABDIV","LNGDES",num$(364),[F:ADI]CODE) From ATEXTRA
  [M:BPC3]XTYPAPL(nolign-1) = [F:ADI]N1
  [M:BPC3]TYPAPL(nolign-1) = mess([F:ADI]N1,8500,1)
 Next
 If [F:BPC]AGTSATTAX <> 2
  Grizo [M:BPC3]NBPRV : Grizo [M:BPC3]SATTAX : Grizo [M:BPC3]DESSAT : Grizo [M:BPC3]TYPAPL : Grizo [M:BPC3]FLGSATTAX
 Else
  Actzo [M:BPC3]NBPRV : Actzo [M:BPC3]SATTAX : Actzo [M:BPC3]DESSAT : Actzo [M:BPC3]TYPAPL : Actzo [M:BPC3]FLGSATTAX
 Endif
 Filter [ADI]
Endif

#Affzo [M:BPRC]CRY, LAN, CUR
#Affzo [M:BPC2]BPCSTA
#Affzo [M:BPC3]1-99

#MAE, bg 49547
If GACTFTC=2
    Call DEFVALADI(425, [M:BPC2]BUS) From CRMUTIL140
Endif

#CRM
#Gosub RAZCRE_CRM From TRTBPCRM        # FGR 27/04/2016 : X3SUIVI116131 : trop tôt. A faire après l'application de la catégorie

#Affzo [M:BPC2]BUS

Gosub GRIZE_LIENS

# LTA.sn - 93205
If func AFNC.ACTIV("LTA")
  If dim([M:BPAC]XADRVAL)>0
    Chgfmt [M:BPAC]XADRVAL With "-LA:1"
    Chgfmt [M:BPAC]VALADR  With "-K:10X"
  Endif
Endif
# LTA.en - 93205

# BRBAN 26-09-2014 SAM#94635
If func AFNC.ACTIV("KPO")
  [M:BPC3]CSHVATRGM(0) = 1
  [M:BPC3]VATSTRDAT(0) = gdat$(1,1,2000)
  [M:BPC3]VATENDDAT(0) = [0/0/0]
  Affzo [M:BPC3]CSHVATRGM(0),VATSTRDAT(0),VATENDDAT(0)
Endif
# -
#NIBOW ZAF LEGISLATION JIRA# X3-1579
If func AFNC.ACTIV("ELINV")
  [M:BPC1]AEIFLG = [V]CST_ANO
  Affzo [M:BPC1]AEIFLG
Endif

If dim([M:BPC3]BELVATSUB)>0
 If [M:BPRC]CRY="BE" : [M:BPC3]BELVATSUB=2 : Else [M:BPC3]BELVATSUB=1 : Endif
Endif

#LSE 22/11/2006 FQ 38466
#Affichage des valeurs par défaut
#LSE 06/02/2007
Affzo [M:BPC0]1-99
Affzo [M:BPRC]1-99
If GACTFTC=2 Affzo [M:BPC1]1-99 Endif   : #--- Issue 106137
Affzo [M:BPC2]1-99
Affzo [M:BPC3]1-99
If GACTFTC=2 Affzo [M:BPC4]1-99 Endif   : #--- Issue 106137

If [M:BPC0]BCGCOD="" zonsui="BCGCOD" Endif

Return

###################################################################
$RAZDUP
#----- Raz des champs "Prospection" et "Jetons" -----#
If dim([M:BPC2]PITCDT)>0     Raz [M:BPC2]PITCDT    : Endif
If dim([M:BPC2]PITCPT)>0     Raz [M:BPC2]PITCPT    : Endif
If dim([M:BPC2]TOTPIT)>0     Raz [M:BPC2]TOTPIT    : Endif
If dim([M:BPC2]COTPITRQD)>0  Raz [M:BPC2]COTPITRQD : Endif
# FGR 06/08/2009 : X3SUIVI56985
#If dim([M:BPC2]CNTFIRDAT)>0  Raz [M:BPC2]CNTFIRDAT : Endif
#If dim([M:BPC2]CNTLASDAT)>0  Raz [M:BPC2]CNTLASDAT : Endif
#If dim([M:BPC2]CNTNEXDAT)>0  Raz [M:BPC2]CNTNEXDAT : Endif
#If dim([M:BPC2]CNTLASTYP)>0  [M:BPC2]CNTLASTYP=1   : Endif
#If dim([M:BPC2]CNTNEXTYP)>0  [M:BPC2]CNTNEXTYP=1   : Endif
#-----

Local Integer WRET

# Raz des zones mémoire de stockage des textes
Call RAZ_CLOB From ACLOB

If dim([M:BPC2]BPCSNCDAT) >= 0 Then  # FGR 19/02/2015 : X3SUIVI106383 : Soumis à CA
  [M:BPC2]BPCSNCDAT = date$   # FGR 03/06/2010 : X3SUIVI64450
Endif

# Dupplication des textes pour le nouveau client
If GACTFTC=2
   If [M:BPC1]ORDTEX<>""
      Call DUP_CLOB("BPC",[M:BPC1]ORDTEX,WRET) From TRTX3TEX
      If WRET<1 Raz [M:BPC1]ORDTEX Endif
   Endif
   If [M:BPC1]INVTEX<>""
      Call DUP_CLOB("BPC",[M:BPC1]INVTEX,WRET) From TRTX3TEX
      If WRET<1 Raz [M:BPC1]INVTEX Endif
   Endif
Endif

#---------------------------------------------------#
#Modif CRM 6/12/2002
#---------------------------------------------------#
If !GIBPCEXIST
    #Voulez-vous partager les interlocuteurs de la société XXXX ?
    Local Integer IASKBPR
    Local Char SZMESS(250)
    IASKBPR = 0
    If [M:CNTC]NBCNT > 0
        SZMESS = mess(834, 196, 2) + ' ' + [M:BPC0]BPCNUM
        Call OUINON(SZMESS, IASKBPR) From GESECRAN
        If IASKBPR <> 2
            Raz [M:CNTC]
            Raz [M:CNTC]NBCNT
            Affzo [M:CNTC]1-99
        Endif
    Endif
Endif

#En duplication TIERS : On ne duplique pas les informations RIB ! #JPGA:12/06/2006 - BUG140:38475
# Raz + Affzo + Non validation du Mask
If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
Look [BPR] BPR0=CZ
If fstat>0
    # Si le client n'existe pas, on efface les RIB (qui ne doivent pas venir du client dupliqué)
    Effzo [M:BIDC]
Endif

#-----------------#
# flags du tiers  #
#-----------------#
If CLECUR
    If CZ <> [M:BPC0]BPCNUM
        Look  [BPR]BPR0 = CZ
        If fstat
           #-- on remet les indicateurs a zero
           [M:BPRC]BPSFLG    = 1
           [M:BPRC]FCTFLG    = 1
           If GACTFTC=2
              [M:BPRC]BPTFLG = 1
              [M:BPRC]REPFLG = 1
           Endif
        #-- pas celui de tiers divers
        #  [M:BPRC]BPRACC    = 1
           [M:BPRC]BPCFLG    = 2
        Endif
    Endif
Endif

#----------------------#
# RAZ total encours    #
#----------------------#
[M:BPC2]XOST = 0

  # Dupplication des textes pour les nouveaux clients livrés
  If GACTFTC = 2 Then
    For nolign = 1 To [M:BPC4]NBDLV
      # ------------------------------------
      # FGR 26/01/2015 : X3SUIVI105670 (début)
      [M:BPC4]FLMOD(nolign-1) = 1
      Raz [M:BPC4]EXPNUM(nolign-1)
      Raz [M:BPC4]CREUSR(nolign-1)
      Raz [M:BPC4]CREDAT(nolign-1)
      Raz [M:BPC4]UPDUSR(nolign-1)
      Raz [M:BPC4]UPDDAT(nolign-1)
      # FGR 26/01/2015 : X3SUIVI105670 (fin)
      # ------------------------------------
      If [M:BPC4]PRPTEX(nolign-1)<>""
        Call DUP_CLOB("BPD",[M:BPC4]PRPTEX(nolign-1),WRET) From TRTX3TEX
        If WRET<1 Raz [M:BPC4]PRPTEX(nolign-1) Endif
      Endif
      If [M:BPC4]DLVTEX(nolign-1)<>""
        Call DUP_CLOB("BPD",[M:BPC4]DLVTEX(nolign-1),WRET) From TRTX3TEX
        If WRET<1 Raz [M:BPC4]DLVTEX(nolign-1) Endif
      Endif
    Next nolign
  Endif

# Réinitialisation du client groupe avec le nouveau client s'il était égal au client dupliqué
If [M]BPCGRU = [M:BPC0]BPCNUM
    If [M:BPC0]REFCOU=""
       [M]BPCGRU = CZ
    Else
       [M]BPCGRU = ""
    Endif
    Affzo [M:BPC3]BPCGRU
    If GINIBPRRSK=3 & [M]BPCRSK=[M:BPC0]BPCNUM [M]BPCRSK=CZ : Affzo [M:BPC3]BPCRSK Endif
Endif
Local Integer J
J=find (2,[M:BPAC]BPAADDFLG(0..[M:BPAC]NBADR-1))
# Réinitialisation du client facture avec le nouveau client s'il était égal au client dupliqué
If [M]BPCINV = [M:BPC0]BPCNUM
    If [M:BPC0]REFCOU=""
       [M]BPCINV = CZ
    Else
       [M]BPCINV = ""
    Endif
    Affzo [M:BPC3]BPCINV
    If !find (GINIBPRRSK,2,3) & [M]BPCRSK=[M:BPC0]BPCNUM [M]BPCRSK=CZ : Affzo [M:BPC3]BPCRSK Endif
    If J [M:BPC3]BPAINV=[M:BPAC]CODADR(J-1) : Affzo [M:BPC3]BPAINV : Endif
Endif
# Réinitialisation du client payeur avec le nouveau client s'il était égal au client dupliqué
If [M]BPCPYR = [M:BPC0]BPCNUM
    If [M:BPC0]REFCOU=""
       [M]BPCPYR = CZ
    Else
       [M]BPCPYR = ""
    Endif
    Affzo [M:BPC3]BPCPYR
    If GINIBPRRSK=2 & [M]BPCRSK=[M:BPC0]BPCNUM [M]BPCRSK=CZ : Affzo [M:BPC3]BPCRSK : Endif
    If J [M:BPC3]BPAPYR=[M:BPAC]CODADR(J-1) : Affzo [M:BPC3]BPAPYR : Endif
Endif
# Réinitialisation du client payeur avec le nouveau client s'il était égal au client dupliqué
If [M]BPCRSK = [M:BPC0]BPCNUM
    [M]BPCRSK = CZ : Affzo [M:BPC3]BPCRSK
Endif
If GACTFTC=2
    If [M]PRITYP=0 [M]PRITYP=1 Endif
Endif

#CRM
Gosub RAZDUP_CRM From TRTBPCRM

Gosub GRIZE_LIENS

#MAE, 22/10/08, puis TS 13/11/08 bg 49699
If [M:BPC0]BCGCOD <> ""
   Read [BCG]BCG0=[M:BPC0]BCGCOD
   If !fstat
      If [F:BCG]CREMOD=2
         [M:BPC0]BPCSTA=1
      Else
         [M:BPC0]BPCSTA=2
      Endif
   Endif
Endif

If dim([M:BPC3]BELVATSUB)>0
 If [M:BPRC]CRY="BE" : [M:BPC3]BELVATSUB=2 : Else [M:BPC3]BELVATSUB=1 : Endif
Endif

Affzo [M:BPC2]1-99
Affzo [M:BPRC]1-99
#MAE, 22/10/08, bg 49699
Affzo [M:BPC0]BPCSTA
Return

###################################################################
$INICRE
Local Integer STAT, WRET, WNUMOK
Local Char    NUMERO(GLONBPC)

#MAE, bg 95169, si BPCNUM est renseigné et que la catégorie a un compteur et qu'on ne vient pas des tiers
#=> raz de la zone
If [M:BPC0]BPCNUM<>"" &  [F:BCG]REFCOU<>"" & GNAVIG(max(GPILNAV-1,1)) <> "GESBPR"
  If [M:BPC3]BPCINV = [M:BPC0]BPCNUM
    [M:BPC3]BPCINV = ""
    [F:BPC]BPCINV = ""
  Endif
  If [M:BPC3]BPCGRU = [M:BPC0]BPCNUM
    [M:BPC3]BPCGRU = ""
    [F:BPC]BPCGRU = ""
  Endif
  If [M:BPC3]BPCPYR = [M:BPC0]BPCNUM
    [M:BPC3]BPCPYR = ""
    [F:BPC]BPCPYR = ""
  Endif
  If [M:BPC3]BPCRSK = [M:BPC0]BPCNUM
     [M:BPC3]BPCRSK = ""
     [F:BPC]BPCRSK=""
  Endif
  [M:BPC0]BPCNUM = ""
  [F:BPC]BPCNUM = ""
Endif

# Si le numéro client est déterminée par un compteur
If [F:BPC]BPCNUM = ""
 WNUMOK=0
 While WNUMOK=0
  # FGR 17/12/2009 : X3SUIVI60196
  #--- à activer en 6.20
  #Call NUMERO([M:BPC0]REFCOU,GFCYDEF(9),datesyst,"",NUMERO,STAT) From SUBANM
  Call NUMCLE ([M:BPC0]REFCOU,GFCYDEF(9),datesyst,"","BPC",NUMERO,STAT) From SUBANM
  #---
  If STAT = 0
    Look [BPR]BPR0=NUMERO
    If fstat
     [F:BPC]BPCNUM =NUMERO
     [M:BPC0]BPCNUM=NUMERO
     If [F:BPC]BPCINV=""
       [F:BPC]BPCINV=NUMERO
       [M:BPC3]BPCINV=NUMERO
     Endif
     If [F:BPC]BPCGRU=""
       [F:BPC]BPCGRU=NUMERO
       [M:BPC3]BPCGRU=NUMERO
     Endif
     If [F:BPC]BPCPYR=""
       [F:BPC]BPCPYR=NUMERO
       [M:BPC3]BPCPYR=NUMERO
     Endif
     If [F:BPC]BPCRSK=""
       Case GINIBPRRSK
           When 2       : [M:BPC3]BPCRSK=[M:BPC3]BPCPYR
           When 3       : [M:BPC3]BPCRSK=[M:BPC3]BPCGRU
           When Default : [M:BPC3]BPCRSK=[M:BPC3]BPCINV
       Endcase
       [F:BPC]BPCRSK=[M:BPC3]BPCRSK
     Endif
     WNUMOK=1
    Endif
  Else
    GOK=0 : WNUMOK=1
    # FGR 20/07/2011 : X3SUIVI75166
    Local Char MESSA(80)
    GMESSAGE = mess(104,117,1) - "(" + [M:BPC0]REFCOU + ") : "
    Gosub MESSAGE From SUBANMARG
    GMESSAGE -= MESSA
  Endif
 Wend
 If GOK=0 Return Endif
Endif

# 09/07/12 Payment days in customer function SAM #82280
Gosub INICRE From TRTPDCLIB

#---------------------------------------------------#
# alimentation rubriques dans bpcustomer            #
#---------------------------------------------------#
Gosub INIBPC

# Création des textes commande et facture
If GACTFTC=2
  If [M:BPC1]ORDTEX<>""
    Call CRE_CLOB([M:BPC1]ORDTEX,GOK) From TRTX3TEX
    If GOK<1 Return Endif
    [F:BPC]ORDTEX = [M:BPC1]ORDTEX
  Endif
  If [M:BPC1]INVTEX<>""
    Call CRE_CLOB([M:BPC1]INVTEX,GOK) From TRTX3TEX
    If GOK<1 Return Endif
    [F:BPC]INVTEX = [M:BPC1]INVTEX
  Endif
Endif

Return

###################################################################
$CREATION
  #MAE, bg 70609: changement dans l'ordre de création : les adresses, les RIB puis les tiers
  #               avant : Tiers, puis adresse puis RIB
  #----    creation ou modification enregistrement tiers
  Gosub CREBPA
  If GOK < 1 : Return : Endif
  #----    creation ou modification enregistrement adresse
  Gosub CRERIB
  If GOK < 1 : Return : Endif
  #----    creation enregistrements rib
  Gosub CREBPR
  If GOK < 1 : Return : Endif
  # FGR 07/12/2010 : X3SUIVI69722 : A faire avant les contacts (début)
  #----    creation enregistrements clients livrés
  If GACTFTC=2 Gosub CREBPD Endif
  If GOK < 1 : Return : Endif
  # FGR 07/12/2010 : X3SUIVI69722 : A faire avant les contacts (fin)
  #----    creation enregistrements contacts
  Gosub CRECNT
  If GOK < 1 : Return : Endif
  Gosub DEFAUT
  # FGR 07/12/2010 : X3SUIVI69722 : A faire avant les contacts (début)
  #----    creation enregistrements clients livrés
  #If GACTFTC=2 Gosub CREBPD Endif
  #If GOK < 1 : Return : Endif
  # FGR 07/12/2010 : X3SUIVI69722 : A faire avant les contacts (fin)
  #
  #    Si le tiers est un site
  #    --> il faut réécrire les adresses les RIB et les contacts du site
  If GACTFTC=2 & [M:BPRC]FCY <> ""
    Gosub MAJFCY From SUBBPR : If GOK < 1 : Return : Endif
  Endif
  #
  #CRM
  Gosub CREATION_CRM From TRTBPCRM
  If GOK < 1 : Return : Endif
  #
  Raz SZOBPP   # FGR 03/02/2010 : X3SUIVI62170
  #MAE, lecture du tiers pour les workflows, ne pas écraser, bg 67131
  If !GIMPORT & GWEBSERV<>1
      If !clalev([F:BPRW]) : Local File BPARTNER [BPRW] : Endif
      If [M:BPC0]BPCNUM <> ""
        Read [BPRW]BPR0 = [M:BPC0]BPCNUM
        If fstat Raz [F:BPRW] Endif
      Endif
  Endif

Return

###################################################################
$AVANTMOD
#----      verrouillage du symbole BPR
#SYMBOLE2 = "BPR"+num$([M:BPC0]BPCNUM)   : # modif le 28/01/98 cg
#Lock = SYMBOLE2 With lockwait = 0
#OK = 1
#If fstat
#     Call ERREUR(mess(10,100,1)) From GESECRAN
#     OK = 0
#Endif
  # FGR 29/08/2014 : X3SUIVI95632
  If find("GESAIN", GNAVIG(1..GPILNAV-1)) <> 0 Then
    If [M:BPRC]BETFCY = 2 Then
      mkstat = 2
      GMESSAGE = mess(1152,196,1)
      Return
    Endif
  Endif
Return

###################################################################
$VERROU

If [M:BPC0]BPCNUM <> ""
   Read [BPR]BPR0 = [M:BPC0]BPCNUM
   If fstat = 0
      #------------------------------------#
      # il faut verrouiller symbole BPR    #
      #------------------------------------#
      SYMBOLE2 = "BPR"+num$([M:BPC0]BPCNUM)
      Lock = SYMBOLE2 With lockwait = 0
      If fstat
         #-- on debloque le BPC - modif non autorisée
         #-- sinon on a probleme sur lock : reste dans le fichier
         Unlock = SYMBOLE
         OK = 0
         Return
      Endif
   Endif
Endif

Return

###################################################################
$FINMODIF
#----      deverrouillage du symbole BPR
# FGR 15/10/2009 : X3SUIVI58119 : on délocke dans DEVERROU, c'est tout
#SYMBOLE2 = "BPR"+num$([M:BPC0]BPCNUM)     : # modif le 28/01/98 cg
#Unlock = SYMBOLE2
Raz GORITRFBPP
Return

###################################################################
$DEVERROU
#----      deverrouillage du symbole BPR
SYMBOLE2 = "BPR"+num$([M:BPC0]BPCNUM)     : # modif le 28/01/98 cg
Unlock = SYMBOLE2
Return

###################################################################
$FIN_GILOCKBPR
  # FGR 16/04/2012 : X3SUIVI81335
  If dim(GILOCKBPR) >= 0 Then
    Gosub DEVERROU
    Kill GILOCKBPR
  Endif
Return

###################################################################
$ABANDON
Local Integer I, WRET

#-------------------------------------------------#
# il faut deverrouiller BPARTNER                  #
#-------------------------------------------------#
# FGR 15/10/2009 : X3SUIVI58119 : on délocke dans DEVERROU, c'est tout
#SYMBOLE2 = "BPR"+num$([M:BPC0]BPCNUM)
#Unlock = SYMBOLE2
Gosub FIN_GILOCKBPR  # FGR 16/04/2012 : X3SUIVI81335

If GACTFTC=2
   If GREP = "D"
      # Suppression des textes commande et facture
      If [M:BPC1]ORDTEX<>""
         Call SUP_CLOB([M:BPC1]ORDTEX,WRET) From TRTX3TEX
      Endif
      If [M:BPC1]INVTEX<>""
         Call SUP_CLOB([M:BPC1]INVTEX,WRET) From TRTX3TEX
      Endif
      # Suppression des textes prépa et livraison
      For I=0 To [M:BPC4]NBDLV-1
         If [M:BPC4]PRPTEX(I)<>""
            Call SUP_CLOB([M:BPC4]PRPTEX(I),WRET) From TRTX3TEX
         Endif
         If [M:BPC4]DLVTEX(I)<>""
            Call SUP_CLOB([M:BPC4]DLVTEX(I),WRET) From TRTX3TEX
         Endif
      Next I
   Endif
   # Raz des zones mémoire de stockage des textes
   Call RAZ_CLOB From ACLOB
Endif

#Local Integer WRETOUR
#Local Char WNUMTEX (12)
#WRETOUR = 0
#If GACTFTC=2
#   If GREP = "D"
#      If ANC_ORDTEX <> [M:BPC1]ORDTEX
