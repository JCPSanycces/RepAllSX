############################################################################
$APRES_MOD
Local Char SZCONNUM(GLONVCR)

If func AFNC.ACTIV("SDD") : Call UPDBID([M]BPCNUM) From SUBMDT : Endif

# Bug 30175
# Transformation d'un prospect en client : Changer la clé des pièces jointes et commentaires (Changer le nom de l'objet)
If GNAVIG(max(GPILNAV-1,1)) = "GESBPP" | GORITRFBPP<>""
    Call CHANGE("BPP","BPC",CLECUR1,CLECUR2,CLECUR1,CLECUR2) From GOBJTXT
Endif

#Met à jour l'utilisateur associé au représentant
Call UPDAUSFROMBPR([M:BPC0]BPCNUM) From SUBAUSCRM

#Met à jour la raison sociale du client interne
If !clalev([F:DBI]) : Local File DOOBPCINT [DBI] : Endif
Read [DBI] DBI0 = [M:BPC0]BPCNUM
If fstat
    [F:DBI]BPCNUM = [M:BPC0]BPCNUM
    [F:DBI]BPCNAM = [M:BPRC]BPRNAM
    [F:DBI]BPCSHO = [M:BPRC]BPRSHO
    [F:DBI]INTBPC = 2
    Write [DBI]
Else
    [F:DBI]BPCNAM = [M:BPRC]BPRNAM
    [F:DBI]BPCSHO = [M:BPRC]BPRSHO
    Rewrite [DBI]
Endif

#Modif CRM 10 janvier 2002
