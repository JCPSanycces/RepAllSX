#    Call MNGADDDEF([M:BPC0]BPCNUM, "BPC") From TRTMST4
#    Call MNGMAINREP([M:BPC0]BPCNUM, "BPC") From TRTMST4
#    Call CHECKMST([M:BPC0]BPCNUM, "BPR", "BPC", 0) From TRTMST4
#Endif

#Modif CRM 25 Septembre 2003
#Débit forfaitaire
Local Integer IERRPIT
IERRPIT = 0
Call SAVEPIT([M:BPC0]BPCNUM, IERRPIT) From SUBBPCB

#Modif CRM 24 Septembre 2003
#Gestion des points
Local Integer IERRINF
IERRINF = 0
#LSE 22/04/2005 rajout 2 paramètres
Local Integer ICHAPTER
Local Integer IBRETOUR
ICHAPTER= 0
IBRETOUR= 1

Call BPCPOINT([M:BPC0]BPCNUM, "SUBBPCA", SZCONNUM, IERRINF, ICHAPTER, IBRETOUR) From TRTPOINT
If IERRINF <> 0 Then
  If SZCONNUM <> "" Then
    Call MESSAGE(mess(IERRINF,ICHAPTER,1) - "(" + SZCONNUM + ")") From GESECRAN
  Else
    Call MESSAGE(mess(IERRINF,ICHAPTER,1)) From GESECRAN
  Endif
