########################################################################
$APRES_CHOIX
  # FGR 16/02/2015 : X3SUIVI101747
  # Si on est venu depuis les prospects pour créer un client et qu'on a abandonné,
  # on repart directement sur l'écran des prospect. On sort de la fiche client.
  If (GNAVIG(max(GPILNAV-1,1)) = "GESBPP" & GREP="M" & [F:BPC]BPCTYP = 4) | GORITRFBPP <> "" Then
    If REPONSE = GSTAFIN Then
      REPONSE = GSTAEND
    Endif
  Endif
Return

#########################################################################
# FGR 11/10/2007 : X3SUIVIXXXXX                                     CRM #
#########################################################################
# Affectation des valeurs pour la création d'un contrat de service.
#########################################################################
$SET_HEA_INFO
  Case IMPZON
    When "CONNUM"  #[M:CON0]
    When "CPY"
      If [M:CON0]CPY = "" Then
        [M:CON0]CPY = [F:SIH]CPY
      Endif
    When "SALFCY"
      If [M:CON0]CPY = "" Then
        [M:CON0]SALFCY = [F:SIH]FCY
      Endif
    When "CONBPC"
      [M:CON0]CONBPC = [F:BPC]BPCNUM
      [M:CON1]CONORI = 7
      [M:CON1]CONORIVCR = ""
      [M:CON1]CONORIVCRL = 0
    When "CUR"
      [M:CON0]CUR = [F:BPC]CUR
    When "CONCCN"

    ######################################
    #[M:CON1]
    When "CONNAM"
      [M:CON1]CONNAM = [F:BPC]BPCNAM
    When "CONTYP"
    When "CONCAT"
    When "EVRPBL"
    When "EVRMAC"
    When "CRSCOVSAM"
    When "SALREP"
      #[M:CON1]SALREP = [F:BPC]REP
    When "CONORIVCR"
      # fait dans CONBPC
    When "CONORI"
      # fait dans CONBPC
    When "CONCOT"
      #[M:CON1]CONCOT = [F:BPC]COTCHX
      [M:CON1]CONCOT = [F:COT]CONNUM   # FGR 23/03/2010 : X3SUIVI63397

    ######################################
    #[M:CON4]
    When "SIUDAT"
      [M:CON4]SIUDAT = date$
    When "CONSTRDAT"
    When "CONENDDAT"
    When "REWFRY"
    When "REWFRYBAS"
    When "CONREW"
    When "MANREWFLG"
    When "CONAMT"
      [M:CON4]CONAMT = 0
    When "PITCDT"
      If [M:CON4]PITCDT = 0 Then
        [M:CON4]PITCDT = [F:BPC]TOTPIT
      Endif
    When "RVAFRY"
    When "RVAFRYBAS"
    When "RVAMET"
    When "RVASSP"
    When "CONBASIDX"
    When "LASVALIDX"
    When "LASIDXDAT"
    When "CONBASFOR"
    When "RSILTI"
    When "RSILTIBAS"
    When "PITTOL"

    ######################################
    #[M:CON8]
    When "INVFRY"
    When "INVFRYBAS"
    When "INVMET"
    When "INVFRYCOE"
    When "INVLTI"
    When "INVLTIBAS"
    When "PTE"
      [M:CON8]PTE = [F:BPC]PTE
    When "NBDPT"  # variable bas de tableau
    When "NBAXE"  # variable bas de tableau
      # mais pour les axes ne rien faire, c'est a priori bon !
    When "CCE"
      [M:CON8]CCE(indice) = [F:BPC]CCE(indice)

    ######################################
    #[M:CONG]
    When "CONBPCINV"
    When "CONBPCPYR"
    When "CONBPCGRU"
    When "CONPJT"
    When "CONCHGTYP"
    When "ITMREF"
    When "CONPRITYP"
    When "CONVACBPR"
      [M:CONG]CONVACBPR = [F:BPC]VACBPR
    When "NBFAC"  # variable bas de tableau

    ######################################
    #[M:CON2]
    When "NBINV"  # variable bas de tableau
    When "NBDUD"  # variable bas de tableau
    When "NBPAY"  # variable bas de tableau

    ######################################
    #[M:CON5]
    When "NBAMT"  # variable bas de tableau
    When "NBREW"  # variable bas de tableau
    When "RSIFLG"
    When "RSIREN"
      # Note FGR : je ne sais pas pourquoi, mais un ADI est initialisé à  "000"
      # Du coup ensuite ça plante parce que le code d'existe pas dans la table !
      [M:CON5]RSIREN = ""
    When "FDDFLG"
    When "RSIDAT"
    When "PRERSIFLG"

    ######################################
    When Default
  Endcase
Return

