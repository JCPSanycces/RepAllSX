$APRES_CRE
Local Char SZCONNUM(GLONVCR)

#Définit le client en tant que client interne par défaut
If !clalev([F:DBI]) : Local File DOOBPCINT [DBI] : Endif
[F:DBI]BPCNUM = [M:BPC0]BPCNUM
[F:DBI]BPCNAM = [M:BPRC]BPRNAM
[F:DBI]BPCSHO = [M:BPRC]BPRSHO
[F:DBI]INTBPC = 2
Write [DBI]

#Modif CRM 10 janvier 2002
