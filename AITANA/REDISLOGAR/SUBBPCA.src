###########################################################################################
#    Avant l'execution des boutons et des menus                                           #
###########################################################################################
$AVANTBOUT
[M:BPC0]NVGCOD = BOUT
If BOUT="2"
   GBIDC2="T" : Raz GFCY : Gosub AUTORIS_OPT From CONTX3
   If !GBIDI2
      GERR=1 : GMESSAGE=mess(7,104,1) : Return
   Endif
   GFLTBPC = [M:BPC0]BPCNUM
   GVISUTAR = 3
   Close Local File [BPD]  # FGR 30/01/2015 : X3SUIVI105772
Endif

If GMODU(13)=2
    Case BOUT
        When ")"
            #Planifier Rendez-vous
            GBCRMFLGNEW=1
        When "("
            #Planifier Appel
            GBCRMFLGNEW=1
        When "£"
            #Planifier tache
            GBCRMFLGNEW=1

        When "}"
            #Enregistrer Rendez-vous
            GBCRMFLGNEW=1
        When "{"
            #Enregistrer Appel
            GBCRMFLGNEW=1
        When "~"
            #Enregistrer tache
            GBCRMFLGNEW=1
        When "!"
            #Enregistrer une affaire
            GBCRMFLGNEW=1
    Endcase
Endif

#Fq74170-Gbn-Message si client (ou client risque) bloqué - Commandes de vente
If BOUT= "E"
 Local Integer WOSTCTL
 If [F:BPC]BPCNUM=[F:BPC]BPCRSK & [F:BPC]OSTCTL=3
  WOSTCTL=2
 Elsif [F:BPC]BPCNUM<>[F:BPC]BPCRSK
  WOSTCTL= func TRTVENCDE.BPCOSTBLK([F:BPC]BPCRSK)
 Endif
 If WOSTCTL=2
   Local Integer WOK : WOK=1
   Call AVERTIR (mess(151,199,1), WOK) From GESECRAN
   If WOK=1 : OK=0 : GERR=1 : Return : Endif
 Endif
Endif

#MAE, commande en création par le tunnel => GCREFONC = 1
If BOUT = "E" | BOUT = "G" | BOUT = "1"
    GCREFONC = 1
Endif
If BOUT ="7" Then
Endif
Return

###########################################################################################
#    Après execution des boutons                                                          #
###########################################################################################
$EXEBOUT
Local Date WDAT
Local Char SGBOITE
SGBOITE=GBOITE
GBOITE =""

WDAT = [0/0/0]
Case REP
     When "2" : GFLTBPC = ""
                GVISUTAR = 0
                If !clalev([F:BPD]) : Local File BPDLVCUST [BPD] : Endif  # FGR 30/01/2015 : X3SUIVI105772
Endcase
GBOITE=SGBOITE
Return

###########################################################################################
#    Après execution des menus;;                                                          #
###########################################################################################
$STATUT

Case BOUT
    When "F"    : If mkstat=4 & GREP=""
                     #MAE, bg 50938
                     #GREP="M" : REP="M"
                     #Gosub SETBOUT From GOBJSUB
                     Gosub ENTRE_MODIF From GOBJSUB
                  Endif
                  If GACTFTC=2
                    If [M]ORDTEX <> ""
                       [M]WORDTEX = 2
                    Else
                       [M]WORDTEX = 1
                    Endif
                    Affzo [M:BPC1]20    : # Issue 106137
                  Endif
                  #Affzo [M:BPC1]20     : # Issue 106137
    When "H"    : If mkstat=4 & GREP=""
                    #MAE, bg 50938
                    #GREP="M" : REP="M"
                    #Gosub SETBOUT From GOBJSUB
                    Gosub ENTRE_MODIF From GOBJSUB
                  Endif
                  If [M]INVTEX <> ""
                     [M]WINVTEX = 2
                  Else
                     [M]WINVTEX = 1
                  Endif
                  If GACTFTC=2 Affzo [M:BPC1]20 Endif   : # Issue 106137
    When "M"    : Call NOTPAY([M]BPCNUM,WLEGCPY,"")     From TIERSZOOM
    When "R"    : Call PROROG([M]BPCNUM,WLEGCPY,"",1)   From TIERSZOOM

    #LSE 13/03/2007 rechargement si modif apres action SAIMST9
    When "5"
        If GIOBPC_MODIF=1
            If !GIMPORT Gosub RELIT From GOBJSUB : Endif
        Endif

    #MAE, bg 72589, si on revient des consultations et multi leg, raz GSOCIETE
    When "T","A","è","B","0","C","9","V","[","]"
       If GNBLEG>1
          Raz GSOCIETE, GCURLEG
       Endif
Endcase

Return

###################################################################
$LIENS
Local Char WCUR (3)
Local Decimal WMONTORG (0..10)
Local Decimal WMONTDES (0..10)

#If dim([M:BPC0]SOC)>0
#    If [M:BPC0]SOC<>""
#        GSOCIETE = [M:BPC0]SOC
#        # --- RECHARGER GCUR avec la devise de la société ----#
#        If [F:CPY]CPY<>GSOCIETE
#           Read [CPY]CPY0 = GSOCIETE
#           If fstat = 0 : GCUR = [F:CPY]ACCCUR : Endif
#        Endif
#    Elsif GSOCIETE=""
#        Call GETDEV(GFCYDEF(0)) From DEVSUB
#    Endif
#    [M]SOC = GSOCIETE
#Endif

# Raz des zones mémoire de stockage des textes
If GFONC1="GESBPC" Call RAZ_CLOB From ACLOB Endif
[F:BPCS]=[F:BPC]    # hcb 106448
GIBPCEXIST = 0

If [F:BPC]BCGCOD<>""
   Read [BCG]BCG0=[F:BPC]BCGCOD
   [M:BPC0]REFCOU=[F:BCG]REFCOU
Endif

#[M:BPC2]XCUR = GCUR
If GACTFTC=2
   [M:BPC1]XCUR = GCUR
   [M:BPC1]WORDTEX = 2
   If [M:BPC1]ORDTEX = "" [M:BPC1]WORDTEX = 1 Endif
   [M:BPC1]WINVTEX = 2
   If [M:BPC1]INVTEX = "" [M:BPC1]WINVTEX = 1 Endif
Endif


If !clalev([F:BPR1]) : Local File BPARTNER [BPR1] : Endif
# Pb en import
# Il ne faut pas écraser [F:BPR] qui peut être chargé avec des champs à importer (Ex import de la raison sociale)
# ==> Lecture du tiers sous une autre abréviation
Read [BPR1]BPR0 = [M:BPC0]BPCNUM
If fstat = 0
    [M:BPRC] = [F:BPR1]
    [M:BPC0]BPCNAM = [F:BPR1]BPRNAM
    [M:BPRC]CUR    = [F:BPC]CUR   : # Récupération devise client
    # FGR 03/06/2010 : X3SUIVI64450 (début)
    If [F:BPR1]BPCFLG <> 2 Then
      # Il n'était pas client : c'est donc qu'il le devient
      If dim([M:BPC2]BPCSNCDAT) >= 0 Then  # FGR 19/02/2015 : X3SUIVI106383 : Soumis à CA
        [M:BPC2]BPCSNCDAT = date$
      Endif
    Endif
    # FGR 03/06/2010 : X3SUIVI64450 (fin)
Else
    Raz [M:BPRC]
Endif
If GACTFTC=2 & [M:BPRC]FCY <> ""
   # Lecture du site lié au client
   If [F:FCY]FCY<>[M:BPRC]FCY
      Read [FCY]FCY0=[M:BPRC]FCY
      If fstat Raz [FCY] Endif
   Endif
   [M:BPC3]LEGCPY = [F:FCY]LEGCPY
Endif

#---- conversion montants de devise dossier vers devise affichage (société ou société du site par défaut)
Local Decimal WMONTORG (0..2)
Local Decimal WMONTDES (0..2)
If GACTFTC=2
   WMONTORG (0) = [F:BPC]ORDMINAMT
   Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG (0),WMONTDES (0),SPSTAT) From TRTDEV
   If SPSTAT = 0
      [M:BPC1]WORDMINAMT = arr(WMONTDES (0),WDECIMAL)
   Else
      [M:BPC1]WORDMINAMT = [F:BPC]ORDMINAMT
   Endif
Endif

