###################################################################
$INIMOD
Local Integer WRET
  #---- alimentation rubriques dans bpcustomer
  Gosub INIBPC
# 09/07/12 Payment days in customer function SAM #82280
Gosub INIMOD From TRTPDCLIB
  #
  # Mise à jour des textes commande et facture
  If GACTFTC=2
    If [M:BPC1]ORDTEX<>""
      Call CRE_CLOB([M:BPC1]ORDTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
      [F:BPC]ORDTEX = [M:BPC1]ORDTEX
    Endif
    If [M:BPC1]INVTEX<>""
      Call CRE_CLOB([M:BPC1]INVTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
      [F:BPC]INVTEX = [M:BPC1]INVTEX
    Endif
  Endif

#MAE, bg 73682, remise en place des champs de travail sauvegardé
#Si des champs de travail sont rajoutés dans les tables : les rajouter ici
#parce que les champs de W de la table BPDLVCUST écrasent ceux de la table BPCUSTOMER
#Bg 78257, on ne réécrase pas tous les champs de mise à jour
If [F:BPC]BPCNUM = [F:BPCS]BPCNUM                     # hcb 90367
   If [F:BPCS]CREDAT <> [0/0/0]                       # hcb 90367
      [F:BPC]CREDAT = [F:BPCS]CREDAT
   Endif                                              # hcb 90367
   If [F:BPCS]CREUSR <> ""                            # hcb 90367
      [F:BPC]CREUSR = [F:BPCS]CREUSR
   Endif                                              # hcb 90367
Endif                                                 # hcb 90367
#[F:BPC]UPDDAT = [F:BPCS]UPDDAT
#[F:BPC]UPDUSR = [F:BPCS]UPDUSR
#[F:BPC]CRESTP = [F:BPCS]CRESTP
#[F:BPC]UPDSTP = [F:BPCS]UPDSTP
#[F:BPC]IDTSGL = [F:BPCS]IDTSGL

If func AFNC.ACTIV("SDD") : Call DELBID([M]BPCNUM) From SUBMDT : Endif
Return

###################################################################
$INIBPC
#---- alimentation rubriques dans bpcustomer
[F:BPC]BPCNAM    = [M:BPRC]BPRNAM(0)
[F:BPC]BPCSHO    = [M:BPRC]BPRSHO

If [M:BPC2]BPCTYP = 4
   [F:BPC]PPTFLG = 2
   # FGR 06/08/2009 : X3SUIVI56985
   #[F:BPC]CNTLASTYP = 1
   #[F:BPC]CNTNEXTYP = 1
Endif

#---- conversion montants de devise affichage (société ou société du site par défaut) vers devise dossier
Local Decimal WMONTORG (0..2)
Local Decimal WMONTDES (0..2)
If GACTFTC=2
   WMONTORG (0)=[M:BPC1]WORDMINAMT
   Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMONTORG (0),WMONTDES (0),SPSTAT) From TRTDEV
   If SPSTAT = 0
      [F:BPC]ORDMINAMT   = WMONTDES (0)
   Else
      [F:BPC]ORDMINAMT   = [M:BPC1]WORDMINAMT
   Endif
Endif
#MAE, bg 99911
If [M:BPC2]WOSTAUZSAV <> [M:BPC2]WOSTAUZ
  #MAE, bg 74262
  WMONTORG (2) = [M:BPC2]WOSTAUZ
  Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMONTORG (2),WMONTDES (2),SPSTAT) From TRTDEV
  If SPSTAT = 0
     [F:BPC]OSTAUZ      = WMONTDES (2)
  Else
     #MAE, bg 74262
    [F:BPC]OSTAUZ      = [M:BPC2]WOSTAUZ
  Endif
Endif
If dim([M:BPC3]FUPMINAMT)>0 : [F:BPC]FUPMINAMT   = [M:BPC3]FUPMINAMT : Endif

If dim([M:BPC2]WCDTISR) <> -1      # corr bug 24197 : BPC2 (TB) 30/08/04
   WMONTORG (0) = [M:BPC2]WCDTISR
   Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMONTORG (0),WMONTDES (0),SPSTAT) From TRTDEV
   If SPSTAT = 0
      [F:BPC]CDTISR = WMONTDES (0)
   Else
      [F:BPC]CDTISR = [M:BPC2]WCDTISR
   Endif
Endif

# Alimentation du code adresse par défaut, du contact par défaut, du client livré par défaut
Local Shortint WI
WI = find (2,[M:BPAC]BPAADDFLG (0..[M:BPAC]NBADR -1))
If WI<>0 [F:BPC]BPAADD = [M:BPAC]CODADR (WI-1) Endif


#LSE 17/06/2006 FQ36999
#WI = ([M:CNTC]NBCNT>0)*max(1,find (2,[M:CNTC]CNTFLG (0..[M:CNTC]NBCNT -1)))
#If WI<>0 [F:BPC]CNTNAM = [M:CNTC]CCNCRM (WI-1) Else [F:BPC]CNTNAM="" Endif
If [M:CNTC]NBCNT >0
    WI = find (2,[M:CNTC]CNTFLG (0..[M:CNTC]NBCNT -1))
    If WI <> 0
        [F:BPC]CNTNAM  = [M:CNTC]CCNCRM (WI-1)
    Else
        [F:BPC]CNTNAM   =[M:CNTC]CCNCRM (0)
    Endif
Else
    [F:BPC]CNTNAM   =""
Endif

  #--- Issue 106137
  If GACTFTC=2
    WI = find (2,[M:BPC4]BPDADDFLG (0..[M:BPC4]NBDLV-1))
    If WI<>0
      [F:BPC]BPDADD = [M:BPC4]BPAADD(WI-1)
    Else
      # Si aucun client livré par défaut
      # On prend d'office le client livré lié à l'adresse par défaut ou le 1er client livré
      WI = find ([F:BPC]BPAADD,[M:BPC4]BPAADD(0..[M:BPC4]NBDLV-1))
      If WI<>0
        If [M:BPC4]ENAFLG(WI-1) = 2 Then
          # FGR 17/02/2015 : X3SUIVI92469 : Seulement si elle est active sur les adresses de livraisons
          [F:BPC]BPDADD=[M:BPC4]BPAADD(WI-1)
          [M:BPC4]FLMOD(WI-1) = 1  # FGR 21/12/2010 : X3SUIVI70104
        Else
          # FGR 17/02/2015 : X3SUIVI92469 : il faudra chercher la première active
          WI = -1
        Endif
      Else
        If [M:BPC4]ENAFLG(0) = 2 Then
          # FGR 17/02/2015 : X3SUIVI92469 : Seulement si elle est active sur les adresses de livraisons
          [F:BPC]BPDADD=[M:BPC4]BPAADD(0)
          [M:BPC4]FLMOD(0) = 1  # FGR 21/12/2010 : X3SUIVI70104
        Else
          # FGR 17/02/2015 : X3SUIVI92469 : il faudra chercher la première active
          WI = -1
        Endif
      Endif
      # ------------------------
      If WI = -1 Then
        # FGR 17/02/2015 : X3SUIVI92469 : on cherche la première adresse de livraison active pour la mettre par défaut
        Raz [F:BPC]BPDADD
        For WI = 0 To [M:BPC4]NBDLV-1
          If [M:BPC4]ENAFLG(WI) = 2 Then
            [F:BPC]BPDADD = [M:BPC4]BPAADD(WI)
            [M:BPC4]FLMOD(WI) = 1
            Break
          Endif
        Next WI
      Endif
      # ------------------------
    Endif
    #--- Issue 106137
  Endif

Return

######################################################################
$AVANT_MODFIC
Local Integer WRET, WMAJNAM : Raz WMAJNAM
If [M:BPRC]BPRNAM <> [F:BPC]BPCNAM | [M:BPRC]BPRSHO <> [F:BPC]BPCSHO WMAJNAM=1 Endif
Local Integer WMAJBPCRSK : Raz WMAJBPCRSK
Local Char WBPCRSK
If [M:BPC3]BPCRSK <> [F:BPC]BPCRSK WBPCRSK = [F:BPC]BPCRSK : WMAJBPCRSK=1 Endif
#MAE bg62889
Local Integer WMAJRISK : Raz WMAJRISK
If [M:BPC2]OSTCTL <>[F:BPC]OSTCTL |[M:BPC2]WOSTAUZ <>[F:BPC]OSTAUZ | [M:BPC2]WCDTISR <>[F:BPC]CDTISR |[M:BPC2]CDTISRDAT <>[F:BPC]CDTISRDAT
WMAJRISK = 1
Endif
Return

######################################################################
$MODIF

  #----    création ou modification enregistrement tiers
  #MAE, bg 71310, changement ordre de création : adresse, RIB et Tiers
  # avant : Tiers, adresse et RIB
  #Gosub CREBPR
  Gosub CREBPA
  If GOK < 1 : Return : Endif

  #----    creation ou modification enregistrement adresse
  #Gosub CREBPA
  Gosub CRERIB
  If GOK < 1 : Return : Endif

  #----    creation enregistrements rib
  #Gosub CRERIB
  Gosub CREBPR
  If GOK < 1 : Return : Endif
  #
  # FGR 07/12/2010 : X3SUIVI69722 : A faire avant les contacts (début)
  #----    creation enregistrements clients livrés
  If GACTFTC=2 Gosub CREBPD Endif
  If GOK < 1 : Return : Endif
  # FGR 07/12/2010 : X3SUIVI69722 : A faire avant les contacts (fin)
  #
  #----    creation enregistrements contacts
  Gosub CRECNT
  If GOK < 1 : Return : Endif

  Gosub DEFAUT
  # FGR 07/12/2010 : X3SUIVI69722 : A faire avant les contacts (début)
  #----    creation enregistrements clients livrés
  #If GACTFTC=2 Gosub CREBPD Endif
  #If GOK < 1 : Return : Endif
  # FGR 07/12/2010 : X3SUIVI69722 : A faire avant les contacts (fin)
  #
  #    Si le tiers est un site
  #    --> il faut réécrire les adresses les RIB et les contacts du site
  If GACTFTC=2 & [M:BPRC]FCY <> ""
     Gosub MAJFCY From SUBBPR : If GOK < 1 : Return : Endif
  Endif
  #    Mise à jour de la raison sociale
  If WMAJNAM=1
    If [M:BPRC]BPSFLG = 2
      If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
      Update [BPS] Where [F:BPS]BPSNUM = [M:BPC0]BPCNUM With BPSNAM=[M:BPRC]BPRNAM, BPSSHO=[M:BPRC]BPRSHO
      If fstat GOK=0 : Call FSTA("BPS") From GLOCK : Endif
    Endif
    If dim([M:BPRC]REPFLG)>0 & [M:BPRC]REPFLG=2
      If clalev([F:REP])=0 : Local File SALESREP [REP] : Endif
      Update [REP] Where [F:REP]REPNUM = [M:BPC0]BPCNUM With REPNAM=[M:BPRC]BPRNAM
      If fstat GOK=0 : Call FSTA("REP") From GLOCK : Endif
    Endif
    If dim([M:BPRC]BPTFLG)>0 & [M:BPRC]BPTFLG=2
      If clalev([F:BPT])=0 : Local File BPCARRIER [BPT] : Endif
      Update [BPT] Where [F:BPT]BPTNUM = [M:BPC0]BPCNUM With BPTNAM=[M:BPRC]BPRNAM, BPTSHO=[M:BPRC]BPRSHO
      If fstat GOK=0 : Call FSTA("BPT") From GLOCK : Endif
    Endif
  Endif
  #    Mise à jour du tiers risque : modification de ts les mvts clients
  If WMAJBPCRSK=1
    If clalev([F:MVC])=0 : Local File BPCUSTMVT [MVC] : Endif
    #Update [MVC] Where [F:MVC]BPCNUM=[M:BPC0]BPCNUM & [F:MVC]BPCRSK=WBPCRSK & [F:MVC]CPY=[M:BPC0]SOC With BPCRSK=[M:BPC3]BPCRSK
    Update [MVC] Where [F:MVC]BPCNUM=[M:BPC0]BPCNUM & [F:MVC]BPCRSK=WBPCRSK With BPCRSK=[M:BPC3]BPCRSK
    If fstat GOK=0 : Call FSTA("MVC") From GLOCK : Endif
  Endif
  #
  #CRM
  Gosub MODIF_CRM From TRTBPCRM
  If GOK < 1 : Return : Endif
  #

  #111269 RBU - Salesforce integration
  Local Char SFCRM(2)
  Call PARAM("","SFCRM", SFCRM) From ADOVAL
  If val(SFCRM)=[V]CST_AYES
    Gosub SF_UPDATE From CRMSFLIB
    If GOK < 1 : Return : Endif
  Endif
  #111269

  Raz SZOBPP   # FGR 03/02/2010 : X3SUIVI62170
Return

#######################################################################
$VERFANU
Local Decimal WMNTANN

#---- test mouvement à zéro                   #
#For [MVC]MVC1 Where BPCNUM = [M:BPC0]BPCNUM & CPY=[M:BPC0]SOC
For [MVC]MVC1 Where BPCNUM = [M:BPC0]BPCNUM
   WMNTANN += [F:MVC]QUOATIC
   WMNTANN += [F:MVC]ORDBPIATIC
   If dim([M:BPC1]LNDAUZ) <> -1
      WMNTANN += [F:MVC]LNDBPIATIC
      WMNTANN += [F:MVC]LNDDLVC
   Endif
   WMNTANN += [F:MVC]BLCC
   WMNTANN += [F:MVC]NYTBILC(0) + [F:MVC]NYTBILC(1) + [F:MVC]NYTBILC(2)
   WMNTANN += [F:MVC]NIVDLVC
   WMNTANN += [F:MVC]DLVOSTC
   WMNTANN += [F:MVC]NPTINVC
Next
If WMNTANN <> 0
   GERR=1 : GMESSAGE = mess(2,192,1) : OK = 0 : Return
Endif

#---- test client facture, payeur ou groupe
For [BPC]
   If [F:BPC]BPCNUM <> [M:BPC0]BPCNUM
      If [F:BPC]BPCINV = [M:BPC0]BPCNUM |
&        [F:BPC]BPCPYR = [M:BPC0]BPCNUM |
&        [F:BPC]BPCGRU = [M:BPC0]BPCNUM
         #MAE, bg 70563 GERR=1 :GMESSAGE = mess(3,192,1) : OK = 0 : Return
         GERR=1 :GMESSAGE = mess(3,192,1) : OK = 0 : Break
      Endif
   Endif
Next
Return

#######################################################################
$ANNULE

#------------------------------------#
# supression des textes associées    #
#------------------------------------#
Local Integer WRET
#Local Integer WRETOUR
#Local Char WNUMTEX (12)

#If GACTFTC=2
#   WNUMTEX = [M:BPC1]ORDTEX
#   If WNUMTEX <> ""
#      WRETOUR = 0
#      Call TEX(9,"BPC1","","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
#   Endif
#   WNUMTEX = [M:BPC1]INVTEX
#   If WNUMTEX <> ""
#      WRETOUR = 0
#      Call TEX(9,"BPC2","","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
#   Endif
#Endif

# Suppression des textes commande et facture
If GACTFTC=2
   If [M:BPC1]ORDTEX<>""
      Call SUP_CLOB([M:BPC1]ORDTEX,WRET) From TRTX3TEX
   Endif
   If [M:BPC1]INVTEX<>""
      Call SUP_CLOB([M:BPC1]INVTEX,WRET) From TRTX3TEX
   Endif
Endif

#---- lecture bpartner pour depositionner le flag BPCFLG
Update [BPR] Where [F:BPR]BPRNUM = [M:BPC0]BPCNUM With BPCFLG = 1
If fstat <> 0
   GERR=1 : GMESSAGE = mess(4,192,1) : GOK = 0 : Return
Endif
#---- suppression des clients livrés
If GACTFTC=2 Gosub ANNBPD Endif

#Modif CRM      24 août 2001
#Supprime la mention client interne.

If !clalev([F:DBI]) : Local File DOOBPCINT [DBI] : Endif
Read [DBI] DBI0 = [M:BPC0]BPCNUM
If !fstat
    Delete [DBI] Curr
    If fstat
        GOK = 0
        Return
    Endif
Endif

#LSE 05/07/2005
If GMODU(12) = 2
    #Supprime les associations de donneurs d'ordre.
    If !clalev([F:DBL]) : Local File DOOBPCLNK [DBL] : Endif

    Delete [DBL] Where [F:DBL]BPCNUM = [M:BPC0]BPCNUM
    If fstat
        GOK = 0
        Return
    Endif
Endif


Return

########################################
$CREBPR
#Local Shortint I,J,K
#I = find (2,[M:BPAC]BPAADDFLG (0..[M:BPAC]NBADR -1))
#If I <> 0     I -= 1 : Endif
#If I < 0      I = 0  : Endif

#J = ([M:CNTC]NBCNT>0)*max(1,find (2,[M:CNTC]CNTFLG (0..[M:CNTC]NBCNT -1)))

Local Integer LEXI

Local Shortint J
# K = find (2,[M:BIDC]BIDNUMFLG (0..[M:BIDC]NBRIB -1))

Look [BPR]BPR0 = [F:BPC]BPCNUM
If fstat <> 0
    Readlock [BPR]BPR0 = [F:BPC]BPCNUM
    If fstat
        Raz [F:BPR]
        Raz LEXI
    Else
        LEXI = 1
    Endif
    [F:BPR]          = [M:BPRC]
    [F:BPR]BPRNUM    = [F:BPC]BPCNUM
    [F:BPR]BPAADD    = [F:BPC]BPAADD
    [F:BPR]CNTNAM    = [F:BPC]CNTNAM
#     [F:BPR]BPAADD    = [M:BPAC]CODADR (I)

#     If   J <> 0 : [F:BPR]CNTNAM    = [M:CNTC]CCNCRM (J-1)
#     Else          [F:BPR]CNTNAM    = ""
#     Endif


    #--- Le RIB par défaut du tiers vient maintenant
    #--- du RIB par défaut de l'adresse par défaut du tiers
    #If K <> 0
    #    [F:BPR]BIDNUM    = [M:BIDC]BIDNUM (K-1)
    #    [F:BPR]BIDCRY    = [M:BIDC]BIDCRY (K-1)
    #Else
    #    [F:BPR]BIDNUM    = ""
    #    [F:BPR]BIDCRY    = ""
    #Endif
    #MAE, le 09/01/09, bg51535
    Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
    If !fstat
       [F:BPR]BIDNUM=[F:BPA]BPABID
    Else
       [F:BPR]BIDNUM=""
    Endif

    [F:BPR]BPSFLG    = 1
    [F:BPR]BPTFLG    = 1
    [F:BPR]REPFLG    = 1
    [F:BPR]FCTFLG    = 1

#-- pas celui de tiers divers
#    [F:BPR]BPRACC    = 1
    For I = 0 To 3
        [F:BPR]BPRFLG (I) = 1
    Next I
#MAE, le 25/11/2008, le tiers est actif par défaut
#    [F:BPR]ENAFLG    = [F:BPC]BPCSTA
    [F:BPR]ENAFLG    = 2
    [F:BPR]BPCFLG    = 2
    [F:BPR]CREDAT    = date$
    [F:BPR]CREUSR    = GUSER
    [F:BPR]BRGCOD    = [F:BPC]BCGCOD
    [F:BPR]BRGOBJ    = "BPC"
    If LEXI
        Rewrite [BPR]
    Else
        Write [BPR]
    Endif
    If fstat
        GOK = 0 : Call FSTA("BPR") From GLOCK
    Endif
Else
     Readlock [BPR]BPR0 = [F:BPC]BPCNUM
     If fstat = 1
         GOK = -1 : GLOCK = "$BPARTNER"-[F:BPC]BPCNUM : Return
     Endif
     Local Char WSAV_CUR(GLONCUR)
     [L]WSAV_CUR      = [F:BPR]CUR        : # Sauvegarde devise tiers
     [F:BPR]          = [M:BPRC]
     [F:BPR]CUR       = [L]WSAV_CUR       : # Restitution devise tiers
     [F:BPR]BPRNUM    = [F:BPC]BPCNUM
#     [F:BPR]BPAADD    = [M:BPAC]CODADR (I)                 : # L'adresse par défaut est maintenant dans la fiche client
#     If   J <> 0 : [F:BPR]CNTNAM    = [M:CNTC]CCNCRM (J-1) : # Le contact par défaut est maintenant dans la fiche client
#     Else          [F:BPR]CNTNAM    = ""
#     Endif

#--- Le RIB par défaut du tiers vient maintenant
#--- du RIB par défaut de l'adresse par défaut du tiers
#     If K <> 0
#         [F:BPR]BIDNUM    = [M:BIDC]BIDNUM (K-1)
#         [F:BPR]BIDCRY    = [M:BIDC]BIDCRY (K-1)
#     Else
#         [F:BPR]BIDNUM    = ""
#         [F:BPR]BIDCRY    = ""
#     Endif

    #MAE, bg 71310, réécriture du RIB si il a été modifié
    Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
    If !fstat
       [F:BPR]BIDNUM=[F:BPA]BPABID
    Else
       [F:BPR]BIDNUM=""
    Endif
    [F:BPR]BPCFLG    = 2
    [F:BPR]UPDDAT    = date$
    [F:BPR]UPDUSR    = GUSER
    Rewrite [BPR]
     If fstat
            GOK = 0 : Call FSTA("BR1") From GLOCK
     Endif
Endif


Return

########################################
$CREBPA

Default Mask [BPAC]
Call CREBPA(WBPATYP,[M:BPC0]BPCNUM) From TRTBPA
If GOK < 1 : Return : Endif
Return

########################################
$CRERIB

Default Mask [BIDC]
Call CRERIB(WBPATYP,[M:BPC0]BPCNUM) From TRTBPA
If GOK < 1 : Return : Endif
Return

########################################
$CRECNT
Default Mask [CNTC]
Call CRECNT(WBPATYP,[M:BPC0]BPCNUM) From TRTBPA
If GOK < 1 : Return : Endif

  Call MAJ_CNTNAM("[F:BPC]") From SUBBPR  # FGR 10/01/2013 X3SUIVI83886
Return

# FGR 29/07/2014 : X3SUIVI100229 (début)
########################################
$CREBPD
Local Integer WRET, LEXI
Local Integer NI   # FGR 28/07/2014 : X3SUIVI100229
Local Integer NE   # FGR 28/07/2014 : X3SUIVI100229

  # suppression des clients livrés avec test des locks
  If GREP <> "C" & GREP <> "D"
    Gosub ANNBPD
  Endif
  # FGR 14/10/2014 : X3SUIVI101807 : On ne conserve que le mode optimisé.
  #  # Création des clients livrés
  #  If dim(GBPCADDOPT) >= 0 Then
    # Cas Optimisé
    # FGR 28/07/2014 : X3SUIVI100229 : Modification de la façon de parcourir la boucle
    #                                  pour ne traiter que celles qui ont été modifiées ou créées ([M:BPC4]FLMOD(x)=1)
    If find(1, [M:BPC4]FLMOD(0..[M:BPC4]NBDLV-1)) <> 0 Then
      #For nolign = 1 To [M:BPC4]NBDLV
      NI = find(1, [M:BPC4]FLMOD(0..[M:BPC4]NBDLV-1))
      Repeat
        nolign = NI
        # ------------------------------------------------------
        Gosub WRITE_REWRITE_BPD
        If GOK < 1 Then
          Break
        Endif
        # ------------------------------------------------------
        NE = NI
        NI = find(1, [M:BPC4]FLMOD(NE..[M:BPC4]NBDLV-1))
        If NI > 0 Then
          NI = NI + NE
        Endif
      Until NI <= 0
    Endif
  #  Else
  #    # Cas Non optimisé
  #    For nolign=1 To [M:BPC4]NBDLV
  #      Gosub WRITE_REWRITE_BPD
  #      If GOK < 1 Then
  #        Break
  #      Endif
  #    Next nolign
  #  Endif
Return

########################################################################
WRITE_REWRITE_BPD
  Readlock [BPD]BPD0=[F:BPC]BPCNUM;[M:BPC4]BPAADD(nolign-1)
  If !fstat Then
    LEXI = 1
  Else
    LEXI = 0
  Endif
  [F:BPD]          = [M:BPC4]
  [F:BPD]BPCNUM    = [F:BPC]BPCNUM
  [F:BPD]BPDNAM(0) = [M:BPC4]BPDNAM0(nolign-1)
  [F:BPD]BPDNAM(1) = [M:BPC4]BPDNAM1(nolign-1)
  [F:BPD]VACBPR    = [M:BPC4]VACBPD(nolign-1)
  If dim([M:BPC4]SSTENTCOD) > 0 Then
    [F:BPD]SSTENTCOD = [M:BPC4]SSTENTCOD(nolign-1)
  Endif
  # -------------------------------------
  # FGR 21/12/2010 : X3SUIVI70104 (début)
  #[F:BPD]CREDAT    = date$
  #[F:BPD]CREUSR    = GUSER
  If [F:BPD]CREDAT = [0/0/0] Then
    [F:BPD]CREDAT = date$  # C'est une vraie création
    Raz [F:BPD]UPDDAT
  Else
    [F:BPD]UPDDAT = date$  # C'est une modification
  Endif
  If [M:BPC4]FLMOD(nolign-1) = 1 Then
    #       Raz [F:BPD]UPDSTP  # FGR SDATA Nouveau superviseur
    Raz [F:BPD]UPDUSR
  Endif
  # FGR 21/12/2010 : X3SUIVI70104 (fin)
  # -------------------------------------
  If [F:BPD]LAN="" Then
    [F:BPD]LAN=[M:BPRC]LAN
  Endif
  # Le régime de taxe ne doit pas être initialisé à partir du client
  #If [F:BPD]VACBPR="" [F:BPD]VACBPR=[M:BPC3]VACBPR Endif
  # particularité pour le représentant (nb par code activité)
  If dim([M:BPC4]REP0) > 0 Then
    [F:BPD]REP(0) = [M:BPC4]REP0(nolign-1)
  Endif
  If dim([M:BPC4]REP1) > 0 Then
    [F:BPD]REP(1) = [M:BPC4]REP1(nolign-1)
  Endif
  # Création ou mise à jour des textes prépa et livraison
  If [M:BPC4]PRPTEX(nolign-1)<>"" Then
    Call CRE_CLOB([M:BPC4]PRPTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1 Then
      Return
    Endif
  Endif
  If [M:BPC4]DLVTEX(nolign-1)<>"" Then
    Call CRE_CLOB([M:BPC4]DLVTEX(nolign-1),GOK) From TRTX3TEX
    If GOK<1 Then
      Return
    Endif
  Endif
  [F:BPD]PRPTEX = [M:BPC4]PRPTEX(nolign-1)
  [F:BPD]DLVTEX = [M:BPC4]DLVTEX(nolign-1)
  If LEXI Then
    Rewrite [BPD]
  Else
    Write [BPD]
  Endif
  If fstat Then
    GOK = 0
    Call FSTA("BPD") From GLOCK
    Return
  Endif
Return
# FGR 29/07/2014 : X3SUIVI100229 (fin)

