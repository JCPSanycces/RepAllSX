#      Endif
#      For nolign = 1 To [M:BPC4]NBDLV
#         If [M]ANCPRPTEX (nolign-1) <> [M]PRPTEX (nolign-1)
#            WNUMTEX = [M:BPC4]PRPTEX(nolign-1)
#            Call TEX(9,"BPD1","","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
#         Endif
#         If [M]ANCDLVTEX (nolign-1) <> [M]DLVTEX (nolign-1)
#            WNUMTEX = [M:BPC4]DLVTEX(nolign-1)
#            Call TEX(9,"BPD2","","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
#         Endif
#      Next nolign
#   Elsif GREP ="C"
#      WNUMTEX = [M:BPC1]ORDTEX
#      Call TEX(9,"BPC1","","","",WNUMTEX,"A",WRETOUR) From TRTX3TEX
