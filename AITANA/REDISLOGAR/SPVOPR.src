$ACTION

# Appel fonctions complémentaires GFI pour l'objet OPR
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Gosub ACTION From SPVOBJOPR

Return

########################################
Subprog AS_ASSPRD(VALEUR)
Variable Char    VALEUR()

Call LECTURE("OPE",[M:OPR1]CODOPE(nolign-1),"")From CONTOBJ
If [F:OPE]OPETYP<>1
    mkstat=2
Endif

End

########################################
Subprog AS_ASSINT(VALEUR)
Variable Char    VALEUR()

Call LECTURE("OPE",[M:OPR1]CODOPE(nolign-1),"")From CONTOBJ
If [F:OPE]OPETYP<>2
    mkstat=2
Endif

End

########################################
Subprog C_UOM(VALEUR)
Variable Char    VALEUR()

Local File TABUNIT

Call LECTURE("OPE",[M:OPR1]CODOPE(nolign-1),"")From CONTOBJ
Call LECTURE("TUN",VALEUR,"")From CONTOBJ
Case [F:OPE]OPETYP
    When 1
        If [F:TUN]UOMTYP=5
            GMESSAGE=VALEUR-mess(19,[V]GXMSGPSA,1)
            mkstat=2
        Endif
    When 2
        If [F:TUN]UOMTYP<>5
            GMESSAGE=VALEUR-mess(18,[V]GXMSGPSA,1)
            mkstat=2
        Endif
Endcase

Close Local File [TUN]
End

