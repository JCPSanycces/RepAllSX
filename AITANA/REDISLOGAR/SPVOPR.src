######################################################################################
Subprog CHERCHEFILSSUP(PERE,NIVEAU)
    Value Char    PERE
    Value Integer NIVEAU

    Gosub INI_XGRPUTIL From SPVOBJXGR

    Local File XGRPUSR [XGR]
    For [F:XGR] Where [F:XGR]XCODEP=[L]PERE
        Local Integer XI
        Local Integer YI
        If[F:XGR]XRUBRIQUE = 2
            If instr(1,[L]XGRPUTIL,[F:XGR]XCODE)
                XI = instr(1,[L]XGRPUTIL,[F:XGR]XCODE)-2
                # On vire la rubrique de la liste des rubriques utilisateur
                #Assign "[M:"+[L]XAMSK+"]XGRPUTIL([M:"+[L]XAMSK+"]XGRPLIG)" With seg$([L]XGRPUTIL,1,XI)+seg$([L]XGRPUTIL,instr(XI+2,[L]XGRPUTIL,";"),len([L]XGRPUTIL))
                Assign "[M:"+[L]XAMSK+"]XGRPUTIL([L]GRPLIG)" With seg$([L]XGRPUTIL,1,XI)+seg$([L]XGRPUTIL,instr(XI+2,[L]XGRPUTIL,";"),len([L]XGRPUTIL))
            Endif
        Else
            Call CHERCHEFILSSUP([F:XGR]XCODE,0)
        Endif
    Next
End

######################################################################################
Subprog AS_NBLIG

# Gestion des classifications pour Planner
#---
If dim([V]GXOPTAGE)>0 & [V]GXOPTAGE
  [M:OPR1]XGRPLIG = nolign
  Local Char XGRPU(250)
  [L]XGRPU = [M:OPR1]XGRPUTIL(nolign-1)
  Raz [M:OPR1]XNBGRP
  Gosub CHARGE_HIE From SPVOBJOPR
  Affzo [M:OPR1]
  If [M:OPR1]CODOPE(nolign-1)="" | [M:OPR1]OPETYP(nolign-1)=1
    Raz [M:OPR1]XGRPLIG
  Endif
  # Surbrillance de la ligne
  Local Integer ZI
  For [L]ZI=0 To [M:OPR1]NBLIG
    If [L]ZI<>nolign-1 | [M:OPR1]NBLIG=0
      Chgstl [M:OPR1]NBLIG([L]ZI) With ""
    Else
      Chgstl [M:OPR1]NBLIG([L]ZI) With "AMKCUR"
    Endif
  Next
Endif
#---

End

######################################################################################
Subprog AS_CODOPR(VALEUR)
Variable Char    VALEUR()

# Chargement des classifications
#--
If dim([V]GXOPTAGE)>0 & [V]GXOPTAGE
  Gosub LIENS From SPVOBJOPR
  Raz [M:OPR1]XGRPLIG
  Affzo [OPR1]
  Local Integer ZI
  For [L]ZI=0 To [M:OPR1]NBLIG
    Chgstl [M:OPR1]NBLIG([L]ZI) With ""
  Next
Endif
#--

End

######################################################################################
Subprog AS_BPAADD(VALEUR)
Variable Char    VALEUR()
If [M:OPR1]BPSNUM(nolign-1)=""
  mkstat=1
Elsif VALEUR=""
  If !clalev([F:BPR]) : Local File BPARTNER : Endif
  Read [F:BPR]BPR0=[M:OPR1]BPSNUM(nolign-1)
  If !fstat
    VALEUR=[F:BPR]BPAADD
  Endif
Endif
End

######################################################################################
Subprog AV_CURSCO(VALEUR)
Variable Char    VALEUR()
If [M:OPR1]BPSNUM(nolign-1)=""
  mkstat=1
Elsif VALEUR=""
  If !clalev([F:BPS]) : Local File BPSUPPLIER : Endif
  Read [F:BPS]BPS0=[M:OPR1]BPSNUM(nolign-1)
  If !fstat
    VALEUR=[F:BPS]CUR
  Endif
Endif
End

######################################################################################
Subprog C_BPAADD(VALEUR)
Variable Char    VALEUR()
If !clalev([F:BPA]) : Local File BPADDRESS : Endif
Read [BPA]BPA0=1;[M:OPR1]BPSNUM(nolign-1);VALEUR
If fstat
  mkstat=1
Endif
End

