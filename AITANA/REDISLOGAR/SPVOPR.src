######################################################################################
Subprog AV_OPETYP(VALEUR)
Variable Integer VALEUR
Read [F:OPE]OPE0=[M:OPR1]CODOPE(nolign-1)
If !fstat
  VALEUR=[F:OPE]OPETYP
Else
  Raz VALEUR
Endif
End

######################################################################################
Subprog AV_CURINV(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
