End

######################################################################################
Subprog IB_XNBGRP
Local Char XGBOUT5
Local Char XGBOUT7
[L]XGBOUT5 = GBOUT5
[L]XGBOUT7 = GBOUT7
If [M:OPR1]XGRPLIG=0
  Raz GBOUT5
  Raz GBOUT7
Else
  GBOUT5 = [L]XGBOUT5
  GBOUT7 = [L]XGBOUT7
Endif
End
