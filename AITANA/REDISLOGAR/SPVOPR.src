Endif
End

######################################################################################
Subprog AV_CURPUR(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  VALEUR=GSYSCUR
Endif
End

######################################################################################
Subprog AV_XNBGRP

    If !clalev([XXGR]) : Local File XGRPUSR  [XXGR] : Endif
    If !clalev([XXGD]) : Local File XGRPUSRD [XXGD] : Endif

    Gosub INI_XGRPUTIL From SPVOBJXGR

    # Si on est sur un element de dernier niveau on affiche les elements details
    Read [F:XXGR]XGR0 = evalue("[M:"+[L]XAMSK+"]"+"XCLE(nolign-1)") #[M:OPR1]XCLE(nolign-1)
    If !fstat
        Assign "[M:"+[L]XAMSK+"]"+"XALPHA1" With ""
        Assign "[M:"+[L]XAMSK+"]"+"XALPHA2" With ""
        Assign "[M:"+[L]XAMSK+"]"+"XNUM1"   With 0
        Assign "[M:"+[L]XAMSK+"]"+"XNUM2"   With 0
        Assign "[M:"+[L]XAMSK+"]"+"XDATE1" With [0/0/0]
        Assign "[M:"+[L]XAMSK+"]"+"XDATE1" With [0/0/0]

        If [F:XXGR]XRUBRIQUE = 2
            If [F:XXGR]XALPHA1I <> "" : Chgtzn [M]XALPHA1 With [F:XXGR]XALPHA1I : Actzo [M]XALPHA1
            Else                      : Chgtzn [M]XALPHA1 With "Non renseigné"  : Diszo [M]XALPHA1 : Endif

            If [F:XXGR]XALPHA2I <> "" : Chgtzn [M]XALPHA2 With [F:XXGR]XALPHA2I : Actzo [M]XALPHA2
            Else                      : Chgtzn [M]XALPHA2 With "Non renseigné"  : Diszo [M]XALPHA2 : Endif

            If [F:XXGR]XNUM1I <> "" : Chgtzn [M]XNUM1   With [F:XXGR]XNUM1I  : Actzo [M]XNUM1
            Else                    : Chgtzn [M]XNUM1   With "Non renseigné" : Diszo [M]XNUM1 : Endif

            If [F:XXGR]XNUM2I <> "" : Chgtzn [M]XNUM2   With [F:XXGR]XNUM2I  : Actzo [M]XNUM2
            Else                    : Chgtzn [M]XNUM2   With "Non renseigné" : Diszo [M]XNUM2 : Endif

            If [F:XXGR]XDATE1I <> "" : Chgtzn [M]XDATE1  With [F:XXGR]XDATE1I : Actzo [M]XDATE1
            Else                     : Chgtzn [M]XDATE1  With "Non renseigné" : Diszo [M]XDATE1 : Endif

            If [F:XXGR]XDATE2I <> "" : Chgtzn [M]XDATE2  With [F:XXGR]XDATE2I : Actzo [M]XDATE2
            Else                     : Chgtzn [M]XDATE2  With "Non renseigné" : Diszo [M]XDATE2 : Endif

            Case [L]XATAB
                When "FNE","OPR" : Read [F:XXGD]XGD0 = [F:XXGR]XCODE;""
                When "AUS"       : Read [F:XXGD]XGD0 = [F:XXGR]XCODE;[F:OPR]CODOPR
                When Default     : Read [F:XXGD]XGD0 = [F:XXGR]XCODE;""
            Endcase

            If !fstat
                Assign "[M:"+[L]XAMSK+"]"+"XALPHA1"  With [F:XXGD]XALPHA1
                Assign "[M:"+[L]XAMSK+"]"+"XALPHA2"  With [F:XXGD]XALPHA2
                Assign "[M:"+[L]XAMSK+"]"+"XALPHA1V" With [F:XXGD]XALPHA1V
                Assign "[M:"+[L]XAMSK+"]"+"XALPHA2V" With [F:XXGD]XALPHA2V
                Assign "[M:"+[L]XAMSK+"]"+"XNUM1"    With [F:XXGD]XNUM1
                Assign "[M:"+[L]XAMSK+"]"+"XNUM2"    With [F:XXGD]XNUM2
                Assign "[M:"+[L]XAMSK+"]"+"XDATE1"   With [F:XXGD]XDATE1
                Assign "[M:"+[L]XAMSK+"]"+"XDATE2"   With [F:XXGD]XDATE2

                Actzo [M]XRUBRIQUE
                Assign "[M:"+[L]XAMSK+"]"+"XRUBRIQUE"  With 2
                Actzo [M]XICODEF

                If evalue("[M:"+[L]XAMSK+"]"+"XALPHA1")="" & evalue("[M:"+[L]XAMSK+"]"+"XALPHA2")="" & evalue("[M:"+[L]XAMSK+"]"+"XNUM1")=0 & evalue("[M:"+[L]XAMSK+"]"+"XNUM1")=0 & evalue("[M:"+[L]
& XAMSK+"]"+
& "XDATE1")=[0/0/0] & evalue("[M:"+[L]XAMSK+"]"+"XDATE1")=[0/0/0]
                    Assign "[M:"+[L]XAMSK+"]"+"XALPHA1"  With [F:XXGR]XALPHA1D
                    Assign "[M:"+[L]XAMSK+"]"+"XALPHA1"  With [F:XXGR]XALPHA2D
                    Assign "[M:"+[L]XAMSK+"]"+"XNUM1"    With [F:XXGR]XNUM1D
                    Assign "[M:"+[L]XAMSK+"]"+"XNUM2"    With [F:XXGR]XNUM2D
                    Assign "[M:"+[L]XAMSK+"]"+"XDATE1"   With [F:XXGR]XDATE1D
                    Assign "[M:"+[L]XAMSK+"]"+"XDATE2"   With [F:XXGR]XDATE2D
                Endif

            Endif
        Else
           Diszo [M]XALPHA1 : Chgtzn [M]XALPHA1 With "Non renseigné"
           Diszo [M]XALPHA2 : Chgtzn [M]XALPHA2 With "Non renseigné"
           Diszo [M]XNUM1   : Chgtzn [M]XNUM1   With "Non renseigné"
           Diszo [M]XNUM2   : Chgtzn [M]XNUM2   With "Non renseigné"
           Diszo [M]XDATE1  : Chgtzn [M]XDATE1  With "Non renseigné"
           Diszo [M]XDATE2  : Chgtzn [M]XDATE2  With "Non renseigné"
           Diszo [M]XRUBRIQUE
           Grizo [M]XICODEF
        Endif

        Affzo [M]XALPHA1 : Affzo [M]XALPHA2
        Affzo [M]XNUM1   : Affzo [M]XNUM2
        Affzo [M]XDATE1  : Affzo [M]XDATE2

         Assign "[M:"+[L]XAMSK+"]"+"XCODE"  With [F:XXGR]XCODE
         Grizo [M]XCODE : Affzo [M]XCODE

    Endif

End

######################################################################################
Subprog B5_XNBGRP

    Gosub INI_XGRPUTIL From SPVOBJXGR

    Local Char XGRPU(250)

    Local Char XCODE
    For [F:XGR] Where XCODEP = ""
        [L]XCODE = [F:XGR]XCODE : Break
    Next
    If [L]XCODE <> ""
        Local Char CLE2
        GCONSULT = 2

        Local Decimal BASPAG
        If !GWEBSERV
         ## Action XGRPALO
         Local Char    PARMSK(250)(1..20) , SAVACT(20)
         SAVACT = GACTION : GACTION = "XGRPALO"
         Call TRAITE_NUM(BASPAG,PARMSK,"XGRPUSRALO","SPVXGR","",1,"") From GTRAITE
         GACTION = SAVACT
        Endif

        GCONSULT = 0

        # Si on a modifié les groupes de l'utilisateur, on passe en modif de l utilisateur
        If evalue("[F:"+[L]XATAB+"]XGRPUTIL") <> [L]XGRPUTIL
            #Assign "[M:"+[L]XAMSK+"]XGRPUTIL([M:"+[L]XAMSK+"]XGRPLIG)" With evalue("[F:"+[L]XATAB+"]"+"XGRPUTIL")
            #[L]XGRPU = evalue("[M:"+[L]XAMSK+"]XGRPUTIL([M:"+[L]XAMSK+"]XGRPLIG)")
            Assign "[M:"+[L]XAMSK+"]XGRPUTIL([L]GRPLIG)" With evalue("[F:"+[L]XATAB+"]"+"XGRPUTIL")
            [L]XGRPU = evalue("[M:"+[L]XAMSK+"]XGRPUTIL([L]GRPLIG)")
            Assign "[M:"+[L]XAMSK+"]"+"XNBGRP" With 0
            Gosub CHARGE_HIE From SPVOBJOPR
            Affzo
            mkstat=4
        Endif
    Endif
End

######################################################################################
Subprog B7_XNBGRP

    Gosub INI_XGRPUTIL From SPVOBJXGR

    Local Char XGRPU(250)
    Local File XGRPUSR [XXGR]

    Read [F:XXGR]XGR0 =  evalue("[M:"+[L]XAMSK+"]"+"XCLE(nolign-1)")
    If !fstat
        Local Integer XI
        Local Integer YI
        If[F:XXGR]XRUBRIQUE = 2
            If instr(1,[L]XGRPUTIL,[F:XXGR]XCODE)
                XI = instr(1,[L]XGRPUTIL,[F:XXGR]XCODE)-2
                # On vire la rubrique de la liste des rubriques utilisateur
                #Assign "[M:"+[L]XAMSK+"]XGRPUTIL([M:"+[L]XAMSK+"]XGRPLIG)" With seg$([L]XGRPUTIL,1,XI)+seg$([L]XGRPUTIL,instr(XI+2,[L]XGRPUTIL,";"),len([L]XGRPUTIL))
                Assign "[M:"+[L]XAMSK+"]XGRPUTIL([L]GRPLIG)" With seg$([L]XGRPUTIL,1,XI)+seg$([L]XGRPUTIL,instr(XI+2,[L]XGRPUTIL,";"),len([L]XGRPUTIL))
            Endif
        Else
            Call CHERCHEFILSSUP([F:XXGR]XCODE,0)
        Endif

        # On raz la hierarchie puis on la reconstruit
        For I=0 To evalue("[M:"+[L]XAMSK+"]"+"XNBGRP")
          Assign "[M:"+[L]XAMSK+"]"+"XPAR(I)"    With ""
          Assign "[M:"+[L]XAMSK+"]"+"XPAR2(I)"   With ""
          Assign "[M:"+[L]XAMSK+"]"+"XCLE(I)"    With ""
          Assign "[M:"+[L]XAMSK+"]"+"XCLE2(I)"   With ""
          Assign "[M:"+[L]XAMSK+"]"+"XDES(I)"    With ""
          Assign "[M:"+[L]XAMSK+"]"+"XDESSHO(I)" With ""
          Assign "[M:"+[L]XAMSK+"]"+"XNIV(I)"    With 0
          Assign "[M:"+[L]XAMSK+"]"+"XIMG1(I)"   With ""
          Assign "[M:"+[L]XAMSK+"]"+"XICO1(I)"   With ""
          Assign "[M:"+[L]XAMSK+"]"+"XLIGSG(I)"  With 0
          Assign "[M:"+[L]XAMSK+"]"+"XRANGG(I)"  With 0
          Assign "[M:"+[L]XAMSK+"]"+"XFRMG(I)"   With ""
          Assign "[M:"+[L]XAMSK+"]"+"XEXP(I)"    With 0
          Assign "[M:"+[L]XAMSK+"]"+"XINFO1(I)"  With ""
          Assign "[M:"+[L]XAMSK+"]"+"XINFO2(I)"  With ""
          Assign "[M:"+[L]XAMSK+"]"+"XINFO3(I)"  With ""
        Next
        Assign "[M:"+[L]XAMSK+"]"+"XNBGRP" With 0

        #[L]XGRPU = [M:OPR1]XGRPUTIL([M:OPR1]XGRPLIG)
        Assign "[L]XGRPU" With evalue("[M:"+[L]XAMSK+"]XGRPUTIL([L]GRPLIG)")
        Gosub CHARGE_HIE From SPVOBJOPR
        Affzo

        mkstat = 4
    Endif

End

######################################################################################
Subprog CL_XICODEF(VALEUR)
Variable Char    VALEUR()

    If !clalev([XXGR]) : Local File XGRPUSR [XXGR] : Endif

    Gosub INI_XGRPUTIL From SPVOBJXGR

    # Si on est sur un element de dernier niveau on affiche les elements details
    #Read [F:XXGR]XGR0 = [M:OPR1]XCLE(nolign-1)
    Read [F:XXGR]XGR0 = evalue("[M:"+[L]XAMSK+"]"+"XCLE(nolign-1)")
    If !fstat
        If [F:XXGR]XRUBRIQUE=2
            Assign "[M:"+[L]XAMSK+"]"+"XALPHA1"    With [F:XXGR]XALPHA1D
            Assign "[M:"+[L]XAMSK+"]"+"XALPHA2"    With [F:XXGR]XALPHA2D
            Assign "[M:"+[L]XAMSK+"]"+"XALPHA1V"   With [F:XXGR]XALPHA1V
            Assign "[M:"+[L]XAMSK+"]"+"XALPHA2V"   With [F:XXGR]XALPHA2V
            Assign "[M:"+[L]XAMSK+"]"+"XNUM1"      With [F:XXGR]XNUM1D
            Assign "[M:"+[L]XAMSK+"]"+"XNUM2"      With [F:XXGR]XNUM2D
            Assign "[M:"+[L]XAMSK+"]"+"XDATE1"     With [F:XXGR]XDATE1D
            Assign "[M:"+[L]XAMSK+"]"+"XDATE2"     With [F:XXGR]XDATE2D
            Affzo [M]XALPHA1 : Affzo [M]XALPHA2
            Affzo [M]XNUM1   : Affzo [M]XNUM2
            Affzo [M]XDATE1  : Affzo [M]XDATE2
            mkstat = 4
        Endif
    Endif
End

