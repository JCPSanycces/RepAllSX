#<AdxTL>@(#)2.0.0.0 $Revision$
#ACV#X12
#TIT#Consultation DS

#==========================================================================================
# Gestion de la consultation :CRQ -- Demandes de service
#
# Auteur                     : OTHYR
# Date de création           :
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 28/02/2003    OTHYR        Modélisation Web + ajout PE
# 15/09/2004    CGUES        Branchement de la recherche de texte Oracle, sup des HCODE
#==========================================================================================
Local Char PARAM(30)(2)

Call GCONSULT("CRQ","",PARAM)From GCONSULT
End


###################################################################
$ACTION
Case ACTION
    When "AUTORIS"    : Gosub AUTORIS
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "SETBOUT"    : Gosub SETBOUT
    When "FIN_CRIT"   : Gosub FIN_CRIT
    When Default
Endcase
Return

#-----------------------------------------------------------------#
#    Gestion des étiquettes liées a ACTION                        #
#-----------------------------------------------------------------#
###################################################################
$AUTORIS
Return

###################################################################
$SETBOUT
Return

###################################################################
$OUVRE

Local Char CRIT1(250), CRIT2(250), CRIT3(250), CRIT4(250), CRITSPE(250)
Local Char DEBNUM,FINNUM, KEYWORD1, KEYWORD2, TIT
Local Char RES_HCREQ(15)(30000), RES_HCREQ1(15)(30000), RES_HCREQ2(15)(30000), RES_REQ(15)(30000)
Local Integer LIGNE, Y1, NB_HCREQ, NB_HCREQ1, NB_HCREQ2, MOT, CPT_HCRES

Local Char X_FIC_RETOUR(250), X_CRIT_REQ_MOT(30)(4)
&            , X_REQ_MOT(15)(30000) , VIDE
Local Date X_REQDAT_DEB,X_CRIT_REQ_DAT(2),X_DAT_MOT(30000)
Local Integer TYPTXT(30000)
Local Char TYPOBJ
[L]TYPOBJ='REQ'

Gosub DEFCRIT

Return

###################################################################
$DEFCRIT

For I = 1 To dim(PARAM)
    Case I
        When 1
            If PARAM(I) <> "" Then
                If [F:BPR]BPRNUM <> PARAM(I) Then
                    Read [F:BPR]BPR0 = PARAM(I)
                    If fstat Then
                        Raz [F:BPR], PARAM(I)
                    Endif
                Endif
                [M:CRQ0]BPCNUM = PARAM(I)
            Endif

        When 2 :    : # Parametre Site
            If PARAM(I) <> "" Then
                If [F:FCY]FCY <> PARAM(I) Then
                    Read [F:FCY]FCY0 = PARAM(I)
                    If fstat  Raz [F:FCY] : Endif
                Endif
#                If !fstat & ((PARAM(I) = GFCYDEF & GUSRACC(1) <> 0) | (PARAM(I) <> GFCYDEF & GUSRACC(2) <> 0)) Then
                    [M:CRQ0]FCY = PARAM(I)
                    Call GETDEV([M:CRQ0]FCY) From DEVSUB
#                Endif
            Endif
    Endcase
Next

If !find([M:CRQ0]FLGREQCAN,1,2)  : [M:CRQ0]FLGREQCAN  = 2 : Endif
If !find([M:CRQ0]FLGREQCANN,1,2) : [M:CRQ0]FLGREQCANN = 2 : Endif
If !find([M:CRQ0]FLGREQCLO,1,2)  : [M:CRQ0]FLGREQCLO  = 2 : Endif
If !find([M:CRQ0]FLGREQCLON,1,2) : [M:CRQ0]FLGREQCLON = 2 : Endif
If !find([M:CRQ0]FLGREQPRN,1,2)  : [M:CRQ0]FLGREQPRN  = 2 : Endif
If !find([M:CRQ0]FLGREQPRNN,1,2) : [M:CRQ0]FLGREQPRNN = 2 : Endif
If !find([M:CRQ0]FLGDIR,1,2)     : [M:CRQ0]FLGDIR     = 2 : Endif
If !find([M:CRQ0]FLGCON,1,2)     : [M:CRQ0]FLGCON     = 2 : Endif
If !find([M:CRQ0]FLGSIT,1,2)     : [M:CRQ0]FLGSIT     = 2 : Endif
If !find([M:CRQ0]FLGMAT,1,2)     : [M:CRQ0]FLGMAT     = 2 : Endif
If !find([M:CRQ0]FLGEXT,1,2)     : [M:CRQ0]FLGEXT     = 2 : Endif

# Copie de l'écran critère (CCRQ) vers la masque 0 d'entete (CRQ0)
Gosub CRITENT From =PROGCNS

Return

###################################################################
$LECTURE

If [M:CRQ0]BEGDAT = [0/0/0] Then

    NBLU=0

    # LBORN 01/10/2013 - Mantis 20503 - On fait l'init à cet endroit pour ne pas déclencher la lecture au lancement de la consultation (sinon trop de lignes)
    [M:CRQ0]BEGDAT=[V]GDATEDEB
    If [V]GDATEFIN>=[M:CRQ0]BEGDAT
      [M:CRQ0]ENDDAT=[V]GDATEFIN
    Endif

    Return

Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 Then
    NOL = MAXLIG
Endif

Call TEMPON("R") From GESECRAN

# Positionnement des filtres
Gosub LOAD_FILTER
# Appel au filtre spécifique client
ACTION = "FILTRE"
Gosub ACTION From XOBJCNS
ACTION = "LECTURE"

#***********************************#
# RAPPEL : valeur CHGPAG :          #
#    1 : Recherche                  #
#    2 : Suite                      #
#    3 : F5 (Rafraichissement)      #
#   -1  : Dernier                   #
#   -2  : Retour (Page précédente)  #
#***********************************#
# Application des filtres
If CHGPAG > 0 Then
    SUITE = 1
    If CHGPAG = 1 Then
        RETOUR = 1
    Elsif CHGPAG = 2 Then
        RETOUR = 2
    Endif
    Filter [REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRIT4) & evalue([L]CRITSPE)
&                Order By Key REQ0 Desc
Else
    RETOUR = 1
    If CHGPAG = -1 Then
        SUITE = 1
    Else
        SUITE = 2
    Endif
    Filter [REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRIT4) & evalue([L]CRITSPE)
&                Order By Key REQ0
Endif

# RAZ du masque
If CHGPAG <> 2 & CHGPAG <> -2 Then
    Raz [M:CRQ1]
    Raz [M:CRQ2]
Endif

# On remplit une variable dimensionnée avec le résultat du filtre sur REQ
Gosub REMP_REQFIL

# On fait appel à la recherche des Hash-codes
#[L]MOT = 0
#Gosub RECH_MOT1
#Gosub RECH_MOT2

# On lie les deux listes de Hash-codes
#Gosub LIEN_LISTE

# Pour incrémenter le compteur d'infos pour le nombre de DS répondant à tel critère de Hash-codes
#[L]CPT_HCRES = 0
#If [L]MOT <> 0 Then
#    For I = 0 To Y1-1
#        If find([L]RES_REQ(I),[L]RES_HCREQ(0..[L]NB_HCREQ)) Then
#            [L]CPT_HCRES += 1
#        Endif
#    Next
#Endif

#CGUES recherche Oracle
If [L]MOT<>0
    #--------------------------------------------------------------- partie avec recherche mot
    ## recherche dans la table oracle
    Call RECH_TXT_ORA([L]TYPOBJ,[M:CRQ0]REQNUM,X_REQDAT_DEB,0,X_CRIT_REQ_MOT,X_CRIT_REQ_DATE
&                        ,[L]KEYWORD1,[L]KEYWORD2,X_FIC_RETOUR) From XMAJTXTORA

    ## récup des N°  de DS & d'inter
    adxifs=" "
    adxirs=chr$(10)
    Openi X_FIC_RETOUR Using [RESX]

    NB_HCREQ=0
    Repeat
        Rdseq [L]TYPOBJ, X_DAT_MOT(NB_HCREQ) , X_REQ_MOT(NB_HCREQ), VIDE ,[L]TYPTXT(NB_HCREQ), VIDE Using [RESX]
        If X_REQ_MOT(NB_HCREQ)<>""
            [L]RES_HCREQ([L]NB_HCREQ)=X_REQ_MOT(NB_HCREQ)
            NB_HCREQ+=1
        Endif
    Until fstat<>0
    Openi Using [RESX]
Endif

#Fin CGUES

[M:CRQ2]NBLIG2 = 0
[L]LIGNE = -1

# Lecture
For I = 0 To (Y1 - 1)
    If ([L]MOT <> 0 & find([L]RES_REQ(I),[L]RES_HCREQ(0..[L]NB_HCREQ))) | [L]MOT = 0 Then
        Read [F:REQ]REQ0 = [L]RES_REQ(I)
        If !fstat Then
            If NBLU = 1 Then
                If CHGPAG = 2 | CHGPAG = -2 Then
                    Raz [M:CRQ1]
                    Raz [M:CRQ2]
                Endif
                NBLU = 2
            Endif
            If CHGPAG > 0 Then
                If NOL >= MAXLIG-1 Then
                    SUITE = 2
                    Break
                Endif
                NOL += 1
                If NOL = 0 Then
                    DEBNUM = [F:REQ]REQNUM
                Endif
                FINNUM = [F:REQ]REQNUM
            Else
                If NOL <= 0 Then
                    RETOUR = 2
                    Break
                Endif
                NOL -= 1
                If NOL = MAXLIG-1 Then
                    FINNUM = [F:REQ]REQNUM
                Endif
                DEBNUM = [F:REQ]REQNUM
            Endif

            nolign = NOL+1

            # Modif Cperr le 21/01/03
            # Contôle de nolign avec la dimension de la zone à renseigner pour l'onglet détail de la DS
            If nolign > dim([M:CRQ2]REQNUM) Then Break Endif

            [M:CRQ1] = [F:REQ]
            Read [F:BPR]BPR0 = [F:REQ]BPCNUM
            If !fstat Then
                [M:CRQ1]BPRNAM(nolign-1) = [F:BPR]BPRNAM     :# Raison sociale
            Endif


            #2ème onglet
            [L]LIGNE += 1

            [M:CRQ2]REQNUM(nolign-1)  = [F:REQ]REQNUM
            [M:CRQ2]REQTYP(nolign-1)  = [F:REQ]REQTYP
            [M:CRQ2]BPCNUM(nolign-1)  = [F:REQ]BPCNUM
            [M:CRQ2]CREADAT(nolign-1) = [F:REQ]CREADAT

            [M:CRQ2]NBLIG2 = [L]LIGNE+1

        Endif
    Endif
Next

If [L]MOT <> 0 Then
    Inftxt num$([L]CPT_HCRES)-mess(189,[V]GXMSGPSA,1) At 2
Endif

Affzo [M:CRQ2]

Filter [REQ]

Call TEMPOFF From GESECRAN

Return


###################################################################
$REMP_REQFIL

Raz RES_REQ
[L]Y1 = 0
For [REQ]
    [L]RES_REQ(Y1) = [F:REQ]REQNUM
    [L]Y1 += 1
    If [L]Y1 = dim([L]RES_REQ) Then
        Break
    Endif
Next
Return

###################################################################
$RECH_MOT1

Raz RES_HCREQ1
[L]NB_HCREQ1 = 0

If [L]KEYWORD1 <> "" Then
    Call LOOKUP_HC("REQSUM",[L]KEYWORD1,RES_HCREQ1) From TRTHCODE

    While [L]RES_HCREQ1([L]NB_HCREQ1) <> ""
        [L]NB_HCREQ1 += 1
    Wend

    [L]MOT = 1
Endif

Return

###################################################################
$RECH_MOT2

Raz RES_HCREQ2
[L]NB_HCREQ2 = 0

If [L]KEYWORD2 <> "" Then
    Call LOOKUP_HC("REQSUM",[L]KEYWORD2,RES_HCREQ2) From TRTHCODE

    While [L]RES_HCREQ2([L]NB_HCREQ2) <> ""
        [L]NB_HCREQ2 += 1
    Wend

    [L]MOT = 1
Endif

Return

###################################################################
$LIEN_LISTE

Raz RES_HCREQ
[L]NB_HCREQ = 0

If [L]KEYWORD1 <> "" & [L]KEYWORD2 <> "" Then
    # On lie les 2 listes en "ET"
    For I = 0 To [L]NB_HCREQ1
        If find([L]RES_HCREQ1(I),[L]RES_HCREQ2(0..[L]NB_HCREQ2)) Then
            [L]RES_HCREQ([L]NB_HCREQ) = [L]RES_HCREQ1(I)
            [L]NB_HCREQ += 1
        Endif
        If [L]NB_HCREQ = dim([L]RES_HCREQ) Then
            Break
        Endif
    Next
Elsif [L]KEYWORD1 <> "" & [L]KEYWORD2 = "" Then
    # La liste résultante est RES_HCREQ1
    [L]NB_HCREQ  = [L]NB_HCREQ1
    For I = 0 To [L]NB_HCREQ1
        [L]RES_HCREQ(I) = [L]RES_HCREQ1(I)
        If I = dim([L]RES_HCREQ) Then
            Break
        Endif
    Next
Elsif [L]KEYWORD1 = "" & [L]KEYWORD2 <> "" Then
    # La liste résultante est RES_HCREQ2
    [L]NB_HCREQ  = [L]NB_HCREQ2
    For I = 0 To [L]NB_HCREQ2
        [L]RES_HCREQ(I) = [L]RES_HCREQ2(I)
        If I = dim([L]RES_HCREQ) Then
            Break
        Endif
    Next
Endif

Return

###################################################################
$LOAD_FILTER
[L]CRIT1    = "1"            :# Critere sur tiers, NumDS, Type DS, Stade DS, File d'attente
[L]CRIT2    = "1"            :# Critere sur bornes de date, Resp DS, Site
[L]CRIT3    = "1"            :# Critere sur flag Origine : Directe, Externe, Contrat, Contrat(matériel) ou Situation
[L]CRIT4    = "1"            :# Critere sur flag Imprimé, Annulé ou Clotûré
[L]CRITSPE  = "1"            :# Critère spécifique client
[L]KEYWORD1 = ""       :# Mot-clé 1
[L]KEYWORD2 = ""       :# Mot-clé 2


# 1er critere
If [M:CRQ0]REQNUM<>"" Then
    [L]CRIT1 += "&[F:REQ]REQNUM=[M:CRQ0]REQNUM"
Endif
If [M:CRQ0]REQTYP<>"" Then
    [L]CRIT1 += "&[F:REQ]REQTYP=[M:CRQ0]REQTYP"
Endif
If [M:CRQ0]REQSTA<>"" Then
    [L]CRIT1 += "&[F:REQ]REQSTA=[M:CRQ0]REQSTA"
Endif
If [M:CRQ0]QUEUE<>"" Then
    [L]CRIT1 += "&[F:REQ]QUEUE=[M:CRQ0]QUEUE"
Endif
If [M:CRQ0]BPCNUM<>"" Then
    [L]CRIT1 += "&[F:REQ]BPCNUM=[M:CRQ0]BPCNUM"
Endif

# 2eme critere
If [M:CRQ0]RESINT<>"" Then
    [L]CRIT2 += "&[F:REQ]RESINT=[M:CRQ0]RESINT"
Endif
If [M:CRQ0]FCY<>"" Then
    [L]CRIT2 += "&[F:REQ]FCY=[M:CRQ0]FCY"
Endif
If [M:CRQ0]BEGDAT <> [0/0/0] Then
    [L]CRIT2 += "&[F:REQ]CREADAT>=[M:CRQ0]BEGDAT"
Endif
If [M:CRQ0]ENDDAT <> [0/0/0] Then
    [L]CRIT2 += "&[F:REQ]CREADAT<=[M:CRQ0]ENDDAT"
Endif

# 3eme critere
# Prise en compte de l'origine
# --> Si 1, on prend origine<>directe
If [M:CRQ0]FLGDIR = 1 Then
    [L]CRIT3 += "&[F:REQ]ORIREQ<>1"
Endif
# --> Si 1, on prend origine<>contrat
If [M:CRQ0]FLGCON = 1 Then
    [L]CRIT3 += "&[F:REQ]ORIREQ<>2"
Endif
# --> Si 1, on prend origine<>situation
If [M:CRQ0]FLGSIT = 1 Then
    [L]CRIT3 += "&[F:REQ]ORIREQ<>3"
Endif
# --> Si 1, on prend origine<>contrat(matériel)
If [M:CRQ0]FLGMAT = 1 Then
    [L]CRIT3 += "&[F:REQ]ORIREQ<>4"
Endif
# --> Si 1, on prend origine<>externe
If [M:CRQ0]FLGEXT = 1 Then
    [L]CRIT3 += "&[F:REQ]ORIREQ<>5"
Endif

# 4eme critere
# Prise en compte des flag Annulé, clotûré et imprimé
If [M:CRQ0]FLGREQPRN = 1 Then
    [L]CRIT4 += "&[F:REQ]FLGREQPRN<>2"
Endif
If [M:CRQ0]FLGREQPRNN = 1 Then
    [L]CRIT4 += "&[F:REQ]FLGREQPRN=2"
Endif

If [M:CRQ0]FLGREQCLO = 1 Then
    [L]CRIT4 += "&[F:REQ]FLGREQCLO<>2"
Endif
If [M:CRQ0]FLGREQCLON = 1 Then
    [L]CRIT4 += "&[F:REQ]FLGREQCLO=2"
Endif

If [M:CRQ0]FLGREQCAN = 1 Then
    [L]CRIT4 += "&[F:REQ]FLGREQCAN<>2"
Endif
If [M:CRQ0]FLGREQCANN = 1 Then
    [L]CRIT4 += "&[F:REQ]FLGREQCAN=2"
Endif

[L]MOT=0
# Mot-clé
If [M:CRQ0]KEYWORD1 <> "" Then
    [L]KEYWORD1 = [M:CRQ0]KEYWORD1
    [L]MOT+=1
Endif
If [M:CRQ0]KEYWORD2 <> "" Then
    [L]KEYWORD2 = [M:CRQ0]KEYWORD2
    [L]MOT+=1
Endif

Raz [L]X_CRIT_REQ_MOT,X_CRIT_REQ_DAT
X_CRIT_REQ_MOT(0)  =num$([M:CRQ0]BPCNUM)        :# Tiers
X_CRIT_REQ_MOT(1)  =num$([M:CRQ0]REQTYP)        :# Type Ds
X_REQDAT_DEB =[M:CRQ0]BEGDAT               :# date Ds (début)

# Fichiers des réponses
X_FIC_RETOUR =filpath("tmp","rech_txt_req","txt")


# OTHYR - 22.10.2008
# Attention, du fait de l'utilisation d'un Order by Desc, on doit inverser !!!
Case CHGPAG
    When 3 : #Rafraichissement
        [L]CRIT1 += "&[F:REQ]REQNUM>=FINNUM"
#        [L]CRIT1 += "&[F:REQ]REQNUM>=DEBNUM"
    When 2 : #Suite
        [L]CRIT1 += "&[F:REQ]REQNUM<FINNUM"
#        [L]CRIT1 += "&[F:REQ]REQNUM>FINNUM"
    When -2 : #Retour
        [L]CRIT1 += "&[F:REQ]REQNUM>DEBNUM"
#        [L]CRIT1 += "&[F:REQ]REQNUM<DEBNUM"
Endcase

Return

###################################################################
$FIN_CRIT
Return


#-----------------------------------------------------------------#
#    Gestion des étiquettes liées aux masques CRQ0, CRQ1 et CCRQ  #
#-----------------------------------------------------------------#
                #-------------------#
                #        CRQ0       #
                #-------------------#
###################################################################
Subprog C_KEYWORD1(VALEUR)
Variable Char     VALEUR
VALEUR = toupper(VALEUR)
End

###################################################################
Subprog C_KEYWORD2(VALEUR)
Variable Char     VALEUR
VALEUR = toupper(VALEUR)
End

                #-------------------#
                #        CRQ1       #
                #-------------------#
###################################################################
Subprog IB_NBLIG

Raz GBOUT1

If [M:CRQ1]NBLIG <> 0 Then
    GBOUT1 = mess(41,[V]GXMSGPSA,1)    : # DS
Endif

End

                #-------------------#
                #        CRQ2       #
                #-------------------#
###################################################################
Subprog IB_NBLIG2

Raz GBOUT1

If [M:CRQ2]NBLIG2 <> 0 Then
    GBOUT1 = mess(41,[V]GXMSGPSA,1)    : # DS
Endif

End

###################################################################
Subprog AS_NBLIG2

If [M:CRQ2]NBLIG2 <> 0 Then
    Gosub AFF_SUM
    Gosub AFF_ITV
Endif

End

###################################################################
Subprog C_CREADAT(VALEUR)
Variable Char     VALEUR

If [M:CRQ2]NBLIG2 <> 0 Then
    Gosub AFF_SUM
    Gosub AFF_ITV
Endif

End

###################################################################
Subprog AS_REQSUM(VALEUR)
Variable Char     VALEUR
mkstat = 2
End

###################################################################
$AFF_SUM

Read [F:REQ]REQ0 = [M:CRQ2]REQNUM(nolign - 1)
If !fstat Then
    [M:CRQ2]REQSUM = [F:REQ]REQSUM
    [M:CRQ2]REQREF = [F:REQ]REQREF
Endif

Affzo [M:CRQ2]REQSUM
Affzo [M:CRQ2]REQREF

Return

###################################################################
$AFF_ITV
Local Integer K
Local Integer M

[M:CRQ2]NBLIG3 = 0

[L]K = 0
[L]M = (nolign - 1)

For [F:ITR]ITR1 Where [F:ITR]REQNUM = [M:CRQ2]REQNUM([L]M)
    [M:CRQ2]ITVNUM([L]K) = [F:ITR]ITVNUM
    [M:CRQ2]ITVTYP([L]K) = [F:ITR]ITVTYP
    [M:CRQ2]ITVDAT([L]K) = [F:ITR]ITVDAT
    [M:CRQ2]NEXSTA([L]K) = [F:ITR]NEXSTA
    [M:CRQ2]USRITV([L]K) = [F:ITR]USRITV
    [M:CRQ2]TIMLEN([L]K) = [F:ITR]TIMLEN
    [M:CRQ2]ITVSUM([L]K) = [F:ITR]ITVSUM

    [M:CRQ2]NBLIG3 = [L]K + 1

    [L]K += 1

    If [L]K = 200 Then
        GERR = 1
        GMESSAGE = mess(188,[V]GXMSGPSA,1)
        Break
    Endif
Next

Affzo [M:CRQ2]

Return


########################################
Subprog IB_NBLIG3

Raz GBOUT1

If [M:CRQ2]NBLIG3 <> 0  Then
    GBOUT1 = mess(3,[V]GXMSGPSA,1)                        : # Intervention
Endif

End
