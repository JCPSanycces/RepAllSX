#<AdxTL>@(#)0.0.0.0 $Revision$
#ACV#X11
#TIT#Gestion de l'objet PSG

GBIDC1=""
GBIDC2=""
Call OBJET("PSG",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet PSG
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "OUVRE"       : Gosub OUVRE       From SPVOBJPSG
  When "FERME"       : Gosub FERME       From SPVOBJPSG
  When "FILTRE"      : Gosub FILTRE      From SPVOBJPSG
  When "LIENS2"      : Gosub LIENS2      From SPVOBJPSG
  When "SETBOUT"     : Gosub SETBOUT     From SPVOBJPSG
  When "VERF_ANU"    : Gosub VERF_ANU    From SPVOBJPSG
  When "DEBUT_MOD"   : Gosub DEBUT_MOD   From SPVOBJPSG
  When "APRES_CRE"   : Gosub APRES_CRE   From SPVOBJPSG
  When "APRES_MOD"   : Gosub APRES_MOD   From SPVOBJPSG
  When "APRES_MODIF" : Gosub APRES_MODIF From SPVOBJPSG
Endcase
Return

########################################################################################################################
# ACTIONS SUR CHAMPS
########################################################################################################################
########################################
Subprog AP_OBJCOD(VALEUR)
Variable Char    VALEUR()
[M:PSG1]OBJET  = [F:GOB]OBJET
[M:PSG1]LNKOBJ = [F:GOB]LNKOBJ
[M:PSG1]NOMFIC = [F:GOB]FILCOD
End


########################################
Subprog AS_PSGCOD(VALEUR)
Variable Char    VALEUR()
If [V]ZTUNPSG & GREP="C"
  VALEUR=[V]GCODPARCTL
Endif
End

########################################
Subprog AS_OBJCOD(VALEUR)
Variable Char    VALEUR()
If [V]ZTUNPSG & GREP="C"
  Read [F:GOB]GOB0=[V]GXCODOBJ
  If !fstat
    VALEUR=[V]GXCODOBJ
  Endif
Endif
End



########################################
Subprog C_OBJCOD(VALEUR)
Variable Char    VALEUR()
If !clalev([F:GOB]) : Local File GASOBJ [GOB] : Endif
Read [F:GOB]GOB0 = VALEUR
If !fstat Then
    If [F:GOB]PSGCOD <> [M:PSG1]PSGCOD Then
        GMESSAGE = mess(210,GXMSGPSA(0),1)-[M:PSG1]PSGCOD
        mkstat = 2
    Endif
Endif
End

########################################
Subprog AS_XTSTFLG(VALEUR)
Variable Integer VALEUR
Call AS_XZON
End

########################################
Subprog AM_XTSTFLG(VALEUR)
Variable Integer VALEUR
[M:PSG1]TSTFLG([M:PSG1]XNUMLIG-1)=VALEUR
End

########################################
Subprog AS_XCONDLIG(VALEUR)
Variable Char     VALEUR
If VALEUR=""
  VALEUR ="1"
  [M:PSG1]CONDLIG([M:PSG1]XNUMLIG-1)=VALEUR
Endif
nolign=[M:PSG1]XNUMLIG
Affzo [M:PSG1]ZONDES,ZONCOD,XTRTLIG
nolign=1
End

########################################
Subprog AM_XCONDLIG(VALEUR)
Variable Char    VALEUR()
[M:PSG1]CONDLIG([M:PSG1]XNUMLIG-1)=VALEUR
End


########################################
Subprog AS_XMODSAI(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1
Call AS_XZON
If !mkstat & [M:PSG1]FLGDEFF([M:PSG1]XNUMLIG-1)=2
  [M:PSG1]FLGSAI([M:PSG1]XNUMLIG-1)=1
  VALEUR=2
  mkstat=2
Endif
End

########################################
Subprog AM_XMODSAI(VALEUR)
Variable Integer VALEUR
[M:PSG1]FLGSAI([M:PSG1]XNUMLIG-1)=2-(VALEUR=2)
End

########################################
Subprog AS_XCONDSAI(VALEUR)
Variable Char     VALEUR
Call AS_XZON
If !mkstat & [M:PSG1]FLGSAI([M:PSG1]XNUMLIG-1)<>2
  [M:PSG1]CONDSAI([M:PSG1]XNUMLIG-1)=""
  mkstat=1
Endif
End

########################################
Subprog AM_XCONDSAI(VALEUR)
Variable Char     VALEUR
[M:PSG1]CONDSAI([M:PSG1]XNUMLIG-1)=VALEUR
End


########################################
Subprog AS_XVALDEF(VALEUR)
Variable Char    VALEUR()
Call AS_XZON
End

########################################
Subprog AM_XVALDEF(VALEUR)
Variable Char    VALEUR()
[M:PSG1]VALDEF([M:PSG1]XNUMLIG-1)=VALEUR
End

########################################
Subprog AS_XFLGDEFF(VALEUR)
Variable Integer VALEUR
Call AS_XZON
If !mkstat & [M:PSG1]FLGSAI([M:PSG1]XNUMLIG-1)=2
  mkstat = 1
Endif
End

########################################
Subprog AM_XFLGDEFF(VALEUR)
Variable Integer VALEUR
[M:PSG1]FLGDEFF([M:PSG1]XNUMLIG-1)=VALEUR
End

########################################
Subprog AS_XFLGOBL(VALEUR)
Variable Integer VALEUR
Call AS_XZON
End

########################################
Subprog AM_XFLGOBL(VALEUR)
Variable Integer VALEUR
[M:PSG1]FLGOBL([M:PSG1]XNUMLIG-1)=VALEUR
End

########################################
Subprog AS_XFLGCTRLB(VALEUR)
Variable Integer VALEUR
Call AS_XZON
If !mkstat & VALEUR=0
  VALEUR=2
  [M:PSG1]FLGCTRLB([M:PSG1]XNUMLIG-1)=VALEUR
Endif
End

########################################
Subprog AM_XFLGCTRLB(VALEUR)
Variable Integer VALEUR
[M:PSG1]FLGCTRLB([M:PSG1]XNUMLIG-1)=VALEUR
End

########################################
Subprog AS_XCTRLSAI(VALEUR)
Variable Char    VALEUR()
Call AS_XZON
End

########################################
Subprog AM_XCTRLSAI(VALEUR)
Variable Char    VALEUR()
[M:PSG1]CTRLSAI([M:PSG1]XNUMLIG-1)=VALEUR
If [M:PSG1]XCTRLSAI="" & VALEUR<>"" & [M:PSG1]XFLGCTRLB<>2
  [M:PSG1]XFLGCTRLB=2
  [M:PSG1]FLGCTRLB([M:PSG1]XNUMLIG-1)=2
  Affzo [M:PSG1]XFLGCTRLB
Endif
End

########################################
Subprog AS_XMSGERR(VALEUR)
Variable Char    VALEUR()
Call AS_XZON
End

########################################
Subprog AM_XMSGERR(VALEUR)
Variable Char    VALEUR()
[M:PSG1]MSGERR([M:PSG1]XNUMLIG-1)=VALEUR
End


########################################
Subprog C_ZONCOD(VALEUR)
Variable Char    VALEUR()
Read [F:GOD]GOD0 = [M:PSG1]OBJCOD;VALEUR
If fstat Then
  [V]GMESSAGE = VALEUR-mess(35,[V]GXMSGPSA,1)-[M:PSG1]OBJCOD
  mkstat=2
Endif
End


########################################
Subprog AV_NOMFIC(VALEUR)
Variable Char VALEUR()
VALEUR=""
Read [F:GOD]GOD0 = [M:PSG1]OBJCOD;[M:PSG1]ZONCOD(nolign-1)
If !fstat
  If [F:GOD]TABCOD<>""
    VALEUR=[F:GOD]TABCOD
  Endif
Endif
If VALEUR=""
  Read [F:GOB]GOB0=[M:PSG1]OBJCOD
  If !fstat
    VALEUR=[F:GOB]FILCOD
  Endif
Endif
End

########################################
Subprog D_TRTSPE(VALEUR)
Variable Char    VALEUR()
VALEUR = "YPSG"+[M:PSG1]PSGCOD
End 

########################################
Subprog C_TYPOBJ(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Call CONTROLE([M:PSG1]OBJET,"!",VALEUR,[M:PSG1]LNKOBJ,mkstat)From CONTOBJ
  If !mkstat & [V]ZTUNPSG
    If !find(VALEUR,"",[V]GTYPOBJ)
      mkstat=1
    Endif
  Endif
Endif
End

########################################
Subprog AS_TYPOBJ(VALEUR)
Variable Char    VALEUR()
If [M:PSG1]OBJET=""
  mkstat=1
Endif
End

#-----------------------------------------------------------
# CPERR 1/10/2003 - SUite à l'ajout de la zone TYPOBJDES dans la table
#-----------------------------------------------------------
########################################
Subprog AM_TYPOBJ(VALEUR)
Variable Char    VALEUR()
    Call INT_AOB(1,[M]OBJET,[M]LNKOBJ,VALEUR,[M]TYPOBJDES)From XTRTAOB
End


########################################
Subprog AS_BASTAB
Local Integer ZLIG
[L]ZLIG=nolign-1
Effzo [M:PSG1]25-99 : # Pour redéclencher init
Gosub LECTAB From SPVOBJPSG
nolign=[L]ZLIG+1
Affzo [M:PSG1]ZONDES,ZONCOD,25-99
End


########################################
Subprog AS_XZON()
If [M:PSG1]XNUMLIG<=0
  mkstat=2
Else
  If [M:PSG1]ZONCOD([M:PSG1]XNUMLIG-1)=""
    mkstat=2
  Endif
Endif
End

########################################
Subprog AV_XTRTLIG(VALEUR)
Variable Char    VALEUR()
VALEUR=[M:PSG1]ZONCOD([M:PSG1]XNUMLIG-1)-[M:PSG1]ZONDES([M:PSG1]XNUMLIG-1)
End

########################################
Subprog AS_ZONCOD(VALEUR)
Variable Char    VALEUR()
If [V]ZTUNPSG & VALEUR=""
  VALEUR=[V]GXPSGZON
Endif
End

########################################
Subprog D_TYPOBJ(VALEUR)
Variable Char    VALEUR()
If [V]ZTUNPSG
  VALEUR=[V]GTYPOBJ
Endif
End

######################################################################################
Subprog AV_ZONCOD(VALEUR)
Variable Char    VALEUR()
Local Integer ZI
For [L]ZI=1 To [M:PSG1]BASTAB+1
  If [L]ZI<>[M:PSG1]XNUMLIG
    Chgstl [M:PSG1]BASTAB([L]ZI-1) With ""
  Else
    Chgstl [M:PSG1]BASTAB([L]ZI-1) With "AMKCUR"
  Endif
Next
End

######################################################################################
Subprog AS_XCOMMENT(VALEUR)
Variable Char    VALEUR()
Call AS_XZON
End

######################################################################################
Subprog AM_XCOMMENT(VALEUR)
Variable Char    VALEUR()
[M:PSG1]COMMENT([M:PSG1]XNUMLIG-1)=VALEUR
End


