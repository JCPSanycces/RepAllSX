Subprog IB_INVSITPRV2
Gosub B_ZOOM
End

Subprog IB_QTEFACTOT
Gosub B_ZOOM
End

Subprog IB_INVSIT2
Gosub B_ZOOM
End

Subprog IB_INVSITPV1M
Gosub B_ZOOM
End

Subprog IB_INVSIT1M
Gosub B_ZOOM
End

Subprog IB_INVQTYTHEM
Gosub B_ZOOM
End

Subprog IB_INVSITPV2M
Gosub B_ZOOM
End

Subprog IB_QTEFACTOTM
Gosub B_ZOOM
End

Subprog IB_INVSIT2M
Gosub B_ZOOM
End


######################################################################################
$B_ZOOM

Read [F:FRL]FRL0=[M:SIL0]FRMNUMLIG
If fstat : Raz [F:FRL] : Endif

If func SPVOBJPFM.SITINVQTY([F:FRL]TYPFRM)=1
  GBOUT5=mess(47,[V]GXMSGOPP,1)
  GBOUT6=mess(48,[V]GXMSGOPP,1)
  GBOUT7=mess(49,[V]GXMSGOPP,1)
Else
  GBOUT5=mess(42,[V]GXMSGOPP,1)
  GBOUT6=mess(43,[V]GXMSGOPP,1)
  GBOUT7=mess(44,[V]GXMSGOPP,1)
Endif
Return

######################################################################################
Subprog C_INVSIT2M(VALEUR)
Variable Decimal VALEUR
Call VERIF_QTYGEN(3,VALEUR,[M:SIL0]FRMNUMLIG) From SPVOBJSIL
If !mkstat & VALEUR>[M:SIL1]GROPRI & [M:SIL1]INVMOD=6
  [V]GMESSAGE=mess(357,[V]GXMSGPSA,1)-mess(6,1733,1)+"\"+mess(45,[V]GXMSGOPP,1)
  mkstat=1
Endif
End

######################################################################################
Subprog AV_XTXMNT(VALEUR)
Variable Char    VALEUR()

Read [F:FRL]FRL0=[M:SIL0]FRMNUMLIG
If fstat : Raz [F:FRL] : Endif

If func SPVOBJPFM.SITINVQTY([F:FRL]TYPFRM)=1
  VALEUR=mess(9,[V]GXMSGOPP,1)-[M:SIL1]CURFRL
Else
  VALEUR=mess(46,[V]GXMSGOPP,1)-[M:SIL1]CURFRL
Endif
End

