#<AdxTL>@(#)9.0.0.0 $Revision:   1.12  $ Gestion du masque SIL1
#ACV#X16
#TIT#Gestion des Situations (lignes)

GBIDC1=""
GBIDC2=""
Call OBJET("SIL",GBIDC1,GBIDC2) From GOBJET
End

#==========================================================================================
# Gestion de l'objet   : Gestion de l'objet Situations (lignes)
#                        
# Auteur               : 
# Date de création     :       
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 15/09/2003    OTHYR        Ajout de l'étiquette AVANTBOUT pour gestion des textes
# 17/01/2005    LBORN        Passage en version 140
#==========================================================================================

$ACTION

# Appel fonctions complémentaires GFI pour l'objet SIL
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
   When "OUVRE"         : Gosub OUVRE         From SPVOBJSIL
   When "LIENS"         : Gosub LIENS         From SPVOBJSIL
   When "MODIF"         : Gosub MODIF         From SPVOBJSIL
   When "INIMOD"        : Gosub INIMOD        From SPVOBJSIL
   When "APRES_MODIF"   : Gosub APRES_MODIF   From SPVOBJSIL
   When "APRES_MOD"     : Gosub APRES_MOD     From SPVOBJSIL
   When "ANNULE"        : Gosub ANNULE        From SPVOBJSIL
   When "SETBOUT"       : Gosub SETBOUT       From SPVOBJSIL
   When "EXEBOUT"       : Gosub EXEBOUT       From SPVOBJSIL
   When "STATUT"        : Gosub STATUT        From SPVOBJSIL
   When "FILTRE"        : Gosub FILTRE        From SPVOBJSIL
   When "FERME"         : Gosub FERME         From SPVOBJSIL
   When "ABANDON"       : Gosub ABANDON       From SPVOBJSIL
   When "OUVRE_BOITE"   : Gosub OUVRE_BOITE   From SPVOBJSIL
   When "FILGAUCHE"     : Gosub FILGAUCHE     From SPVOBJSIL
Endcase

Return

########################################
# Ecran SIL0
########################################

#---------------------------------------
Subprog AV_OPPNUM(VALEUR) # Utiliser pour les actions PSG
Variable Char    VALEUR()
Call ITYPOBJ1([OPP]OPPTYP) From SPVOBJPSG 
End

#---------------------------------------
Subprog AP_OPPNUM(VALEUR) # Utiliser pour les actions PSG
Variable Char    VALEUR()
Call ITYPOBJ2([OPP]OPPTYP) From SPVOBJPSG 
End


########################################
# Ecran SIL1
########################################

#---------------------------------------
Subprog AV_NETAMT(VALEUR)
Variable Decimal VALEUR
Local Integer STAT

Gosub INIT_ZREM From SPVOBJSIL

Call CAL_MNTHT(VALEUR,[M:SIL1]CURFRL,[M:SIL1]GROPRI, [L]ZREM, [M:SIL1]QTY) From SPVOBJFRL
Call CONVERT([M:SIL1]CURFRL,GLOCALDEV,GLOCALDEV,1,date$,VALEUR,VALEUR,STAT) From TRTDEV 
End

#---------------------------------------
Subprog C_INVSIT2(VALEUR)
Variable Decimal VALEUR
Call VERIF_QTYGEN(3,VALEUR,[M:SIL0]FRMNUMLIG) From SPVOBJSIL
If !mkstat & VALEUR>[M:SIL1]QTY & [M:SIL1]INVMOD=6
  [V]GMESSAGE=mess(357,[V]GXMSGPSA,1)-mess(6,1733,1)+"\"+mess(358,[V]GXMSGPSA,1)
  mkstat=1
Endif
End


########################################
# Ecran SIL2
########################################

#---------------------------------------
Subprog AS_NBLIG
Local Integer ZLIG, ZI

# On ne déclenche pas l'action en controle de validation d'une situation
If dim([V]XCTRLVALSIT)>0
  If [V]XCTRLVALSIT=1 : End : Endif
Endif

[L]ZLIG=nolign-1

If [M:SIL2]ITMREFPUR([L]ZLIG)<>""
  Effzo [M:SIL2] 15-99
  Gosub AFFECT_SL2 From SPVOBJSIL
  Affzo [M:SIL2]15-99
Endif

nolign=[L]ZLIG+1
Affzo [M:SIL2]ITMREFPUR,BPSNUM
End

#---------------------------------------
Subprog IB_NBLIG
Gosub BOUT_ZOOM
End

$BOUT_ZOOM
If nolign<=0 : Return : Endif
[V]GBOUT5=mess(395,[V]GXMSGPSA,1)
If [M:SIL2]QTYLIVPREV(nolign-1) =0 : Raz [V]GBOUT6  : Else [V]GBOUT6=mess(396,[V]GXMSGPSA,1) : Endif
If [M:SIL2]QTYLIVDEP(nolign-1)  =0 : Raz [V]GBOUT7  : Else [V]GBOUT7=mess(397,[V]GXMSGPSA,1) : Endif
If [M:SIL2]QTYRECPREV(nolign-1) =0 : Raz [V]GBOUT9  : Endif
If [M:SIL2]QTYRECDEP(nolign-1)  =0 : Raz [V]GBOUT10 : Endif
Return

#---------------------------------------
Subprog AV_ITMREFPUR(VALEUR)
Variable Char     VALEUR
Local Integer ZI
For [L]ZI=1 To [M:SIL2]NBLIG+1
  If [L]ZI<>[M:SIL2]XNUMLIG
    Chgstl [M:SIL2]NBLIG([L]ZI-1) With ""
  Else
    Chgstl [M:SIL2]NBLIG([L]ZI-1) With "AMKCUR"
  Endif
Next
End

#---------------------------------------
Subprog IB_XQTYPUR
Local Integer SVGLIG : [L]SVGLIG=nolign : nolign=[M:SIL2]XNUMLIG
Gosub BOUT_ZOOM
nolign=[L]SVGLIG
End


#---------------------------------------
Subprog C_XQTYPUR(VALEUR)
Variable Decimal VALEUR
Call VERIF_QTYGEN(1,VALEUR,[M:SIL0]FRMNUMLIG) From SPVOBJSIL
End

#---------------------------------------
Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()

Local Shortint XSTAT
Local Char TYPDOC(3)

# Fournisseur obligatoire ?
If VALEUR=""
    Read [F:OPP]OPP0=[M:SIL0]OPPNUM
    If !fstat
      Read [F:PPT]PPT0=[F:OPP]OPPTYP
      If !fstat
        Raz [L]XSTAT
        If [F:PPT]TYPBRDBUY=2
          If !clalev([F:PFM]) : Local File PARFRMTYP  : Endif
          If !clalev([F:X1B]) : Local File XPARFRMSTA : Endif
          If !clalev([F:FRL]) : Local File FORMSL : Endif
          Read [F:FRL]FRL0=[M:SIL0]FRMNUMLIG
          If !fstat
            Read [F:X1B]X1B0=[F:FRL]TYPFRM;[F:FRL]STAFRM
            If fstat : Raz [F:X1B] : Endif
            Read [F:PFM]PFM0=[F:FRL]TYPFRM
            If !fstat & [F:X1B]VALBUYOPP<>""
              Call LEC_TYPDOC([F:X1B]VALBUYOPP,[L]TYPDOC,[L]XSTAT) From SPVOBJPV1
            Endif
          Endif
        Elsif [F:PPT]CODVALBUY<>""
          Call LEC_TYPDOC([F:PPT]CODVALBUY,[L]TYPDOC,[L]XSTAT) From SPVOBJPV1
        Endif
        If [L]XSTAT | [L]TYPDOC="CA1"
          [V]GMESSAGE=mess(10,123,1)
          mkstat=1
        Endif
      Endif
    Endif
Endif
End

#---------------------------------------
Subprog C_XEXTRCPDAT(VALEUR)
Variable Date    VALEUR

If VALEUR=[0/0/0]
  If [M:SIL2]QTYPUR([M:SIL2]XNUMLIG-1)<>0
    [V]GMESSAGE=mess(10,123,1)
    mkstat=1
  Endif
Else
  Local Date ZDEB
    Read [F:FRL]FRL0=[M:SIL0]FRMNUMLIG
    If !fstat
      [L]ZDEB=[F:FRL]CREDATFRM
    Endif
  Call CONT_EXTRCPDAT([M:SIL2]STOFCY([M:SIL2]XNUMLIG-1),VALEUR,[L]ZDEB) From SPVOBJFRL
Endif

End

#---------------------------------------
Subprog AM_XQTYPUR(VALEUR)
Variable Decimal VALEUR
[M:SIL2]QTYPUR([M:SIL2]XNUMLIG-1)=VALEUR
End


#---------------------------------------
Subprog AM_XMNTPUR(VALEUR)
Variable Decimal VALEUR
[M:SIL2]MNTPUR([M:SIL2]XNUMLIG-1)=VALEUR
End

#---------------------------------------
Subprog IB_XMNTPUR
Local Integer SVGLIG : [L]SVGLIG=nolign : nolign=[M:SIL2]XNUMLIG
Gosub BOUT_ZOOM
nolign=[L]SVGLIG
End


#---------------------------------------
Subprog AM_XEXTRCPDAT(VALEUR)
Variable Date    VALEUR
[M:SIL2]EXTRCPDAT([M:SIL2]XNUMLIG-1)=VALEUR
End

#---------------------------------------
Subprog AM_XBPSREF(VALEUR)
Variable Char    VALEUR()
[M:SIL2]BPSREF([M:SIL2]XNUMLIG-1)=VALEUR
End



########################################
# Ecran SIL3
########################################

#---------------------------------------
Subprog IB_NBLIGDS
Raz [V]GBOUT1
[V]GBIDI1=1
If [M:SIL3]REQTYP(nolign-1)<>""
  [V]GBOUT1="Info DS"
  If !find([V]GREP,"C","D")
    If !instr(1,[V]GCHAINE,"M")
      [V]GBIDI1=0
    Else
      Local Char ZSYMBOLE(155)
      [L]ZSYMBOLE="SL1"+[M:SIL0]LINSITNUM
      Lock =[L]ZSYMBOLE With lockwait=0
      If fstat
        [V]GBIDI1=0
      Endif
    Endif
  Endif
Endif

If [M:SIL3]CPLPREV1(nolign-1)=0 : Raz [V]GBOUT6  : Endif
If [M:SIL3]CPLPREV2(nolign-1)=0 : Raz [V]GBOUT7  : Endif

End


#---------------------------------------
Subprog IB_XCORPREV2
If [M:SIL3]CPLPREV1([M:SIL3]XNUMLIG-1)=0 : Raz [V]GBOUT6  : Endif
If [M:SIL3]CPLPREV2([M:SIL3]XNUMLIG-1)=0 : Raz [V]GBOUT7  : Endif
End

#---------------------------------------
Subprog IB_XRMNQTY
If [M:SIL3]CPLPREV1([M:SIL3]XNUMLIG-1)=0 : Raz [V]GBOUT6  : Endif
If [M:SIL3]CPLPREV2([M:SIL3]XNUMLIG-1)=0 : Raz [V]GBOUT7  : Endif
End


#---------------------------------------
Subprog AS_NBLIGDS

# On ne déclenche pas l'action en controle de validation d'une situation
If dim([V]XCTRLVALSIT)>0
  If [V]XCTRLVALSIT=1 : End : Endif
Endif

Local Integer ZLIG, ZI

[L]ZLIG=nolign-1

# Pas d'affectation en création, sinon pas d'init
If [M:SIL3]CODOPE([L]ZLIG)<>""
  Effzo [M:SIL3] 15-99
  Gosub AFFECT_SL3 From SPVOBJSIL
  Affzo [M:SIL3]15-99
Endif

nolign=[L]ZLIG+1
Affzo [M:SIL3]CODOPE,WSTREQ,REQTYP

End

#---------------------------------------
Subprog AV_WSTREQ(VALEUR)
Variable Char     VALEUR
Local Integer ZI
For [L]ZI=1 To [M:SIL3]NBLIGDS+1
  If [L]ZI<>[M:SIL3]XNUMLIG
    Chgstl [M:SIL3]NBLIGDS([L]ZI-1) With ""
  Else
    Chgstl [M:SIL3]NBLIGDS([L]ZI-1) With "AMKCUR"
  Endif
Next
End

#---------------------------------------
Subprog C_XENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M:SIL3]BEGDAT([M:SIL3]XNUMLIG-1)
  mkstat=1
Endif
End

#---------------------------------------
Subprog C_XRMNQTY(VALEUR)
Variable Decimal VALEUR
Call VERIF_QTYGEN(2,VALEUR,[M:SIL0]FRMNUMLIG) From SPVOBJSIL
End


#---------------------------------------
Subprog AM_XRSSIUS(VALEUR)
Variable Char    VALEUR()
[M:SIL3]RSSIUS([M]XNUMLIG-1)=VALEUR
End

#---------------------------------------
Subprog AM_XBEGDAT(VALEUR)
Variable Date    VALEUR
[M:SIL3]BEGDAT([M]XNUMLIG-1)=VALEUR
End

#---------------------------------------
Subprog AM_XENDDAT(VALEUR)
Variable Date    VALEUR
[M:SIL3]ENDDAT([M]XNUMLIG-1)=VALEUR
End

#---------------------------------------
Subprog AM_XCORPREV2(VALEUR)
Variable Decimal VALEUR
[M:SIL3]CORPREV2([M]XNUMLIG-1)=VALEUR
Effzo [M:SIL3]XCORPREV2M
Raz [M:SIL3]CORPREV2M([M]XNUMLIG-1)
End

#---------------------------------------
Subprog AM_XRMNQTY(VALEUR)
Variable Decimal VALEUR
[M:SIL3]RMNQTY([M]XNUMLIG-1)=VALEUR
End

#---------------------------------------
Subprog AM_XRMNMNT(VALEUR)
Variable Decimal VALEUR
[M:SIL3]RMNMNT([M]XNUMLIG-1)=VALEUR
End

#---------------------------------------
Subprog IB_XRMNMNT
If [M:SIL3]CPLPREV1([M:SIL3]XNUMLIG-1)=0 : Raz [V]GBOUT6  : Endif
If [M:SIL3]CPLPREV2([M:SIL3]XNUMLIG-1)=0 : Raz [V]GBOUT7  : Endif
End

#---------------------------------------
Subprog AS_XCORPREV2M(VALEUR)
Variable Decimal VALEUR
If [M:SIL3]XCORPREV2=0
  mkstat=1
Elsif VALEUR=0 & [M:SIL3]XEXTQTY
  VALEUR=arr(abs([M:SIL3]XEXTMNT/[M:SIL3]XEXTQTY)*[M:SIL3]XCORPREV2,[V]GARODEV)
Endif
End

#---------------------------------------
Subprog AM_XCORPREV2M(VALEUR)
Variable Decimal VALEUR
[M:SIL3]CORPREV2M([M]XNUMLIG-1)=VALEUR
End

#---------------------------------------
Subprog IB_XCORPREV2M
If [M:SIL3]CPLPREV1([M:SIL3]XNUMLIG-1)=0 : Raz [V]GBOUT6  : Endif
If [M:SIL3]CPLPREV2([M:SIL3]XNUMLIG-1)=0 : Raz [V]GBOUT7  : Endif
End





########################################
# SIL4
########################################
#---------------------------------------
Subprog AS_CPLFLG(VALEUR)
Variable Integer VALEUR

If [M:SIL1]INVMOD<>4
  mkstat=2
Endif

End

#---------------------------------------
Subprog AM_CPLFLG(VALEUR)
Variable Integer VALEUR

If [M:SIL1]INVMOD=4 & VALEUR<>2
  Local File FORMSLD [FLD]
  Read [F:FLD]FLD0=[M:SIL4]FRMNUMLIG(nolign-1);[M:SIL4]NUMLIGSIT(nolign-1)
  If !fstat & [F:FLD]CPLDAT<>[0/0/0]
    [V]GMESSAGE=mess(21,[V]GXMSGPSA(1),1)
    [V]GERR=3
  Endif
Endif

End

#---------------------------------------
Subprog AS_EXTDAT(VALEUR)
Variable Date    VALEUR
If [M:SIL1]INVMOD=5
  Local File FORMSLF [FLF]
  Read [F:FLF]FLF0=[M:SIL4]FRMNUMLIG(nolign-1);[M:SIL4]NUMLIGSIT(nolign-1)
  If !fstat & [F:FLF]CPLFIXDAT<>[0/0/0]
    mkstat=2
  Endif
Else
  mkstat=2
Endif
End

#---------------------------------------
Subprog IB_NBLIGB
If nolign>[M:SIL4]NBLIGB
  [V]GBOUT9=""
Endif
End

#---------------------------------------
Subprog AS_NBLIGOF
Local Integer ZLIG, ZI

# On ne déclenche pas l'action en controle de validation d'une situation
If dim([V]XCTRLVALSIT)>0
  If [V]XCTRLVALSIT=1 : End : Endif
Endif

[L]ZLIG=nolign-1

If [M:SIL5]ITMREFOF([L]ZLIG)<>""
  Effzo [M:SIL5]15-99
  Gosub AFFECT_SL5 From SPVOBJSIL
  Affzo [M:SIL5]15-99
Endif

nolign=[L]ZLIG+1
Affzo [M:SIL5]ITMREFOF

End

#---------------------------------------
Subprog AV_ITMREFOF(VALEUR)
Variable Char    VALEUR()
Local Integer ZI
For [L]ZI=1 To [M:SIL5]NBLIGOF+1
  If [L]ZI<>[M:SIL5]XNUMLIG
    Chgstl [M:SIL5]NBLIGOF([L]ZI-1) With ""
  Else
    Chgstl [M:SIL5]NBLIGOF([L]ZI-1) With "AMKCUR"
  Endif
Next
End

#---------------------------------------
Subprog C_XQTYMFG(VALEUR)
Variable Decimal VALEUR
Call VERIF_QTYGEN(4,VALEUR,[M:SIL0]FRMNUMLIG) From SPVOBJSIL
End

#---------------------------------------
Subprog AM_XQTYMFG(VALEUR)
Variable Decimal VALEUR
[M:SIL5]QTYMFG([M:SIL5]XNUMLIG-1)=VALEUR
End

#---------------------------------------
Subprog IB_NBLIGOF
Gosub BOUT_ZOOMOF
End

#---------------------------------------
$BOUT_ZOOMOF

If nolign<=0 : Return : Endif

[V]GBOUT5=mess(395,[V]GXMSGPSA,1)
[V]GBOUT6=mess(396,[V]GXMSGPSA,1)
[V]GBOUT7=mess(397,[V]GXMSGPSA,1)
[V]GBOUT8=mess(29,[V]GXMSGPSA(1),1)
[V]GBOUT9=mess(30,[V]GXMSGPSA(1),1)
[V]GBOUT10=mess(31,[V]GXMSGPSA(1),1)
[V]GBOUT11=mess(32,[V]GXMSGPSA(1),1)
[V]GBOUT12=mess(33,[V]GXMSGPSA(1),1)

If [M:SIL5]QTYLIVPREV(nolign-1) =0 : Raz [V]GBOUT6  : Endif
If [M:SIL5]QTYLIVDEP(nolign-1)  =0 : Raz [V]GBOUT7  : Endif
If [M:SIL5]QTYREAPREV(nolign-1) =0 : Raz [V]GBOUT9  : Endif
If [M:SIL5]QTYREADEP(nolign-1)  =0 : Raz [V]GBOUT10 : Endif
Return

#---------------------------------------
Subprog IB_XQTYMFG
Local Integer SVGLIG : [L]SVGLIG=nolign : nolign=[M:SIL5]XNUMLIG
Gosub BOUT_ZOOMOF
nolign=[L]SVGLIG
End

#---------------------------------------
Subprog IB_XMNTMFG
Local Integer SVGLIG : [L]SVGLIG=nolign : nolign=[M:SIL5]XNUMLIG
Gosub BOUT_ZOOM
nolign=[L]SVGLIG
End

#---------------------------------------
Subprog AM_XMNTMFG(VALEUR)
Variable Decimal VALEUR
[M:SIL5]MNTMFG([M:SIL5]XNUMLIG-1)=VALEUR
End

#---------------------------------------
Subprog AM_XDATFOF(VALEUR)
Variable Date    VALEUR
[M:SIL5]DATFOF([M:SIL5]XNUMLIG-1)=VALEUR
End

#---------------------------------------
Subprog C_XDATFOF(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
  If [M:SIL5]QTYMFG([M:SIL5]XNUMLIG-1)<>0
    [V]GMESSAGE=mess(10,123,1)
    mkstat=1
  Endif
Else
  Local Date ZDEB
    Read [F:FRL]FRL0=[M:SIL0]FRMNUMLIG
    If !fstat
      [L]ZDEB=[F:FRL]CREDATFRM
    Endif
  [L]ZDEB=max([L]ZDEB,datesyst)
  If VALEUR<[L]ZDEB
    [V]GMESSAGE = mess(305,[V]GXMSGPSA,1)-format$("D:DD[/]MM[/]YYYY",[L]ZDEB)
    mkstat=1
  Endif
Endif
End

