#<AdxTL>@(#)1.0.0.0 $Revision:   1.18  $ Gestion du masque GDM1
#ACV#X11
#TIT#Gestion element de dimensionnement GAS

$ACTION
Case ACTION
 When Default
Endcase
Return

########################################
Subprog C_COD(VALEUR)
Variable Char    VALEUR()

Call UNICITE(VALEUR,[M:GDM1]COD)From OBJDIV
End

########################################
Subprog AV_ZDES(VALEUR)
Variable Char    VALEUR()

If [M:GDM1]DES(nolign-1)<>0
    Call TEXTE([M:GDM1]DES(nolign-1),VALEUR)From OBJDIV
Endif
End

########################################
Subprog AM_COD(VALEUR)
Variable Char    VALEUR()

If !clalev([F:ADE]) : Local File ADOSDIM : Endif
If !clalev([F:ADM]) : Local File ADIMENSION : Endif
Read [ADE]ADE0=nomap;VALEUR
If !fstat
    Read [ADM]ADM0=VALEUR
    [M:GDM1]DES(nolign-1)=[F:ADM]DES
    [M:GDM1]COEFF(nolign-1)=[F:ADE]NBR
    If ![V]GIMPORT
        Affzo [M:GDM1]COEFF(nolign-1)
    Endif
Endif
End

########################################
Subprog AS_COEFF(VALEUR)
Variable Decimal VALEUR

If !clalev([F:ADE]) : Local File ADOSDIM : Endif
Read [ADE]ADE0=nomap;[M:GDM1]COD(nolign-1)
If !fstat
    mkstat=2
Endif
End

########################################
Subprog AS_ZDES(VALEUR)
Variable Char    VALEUR()

If !clalev([F:ADE]) : Local File ADOSDIM : Endif
Read [ADE]ADE0=nomap;[M:GDM1]COD(nolign-1)
If !fstat
    mkstat=2
Endif
End

