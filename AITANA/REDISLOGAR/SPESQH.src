## Modificar fechas al hacer picking JC 02/01/2020
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################

Return

##############################################################
$FIN

# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
## Modificar fechas al hacer picking JC 02/01/2020
## utilizo esta variable para que actualice las fechas si se genera el pedido desde presupuesto
#  Raz YGVIENEDEPPTO
## Modificar fechas al hacer picking JC 02/01/2020
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################

Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
######################################################################################
## YA030 - Control de autorizado alcanzado
######################################################################################
$CTL_ENCURSALCAN

Local Integer WCDTSTA
Local Decimal WOST, WOSTAUZ
Local Integer WOK

Call SDCDTSTA('', [M:SQH0]BPCORD, [M:SQH0]CHGTYP, 0, [M:SQH1]CUR, [M:SQH0]QUODAT, 0, 1, WCDTSTA, WOST, WOSTAUZ) From TRTVENCDT

#Infbox("QUOINVATI + WOST = " + num$([M:SQH2]QUOINVATI) + " + " + num$(WOST) + " = " + num$([M:SQH2]QUOINVATI + WOST))
#Infbox("WOSTAUZ: " + num$(WOSTAUZ))

If ([M:SQH2]QUOINVATI + WOST > WOSTAUZ)

   OK = 2
   GERR = 3
   GMESSAGE = sum(mess(29,192,1), " " ,num$(WOSTAUZ), " " , [M]CUR)

Endif

Return

##############################################################
$P1_NBLIG
Local Integer WOK
  For WOK = 0 To [M:SQH2]NBLIG-1
  Case [M:SQH2]YTIPPRI(WOK)
      When 1 : [M:SQH2]YGROPRI(WOK) = [M:SQH2]GROPRI(WOK)
      When 2 : [M:SQH2]YGROPRI(WOK) = [M:SQH2]GROPRI(WOK) * 10
      When 3 : [M:SQH2]YGROPRI(WOK) = [M:SQH2]GROPRI(WOK) * 100
      When 4 : [M:SQH2]YGROPRI(WOK) = [M:SQH2]GROPRI(WOK) * 1000
    Endcase
    Affzo [M:SQH2]YGROPRI(WOK)
Next
Return

##############################################################
$CHARGE_HEAD_TXT
Gosub ACTION From SUBSQH

If [M:SQH0]YSQHTEX<>""
   If left$([M:SQH0]YSQHTEX,3)="SQH"
      #si no existe creamos el clob
      Call CRE_CLOB([M:SQH0]YSQHTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:SQH]YSQHTEX = [M:SQH0]YSQHTEX
Else
   #borra la cabecera traspasable vacia
   If left$(TABLETEX,3)="SQH"
      Call SUP_CLOB(TABLETEX,WRET) From TRTX3TEX
   Endif
Endif

GPE=1
Return
######################### FIN YA032 #################################

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################
######################################################################################
## YA037 - Traer el código de articulo para el cliente
######################################################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()

If clalev ([F:ZITU])  = 0 : Local File ITMBPC  [ZITU] : Endif

Read [F:ZITU]ITU0 = VALEUR;[M:SQH0]BPCORD
If fstat = 0

  [M:SQH2]YITMCLI(nolign -1)   = [F:ZITU]ITMDESBPC # MS.14042020 - R8
  [M:SQH2]YITMDESCLI(nolign-1) = [F:ZITU]ITMDESBPC # MAB.08042020.NEW

  Affzo [M:SQH2]YITMCLI(nolign -1)
  Affzo [M:SQH2]YITMDESCLI(nolign-1) # MAB.08042020.NEW

Endif
End

##############################################################
######################################################################################
## YA030 - Control de cliente bloqueado
######################################################################################
Subprog C_BPCORD(VALEUR)
Variable Char    VALEUR()
If (find(GREP, "C", "D") | [M]BPCORD <> VALEUR)
    Local Integer WOSTCTL
    If [F:BPC]BPCRSK<>VALEUR
      Local File BPCUSTOMER [BPC1]
      If [F:BPC1]BPCNUM <> [F:BPC]BPCRSK
        Read [F:BPC1]BPC0 = [F:BPC]BPCRSK
        If fstat Raz [F:BPC1] : Endif
      Endif
      WOSTCTL=[F:BPC1]OSTCTL
    Else
      WOSTCTL=[F:BPC]OSTCTL
    Endif
    If WOSTCTL = 3
      Local Integer WOK : WOK=2  # WOK=1 pour ne pas bloquer en import
      Call AVERTIR (mess(151,199,1), WOK) From GESECRAN
      #If WOK=1 mkstat=2 : End : Endif
      mkstat=2
    Endif
Endif
End

##############################################################
######################################################################################
## YA030 - Control de autorizado alcanzado
######################################################################################
Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()

Local Integer WCDTSTA
Local Decimal WOST, WOSTAUZ
Local Integer WOK

Call SDCDTSTA('', VALEUR, [M:SQH0]CHGTYP, 0, [M:SQH1]CUR, [M:SQH0]QUODAT, 0, 1, WCDTSTA, WOST, WOSTAUZ) From TRTVENCDT
 Case WCDTSTA
    When 3
      # Excediendo
      WOK = 2     # FGR 21/03/2014 : X3SUIVI98224 pas WOK=1 pour ne pas bloquer en import
      Call AVERTIR(mess(29,192,1), WOK) From GESECRAN
      If WOK=1 mkstat=2 : End : Endif
    When Default
 Endcase
 For WOK = 0 To [M:SQH2]NBLIG-1
  Case [M:SQH2]YTIPPRI(WOK)
      When 1 : [M:SQH2]YGROPRI(WOK) = [M:SQH2]GROPRI(WOK)
      When 2 : [M:SQH2]YGROPRI(WOK) = [M:SQH2]GROPRI(WOK) * 10
      When 3 : [M:SQH2]YGROPRI(WOK) = [M:SQH2]GROPRI(WOK) * 100
      When 4 : [M:SQH2]YGROPRI(WOK) = [M:SQH2]GROPRI(WOK) * 1000
    Endcase
    Affzo [M:SQH2]YGROPRI(WOK)
Next
End

##############################################################
######################################################################################
## YA039 - Campos específicos
######################################################################################
Subprog AM_ITMREF(VALEUR)
  Variable Char    VALEUR()
  If [M:SQH1]DEMDLVDAT <> [0/0/0]
    [M:SQH2]DDEMDLVDAT(nolign-1) = [M:SQH1]DEMDLVDAT
  Endif

  # YA034 - Tipo precio en Ventas
  If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
  Read [F:ZITM]ITM0 = VALEUR
  If fstat = 0
    [M:SQH2]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
    Affzo [M:SQH2]YTIPPRI(nolign -1)
  Endif

   Case [M:SQH2]YTIPPRI(nolign -1)
    When 1 : [M:SQH2]YGROPRI(nolign -1) = [M:SQH2]GROPRI(nolign -1)
    When 2 : [M:SQH2]YGROPRI(nolign -1) = [M:SQH2]GROPRI(nolign -1) * 10
    When 3 : [M:SQH2]YGROPRI(nolign -1) = [M:SQH2]GROPRI(nolign -1) * 100
    When 4 : [M:SQH2]YGROPRI(nolign -1) = [M:SQH2]GROPRI(nolign -1) * 1000
  Endcase
  Affzo [M:SQH2]YGROPRI(nolign -1)
  ## FIN YA034

End

##############################################################
######################################################################################
## YA034 - Tipo precio en Ventas
######################################################################################
Subprog AM_YGROPRI(VALEUR)
Variable Decimal VALEUR
Variable Decimal PRECIO

Local Decimal LVALEUR

  Case [M:SQH2]YTIPPRI(nolign -1)
    When 1 : PRECIO  = VALEUR
    When 2 : PRECIO  = VALEUR / 10
    When 3 : PRECIO  = VALEUR / 100
    When 4 : PRECIO  = VALEUR / 1000
  Endcase

  # Actualizamos el campo standard
  [M:SQH2]GROPRI(nolign -1) = PRECIO
  Affzo [M:SQH2]GROPRI(nolign -1)
  LVALEUR=VALEUR
  VALEUR=PRECIO
  # Llamamos a las funciones del campo GROPRI, como si se hubiese modificdo en pantalla
  # Como no hay funciones, tengo que replicar el código

  #La acción es DIVDISCRG, pero llama al punto D_DISCRG
  Local Char    WABMSK    :    WABMSK="SQH2"
  Local Integer DISCRGNUM :    DISCRGNUM = 0
  Local Integer NOLIG     :    NOLIG=nolign-1

  If DISCRGNUM > 0 & DISCRGNUM < 10
     Assign "[M:"+WABMSK+"]DISCRGREN"+num$(DISCRGNUM)+"(NOLIG)" With GDACMANSAL
  Elsif DISCRGNUM = 0
     Assign "[M:"+WABMSK+"]PRIREN(NOLIG)" With GDACMANSAL
  Endif

#  #Para suplir la acción DIVPRIPFM, llamamos a los siguientes subprogramas
#  Call CLCNETPRI([M]QTY(nolign-1), [M:SQH0]CUR, nolign-1) From TRTVENPRI
#  Call CLCPFM([M]DSTOFCY(nolign-1), [M]PRITYP, [M]CHGTYP, [M]QUODAT, [M]CUR, nolign-1,1) From TRTVENPRI
#  Call APRES_LIGNE (nolign-1,1) From SUBSQHB

Local Char PARAM(250)(250)
Local Char TRAIT
TRAIT="DIVPRIPFM"
PARAM(1)="0"
PARAM(2)=num$([M]QTY(nolign-1))
PARAM(3)=[M:SQH0]BPCORD
PARAM(4)=num$([M:SQH0]CHGTYP)
PARAM(5)=[M:SQH0]QUODAT
PARAM(6)=[M:SQH1]CUR
PARAM(7)=num$(nolign-1)
PARAM(8)=[M:SQH2]DSTOFCY(nolign-1)
PARAM(9)=num$([M:SQH1]PRITYP)
PARAM(10)="GROPRI"
Gosub DIVPRIPFM From TRTVENPRI
VALEUR=LVALEUR
 # Actualizamos el campo standard
  [M:SQH2]GROPRI(nolign -1) = PRECIO
  Affzo [M:SQH2]GROPRI(nolign -1)

End

##############################################################
######################################################################################
## YA034 - Tipo precio en Ventas
######################################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR

 Case [M:SQH2]YTIPPRI(nolign -1)
  When 1 : [M:SQH2]YGROPRI(nolign -1) = [M:SQH2]GROPRI(nolign -1)
  When 2 : [M:SQH2]YGROPRI(nolign -1) = [M:SQH2]GROPRI(nolign -1) * 10
  When 3 : [M:SQH2]YGROPRI(nolign -1) = [M:SQH2]GROPRI(nolign -1) * 100
  When 4 : [M:SQH2]YGROPRI(nolign -1) = [M:SQH2]GROPRI(nolign -1) * 1000
Endcase
Affzo [M:SQH2]YGROPRI(nolign -1)

End

##############################################################
######################################################################################
## Etiqueta añadida por el supervisor (pantalla SQH0) 03/06/2019 13:50:31 (LIVDV)
######################################################################################
Subprog AP_QUODAT(VALEUR)
Variable Date    VALEUR
Local Integer WOK
  For WOK = 0 To [M:SQH2]NBLIG-1
    Case [M:SQH2]YTIPPRI(WOK)
        When 1 : [M:SQH2]YGROPRI(WOK) = [M:SQH2]GROPRI(WOK)
        When 2 : [M:SQH2]YGROPRI(WOK) = [M:SQH2]GROPRI(WOK) * 10
        When 3 : [M:SQH2]YGROPRI(WOK) = [M:SQH2]GROPRI(WOK) * 100
        When 4 : [M:SQH2]YGROPRI(WOK) = [M:SQH2]GROPRI(WOK) * 1000
      Endcase
      Affzo [M:SQH2]YGROPRI(WOK)
  Next
End

