######################################################################################
$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "VERIF_CRE"      : Gosub VERIF_CRE
  When "VERIF_MOD"      : Gosub VERIF_MOD
  When "SETBOUT"        : Gosub SETBOUT
  When "RAZDUP"         : Gosub RAZDUP
  When "RAZCRE"         : Gosub RAZCRE
  When "ANNULE"         : Gosub ANNULE
  When "ABANDON"        : Gosub ABANDON
  When "INIMOD"         : Gosub INIMOD
  When "INICRE"         : Gosub INICRE
  When "STATUT"         : Gosub STATUT
  When "TRT_DIV"        : Gosub TRT_DIV
  When "AVANTBOUT"      : Gosub AVANTBOUT
  When "FIN"            : Gosub FIN
  When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$TRT_DIV
Case TRAIT
    When "P1NBLIG"    :    Gosub P1_NBLIG
Endcase
Return

##############################################################
######################################################################################
## YA030 - Control de autorizado alcanzado
######################################################################################
$VERIF_CRE
# Le indicamos que valla primero al SUB
Gosub ACTION From SUBSQH

#Infbox("Creando")
Gosub CTL_ENCURSALCAN

# Que no vuelva a ejecutar el la parte del SUB
GPE=1
Return

##############################################################
######################################################################################
## YA030 - Control de autorizado alcanzado
######################################################################################
$VERIF_MOD
# Le indicamos que valla primero al SUB
Gosub ACTION From SUBSQH

#Infbox("Modificando")
Gosub CTL_ENCURSALCAN

# Que no vuelva a ejecutar el la parte del SUB
GPE=1
Return

##############################################################
################YA032 -  Textos de cabecera traspasables #################
#Activamos el boton de menu creado
$SETBOUT
# Le indicamos que valla primero al SUB
Gosub ACTION From SUBSQH
Global Char TABLETEX
#boton cabecera traspasable
CHMEN += "B"
Gosub SET_BOUT_SPE From GSAISIE

# Que no vuelva a ejecutar el la parte del SUB
GPE=1
Return

##############################################################
$STATUT
TABLETEX = [F:SQH]YSQHTEX
Gosub ACTION From SUBSQH
Case BOUT
    When "B"  :   If mkstat=4 & GREP=""
#                      GREP="M" : REP="M"
#                      Gosub SETBOUT From GOBJSUB
                       Gosub ENTRE_MODIF From GOBJSUB
                   Endif
                   If [M]YSQHTEX <> "" & !GIMPORT
                       Call SET_IMAGE (4) From GESECRAN
                   Elsif !GIMPORT
                       Call RESET_IMAGE (4) From GESECRAN
                   Endif

Endcase
GPE=1
Return

##############################################################
$RAZCRE
Gosub ACTION From SUBSQH

Raz [M:SQH0]YSQHTEX

GPE=1
Return

##############################################################
$RAZDUP
Gosub ACTION From SUBSQH
If left$([M:SQH0]YSQHTEX,3)="SQH"
  Call DUP_CLOB("SQH",[M:SQH0]YSQHTEX,WRET) From TRTX3TEX
  If WRET<1 Raz [M:SQH0]YSQHTEX Endif
Endif

GPE=1
Return

##############################################################
$ANNULE
Gosub ACTION From SUBSQH

If left$([F:SQH]YSQHTEX,3)="SQH"
   Call SUP_CLOB([F:SQH]YSQHTEX,WRET) From TRTX3TEX
Endif
GPE=1
Return

##############################################################
$ABANDON
Gosub ACTION From SUBSQH
#Si ya hay algo guardado en la cabecera traspasable al darle a salir no lo borrara.
If GREP = "D"
  If left$([M:SQH0]YSQHTEX,3)="SQH"
        Call SUP_CLOB([M:SQH0]YSQHTEX,WRET) From TRTX3TEX
  Endif
Endif
GPE=1
Return

##############################################################
$INICRE
Gosub CHARGE_HEAD_TXT
Return

##############################################################
$INIMOD
Gosub CHARGE_HEAD_TXT
Return

##############################################################
$AVANTBOUT

# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
## Modificar fechas al hacer picking JC 02/01/2020
## utilizo esta variable para que actualice las fechas si se genera el pedido desde presupuesto
