##################################################################
Subprog AS_PRNFLG(VALEUR)
Variable Integer VALEUR

If [M:XPI3]STACOD = "" Then
    mkstat = 1
Endif

End

##################################################################
Subprog C_CODOPE2(VALEUR)
Variable Char     VALEUR

If VALEUR = [M:XPI5]CODOPE1(nolign-1) Then
    GMESSAGE = mess(54,[V]GXMSGPSA,1)
    mkstat = 2
Endif

End

##################################################################
Subprog D_NUMLIG(VALEUR)
Variable Decimal  VALEUR
VALEUR = nolign
End

##################################################################
Subprog C_CODOPE1(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR, [M:XPI5]CODOPE1) From OBJDIV
End

##################################################################
Subprog AS_FLGINIOPE(VALEUR)
Variable Integer  VALEUR
# Si aucun enchainement n'est paramétré, alors impossible de cocher 'Init 1ere ligne'
If [M:XPI5]NBLIGDECL = 0 Then
    mkstat = 2
Endif
End

##################################################################
Subprog C_NBLIGDECL
If [M:XPI5]NBLIGDECL = 0 & [M:XPI5]FLGINIOPE = 2 Then
    [M:XPI5]FLGINIOPE = 1
    If !GIMPORT Then
        Affzo [M:XPI5]FLGINIOPE
    Endif
Endif
End



##################################################################
#             Paramétrage sur Stade d'Intervention               #
##################################################################
##################################################################
Subprog LEC_STADE(TYPINT, STADE, STAT)
Value    Char    TYPINT()
Variable Char    STADE()()
Variable Integer STAT

If !clalev([F:X7Y]) : Local File PARINTTYP [X7Y] : Endif

Call LECTURE("X7Y", TYPINT, "") From CONTOBJ
If [F:X7Y]CTRLSTAB = 2 Then
    For X = 0 To [F:X7Y]NBLIGBEF-1
        STADE(X) = [F:X7Y]STABEF(X)
    Next
    STAT = 1
Else
    STAT = 0
Endif

End


##################################################################
# Paramétrage sur Questionnaire
##################################################################
Subprog LEC_CODQUEST(TYPREQ, CODQUEST, STAT)
Value    Char    TYPREQ()
Variable Char    CODQUEST()()
Variable Integer STAT

Local File PARINTTYP [X7Y]

Call LECTURE("X7Y", TYPREQ, "") From CONTOBJ

If [F:X7Y]CTRLQUEST = 2 Then
    For X = 0 To [F:X7Y]NBLIGQUES-1
        CODQUEST(X) = [F:X7Y]CODQUEST(X)
    Next
    STAT = 1
Else
    STAT = 0
Endif

End


