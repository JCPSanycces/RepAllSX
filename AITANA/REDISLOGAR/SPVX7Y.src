##################################################################
Subprog C_DEFINTAFT(VALEUR)
Variable Char VALEUR()

Local Integer INDEX

Call TROUVE([M:XPI1]CTRLSTAA,VALEUR,[M:XPI1]STAAFT,INDEX) From SPVOBJXRT

End
##################################################################
Subprog C_DEFQUEST(VALEUR)
Variable Char    VALEUR()

Local Integer INDEX

Call TROUVE([M:XPI2]CTRLQUEST,VALEUR,[M:XPI2]CODQUEST,INDEX) From SPVOBJXRT

End

