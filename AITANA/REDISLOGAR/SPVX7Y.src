#ACV#X12
#TIT#Gestion de l'objet Paramétrage du type d'intervention

#==========================================================================================
# Gestion de l'objet   : Gestion de l'objet Paramétrage du type d'intervention
#
# Auteur               :
# Date de création     :
#==========================================================================================
# Modifications significatives :
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 09/08/2002    OTHYR        Modélisation Web
# 22/12/2004    CPERR        Gestion des textes traduisibles
#==========================================================================================

GBIDC1=""
GBIDC2=""
GFONC1="GESX7Y"
Call OBJET("X7Y",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

#####################################################################
$ACTION
# Appel fonctions complémentaires GFI pour l'objet X7Y
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

#===== Actions scénario Objet
Case ACTION
    When "INICRE"   : Gosub INICRE   From SPVOBJX7Y
    When "INIMOD"   : Gosub INIMOD   From SPVOBJX7Y
    When "CHANGE"   : Gosub CHANGE   From SPVOBJX7Y
    When "ANNULE"   : Gosub ANNULE   From SPVOBJX7Y

    When "SETBOUT"    : Gosub SETBOUT   From SPVOBJX7Y
    When "EXEBOUT"    : Gosub EXEBOUT   From SPVOBJX7Y
Endcase

#===== Actions scénario sélection dans table
Case ACTION
    When "SEL_TABLE"  : Gosub SEL_TABLE From SPVOBJX7Y
Endcase

Return



##################################################################

Subprog D_NUMLIGQUES(VALEUR)
Variable Decimal  VALEUR
VALEUR = nolign
End


