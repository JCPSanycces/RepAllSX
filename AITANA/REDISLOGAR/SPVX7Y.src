Subprog AV_CTRLQUEST(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 1 : Grizo [M:XPI2]15
             Effzo [M:XPI2]15
    When 2 : Actzo [M:XPI2]15
Endcase

If !GIMPORT Then
    Affzo [M:XPI2]15
Endif

End

##################################################################
Subprog AP_CTRLQUEST(VALEUR)
Variable Integer VALEUR

