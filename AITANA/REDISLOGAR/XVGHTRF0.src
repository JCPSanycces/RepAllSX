#<AdxTL>@(#)9.0.0.0 $Revision:   1.20  $ Gestion du masque VGHTRF
#ACV#X11
#TIT#Trasfert des enreg de VALGAS (cloturé ou annulé) dans VALGASHIS
#####CGUES 27/01/03 chgt trt ecran

$ACTION
Return

########################################
Subprog AV_PCEDATEND(VALEUR)
    Variable Date    VALEUR
    If VALEUR=[00/00/0000] & [M]PCEDATBEG<>[00/00/0000]
        VALEUR=addmonth([M]PCEDATBEG,1)
    Endif
End

########################################
Subprog AP_TSSITE(VALEUR)
    Variable Integer  VALEUR
    If VALEUR=2 Then
        Effzo [M]FCYBEG
        Grizo [M]FCYBEG
    Else
        Actzo [M]FCYBEG
    Endif
End

########################################
Subprog AP_TSCODVAL(VALEUR)
    Variable Integer  VALEUR
    If VALEUR=2 Then
        Effzo [M]CODVALBEG
        Grizo [M]CODVALBEG
    Else
        Actzo [M]CODVALBEG
    Endif
End

########################################
Subprog AV_INITZON(VALEUR)
    Variable Decimal  VALEUR
    Call AP_TSCODVAL([M]TSCODVAL)
    Call AP_TSSITE([M]TSSITE)
    Call AP_TSOPE([M]TSOPE)
    Call AP_TSDOC([M]TSDOC)
End

########################################
Subprog D_FCYBEG(VALEUR)
    Variable Char     VALEUR
    VALEUR=GUSRFCY
End

########################################
Subprog C_CODVALBEG(VALEUR)
    Variable Char     VALEUR
    If [M]TSCODVAL<>2 & VALEUR="" Then
        mkstat=2
    Endif
End

########################################
Subprog C_FCYBEG(VALEUR)
    Variable Char     VALEUR
    If [M]TSSITE<>2 & VALEUR="" Then
        mkstat=2
    Endif
End
########################################
Subprog AP_TSOPE(VALEUR)
    Variable Integer VALEUR
    If VALEUR=2 Then
        Effzo [M]OPEBEG
        Grizo [M]OPEBEG
    Else
        Actzo [M]OPEBEG
    Endif
End

########################################
Subprog C_OPEBEG(VALEUR)
    Variable Char    VALEUR()
    If [M]TSOPE<>2 & VALEUR="" Then
        mkstat=2
    Endif
End

########################################
Subprog AP_TSDOC(VALEUR)
    Variable Integer VALEUR
    If VALEUR=2 Then
        Effzo [M]DOCBEG
        Grizo [M]DOCBEG
    Else
        Actzo [M]DOCBEG
    Endif
End

########################################
Subprog C_DOCBEG(VALEUR)
    Variable Char    VALEUR()
    If [M]TSDOC<>2 & VALEUR="" Then
        mkstat=2
    Endif
End


