#<AdxTL>@(#)3.0.0.0 $Revision$
#ACV#X00
#TIT#XML Design


$ACTION
Case ACTION
  When "OUVRE" : Gosub OUVRE
  When "DEBUT" : Gosub DEBUT
  When "OK"    : Gosub OK
Endcase
Return


#################################
$OUVRE

Local Integer KFULTAB
Local Char KXSD

If [M:XWI3]CTLXSD=2    # SOUCH # Il faudrait le passer en paramètre
  KXSD = [F:X72]XSD
Endif

Return

#################################
$DEBUT

Raz [M:XXMD]

Local Clbfile FLUXXML(GLONXML)
[L]FLUXXML = VALEUR

If VALEUR = "" : Return : Endif
Call READXML([F:X72]HOST,num$([F:X72]PORT),[L]FLUXXML,KXSD,[M:XXMD]NODESPATH,[M:XXMD]NODESVALUE) From XCDOMUTILS
If GXJVOK : FIN=1 : Return : Endif

Local Integer WI
For WI=0 To dim([M:XXMD]NODESPATH)-1
    If [M:XXMD]NODESPATH(WI)=""
      Break
    Endif
    [M:XXMD]BASTAB+=1
Next
Affzo [M:XXMD]

Return

#################################
$OK

Local Integer WJ
Local Integer WI
For [L]WI=0 To dim([M:XXMD]NODESPATH)-1
  If [M:XXMD]NODESPATH([L]WI)=""
    Break
  Endif
  [L]WJ+=1
Next

Local Char YTAB(255)([L]WJ)
Local Char YVAL(80)([L]WJ)

For [L]WI=0 To [L]WJ-1
    YTAB([L]WI) = [M:XXMD]NODESPATH([L]WI)
    YVAL([L]WI) = [M:XXMD]NODESVALUE([L]WI)
Next

Call BUILDXML([F:X72]HOST,num$([F:X72]PORT),KXSD,YTAB,YVAL,VALEUR) From XCDOMUTILS
If GXJVOK : FIN=1 : Return : Endif

Affzo [M:XWI2]REQUEST # SOUCH # A faire en dehors de l'action

Return
