Local Char VALBOUT(250) , PARBOUT(250)(1..20)
PARBOUT(1) = "AFF1002SAL00001"
PARBOUT(1)="AFF1001LYO00001"
PARBOUT(1)="AFF1003LYO00002"
FLGEXE = 1
GACTION = "XPILOPP"
Call SAISIE_CHAR(VALBOUT,PARBOUT,"XPILOPP","XPILOPP","YPILOPP") From GSAISIE
End

#==========================================================================================
$ACTION
Case ACTION
  When "OUVRE" : Gosub OUVRE From XZOOMOPP2
  When "DEBUT" : Gosub DEBUT From XZOOMOPP2
  When "TITRE" : Gosub D_TIT From XZOOMOPP2
Endcase
Return

#==========================================================================================
Subprog IB_NBZ

If [M:DIA]OBJ(nolign-1)<>"" & [M:DIA]PCENUM(nolign-1)<>""
  [V]GBOUT5=mess(7,100,1)
Else
  Raz [V]GBOUT5
Endif

# LBORN 01/03/2018 - Mantis 34973
Raz [V]GBOUT6, [V]GBIDC1
If [M:DIA]OBJ(nolign-1)<>"" & [M:DIA]PCENUM(nolign-1)<>"" & [M:DIA]OBJ(nolign-1)="VGS"
  If !clalev([F:VGS]) : Local File VALGASSIT : Endif
  Read [F:VGS]VGA1=[M:DIA]PCENUM(nolign-1)
  If !fstat & [F:VGS]ORIVAL=13
    [V]GBOUT6=mess(24,477,1)-[M:DIA]ORINUM(nolign-1)
    [V]GBIDC1="PIH"
  Endif
Endif

End

