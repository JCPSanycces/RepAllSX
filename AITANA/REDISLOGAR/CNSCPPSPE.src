# CODACT: YA052 - Campo Tiene Adjuntos en Consultas
#####################################################################################

$ACTION
Case ACTION
  When "LECTURE"     : Gosub LECTURE
Endcase

Return

#####################################################################################

$LECTURE

Gosub ACTION From CNSCPPSTD
GPE = 1

Local Integer NLIN

For NLIN = 0 To NOL
  [M:CPP2]YITMADJ (NLIN) = func YFNC.TIENE_ADJ ('ITM', [M:CPP2]ITMREF (NLIN), '', '')
Next

Affzo [M:CPP2]YITMADJ

Return

