#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
 #Infbox ACTION
  Case ACTION
    When "OUVRE"  : Gosub $OUVRE
    When "DEBUT"  : Gosub $DEBUT
    When "OK"     : Gosub $OK
  Endcase
Return

########################################################################################
$OUVRE
  #Infbox num$([M:SIH0]YTIPOMAT)
  If [M:SIH0]BPCINV <> '35024' Then
     Gosub FIN From GSAISIE # cerrar ventana si el cliente no es NAVARRA
  Endif
Return

########################################################################################
$DEBUT
  #Infbox num$([M:SIH0]YTIPOMAT)
  [M:YSTM]YTIPOMAT = [M:SIH0]YTIPOMAT
  Affzo [M:YSTM]YTIPOMAT

Return

########################################################################################
$OK
  # Infbox num$([M:YSTM]YTIPOMAT)
  If num$([M:YSTM]YTIPOMAT) <> '' Then
    If !clalev([ZSIH])  Then : Local File SINVOICE [ZSIH] : Endif
    Read [ZSIH]SIH0=[M:SIH0]NUM
    # Read [ZSIH] First
    If !fstat Then
      Trbegin [ZSIH]
      [F:ZSIH]YTIPOMAT = [M:YSTM]YTIPOMAT
      [M:SIH0]YTIPOMAT = [M:YSTM]YTIPOMAT
      Rewrite
      Commit
    Endif
    Affzo [M:SIH0]YTIPOMAT
    Close File [ZSIH]
  Endif
Return

