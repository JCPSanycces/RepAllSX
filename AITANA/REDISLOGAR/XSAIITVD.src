########################################
Subprog AV_ENDDAT(VALEUR)
Variable Date    VALEUR

If VALEUR=[0/0/0] | VALEUR<>[M]STRDAT Then
  Case [V]GBOITE
    When "SAIITVD1" :
    When "SAIITVD2" :
    When "SAIITVD3" : # LBORN 12/11/2014
                      # VALEUR=[M]STRDAT
                      If VALEUR=[0/0/0] : VALEUR=[M]STRDAT : Endif
    When "SAIITVD4" : VALEUR=[M]STRDAT
    When "SAIITVD5"
  Endcase
Endif
End

########################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

Case [V]GBOITE
When "SAIITVD1" :
When "SAIITVD2" :
When "SAIITVD3" : If VALEUR<[M]STRDAT Then
                    [V]GMESSAGE=mess(6,199,1)
                    [V]GERR=1
                    mkstat=2
                  Endif
When "SAIITVD4" :
When "SAIITVD5" : If VALEUR<[M]STRDAT Then
                    [V]GMESSAGE=mess(6,199,1)
                    mkstat=2
                    [V]GERR=1
                  Endif
Endcase

If !mkstat & !func XCLOPER2.AUTORIS_DAT([M:DIA]CODOPE,[M:DIA]ASSITV,[M:DIA]STRDAT,VALEUR)
  mkstat=2
  [V]GERR=1
Endif

End

########################################
Subprog C_ENDHOU(VALEUR)
Variable Char    VALEUR()

Case [V]GBOITE
When "SAIITVD1"
When "SAIITVD2"
When "SAIITVD3" : If [M]ENDDAT=[M]STRDAT & VALEUR<[M]STRHOU Then
                    GMESSAGE=mess(6,199,1)
                    mkstat=2
                  Endif
When "SAIITVD4" :
Endcase
End

########################################
Subprog AM_NBDAY(VALEUR)
Variable Decimal VALEUR

# SOUCH # 2010 # Compatibilité Web Services et import #

Local Integer UVYDAY(7)
Local Char    UVYCOD
Local Decimal HOUWKD(7)
Local Date    DATDISPO


Local Char XREQNUM
Local Char XFCY
Local Char XCODOPE
Local Char XITVTYP
Local Char XASSITV

Local Char XHMLEN
Local Date  XENDDAT

[L]DATDISPO=[M]STRDAT

If GWEBSERV | GIMPORT

   # LBORN 19/12/2014 - Mantis 27474
   If [M]ASSITV(nolign-1)="" & [M]ASSLIB(nolign-1)<>""
     [M]ASSITV(nolign-1)=[M]ASSLIB(nolign-1)
   Endif

   [L]XREQNUM  = [M]REQNUM(nolign-1)
   [L]XFCY     = [M]FCY(nolign-1)
   [L]XCODOPE  = [M]CODOPE(nolign-1)
   [L]XITVTYP  = [M]ITVTYP(nolign-1)
   [L]XASSITV  = [M]ASSITV(nolign-1)
Else
   [L]XREQNUM  = [M]REQNUM
   [L]XFCY     = [M]FCY
   [L]XCODOPE  = [M]CODOPE
   [L]XITVTYP  = [M]ITVTYP
   [L]XASSITV  = [M]ASSITV
Endif

Call RECUP_DISPO([L]XREQNUM,[L]XFCY,[L]XCODOPE,[L]XITVTYP,[L]XASSITV,[L]UVYDAY,[L]UVYCOD,[L]HOUWKD)
&From SPVOBJITV3

Call DUREE_FIN_DAY([L]DATDISPO,VALEUR,[L]UVYDAY,[L]UVYCOD,[L]HOUWKD,[L]XHMLEN,[L]XENDDAT)
&From SPVOBJITV3

If GWEBSERV | GIMPORT
  [M]HMLEN(nolign-1) = [L]XHMLEN
  [M]ENDDAT(nolign-1)= [L]XENDDAT
Else
  [M]HMLEN = [L]XHMLEN
  [M]ENDDAT= [L]XENDDAT
Endif

# LBORN 15/10/2012
If !mkstat & !func XCLOPER2.AUTORIS_DAT([L]XCODOPE,[L]XASSITV,[L]DATDISPO,[L]XENDDAT)
  mkstat=2
Endif

End

########################################
Subprog AM_HMLEN(VALEUR)
Variable Char    VALEUR()

# SOUCH # 2010 # Compatibilité Web Services et import #

Local Integer UVYDAY(7)
Local Char    UVYCOD
Local Decimal HOUWKD(7), NBJOU
Local Date    DATDISPO

Local Char XREQNUM
Local Char XFCY
Local Char XCODOPE
Local Char XITVTYP
Local Char XASSITV

Local Decimal XNBDAY
Local Date  XENDDAT

# LBORN 30/10/2014 - Mantis 26998
# [L]DATDISPO=[M]STRDAT

# LBORN 19/12/2014 - Mantis 27474
If GWEBSERV | GIMPORT
  If [M]ASSITV(nolign-1)="" & [M]ASSLIB(nolign-1)<>""
    [M]ASSITV(nolign-1)=[M]ASSLIB(nolign-1)
  Endif
Endif

If (GWEBSERV | GIMPORT) & dim([M]REQNUM)>1
   # LBORN 30/10/2014 - Mantis 26998
   [L]DATDISPO=[M]STRDAT(nolign-1)

   [L]XREQNUM = [M]REQNUM(nolign-1)
   [L]XFCY    = [M]FCY(nolign-1)
   [L]XCODOPE = [M]CODOPE(nolign-1)
   [L]XITVTYP  = [M]ITVTYP(nolign-1)
   [L]XASSITV = [M]ASSITV(nolign-1)
Else
   # LBORN 30/10/2014 - Mantis 26998
   [L]DATDISPO=[M]STRDAT

   [L]XREQNUM = [M]REQNUM
   [L]XFCY    = [M]FCY
   [L]XCODOPE = [M]CODOPE
   [L]XITVTYP  = [M]ITVTYP
   [L]XASSITV = [M]ASSITV
Endif

Call RECUP_DISPO([L]XREQNUM,[L]XFCY,[L]XCODOPE,[L]XITVTYP,[L]XASSITV,[L]UVYDAY,[L]UVYCOD,[L]HOUWKD)
&From SPVOBJITV3

Call DAY_FIN_DUREE([L]DATDISPO,[L]XNBDAY,[L]UVYDAY,[L]UVYCOD,[L]HOUWKD,VALEUR,[L]XENDDAT)
&From SPVOBJITV3

If GWEBSERV | GIMPORT
  [M]NBDAY(nolign-1) = [L]XNBDAY
  [M]ENDDAT(nolign-1)= [L]XENDDAT
Else
  [M]NBDAY = [L]XNBDAY
  [M]ENDDAT= [L]XENDDAT
Endif

If !GIMPORT Then Affzo [M]NBDAY Endif

# LBORN 15/10/2012
If !mkstat & !func XCLOPER2.AUTORIS_DAT([L]XCODOPE,[L]XASSITV,[L]DATDISPO,[L]XENDDAT)
  mkstat=2
Endif

End

########################################
Subprog AV_NBDAY(VALEUR)
Variable Decimal VALEUR

Local Integer UVYDAY(7)
Local Char    UVYCOD
Local Decimal HOUWKD(7), DUREE
Local Date    DATDISPO, DATEFIN

Case [V]GBOITE
When "SAIITVD1" :
When "SAIITVD2" :
When "SAIITVD3" :

                  # LBORN 23/03/2015 - Mantis 28871
                  # [L]DUREE=(int(val([M]ENDHOU)/100)*60+mod(val([M]ENDHOU),100))-(int(val([M]STRHOU)/100)*60+mod(val([M]STRHOU),100))
                  If [M]ENDDAT>[M]STRDAT
                    [L]DUREE=1440-(int(val([M]STRHOU)/100)*60+mod(val([M]STRHOU),100))
                    [L]DUREE+=([M]ENDDAT-[M]STRDAT-1)*1440
                    [L]DUREE+=(int(val([M]ENDHOU)/100)*60+mod(val([M]ENDHOU),100))
                  Else
                    [L]DUREE=(int(val([M]ENDHOU)/100)*60+mod(val([M]ENDHOU),100))-(int(val([M]STRHOU)/100)*60+mod(val([M]STRHOU),100))
                  Endif

                  [M]HMLEN=" " + string$(3-len(num$(int([L]DUREE/60))),"0")
&                         + num$(int([L]DUREE/60))+string$(2-len(num$(mod([L]DUREE,60))),"0")
&                         + num$(mod([L]DUREE,60))

                  # LBORN 23/03/2015 - Mantis 28871
                  # [L]DATDISPO=[M]ENDDAT
                  [L]DATDISPO=[M]STRDAT

                  Call RECUP_DISPO([M]REQNUM,[M]FCY,[M]CODOPE,[M]ITVTYP,[M]ASSITV,[L]UVYDAY,[L]UVYCOD
&                                 ,[L]HOUWKD)
&                 From SPVOBJITV3

                  Call DAY_FIN_DUREE([L]DATDISPO,VALEUR,[L]UVYDAY,[L]UVYCOD,[L]HOUWKD,[M]HMLEN,[L]DATEFIN)
&                 From SPVOBJITV3

When "SAIITVD4"
When "SAIITVD5" : Call RECUP_DISPO([M]REQNUM,[M]FCY,[M]CODOPE,[M]ITVTYP,[M]ASSITV,[L]UVYDAY,[L]UVYCOD,[L]HOUWKD) From SPVOBJITV3
                  Call DUREE_DAY([M]STRDAT,[M]ENDDAT,[L]UVYDAY,[L]UVYCOD,[L]HOUWKD,VALEUR) From SPVOBJITV3
Endcase
End

########################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR

Local Integer UVYDAY(7), OK
Local Char    UVYCOD
Local Decimal HOUWKD(7), XNBDAY
Local Date    DATDISPO, DATEFIN

# Ctrl cohérence date saisie /date debut ligne C.R.A
# Numlig provient du trt SPEOBJITV3 (global cause Web, nolign non fiable)
If GFONC1="GESITL" & VALEUR<>[M:ITL1]DATITV(GWEBNOL) Then
  mkstat=2 : End
Endif

[L]DATDISPO=VALEUR

Call RECUP_DISPO([M]REQNUM,[M]FCY,[M]CODOPE,[M]ITVTYP,[M]ASSITV,[L]UVYDAY,[L]UVYCOD,[L]HOUWKD)
&From SPVOBJITV3

# LBORN 14/06/2016 - Mantis 32918
# Call CTL_JOU([L]DATDISPO,[L]UVYDAY,[L]UVYCOD,0) From CONTX3
Call CTL_JOU([L]DATDISPO,[L]UVYDAY,[L]UVYCOD,0) From XX03SCONTX3

# Raz mkstat car le ctl_jou renvoit mkstat=2 si le code indispo contient la date
If [L]DATDISPO<>VALEUR | mkstat Then
    Raz mkstat
    [V]GMESSAGE=mess(137,[V]GXMSGPSA,1)
    Call AVERTIR([V]GMESSAGE,[L]OK)From GESECRAN
    If [L]OK<>2 Then mkstat=2 Endif
Endif

# LBORN 15/10/2012
If !mkstat & !func XCLOPER2.AUTORIS_DAT([M]CODOPE,[M]ASSITV,VALEUR,VALEUR)
  mkstat=2 : End
Endif

# LBORN 18/10/2012
If !func SPVOBJITL.VALID_FRAIS([M]FCY, [M]CODOPE, [M]ITVTYP, [M]ASSITV, VALEUR, "*")
  mkstat=2 : End
Endif

# LBORN 14/11/2013 - Mantis 22108 (sinon date fin non recalculée)
# LBORN 04/01/2015 - Mantis 31782
# If dim([M]HMLEN)>0
If dim([M]HMLEN)>0 & (GBOITE<>"SAIITVD3" | GWEBSERV | GIMPORT)
  Call DAY_FIN_DUREE([L]DATDISPO,[L]XNBDAY,[L]UVYDAY,[L]UVYCOD,[L]HOUWKD,[M]HMLEN,[L]DATEFIN) From SPVOBJITV3
  If GWEBSERV | GIMPORT
    [M]NBDAY(nolign-1) = [L]XNBDAY
    [M]ENDDAT(nolign-1)= [L]DATEFIN
  Else
    [M]NBDAY = [L]XNBDAY
    [M]ENDDAT= [L]DATEFIN
  Endif
Endif

End



######################################################################################
## Etiquette ajoutée par le superviseur (écran SAIITVD1) 06/03/2006 23:10:14 (FMUYS)
######################################################################################

Subprog D_STRDAT(VALEUR)
Variable Date VALEUR
#FM le 06.03.06 Suite bug adonix Trt W1SAIITVDn
If VALEUR=[0/0/0] Then
  #Remplace init du Trt SPEOBJITV3
  VALEUR=date$
Endif
End

Subprog D_NBDAY(VALEUR)
Variable Decimal VALEUR
#FM le 06.03.06 Suite bug adonix Trt W1SAIITVDn
If !VALEUR Then
  #Remplace init du Trt SPEOBJITV3
  VALEUR=0
Endif
End

Subprog D_HMLEN(VALEUR)
Variable Char VALEUR()
#FM le 06.03.06 Suite bug adonix Trt W1SAIITVDn
If VALEUR="" Then
  #Remplace init du Trt SPEOBJITV3
  VALEUR=" 00000"
Endif
End

Subprog D_STRHOU(VALEUR)
Variable Char    VALEUR()
#FM le 06.03.06 Suite bug adonix Trt W1SAIITVDn
If VALEUR="" Then
  #Remplace init du Trt SPEOBJITV3
  VALEUR=num$(int(time/3600)*100+(int(mod(time,3600)/60)))
  VALEUR=string$(4-len(VALEUR),"0")+VALEUR
Endif
End

Subprog D_ENDHOU(VALEUR)
Variable Char    VALEUR()
#FM le 06.03.06 Suite bug adonix Trt W1SAIITVDn
If VALEUR="" Then
  #Remplace init du Trt SPEOBJITV3
  Case [V]GBOITE
  When "SAIITVD1" :
  When "SAIITVD2" :
  When "SAIITVD3" : VALEUR=[M]STRHOU
  When "SAIITVD4" :
  Endcase
Endif
End

