#<AdxTL>@(#)12.0.0.0 $Revision:   1.18  $ Gestion du masque CRITGFD
#ACV#X11
#TIT#Consultation des factures liées au contrat

#==========================================================================================
# Gestion de la consultation : GFD -- Factures des contrats
#                        
# Auteur                     : 
# Date de création           :       
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 28/02/2003    OTHYR        Modélisation Web + ajout PE
#==========================================================================================

Local Char PARAM(30)(2)

Call GCONSULT("GFD","",PARAM)From GCONSULT
End


###################################################################
$ACTION

Case ACTION
    When "AUTORIS"    : Gosub AUTORIS
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "SETBOUT"    : Gosub SETBOUT
    When "FIN_CRIT"   : Gosub FIN_CRIT
    When default
Endcase
Return

#-----------------------------------------------------------------#
#    Gestion des étiquettes liées a ACTION                        #
#-----------------------------------------------------------------#
###################################################################
$AUTORIS
Return

###################################################################
$SETBOUT
Return

###################################################################
$OUVRE

Local Char CRIT1(250), CRIT2(250), CRIT3(250), CRITSPE(250), CRITSPE2(250)
Local   Decimal  WMNTORG(0..5), WMNTDES(0..5)
Local   Integer  SPSTAT

If !clalev([F:DUD]) : Local File GACCDUDATE [DUD] : Endif
If !clalev([F:TCU]) : Local File TABCUR     [TCU] : Endif
If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif

Gosub DEFCRIT

[M:GFD1]CURD = GSYSCUR

Return

###################################################################
$DEFCRIT

#If [M:GFD1]SALFCY <> "" & (([M:GFD1]SALFCY = GFCYDEF & GUSRACC(1) = 0) | ([M:GFD1]SALFCY <> GFCYDEF & GUSRACC(2) = 0)) Then
#    [M:GFD1]SALFCY = ""
#Endif

For I = 1 To dim(PARAM)
    Case I  
        When 1      : #Parametre avenant
            If PARAM(I) <> "" Then
                 Call LECTURE("REQ",PARAM(I),"") From CONTOBJ
                 If !fstat Then
                     [M:GFD1]REQNUM = PARAM(I)
                 Endif   
            Endif    
        When 2 :    : # Parametre Client 
            If PARAM(I) <> "" Then
                If [F:BPC]BPCNUM <> PARAM(I) Then
                    Read [F:BPC]BPC0 = PARAM(I)
                    If fstat Then 
                        Raz [F:BPC] 
                    Endif
                Endif
            If !fstat [M:GFD1]BPCINV = PARAM(I) : Endif
            Endif
        When 3 :    : # Parametre Site
            If PARAM(I) <> "" Then
                If [F:FCY]FCY <> PARAM(I) Then   
                    Read [F:FCY]FCY0 = PARAM(I)
                    If fstat  Raz [F:FCY] : Endif
                Endif
#                If !fstat & ((PARAM(I) = GFCYDEF & GUSRACC(1) <> 0) | (PARAM(I) <> GFCYDEF & GUSRACC(2) <> 0)) Then
                    [M:GFD1]SALFCY = PARAM(I) 
                    Call GETDEV([M:GFD1]SALFCY) From DEVSUB
                    [M:GFD1]CPY    = GSOCIETE
#                Endif
            Endif
    Endcase
Next I   

If !find([M:GFD1]INVTYPFAC,1,2) : [M:GFD1]INVTYPFAC = 2 : Endif
If !find([M:GFD1]INVTYPAVO,1,2) : [M:GFD1]INVTYPAVO = 2 : Endif
If !find([M:GFD1]INVSTAO,1,2)   : [M:GFD1]INVSTAO   = 2 : Endif
If !find([M:GFD1]INVSTAN,1,2)   : [M:GFD1]INVSTAN   = 2 : Endif
If !find([M:CGFD]VGACON,1,2)    : [M:CGFD]VGACON    = 2 : Endif
If !find([M:CGFD]VGAITV,1,2)    : [M:CGFD]VGAITV    = 2 : Endif
If !find([M:CGFD]TRI,1,2)       : [M:CGFD]TRI       = 1 : Endif

# -- copie de l'écran critères (CGFD) vers le masque 1 (GFD1)
Gosub CRITENT From =PROGCNS

Return

###################################################################
$LECTURE

If [M:GFD1]REQNUM = "" & [M:GFD1]CPY = "" & [M:GFD1]SALFCY = "" Then
    NBLU = 0 
    Return
Endif

Gosub CHANGE_MSK From GCONSULT 
If CHGPAG<0 : NOL = MAXLIG : Endif

Call TEMPON("R") From GESECRAN

#-- Positionnement des Filtres
Gosub LOAD_FILTER
# Appel au filtre spécifique client
ACTION = "FILTRE"
Gosub ACTION From XOBJCNS
ACTION = "LECTURE"

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CGFD]TRI
        When 1     : # tri par numéro
            Filter [VGA] Where evalue([L]CRIT1) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                        Order By Key CLE=[F:VGA]PCENUM;[F:VGA]PCEDAT;[F:VGA]VALNUM
            Filter [SIV] Where evalue([L]CRIT2) & evalue([L]CRITSPE2)
        When 2     : # tri par date
            Filter [VGA] Where evalue([L]CRIT1) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                        Order By Key CLE=[F:VGA]PCEDAT;[F:VGA]PCENUM;[F:VGA]VALNUM
            Filter [SIV] Where evalue([L]CRIT2) & evalue([L]CRITSPE2)
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CGFD]TRI
        When 1     : # tri par numéro
            Filter [VGA] Where evalue([L]CRIT1) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                        Order By Key CLE=[F:VGA]PCENUM Desc;[F:VGA]PCEDAT Desc;[F:VGA]VALNUM Desc
            Filter [SIV] Where evalue([L]CRIT2) & evalue([L]CRITSPE2)
        When 2     : # tri par date
            Filter [VGA] Where evalue([L]CRIT1) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                        Order By Key CLE=[F:VGA]PCEDAT Desc;[F:VGA]PCENUM Desc;[F:VGA]VALNUM Desc 
            Filter [SIV] Where evalue([L]CRIT2) & evalue([L]CRITSPE2)
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:GFD2] : Endif

#-- lecture 
$BOUCLE
For [VGA]CLE(2)
    Read [SIV] SIV0 = [F:VGA]PCENUM
    If fstat Goto SUIV : Endif 
    
    Read [SIH] SIH0 = [F:SIV]NUM
    If fstat Goto SUIV : Endif 
    
    # Filtre sur la société
    If [M:GFD1]CPY <> "" & ([M:GFD1]CPY <> [F:SIH]CPY) Then 
        Goto SUIV 
    Endif

    If NBLU = 1 Then
        If CHGPAG = 2 | CHGPAG = -2 : Raz [M:GFD2] : Endif
        NBLU = 2
    Endif
    If CHGPAG > 0 Then
        If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
        NOL += 1     
        If NOL = 0  Then
            DEBNUM = [F:SIV]NUM 
            DEBDAT = [F:SIV]INVDAT
        Endif
        FINNUM = [F:SIV]NUM
        FINDAT = [F:SIV]INVDAT
    Else
        If NOL <= 0 : RETOUR=2 : Break : Endif
        NOL -= 1 
        If NOL = MAXLIG-1 Then
            FINNUM = [F:SIV]NUM 
            FINDAT = [F:SIV]INVDAT
        Endif
        DEBNUM = [F:SIV]NUM
        DEBDAT = [F:SIV]INVDAT
    Endif

    nolign = NOL+1

    [M:GFD2]NUM(nolign-1)        = [F:SIV]NUM
    [M:GFD2]BPCINV(nolign-1)     = [F:SIV]BPCINV
    Read [F:BPC]BPC0=[F:SIV]BPCINV
    If !fstat 
        [M:GFD2]BPCNAM(nolign-1)     = [F:BPC]BPCNAM
    Endif
    [M:GFD2]INVDAT(nolign-1)     = [F:SIV]INVDAT
    [M:GFD2]INVTYP(nolign-1)     = [F:SIV]INVTYP
    [M:GFD2]INVSTA(nolign-1)     = [F:SIV]INVSTA
    [M:GFD2]AMTATI(nolign-1)     = [F:SIH]AMTATI
    [M:GFD2]AMTNOT(nolign-1)     = [F:SIH]AMTNOT
    [M:GFD2]CUR(nolign-1)        = [F:SIH]CUR
    [M:GFD2]REQNUM(nolign-1)     = [F:VGA]REQNUM
    [M:GFD2]ITVNUM(nolign-1)     = [F:VGA]ITVNUM
    
    Raz WMNTORG
    WMNTORG (0) = [F:SIH]AMTATI
    #    Recherche du montant réglé
    For [DUD] Where TYP=[F:SIH]GTE & NUM=[F:SIH]NUM
        WMNTORG (1) += [F:DUD]PAYCUR
    Next
    [M:GFD2]AMTPAY(nolign-1)    = WMNTORG (1)
    #    Calcul des montants en devise société
    Call CONVERT_TAB([F:SIH]CUR, [M:GFD1]CURS, [M:GFD1]CURS, [F:SIH]CURTYP, date$, WMNTORG, WMNTDES,SPSTAT) From TRTDEV
    [M:GFD2]AMTATISOC(nolign-1)  = WMNTDES (0)
    [M:GFD2]AMTPAYSOC(nolign-1)  = WMNTDES (1)
    #    Calcul des montants en devise dossier
    Call CONVERT_TAB([F:SIH]CUR, [M:GFD1]CURD, [M:GFD1]CURS, [F:SIH]CURTYP, date$, WMNTORG, WMNTDES,SPSTAT) From TRTDEV
    [M:GFD2]AMTATIDOS(nolign-1)  = WMNTDES (0)
    [M:GFD2]AMTPAYDOS(nolign-1)  = WMNTDES (1)
 
    [M:GFD2]BPCGRU(nolign-1)    = [F:SIV]BPCGRU
    [M:GFD2]BPRPAY(nolign-1)    = [F:SIH]BPRPAY
    [M:GFD2]PTE(nolign-1)       = [F:SIH]PTE
    [M:GFD2]STRDUDDAT(nolign-1) = [F:SIH]STRDUDDAT
    [M:GFD2]SALFCY(nolign-1)    = [F:SIV]SALFCY

  $SUIV  
Next

Filter [SIV]
Filter [VGA]

Call TEMPOFF From GESECRAN

Return

###################################################################
$LOAD_FILTER
[L]CRIT1    = "1"     :# Sur VALGAS
[L]CRIT2    = "1"     :# Sur SINVOICEV
[L]CRIT3    = "1"     :# Sur VALGAS
[L]CRITSPE  = "1"     :# Critère spécifique client sur VALGAS  
[L]CRITSPE2 = "1"     :# Critère spécifique client sur SINVOICEV


# Uniquement facture et avoir
[L]CRIT1 += "& find([F:VGA]TYPDOC,'AC1','FC1','FF1','AF1')<>0"

If [M:GFD1]SALFCY <> "" Then
    [L]CRIT1 += "&[F:VGA]ORGFCY=[M:GFD1]SALFCY"
Endif
If [M:GFD1]BPCINV <> ""
   [L]CRIT1 += "&[F:VGA]BPCINV =[M:GFD1]BPCINV"
Endif

[L]CRIT2 += "&[F:SIV]INVTYP<>3 & [F:SIV]INVTYP<>4"
# Prise en compte des factures
# --> Si 1 (Non) On exclut les factures
If [M:GFD1]INVTYPFAC = 1 Then
    [L]CRIT2 += "&[F:SIV]INVTYP<>1"
Endif
# Prise en compte des avoirs
# --> Si 1 (Non) On exclut les avoirs
If [M:GFD1]INVTYPAVO = 1 Then
    [L]CRIT2 += "&[F:SIV]INVTYP<>2"
Endif
# Prise en compte des factures validées
# --> Si 1 (Non) On exclut les factures validées
If [M:GFD1]INVSTAO = 1 Then
    [L]CRIT2 += "&[F:SIV]INVSTA<>3"
Endif
# Prise en compte des factures non validées
# --> Si 1 (Non) On exclut les factures non validées
If [M:GFD1]INVSTAN = 1 Then
    [L]CRIT2 += "&[F:SIV]INVSTA>2"
Endif

#DS
If [M:GFD1]REQNUM <> "" Then
    [L]CRIT1 +="& [F:VGA]REQNUM=[M:GFD1]REQNUM"
Endif
If [M:CGFD]NUMDEB <> "" Then
    [L]CRIT1 += "&[F:VGA]PCENUM>=[M:CGFD]NUMDEB"
Endif
If [M:CGFD]NUMFIN <> "" Then
    [L]CRIT1 += "&[F:VGA]PCENUM<=[M:CGFD]NUMFIN"
Endif
[L]CRIT1 += "& [F:VGA]PCENUM<>''"

If [M:CGFD]INVDATDEB <> [0/0/0] Then
    [L]CRIT1 += "&[F:VGA]PCEDAT>=[M:CGFD]INVDATDEB"
Endif
If [M:CGFD]INVDATFIN <> [0/0/0] Then
    [L]CRIT1 += "&[F:VGA]PCEDAT<=[M:CGFD]INVDATFIN"
Endif

#Origine DS et Inter
[L]CRIT3 += "& ([F:VGA]ORIVAL=1 | [F:VGA]ORIVAL=2)"

# Cloturé
[L]CRIT3 += "& [F:VGA]VGASTA=2"

Case CHGPAG
    When 3 : # rafraichissement
        Case [M:CGFD]TRI
            When 1 : # tri par numéro
                [L]CRIT1 += "&[F:VGA]PCENUM>=DEBNUM"
            When 2 : # tri par date
                [L]CRIT1 += "&[F:VGA]PCEDAT>=DEBDAT"
        Endcase
    When 2 : # suite
        Case [M:CGFD]TRI
            When 1 : # tri par numéro
                [L]CRIT1  += "&[F:VGA]PCENUM>FINNUM"
            When 2 : # tri par date
                [L]CRIT1 += "&[F:VGA]PCEDAT>FINDAT"
        Endcase
    When -2 : # retour
        Case [M:CGFD]TRI
            When 1 : # tri par numéro
                [L]CRIT1 += "&[F:VGA]PCENUM<DEBNUM"
            When 2 : # tri par date
                [L]CRIT1 += "&[F:VGA]PCEDAT<DEBDAT"
        Endcase
Endcase

Return


###################################################################
$FIN_CRIT
[M:GFD1] = [M:CGFD]
Return


#-----------------------------------------------------------------#
#    Gestion des étiquettes liées aux masques GFD1, GFD2 et CGFD  #
#-----------------------------------------------------------------#
###################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" Then
    [M]CURS = [F:CPY]ACCCUR
Elsif [M]SALFCY = "" Then
    GERR=2 : GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    Raz [M]CURS
Endif
Affzo [M]CURS
End

###################################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" Then
# -- Controle autorisation sur le site
#    If (GUSRACC(1) = 0 & GFCYDEF = VALEUR) or (GUSRACC(2) = 0 & GFCYDEF <> VALEUR) Then
#        GMESSAGE = VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
#        mkstat   = 2 
#        End
#    Endif
    #-----------------------------------#
    # Alimentation site fin.(GFINRSP)   #
    #              soc. (GSOCIETE)      #
    #              dev.soc. (GLOCALDEV) #
    #-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY  = GSOCIETE 
    [M]CURS = GLOCALDEV
    Affzo [M]CPY, ZCPY, CURS
Elsif [M]CPY = "" Then
    GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    mkstat   = 2
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif

End

###################################################################
Subprog IB_NBLIG

Raz GBOUT1

If [M:GFD2]NUM(nolign-1) <> "" Then
    GBOUT1 = mess(193, 198,1) 
Endif

End

###################################################################
Subprog AM_NUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" Then 
    [M]NUMFIN = VALEUR 
Endif
End

###################################################################
Subprog AM_INVDATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] Then 
    [M]INVDATFIN = VALEUR 
Endif
End



