#####################################################################################
# CODACT: Y0000 - Genéricos
#####################################################################################

$ACTION
Case ACTION
  When "RAZCRE"     : Gosub RAZCRE
Endcase

Return

#####################################################################################

$RAZCRE
Case [M:SRE0]YTIPO
  When "RP"  : [M:ITN0]YITNTYP = "RI"
  When "SP"  : [M:ITN0]YITNTYP = "TK"
Endcase
Affzo [M:ITN0]YITNTYP

Return

