#<AdxTL>@(#)0.0.0.0 $Revision$ Purchase Order Confirmations
######################################################################################
# Program Name: SPEYPOC
# Description : Specific Processing - Purchase Order Confirmation
# Author      :
# Date        : AUG 2nd, 2018
######################################################################################

$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
 When "VERIF_CRE"     : Gosub VERIF_CRE
 When "VERIF_MOD"     : Gosub VERIF_MOD
 When "CREATION"      : Gosub CREATION From TABLEAUX
 When "LIENS"         : Gosub LIENS From TABLEAUX
 When "ANNULE"        : Gosub ANNULE From TABLEAUX
 When "MODIF"         : Gosub MODIF From TABLEAUX
 When "DEFLIG"        : Gosub DEFLIG
 When "APRES_CRE"     : Gosub LIENS From TABLEAUX
 When "APRES_MOD"     : Gosub LIENS From TABLEAUX
 When "OUVRE"         : Gosub OUVRE
 When "FILTRE"        : Default File [YPCH]
 When "PICKE"         : Gosub PICKE
 When "DEPICK"        : Gosub DEPICK
 When "AVANTBOUT"     : Gosub AVANTBOUT
 When "FILGAUCHE"     : Gosub FILGAUCHE
 When "SETBOUT"       : Gosub SETBOUT
 When "RAZDUP"        : Gosub RAZDUP
 When "INICRE_LIG"    : Gosub INICRE_LIG
 When "ABANDON"       : Gosub ABANDON
 When "FIN"           : Gosub FIN
 When Default
Endcase
Return
######################################################################################

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$VERIF_MOD
 If [M:YPOC1]NBLIG = 0 : GMESSAGE = mess(17,106,1) : GERR = 1 : mkstat = 2 : Return: Endif
 For J = 0 To [M:YPOC1]NBLIG-1
  If [M:YPOC1]YPOCLIN(J) = 0
   [M:YPOC1]CREFLG(J)=2
  Else
   [M:YPOC1]UPDFLG(J)=2
  Endif
  [M:YPOC1]YPOCNUM(J) = [M:YPOC0]YPOCNUM
  Affzo [M:YPOC1]YPOCNUM(J)
  Affzo [M:YPOC1]UPDFLG(J)
 Next
Return

##############################################################
$VERIF_CRE
 ##Local Char SEQCODE(50) : SEQCODE = ""
 ##Local Integer STAT : STAT = 0
 If [M:YPOC1]NBLIG = 0 : GMESSAGE = mess(17,106,1) : GERR = 1 : mkstat = 2 :  Return : Endif
 ##Call NUMERO("YPOC",[M:YPOC0]YFCY,"01/01/01","",SEQCODE,STAT) From SUBANM
 ##[M:YPOC0]YPOCNUM = SEQCODE
 ##Affzo [M:YPOC0]YPOCNUM
 For J = 0 To [M:YPOC1]NBLIG-1
  [M:YPOC1]YPOCNUM(J) = [M:YPOC0]YPOCNUM
  Affzo [M:YPOC1]YPOCNUM(J)
 Next
Return

##############################################################
$DEFLIG
Default Mask [YPOC1]
Default File [YPCD]

CRIT = 'YPOCNUM="'+[M:YPOC1]YPOCNUM+'"'
FICLIG = "YPCD"
ABLIG = "YPCD"
ZONLIG = "YPOCLIN"
Return

##############################################################
$OUVRE
If !clalev([M:PCOW])   Local Mask PCRITORD  [PCOW]  : Endif
Gosub DECLARE From TABLEAUX

#  ##########################JCH - 19/11/2019
#Global Decimal INIQTY(0..)
#Raz INIQTY
Global Char     NUMPEDIDO(50) : Raz NUMPEDIDO
Global Integer  NLPEDIDO      : Raz NLPEDIDO
Global Integer  PARCIALFLG    : Raz PARCIALFLG
Global Char     GYSOHDUPLI(50)(0..)

Return

##############################################################
$INICRE_LIG
  [F:YPCD]YPOCNUM = [M:YPOC0]YPOCNUM
Return

##############################################################
$PICKE
If currbox = "GAU_CHE1"
 Local Integer ZNBLIG : ZNBLIG = [M:YPOC1]NBLIG
 [M:YPOC1]YQTY(ZNBLIG) = [F:POQ]QTYPUU
 [M:YPOC1]NBLIG = ZNBLIG + 1
 [M:YPOC1]YPOHNUM(ZNBLIG)     = [F:POH]POHNUM
 [M:YPOC1]YPOPLIN(ZNBLIG)     = [F:POQ]POPLIN
 [M:YPOC1]YITMREF(ZNBLIG)     = [F:POP]ITMREF
 [M:YPOC1]YPRICE(ZNBLIG)      = [F:POP]GROPRI
 [M:YPOC1]YTIPPRI(ZNBLIG)     = [F:POP]YTIPPRI
 [M:YPOC1]YCNFRCPDAT(ZNBLIG)  = [F:POQ]EXTRCPDAT
 [M:YPOC1]YDISCRGAMT1(ZNBLIG) = [F:POP]DISCRGVAL1
 [M:YPOC1]YDISCRGAMT2(ZNBLIG) = [F:POP]DISCRGVAL2
 [M:YPOC1]YDISCRGAMT3(ZNBLIG) = [F:POP]DISCRGVAL3
 [M:YPOC1]YDISCRGAMT4(ZNBLIG) = [F:POP]DISCRGVAL4
 [M:YPOC1]YDISCRGAMT5(ZNBLIG) = [F:POP]DISCRGVAL5
 [M:YPOC1]YDISCRGAMT6(ZNBLIG) = [F:POP]DISCRGVAL6
 [M:YPOC1]YDISCRGAMT7(ZNBLIG) = [F:POP]DISCRGVAL7
 [M:YPOC1]YDISCRGAMT8(ZNBLIG) = [F:POP]DISCRGVAL8
 [M:YPOC1]YDISCRGAMT9(ZNBLIG) = [F:POP]DISCRGVAL9
 [M:YPOC1]YPRHFCY(ZNBLIG)     = [F:POP]PRHFCY
 [M:YPOC1]YSOLRCPDAT(ZNBLIG)  = [F:POQ]YSOLRCPDAT

 Affzo [M:YPOC1]NBLIG(ZNBLIG)
 Affzo [M:YPOC1]YPOHNUM(ZNBLIG)
 Affzo [M:YPOC1]YPOPLIN(ZNBLIG)
 Affzo [M:YPOC1]YPRICE(ZNBLIG)
 Affzo [M:YPOC1]YITMREF(ZNBLIG)
 Affzo [M:YPOC1]YQTY(ZNBLIG)
 Affzo [M:YPOC1]YCNFRCPDAT(ZNBLIG)
 Affzo [M:YPOC1]YDISCRGAMT1(ZNBLIG)
 Affzo [M:YPOC1]YDISCRGAMT2(ZNBLIG)
 Affzo [M:YPOC1]YDISCRGAMT3(ZNBLIG)
 Affzo [M:YPOC1]YDISCRGAMT4(ZNBLIG)
 Affzo [M:YPOC1]YDISCRGAMT5(ZNBLIG)
 Affzo [M:YPOC1]YDISCRGAMT6(ZNBLIG)
 Affzo [M:YPOC1]YDISCRGAMT7(ZNBLIG)
 Affzo [M:YPOC1]YDISCRGAMT8(ZNBLIG)
 Affzo [M:YPOC1]YDISCRGAMT9(ZNBLIG)
 Affzo [M:YPOC1]YPRHFCY(ZNBLIG)
 Affzo [M:YPOC1]YSOLRCPDAT(ZNBLIG)

 #OK=0
 Affzo [M:YPOC1]
Endif
Return

##############################################################
$AVANTBOUT
Local Char PARBOUT(250)(1..20)
Local Integer ZERRCNT : ZERRCNT = 0
##GGAR Fix Error ZGPATH
#Global Char ZGPATH(250)

## "Y" - Validated

# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
  ##########################JCH - 09/12/2019
  If BOUT = "Y" Then
    Gosub LANZA_VALIDACION
  Endif

If 1=2 Then
 If BOUT = "Y"
  Local Integer ZOK
  ZOK = 1
  Call OUINON(mess(432,7773,1),ZOK) From GESECRAN
  If ZOK = 1 : Return : Endif

  If !clalev([F:YPOH]) : Local File PORDER  [F:YPOH] : Endif
  If !clalev([F:YSOH]) : Local File SORDER  [F:YSOH] : Endif
  If !clalev([F:YMLK]) : Local File MTOLINK [F:YMLK] : Endif

  ##########################JCH - 19/11/2019
  If !clalev([F:SOQ0]) : Local File SORDERQ [F:SOQ0] : Endif
  If !clalev([F:POQ0]) : Local File PORDERQ [F:POQ0] : Endif
  ##########################JCH - 19/11/2019

  Local Char WDOCLOCK (20) (0..100), WSIMB (250)
  Local Integer WNDOCLOCK

  For K = 0 To [M:YPOC1]NBLIG - 1
    # Compruebo los Pedidosde Compra  de la línea de Confirmación
    If !find ([M:YPOC1]YPOHNUM (K), WDOCLOCK(0..100))
      WSIMB = "POH"+[M:YPOC1]YPOHNUM (K)
      Lock = WSIMB
      If fstat
        Call MESSAGE ("Pedido "- [M:YPOC1]YPOHNUM (K) -"Bloqueado") From GESECRAN
        Return
      Else
        WDOCLOCK (WNDOCLOCK) = WSIMB
        WNDOCLOCK += 1
      Endif

    Endif

    # Comprubeo los Pedidos de Venta linkados a cada línea de Confirmación
    For [F:YMLK]MLK0 Where DEMNUM = [M:YPOC1]YPOHNUM (K) and DEMLIN = [M:YPOC1]YPOPLIN (K)
      If !find ([F:YMLK]RESSNUM, WDOCLOCK(0..100))
        WSIMB = "SOH"+[F:YMLK]RESSNUM
        Lock = WSIMB
        If fstat
          Call MESSAGE ("Pedido "- [F:YMLK]RESSNUM -"Bloqueado") From GESECRAN
          Return
        Else
          WDOCLOCK (WNDOCLOCK) = WSIMB
          WNDOCLOCK += 1
        Endif
      Endif
    Next

    For [F:YMLK]MLK0 Where RESSNUM = [M:YPOC1]YPOHNUM (K) and RESSLIN = [M:YPOC1]YPOPLIN (K)
      If !find ([F:YMLK]DEMNUM, WDOCLOCK(0..100))
        WSIMB = "SOH"+[F:YMLK]DEMNUM
        Lock = WSIMB
        If fstat
          Call MESSAGE ("Pedido "- [F:YMLK]DEMNUM -"Bloqueado") From GESECRAN
          Return
        Else
          WDOCLOCK (WNDOCLOCK) = WSIMB
          WNDOCLOCK += 1
        Endif
      Endif
    Next

    ##########################JCH - 19/11/2019
    # Busca si el pedido de venta relacionado con ese pedido de compra ya tiene fecha de confirmación asignada
    Filter [F:POQ0] Where POHNUM = [M:YPOC1]YPOHNUM(K)
    Read   [F:POQ0] First
    If !fstat Then
      Filter [F:SOQ0] Where POHNUM = [F:POQ0]POHNUM and POPLIN = [F:POQ0]POPLIN and SOQSEQ = [F:POQ0]POQSEQ
      If !fstat Then
        If [F:SOQ0]YCONFIRMADAT <> [00/00/0000] Then
          Call MESSAGE("La línea "+[M:YPOC1]YPOPLIN(K)+" del pedido "+[M:YPOC1]YPOHNUM(K)+" ya tiene fecha de confirmación") From GESECRAN
        Endif
      Endif
    Endif
    Filter [F:POQ0]
    ##########################JCH - 19/11/2019

  Next

  ##########################JCH - 19/11/2019
  Close Local File [SOQ0],[POQ0]
  ##########################JCH - 19/11/2019

  For K = 0 To [M:YPOC1]NBLIG - 1
    Unlock = WDOCLOCK (K)
  Next

  If dim(ZNDFLG) > 0 : Kill ZNDFLG : Endif
  Global Integer ZNDFLG : ZNDFLG = 1
  If dim(ZIMPFLG) > 0 : Kill ZIMPFLG : Endif
  Global Integer ZIMPFLG : ZIMPFLG = 1
  If dim(ZSPLFLG) > 0 : Kill ZSPLFLG : Endif
  Global Integer ZSPLFLG : ZSPLFLG = 1
  Local Integer ZGWEBSERV : ZGWEBSERV = GWEBSERV
  Local Integer ZGIMPORT : ZGIMPORT = GIMPORT
  Local Char HEADER(250)
  Local Char ZPATH(250) : ZPATH = ""
  Local Char PATH1 : ZPATH = ""
  Local Char URL : URL = ""
  Local Char ZDISTPO(50)(0..)
  Local Integer ZDISTPOCNT : ZDISTPOCNT = 0
  Local Integer ZSPLCNT : ZSPLCNT = 0

  Call OUVRE_TRACE(mess(4,6004,1) + "-" + [M:YPOC0]YPOCNUM) From LECFIC

  For K = 0 To [M:YPOC1]NBLIG-1
   If [M:YPOC1]YLNVALIDATED(K) = 2 : Goto SKIPNEXT : Endif
   Call ZGETSPLCNT(K,ZSPLCNT)
   If ZSPLCNT = 1
    Call ZCALIMPTEMPLATE(K,0)
   Else
    If find([M:YPOC1]YPOHNUM(K),ZDISTPO) = 0
     ZDISTPO(ZDISTPOCNT) = [M:YPOC1]YPOHNUM(K)
     ZDISTPOCNT+=1
    Endif
   Endif
   Raz ZSPLCNT
   SKIPNEXT
  Next
#  Gosub IMPORT_POH

#infbox ZDISTPO
  For J = 0 To ZDISTPOCNT-1
   Raz ZPATH
   Call SET_FICNAM(PATH1,ZPATH,URL) From ORDSYS
   Openo ZPATH Using [FACS]
   HEADER = "E;"+ ZDISTPO(J)
   HEADER += ";" + [M:YPOC0]YBPS
   HEADER += chr$(13)
   Wrseq HEADER  Using [FACS]
   Openo Using [FACS]
   GWEBSERV = 1
   GIMPORT = 1
   ZNDFLG = 1

   Onerrgo $ZRESUME
   If dim(ZEXPDATIMPPATH)> 0 : Kill ZEXPDATIMPPATH : Endif
   Global Char ZEXPDATIMPPATH(250) : Raz ZEXPDATIMPPATH
   Call IMPORTSIL("YPOCPOH",ZPATH) From GIMPOBJ
   If dim(ZSTAT) < 0 : Local Integer ZSTAT : Endif :  ZSTAT = 0
   ##Call SYSTEME(adxmac(1),'ae_rm ' + ZPATH, "",ZSTAT) From ORDSYS
   ###########################################################################################
   ###########################################################################################
   Call ZUPMTLINK(ZDISTPO(J))
   If dim(ZEXPDATIMPPATH)> 0
    Call IMPORTSIL("ZSOH2",ZEXPDATIMPPATH) From GIMPOBJ
    If dim(ZSTAT) < 0 : Local Integer ZSTAT : Endif :  ZSTAT = 0
    ##Call SYSTEME(adxmac(1),'ae_rm ' + ZEXPDATIMPPATH, "",ZSTAT) From ORDSYS
	  Kill ZEXPDATIMPPATH
   Endif
   ###########################################################################################
   For H = 0 To [M:YPOC1]NBLIG-1
    If [M:YPOC1]YLNVALIDATED(H) = 2 : Goto SKIPNEXTH : Endif
    If [M:YPOC1]YPOHNUM(H) = ZDISTPO(J)
     Call ZCALIMPTEMPLATE(H,1)
    Endif
    SKIPNEXTH
   Next
   Onerrgo
   If ZERRCNT > 3
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE() From LECFIC
    If dim(ZNDFLG) > 0 : Kill ZNDFLG : Endif
    If dim(ZIMPFLG) > 0 : Kill ZIMPFLG : Endif
    If dim(ZSPLFLG) > 0 : Kill ZSPLFLG : Endif
    Return
   Endif
   GWEBSERV = ZGWEBSERV
   GIMPORT = ZGIMPORT
  Next

  Call FERME_TRACE From LECFIC
  Call LEC_TRACE() From LECFIC
  If dim(ZNDFLG) > 0 : Kill ZNDFLG : Endif
  If dim(ZIMPFLG) > 0 : Kill ZIMPFLG : Endif
  If dim(ZSPLFLG) > 0 : Kill ZSPLFLG : Endif

  Local Integer ZVALCNT : [L]ZVALCNT = 0
  For G = 0 To [M:YPOC1]NBLIG-1
   For [F:YPCD] Where [F:YPCD]YPOCNUM = [M:YPOC0]YPOCNUM & [F:YPCD]YPOCLIN = [M:YPOC1]YPOCLIN(G)
    [F:YPCD]YLNVALIDATED = [M:YPOC1]YLNVALIDATED(G)
    Rewrite [F:YPCD]
   Next
   If [M:YPOC1]YLNVALIDATED(G) = 2 : ZVALCNT+=1 : Endif
  Next

  If ZVALCNT = 0 : [M:YPOC0]YVALIDATED = 1 : Endif
  If ZVALCNT > 0 : [M:YPOC0]YVALIDATED = 2 : Endif
  If ZVALCNT = [M:YPOC1]NBLIG : [M:YPOC0]YVALIDATED = 3 : Endif

  For [F:YPCH] Where [F:YPCH]YPOCNUM = [M:YPOC0]YPOCNUM
   [F:YPCH]YVALIDATED = [M:YPOC0]YVALIDATED
   Rewrite [F:YPCH]
  Next
 Endif
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
Endif
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################

Return

##############################################################
$FILGAUCHE
 FILGAUSUP(0..1) = "[F:POH]POHFCY = '"+[M:YPOC0]YFCY+"' and [F:POH]BPSNUM = '"+[M:YPOC0]YBPS+"' and [F:POQ]LINCLEFLG <> 2"
Return

##############################################################
$SETBOUT
 Local Integer ZFLGCNT : ZFLGCNT = 0
 If !clalev([F:PRS]) : Local File PRICSTRUCT [F:PRS] : Endif
 Actzo [M:YPOC1]
 Actzo [M:YPOC0]YFCY
 Actzo [M:YPOC0]YBPS
 CHMEN += "Y"
 CHMEN += "A"
 For I = 0 To [M:YPOC1]NBLIG-1
  If [M:YPOC1]YLNVALIDATED(I) = 2
   Call VIREBOUT(CHAINE,"A") From GOBJET
   Diszo [M:YPOC1]
   Diszo [M:YPOC0]YFCY
   Diszo [M:YPOC0]YBPS
   ZFLGCNT+=1
  Endif
 Next

 If ZFLGCNT=[M:YPOC1]NBLIG & ZFLGCNT <> 0
  [M:YPOC0]YVALIDATED = 3
  Call VIREBOUT(CHAINE,"Y") From GOBJET
 Endif
 Affzo [M:YPOC0]YVALIDATED

 For [F:PRS] Where PLISTC = "" & BPCBPS = 2
  For I = 0 To 8
   If evalue("[F:PRS]LANDESSHO(" + num$(I) + ")") = ""
    Case I + 1
     When 1 : Chgfmt [M:YPOC1]YDISCRGAMT1 With "-K:10" : Diszo [M:YPOC1]YDISCRGAMT1
     When 2 : Chgfmt [M:YPOC1]YDISCRGAMT2 With "-K:10" : Diszo [M:YPOC1]YDISCRGAMT2
     When 3 : Chgfmt [M:YPOC1]YDISCRGAMT3 With "-K:10" : Diszo [M:YPOC1]YDISCRGAMT3
     When 4 : Chgfmt [M:YPOC1]YDISCRGAMT4 With "-K:10" : Diszo [M:YPOC1]YDISCRGAMT4
     When 5 : Chgfmt [M:YPOC1]YDISCRGAMT5 With "-K:10" : Diszo [M:YPOC1]YDISCRGAMT5
     When 6 : Chgfmt [M:YPOC1]YDISCRGAMT6 With "-K:10" : Diszo [M:YPOC1]YDISCRGAMT6
     When 7 : Chgfmt [M:YPOC1]YDISCRGAMT7 With "-K:10" : Diszo [M:YPOC1]YDISCRGAMT7
     When 8 : Chgfmt [M:YPOC1]YDISCRGAMT8 With "-K:10" : Diszo [M:YPOC1]YDISCRGAMT8
     When 9 : Chgfmt [M:YPOC1]YDISCRGAMT9 With "-K:10" : Diszo [M:YPOC1]YDISCRGAMT9
    Endcase
   Endif
  Next
 Next
 Close File [F:PRS]

#  ##########################JCH - 19/11/2019
#  Local Integer LCON1 : Raz LCON1
#  For I = 0 To [M:YPOC1]NBLIG -1
#    If [M:YPOC1]YCNFRCPDAT(I) <> [00/00/0000] Then
#      LCON1 += 1
#    Endif
#  Next
#  If LCON1 = [M:YPOC1]NBLIG Then
#    Call VIREBOUT(CHAINE,"Y") From GOBJET
#  Endif
#  ##########################JCH - 19/11/2019

Return

##############################################################
$RAZDUP
 Raz [M:YPOC0]YVALIDATED
 Raz [F:YPCH]YVALIDATED
 Raz [M:YPOC0]YPOCNUM
 Affzo [M:YPOC0]YVALIDATED
 Affzo [M:YPOC0]YPOCNUM
 Raz [M:YPOC1]YLNVALIDATED
 Affzo [M:YPOC1]YLNVALIDATED
Return

##############################################################
$DEPICK
If currbox = "GAU_CHE1"
Local Integer ZCNT : ZCNT = [M:YPOC1]NBLIG-1


 For I = 0 To [M:YPOC1]NBLIG-1
  If [M:YPOC1]YPOHNUM(I) = [F:POQ]POHNUM & [M:YPOC1]YPOPLIN(I) = [F:POQ]POPLIN
#infbox num$(I)
   Dela I,1,[M:YPOC1]NBLIG-1 [M:YPOC1]NBLIG
   [M:YPOC1]NBLIG-=1
   Affzo [M:YPOC1]NBLIG
   I = 0
  Endif
 Next
Affzo [M:YPOC1]
Endif
Return

##############################################################
$ABANDON
 #########################JCH - 19/11/2019
  Raz NUMPEDIDO, NLPEDIDO, PARCIALFLG
 #########################JCH - 19/11/2019
Return

##############################################################
$FIN
 #########################JCH - 19/11/2019
  Kill NUMPEDIDO, NLPEDIDO, PARCIALFLG, GYSOHDUPLI
 #########################JCH - 19/11/2019
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ZRESUME
 Call ECR_TRACE(errmes$(errn),1) From GESECRAN
 Call ECR_TRACE(errmes$(errm),1) From GESECRAN
 ZERRCNT+= 1
Resume

# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
##############################################################
$LANZA_VALIDACION
Local Char WDOCLOCK (20) (0..100), WSIMB (250)
Local Integer WNDOCLOCK
Local Integer K

  Local Integer ZOK
  ZOK = 1
  Call OUINON(mess(432,7773,1),ZOK) From GESECRAN
  If ZOK = 1 : Return : Endif

  If !clalev([F:YMLK]) : Local File MTOLINK [F:YMLK] : Endif

  For K = 0 To [M:YPOC1]NBLIG - 1
    # Compruebo los Pedidos de Compra de la línea de Confirmación
    If !find ([M:YPOC1]YPOHNUM(K), WDOCLOCK(0..100))
      WSIMB = "POH"+[M:YPOC1]YPOHNUM(K)
      Lock = WSIMB
      If fstat
        Call MESSAGE ("Pedido "- [M:YPOC1]YPOHNUM(K) -"Bloqueado") From GESECRAN
        Return
      Else
        WDOCLOCK (WNDOCLOCK) = WSIMB
        WNDOCLOCK += 1
      Endif
    Endif

    # Comprubeo los Pedidos de Venta linkados a cada línea de Confirmación
    For [F:YMLK]MLK0 Where DEMNUM = [M:YPOC1]YPOHNUM(K) and DEMLIN = [M:YPOC1]YPOPLIN(K)
      If !find ([F:YMLK]RESSNUM, WDOCLOCK(0..100))
        WSIMB = "SOH"+[F:YMLK]RESSNUM
        Lock = WSIMB
        If fstat
          Call MESSAGE ("Pedido "- [F:YMLK]RESSNUM -"Bloqueado") From GESECRAN
          Return
        Else
          WDOCLOCK (WNDOCLOCK) = WSIMB
          WNDOCLOCK += 1
        Endif
      Endif
    Next

    For [F:YMLK]MLK0 Where RESSNUM = [M:YPOC1]YPOHNUM(K) and RESSLIN = [M:YPOC1]YPOPLIN(K)
      If !find ([F:YMLK]DEMNUM, WDOCLOCK(0..100))
        WSIMB = "SOH"+[F:YMLK]DEMNUM
        Lock = WSIMB
        If fstat
          Call MESSAGE ("Pedido "- [F:YMLK]DEMNUM -"Bloqueado") From GESECRAN
          Return
        Else
          WDOCLOCK (WNDOCLOCK) = WSIMB
          WNDOCLOCK += 1
        Endif
      Endif
    Next
  Next

  Close File [F:YMLK]

  # desbloquea los pedidos de compra
  If !clalev([F:MLK9]) Then : Local File MTOLINK [F:MLK9] : Endif     # busca en la tabla MTOLINK pq es la que relaciona las líneas validadas
  For K = 0 To [M:YPOC1]NBLIG - 1
#Infbox num$(WDOCLOCK(K))
    Unlock = WDOCLOCK(K)
#Infbox "desbloqueo poh:"-num$(fstat)

    Filter [F:MLK9] Where RESSNUM = [M:YPOC1]YPOHNUM(K) and RESSLIN = [M:YPOC1]YPOPLIN(K)
    For [MLK9]
#Infbox num$([F:MLK9]DEMNUM)
      Unlock = "SOH"+[F:MLK9]DEMNUM
#Infbox num$(fstat)
    Next
    Filter [F:MLK9]
  Next
  If clalev([F:MLK9])  Then : Close Local File   [F:MLK9] : Endif

  # genera el fichero y lanza la importación silenciosa
  Gosub GENFICH

#  # desbloquea los pedidos de compra
#  For K = 0 To [M:YPOC1]NBLIG - 1
##Infbox num$(WDOCLOCK(K))
#    Unlock = WDOCLOCK(K)
##Infbox "desbloqueo poh:"-num$(fstat)
#  Next
#Infbox "antes UPD_EXTRCPDAT"
  # actualiza la fecha de confirmación directamente en la tabla PORDERQ
  Gosub UPD_EXTRCPDAT

#  # desbloquea los pedidos de compra
#  For K = 0 To [M:YPOC1]NBLIG - 1
##Infbox num$(WDOCLOCK(K))
#    Unlock = WDOCLOCK(K)
##Infbox "desbloqueo poh:"-num$(fstat)
#  Next
#Infbox "antes UPD_YCNFRCPDAT"
  # actualiza la fecha de confirmación directamente en la tabla SORDERQ
  Gosub UPD_YCNFRCPDAT

#  # desbloquea los pedidos de compra
#  For K = 0 To [M:YPOC1]NBLIG - 1
##Infbox num$(WDOCLOCK(K))
#    Unlock = WDOCLOCK(K)
##Infbox "desbloqueo poh:"-num$(fstat)
#  Next
#Infbox "antes UPD_VALIDATE"
  # actualiza los valores del campo validado para el pedido
  Gosub UPD_VALIDATE
#Infbox "despues UPD_VALIDATE"

Return

##############################################################
# genera el fichero y lanza la importación silenciosa
$GENFICH

Local Char    LDIRIMPORT(250) : LDIRIMPORT = filpath("IMPORT_EXPORT\CONFPOH","","")
Local Char    LFILE_W(200) : LFILE_W = "\ConfPOH"
Local Char    LDATCAB(100)(1..17)
Local Char    LFECHA(10), LHORA(10) : Raz LFECHA, LHORA
Local Char    LSEP(1) : LSEP = ";"  # separador
Local Integer LCON0   : Raz LCON0

  If !clalev([F:POQ1]) Then : Local File PORDERQ [F:POQ1] : Endif
  If !clalev([F:SOQ1]) Then : Local File SORDERQ [F:SOQ1] : Endif

  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

  LDIRIMPORT += "\"
  LFILE_W = LDIRIMPORT + LFILE_W + "_" + LFECHA + LHORA + ".txt"

#  mkstat = 0 : fstat = 0 : GERRTRACE = 0
  # si se lanza la tarea batch
  If !GSERVEUR Then
    Call TEMPON("Proceso confirmación pedidos de compra") From GESECRAN
    Call OUVRE_TRACE ("Proceso confirmación pedidos de compra") From LECFIC
  Endif

  # borramos el fichero si existe...
  If filinfo(LFILE_W, 7) > 0 Then
    System "ae_rm " + LFILE_W
  Endif

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W

  For LCON0 = 0 To [M:YPOC1]NBLIG -1
    # pedido de compra
#Infbox [M:YPOC1]YPOHNUM(LCON0)
#Infbox num$([M:YPOC1]YPOPLIN(LCON0))
#Infbox [M:YPOC1]YITMREF(LCON0)
#Infbox num$([M:YPOC1]YPRICE(LCON0))
#Infbox num$([M:YPOC1]YDISCRGAMT1(LCON0))
#Infbox num$([M:YPOC1]YDISCRGAMT2(LCON0))
#Infbox num$([M:YPOC1]YDISCRGAMT3(LCON0))
#Infbox num$([M:YPOC1]YDISCRGAMT4(LCON0))
#Infbox num$([M:YPOC1]YDISCRGAMT5(LCON0))
#Infbox num$([M:YPOC1]YDISCRGAMT6(LCON0))
#Infbox num$([M:YPOC1]YDISCRGAMT7(LCON0))
#Infbox num$([M:YPOC1]YDISCRGAMT8(LCON0))
#Infbox num$([M:YPOC1]YDISCRGAMT9(LCON0))
#Infbox [M:YPOC1]YPOCNUM(LCON0)
#Infbox [M:YPOC1]YPRHFCY(LCON0)
#Infbox num$([M:YPOC1]YSOLRCPDAT(LCON0))
    LDATCAB(1)  = [M:YPOC1]YPOHNUM(LCON0)                                     # nº pedido
    LDATCAB(2)  = num$([M:YPOC1]YPOPLIN(LCON0))                               # nº línea
    LDATCAB(3)  = [M:YPOC1]YITMREF(LCON0)                                     # artículo
    LDATCAB(4)  = num$([M:YPOC1]YQTY(LCON0))                                  # cantidad
    Case [M:YPOC1]YTIPPRI(LCON0)                                              # precio
      When 0, 1
        LDATCAB(5) = num$([M:YPOC1]YPRICE(LCON0))
      When 2
        LDATCAB(5) = num$([M:YPOC1]YPRICE(LCON0)*10)
      When 3
        LDATCAB(5) = num$([M:YPOC1]YPRICE(LCON0)*100)
      When 4
        LDATCAB(5) = num$([M:YPOC1]YPRICE(LCON0)*1000)
      When Default
        LDATCAB(5) = num$([M:YPOC1]YPRICE(LCON0))
    Endcase
    LDATCAB(6)  = num$([M:YPOC1]YDISCRGAMT1(LCON0))                           # dto1
    LDATCAB(7)  = num$([M:YPOC1]YDISCRGAMT2(LCON0))                           # dto2
    LDATCAB(8)  = num$([M:YPOC1]YDISCRGAMT3(LCON0))                           # dto3
    LDATCAB(9)  = num$([M:YPOC1]YDISCRGAMT4(LCON0))                           # dto4
    LDATCAB(10) = num$([M:YPOC1]YDISCRGAMT5(LCON0))                           # dto5
    LDATCAB(11) = num$([M:YPOC1]YDISCRGAMT6(LCON0))                           # dto6
    LDATCAB(12) = num$([M:YPOC1]YDISCRGAMT7(LCON0))                           # dto7
    LDATCAB(13) = num$([M:YPOC1]YDISCRGAMT8(LCON0))                           # dto8
    LDATCAB(14) = num$([M:YPOC1]YDISCRGAMT9(LCON0))                           # dto9
    LDATCAB(15) = [M:YPOC1]YPOCNUM(LCON0)                                     # nº confirmación
    LDATCAB(16) = [M:YPOC1]YPRHFCY(LCON0)                                     # planta recepción
    LDATCAB(17) = num$([M:YPOC1]YSOLRCPDAT(LCON0))                            # fecha recepción solicitada

    Wrseq "E" + LSEP + LDATCAB(1)  Using [ZIMP_W]
    Wrseq "L" + LSEP + LDATCAB(2) + LSEP + LDATCAB(3) + LSEP + LDATCAB(4) + LSEP + LDATCAB(5) +
&   LSEP + LDATCAB(6) + LSEP + LDATCAB(7) + LSEP + LDATCAB(8) + LSEP + LDATCAB(9) + LSEP + LDATCAB(10) + LSEP + LDATCAB(11) +
&   LSEP + LDATCAB(12) + LSEP + LDATCAB(13) + LSEP + LDATCAB(14) + LSEP + LDATCAB(15) + LSEP + LDATCAB(16) + LSEP + LDATCAB(17) Using [ZIMP_W]

    # modifica el estado de la línea a validado
    [M:YPOC1]YLNVALIDATED(LCON0) = 2
    Affzo [M:YPOC1]YLNVALIDATED(LCON0)
  Next

  Gosub CLOSE_FILE_W
#Infbox LFILE_W
  Call IMPORTSIL("YPOHC",LFILE_W) From GIMPOBJ
#Infbox "después de importsil"
  If !GSERVEUR Then
    Call TEMPOFF() From GESECRAN
    # fin de traza
    Call ECR_TRACE("Fichero " + ctrans(LFILE_W,"\","/") + " generado", 0) From GESECRAN
    Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
    Call FERME_TRACE From LECFIC

#    mkstat = 0 : fstat = 0 : GERRTRACE = 0 : GOK = 1
  Endif

  If clalev([F:POQ1])  Then : Close Local File [F:POQ1] : Endif
  If clalev([F:SOQ1])  Then : Close Local File [F:SOQ1] : Endif

Return

########################################################
$OPEN_FILE_W

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_W Using [ZIMP_W]

Return

########################################################
$CLOSE_FILE_W

Openo Using [ZIMP_W]

Return

Return

##############################################################
# actualiza la fecha de confirmación directamente en la tabla PORDERQ
$UPD_EXTRCPDAT
  If !clalev([F:POQ2]) Then : Local File PORDERQ  [F:POQ2] : Endif
  If !clalev([F:POH2]) Then : Local File PORDER   [F:POH2] : Endif
  If !clalev([F:FCY2]) Then : Local File FACILITY [F:FCY2] : Endif
    For K = 0 To [M:YPOC1]NBLIG-1
      Filter [F:POQ2] Where POHNUM = [M:YPOC1]YPOHNUM(K) and POPLIN = [M:YPOC1]YPOPLIN(K)
      Read   [F:POQ2] First
      If !fstat Then
        Trbegin [F:POQ2]
        [F:POQ2]YANTRCPDAT  = [F:POQ2]EXTRCPDAT
        [F:POQ2]EXTRCPDAT   = [M:YPOC1]YCNFRCPDAT(K)
        [F:POQ2]YRCPDAT   = 2
        Rewrite [F:POQ2]
        If !fstat Then
          Commit
          ############## ejecuta la acción 'Después de campo' en EXTRCPDAT (inicio)
          LVALEUR = [M:YPOC1]YCNFRCPDAT(I)
          Read [F:FCY2]FCY0 = [F:POQ2]PRHFCY
          If !fstat Then
            If [F:POQ2]RETQTYSTU=0 & [F:POQ2]SOHNUM="" & LVALEUR<[F:POQ2]RETRCPDAT
              If [F:FCY2]FCY<>[F:POQ2]PRHFCY
                Read [FCY2]FCY0=[F:POQ2]PRHFCY : If fstat Raz [F:FCY2] : Endif
              Endif
              Call CTL_JOU2(LVALEUR,[F:POQ2]ORDDAT,[F:FCY2]UVYDAY,[F:FCY2]UVYCOD,0) From CONTX3
              Raz mkstat, GMESSAGE
            Endif
          Endif
          Read [F:POH2]POH0 = [F:POQ2]POHNUM
          If !fstat Then
            If [F:POH2]BETFCY=2 & [F:POH2]SALFCY<>"" Then
              Call C_SHIDAT(LVALEUR,[F:POH2]BPCORD,[F:POH2]RCPFCY,[F:POH2]STOFCY,[F:POH2]ORDDAT) From TRTVENISOC
              If mkstat End : Endif
            Endif
          Endif
          ############## ejecuta la acción 'Después de campo' en EXTRCPDAT (fin)
        Else
          Rollback
        Endif
      Endif
      Filter [F:POQ2]
    Next
  Close Local File [F:POQ2],[F:POH2],[F:FCY2]

Return

##############################################################
# actualiza la fecha de confirmación directamente en la tabla SORDERQ
$UPD_YCNFRCPDAT
Local Integer I : Raz I
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
Local Integer NUMASIG : Raz NUMASIG
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################

  For I = 0 To [M:YPOC1]NBLIG-1
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
#    If [M:YPOC1]YPARCIALFLG(I) = 2 Then
#      If !clalev([F:MLK0]) Then : Local File MTOLINK [F:MLK0] : Endif     # busca en la tabla MTOLINK pq es la que relaciona las líneas validadas
#      Filter [F:MLK0] Where RESSNUM = [M:YPOC1]YPOHNUM(I)
#      Read   [F:MLK0] First
#      If !fstat Then
    If !clalev([F:MLK0]) Then : Local File MTOLINK [F:MLK0] : Endif     # busca en la tabla MTOLINK pq es la que relaciona las líneas validadas
    If [M:YPOC1]YDUPLIFLG(I) <> 2 Then                                  # sólo actualiza la fecha cuando no es una línea duplicada
#Infbox "POHNUM2:"-num$([M:YPOC1]YPOHNUM(I))
#Infbox "POPLIN2:"-num$([M:YPOC1]YPOPLIN(I))
      Filter [F:MLK0] Where RESSNUM = [M:YPOC1]YPOHNUM(I) and RESSLIN = [M:YPOC1]YPOPLIN(I)
      NUMASIG = rowcount([F:MLK0])
If GUSER = "AIT07" Then
  Infbox num$(NUMASIG)
Endif
      For [MLK0]
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
        If !clalev([F:SOQ1]) Then : Local File SORDERQ [F:SOQ1] : Endif
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
#Infbox "DEMNUM:"-num$([F:MLK0]DEMNUM)
#Infbox "DEMLIN:"-num$([F:MLK0]DEMLIN)
#        Filter [F:SOQ1] Where SOHNUM = [F:MLK0]DEMNUM
        Filter [F:SOQ1] Where SOHNUM = [F:MLK0]DEMNUM and SOPLIN = [F:MLK0]DEMLIN
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
        Read   [F:SOQ1] First
        If !fstat Then
          Trbegin [F:SOQ1]
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
#          [F:SOQ1]YCONFIRMADAT = [01/01/2199]
          If [M:YPOC1]YPARCIALFLG(I) = 2 Then
            [F:SOQ1]YCONFIRMADAT = [01/01/2199]
          Else
            If !clalev([F:POQ1]) Then : Local File PORDERQ [F:POQ1] : Endif
            Filter [F:POQ1] Where POHNUM = [F:MLK0]RESSNUM and POPLIN = [F:MLK0]RESSLIN and POQSEQ = [F:MLK0]RESSSEQ
            Read [F:POQ1] First
            If !fstat Then
              [F:SOQ1]YCONFIRMADAT = [F:POQ1]EXTRCPDAT
            Endif
            # desbloquea el pedido de venta asociado
            Unlock = "SOH"+[F:SOQ1]SOHNUM
            Filter [F:POQ1]
            If clalev([F:SOQ1])  Then : Close Local File   [F:SOQ1] : Endif
          Endif
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
          Rewrite [F:SOQ1]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
        Endif
        Filter [F:SOQ1]
        If clalev([F:SOQ1])  Then : Close Local File   [F:SOQ1] : Endif
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
      Next
#      Endif
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
      Filter [F:MLK0]
      If clalev([F:MLK0])  Then : Close Local File   [F:MLK0] : Endif
    Endif
  Next

Kill I

Return

# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
##############################################################
# actualiza los valores del campo validado para el pedido
$UPD_VALIDATE
  Local Integer ZVALCNT : [L]ZVALCNT = 0
  For G = 0 To [M:YPOC1]NBLIG-1
   For [F:YPCD] Where [F:YPCD]YPOCNUM = [M:YPOC0]YPOCNUM & [F:YPCD]YPOCLIN = [M:YPOC1]YPOCLIN(G)
    [F:YPCD]YLNVALIDATED = [M:YPOC1]YLNVALIDATED(G)
    Rewrite [F:YPCD]
   Next
   If [M:YPOC1]YLNVALIDATED(G) = 2 : ZVALCNT+=1 : Endif
  Next

  If ZVALCNT = 0 : [M:YPOC0]YVALIDATED = 1 : Endif
  If ZVALCNT > 0 : [M:YPOC0]YVALIDATED = 2 : Endif
  If ZVALCNT = [M:YPOC1]NBLIG : [M:YPOC0]YVALIDATED = 3 : Endif

  For [F:YPCH] Where [F:YPCH]YPOCNUM = [M:YPOC0]YPOCNUM
   [F:YPCH]YVALIDATED = [M:YPOC0]YVALIDATED
   Rewrite [F:YPCH]
  Next

Return
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################
Subprog AM_YPOPLIN(VALEUR)
Variable Decimal VALEUR

Local Integer ZPOQOPENEDHERE : ZPOQOPENEDHERE = 0
Local Integer ZPOPOPENEDHERE : ZPOPOPENEDHERE = 0

If !clalev([F:ZPOQ]) : Local File PORDERQ [F:ZPOQ] : ZPOQOPENEDHERE = 1 : Endif
If !clalev([F:ZPOP]) : Local File PORDERP [F:ZPOP] : ZPOPOPENEDHERE = 1 : Endif


For [F:ZPOQ] Where [F:ZPOQ]POHNUM = [M:YPOC1]YPOHNUM(nolign-1) and [F:ZPOQ]POPLIN = VALEUR
 [M:YPOC1]YITMREF(nolign-1) = [F:ZPOQ]ITMREF
 #[M:YPOC1]YQTY(nolign-1) = [F:ZPOQ]QTYPUU
 [M:YPOC1]YCNFRCPDAT(nolign-1) = [F:ZPOQ]EXTRCPDAT

 Affzo [M:YPOC1]YPRICE(nolign-1)
 Affzo [M:YPOC1]YITMREF(nolign-1)
 Affzo [M:YPOC1]YQTY(nolign-1)
 Affzo [M:YPOC1]YCNFRCPDAT(nolign-1)
Next

For [F:ZPOP] Where [F:ZPOP]POHNUM = [M:YPOC1]YPOHNUM(nolign-1) and [F:ZPOP]POPLIN = VALEUR
 [M:YPOC1]YTIPPRI(nolign-1)     = [F:ZPOP]YTIPPRI
 [M:YPOC1]YPRICE(nolign-1)      = [F:ZPOP]GROPRI
 [M:YPOC1]YDISCRGAMT1(nolign-1) = [F:ZPOP]DISCRGVAL1
 [M:YPOC1]YDISCRGAMT2(nolign-1) = [F:ZPOP]DISCRGVAL2
 [M:YPOC1]YDISCRGAMT3(nolign-1) = [F:ZPOP]DISCRGVAL3
 [M:YPOC1]YDISCRGAMT4(nolign-1) = [F:ZPOP]DISCRGVAL4
 [M:YPOC1]YDISCRGAMT5(nolign-1) = [F:ZPOP]DISCRGVAL5
 [M:YPOC1]YDISCRGAMT6(nolign-1) = [F:ZPOP]DISCRGVAL6
 [M:YPOC1]YDISCRGAMT7(nolign-1) = [F:ZPOP]DISCRGVAL7
 [M:YPOC1]YDISCRGAMT8(nolign-1) = [F:ZPOP]DISCRGVAL8
 [M:YPOC1]YDISCRGAMT9(nolign-1) = [F:ZPOP]DISCRGVAL9
 [M:YPOC1]YPRHFCY(nolign-1)     = [F:ZPOP]PRHFCY
 Affzo [M:YPOC1]YPRICE(nolign-1)
 Affzo [M:YPOC1]YDISCRGAMT1(nolign-1)
 Affzo [M:YPOC1]YDISCRGAMT2(nolign-1)
 Affzo [M:YPOC1]YDISCRGAMT3(nolign-1)
 Affzo [M:YPOC1]YDISCRGAMT4(nolign-1)
 Affzo [M:YPOC1]YDISCRGAMT5(nolign-1)
 Affzo [M:YPOC1]YDISCRGAMT6(nolign-1)
 Affzo [M:YPOC1]YDISCRGAMT7(nolign-1)
 Affzo [M:YPOC1]YDISCRGAMT8(nolign-1)
 Affzo [M:YPOC1]YDISCRGAMT9(nolign-1)
 Affzo [M:YPOC1]YPRHFCY(nolign-1)
Next

If ZPOQOPENEDHERE = 1 : Close File [F:ZPOQ] : Endif
If ZPOPOPENEDHERE = 1 : Close File [F:ZPOP] : Endif
End

##############################################################
Subprog C_YPOPLIN(VALEUR)
Variable Decimal VALEUR

Local Decimal ZQTY
Local Integer ZPOQFLG : ZPOQFLG = 0
Local Integer ZPOQOPENEDHERE :  ZPOQOPENEDHERE = 0
If !clalev([F:ZPOQ]) : Local File PORDERQ [F:ZPOQ] : ZPOQOPENEDHERE = 1 : Endif
For [F:ZPOQ] Where [F:ZPOQ]POHNUM = [M:YPOC1]YPOHNUM(nolign-1) and [F:ZPOQ]POPLIN = VALEUR
 ZPOQFLG = 1
 ZQTY = [F:ZPOQ]QTYPUU
 For I = 0 To [M:YPOC1]NBLIG - 1
  If [M:YPOC1]YPOHNUM(I) = [M:YPOC1]YPOHNUM(nolign-1) and [M:YPOC1]YPOPLIN(I) = VALEUR and I <> (nolign-1)
   If (ZQTY-[M:YPOC1]YQTY(I) > 0)
    ZQTY = ZQTY - [M:YPOC1]YQTY(I)
   Else
  ZQTY = 0
#    Wrnbox [M:YPOC1]YPOHNUM(nolign-1) + " " + [F:ZPOQ]ITMREF + " - " + mess(201, 194, 1) [Titled "Warning"] Using [L]REP
    Local Integer OK
  OK=2 : Call AVERTIR([M:YPOC1]YPOHNUM(nolign-1) + " " + [F:ZPOQ]ITMREF + " - " + mess(201, 194, 1),OK) From GESECRAN
    If OK=1 : mkstat=2 : Break : Endif
   Endif
  Endif
 Next
 [M:YPOC1]YQTY(nolign-1) = ZQTY
Next
If ZPOQFLG = 0 : GMESSAGE = mess(1,6004,1) : GERR = 1 : mkstat = 2 : Endif
If ZPOQOPENEDHERE = 1 : Close File [F:ZPOQ] : Endif
End

##############################################################
Subprog C_YQTY(VALEUR)
Variable Decimal VALEUR

If [M:YPOC1]YQTY(nolign-1) = 0 & VALEUR > 0
 #Local Integer REP
 #Wrnbox mess(200, 194, 1) [Titled "Warning"] Using [L]REP
 #If [L]REP <> 1 : mkstat = 2 : Endif
 Local Integer OK
 OK=2 : Call AVERTIR(mess(200, 194, 1),OK) From GESECRAN
 If OK=1 : mkstat=2 : Endif
Endif
End

##############################################################
Subprog AS_NBLIG
 If [M:YPOC0]YVALIDATED = 3
  Errbox mess(28,199,1) - "-" -mess(3,6005,1)
 Elsif [M:YPOC0]YVALIDATED = 2
 Errbox mess(28,199,1) - "-" -mess(2,6005,1)
 Endif
End

##############################################################
## Después de modificar el campo 'Cantidad'
##############################################################
Subprog AM_YQTY(VALEUR)
Variable Decimal VALEUR

  ##########################JCH - 19/11/2019
Local Integer OKCAN   : OKCAN = 2 # Ok
Local Decimal INIQTY  : Raz INIQTY
Local Integer NUMLIN  : Raz NUMLIN
Local Char    MSG(250): Raz MSG
  MSG += "Cantidad confirmada inferior a la pedida.\"
  MSG += "Se va a generar una nueva línea con la cantidad restante.\"
  MSG += "Recuerde modificar la fecha de recepción confirmada en caso de ser necesario."
  Call AVERTIR(MSG,OKCAN) From GESECRAN
  If OKCAN = 2 Then

    # obtención del siguiente número de línea para ese pedido
    If NUMPEDIDO = "" or NUMPEDIDO <> [M:YPOC1]YPOHNUM(nolign-1) Then
      NUMPEDIDO = [M:YPOC1]YPOHNUM(nolign-1)
      If !clalev([F:POQ1])  Then : Local File PORDERQ [F:POQ1] : Endif
      Filter [F:POQ1] Where POHNUM = NUMPEDIDO Order By POPLIN Desc
      Read [F:POQ1] First
      If !fstat Then
        NLPEDIDO  = [F:POQ1]POPLIN + 1000
      Endif
      Filter [F:POQ1]
      If clalev([F:POQ1])   Then : Close Local File  [F:POQ1] : Endif
    Else
      NLPEDIDO += 1000
    Endif

    # asignación de los campos
    INIQTY = [M:YPOC1]YQTY(nolign-1)
    NUMLIN = [M:YPOC1]NBLIG + 1
    [M:YPOC1]YPOCNUM(NBLIG)         = [M:YPOC1]YPOCNUM(nolign-1)
    [M:YPOC1]YPOHNUM(NBLIG)         = [M:YPOC1]YPOHNUM(nolign-1)
    [M:YPOC1]YPOPLIN(NBLIG)         = NLPEDIDO
    [M:YPOC1]YITMREF(NBLIG)         = [M:YPOC1]YITMREF(nolign-1)
    [M:YPOC1]YQTY(NBLIG)            = INIQTY - VALEUR
    [M:YPOC1]YTIPPRI(NBLIG)         = [M:YPOC1]YTIPPRI(nolign-1)
    [M:YPOC1]YPRICE(NBLIG)          = [M:YPOC1]YPRICE(nolign-1)
    [M:YPOC1]YDISCRGAMT1(NBLIG)     = [M:YPOC1]YDISCRGAMT1(nolign-1)
    [M:YPOC1]YDISCRGAMT2(NBLIG)     = [M:YPOC1]YDISCRGAMT2(nolign-1)
    [M:YPOC1]YDISCRGAMT3(NBLIG)     = [M:YPOC1]YDISCRGAMT3(nolign-1)
    [M:YPOC1]YDISCRGAMT4(NBLIG)     = [M:YPOC1]YDISCRGAMT4(nolign-1)
    [M:YPOC1]YDISCRGAMT5(NBLIG)     = [M:YPOC1]YDISCRGAMT5(nolign-1)
    [M:YPOC1]YDISCRGAMT6(NBLIG)     = [M:YPOC1]YDISCRGAMT6(nolign-1)
    [M:YPOC1]YDISCRGAMT7(NBLIG)     = [M:YPOC1]YDISCRGAMT7(nolign-1)
    [M:YPOC1]YDISCRGAMT8(NBLIG)     = [M:YPOC1]YDISCRGAMT8(nolign-1)
    [M:YPOC1]YDISCRGAMT9(NBLIG)     = [M:YPOC1]YDISCRGAMT9(nolign-1)
    [M:YPOC1]YPRHFCY(NBLIG)         = [M:YPOC1]YPRHFCY(nolign-1)
    [M:YPOC1]YCNFRCPDAT(NBLIG)      = [M:YPOC1]YCNFRCPDAT(nolign-1)
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
    [M:YPOC1]YSOLRCPDAT(NBLIG)      = [M:YPOC1]YSOLRCPDAT(nolign-1)
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
    [M:YPOC1]YPOCLIN(NBLIG)         = NLPEDIDO
    [M:YPOC1]UPDFLG(NBLIG)          = 3
    [M:YPOC1]YLNVALIDATED(NBLIG)    = [M:YPOC1]YLNVALIDATED(nolign-1)
    [M:YPOC1]YPOCLIN(nolign-1)      = [M:YPOC1]YPOCLIN(nolign-1)
    [M:YPOC1]UPDFLG(nolign-1)       = 3
    [M:YPOC1]YQTY(nolign-1)         = VALEUR
    [M:YPOC1]NBLIG                  = NUMLIN
    [M:YPOC1]YPARCIALFLG(nolign-1)  = 2                                                    # control del cambio producido para asignar fecha de confirmación diferente
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
#    [M:YPOC1]YPARCIALFLG(NBLIG)     = 2                                                    # control del cambio producido para asignar fecha de confirmación diferente
    [M:YPOC1]YPARCIALFLG(NBLIG-1)   = 2                                                    # control del cambio producido para asignar fecha de confirmación diferente
    [M:YPOC1]YDUPLIFLG(NBLIG-1)     = 2                                                    # indica que esta línea es la duplicada
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
  Else
    VALEUR = [M:YPOC1]YQTY(nolign-1)
  Endif
  Affzo [M:YPOC1]5
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################

  Local Integer LCON1 : Raz LCON1

  While GYSOHDUPLI(LCON1) <> ""
    LCON1 += 1
  Wend
  GYSOHDUPLI(LCON1) = NUMPEDIDO
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
  ##########################JCH - 19/11/2019

End


