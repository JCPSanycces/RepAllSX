##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################
##  Logic to update MT link
##############################################################
Subprog ZUPMTLINK(ZPHNM)
Value Char ZPHNM()

Local Integer ZMLKOPENEDHERE : ZMLKOPENEDHERE = 0
Local Integer ZZSOQOPENEDHERE : ZZSOQOPENEDHERE = 0
Local Integer ZORDOPENEDHERE : ZORDOPENEDHERE = 0
If !clalev([F:MLK]) : Local File MTOLINK [F:MLK] : ZMLKOPENEDHERE = 1 : Endif
If !clalev([F:ZORD]) : Local File ORDERS [F:ZORD] : ZORDOPENEDHERE = 1 :Endif
If !clalev([F:ZSOQ]) : Local File SORDERQ [F:ZSOQ] : ZZSOQOPENEDHERE = 1 : Endif

If dim(ZGPATH) > 0
ZPATH = ZGPATH
Else
Local Char ZPATH (250)
Endif
#------------------------------------------Call the import template----------------------------------#
If ZPATH <> ""
 GWEBSERV = 1
 Call IMPORTSIL("ZSOH1",ZPATH) From GIMPOBJ
 If dim(ZSTAT) < 0 : Local Integer ZSTAT : Endif :  ZSTAT = 0
 ##Call SYSTEME(adxmac(1),'ae_rm ' + ZPATH, "",ZSTAT) From ORDSYS
 GWEBSERV = 0
 ZPATH = ""
Endif
#------------------------------------------Call the import template----------------------------------#

#------------------------------------------Deallocate SO line----------------------------------------#
For [F:ZSOQ] Where [F:ZSOQ]ZPOHNUM = ZPHNM
  ZORDR = [F:ZSOQ]SOHNUM
  ZORDCPY = [F:ZSOQ]CPY
  ZORDFCY = [F:ZSOQ]STOFCY
  ZORDLINE = [F:ZSOQ]SOPLIN
  ZORDQTY  = [F:ZSOQ]QTY
  Gosub EXEC From ZDEALLOC
Next
#------------------------------------------Deallocate SO line----------------------------------------#

#------------------------------------------Create MTOLINK record-------------------------------------#
For [F:MLK] Where RESSNUM = ZPHNM
 For [F:ZORD] Where [F:ZORD]VCRNUM = [F:MLK]DEMNUM and [F:ZORD]VCRLIN = [F:MLK]DEMLIN
  If [F:ZORD]MTOQTY <> 0 : [F:ZORD]MTOQTY = [F:ZORD]MTOQTY - [F:MLK]LIKQTY : Endif
  Rewrite [F:ZORD]
 Next
 For [F:ZORD] Where [F:ZORD]VCRNUM = ZPHNM and [F:ZORD]VCRLIN = [F:MLK]RESSLIN
  If [F:ZORD]MTOQTY <> 0 : [F:ZORD]MTOQTY = [F:ZORD]MTOQTY - [F:MLK]LIKQTY : Endif
  Rewrite [F:ZORD]
 Next
Next
Delete [F:MLK] Where RESSNUM = ZPHNM
Filter [F:ZSOQ]
For [F:ZSOQ] Where [F:ZSOQ]ZPOHNUM = ZPHNM
 Read [F:MLK]MLK0 = [F:ZSOQ]STOFCY;[F:ZSOQ]ITMREF;2;[F:ZSOQ]SOHNUM;[F:ZSOQ]SOPLIN;[F:ZSOQ]SOPLIN
 If fstat
  [F:MLK]STOFCY = [F:ZSOQ]STOFCY
  [F:MLK]DEMLIN = [F:ZSOQ]SOPLIN
  [F:MLK]DEMNUM = [F:ZSOQ]SOHNUM
  [F:MLK]DEMSEQ = [F:ZSOQ]SOPLIN
  [F:MLK]DEMTYP = 2
  [F:MLK]DWIPSTA = 1
  [F:MLK]DWIPTYP = 1
  [F:MLK]EXPNUM = 33
  [F:MLK]FMIFLG = 1
  [F:MLK]FRCFLG = 1
  [F:MLK]ITMREF = [F:ZSOQ]ITMREF
  [F:MLK]LIKQTY = [F:ZSOQ]QTYSTU
  [F:MLK]RESSLIN = [F:ZSOQ]ZPOHLIN
  [F:MLK]RESSNUM = [F:ZSOQ]ZPOHNUM

  For [F:POQ] Where [F:POQ]POHNUM = ZPHNM & [F:POQ]POPLIN = [F:ZSOQ]ZPOHLIN
   [F:MLK]RESSSEQ = [F:POQ]POQSEQ
   Break
  Next
  [F:MLK]RESSTYP = 14
  [F:MLK]RWIPSTA = 1
  [F:MLK]RWIPTYP = 2
  Write [F:MLK]
 Endif
Next
#------------------------------------------Create MTOLINK record-------------------------------------#

#----------------------------------------Update Orders data------------------------------------------#
For [F:ZSOQ] Where [F:ZSOQ]ZPOHNUM = ZPHNM
 For [F:ZORD] Where [F:ZORD]VCRNUM = [F:ZSOQ]SOHNUM and [F:ZORD]VCRLIN = [F:ZSOQ]SOPLIN
  [F:ZORD]MTOQTY = [F:MLK]LIKQTY   #[F:ZORD]EXTQTY
  Rewrite [F:ZORD]
 Next
 For [F:ZORD] Where [F:ZORD]VCRNUM = [F:ZSOQ]ZPOHNUM and [F:ZORD]VCRLIN = [F:ZSOQ]ZPOHLIN
  [F:ZORD]MTOQTY = [F:MLK]LIKQTY   #[F:ZORD]EXTQTY
  Rewrite [F:ZORD]
 Next
Next

#----------------------------------------Update Orders data------------------------------------------#
If ZMLKOPENEDHERE = 1 : Close File [F:MLK] : Endif
If ZZSOQOPENEDHERE = 1 : Close File [F:ZSOQ] : Endif
If ZORDOPENEDHERE = 1 : Close File [F:ZORD] : Endif
End

##############################################################
Subprog ZCALIMPTEMPLATE(ZNOL,ZGROUPDFLG)
Value Integer ZNOL
Value Integer ZGROUPDFLG                                      ## Gross Price Update Flag

Local Char ZPATH(250) : Raz ZPATH
Local Char PATH1(250) : Raz PATH1
Local Char URL(250) : Raz URL
Local Char HEADER(250) : Raz HEADER
Local Char DETAIL(250) : Raz DETAIL
Local Integer ZPOQOPENEDHERE : ZPOQOPENEDHERE = 1
Local Integer ZPOPLIN : ZPOPLIN  = 0
If !clalev([F:ZPOQ]) : Local File PORDERQ [F:ZPOQ] : ZPOQOPENEDHERE = 1 : Endif
Local Char ZOLDYPOC : ZOLDYPOC = ""

GIMPORT = 1
If dim(ZNDFLG) > 0 : ZNDFLG = 0 : Endif
If dim(ZSPLFLG) > 0 : ZSPLFLG = 0 : Endif
If ZGROUPDFLG = 1
 Filter [F:ZPOQ]
 For [F:ZPOQ] Where [F:ZPOQ]POHNUM = [M:YPOC1]YPOHNUM(ZNOL) & [F:ZPOQ]YPOCLIN = [M:YPOC1]YPOCLIN(ZNOL) & [F:ZPOQ]YPOCNUM = [M:YPOC0]YPOCNUM
  ZPOPLIN = [F:ZPOQ]POPLIN
 Next
Else
 For [F:ZPOQ] Where [F:ZPOQ]POHNUM = [M:YPOC1]YPOHNUM(ZNOL) & [F:ZPOQ]POPLIN = [M:YPOC1]YPOPLIN(ZNOL)
  ZOLDYPOC = [F:ZPOQ]YPOCNUM
 Next
Endif
Call SET_FICNAM(PATH1,ZPATH,URL) From ORDSYS
Openo ZPATH Using [FACS]
HEADER = "E;"+ [M:YPOC1]YPOHNUM(ZNOL)
HEADER += chr$(13)
Wrseq HEADER  Using [FACS]

DETAIL = "L;"+ [M:YPOC1]YITMREF(ZNOL)
If ZGROUPDFLG = 1
 DETAIL += ";" + num$(ZPOPLIN)
Else
 DETAIL += ";" + num$([M:YPOC1]YPOPLIN(ZNOL))
Endif
DETAIL += ";" + num$([M:YPOC1]YQTY(ZNOL))
##########################JCH - 19/11/2019
If PARCIALFLG <> 2 Then
  DETAIL += ";" + [M:YPOC1]YCNFRCPDAT(ZNOL)
Else
  DETAIL += ";21990101"
Endif
##########################JCH - 19/11/2019
Case [M:YPOC1]YTIPPRI (ZNOL)
  When 0, 1
    DETAIL += ";" + num$([M:YPOC1]YPRICE(ZNOL))
  When 2
    DETAIL += ";" + num$([M:YPOC1]YPRICE(ZNOL)*10)
  When 3
    DETAIL += ";" + num$([M:YPOC1]YPRICE(ZNOL)*100)
  When 4
    DETAIL += ";" + num$([M:YPOC1]YPRICE(ZNOL)*1000)
  When Default
    DETAIL += ";" + num$([M:YPOC1]YPRICE(ZNOL))
Endcase

DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT1(ZNOL))
DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT2(ZNOL))
DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT3(ZNOL))
DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT4(ZNOL))
DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT5(ZNOL))
DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT6(ZNOL))
DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT7(ZNOL))
DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT8(ZNOL))
DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT9(ZNOL))
DETAIL += ";" + [M:YPOC0]YPOCNUM
DETAIL += ";" + [M:YPOC1]YPRHFCY(ZNOL)
DETAIL += ";" + [M:YPOC1]YCNFRCPDAT(ZNOL)

DETAIL += chr$(13)
Wrseq DETAIL  Using [FACS]

###########################JCH - 19/11/2019
#  If INIQTY(ZNOL) <> 0 Then
#    DETAIL = "L;"+ [M:YPOC1]YITMREF(ZNOL)
#    If ZGROUPDFLG = 1
#     DETAIL += ";" + num$(ZPOPLIN)
#    Else
#     DETAIL += ";" + num$([M:YPOC1]YPOPLIN(ZNOL) + ZNOL +1)
#    Endif
#    DETAIL += ";" + num$(INIQTY(ZNOL) - [M:YPOC1]YQTY(ZNOL))
#    DETAIL += ";" + [M:YPOC1]YCNFRCPDAT(ZNOL)
#    Case [M:YPOC1]YTIPPRI (ZNOL)
#      When 0, 1
#        DETAIL += ";" + num$([M:YPOC1]YPRICE(ZNOL))
#      When 2
#        DETAIL += ";" + num$([M:YPOC1]YPRICE(ZNOL)*10)
#      When 3
#        DETAIL += ";" + num$([M:YPOC1]YPRICE(ZNOL)*100)
#      When 4
#        DETAIL += ";" + num$([M:YPOC1]YPRICE(ZNOL)*1000)
#      When Default
#        DETAIL += ";" + num$([M:YPOC1]YPRICE(ZNOL))
#    Endcase
#
#    DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT1(ZNOL))
#    DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT2(ZNOL))
#    DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT3(ZNOL))
#    DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT4(ZNOL))
#    DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT5(ZNOL))
#    DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT6(ZNOL))
#    DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT7(ZNOL))
#    DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT8(ZNOL))
#    DETAIL += ";" + num$([M:YPOC1]YDISCRGAMT9(ZNOL))
#    DETAIL += ";" + [M:YPOC0]YPOCNUM
#
#    DETAIL += chr$(13)
#    Wrseq DETAIL  Using [FACS]
#  Endif
###########################JCH - 19/11/2019

Openo Using [FACS]
If dim(ZEXPDATIMPPATH)> 0 : Kill ZEXPDATIMPPATH : Endif
Global Char ZEXPDATIMPPATH(250) : ZEXPDATIMPPATH = ""
Call IMPORTSIL("YPOH1",ZPATH) From GIMPOBJ
If dim(ZSTAT) < 0 : Local Integer ZSTAT : Endif :  ZSTAT = 0
##Call SYSTEME(adxmac(1),'ae_rm ' + ZPATH, "",ZSTAT) From ORDSYS
If dim(ZSYMBOLE2) = 1 :  Unlock = ZSYMBOLE2 : Endif
If dim(ZEXPDATIMPPATH)> 0
 Call IMPORTSIL("ZSOH2",ZEXPDATIMPPATH) From GIMPOBJ
 If dim(ZSTAT) < 0 : Local Integer ZSTAT : Endif :  ZSTAT = 0
## Call SYSTEME(adxmac(1),'ae_rm ' + ZEXPDATIMPPATH, "",ZSTAT) From ORDSYS
 Kill ZEXPDATIMPPATH
Endif
Filter [F:ZPOQ]
Local Char ZCRITER(250) : ZCRITER = ""

If ZGROUPDFLG = 1
 ZCRITER = "[F:ZPOQ]POHNUM = [M:YPOC1]YPOHNUM(ZNOL) & [F:ZPOQ]YPOCLIN = [M:YPOC1]YPOCLIN(ZNOL) & [F:ZPOQ]YPOCNUM = [M:YPOC0]YPOCNUM"
Else
 ZCRITER = "[F:ZPOQ]POHNUM = [M:YPOC1]YPOHNUM(ZNOL) & [F:ZPOQ]POPLIN = [M:YPOC1]YPOPLIN(ZNOL) & [F:ZPOQ]YPOCNUM = [M:YPOC0]YPOCNUM"
Endif

For [F:ZPOQ] Where evalue(ZCRITER)
    [F:ZPOQ]YPOCUPDTICK = [F:ZPOQ]YPOCUPDTICK + 1
    [F:ZPOQ]YPOCLIN = [M:YPOC1]YPOCLIN(ZNOL)
	  If ZOLDYPOC = "" : [F:ZPOQ]YRCPDAT = 2 : Endif
    Rewrite [F:ZPOQ]
    For [YPCD] Where YPOCNUM= [M:YPOC0]YPOCNUM and YPOCLIN = [M:YPOC1]YPOCLIN(ZNOL)
     [YPCD]YLNVALIDATED =  2
     Rewrite [YPCD]
    Next
    [M:YPOC1]YLNVALIDATED(ZNOL) = 2
    Affzo [M:YPOC1]YLNVALIDATED(ZNOL)
Next

If ZPOQOPENEDHERE = 1 : Close File [F:ZPOQ] : Endif
End

##############################################################
Subprog ZGETSPLCNT(ZNOL,ZSPLCNT)
Value Integer ZNOL
Variable Integer ZSPLCNT

For I = 0 To [M:YPOC1]NBLIG - 1
 If [M:YPOC1]YPOHNUM(I) = [M:YPOC1]YPOHNUM(ZNOL) and [M:YPOC1]YPOPLIN(I) = [M:YPOC1]YPOPLIN(ZNOL)
  ZSPLCNT+=1
 Endif
Next
End

