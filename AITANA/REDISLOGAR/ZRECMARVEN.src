#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# YA009 - Recálculo de margen de ventas
#######################################################################################
$ACTION

Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "SORTIE"      : Gosub SORTIE
 When Default
Endcase
Return
########################################
$INIT
If GSERVEUR
    Onerrgo ERRBATCH
Endif
Gosub OUVRE
Return
########################################
$INIT_DIA
Raz [M:DIA]
Return
########################################
$EXEC
If !GSERVEUR
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(" ",0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call PRTSCR("ZRECMARVEN","DIA","",0,1) From ATRTX3
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0) From GESECRAN
Endif
If GSERVEUR
  Call ECR_TRACE(" ",0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(TIT + " " + date$ + " " + time$,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0) From GESECRAN
Endif

Gosub SEL_ENTREGA
Gosub TRT_ENTREGA

If !GSERVEUR
  Call ECR_TRACE(" ",0) From GESECRAN
  Call ECR_TRACE("Actualizados " + num$(CONTADOR_ALB) + " albaranes de entrega",0) From GESECRAN
  #Call ECR_TRACE("Actualizados " + num$(CONTADOR_FAC) + " facturas de venta",0) From GESECRAN
  Call FERME_TRACE From LECFIC
  TRA=1
Endif

Return
########################################
$TERMINE
Return
########################################
$SORTIE
SYMBOLE ="ZRECMARVEN"
Unlock =SYMBOLE
Return
#########################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
#########################################################################
#-----------------------------------------------------------------------#
# Abrir
#-----------------------------------------------------------------------#
$OUVRE

# Entregas
If clalev([F:ZSDH]) = 0 : Local File SDELIVERY   [ZSDH] : Endif
If clalev([F:ZSDD]) = 0 : Local File SDELIVERYD  [ZSDD] : Endif
#Facturas
If clalev([F:ZSIH]) = 0 : Local File SINVOICE    [ZSIH] : Endif
If clalev([F:ZSID]) = 0 : Local File SINVOICED   [ZSID] : Endif

#Articulo planta
If clalev([F:ZITF]) = 0 : Local File ITMFACILIT  [ZITF] : Endif
If clalev([F:ZTCM]) = 0 : Local File TABCOSTMET  [ZTCM] : Endif

#movimientos de stok
If clalev([F:ZSTJ]) = 0 : Local File STOJOU      [ZSTJ] : Endif
If clalev([F:ZSTJ2])= 0 : Local File STOJOU      [ZSTJ2]: Endif

#Acum. mvtos Artículo-planta
If clalev([F:ZITV]) = 0 : Local File ITMMVT     [ZITV] : Endif

#Facturas
If clalev([F:ZSID]) = 0 : Local File SINVOICED  [ZSID] : Endif

Local Char TIT(50)
Local Char SYMBOLE(20)
Local Char CRITERE(250)
Local Char CRITER2(250)
Local Integer CONTADOR_ALB
Local Integer CONTADOR_FAC

TIT = "Recálculo de margen de ventas"
Raz CONTADOR_ALB,CONTADOR_FAC

SYMBOLE ="ZRECMARVEN"
Lock =SYMBOLE
If fstat <> 0
  Call ERREUR("Ya existe un proceso en curso") From GESECRAN
  Gosub SORTIE
  End
Endif

Return
#########################################################################
#-----------------------------------------------------------------------#
# Criterios de selección
#-----------------------------------------------------------------------#
$SEL_ENTREGA

CRITERE = "1=1"
CRITER2 = "1=1"

#CRITERE
#planta
If [M:DIA]ZFCY <> ''
    CRITERE -= '&[F:ZSDH]STOFCY="' + [M:DIA]ZFCY + '"'
Endif
#Fecha presupuesto
If [M:DIA]ZSTRDAT <> [0/0/0]
    CRITERE -= '&[F:ZSDH]DLVDAT>=' + "[" + format$(GFMD,[M:DIA]ZSTRDAT)+"]"
Endif
If [M:DIA]ZENDDAT <> [0/0/0]
    CRITERE -= '&[F:ZSDH]DLVDAT<=' + "[" + format$(GFMD,[M:DIA]ZENDDAT)+"]"
Endif

Return
#########################################################################
#-----------------------------------------------------------------------#
# Tratamiento
#-----------------------------------------------------------------------#
$TRT_ENTREGA
Local Integer WALB, WLINALB
Local Integer WFAC, WLINFAC
Local Decimal WCOSTE_ALB_OLD, WCOSTE_FAC_OLD

Raz WALB, WLINALB, WFAC, WLINFAC
Raz WCOSTE_ALB_OLD, WCOSTE_FAC_OLD

# Obtenemos las entregas filtradas por planta y fecha
Filter [ZSDH] Where evalue (CRITERE) Order By Key ZSDH1 = [F:ZSDH]DLVDAT;[F:ZSDH]SDHNUM
  For [ZSDH]

    WLINALB = 0
    WLINFAC = 0
    WALB = 0

    # Por cada entrega, revisamos lás lineas que tienen árticulos con valorización PMP
    Link [ZSDD] With [F:ZITF]ITF0 = [F:ZSDD]ITMREF ; [F:ZSDH]STOFCY
&                 As [LNK]
&                 Where [F:ZSDD]SDHNUM = [F:ZSDH]SDHNUM and [F:ZITF]VLTCOD = 'AVC'
      For [LNK]

        #Infbox ('Fecha:'- format$(GFMD,[F:ZSDH]DLVDAT) - 'Entrega:'- [F:ZSDD]SDHNUM - 'Articulo:' - [F:ZSDD]ITMREF - 'Coste:' - num$([F:ZSDD]CPRPRI))

        #Obtenemos el coste PMP
        Gosub COSTE_PMP

        #Infbox ('Coste PMP:' - num$(WCOU) )

        # Comprobamos si el precio PMP ha cambiado, si no, no hacemos nada.
        If ar2(WCOU) <> ar2([F:ZSDD]CPRPRI)
          #guardo el coste anterior
          WCOSTE_ALB_OLD = [F:ZSDD]CPRPRI

          Trbegin [ZSDD]
          # Modificamos el coste y el margen de la línea
          [F:ZSDD]CPRPRI = WCOU
          If [F:ZSDD]NETPRI <> 0
            [F:ZSDD]PFM = [F:ZSDD]NETPRI - WCOU
          Endif
          Rewrite [F:ZSDD]
            If fstat=0
              Commit
              WLINALB += 1
            Else
              Rollback
            Endif

          #Actualizamola la línea de la factura, si es que existe

          Filter [ZSID] Where [F:ZSID]SDHNUM = [F:ZSDH]SDHNUM and [F:ZSID]SDDLIN = [F:ZSDD]SDDLIN
            For [ZSID]
              # Comprobamos si el precio PMP ha cambiado, si no, no hacemos nada.
              If ar2(WCOU) <> ar2([F:ZSID]CPRPRI)
                #guardo el coste anterior
                WCOSTE_FAC_OLD = [F:ZSID]CPRPRI

                Trbegin [ZSID]

                [F:ZSID]CPRPRI = WCOU
                If [F:ZSID]NETPRI <> 0
                  [F:ZSID]PFM = [F:ZSID]NETPRI - WCOU
                Endif

                #Escribimos
                Rewrite [F:ZSID]
                  If fstat=0
                    Commit
                    WLINFAC += 1
                  Else
                    Rollback
                  Endif
              Endif
            Next
          Filter [ZSID]


          If WALB = 0
            # Para que el título de albarán solo se muestre una vez aunque modifiquemos varias líneas
            WALB = 1
            Call ECR_TRACE('Fecha:'- format$(GFMD,[F:ZSDH]DLVDAT) - 'Entrega:'- [F:ZSDH]SDHNUM,0) From GESECRAN
          Endif


          Call ECR_TRACE('> Articulo:' - [F:ZSDD]ITMREF - '/ Coste antiguo:' - num$(ar2(WCOSTE_ALB_OLD)) - '/ Coste PMP actualizado:' - num$(ar2(WCOU)),0) From GESECRAN
          If WLINFAC > 0
            Call ECR_TRACE('>> Factura relacionada:' - [F:ZSID]NUM - '/ Coste antiguo:' - num$(ar2(WCOSTE_FAC_OLD)) - '/ Coste PMP actualizado:' - num$(ar2(WCOU)),0) From GESECRAN
          Endif
        Endif
      Next
    If WLINALB > 0
      CONTADOR_ALB += 1
    Endif
  Next
Filter [ZSDH]

Return
#########################################################################
$COSTE_PMP
## Obtener el coste PMP a la fecha requerida
# (Basado en lo encontrado en FUNSTVA)
Local Integer LACCFLG : LACCFLG=0
Local Char     LFILSTJWRH(250)
Local Decimal  WCOU
Local Decimal  WQTE(4)    # 0:Total ; 1:statut A ; 2:Q ; 3:R
Local Decimal  WQTF, WQTY, WQTYRCP, WQTYISS, WQTYCHG
Local Decimal  WAMT, WORDRCP, WORDISS, WORDCHG, WVALRCP, WVALISS, WVALCHG, WAMTTRA

LFILSTJWRH="1=1"
Raz WCOU
Raz WQTE, WQTF, WQTY, WQTYRCP, WQTYISS, WQTYCHG
Raz WAMT, WORDRCP, WORDISS, WORDCHG, WVALRCP, WVALISS, WVALCHG, WAMTTRA

Read [ZTCM]TCM0 = 'AVC'
Read [ZITV]ITV0 = [F:ZSDD]ITMREF ; [F:ZSDH]STOFCY

WQTE(1) = [F:ZITV]PHYSTO + [F:ZITV]PLFPHYSTO + [F:ZITV]BPRPHYSTO + [F:ZITV]SCOPHYSTO
WQTE(2) = [F:ZITV]CTLSTO + [F:ZITV]PLFCTLSTO + [F:ZITV]BPRCTLSTO + [F:ZITV]SCOCTLSTO
WQTE(3) = [F:ZITV]REJSTO + [F:ZITV]PLFREJSTO + [F:ZITV]BPRREJSTO + [F:ZITV]SCOREJSTO
WQTE(0) = sum(WQTE(1..3))


If LACCFLG<>0   # Issue 100246 - 2015-02-12 by CCC : add accounting date criteria
            Filter [ZSTJ] Where STOFCY = [F:ZITF]STOFCY &
&                              OWNER  = [F:ZITF]STOFCY &
&                              UPDCOD = 2             &
&                              ITMREF = [F:ZITF]ITMREF &
&                              evalue(LFILSTJWRH)     &
&                              (ACCDAT=[0/0/0] | ACCDAT > [F:ZSDH]DLVDAT)
Else

    # Avec la régul de sortie, c'est uniquement la date d'imputation qui compte
    If [F:ZTCM]PRIREGS<>2

        # Issue 93606 - 2013-11-04 by CCC : Add OWNER in filter
        # CCC (2010-01-22) Bug 61872 : Tenir compte des changements de valeur en date de création
        Filter [ZSTJ] Where STOFCY = [F:ZITF]STOFCY &
&                          OWNER  = [F:ZITF]STOFCY &
&                          UPDCOD = 2             &
&                          ITMREF = [F:ZITF]ITMREF &
&                          evalue(LFILSTJWRH)     &
&                          (IPTDAT > [F:ZSDH]DLVDAT | (CREDAT > [F:ZSDH]DLVDAT & (PRIREGFLG=2 | TRSTYP=23)) )
&                    Order By Key STJ0
    Else

      # Issue 93606 - 2013-11-04 by CCC : Add OWNER in filter
      Filter [ZSTJ] Where STOFCY = [F:ZITF]STOFCY &
&                        OWNER  = [F:ZITF]STOFCY &
&                        UPDCOD = 2             &
&                        ITMREF = [F:ZITF]ITMREF &
&                        evalue(LFILSTJWRH)     &
&                        IPTDAT > [F:ZSDH]DLVDAT
&                  Order By Key STJ0
    Endif
Endif
  For [ZSTJ]

      GPE=0
      # If ACCDAT=[0/0/0] it can be because of reverse movement although new movement has been accounted before REFDAT
      # This kind of movement musn't decrease quantity. It has to be taken into account as if it has been accounted.
      If LACCFLG & [F:ZSTJ]ACCDAT=[0/0/0] & [F:ZSTJ]AGGIFAFLG=2 & [F:ZSTJ]VARORD=0 & [F:ZSTJ]VARVAL=0

          Filter [ZSTJ2] Where STOFCY = [F:ZSTJ]STOFCY
&                             & UPDCOD = 2
&                             & ITMREF = [F:ZSTJ]ITMREF
&                             & IPTDAT = [F:ZSTJ]IPTDAT
&                             & VCRTYP = [F:ZSTJ]VCRTYP
&                             & VCRNUM = [F:ZSTJ]VCRNUM
&                             & VCRLIN = [F:ZSTJ]VCRLIN
&                             & MVTSEQ < [F:ZSTJ]MVTSEQ
&                             & ACCDAT<= [F:ZSDH]DLVDAT
&                             & ACCDAT<> [0/0/0]
          Look [ZSTJ2] First
          Filter [ZSTJ2]
          If !fstat
              GPE=1
          Endif
      Endif
      If GPE=0
          GPOINT = "REASTJ"
          Gosub ENTREE From EXEFNC
      Endif
      If GPE = 0

          Case abs(func STKLIB.SENSTRS([F:ZSTJ]TRSTYP))
            When 1, -2 :
                # CCC (2009-10-12) Bug 58655 : On fait la somme algébrique des quantités de tous les mouvements
                #WQTYRCP += [F:STJ]ACTQTY*([F:STJ]PRIREGFLG<>2) # On ne prend pas en compte la quantité des mouvements de régul
                WQTYRCP += [F:ZSTJ]ACTQTY
                WVALRCP += [F:ZSTJ]VARVAL
                WORDRCP += [F:ZSTJ]VARORD
            When 2, -1 :
                WQTYISS -= [F:ZSTJ]ACTQTY#*([F:STJ]PRIREGFLG<>2)
                WVALISS -= [F:ZSTJ]VARVAL
                WORDISS -= [F:ZSTJ]VARORD
            When Default :
                If [F:ZSTJ]TRSTYP=13
                    If [F:ZSTJ]QTYSTU>0
                        WQTYRCP += [F:ZSTJ]ACTQTY
                        WVALRCP += [F:ZSTJ]VARVAL
                        WORDRCP += [F:ZSTJ]VARORD
                    Else
                        WQTYISS -= [F:ZSTJ]ACTQTY
                        WVALISS -= [F:ZSTJ]VARVAL
                        WORDISS -= [F:ZSTJ]VARORD
                    Endif
                Else
                    WQTYCHG += [F:ZSTJ]ACTQTY
                    WORDCHG += [F:ZSTJ]VARORD
                    WVALCHG += [F:ZSTJ]VARVAL
                Endif
          Endcase
         WQTE(find(left$([F:ZSTJ]STA,1),"A","Q","R")) -= [F:ZSTJ]ACTQTY#*([F:ZSTJ]PRIREGFLG<>2)
      Endif
  Next
Filter [ZSTJ]

If [F:ZITV]AVCBASQTY<>0
  WAMT = [F:ZITV]AVCBASAMT*WQTE/[F:ZITV]AVCBASQTY
Endif

WQTE(0) += WQTYISS-WQTYRCP-WQTYCHG
WAMT += WORDISS-WORDRCP-WORDCHG

If WQTE(0)<>0
    WAMT = ((2=2)*WQTE(1)+(2=2)*WQTE(2)+(2=2)*WQTE(3))*WAMT/WQTE(0)
Else
    WAMT = 0
Endif
WQTE(0) = (2=2)*WQTE(1)+(2=2)*WQTE(2)+(2=2)*WQTE(3)

WAMT += WAMTTRA

If (WQTE+WQTF)=0
    WCOU=0
Else
    WCOU = WAMT/(WQTE+WQTF)
Endif

Return
############################################################
######################################################################################
Subprog AM_ZSTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0]
  [M]ZENDDAT=VALEUR
  Affzo ZENDDAT
Endif
End

######################################################################################

