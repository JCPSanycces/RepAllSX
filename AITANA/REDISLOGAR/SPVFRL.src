#--------------------------------------------------
Subprog D_XUOM(VALEUR)
Variable Char    VALEUR()

If [M:FRL2]XNUMLIG<=0 : End : Endif

If [M:FRL2]ITMREFPUR([M:FRL2]XNUMLIG-1)<>""
  Read [ITM]ITM0=[M:FRL2]ITMREFPUR([M:FRL2]XNUMLIG-1)
  If !fstat
    VALEUR=[F:ITM]PUU
  Endif
Elsif find("UN",[V]GUNITE)
  VALEUR="UN"
Else
  VALEUR=[V]GUNITE(8)
Endif
End

#--------------------------------------------------
Subprog D_XGROPRIPUR(VALEUR)
Variable Decimal VALEUR

If [M:FRL2]XNUMLIG<=0 : End : Endif

Local Char ACTION(20)

# Initialisation du prix d'achat par rapport    #
# Recupere le nb de remises gerees dans le GAS  #
Local Integer NBREM
Call LECTURE("ACV","PPR","")From CONTOBJ
If [F:ACV]FLACT = 2 Then
  [L]NBREM = [F:ACV]DIME
Endif

Local Integer NOL
Local Decimal PRIX,REMISE([L]NBREM)
Local Char    DEVISE,IUSRES
Local Date    ZDEB

[L]NOL=[M:FRL2]XNUMLIG-1
[L]DEVISE=[M:FRL2]PURCUR([L]NOL)

[L]ZDEB=[M:FRL0]CREDATFRM

If [L]PRIX=0
    Raz [L]PRIX,[L]REMISE,[L]IUSRES
    Call RECHPJT_PRIXA([M:FRL0]OPPNUM,[M:FRL2]BPSNUM(NOL),[L]ZDEB,[M:FRL2]ITMREFPUR([L]NOL),
&                      [L]PRIX,[L]DEVISE,[L]REMISE,[M:FRL2]CURTYP([L]NOL),
&                      [L]IUSRES,[M:FRL2]UOM([L]NOL))
&   From SPVOBJITV2
Endif

# Actions spécifiques : renseigner las variables PRIX et REMISE() en se servant de la devise de calcul DEVISE
GPOINT="D_GROPRIPUR" : Gosub ENTREE From EXEFNC
VALEUR=[L]PRIX

If dim([M:FRL2]DISPUR)>=0
    [M:FRL2]DISPUR(NOL)=[L]REMISE(0)
    [M:FRL2]XDISPUR=[L]REMISE(0)
    If !GIMPORT : Affzo [M:FRL2]XDISPUR : Endif
Endif
If dim([M:FRL2]DISPUR2)>=0
    [M:FRL2]DISPUR2(NOL)=[L]REMISE(1)
    [M:FRL2]XDISPUR2=[L]REMISE(1)
    If !GIMPORT : Affzo [M:FRL2]XDISPUR2 : Endif
Endif
If dim([M:FRL2]DISPUR3)>=0
    [M:FRL2]DISPUR3(NOL)=[L]REMISE(2)
    [M:FRL2]XDISPUR3=[L]REMISE(2)
    If !GIMPORT : Affzo [M:FRL2]XDISPUR3 : Endif
Endif
If dim([M:FRL2]DISPUR4)>=0
    [M:FRL2]DISPUR4(NOL)=[L]REMISE(3)
    [M:FRL2]XDISPUR4=[L]REMISE(3)
    If !GIMPORT : Affzo [M:FRL2]XDISPUR4 : Endif
Endif
If dim([M:FRL2]DISPUR5)>=0
    [M:FRL2]DISPUR5(NOL)=[L]REMISE(4)
    [M:FRL2]XDISPUR5=[L]REMISE(4)
    If !GIMPORT : Affzo [M:FRL2]XDISPUR5 : Endif
Endif
End


#--------------------------------------------------
Subprog AS_XNBANAPUR
If nolign>GNBDIE | [M:FRL2]XFLGTRT([M:FRL2]XNUMLIG-1)=2 : End : Endif
Local Shortint XSTAT
Local Integer I, ZZLIG
[L]ZZLIG=nolign
# Déclenchement Init sections ana
Call INISEC_PUR([L]XSTAT)
# Pour déclencher PSG/Actions SPE et enregistrer zone lorsque changement d'onglet sans saisie
Affzo [M:FRL2]20
For [L]I=1 To GNBDIE
  Assign "[M:FRL2]CCE"+num$([L]I)+"("+num$([M:FRL2]XNUMLIG-1)+")" With [M:FRL2]XSECPUR([L]I-1)
Next
End

Subprog INISEC_PUR(XSTAT)
Variable Shortint XSTAT

Read [F:ITM]ITM0=[M:FRL2]ITMREFPUR(max([M:FRL2]XNUMLIG,1)-1)
If fstat : Raz [F:ITM] : Endif

Local Char SECTION(20), XGAXE(30)
Local Integer ZI, SVGLIG

[L]SVGLIG=nolign
[L]XSTAT=0

[M:FRL2]XNBANAPUR=GNBDIE
[M:FRL2]XFLGTRT([M:FRL2]XNUMLIG-1)=2

For [L]ZI=1 To GNBDIE
  nolign=[L]ZI
  [L]XGAXE=GDIE([L]ZI)
  If [M:FRL2]XSECPUR([L]ZI-1)=""
    Call INISEC([L]SECTION,"XFRL2",[L]XGAXE) From SUBCDE
    If [L]SECTION<>""
      Call CONTROLE("CCE","#",[L]SECTION,[L]XGAXE,[L]XSTAT) From CONTOBJ
      If [L]XSTAT
        Raz [V]GMESSAGE
      Else
        [M:FRL2]XSECPUR([L]ZI-1)=[L]SECTION
        Assign "[M:FRL2]CCE"+num$([L]ZI)+"("+num$([M:FRL2]XNUMLIG-1)+")" With [L]SECTION
      Endif
    Endif
  Endif
Next
nolign=[L]SVGLIG
End

#--------------------------------------------------
Subprog C_XSECPUR(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" | [V]XFRLTYP : End : Endif
Local Integer J
Read [F:PFM]PFM0=[M:FRL0]TYPFRM
If !fstat
  [L]J=find([M:FRL2]XDIEPUR(nolign-1),[F:PFM]FLADIE)
  If [L]J>0 & [F:PFM]FLACCE([L]J-1)=2
    GMESSAGE=mess(10,123,1)
    GERR=1
    mkstat=1
  Endif
Endif
End


