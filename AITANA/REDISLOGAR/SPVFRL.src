&          ,[M:FRL3]XCATPRIRES,VALEUR,[M:FRL3]XNUMLIG,[M:FRL3]FCYFRL3([M:FRL3]XNUMLIG-1))
If !GIMPORT
  Affzo [M:FRL3]UOMEXT([M]XNUMLIG-1)
Endif
End


#---------------------------------------
Subprog AP_XEXTQTY(VALEUR)
Variable Decimal VALEUR
Call SUM_DS([M:FRL1]REQCOS) From SPVOBJFRL
If !GIMPORT: Affzo [M:FRL1]17: Endif
End

#---------------------------------------
Subprog AM_XEXTQTY(VALEUR)
Variable Decimal VALEUR
[M:FRL3]EXTQTY([M]XNUMLIG-1)=VALEUR
Affzo [M:FRL3]EXTQTY([M]XNUMLIG-1),XBUYCOS
End

#---------------------------------------
Subprog D_XCOST(VALEUR)
Variable Decimal VALEUR
If [M:FRL3]XNUMLIG<=0 : End : Endif
Call CALPRICOST(VALEUR,[M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1),[M:FRL3]ITEM([M:FRL3]XNUMLIG-1),[M:FRL3]CODOPE([M:FRL3]XNUMLIG-1)
&          ,[M:FRL3]CATPRIRES([M:FRL3]XNUMLIG-1),[M:FRL3]UOMEXT([M:FRL3]XNUMLIG-1),0,[M:FRL3]FCYFRL3([M:FRL3]XNUMLIG-1))
End

Subprog CALPRICOST(VALEUR,CURFRL3,ITM,CODOPE,CATPRIRES,UOMEXT,XNUMLIG,FCY)
Variable Decimal VALEUR
Value Char CURFRL3, ITM, CODOPE, CATPRIRES, UOMEXT, FCY
Value Decimal XNUMLIG

If UOMEXT="" : End : Endif

Local Integer STAT
Local Date ZDAT
Local Char ZFCY(5)

# Date référence
[L]ZDAT=[M:FRL0]CREDATFRM

# LBORN 15/09/2014 - Mantis 25752
# Raz [L]ZFCY
# If [M:FRL0]OPPNUM<>""

[L]ZFCY=[L]FCY
If [M:FRL0]OPPNUM<>"" & [L]ZFCY=""
  Read [F:OPP]OPP0=[M:FRL0]OPPNUM
  If !fstat & [F:OPP]SALFCY<>""
    [L]ZFCY=[F:OPP]SALFCY
  Endif
Endif

Call CALCOST(VALEUR,[L]ZDAT,[L]ZFCY,[L]CURFRL3,[L]ITM,[L]CODOPE,[L]CATPRIRES,[L]UOMEXT,[L]STAT) From SPVOBJFRL
If [L]STAT : End : Endif

If [L]XNUMLIG
  [M:FRL3]XCOST=VALEUR
  [M:FRL3]COST([L]XNUMLIG-1)=VALEUR
  If !GIMPORT
    Affzo [M:FRL3]XCOST,XBUYCOS
  Endif
Endif

End

#--------------------------------------------------
Subprog C_XCOST(VALEUR)
Variable Decimal VALEUR

Local Decimal AUX
Local Integer STAT

Read [F:XOP]XOP0=[M:FRL0]OPPNUM
If fstat : Raz [F:XOP] : Endif

If VALEUR<>[M:FRL3]COSPRIDS([M:FRL3]XNUMLIG-1)
  Raz [M:FRL3]COSPRIDS([M:FRL3]XNUMLIG-1)
  Raz [M:FRL3]XCOSPRIDS
Endif

[L]AUX=VALEUR*[M:FRL3]EXTQTY([M:FRL3]XNUMLIG-1)
If [M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1)<>[V]GLOCALDEV
  # LBORN 02/03/2017
  # Call CONVERT([M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1),[V]GLOCALDEV,[V]GLOCALDEV,[F:XOP]CHGTYP,datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
  Call CONVERT([M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1),[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
Endif

[M:FRL3]BUYCOS([M:FRL3]XNUMLIG-1)=[L]AUX
[M:FRL3]XBUYCOS=[L]AUX
Affzo [M:FRL3]XBUYCOS

End


#---------------------------------------
Subprog AM_XCOST(VALEUR)
Variable Decimal VALEUR

[M:FRL3]COST([M]XNUMLIG-1)=VALEUR

Call SUM_DS([M:FRL1]REQCOS) From SPVOBJFRL
If !GIMPORT: Affzo [M:FRL1]17: Endif

End

#---------------------------------------
Subprog AV_XBUYCOS(VALEUR)
Variable Decimal VALEUR
If !find([V]GREP,"C","D","M") : End : Endif

Local Decimal AUX
Local Integer STAT

Read [F:XOP]XOP0=[M:FRL0]OPPNUM
If fstat : Raz [F:XOP] : Endif

[L]AUX=[M:FRL3]COST([M]XNUMLIG-1)*[M:FRL3]EXTQTY([M]XNUMLIG-1)
If [M:FRL3]CURFRL3([M]XNUMLIG-1)<>[V]GLOCALDEV
  # LBORN 02/03/2017
  # Call CONVERT([M:FRL3]CURFRL3([M]XNUMLIG-1),[V]GLOCALDEV,[V]GLOCALDEV,[F:XOP]CHGTYP,datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
  Call CONVERT([M:FRL3]CURFRL3([M]XNUMLIG-1),[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
Endif

VALEUR=[L]AUX
[M:FRL3]BUYCOS([M]XNUMLIG-1)=VALEUR

End


#---------------------------------------
Subprog IB_NBLIGFRL3

[V]GBIDI1=1
If [M:FRL3]REQTYP(nolign-1)<>""
  # LBORN 11/01/2013 - Mantis 17408
  # [V]GBOUT1="Info DS"
  [V]GBOUT1=mess(90,[V]GXMSGOPP,1)
  If !find([V]GREP,"C","D")
    If !instr(1,[V]GCHAINE,"M")
      [V]GBIDI1=0
    Else
      Local Char ZSYMBOLE(155)
      [L]ZSYMBOLE="FRL"+[M:FRL0]FRMNUMLIG
      Lock =[L]ZSYMBOLE With lockwait=0
      If fstat
        [V]GBIDI1=0
      Endif
    Endif
  Endif
Else
  [V]GBOUT1=""
Endif

Raz [V]GBOUT10
If ![V]XFRLTYP
  If [M:FRL0]REVNUM>0 & nolign>0 & nolign<=[M:FRL3]NBLIGFRL3 & GREP=""
    [V]GBOUT10=mess(148,[V]GXMSGOPP,1)
  Endif
Endif

End

#---------------------------------------
Subprog C_CODOPE(VALEUR)
Variable Char    VALEUR()

Local Char LISTRIPLET(9)(dim([M:FRL3]CODOPE))
Local Char CHAINE(255),A,B(10),C(20),LISTRIPLET(50)(max(dim([M:FRL3]CODOPE),1))
Local Integer TROUVE, POS

[L]CHAINE=[M:FRL3]WSTREQ(nolign-1)+chr$(254)+[M:FRL3]REQTYP(nolign-1)+chr$(254)+VALEUR

[L]POS=nolign-1

For I=0 To dim([M:FRL3]CODOPE)-1

   If I <> [L]POS:
      [L]A=[M:FRL3]WSTREQ(I)
      [L]B=[M:FRL3]REQTYP(I)
      [L]C=[M:FRL3]CODOPE(I)

      LISTRIPLET(I)=[L]A+chr$(254)+[L]B+chr$(254)+[L]C
   Endif
Next I

[L]TROUVE=find([L]CHAINE,[L]LISTRIPLET)

If [L]TROUVE:
  [V]GMESSAGE=mess(98,[V]GXMSGPSA,1)-num$([L]TROUVE)
  mkstat=2
Else
  Call CONOPEREQ(VALEUR,[M:FRL3]REQTYP(nolign-1)) From SPVOBJOPE
  If !mkstat & VALEUR<>[M:FRL3]CODOPE(nolign-1)
    Raz [M:FRL3]COST(nolign-1)
    Raz [M:FRL3]BUYCOS(nolign-1)
    Raz [M:FRL3]XCOST
    Raz [M:FRL3]XBUYCOS
  Endif
Endif
End

#---------------------------------------
Subprog D_XCOEDS(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
  VALEUR=1
Endif
End

#---------------------------------------
Subprog C_XCOEDS(VALEUR)
Variable Decimal VALEUR

If VALEUR<>[M:FRL3]COEDS([M:FRL3]XNUMLIG-1)

  If [V]GXOPTSOF

    Local Integer STAT
    Local Decimal AUX

    Read [F:XOP]XOP0=[M:FRL0]OPPNUM
    If fstat : Raz [F:XOP] : Endif
    Read [F:OPP]OPP0=[M:FRL0]OPPNUM
    If fstat : Raz [F:OPP] : Endif

    [L]AUX=[M:FRL3]COST([M:FRL3]XNUMLIG-1)
    If [M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1)<>[V]GLOCALDEV
      # LBORN 02/03/2017
      # Call CONVERT([M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1),[V]GLOCALDEV,[V]GLOCALDEV,[F:XOP]CHGTYP,datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
      Call CONVERT([M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1),[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
    Endif

    [M:FRL3]COSPRIDS([M:FRL3]XNUMLIG-1)=ar2([L]AUX*VALEUR)
    [M:FRL3]XCOSPRIDS=[M:FRL3]COSPRIDS([M:FRL3]XNUMLIG-1)

  Else

    Raz [M:FRL3]COSPRIDS([M:FRL3]XNUMLIG-1)
    Raz [M:FRL3]DISPRIDS([M:FRL3]XNUMLIG-1)
    Raz [M:FRL3]XCOSPRIDS
    Raz [M:FRL3]XDISPRIDS

  Endif

Endif

End

#---------------------------------------
Subprog AM_XCOEDS(VALEUR)
Variable Decimal VALEUR
[M:FRL3]COEDS([M:FRL3]XNUMLIG-1)=VALEUR
End

