Subprog C_XITMDESPUR(VALEUR)
Variable Char    VALEUR()
# A cause Bug Adonix, pas de déclenchement d'init après COUZON en création
[M:FRL2]ITMDESPUR([M:FRL2]XNUMLIG-1)=VALEUR
End

#--------------------------------------------------
Subprog AM_XITMDESPUR(VALEUR)
