Subprog D_XPURCUR(VALEUR)
Variable Char    VALEUR()
If [M:FRL2]XNUMLIG<=0 : End : Endif
Local File BPARTNER [XBPR]
Read [XBPR]BPR0=[M:FRL2]BPSNUM([M:FRL2]XNUMLIG-1)
If !fstat
  VALEUR=[F:XBPR]CUR
Else
  VALEUR=[V]GLOCALDEV
Endif
Close Local File [XBPR]
End


#--------------------------------------------------
Subprog AS_XDISPRIPUR(VALEUR)
Variable Decimal VALEUR
If [M:FRL2]COSPRIPUR([M:FRL2]XNUMLIG-1)=0
  [M:FRL2]DISPRIPUR([M:FRL2]XNUMLIG-1)=0
  mkstat=1
Endif
End



#--------------------------------------------------
Subprog AS_XCOSPRIPUR(VALEUR)
Variable Decimal VALEUR

If VALEUR<>0 : End : Endif

Local Integer J, STAT, ZNBREM
Local Decimal AUX, ZREM(9)
Raz [L]ZREM, [L]ZNBREM
If dim([M:FRL2]DISPUR)>0
  [L]ZREM(0)=[M:FRL2]DISPUR([M:FRL2]XNUMLIG-1) : [L]ZNBREM+=1
Endif
For [L]J=2 To 9
  If evalue("dim([M:FRL2]DISPUR"+num$([L]J)+")>0")
    [L]ZREM([L]ZNBREM)=evalue("[M:FRL2]DISPUR"+num$([L]J)+"([M:FRL2]XNUMLIG-1)") : [L]ZNBREM+=1
  Endif
Next

# Prix net en devise achat
[L]AUX=[M:FRL2]GROPRIPUR([M:FRL2]XNUMLIG-1)
Call CALNET(2,"",[M:FRL2]GROPRIPUR([M:FRL2]XNUMLIG-1),[L]ZREM,[M:FRL2]QTYUOM([M:FRL2]XNUMLIG-1),[L]AUX,GSYSCUR) From TRTPRICE
If [M:FRL2]PURCUR([M:FRL2]XNUMLIG-1)<>[V]GLOCALDEV
  Call CONVERT([M:FRL2]PURCUR([M:FRL2]XNUMLIG-1),[V]GLOCALDEV,[V]GLOCALDEV,[M:FRL2]CURTYP([M:FRL2]XNUMLIG-1),datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
Endif
VALEUR=arr([L]AUX*[M:FRL2]COEPUR([M:FRL2]XNUMLIG-1),[V]GARODEV)
[M:FRL2]COSPRIPUR([M:FRL2]XNUMLIG-1)=VALEUR

If !GIMPORT : Affzo [M:FRL1] : Endif

End

#---------------------------------------
Subprog AM_XCOSPRIPUR(VALEUR)
Variable Decimal VALEUR

Local Integer J, STAT, ZNBREM
Local Decimal AUX, ZREM(9)

# Prix d'achat net en devise locale
Raz [L]ZREM,[L]ZNBREM
If dim([M:FRL2]DISPUR)>0
  ZREM(0)=[M:FRL2]DISPUR([M:FRL2]XNUMLIG-1) : [L]ZNBREM+=1
Endif
For [L]J=2 To 9
  If evalue("dim([M:FRL2]DISPUR"+num$([L]J)+")>0")
    [L]ZREM([L]ZNBREM)=evalue("[M:FRL2]DISPUR"+num$([L]J)+"([M:FRL2]XNUMLIG-1)") : [L]ZNBREM+=1
  Endif
Next

# Prix net en devise achat
[L]AUX=[M:FRL2]GROPRIPUR([M:FRL2]XNUMLIG-1)
Call CALNET(2,"",[M:FRL2]GROPRIPUR([M:FRL2]XNUMLIG-1),[L]ZREM,[M:FRL2]QTYUOM([M:FRL2]XNUMLIG-1),[L]AUX,GSYSCUR) From TRTPRICE
If [M:FRL2]PURCUR([M:FRL2]XNUMLIG-1)<>[V]GLOCALDEV
  Call CONVERT([M:FRL2]PURCUR([M:FRL2]XNUMLIG-1),[V]GLOCALDEV,[V]GLOCALDEV,[M:FRL2]CURTYP([M:FRL2]XNUMLIG-1),datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
Endif
If [L]AUX=0
  [M:FRL2]COEPUR([M:FRL2]XNUMLIG-1)=1
  [M:FRL2]XCOEPUR=1
Else
  [M:FRL2]COEPUR([M:FRL2]XNUMLIG-1)=arr([L]VALEUR/[L]AUX,10^(len(num$(fix([L]VALEUR/[L]AUX)))-11))
  [M:FRL2]XCOEPUR=[M:FRL2]COEPUR([M:FRL2]XNUMLIG-1)
Endif
Affzo [M:FRL2]XCOEPUR

[M:FRL2]COSPRIPUR([M:FRL2]XNUMLIG-1)=VALEUR

If !GIMPORT : Affzo [M:FRL1] : Endif
End


#--------------------------------------------------
Subprog C_XEXTRCPDAT(VALEUR)
Variable Date VALEUR
If VALEUR=[0/0/0] : End : Endif

Local Date ZDEB
[L]ZDEB=[M:FRL0]CREDATFRM
Call CONT_EXTRCPDAT([M:FRL2]STOFCY([M:FRL2]XNUMLIG-1),VALEUR,[L]ZDEB) From SPVOBJFRL

End


#--------------------------------------------------
Subprog AS_NBLIG

Local Shortint XSTAT
Local Integer I, ZZLIG, ZLIG, ZI
Local Char SVGREP

[L]ZZLIG=nolign


# DEBUT #######################################
# Init dernière fiche traitée pour initialiser analytique (cas où l'on ne passe pas dans le tableau
# analytique et que l'on passe à la ligne suivante)
# Le cas du changement d'onglet sera traité en AV_Saisie du tableau Ana

# Déclenchement Init sections ana
If [M:FRL2]XNUMLIG>0 & [M:FRL2]XFLGTRT([M:FRL2]XNUMLIG-1)<>2 & [M:FRL2]ITMREFPUR([M:FRL2]XNUMLIG-1)<>""
  nolign=[M:FRL2]XNUMLIG
  Call INISEC_PUR([L]XSTAT)
  # Pour déclencher PSG/Actions SPE et enregistrer zone lorsque changement d'onglet sans saisie
  Affzo [M:FRL2]20
  For [L]I=1 To GNBDIE
    If [M:FRL2]XSECPUR([L]I-1)<>""
      Call CONTROLE("CCE","#",[M:FRL2]XSECPUR([L]I-1),[M:FRL2]XDIEPUR([L]I-1),[L]XSTAT) From CONTOBJ
      If [L]XSTAT : Raz [V]GMESSAGE : Raz [M:FRL2]XSECPUR([L]I-1) : Endif
    Endif
    Assign "[M:FRL2]CCE"+num$([L]I)+"("+num$([M:FRL2]XNUMLIG-1)+")" With [M:FRL2]XSECPUR([L]I-1)
  Next
  nolign=[L]ZZLIG
Endif
# FIN #######################################

[L]ZLIG=nolign-1

Effzo [M:FRL2]15-99

# Pas d'affectation en création, sinon pas d'init
If [M:FRL2]ITMREFPUR([L]ZLIG)<>""
  Gosub AFFECT_FRA From SPVOBJFRL
  # GREP pour éviter de redéclencher les Init en avant_zone PSG (déjà fait)
  [L]SVGREP=GREP
  If GREP="C" : GREP="M" : Endif
  Affzo [M:FRL2]15-99
  GREP=[L]SVGREP
Else
  [M:FRL2]XNUMLIG=[L]ZLIG+1
  [M:FRL2]XNBANAPUR=GNBDIE
  For [L]ZI=1 To GNBDIE
    [M:FRL2]XDIEPUR([L]ZI-1)=GDIE([L]ZI)
  Next
  Affzo [M:FRL2]XDIEPUR
Endif

nolign=[L]ZLIG+1
Affzo [M:FRL2]ITMREFPUR,BPSNUM
End

#--------------------------------------------------
Subprog C_NBLIG
If status=73
  # Insertion
  Local Integer ZI
  Effzo [M:FRL2]15-99
  [M:FRL2]XNUMLIG=nolign
  [M:FRL2]XNBANAPUR=GNBDIE
  For [L]ZI=1 To GNBDIE
    [M:FRL2]XDIEPUR([L]ZI-1)=GDIE([L]ZI)
  Next
  Affzo [M:FRL2]XDIEPUR
Endif
End

