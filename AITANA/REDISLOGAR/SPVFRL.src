Endif
End


#--------------------------------------------------
Subprog AS_XDISPRIDS(VALEUR)
Variable Decimal VALEUR
If [M:FRL3]COSPRIDS([M:FRL3]XNUMLIG-1)=0
  mkstat=1
Endif
End

#--------------------------------------------------
Subprog AM_XDISPRIDS(VALEUR)
Variable Decimal VALEUR
[M:FRL3]DISPRIDS([M:FRL3]XNUMLIG-1)=VALEUR
End


#--------------------------------------------------
Subprog AS_XCOSPRIDS(VALEUR)
Variable Decimal VALEUR

If VALEUR<>0 : End : Endif

Local Integer STAT
Local Decimal AUX, ZREM(9)

Read [F:XOP]XOP0=[M:FRL0]OPPNUM
If fstat : Raz [F:XOP] : Endif
Read [F:OPP]OPP0=[M:FRL0]OPPNUM
If fstat : Raz [F:OPP] : Endif

[L]AUX=[M:FRL3]COST([M:FRL3]XNUMLIG-1)
If [M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1)<>[V]GLOCALDEV
  # LBORN 02/03/2017
  # Call CONVERT([M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1),[V]GLOCALDEV,[V]GLOCALDEV,[F:XOP]CHGTYP,datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
  Call CONVERT([M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1),[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
Endif

# LBORN 09/09/2013 - Mantis 20576
If [V]GXOPTSOF

  # LBORN 02/03/2017
  # Call INIT_PRIXP([F:OPP]OPPTYP,[M:FRL0]OPPNUM,[M:FRL3]XFCYFRL3,[M:FRL0]BPCNUM,[M:FRL7]BPAADD,[M:FRL3]XITEM
  # &                ,[M:FRL3]XEXTQTY,[M:FRL3]XUOMEXT,[V]GLOCALDEV,[F:XOP]CHGTYP,"",[M:FRL0]CREDATFRM
  # &                ,VALEUR,[L]ZREM,"") From SPVOBJFRL
  Call INIT_PRIXP([F:OPP]OPPTYP,[M:FRL0]OPPNUM,[M:FRL3]XFCYFRL3,[M:FRL0]BPCNUM,[M:FRL7]BPAADD,[M:FRL3]XITEM
&                ,[M:FRL3]XEXTQTY,[M:FRL3]XUOMEXT,[V]GLOCALDEV,[F:OPP]CHGTYP,"",[M:FRL0]CREDATFRM
&                ,VALEUR,[L]ZREM,"") From SPVOBJFRL

  If VALEUR<>0
    If [L]AUX<>0
      [M:FRL3]XCOEDS=VALEUR/[L]AUX
    Else
      [M:FRL3]XCOEDS=0
    Endif
    [M:FRL3]COEDS([M:FRL3]XNUMLIG-1)=[M:FRL3]XCOEDS
  Else
    VALEUR=ar2([L]AUX*[M:FRL3]COEDS([M:FRL3]XNUMLIG-1))
  Endif
Else
  VALEUR=ar2([L]AUX*[M:FRL3]COEDS([M:FRL3]XNUMLIG-1))
Endif

[M:FRL3]COSPRIDS([M:FRL3]XNUMLIG-1)=VALEUR
If !GIMPORT
  Affzo [M:FRL1]
  Affzo [M:FRL3]XCOEDS
Endif

End

#--------------------------------------------------
Subprog AM_XCOSPRIDS(VALEUR)
Variable Decimal VALEUR

Local Integer STAT
Local Decimal AUX

Read [F:XOP]XOP0=[M:FRL0]OPPNUM
If fstat : Raz [F:XOP] : Endif

[L]AUX=[M:FRL3]COST([M:FRL3]XNUMLIG-1)
If [L]AUX=0
  [M:FRL3]COEDS([M:FRL3]XNUMLIG-1)=0
  [M:FRL3]XCOEDS=0
Else
  If [M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1)<>[V]GLOCALDEV
    # LBORN 02/03/2017
    # Call CONVERT([M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1),[V]GLOCALDEV,[V]GLOCALDEV,[F:XOP]CHGTYP,datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
    Call CONVERT([M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1),[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
  Endif
  [M:FRL3]COEDS([M:FRL3]XNUMLIG-1)=arr([L]VALEUR/[L]AUX,10^(len(num$(fix([L]VALEUR/[L]AUX)))-11))
  [M:FRL3]XCOEDS=arr([L]VALEUR/[L]AUX,10^(len(num$(fix([L]VALEUR/[L]AUX)))-11))
Endif

Affzo [M:FRL3]XCOEDS

[M:FRL3]COSPRIDS([M:FRL3]XNUMLIG-1)=VALEUR
If !GIMPORT : Affzo [M:FRL1] : Endif

End


#--------------------------------------------------
Subprog AM_XSECREQ(VALEUR)
Variable Char    VALEUR()
Assign "[M:FRL3]CCEDS"+num$(nolign)+"("+num$([M:FRL3]XNUMLIG-1)+")" With VALEUR
End


#--------------------------------------------------
Subprog C_XNBANAREQ

# Recalcul de l'onglet "Ventes"
Call SUM_DS([M:FRL1]REQCOS) From SPVOBJFRL
If !GIMPORT: Affzo [M:FRL1]17: Endif

End


#--------------------------------------------------
Subprog AS_XNBANAREQ
If nolign>GNBDIE | [M:FRL3]XFLGTRT([M:FRL3]XNUMLIG-1)=2 : End : Endif
Local Shortint XSTAT
Local Integer I, ZZLIG
[L]ZZLIG=nolign
# Déclenchement Init sections ana
Call INISEC_REQ([L]XSTAT)
# Pour déclencher PSG/Actions SPE et enregistrer zone lorsque changement d'onglet sans saisie
Affzo [M:FRL3]20
For [L]I=1 To GNBDIE
  Assign "[M:FRL3]CCEDS"+num$([L]I)+"("+num$([M:FRL3]XNUMLIG-1)+")" With [M:FRL3]XSECREQ([L]I-1)
Next
End


Subprog INISEC_REQ(XSTAT)
Variable Shortint XSTAT

Local Char SECTION(20), XGAXE(30)
Local Integer ZI, SVGLIG

[L]SVGLIG=nolign
[L]XSTAT=0

[M:FRL3]XNBANAREQ=GNBDIE
[M:FRL3]XFLGTRT([M:FRL3]XNUMLIG-1)=2

Read [F:ITM]ITM0=[M:FRL3]ITEM([M:FRL3]XNUMLIG-1)
If fstat : Raz [F:ITM] : Endif

For [L]ZI=1 To GNBDIE
  nolign=[L]ZI
  [L]XGAXE=GDIE([L]ZI)
  If [M:FRL3]XSECREQ([L]ZI-1)=""
    Call INISEC([L]SECTION,"XFRL3",[L]XGAXE) From SUBCDE
    If [L]SECTION<>""
      Call CONTROLE("CCE","#",[L]SECTION,[L]XGAXE,[L]XSTAT) From CONTOBJ
      If [L]XSTAT
        Raz [V]GMESSAGE
      Else
        [M:FRL3]XSECREQ([L]ZI-1)=[L]SECTION
        Assign "[M:FRL3]CCEDS"+num$([L]ZI)+"("+num$([M:FRL3]XNUMLIG-1)+")" With [L]SECTION
      Endif
    Endif
  Endif
Next
End


#--------------------------------------------------
Subprog C_XSECREQ(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" | [V]XFRLTYP : End : Endif
Local Integer J
Read [F:PFM]PFM0=[M:FRL0]TYPFRM
If !fstat
  [L]J=find([M:FRL3]XDIEREQ(nolign-1),[F:PFM]FLRDIE)
  If [L]J>0 & [F:PFM]FLRCCE([L]J-1)=2
    GMESSAGE=mess(10,123,1)
    GERR=1
    mkstat=1
  Endif
Endif
End

#--------------------------------------------------
Subprog IB_NBETP

If nolign>[M:FRL1]NBETP
  [V]GBOUT9=""
Endif
If [M:FRL1]INVMOD=4
  [V]GBIDC1="FLD"
Else
  [V]GBIDC1="FLF"
Endif

Raz [V]GBOUT10
If ![V]XFRLTYP
  If [M:FRL0]REVNUM>0 & nolign>0 & nolign<=[M:FRL1]NBETP & GREP=""
    [V]GBOUT10=mess(150,[V]GXMSGOPP,1)
  Endif
Endif

End

#--------------------------------------------------
Subprog AS_STEPS(VALEUR)
Variable Integer VALEUR
If [M:FRL1]INVMOD<>4
  mkstat=1
Endif
End

#--------------------------------------------------
Subprog AS_MINDAT(VALEUR)
Variable Date    VALEUR
If [M:FRL1]INVMOD<>4
  mkstat=1
Endif
End

#--------------------------------------------------
Subprog AS_MAXDAT(VALEUR)
Variable Date    VALEUR
If [M:FRL1]INVMOD<>4
  mkstat=1
Endif
End


#--------------------------------------------------
Subprog C_NBETP

If find(status,65,75) & [M:FRL1]CPLDAT(nolign-1)<>[0/0/0]
  mkstat=1
Endif

End

#--------------------------------------------------
Subprog C_STEPS(VALEUR)
Variable Integer VALEUR
Call UNICITE(VALEUR, [M:FRL1]STEPS) From OBJDIV
End

#--------------------------------------------------
Subprog C_MINDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR>[M]EXTDAT(nolign-1)
  mkstat=1
Endif
End

#--------------------------------------------------
Subprog C_MAXDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & (VALEUR<[M]EXTDAT(nolign-1) | VALEUR<[M]MINDAT(nolign-1))
  mkstat=1
Endif
End

#--------------------------------------------------
Subprog D_PRCINV(VALEUR)
Variable Decimal VALEUR

Local Decimal ZTX

[L]ZTX=0
For I=0 To max([M:FRL1]NBETP-1,indice)
  If I<>indice
    [L]ZTX+=[M:FRL1]PRCINV(I)
  Endif
Next
VALEUR=max(100-[L]ZTX,0)
End

#--------------------------------------------------
Subprog AM_PRCINV(VALEUR)
Variable Decimal VALEUR

Local Decimal ZPV, ZTX, ZMNT, ZQTY
Local Integer ZIND, STAT

[L]ZIND=indice

Read [F:XOP]XOP0=[M:FRL0]OPPNUM
If fstat : Raz [F:XOP] : Endif

If func SPVOBJPFM.SITMSTQTY([M:FRL0]TYPFRM)<>2

  [L]ZPV=[M:FRL1]GROPRI
  If [M:FRL1]CURFRL<>[V]GLOCALDEV
    # LBORN 02/03/2017
    # Call CONVERT([M:FRL1]CURFRL,[V]GLOCALDEV,[V]GLOCALDEV,[F:XOP]CHGTYP,datesyst,[L]ZPV,[L]ZPV,[L]STAT) From TRTDEV
    # LBORN 03/05/2017 - Mantis 34166
    # Call CONVERT([M:FRL1]CURFRL,[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,datesyst,[L]ZPV,[L]ZPV,[L]STAT) From TRTDEV
    Call CONVERT_FRL([M:FRL1]CURFRL,[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,[M:FRL0]CREDATFRM,[L]ZPV,[L]ZPV,[L]STAT) From SPVOBJFRL2
  Endif

  [L]ZTX=0
  [L]ZMNT=0
  For I=0 To max([M:FRL1]NBETP-1,indice)
    If indice<>I
      [L]ZTX+=[M:FRL1]PRCINV(I)
      [L]ZMNT+=[M:FRL1]AMTINV(I)
    Else
      [L]ZTX+=VALEUR
    Endif
  Next

  If [L]ZTX=100
    [M:FRL1]AMTINV(ZIND)=arr([L]ZPV-[L]ZMNT,[V]GARODEV)
  Else
    [M:FRL1]AMTINV(ZIND)=arr([L]ZPV*VALEUR/100,[V]GARODEV)
  Endif
  Affzo [M:FRL1]AMTINV(ZIND)

  #----- CLAVA 18/01/11
  [L]ZIND=indice

  [L]ZPV=[M:FRL1]GROPRI

  [L]ZTX=0
  [L]ZMNT=0
  For I=0 To max([M:FRL1]NBETP-1,indice)
    If indice<>I
      [L]ZTX+=[M:FRL1]PRCINV(I)
      [L]ZMNT+=[M:FRL1]AMTCUR(I)
    Else
      [L]ZTX+=VALEUR
    Endif
  Next

  If [L]ZTX=100
    [M:FRL1]AMTCUR(ZIND)=arr([L]ZPV-[L]ZMNT,[V]GARODEV)
  Else
    [M:FRL1]AMTCUR(ZIND)=arr([L]ZPV*VALEUR/100,[V]GARODEV)
  Endif
  If !GIMPORT Then Affzo [M:FRL1]AMTCUR(ZIND) Endif
  #--

Else

  If !clalev([F:TUN]) : Local File TABUNIT : Endif

  If [F:TUN]UOM<>[M:FRL1]SAU
    Read [F:TUN]TUN0=[M:FRL1]SAU
    If fstat : Raz [F:TUN] : Endif
  Endif

  [L]ZPV=[M:FRL1]QTY

  [L]ZTX=0
  [L]ZQTY=0
  For I=0 To max([M:FRL1]NBETP-1,indice)
    If indice<>I
      [L]ZTX+=[M:FRL1]PRCINV(I)
      [L]ZQTY+=[M:FRL1]QTYINV(I)
    Else
      [L]ZTX+=VALEUR
    Endif
  Next

  If [L]ZTX=100
    [M:FRL1]QTYINV(ZIND)=arr([L]ZPV-[L]ZQTY,10^([F:TUN]UOMDEC*(-1)))
  Else
    [M:FRL1]QTYINV(ZIND)=arr([L]ZPV*VALEUR/100,10^([F:TUN]UOMDEC*(-1)))
  Endif
  Affzo [M:FRL1]QTYINV(ZIND)

Endif

End

#--------------------------------------------------
Subprog D_AMTCUR(VALEUR)
Variable Decimal VALEUR

# LBORN 28/01/2015 - Mantis 27100
If func SPVOBJPFM.SITMSTQTY([M:FRL0]TYPFRM)=2 : End : Endif

Local Decimal ZPV, ZTX, ZMNT
Local Integer ZIND, STAT

#-- CLAVA 19/01/11
[L]ZIND=indice

Read [F:XOP]XOP0=[M:FRL0]OPPNUM
If fstat : Raz [F:XOP] : Endif

[L]ZPV=[M:FRL1]GROPRI

[L]ZMNT=0
For I=0 To max([M:FRL1]NBETP-1,[L]ZIND)
  If I<>indice
    [L]ZMNT+=[M:FRL1]AMTCUR(I)
  Endif
Next
VALEUR=max([L]ZPV-[L]ZMNT,0)

End

#--------------------------------------------------
Subprog AS_XNBANAOF
If nolign>GNBDIE | [M:FRL5]XFLGTRT([M:FRL5]XNUMLIG-1)=2 : End : Endif
Local Shortint XSTAT
Local Integer I, ZZLIG
[L]ZZLIG=nolign
# Déclenchement Init sections ana
Call INISEC_OF([L]XSTAT)
# Pour déclencher PSG/Actions SPE et enregistrer zone lorsque changement d'onglet sans saisie
Affzo [M:FRL5]20
For [L]I=1 To GNBDIE
  Assign "[M:FRL5]CCE"+num$([L]I)+"("+num$([M:FRL5]XNUMLIG-1)+")" With [M:FRL5]XSECOF([L]I-1)
Next
End

#--------------------------------------------------
Subprog INISEC_OF(XSTAT)
Variable Shortint XSTAT

Read [F:ITM]ITM0=[M:FRL5]ITMREFOF(max([M:FRL5]XNUMLIG,1)-1)
If fstat : Raz [F:ITM] : Endif

Local Char SECTION(20), XGAXE(30)
Local Integer ZI, SVGLIG

[L]SVGLIG=nolign
[L]XSTAT=0

[M:FRL5]XNBANAOF=GNBDIE
[M:FRL5]XFLGTRT([M:FRL5]XNUMLIG-1)=2

For [L]ZI=1 To GNBDIE
  nolign=[L]ZI
  [L]XGAXE=GDIE([L]ZI)
  If [M:FRL5]XSECOF([L]ZI-1)=""
    Call INISEC([L]SECTION,"XFRL5",[L]XGAXE) From SUBCDE
    If [L]SECTION<>""
      Call CONTROLE("CCE","#",[L]SECTION,[L]XGAXE,[L]XSTAT) From CONTOBJ
      If [L]XSTAT
        Raz [V]GMESSAGE
      Else
        [M:FRL5]XSECOF([L]ZI-1)=[L]SECTION
        Assign "[M:FRL5]CCE"+num$([L]ZI)+"("+num$([M:FRL5]XNUMLIG-1)+")" With [L]SECTION
      Endif
    Endif
  Endif
Next
nolign=[L]SVGLIG
End

#--------------------------------------------------
Subprog AS_NBLIGOF
Local Shortint XSTAT
Local Integer I, ZZLIG, ZLIG, ZI
Local Char SVGREP

[L]ZZLIG=nolign


# DEBUT #######################################
# Init dernière fiche traitée pour initialiser analytique (cas où l'on ne passe pas dans le tableau
# analytique et que l'on passe à la ligne suivante)
# Le cas du changement d'onglet sera traité en AV_Saisie du tableau Ana

# Déclenchement Init sections ana
If [M:FRL5]XNUMLIG>0 & [M:FRL5]XFLGTRT([M:FRL5]XNUMLIG-1)<>2 & [M:FRL5]ITMREFOF([M:FRL5]XNUMLIG-1)<>""
  nolign=[M:FRL5]XNUMLIG
  Call INISEC_OF([L]XSTAT)
  # Pour déclencher PSG/Actions SPE et enregistrer zone lorsque changement d'onglet sans saisie
  Affzo [M:FRL5]20
  For [L]I=1 To GNBDIE
    If [M:FRL5]XSECOF([L]I-1)<>""
      Call CONTROLE("CCE","#",[M:FRL5]XSECOF([L]I-1),GDIE([L]I),[L]XSTAT) From CONTOBJ
      If [L]XSTAT : Raz [V]GMESSAGE : Raz [M:FRL5]XSECOF([L]I-1) : Endif
    Endif
    Assign "[M:FRL5]CCE"+num$([L]I)+"("+num$([M:FRL5]XNUMLIG-1)+")" With [M:FRL5]XSECOF([L]I-1)
  Next
  nolign=[L]ZZLIG
Endif
# FIN #######################################

[L]ZLIG=nolign-1

Effzo [M:FRL5]15-99

# Pas d'affectation en création, sinon pas d'init
If [M:FRL5]ITMREFOF([L]ZLIG)<>""
  Gosub AFFECT_FRP From SPVOBJFRL
  # GREP pour éviter de redéclencher les Init en avant_zone PSG (déjà fait)
  [L]SVGREP=GREP
  If GREP="C" : GREP="M" : Endif
  Affzo [M:FRL5]15-99
  GREP=[L]SVGREP
Else
  [M:FRL5]XNUMLIG=[L]ZLIG+1
  [M:FRL5]XNBANAOF=GNBDIE
  For [L]ZI=1 To GNBDIE
    [M:FRL5]XDIEOF([L]ZI-1)=GDIE([L]ZI)
  Next
  Affzo [M:FRL5]XDIEOF
Endif

nolign=[L]ZLIG+1
Affzo [M:FRL5]ITMREFOF

End

#--------------------------------------------------
Subprog C_NBLIGOF
If status=73
  # Insertion
  Local Integer ZI
  Effzo [M:FRL5]15-99
  [M:FRL5]XNUMLIG=nolign
  [M:FRL5]XNBANAOF=GNBDIE
  For [L]ZI=1 To GNBDIE
    [M:FRL5]XDIEOF([L]ZI-1)=GDIE([L]ZI)
  Next
  Affzo [M:FRL5]XDIEOF
Endif
End

#--------------------------------------------------
Subprog AV_ITMREFOF(VALEUR)
Variable Char    VALEUR()
Local Integer ZI
For [L]ZI=1 To [M:FRL5]NBLIGOF+1
  If [L]ZI<>[M:FRL5]XNUMLIG
    Chgstl [M:FRL5]NBLIGOF([L]ZI-1) With ""
  Else
    Chgstl [M:FRL5]NBLIGOF([L]ZI-1) With "AMKCUR"
  Endif
Next
End

#--------------------------------------------------
Subprog AM_ITMREFOF(VALEUR)
Variable Char    VALEUR()

Read [F:ITM]ITM0=VALEUR
If !fstat & [F:ITM]PURFLG=2
  # Warning "Article acheté"
  GSTATUS=1 : Call AVERTIR(mess(132,[V]GXMSGOPP,1),GSTATUS) From GESECRAN
  If GSTATUS=1 : mkstat=1 : End : Endif
Endif

Local Integer ZNOL

[L]ZNOL=nolign-1

#[M:FRL5]STOMGTCOD([L]ZNOL)=[F:ITM]STOMGTCOD

Call INIT_ITM(VALEUR,[M:FRL5]ITMDESOF([L]ZNOL),[M:FRL5]UOMOF([L]ZNOL), "p") From X11TRTDIV
[M:FRL5]XITMDESOF=[M:FRL5]ITMDESOF([L]ZNOL)
[M:FRL5]XUOMOF=[M:FRL5]UOMOF([L]ZNOL)

If [M:FRL5]XUOMOF=""
  Call D_XUOMOF([M:FRL5]XUOMOF)
  [M:FRL5]UOMOF([L]ZNOL)=[M:FRL5]XUOMOF
Endif
#Call D_XPURCUR([M:FRL5]XPURCUR)
#[M:FRL5]PURCUR([L]ZNOL)=[M:FRL5]XPURCUR

nolign=[L]ZNOL+1
Affzo [FRL5]XUOMOF

nolign=[L]ZNOL+1

End

#--------------------------------------------------
Subprog C_XITMDESOF(VALEUR)
Variable Char    VALEUR()
# A cause Bug Adonix, pas de déclenchement d'init après COUZON en création
[M:FRL5]ITMDESOF([M:FRL5]XNUMLIG-1)=VALEUR
End

#--------------------------------------------------
Subprog AM_XITMDESOF(VALEUR)
Variable Char    VALEUR()
[M:FRL5]ITMDESOF([M:FRL5]XNUMLIG-1)=VALEUR
End

#--------------------------------------------------
Subprog D_XMFGFCY(VALEUR)
Variable Char    VALEUR()
If [V]GFCYDEF(8)<>""
  VALEUR=[V]GFCYDEF(8)
Elsif [M:FRL5]ITMREFOF([M:FRL5]XNUMLIG-1)=""
  For [F:FCY]FCY0 Where [F:FCY]MFGFLG=2
    VALEUR=[F:FCY]FCY : Break
  Next
Endif
End

#--------------------------------------------------
Subprog AM_XMFGFCY(VALEUR)
Variable Char    VALEUR()
[M:FRL5]MFGFCY([M:FRL5]XNUMLIG-1)=VALEUR
Local Date ZDEB
[L]ZDEB=[M:FRL0]CREDATFRM
Call AFF_COUT(max([M:FRL5]XCSTTYP,1),[L]ZDEB,[M:FRL5]ITMREFOF([M:FRL5]XNUMLIG-1),VALEUR,[M:FRL5]MATCST([M:FRL5]XNUMLIG-1),[M:FRL5]MACCST([M:FRL5]XNUMLIG-1)
&           ,[M:FRL5]LABCST([M:FRL5]XNUMLIG-1),[M:FRL5]SCOCST([M:FRL5]XNUMLIG-1),[M:FRL5]OVECST([M:FRL5]XNUMLIG-1),[M:FRL5]CSTTOT([M:FRL5]XNUMLIG-1)
&           ,[M:FRL5]CSTTOT2([M:FRL5]XNUMLIG-1),[M:FRL5]CLCQTY([M:FRL5]XNUMLIG-1),[M:FRL5]COEOF([M:FRL5]XNUMLIG-1),[M:FRL5]COSPRIOF([M:FRL5]XNUMLIG-1)) From SPVOBJFRL
End

#--------------------------------------------------
Subprog D_XUOMOF(VALEUR)
Variable Char    VALEUR()
If [M:FRL5]ITMREFOF([M:FRL5]XNUMLIG-1)<>""
  Read [ITM]ITM0=[M:FRL5]ITMREFOF([M:FRL5]XNUMLIG-1)
  If !fstat
    VALEUR=[F:ITM]STU
  Endif
Elsif find("UN",[V]GUNITE)
  VALEUR="UN"
Endif
End

#--------------------------------------------------
Subprog AM_XUOMOF(VALEUR)
Variable Char    VALEUR()
[M:FRL5]UOMOF([M:FRL5]XNUMLIG-1)=VALEUR
End

#--------------------------------------------------
Subprog AM_XQTYOF(VALEUR)
Variable Decimal VALEUR
[M:FRL5]QTYOF([M:FRL5]XNUMLIG-1)=VALEUR
End

#--------------------------------------------------
Subprog D_XCOEOF(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
  VALEUR=1
Endif
End

#--------------------------------------------------
Subprog AM_XCOEOF(VALEUR)
Variable Decimal VALEUR
Raz [M:FRL5]COSPRIOF([M:FRL5]XNUMLIG-1)
Raz [M:FRL5]XCOSPRIOF
Raz [M:FRL5]DISPRIOF([M:FRL5]XNUMLIG-1)
Raz [M:FRL5]XDISPRIOF
[M:FRL5]COEOF([M:FRL5]XNUMLIG-1)=VALEUR
End

#--------------------------------------------------
Subprog AS_XCOSPRIOF(VALEUR)
Variable Decimal VALEUR

If VALEUR<>0 : End : Endif

Local Decimal AUX

[L]AUX=[M:FRL5]CSTTOT2([M:FRL5]XNUMLIG-1)
VALEUR=arr([L]AUX*[M:FRL5]COEOF([M:FRL5]XNUMLIG-1),[V]GARODEV)

[M:FRL5]COSPRIOF([M:FRL5]XNUMLIG-1)=VALEUR
If !GIMPORT : Affzo [M:FRL1] : Endif

End

#--------------------------------------------------
Subprog AM_XCOSPRIOF(VALEUR)
Variable Decimal VALEUR

Local Decimal AUX

# Prix net en devise achat
[L]AUX=[M:FRL5]CSTTOT2([M:FRL5]XNUMLIG-1)
If [L]AUX=0
  [M:FRL5]COEOF([M:FRL5]XNUMLIG-1)=1
  [M:FRL5]XCOEOF=1
Else
  [M:FRL5]COEOF([M:FRL5]XNUMLIG-1)=arr([L]VALEUR/[L]AUX,10^(len(num$(fix([L]VALEUR/[L]AUX)))-11))
  [M:FRL5]XCOEOF=[M:FRL5]COEOF([M:FRL5]XNUMLIG-1)
Endif
If [M:FRL5]XCOEOF=0
  [M:FRL5]COEOF([M:FRL5]XNUMLIG-1)=1
  [M:FRL5]XCOEOF=1
Endif
If !GIMPORT
  Affzo [M:FRL5]XCOEOF
Endif
[M:FRL5]COSPRIOF([M:FRL5]XNUMLIG-1)=VALEUR
If !GIMPORT : Affzo [M:FRL1] : Endif

End

#--------------------------------------------------
Subprog AS_XDISPRIOF(VALEUR)
Variable Decimal VALEUR
If [M:FRL5]COSPRIOF([M:FRL5]XNUMLIG-1)=0
  [M:FRL5]DISPRIOF([M:FRL5]XNUMLIG-1)=0
  mkstat=1
Endif
End

#--------------------------------------------------
Subprog AM_XDISPRIOF(VALEUR)
Variable Decimal VALEUR
[M:FRL5]DISPRIOF([M:FRL5]XNUMLIG-1)=VALEUR
End

#--------------------------------------------------
Subprog C_XNBANAOF
Local Shortint XSTAT

If [V]GXOPTOPR
  Call SUM_OF([M:FRL1]MFGCOS) From SPVOBJFRL
  If !GIMPORT: Affzo [M:FRL1]17 : Endif
Endif

End

#--------------------------------------------------
Subprog C_XSECOF(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" | [V]XFRLTYP : End : Endif
Local Integer J
Read [F:PFM]PFM0=[M:FRL0]TYPFRM
If !fstat
  [L]J=find([M:FRL5]XDIEOF(nolign-1),[F:PFM]FLPDIE)
  If [L]J>0 & [F:PFM]FLPCCE([L]J-1)=2
    GMESSAGE=mess(10,123,1)
    GERR=1
    mkstat=1
  Endif
Endif
End

#--------------------------------------------------
Subprog AM_XSECOF(VALEUR)
Variable Char    VALEUR()
Assign "[M:FRL5]CCE"+num$(nolign)+"("+num$([M:FRL5]XNUMLIG-1)+")" With VALEUR
End

#--------------------------------------------------
Subprog AM_XCSTTYP(VALEUR)
Variable Integer VALEUR

Local Date ZDEB
[L]ZDEB=[M:FRL0]CREDATFRM

[M:FRL5]CSTTYP([M:FRL5]XNUMLIG-1)=VALEUR

Raz [M:FRL5]XCOSPRIOF
Raz [M:FRL5]COSPRIOF([M:FRL5]XNUMLIG-1)

Call AFF_COUT(VALEUR,[L]ZDEB,[M:FRL5]ITMREFOF([M:FRL5]XNUMLIG-1),[M:FRL5]XMFGFCY,[M:FRL5]MATCST([M:FRL5]XNUMLIG-1),[M:FRL5]MACCST([M:FRL5]XNUMLIG-1)
&           ,[M:FRL5]LABCST([M:FRL5]XNUMLIG-1),[M:FRL5]SCOCST([M:FRL5]XNUMLIG-1),[M:FRL5]OVECST([M:FRL5]XNUMLIG-1),[M:FRL5]CSTTOT([M:FRL5]XNUMLIG-1)
&           ,[M:FRL5]CSTTOT2([M:FRL5]XNUMLIG-1),[M:FRL5]CLCQTY([M:FRL5]XNUMLIG-1),[M:FRL5]COEOF([M:FRL5]XNUMLIG-1),[M:FRL5]COSPRIOF([M:FRL5]XNUMLIG-1)) From SPVOBJFRL

If !GIMPORT
  Affzo [M:FRL5]XCOEOF,XCOSPRIOF
Endif

End

#--------------------------------------------------
Subprog CL_XICOTYP(VALEUR)
Variable Char    VALEUR()
[V]GBIDC1=[M:FRL5]XMFGFCY
[V]GBIDC2=[M:FRL5]ITMREFOF([M:FRL5]XNUMLIG-1)
GFLTITM =[V]GBIDC2
GFLTFCY =[V]GBIDC1
Case [M:FRL5]XCSTTYP
  When 1 : Call OBJET("ICD",[V]GBIDC1,[V]GBIDC2) From GOBJET
  When 2 : Call OBJET("ICA",[V]GBIDC1,[V]GBIDC2) From GOBJET
  When 3 : Call OBJET("ICB",[V]GBIDC1,[V]GBIDC2) From GOBJET
  When 4 : Call OBJET("ICS",[V]GBIDC1,[V]GBIDC2) From GOBJET
Endcase
End

