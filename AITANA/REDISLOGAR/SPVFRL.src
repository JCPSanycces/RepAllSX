Subprog AS_BUDCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If !clalev([F:XST]) : Local File SITUATION  : Endif
If !clalev([F:SL1]) : Local File SITUATIONL : Endif
Filter [F:SL1] Where [F:SL1]FRMNUMLIG=[M:FRL0]FRMNUMLIG
For [F:SL1]SL13(2) Hint Key SL13
  Read [F:XST]XST0=[F:SL1]SITNUM
  If !fstat & [F:XST]BUDFLG=2
    mkstat=2
  Endif
Next
Filter [F:SL1]
End

