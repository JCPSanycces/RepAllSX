Next
End

######################################################################################
Subprog AV_CUMGROPRIA(VALEUR)
Variable Decimal VALEUR
Raz VALEUR
Local Integer I, STAT
Local Decimal AUX
For [L]I=0 To [M:FRL2]NBLIG-1
  [L]AUX=[M:FRL2]GROPRIPUR([L]I)
  If [L]AUX<>0 & [M:FRL2]PURCUR([L]I)<>[V]GLOCALDEV
    Call CONVERT([M:FRL2]PURCUR([L]I),[V]GLOCALDEV,[V]GLOCALDEV,[M:FRL2]CURTYP([L]I),datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
  Endif
  VALEUR+=arr([L]AUX,[V]GARODEV)*[M:FRL2]QTYUOM([L]I)
Next
End

######################################################################################
Subprog AV_CUMPVA(VALEUR)
Variable Decimal VALEUR
Raz VALEUR
Local Integer I
For [L]I=0 To [M:FRL2]NBLIG-1
  VALEUR+=arr([M:FRL2]COSPRIPUR([L]I),[V]GARODEV)*[M:FRL2]QTYUOM([L]I)
Next
End

