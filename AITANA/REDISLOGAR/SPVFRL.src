Subprog APRES_NBREM

Local Integer OK

Read [F:XOP]XOP0=[M:FRL0]OPPNUM
If fstat : Raz [F:XOP] : Endif

Gosub INIT_ZREM From SPVOBJFRL

# LBORN 02/03/2017
# Call CAL_NETAMT([M:FRL1]NETAMT,[M:FRL1]GROPRI,[L]ZREM,[M:FRL1]QTY,[M:FRL1]CURFRL,[F:XOP]CHGTYP,[L]OK) From SPVOBJFRL
# LBORN 03/05/2017 - Mantis 34166
# Call CAL_NETAMT([M:FRL1]NETAMT,[M:FRL1]GROPRI,[L]ZREM,[M:FRL1]QTY,[M:FRL1]CURFRL,[F:OPP]CHGTYP,[L]OK) From SPVOBJFRL
Call CAL_NETAMT([M:FRL1]NETAMT,[M:FRL1]GROPRI,[L]ZREM,[M:FRL1]QTY,[M:FRL1]CURFRL,[F:OPP]CHGTYP,[M:FRL0]CREDATFRM,[L]OK) From SPVOBJFRL

If ![L]OK
  Call AVERTIR([V]GMESSAGE,[L]OK) From GESECRAN
Endif

If !GIMPORT: Affzo [M:FRL1]17: Endif

End

