CLE1=""
GBIDC1=""
GBIDC2=""
Call OBJET("FRL",GBIDC1,GBIDC2) From GOBJET
End

#==========================================================================================
# Gestion de l'objet   : Gestion de l'objet Bordereaux (lignes)
#
# Auteur               :
# Date de création     :
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 12/09/2003    OTHYR        Ajout des étiquettes AVANTBOUT et ABANDON pour gestion des textes
# 14/01/2004    LBORN        Passage des écrans FRL2 et FRL3 en mode <Fiche>
# 17/01/2005    LBORN        Passage en version 140
#==========================================================================================

$ACTION
# Appel fonctions complémentaires GFI pour l'objet FRL
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Gosub ACTION From SPVOBJFRL

Return


#######################################################
# Ecran FRL0
#######################################################

#---------------------------------------
Subprog AS_AUTVAL(VALEUR)
Variable Integer VALEUR
If find(GREP,"C","D") | [V]XFRLTYP
  mkstat=1
Elsif [M:FRL0]VLYFLG=2
  mkstat=2
Endif
End


#---------------------------------------
Subprog D_FRLMDL(VALEUR)
Variable Integer VALEUR
If [V]XFRLTYP=1
  VALEUR=2
Else
  VALEUR=1
Endif
End


#######################################################
# Ecran FRL1
#######################################################

#---------------------------------------
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

Call CTRLSTA_ITMFRL(VALEUR) From SPVOBJFRL
If mkstat : End : Endif

Call INIT_ITM(VALEUR,[M:FRL1]ITMDES,[M:FRL1]SAU,"v") From X11TRTDIV
Call ACTGRIZ_ITM(VALEUR) From SPVOBJFRL
If !GIMPORT
  Affzo [M:FRL1]ITMDES
  Affzo [M:FRL1]SAU
Endif

Gosub FRL1_GROPRI From SPVOBJFRL
If !GIMPORT : Affzo [M:FRL1]GROPRI : Endif

End


#---------------------------------------
Subprog AM_INVMOD(VALEUR)
Variable Integer VALEUR

If find(VALEUR,4,5) & [M:FRL1]GROPRI<>0
  GSTATUS=1
  If sum([M:FRL1]AMTINV)=0
    GSTATUS=2
  Else
    Call OUINON(mess(1,[V]GXMSGOPP,1),GSTATUS) From GESECRAN
  Endif
  If GSTATUS=2
    Call RECAL_AMTINV([M:FRL1]QTY,[M:FRL1]GROPRI,[M:FRL1]CURFRL) From SPVOBJFRL
  Endif
Endif
Call ACTGRIZ_INVMOD(VALEUR) From SPVOBJFRL

# LBORN 10/01/2014 - Mantis 22947
If VALEUR=9 & !GIMPORT & [V]GXOPTCON
  ## Action XFRLCON
  Local Char    PARMSK(250)(1..20) , SAVACT(20), XVAL
  SAVACT = GACTION : GACTION = "XFRLCON"
  PARMSK(1) = [M:FRL0]FRMNUMLIG
  Call SAISIE_CHAR([L]XVAL,PARMSK,"XFRLCON","XFRLCON","YFRLCON") From GSAISIE
  GACTION = SAVACT
Endif

End


#---------------------------------------
Subprog AS_INVMOD(VALEUR)
Variable Integer VALEUR
If ![V]XFRLTYP
  GMENLOC(7)=1
  GMENLOC(8)=1

  # LBORN 08/01/2014 - Mantis 22947
  If ![V]GXOPTCON
    GMENLOC(9)=1
  Endif

Endif
End


#---------------------------------------
Subprog AS_SAU(VALEUR)
Variable Char    VALEUR()
If [M:FRL1]ITMREF=""
  mkstat=1 : End
Endif

If VALEUR=""
  Read [ITM]ITM0=[M:FRL1]ITMREF
  If !fstat
    VALEUR=[F:ITM]SAU
  Endif
Endif
[V]GBIDC1=[M:FRL7]BPCINV

End



#---------------------------------------
Subprog AS_CURFRL(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & ![V]XFRLTYP
  VALEUR=[OPP]CUR
  If VALEUR=""
    VALEUR=[V]GLOCALDEV
  Endif
Endif
End


#---------------------------------------
Subprog D_INVMOD(VALEUR)
Variable Integer VALEUR
If ![V]XFRLTYP
  Read [F:XOP]XOP0=[M:FRL0]OPPNUM
  If !fstat
    VALEUR=max([XOP]INVMOD,1)
  Else
    VALEUR=1
  Endif
Else
  VALEUR=7
Endif
End

#---------------------------------------
Subprog AV_LOCALDEV(VALEUR)
Variable Char    VALEUR()
VALEUR=[V]GLOCALDEV
End


#--------------------------------------------------
Subprog AM_GROPRI(VALEUR)
Variable Decimal VALEUR

If find([M:FRL1]INVMOD,4,5)

  If func SPVOBJPFM.SITMSTQTY([M:FRL0]TYPFRM)<>2

    GSTATUS=1
    If sum([M:FRL1]AMTINV)=0
      GSTATUS=2
    Else
      Call OUINON(mess(1,[V]GXMSGOPP,1),GSTATUS) From GESECRAN
    Endif
    If GSTATUS=2
      Call RECAL_AMTINV([M:FRL1]QTY,VALEUR,[M:FRL1]CURFRL) From SPVOBJFRL
    Endif

  Else

    Local Integer ZI, STAT
    Local Decimal ZPV
    [L]ZPV=VALEUR
    If [M:FRL1]CURFRL<>[V]GLOCALDEV
      # LBORN 02/03/2017
      # Call CONVERT([M:FRL1]CURFRL,[V]GLOCALDEV,[V]GLOCALDEV,[F:XOP]CHGTYP,datesyst,[L]ZPV,[L]ZPV,[L]STAT) From TRTDEV
      # LBORN 03/05/2017 - Mantis 34166
      # Call CONVERT([M:FRL1]CURFRL,[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,datesyst,[L]ZPV,[L]ZPV,[L]STAT) From TRTDEV
      Call CONVERT_FRL([M:FRL1]CURFRL,[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,[M:FRL0]CREDATFRM,[L]ZPV,[L]ZPV,[L]STAT) From SPVOBJFRL2
    Endif

    For [L]ZI=0 To [M:FRL1]NBETP-1
      [M:FRL1]AMTINV([L]ZI)=[L]ZPV
      [M:FRL1]AMTCUR([L]ZI)=VALEUR
    Next
    If [M:FRL1]CURFRL<>[V]GLOCALDEV
      Affzo [M:FRL1]AMTINV, AMTCUR
    Else
      Affzo [M:FRL1]AMTCUR
    Endif
  Endif

Endif
End

#--------------------------------------------------
Subprog AM_CURFRL(VALEUR)
Variable Char    VALEUR()

If find([M:FRL1]INVMOD,4,5) & [M:FRL1]GROPRI<>0

  If func SPVOBJPFM.SITMSTQTY([M:FRL0]TYPFRM)<>2

    GSTATUS=1
    If sum([M:FRL1]AMTINV)=0
      GSTATUS=2
    Else
      Call OUINON(mess(1,[V]GXMSGOPP,1),GSTATUS) From GESECRAN
    Endif
    If GSTATUS=2
      Call RECAL_AMTINV([M:FRL1]QTY,[M:FRL1]GROPRI,VALEUR) From SPVOBJFRL
    Endif

  Else

    Local Integer ZI, STAT
    Local Decimal ZPV
    [L]ZPV=[M:FRL1]GROPRI
    If VALEUR<>[V]GLOCALDEV
      # LBORN 02/03/2017
      # Call CONVERT(VALEUR,[V]GLOCALDEV,[V]GLOCALDEV,[F:XOP]CHGTYP,datesyst,[L]ZPV,[L]ZPV,[L]STAT) From TRTDEV
      # LBORN 03/05/2017 - Mantis 34166
      # Call CONVERT(VALEUR,[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,datesyst,[L]ZPV,[L]ZPV,[L]STAT) From TRTDEV
      Call CONVERT_FRL(VALEUR,[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,[M:FRL0]CREDATFRM,[L]ZPV,[L]ZPV,[L]STAT) From SPVOBJFRL2
    Endif

    For [L]ZI=0 To [M:FRL1]NBETP-1
      [M:FRL1]AMTINV([L]ZI)=[L]ZPV
      [M:FRL1]AMTCUR([L]ZI)=[M:FRL1]GROPRI
    Next
    Affzo 30

  Endif

Endif

# LBORN 13/03/2012 - Sinon non raffraichi
[M:FRL1]CURFRL=VALEUR
Affzo [M:FRL1]AMTCUR
Gosub ACTGRIZ_AMTINV From SPVOBJFRL

End


#---------------------------------------
Subprog AP_GROPRI(VALEUR)
Variable Decimal VALEUR

Local Integer K, OK

Read [F:XOP]XOP0=[M:FRL0]OPPNUM
If fstat : Raz [F:XOP] : Endif

Gosub INIT_ZREM From SPVOBJFRL

# LBORN 02/03/2017
# Call CAL_NETAMT([M:FRL1]NETAMT,VALEUR,[L]ZREM,[M:FRL1]QTY,[M:FRL1]CURFRL,[F:XOP]CHGTYP,[L]OK) From SPVOBJFRL
# LBORN 03/05/2017 - Mantis 34166
# Call CAL_NETAMT([M:FRL1]NETAMT,VALEUR,[L]ZREM,[M:FRL1]QTY,[M:FRL1]CURFRL,[F:OPP]CHGTYP,[L]OK) From SPVOBJFRL
Call CAL_NETAMT([M:FRL1]NETAMT,VALEUR,[L]ZREM,[M:FRL1]QTY,[M:FRL1]CURFRL,[F:OPP]CHGTYP,[M:FRL0]CREDATFRM,[L]OK) From SPVOBJFRL

If ![L]OK
  Call AVERTIR([V]GMESSAGE,[L]OK) From GESECRAN
Endif

[M:FRL1]GROPRI=VALEUR
If !GIMPORT: Affzo [M:FRL1]17: Endif
End

#---------------------------------------
Subprog AP_QTY(VALEUR)
Variable Decimal VALEUR

Local Integer OK

Read [F:XOP]XOP0=[M:FRL0]OPPNUM
If fstat : Raz [F:XOP] : Endif

Gosub INIT_ZREM From SPVOBJFRL

# LBORN 02/03/2017
# Call CAL_NETAMT([M:FRL1]NETAMT,[M:FRL1]GROPRI,[L]ZREM,VALEUR,[M:FRL1]CURFRL,[F:XOP]CHGTYP,[L]OK) From SPVOBJFRL
# LBORN 03/05/2017 - Mantis 34166
# Call CAL_NETAMT([M:FRL1]NETAMT,[M:FRL1]GROPRI,[L]ZREM,VALEUR,[M:FRL1]CURFRL,[F:OPP]CHGTYP,[L]OK) From SPVOBJFRL
Call CAL_NETAMT([M:FRL1]NETAMT,[M:FRL1]GROPRI,[L]ZREM,VALEUR,[M:FRL1]CURFRL,[F:OPP]CHGTYP,[M:FRL0]CREDATFRM,[L]OK) From SPVOBJFRL

If ![L]OK
  Call AVERTIR([V]GMESSAGE,[L]OK) From GESECRAN
Endif

[M:FRL1]QTY=VALEUR
If !GIMPORT: Affzo [M:FRL1]17: Endif
End

#---------------------------------------
Subprog AV_PFMB(VALEUR)
Variable Decimal VALEUR
If [V]GXOPTOPR
  Call CAL_PFMB("M",VALEUR,[M:FRL1]NETAMT,[M:FRL1]BUYCOS+[M:FRL1]MFGCOS) From SPVOBJFRL
Else
  Call CAL_PFMB("M",VALEUR,[M:FRL1]NETAMT,[M:FRL1]BUYCOS) From SPVOBJFRL
Endif
End

#---------------------------------------
Subprog AV_PFMBP(VALEUR)
Variable Char    VALEUR

Local    Decimal P

Call CAL_POURCENT(P,[M:FRL1]NETAMT,[M:FRL1]PFMB) From SPVOBJFRL
VALEUR = num$(P)-"%"
End

#---------------------------------------
Subprog AV_PFMN(VALEUR)
Variable Decimal VALEUR
Call CAL_PFMN("M",VALEUR,[M:FRL1]PFMB,[M:FRL1]REQCOS) From SPVOBJFRL
End

#---------------------------------------
Subprog AV_PFMNP(VALEUR)
Variable Char    VALEUR

Local    Decimal P

Call CAL_POURCENT(P,[M:FRL1]NETAMT,[M:FRL1]PFMN) From SPVOBJFRL
VALEUR = num$(P)-"%"
End

#---------------------------------------
Subprog AV_COSPRI(VALEUR)
Variable Decimal VALEUR

Local Integer I, STAT, OK

If find([V]GREP,"C","D","M")

  VALEUR=0

  # Achat
  For [L]I=0 To [M:FRL2]NBLIG-1
    VALEUR+=ar2([M:FRL2]COSPRIPUR([L]I)*(1-[M:FRL2]DISPRIPUR([L]I)/100)*[M:FRL2]QTYUOM([L]I))
  Next

  # Production
  If [V]GXOPTOPR
    For [L]I=0 To [M:FRL5]NBLIGOF-1
      VALEUR+=ar2([M:FRL5]COSPRIOF([L]I)*(1-[M:FRL5]DISPRIOF([L]I)/100)*[M:FRL5]QTYOF([L]I))
    Next
  Endif

  # DS
  For [L]I=0 To [M:FRL3]NBLIGFRL3-1
    VALEUR+=ar2([M:FRL3]COSPRIDS([L]I)*(1-[M:FRL3]DISPRIDS([L]I)/100)*[M:FRL3]EXTQTY([L]I))
  Next

  If [M:FRL1]CURFRL<>[V]GLOCALDEV
    Read [F:XOP]XOP0=[M:FRL0]OPPNUM
    If fstat : Raz [F:XOP] : Endif

    # LBORN 02/03/2017
    # Call CONVERT([V]GLOCALDEV,[M:FRL1]CURFRL,[V]GLOCALDEV,[F:XOP]CHGTYP,datesyst,VALEUR,VALEUR,STAT) From TRTDEV
    # LBORN 03/05/2017 - Mantis 34166
    # Call CONVERT([V]GLOCALDEV,[M:FRL1]CURFRL,[V]GLOCALDEV,[F:OPP]CHGTYP,datesyst,VALEUR,VALEUR,STAT) From TRTDEV
    Call CONVERT_FRL([V]GLOCALDEV,[M:FRL1]CURFRL,[V]GLOCALDEV,[F:OPP]CHGTYP,[M:FRL0]CREDATFRM,VALEUR,VALEUR,STAT) From SPVOBJFRL2

  Endif

  If [M:FRL1]QTY=0
    [L]VALEUR=0
  Else
    [L]VALEUR=ar2([L]VALEUR/[M:FRL1]QTY)
  Endif

Endif
End


#---------------------------------------
Subprog AS_NBAXEFRL
Read [F:XOP]XOP0=[M:FRL0]OPPNUM
If fstat : Raz [F:OPP] : Endif

Read [F:ITM]ITM0=[M:FRL1]ITMREF
If fstat : Raz [F:ITM] : Endif

Local Char SECTION(20), SVGREP, XGAXE(30)
Local Integer ZI, ZZ
Local Shortint XSTAT
[M:FRL1]NBAXEFRL=GNBDIE
[L]ZZ=nolign
For [L]ZI=1 To GNBDIE
  If [M:FRL1]CCE([L]ZI-1)="" & [M:FRL1]XFLGTRT([L]ZI-1)<>2
    nolign=[L]ZI
    [L]XGAXE=GDIE([L]ZI)
    If [L]XGAXE<>"" & find([L]XGAXE,[F:XOP]DIE)>0
      [L]SECTION=[F:XOP]CCE(find([L]XGAXE,[F:XOP]DIE)-1)
    Else
      [L]SECTION=""
    Endif
    If [L]SECTION=""
      Call INISEC([L]SECTION,"XFRL1",[L]XGAXE) From SUBCDE
    Endif
    If [L]SECTION<>""
      Call CONTROLE("CCE","#",[L]SECTION,[L]XGAXE,[L]XSTAT) From CONTOBJ
      If [L]XSTAT
        Raz [V]GMESSAGE
      Else
        [M:FRL1]CCE([L]ZI-1)=[L]SECTION
      Endif
    Endif
  Endif
Next
nolign=[L]ZZ

If !GIMPORT
  [L]SVGREP=GREP
  If find(2,[M:FRL1]XFLGTRT(0..GNBDIE-1))
    GREP="M" : Affzo [M:FRL1]20
  Else
    # Pour déclencher PSG si changement d'onglet sans passage sur le tableau analytique
    GREP="C" : Affzo [M:FRL1]20
  Endif
  GREP=[L]SVGREP
Endif
End

#---------------------------------------
Subprog AM_CCE(VALEUR)
Variable Char    VALEUR()
[M:FRL1]XFLGTRT(nolign-1)=2
End

#---------------------------------------
Subprog D_SALFCY(VALEUR)
Variable Char    VALEUR()
Read [F:OPP]OPP0=[M:FRL0]OPPNUM
If !fstat
  VALEUR=[F:OPP]SALFCY
Endif
End

#---------------------------------------
Subprog AS_SALFCY(VALEUR)
Variable Char    VALEUR()
[V]GBIDC1=""
If [M:FRL0]OPPNUM<>""
  Read [F:OPP]OPP0=[M:FRL0]OPPNUM
  If !fstat & [F:OPP]SALFCY<>""
    Read [F:FCY]FCY0=[F:OPP]SALFCY
    If !fstat : [V]GBIDC1=[F:FCY]LEGCPY : Endif
  Endif
Endif
End

#---------------------------------------
Subprog C_CCE(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" | [V]XFRLTYP : End : Endif
Local Integer J
Read [F:PFM]PFM0=[M:FRL0]TYPFRM
If !fstat
  [L]J=find([M:FRL1]DIE(nolign-1),[F:PFM]FRLDIE)
  If [L]J>0 & ([F:PFM]FRLCCE([L]J-1)=2 | evalue("GOBLDIE("+num$([L]J)+")")=2) & [M:FRL1]ITMREF<>"" & [M:FRL1]INVMOD>1
    GMESSAGE=mess(10,123,1)
    GERR=1
    mkstat=1
  Endif
Endif
End


#######################################################
# Ecran FRL2
#######################################################

#---------------------------------------
Subprog AV_BPSNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=chr$(255)
  VALEUR=""
Endif
End

#---------------------------------------
Subprog AV_ITMREFPUR(VALEUR)
Variable Char    VALEUR()
Local Integer ZI
For [L]ZI=1 To [M:FRL2]NBLIG+1
  If [L]ZI<>[M:FRL2]XNUMLIG
    Chgstl [M:FRL2]NBLIG([L]ZI-1) With ""
  Else
    Chgstl [M:FRL2]NBLIG([L]ZI-1) With "AMKCUR"
  Endif
Next
End

#---------------------------------------
Subprog D_CHRACHAT(VALEUR)
Variable Decimal VALEUR
VALEUR=max([M:FRL2]CHRACHAT)+1
End


#---------------------------------------
Subprog AM_ITMREFPUR(VALEUR)
Variable Char    VALEUR()

If [V]GXOPTOPR
  Read [F:ITM]ITM0=VALEUR
  # LBORN 06/07/2016
  # If !fstat & [F:ITM]MFGFLG=2
  If !fstat & [F:ITM]MFGFLG=2 & !GIMPORT
    # Warning "Article fabriqué"
    GSTATUS=1 : Call AVERTIR(mess(133,[V]GXMSGOPP,1),GSTATUS) From GESECRAN
    If GSTATUS=1 : mkstat=1 : End : Endif
  Endif
Endif

Local Integer ZNOL

[L]ZNOL=nolign-1

[M:FRL2]STOMGTCOD([L]ZNOL)=[F:ITM]STOMGTCOD

Call INIT_ITM(VALEUR,[M:FRL2]ITMDESPUR([L]ZNOL),[M:FRL2]UOM([L]ZNOL), "a") From X11TRTDIV
[M:FRL2]XITMDESPUR=[M:FRL2]ITMDESPUR([L]ZNOL)
[M:FRL2]XUOM=[M:FRL2]UOM([L]ZNOL)

If [M:FRL2]XUOM=""
  Call D_XUOM([M:FRL2]XUOM)
  [M:FRL2]UOM([L]ZNOL)=[M:FRL2]XUOM
Endif
Call D_XPURCUR([M:FRL2]XPURCUR)
[M:FRL2]PURCUR([L]ZNOL)=[M:FRL2]XPURCUR

nolign=[L]ZNOL+1
Affzo [FRL2]XUOM,XPURCUR

If [M:FRL2]BPSNUM([L]ZNOL)=""
  [M:FRL2]BPSNUM([L]ZNOL)=chr$(255)
Endif

nolign=[L]ZNOL+1

End


#---------------------------------------
Subprog AV_STOMGTCOD(VALEUR)
Variable Integer VALEUR
Read [F:ITM]ITM0=[M:FRL2]ITMREFPUR(nolign-1)
If !fstat
  VALEUR=[F:ITM]STOMGTCOD
Else
  VALEUR=0
Endif
End




#---------------------------------------
Subprog AV_XNETAMTPUR(VALEUR)
Variable Decimal VALEUR

If [M:FRL2]XNUMLIG<=0 | [M:FRL2]NBLIG=0 : End : Endif

If !find(GREP,"C","D","M") : End : Endif

Local Integer J, STAT, ZNBREM
Local Decimal AUX, ZREM(9)

# Prix d'achat net en devise locale
Raz [L]ZREM,[L]ZNBREM

If dim([M:FRL2]DISPUR)>0
  [L]ZREM(0)=[M:FRL2]DISPUR([M:FRL2]XNUMLIG-1) : [L]ZNBREM+=1
Endif

For [L]J=2 To 9
  If evalue("dim([M:FRL2]DISPUR"+num$([L]J)+")>0")
    [L]ZREM([L]ZNBREM)=evalue("[M:FRL2]DISPUR"+num$([L]J)+"([M:FRL2]XNUMLIG-1)") : [L]ZNBREM+=1
  Endif
Next

# Prix net en devise achat
[L]AUX=[M:FRL2]GROPRIPUR([M:FRL2]XNUMLIG-1)
Call CALNET(2,"",[M:FRL2]GROPRIPUR([M:FRL2]XNUMLIG-1),[L]ZREM,[M:FRL2]QTYUOM([M:FRL2]XNUMLIG-1),[L]AUX,GSYSCUR) From TRTPRICE
[M:FRL2]GROPRINET([M:FRL2]XNUMLIG-1)=[L]AUX*[M:FRL2]QTYUOM([M:FRL2]XNUMLIG-1)

# Prix net en devise locale
[L]AUX=[M:FRL2]GROPRINET([M:FRL2]XNUMLIG-1)
If [L]AUX<>0 & [M:FRL2]PURCUR([M:FRL2]XNUMLIG-1)<>[V]GLOCALDEV
  Call CONVERT([M:FRL2]PURCUR([M:FRL2]XNUMLIG-1),[V]GLOCALDEV,[V]GLOCALDEV,[M:FRL2]CURTYP([M:FRL2]XNUMLIG-1),datesyst,[L]AUX,[L]AUX,[L]STAT) From TRTDEV
Endif
[L]VALEUR=arr([L]AUX,[V]GARODEV)
[M:FRL2]NETAMTPUR([M:FRL2]XNUMLIG-1)=[L]VALEUR


End


#--------------------------------------------------
Subprog D_XCOEPUR(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
  VALEUR=1
Endif
End


#--------------------------------------------------
Subprog AM_XDISPUR(VALEUR)
Variable Decimal VALEUR
Raz [M:FRL2]COSPRIPUR([M:FRL2]XNUMLIG-1)
Raz [M:FRL2]DISPRIPUR([M:FRL2]XNUMLIG-1)
Raz [M:FRL2]XCOSPRIPUR
Raz [M:FRL2]XDISPRIPUR
[M:FRL2]DISPUR([M:FRL2]XNUMLIG-1)=VALEUR
End

#--------------------------------------------------
Subprog AM_XDISPUR2(VALEUR)
Variable Decimal VALEUR
Raz [M:FRL2]COSPRIPUR([M:FRL2]XNUMLIG-1)
Raz [M:FRL2]DISPRIPUR([M:FRL2]XNUMLIG-1)
Raz [M:FRL2]XCOSPRIPUR
Raz [M:FRL2]XDISPRIPUR
[M:FRL2]DISPUR2([M:FRL2]XNUMLIG-1)=VALEUR
End

#--------------------------------------------------
Subprog AM_XDISPUR3(VALEUR)
Variable Decimal VALEUR
Raz [M:FRL2]COSPRIPUR([M:FRL2]XNUMLIG-1)
Raz [M:FRL2]DISPRIPUR([M:FRL2]XNUMLIG-1)
Raz [M:FRL2]XCOSPRIPUR
Raz [M:FRL2]XDISPRIPUR
[M:FRL2]DISPUR3([M:FRL2]XNUMLIG-1)=VALEUR
End

#--------------------------------------------------
Subprog AM_XDISPUR4(VALEUR)
Variable Decimal VALEUR
Raz [M:FRL2]COSPRIPUR([M:FRL2]XNUMLIG-1)
Raz [M:FRL2]DISPRIPUR([M:FRL2]XNUMLIG-1)
Raz [M:FRL2]XCOSPRIPUR
Raz [M:FRL2]XDISPRIPUR
[M:FRL2]DISPUR4([M:FRL2]XNUMLIG-1)=VALEUR
End

