Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

GFCY=VALEUR
Gosub CHARG_PARAM From SPVOBJFRL
Call RAFFRAICHI_ANA From SPVOBJFRL

# LBORN 26/02/2010 - Ré-init en fonction des exceptions Tiers/Société
If [M:FRL7]PTE<>"" | ![V]XFRLTYP
  Call INIPTE ([M:FRL7]BPCPYR,[M:FRL7]BPCINV,"C",[M:FRL7]PTE) From TRTX3
  If !GIMPORT : Affzo [M:FRL7]PTE : Endif
Endif
If [M:FRL1]VACBPR<>"" | ![V]XFRLTYP
  Call INIT_REGIME([M:FRL7]BPCINV,GSOCIETE,"C",[M:FRL1]VACBPR) From CPTSUB
