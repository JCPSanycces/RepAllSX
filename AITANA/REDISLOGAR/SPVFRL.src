#--------------------------------------------------
Subprog C_ITMREFOF(VALEUR)
Variable Char    VALEUR()

# Vérif Catégorie fantôme
If !clalev([F:ITM]) : Local File ITMMASTER : Endif
If !clalev([F:ITG]) : Local File ITMCATEG  : Endif
Read [F:ITM]ITM0=VALEUR
If !fstat
  Read [F:ITG]ITG1(1)=[F:ITM]TCLCOD
  If !fstat & [F:ITG]PHAFLG=2
    [V]GMESSAGE=VALEUR-":"-mess(27,[V]GXMSGPSA(1),1)
    [V]GERR=1
    mkstat=1
  Endif
Endif

End


