######################################################################################
Subprog AM_AMTCUR(VALEUR)
Variable Decimal VALEUR

#----- CLAVA 18/01/11
Local Decimal ZPV, ZTX, ZMNT
Local Integer ZIND, STAT

[L]ZIND=nolign-1

[L]ZPV=[M:FRL1]GROPRI

[M:FRL1]PRCINV([L]ZIND)=0

[L]ZTX=0
[L]ZMNT=0
For I=0 To max([M:FRL1]NBETP-1,[L]ZIND)
  If [L]ZIND<>I
    [L]ZTX+=[M:FRL1]PRCINV(I)
    [L]ZMNT+=[M:FRL1]AMTCUR(I)
  Else
    [L]ZMNT+=VALEUR
  Endif
Next

If [L]ZMNT=[L]ZPV
  [M:FRL1]PRCINV(ZIND)=max(100-[L]ZTX,0)
Else
  [M:FRL1]PRCINV(ZIND)=ar2(VALEUR/[L]ZPV*100)
Endif

If !GIMPORT Then Affzo [M:FRL1]PRCINV(ZIND) Endif

If [M:FRL1]CURFRL<>[V]GLOCALDEV
  [M:FRL1]AMTCUR(ZIND)=VALEUR
  Affzo [M:FRL1]AMTINV(ZIND)
Endif

End

######################################################################################
Subprog AM_QTYINV(VALEUR)
Variable Decimal VALEUR

Local Decimal ZPV, ZTX, ZQTY
Local Integer ZIND, STAT

[L]ZIND=nolign-1

[L]ZPV=[M:FRL1]QTY

[M:FRL1]PRCINV([L]ZIND)=0

If !clalev([F:TUN]) : Local File TABUNIT : Endif

If [F:TUN]UOM<>[M:FRL1]SAU
  Read [F:TUN]TUN0=[M:FRL1]SAU
  If fstat : Raz [F:TUN] : Endif
Endif

[L]ZTX=0
[L]ZQTY=0
For I=0 To max([M:FRL1]NBETP-1,[L]ZIND)
  If [L]ZIND<>I
    [L]ZTX+=[M:FRL1]PRCINV(I)
    [L]ZQTY+=[M:FRL1]QTYINV(I)
  Else
    [L]ZQTY+=VALEUR
  Endif
Next

If [L]ZQTY=[L]ZPV
  [M:FRL1]PRCINV(ZIND)=max(100-[L]ZTX,0)
Else
  [M:FRL1]PRCINV(ZIND)=ar2(VALEUR/[L]ZPV*100)
Endif

If !GIMPORT Then Affzo [M:FRL1]PRCINV(ZIND) Endif

End

######################################################################################
Subprog IB_NBLIG
Raz [V]GBOUT10
If ![V]XFRLTYP
  If [M:FRL0]REVNUM>0 & nolign>0 & nolign<=[M]NBLIG & GREP=""
    [V]GBOUT10=mess(147,[V]GXMSGOPP,1)
  Endif
Endif
End

######################################################################################
Subprog IB_NBLIGOF
Raz [V]GBOUT10
If ![V]XFRLTYP
  If [M:FRL0]REVNUM>0 & nolign>0 & nolign<=[M]NBLIGOF & GREP=""
    [V]GBOUT10=mess(149,[V]GXMSGOPP,1)
  Endif
Endif
End

######################################################################################
Subprog AV_XMAJCST(VALEUR)
Variable Char    VALEUR()
If [M:FRL5]ITMREFOF([M:FRL5]XNUMLIG-1)<>"" & [M:FRL5]MFGFCY([M:FRL5]XNUMLIG-1)<>""
  VALEUR="258"
Else
  VALEUR=""
Endif
End

######################################################################################
Subprog CL_XMAJCST(VALEUR)
Variable Char    VALEUR()

GSTATUS=1 : Call OUINON(mess(7,[V]GXMSGOPR,1),GSTATUS) From GESECRAN
If GSTATUS=1 : mkstat=1 : End : Endif

Local Date ZDEB
[L]ZDEB=[M:FRL0]CREDATFRM

Raz [M:FRL5]XCOSPRIOF
Raz [M:FRL5]COSPRIOF([M:FRL5]XNUMLIG-1)

Call AFF_COUT([M:FRL5]CSTTYP([M:FRL5]XNUMLIG-1),[L]ZDEB,[M:FRL5]ITMREFOF([M:FRL5]XNUMLIG-1),[M:FRL5]XMFGFCY,[M:FRL5]MATCST([M:FRL5]XNUMLIG-1),[M:FRL5]MACCST([M:FRL5]XNUMLIG-1)
&           ,[M:FRL5]LABCST([M:FRL5]XNUMLIG-1),[M:FRL5]SCOCST([M:FRL5]XNUMLIG-1),[M:FRL5]OVECST([M:FRL5]XNUMLIG-1),[M:FRL5]CSTTOT([M:FRL5]XNUMLIG-1)
&           ,[M:FRL5]CSTTOT2([M:FRL5]XNUMLIG-1),[M:FRL5]CLCQTY([M:FRL5]XNUMLIG-1),[M:FRL5]COEOF([M:FRL5]XNUMLIG-1),[M:FRL5]COSPRIOF([M:FRL5]XNUMLIG-1)) From SPVOBJFRL

If !GIMPORT
  Affzo [M:FRL5]
Endif

mkstat=4

End

######################################################################################
Subprog AV_QTYINV(VALEUR)
Variable Decimal VALEUR

If VALEUR<>0 : End : Endif

If !clalev([F:TUN]) : Local File TABUNIT : Endif

If [F:TUN]UOM<>[M:FRL1]SAU
  Read [F:TUN]TUN0=[M:FRL1]SAU
  If fstat : Raz [F:TUN] : Endif
Endif

If func SPVOBJPFM.SITMSTQTY([M:FRL0]TYPFRM)=2
  VALEUR=arr(([M:FRL1]PRCINV(nolign-1)*[M:FRL1]QTY)/100,10^([F:TUN]UOMDEC*(-1)))
Else
  VALEUR=[M:FRL1]QTY
Endif

End

######################################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR

If find([M:FRL1]INVMOD,4,5)

  If func SPVOBJPFM.SITMSTQTY([M:FRL0]TYPFRM)=2

    GSTATUS=1
    If sum([M:FRL1]AMTINV)=0
      GSTATUS=2
    Else
      Call OUINON(mess(1,[V]GXMSGOPP,1),GSTATUS) From GESECRAN
    Endif
    If GSTATUS=2
      Call RECAL_AMTINV(VALEUR,[M:FRL1]GROPRI,[M:FRL1]CURFRL) From SPVOBJFRL
    Endif

  Else

    Local Integer ZI
    For [L]ZI=0 To [M:FRL1]NBETP-1
      [M:FRL1]QTYINV([L]ZI)=VALEUR
    Next
    Affzo [M:FRL1]QTYINV

  Endif

Endif

End

######################################################################################
Subprog AV_AMTCUR(VALEUR)
Variable Decimal VALEUR

If find([M:FRL1]INVMOD,4,5) & func SPVOBJPFM.SITMSTQTY([M:FRL0]TYPFRM)=2
  VALEUR=[M:FRL1]GROPRI
Endif

End

######################################################################################
Subprog AV_AMTINV(VALEUR)
Variable Decimal VALEUR

If find([M:FRL1]INVMOD,4,5)
  Local Integer STAT
  Local Decimal ZPV
  If func SPVOBJPFM.SITMSTQTY([M:FRL0]TYPFRM)=2
    If [M:FRL1]CURFRL=[V]GLOCALDEV
      VALEUR=[M:FRL1]GROPRI
    Else
      [L]ZPV=[M:FRL1]GROPRI

      # LBORN 02/03/2017
      # Call CONVERT([M:FRL1]CURFRL,[V]GLOCALDEV,[V]GLOCALDEV,[F:XOP]CHGTYP,datesyst,[L]ZPV,[L]ZPV,[L]STAT) From TRTDEV
      # LBORN 03/05/2017 - Mantis 34166
      # Call CONVERT([M:FRL1]CURFRL,[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,datesyst,[L]ZPV,[L]ZPV,[L]STAT) From TRTDEV
      Call CONVERT_FRL([M:FRL1]CURFRL,[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,[M:FRL0]CREDATFRM,[L]ZPV,[L]ZPV,[L]STAT) From SPVOBJFRL2

      VALEUR=[L]ZPV
    Endif
  Elsif [M:FRL1]CURFRL=[V]GLOCALDEV
    VALEUR=[M:FRL1]AMTCUR(nolign-1)
  Else
    [L]ZPV=[M:FRL1]AMTCUR(nolign-1)

    # LBORN 02/03/2017
    # Call CONVERT([M:FRL1]CURFRL,[V]GLOCALDEV,[V]GLOCALDEV,[F:XOP]CHGTYP,datesyst,[L]ZPV,[L]ZPV,[L]STAT) From TRTDEV
    # LBORN 03/05/2017 - Mantis 34166
    # Call CONVERT([M:FRL1]CURFRL,[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,datesyst,[L]ZPV,[L]ZPV,[L]STAT) From TRTDEV
    Call CONVERT_FRL([M:FRL1]CURFRL,[V]GLOCALDEV,[V]GLOCALDEV,[F:OPP]CHGTYP,[M:FRL0]CREDATFRM,[L]ZPV,[L]ZPV,[L]STAT) From SPVOBJFRL2

    VALEUR=[L]ZPV
  Endif
Endif

Gosub ACTGRIZ_AMTINV From SPVOBJFRL

End

######################################################################################
Subprog AV_ICOCON(VALEUR)
Variable Char    VALEUR()
If ![V]GXOPTCON | [M:FRL1]INVMOD<>9
  Raz VALEUR
Else
  VALEUR="56"
Endif
End

######################################################################################
Subprog AS_AMTCUR(VALEUR)
Variable Decimal VALEUR

# LBORN 21/07/2016 - Mantis 32658 (le diszo dans $SETBOUT est désactivé après tunnel, du coup on ajoute une action complémentaire)
If find([M:FRL1]INVMOD,4,5) & func SPVOBJPFM.SITMSTQTY([M:FRL0]TYPFRM)=2
  VALEUR=[M:FRL1]GROPRI
  mkstat=2
Endif

End

######################################################################################
Subprog AS_QTYINV(VALEUR)
Variable Decimal VALEUR

# LBORN 21/07/2016 - Mantis 32658 (le diszo dans $SETBOUT est désactivé après tunnel, du coup on ajoute une action complémentaire)
If func SPVOBJPFM.SITMSTQTY([M:FRL0]TYPFRM)<>2
  VALEUR=[M:FRL1]QTY
  mkstat=2
Endif

End

######################################################################################
# LBORN 03/05/2017 - Mantis 34166
######################################################################################
Subprog AM_CREDATFRM(VALEUR)
Variable Date    VALEUR

Local Integer ZI, STAT
Local Decimal ZPV

[L]ZPV=[M:FRL1]GROPRI

If [M:FRL1]CURFRL<>[V]GLOCALDEV & [M:FRL1]CURFRL<>"" & [M:FRL1]GROPRI<>0 & find([M:FRL1]INVMOD,4,5)
  Call CONVERT_FRL([M:FRL1]CURFRL,[V]GLOCALDEV,[V]GLOCALDEV,[F:XOP]CHGTYP,[M:FRL0]CREDATFRM,[L]ZPV,[L]ZPV,[L]STAT) From SPVOBJFRL2
  For [L]ZI=0 To [M:FRL1]NBETP-1
    [M:FRL1]AMTINV([L]ZI)=[L]ZPV
  Next
  Affzo [M:FRL1]AMTINV
Endif

End

######################################################################################
# LBORN 03/05/2017 - Mantis 34166
######################################################################################
Subprog AP_CREDATFRM(VALEUR)
Variable Date    VALEUR

Local Integer OK

Read [F:XOP]XOP0=[M:FRL0]OPPNUM
If fstat : Raz [F:XOP] : Endif

Gosub INIT_ZREM From SPVOBJFRL

Call CAL_NETAMT([M:FRL1]NETAMT,[M:FRL1]GROPRI,[L]ZREM,[M:FRL1]QTY,[M:FRL1]CURFRL,[F:OPP]CHGTYP,VALEUR,[L]OK) From SPVOBJFRL
If ![L]OK
  Call AVERTIR([V]GMESSAGE,[L]OK) From GESECRAN
Endif

[M:FRL0]CREDATFRM=VALEUR
If !GIMPORT: Affzo [M:FRL1]17: Endif

End

