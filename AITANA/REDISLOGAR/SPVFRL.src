  [M:FRL3]BEGDAT([M:FRL3]XNUMLIG-1)=VALEUR
  If !GIMPORT
    Affzo [M:FRL3]BEGDAT([M:FRL3]XNUMLIG-1)
  Endif
Endif
End

#---------------------------------------
Subprog AM_XBEGDAT(VALEUR)
