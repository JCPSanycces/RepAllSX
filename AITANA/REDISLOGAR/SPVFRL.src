Subprog AS_REVBAS(VALEUR)
Variable Date    VALEUR
If [M:FRL7]REVFOR = "" & [M:FRL7]REVCOE = 0 Then
  mkstat = 1
Elsif VALEUR = [0/0/0] Then
  VALEUR = [M:FRL0]CREDATFRM
Endif
End

Subprog AS_REVDATDEB(VALEUR)
Variable Date    VALEUR
If [M:FRL7]REVFOR = "" & [M:FRL7]REVCOE = 0 Then
  mkstat = 1
Elsif VALEUR = [0/0/0] Then
  VALEUR = [M:FRL0]CREDATFRM
Endif
End

Subprog AS_REVPER(VALEUR)
Variable Integer VALEUR
If [M:FRL7]REVFOR="" & [M:FRL7]REVCOE = 0 Then
  mkstat=1
Else
  If VALEUR=0
    VALEUR=9
  Endif
  GMENLOC(8)=1
  GMENLOC(10)=1
Endif
End

Subprog AV_REVNEXT(VALEUR)
Variable Date    VALEUR
Local Date    XDATREF
Local Char    XTYP

Local Date    XDATREF
Local Char    XTYP

If ([M:FRL7]REVFOR="" & [M:FRL7]REVCOE = 0) | find([M:FRL7]REVPER,0,8,9) | [M:FRL7]REVBAS=[0/0/0]
  VALEUR=[0/0/0]
Else
  # Récupération de la valeur paramètre qui détermine la date faisant foi pour l'application
  # de la périodicité, une fois la date de début dépassée.
  # Applique t'on la périodidicté sur Date de référence (REVBAS) ou sur Date de début Révision (REVDATDEB)
  Call PARAM("","XDATREVPER",[L]XTYP) From ADOVAL
  If [L]XTYP = "" | [L]XTYP = "0" Then
    [L]XTYP = "1"
  Endif

  If [L]XTYP = "1" Then
    [L]XDATREF = [M:FRL7]REVBAS
  Else
    [L]XDATREF = [M:FRL7]REVDATDEB
  Endif

  VALEUR = [L]XDATREF

  While VALEUR < max([L]XDATREF,date$)
    Case [M:FRL7]REVPER
      When 1  : VALEUR = addmonth(VALEUR,1)
      When 2  : VALEUR = addmonth(VALEUR,2)
      When 3  : VALEUR = addmonth(VALEUR,3)
      When 4  : VALEUR = addmonth(VALEUR,6)
      When 5  : VALEUR = addmonth(VALEUR,12)
      When 6  : VALEUR = addmonth(VALEUR,24)
      When 7  : VALEUR = addmonth(VALEUR,36)
      When 11 : VALEUR = addmonth(VALEUR,60)
      When 12 : VALEUR = addmonth(VALEUR,4)
    Endcase
  Wend
Endif
End

