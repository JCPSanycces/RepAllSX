[M:FRL2]ITMDESPUR([M:FRL2]XNUMLIG-1)=VALEUR
End


#--------------------------------------------------
Subprog AM_XSTOFCY(VALEUR)
Variable Char    VALEUR()

[M:FRL2]STOFCY([M:FRL2]XNUMLIG-1)=VALEUR

# LBORN 20/11/2014 - Mantis 26720
If ![V]XFRLTYP
  ## Action TRTPRHFCY
  Local Char PARMSK(250)(1..20), SAVACT(20)
  SAVACT = GACTION : GACTION = "TRTPRHFCY"
  PARMSK(1)=[M:FRL2]ITMREFPUR([M:FRL2]XNUMLIG-1)
  Call TRAITE_CHAR(VALEUR,PARMSK,"","TRTACHCTL1","",1,"XYTRTACHCTL1") From GTRAITE
  GACTION = SAVACT

  # LBORN 23/02/2015 - Mantis 28339 (déclenchement de l'action suite GOBJETCOA)
  If !mkstat
    ## Action GOBJETC0A
    SAVACT=GACTION : GACTION="GOBJETC0A"
    Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
    ACTION="AAM_XSTOFCY" : PROGSUB="SUBFRL" : PROGSPE="SPEFRL" : PROGSPV="SPVFRL"
    Gosub ACTSUB From GOBJSUB
    Local Char OBJCLE(30)
    OBJCLE=VALEUR
    Call OBJET_CHAR(OBJCLE,WOBJET,[M:FRL2]ITMREFPUR([M:FRL2]XNUMLIG-1)) From GOBJET
    ACTION="BAM_XSTOFCY" : PROGSUB="SUBFRL" : PROGSPE="SPEFRL" : PROGSPV="SPVFRL"
    Gosub ACTSUB From GOBJSUB
    GACTION = SAVACT
  Endif
Endif

End

#--------------------------------------------------
Subprog C_XSTOFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & ![V]XFRLTYP
  GMESSAGE=mess(10,123,1)
  GERR=1
  mkstat=1
Endif
End

#--------------------------------------------------
Subprog D_XSTOFCY(VALEUR)
Variable Char    VALEUR()
If [M:FRL2]XNUMLIG<=0 : End : Endif
If [V]GFCYDEF(6)<>""
  VALEUR=[V]GFCYDEF(6)
Elsif [M:FRL2]ITMREFPUR([M:FRL2]XNUMLIG-1)=""
  For [F:FCY]FCY0 Where [F:FCY]PURFLG=2
    VALEUR=[F:FCY]FCY : Break
  Next
Endif
End

