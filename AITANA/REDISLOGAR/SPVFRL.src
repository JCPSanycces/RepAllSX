# Ecran FRL3
#######################################################

## 04/05/2016 12:54:15 (SOUCH) M32219
#---------------------------------------
# Empêcher la modification de la durée dans la ligne de détail
# si il y a des données dans la table des tâches scindées
Subprog AS_XEXTQTY(VALEUR)
Variable Decimal VALEUR
If [V]GXOPTAGE
  Gosub TEST_MULTI
  If [L]TEST_RET=2
    mkstat=2
  Endif
Endif
End

## 25/05/2016 10:11:09 (SOUCH) M32829
#---------------------------------------
# Empêcher la modification de la ressource dans la ligne de détail
# si il y a des données dans la table des tâches scindées
Subprog AS_XRSSIUS(VALEUR)
Variable Char    VALEUR()
If [V]GXOPTAGE
  Gosub TEST_MULTI
  If [L]TEST_RET=2
    mkstat=2
  Endif
Endif
End

$TEST_MULTI
  Local Shortint TEST_RET
  If [V]GXOPTAGE
    Local File FORMSLR
    Local Integer NOL
    If nolign>0
      [L]NOL=nolign-1
    Else
      [L]NOL=0
    Endif
    Read [F:FRR]FRR0 = [M:FRL0]FRMNUMLIG;[M:FRL3]NUMLIGFRL3([L]NOL)
    If [F:FRR]XPLATSKM>0 | [F:FRR]XPLATSKM>0
      [L]TEST_RET=2
      Return
    Endif
    Local File XFORMSLRP [XFP]
    Look [F:XFP]XFP0(2) = [F:FRR]FRMNUMLIG;[F:FRR]NUMLIGFRL3
    If !fstat
      [L]TEST_RET=2
    Endif
  Endif
Return

#---------------------------------------
Subprog AV_WSTREQ(VALEUR)
Variable Char     VALEUR
Local Integer ZI
For [L]ZI=1 To [M:FRL3]NBLIGFRL3+1
  If [L]ZI<>[M:FRL3]XNUMLIG
    Chgstl [M:FRL3]NBLIGFRL3([L]ZI-1) With ""
  Else
    Chgstl [M:FRL3]NBLIGFRL3([L]ZI-1) With "AMKCUR"
  Endif
Next
End

#---------------------------------------
Subprog C_REQTYP(VALEUR)
Variable Char VALEUR

Local Integer RETOUR, I

Call CON_SELFRLREQ([M:FRL0]OPPNUM,VALEUR,RETOUR)From SPVOBJXRT
If ![L]RETOUR
  GERR=1
  mkstat=2
  [M:FRL3]OUVINFOREQ(nolign-1)=0
Else
  [M:FRL3]OUVINFOREQ(nolign-1)=1
  [M:FRL3]XQUEUE=[M:FRL3]QUEUE(nolign-1)
  [M:FRL3]XRESINT=[M:FRL3]RESINT(nolign-1)
  [M:FRL3]XREQSUM=[M:FRL3]REQSUM(nolign-1)
  For [L]I=0 To [M:FRL3]NBLIGFRL3-1
    If [M:FRL3]WSTREQ([L]I)=[M:FRL3]WSTREQ(nolign-1) & [M:FRL3]REQTYP([L]I)=VALEUR
      [M:FRL3]OUVINFOREQ(nolign-1)=0
      [M:FRL3]QUEUE(nolign-1)=[M:FRL3]QUEUE([L]I)
      [M:FRL3]RESINT(nolign-1)=[M:FRL3]RESINT([L]I)
      [M:FRL3]REQSUM(nolign-1)=[M:FRL3]REQSUM([L]I)
      Break
    Endif
  Next
  If !GIMPORT
    Affzo [M:FRL3]REQSUM(nolign-1)
  Endif
Endif
End


#---------------------------------------
Subprog AS_NBLIGFRL3
Local Shortint XSTAT
Local Integer I, ZZLIG, ZLIG, ZI
Local Char    SVGREP

[L]ZZLIG=nolign

# DEBUT #######################################
# Init dernière fiche traitée pour initialiser analytique (cas où l'on ne passe pas dans le tableau
# analytique et que l'on passe à la ligne suivante)
# Le cas du changement d'onglet sera traité en AV_Saisie du tableau Ana

# Déclenchement Init sections ana
If [M:FRL3]XNUMLIG>0 & [M:FRL3]XFLGTRT([M:FRL3]XNUMLIG-1)<>2 & [M:FRL3]CODOPE([M:FRL3]XNUMLIG-1)<>""
  nolign=[M:FRL3]XNUMLIG
  Call INISEC_REQ([L]XSTAT)
  # Pour déclencher PSG/Actions SPE et enregistrer zone lorsque changement d'onglet sans saisie
  Affzo [M:FRL3]20
  For [L]I=1 To GNBDIE
    If [M:FRL3]XSECREQ([L]I-1)<>""
      Call CONTROLE("CCE","#",[M:FRL3]XSECREQ([L]I-1),GDIE([L]I),[L]XSTAT) From CONTOBJ
      If [L]XSTAT : Raz [V]GMESSAGE : Raz [M:FRL3]XSECREQ([L]I-1) : Endif
    Endif
    Assign "[M:FRL3]CCEDS"+num$([L]I)+"("+num$([M:FRL3]XNUMLIG-1)+")" With [M:FRL3]XSECREQ([L]I-1)
  Next
  nolign=[L]ZZLIG
Endif
# FIN #######################################

[L]ZLIG=nolign-1

Effzo [M:FRL3] 15-99

# Pas d'affectation en création, sinon pas d'init
If [M:FRL3]CODOPE([L]ZLIG)<>""

  If dim([V]GXPICKACT)<=0
    Gosub AFFECT_FRR From SPVOBJFRL
    # GREP pour éviter de redéclencher les Init en avant_zone PSG (déjà fait)
    [L]SVGREP=GREP
    If GREP="C" : GREP="M" : Endif
    Affzo [M:FRL3]15-99
    GREP=[L]SVGREP
  Else
    Gosub AFFECT_FRR2 From SPVOBJFRL
    Kill [V]GXPICKACT
  Endif

Else
  [M:FRL3]XNUMLIG=[L]ZLIG+1
  [M:FRL3]XNBANAREQ=GNBDIE
  For [L]ZI=1 To GNBDIE
    [M:FRL3]XDIEREQ([L]ZI-1)=GDIE([L]ZI)
  Next
  Affzo [M:FRL3]XDIEREQ
Endif

nolign=[L]ZLIG+1

# Pour afficher les couleurs, et gérer le PSG
For [L]I=1 To [M:FRL3]NBLIGFRL3
  If [M:FRL3]CODOPE([L]I-1)<>""
    Affzo [M:FRL3]WSTREQ([L]I-1),REQTYP([L]I-1),CODOPE([L]I-1)
  Endif
Next

End

#---------------------------------------
Subprog C_NBLIGFRL3
If status=73
  # Insertion
  Local Integer ZI
  Effzo [M:FRL3]15-99
  [M:FRL3]XNUMLIG=nolign
  [M:FRL3]XNBANAREQ=GNBDIE
  For [L]ZI=1 To GNBDIE
    [M:FRL3]XDIEREQ([L]ZI-1)=GDIE([L]ZI)
  Next
  Affzo [M:FRL3]XDIEREQ
Endif
End


#---------------------------------------
Subprog D_CHRDS(VALEUR)
Variable Decimal VALEUR
VALEUR=max([M:FRL3]CHRDS)+1
End


#---------------------------------------
Subprog AS_XCATPRIRES(VALEUR)
Variable Char    VALEUR()

Raz [V]GBOUT1,GBIDI1

Read [OPE]OPE0=[M:FRL3]CODOPE([M:FRL3]XNUMLIG-1)
If !fstat
  Case [OPE]OPETYP
     When 2: # Prestation
             GBIDI1 = 1717
     When 3: # Ressource
             GBIDI1 = 411
     When Default
             mkstat=1 : End
  Endcase

  Read [F:ADV]CODE=GBIDI1
  If !fstat
    Call LEC_TEXTRA("ATABTAB","LNGDES",[V]GLANGUE,num$([V]GBIDI1),"",[V]GBOUT1) From XTRTATEXTRA
  Endif
Endif

End


#---------------------------------------
Subprog AM_XCATPRIRES(VALEUR)
Variable Char    VALEUR()
[M:FRL3]CATPRIRES([M]XNUMLIG-1)=VALEUR
Call CALPRICOST([M:FRL3]XCOST,[M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1),[M:FRL3]ITEM([M:FRL3]XNUMLIG-1),[M:FRL3]CODOPE([M:FRL3]XNUMLIG-1)
&          ,VALEUR,[M:FRL3]UOMEXT([M:FRL3]XNUMLIG-1),[M:FRL3]XNUMLIG,[M:FRL3]FCYFRL3([M:FRL3]XNUMLIG-1))
End

#---------------------------------------
Subprog C_XCATPRIRES(VALEUR)
Variable Char    VALEUR()
# A cause Bug adonix COUZON
[M:FRL3]CATPRIRES([M]XNUMLIG-1)=VALEUR
End


#---------------------------------------
Subprog AM_XCURFRL3(VALEUR)
Variable Char    VALEUR()
[M:FRL3]CURFRL3([M]XNUMLIG-1)=VALEUR
Call CALPRICOST([M:FRL3]XCOST,VALEUR,[M:FRL3]ITEM([M:FRL3]XNUMLIG-1),[M:FRL3]CODOPE([M:FRL3]XNUMLIG-1)
&          ,[M:FRL3]XCATPRIRES,[M:FRL3]UOMEXT([M:FRL3]XNUMLIG-1),[M:FRL3]XNUMLIG,[M:FRL3]FCYFRL3([M:FRL3]XNUMLIG-1))
End


#---------------------------------------
Subprog AM_XRSSIUS(VALEUR)
Variable Char    VALEUR()
[M:FRL3]RSSIUS([M]XNUMLIG-1)=VALEUR
End


#---------------------------------------
Subprog AM_XITEM(VALEUR)
Variable Char    VALEUR()
[M:FRL3]ITEM([M]XNUMLIG-1)=VALEUR
Call CALPRICOST([M:FRL3]XCOST,[M:FRL3]CURFRL3([M:FRL3]XNUMLIG-1),VALEUR,[M:FRL3]CODOPE([M:FRL3]XNUMLIG-1)
&          ,[M:FRL3]XCATPRIRES,[M:FRL3]UOMEXT([M:FRL3]XNUMLIG-1),[M:FRL3]XNUMLIG,[M:FRL3]FCYFRL3([M:FRL3]XNUMLIG-1))
End


#---------------------------------------
Subprog C_XUOMEXT(VALEUR)
Variable Char    VALEUR()
If [M:FRL3]REQTYP(max([M]XNUMLIG,1)-1)<>"" & VALEUR=""
  [V]GMESSAGE=mess(10,123,1)
  GERR=1
  mkstat=1
Endif
End


#---------------------------------------
Subprog AM_XUOMEXT(VALEUR)
Variable Char    VALEUR()
[M:FRL3]UOMEXT([M]XNUMLIG-1)=VALEUR
