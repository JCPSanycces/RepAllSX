######################################################################################
Subprog AM_MESSREQ(VALEUR)
Variable Char    VALEUR()
Effzo [M]MESSTIT(nolign-1)
End

######################################################################################
Subprog AS_MESSTIT(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  VALEUR=func AFNC.TEXTRA("AWRKPAR","INTIT",[M]MESSREQ(nolign-1),"")
Endif
End

######################################################################################
Subprog AV_LIBIND(VALEUR)
Variable Char    VALEUR()

If nolign<1 : VALEUR="" : End : Endif

If !clalev([F:CCL]) : Local File GACCCODLIG : Endif

Read [F:CCL]CCL0=[M:XRT8]TYPACC(nolign-1);[M:XRT8]ACCNUM(nolign-1)
If !fstat
  VALEUR=left$(mess([F:CCL]TYPCPT,604,1),3)-mess([F:CCL]TXT,853,1)
Else
  VALEUR=""
Endif

End

######################################################################################
Subprog AM_CMM(VALEUR)
Variable Integer VALEUR

If VALEUR=2

  Local Char ZITM
  Raz [L]ZITM
  For [F:PRT]PRT0 Where [F:PRT]REQTYP<>[M:XRT0]REQTYP
    If [F:PRT]CMM=2
      If [F:PRT]ITMCMM<>""
        If [L]ZITM<>"" & [L]ZITM<>[F:PRT]ITMCMM
          Raz [L]ZITM : Break
        Else
          [L]ZITM=[F:PRT]ITMCMM
        Endif
      Endif
    Endif
  Next
  If [L]ZITM<>""
    [M:XRT8]ITMCMM=[L]ZITM
  Endif

  Local Integer ZIND
  Raz [L]ZIND
  For [F:PRT]PRT0 Where [F:PRT]REQTYP<>[M:XRT0]REQTYP
    If [F:PRT]CMM=2
      If [F:PRT]ACCNUM<>0
        If [L]ZIND<>0 & [L]ZIND<>[F:PRT]ACCNUM
          Raz [L]ZIND : Break
        Else
          [L]ZIND=[F:PRT]ACCNUM
        Endif
      Endif
    Endif
  Next
  If [L]ZIND<>0
    [M:XRT8]ACCNUM=[L]ZIND
  Endif

Endif

Call ACTGRIZO_CMM(VALEUR) From SPVOBJXRT

End

######################################################################################
Subprog AV_ORIFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=0
  VALEUR=1
Endif
If [M:XRT9]REO<>2
  Grizo [M:XRT9]ORIFCY
Else
  Actzo [M:XRT9]ORIFCY
Endif
End

######################################################################################
Subprog AM_REO(VALEUR)
Variable Integer VALEUR
[M:XRT9]REO=VALEUR
Affzo [M:XRT9]ORIFCY
End

######################################################################################
Subprog AV_STASQH(VALEUR)
Variable Char    VALEUR()
