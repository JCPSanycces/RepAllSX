#-----------------------------------------------------------
# LBO 31/12/2002 - Subprog mis en commentaire - Non utilisé
#-----------------------------------------------------------
#Subprog C_DEFTYPREV(VALEUR)
#Variable Char    VALEUR()
#Local Integer INDEX
#Call TROUVE([M:XRT5]CTRLTYPREV,VALEUR,[M:XRT5]TYPREV,INDEX) From SPVOBJXRT
#End

#####################################################################
Subprog C_REQSTA(VALEUR)
Variable Char VALEUR()

Local Integer INDEX

Call TROUVE([M:XRT1]CTRLSTA,VALEUR,[M:XRT1]CLOREQSTA,INDEX) From SPVOBJXRT

If (INDEX<>0) and ([M:XRT1]INIREQFLG(INDEX - 1) = 1) Then
    [V]GMESSAGE = mess(6,[V]GXMSGPSA,1)
    mkstat = 2
Endif

End

#####################################################################
Subprog C_DEFOPR(VALEUR)
Variable Char    VALEUR()
Local Integer INDEX
Call TROUVE([M:XRT2]CTRLOPR,VALEUR,[M:XRT2]CODOPR,INDEX) From SPVOBJXRT
End

