#####################################################################
Subprog C_CTRLQUE(VALEUR)
Variable Integer VALEUR

Local Integer I

If ([M:XRT2]CTRLINT = 2) & ([M:XRT1]CTRLSTA = 2) Then
    For I = 0 To ([M:XRT1]NBLIGSTA-1)
        If !find([M:XRT1]DEFINT(I),[M:XRT2]INTTYP) Then
            [V]GMESSAGE = mess(38,[V]GXMSGPSA,1)-[M:XRT0]REQTYP
            mkstat = 3
            zonsui = "[M:XRT1]DEFINT("+num$(I)+")"
        Endif
    Next
Endif

End

#####################################################################
Subprog AS_PRNFLG(VALEUR)
Variable Integer VALEUR

If [M:XRT4]STACOD = "" Then
    mkstat = 1
Endif

End

########################################
Subprog AV_XSRALL(VALEUR)
Variable Integer VALEUR

If VALEUR=2 Then
  Grizo [M:XRT7]XSREVEN
Else
  Actzo [M:XRT7]XSREVEN
Endif
End

########################################
Subprog AM_XSRALL(VALEUR)
Variable Integer VALEUR

If VALEUR=2 Then
  Local Integer I
  For I=1 To [M:XRT7]NBLIGXSR
    [M:XRT7]XSREVEN(I-1)=2
    If !GIMPORT Then Affzo [M:XRT7]XSREVEN(I-1) Endif
  Next
  Grizo [M:XRT7]XSREVEN
Else
  Actzo [M:XRT7]XSREVEN
Endif
End

########################################
Subprog AS_XSRMODIF(VALEUR)
Variable Integer VALEUR
mkstat=0
If [M:XRT7]XSREVEN(nolign-1)<>2 Then
  mkstat=1
Endif
End

########################################
Subprog C_XSRMODIF(VALEUR)
Variable Integer VALEUR

Local Integer NOL

  [L]NOL = nolign - 1
  If [M:XRT7]XSREVEN(NOL) <> 2 Then
    VALEUR = 1
  Endif
End

########################################
Subprog AM_XSREVEN(VALEUR)
Variable Integer VALEUR

If VALEUR<>2 Then
  Effzo [M:XRT7]XSRMODIF(nolign-1)
Endif
End

