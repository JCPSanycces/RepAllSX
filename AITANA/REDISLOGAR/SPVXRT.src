Subprog AV_CTRLTYPREV(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 1 : Grizo [M:XRT5]20
             Effzo [M:XRT5]20
    When 2 : Actzo [M:XRT5]20
Endcase

If !GIMPORT Then
    Affzo [M:XRT5]20
Endif

End

