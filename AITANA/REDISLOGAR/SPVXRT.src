GBIDC1=""
GBIDC2=""
GFONC1="GESXRT"
Call OBJET("XRT",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

#####################################################################
$ACTION

# Appel fonctions complémentaires GFI pour l'objet XRT
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
 When "RAZCRE"    : Gosub RAZCRE    From SPVOBJXRT
 When "INICRE"    : Gosub INICRE    From SPVOBJXRT
 When "INIMOD"    : Gosub INIMOD    From SPVOBJXRT
 When "CHANGE"    : Gosub CHANGE    From SPVOBJXRT
 When "ANNULE"    : Gosub ANNULE    From SPVOBJXRT
 When "SETBOUT"   : Gosub SETBOUT   From SPVOBJXRT
 When "OUVRE"     : Gosub OUVRE     From SPVOBJXRT
 When "FERME"     : Gosub FERME     From SPVOBJXRT
 When "LIENS"     : Gosub LIENS     From SPVOBJXRT
 When "CREATION"  : Gosub CREATION  From SPVOBJXRT
 When "MODIF"     : Gosub MODIF     From SPVOBJXRT
 When "SEL_LISTE" : Gosub SEL_LISTE From SPVOBJXRT
Endcase

Return


