#<AdxTL>@(#)11.0.0.0 $Revision:   1.20  $ Gestion du masque TESTFREQ
#ACV#X11
#TIT#Gestion des fréquences

Chain SPECON

#=======================================================================================================================#
# Actions sur champs de l'écran TESTFREQ
#=======================================================================================================================#

####################################### 
Subprog C_BEGDAT(VALEUR)
Variable Date    VALEUR
If [L]VALEUR<[M:DIA]REFDAT & VALEUR<>[0/0/0]
  mkstat=1
Endif
End

########################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If [L]VALEUR<[M:DIA]BEGDAT
  mkstat=1
Endif
End

########################################
Subprog C_CODCAL(VALEUR)
Variable Char    VALEUR()
If [L]VALEUR<>""
  Call UNICITE([L]VALEUR,[M]CODCAL(0..[M]NBLIG-1)) From OBJDIV
Endif
End

########################################
Subprog C_UVYCOD(VALEUR)
Variable Char    VALEUR()
If [L]VALEUR<>""
  Call UNICITE([L]VALEUR,[M]UVYCOD(0..[M]NBLIG-1)) From OBJDIV
Endif
End


########################################
Subprog AM_FCYDIA(VALEUR)
Variable Char    VALEUR()

If !clalev([FCY]): Local File FACILITY [FCY]: Endif
Local Integer ZNBCAL, ZNBUVY, I

Raz [L]ZNBCAL, [L]ZNBUVY
For [L]I=0 To [M]NBLIG-1
  If [M]CODCAL(I)<>"" : [L]ZNBCAL+=1 : Endif
  If [M]UVYCOD(I)<>"" : [L]ZNBUVY+=1 : Endif
Next

Read [FCY]FCY0=VALEUR
If !fstat
  If !find([FCY]CODCALFCY,[M]CODCAL(0..[L]ZNBCAL-1))
    [M]CODCAL([L]ZNBCAL)=[F:FCY]CODCALFCY : [L]ZNBCAL+=1
  Endif
  If !find([FCY]UVYCOD,[M]UVYCOD(0..[L]ZNBUVY-1))
    [M]UVYCOD([L]ZNBUVY)=[F:FCY]UVYCOD : [L]ZNBUVY+=1
  Endif
  [M]NBLIG=max([L]ZNBCAL,[L]ZNBUVY)
  Affzo [M] 15
Endif
End
