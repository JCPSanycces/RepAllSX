#<AdxTL>@(#)9.0.0.0 $Revision$
#ACV#X12
#TIT#Gestion de l'action XSUIVIREQ

#===============================================================================
# Ce traitement contient les actions propres Ã  l'action XSUIVIREQ
#
# Auteur                     : CRYBI
# Date de crÃĐation           : 19/02/03
#===============================================================================
# Modifications significatives
#-------------------------------------------------------------------------------
# Date          Auteur       Description
#-------------------------------------------------------------------------------
# 04.02.05      FM           Passage 140
# 03.11.10      LBORN        Migration V6 - Utilisation table TMP pour Clob
#===============================================================================

GBIDC1=""
GBIDC2=""
GFONC1="GESREQ"
Call OBJET("REQ",[V]GBIDC1,[V]GBIDC2)From GOBJET
End

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "DEBUT"       : Gosub DEBUT
  When "APRES_MODIF" : Gosub APRES_MODIF
  When "ABA"         : Gosub B_ABANDON
  When "ENR"         : Gosub B_ENREG
  When "FIN"         : Gosub FIN
Endcase
Return

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$OUVRE
Global Integer GXAUTMOD  # =1 si possibilitÃĐ de modification
Global Integer GXAUZFCY
Global Integer GXNOL

Local  File    XSUIVIREQ  [XSR]
Local  File    XSUIVIREQ  [XLO] # pour effectuer un look sur la table
Local  File    XSRTMP

If !clalev([F:TXC]) : Local File TEXCLOB : Endif

Local Integer XNUM, XSTAT, I
Local Char ZTXT
Return

################################################################################
$DEBUT

Gosub DEL_TABTMP
If GOK=0 : Return : Endif
Gosub ECR_TABTMP
If GOK=0 : Return : Endif

Raz [M:XSR]
For nolign=1 To dim([M:XSR]REQNUM)
  Read [F:XSR]XSR0=[F:REQ]REQNUM;nolign
  If fstat Then Break Endif
  [M:XSR]=[F:XSR]
  [M:XSR]EVENEM(nolign-1)  = num$([F:XSR]EVENEM)
  [M:XSR]EVINTIT(nolign-1) = mess([F:XSR]EVENEM,[F:XSR]NUMENULOC,1)
Next
[M:XSR]NBLIG=nolign-1

Sorta NBLIG NBLIG Order By [M:XSR]EVENDAT(indice), [M:XSR]EVENTIM(indice)

# Si la D.S est clÃīturÃĐe, modification impossible
# Test accÃĻs en modification de l'utilisateur par rapport Ã  la fonction GESREQ
[V]GXAUTMOD=1 : Actzo [M:XSR]
Call CTL_AUZFCY([F:REQ]FCY,"GESREQ","M",GXAUTMOD)From XTRTFCY
Call CTLACC([M:REQ0]ACS,"M")From CONTX3 #retourne mkstat
If [F:REQ]FLGREQCLO=2 | !GXAUTMOD | mkstat=2 Then
  Raz [V]GXAUTMOD : Diszo [M:XSR]
Endif

If !GIMPORT Then Affzo [M:XSR] Endif
Return

################################################################################
$APRES_MODIF

If [V]GXAUTMOD=1 Then

  If !find(COUZON,"NBLIG") Then
    If COUZON<>"XCOMMTXT"
      Case evalue("type([M:XSR]"+COUZON+")")
      When 1,2,4,5,6,7,9
         Assign "[M:XSR]"+COUZON+string$(left$(COUZON,1)<>"X","(GXNOL)") With val(CZ)
      When Default
         Assign "[M:XSR]"+COUZON+string$(left$(COUZON,1)<>"X","(GXNOL)") With CZ
      Endcase
    Endif

    If left$(COUZON,1)="X" Then

      Look [F:XLO]XSR0=[F:REQ]REQNUM;GXNOL+1
      If !fstat Then
        [M:XSR]XUPDDAT = date$
        [M:XSR]XUPDTIM = left$(time$,2)+mid$(time$,4,2)
        [M:XSR]XUPDUSR = GUSER
      Endif

      Gosub CHARGE_XZON

    Else

      Look [F:XLO]XSR0=[F:REQ]REQNUM;GXNOL+1
      If !fstat Then
        [M:XSR]UPDDAT(GXNOL) = date$
        [M:XSR]UPDTIM(GXNOL) = left$(time$,2)+mid$(time$,4,2)
        [M:XSR]UPDUSR(GXNOL) = GUSER
      Endif

      Gosub CHARGE_ZON

    Endif

    If COUZON="EVINTIT" & !GIMPORT & !GINTRA Then zonsui='[M:XSR]XDETAIL' Endif

  Endif

  REP="M"

Endif
Return

################################################################################
$B_ABANDON
Gosub DEBUT
Raz REP
Return

################################################################################
$B_ENREG

Call DEBTRANS From GLOCK
Trbegin [F:XSR],[F:TXC]
GOK=1
Delete [F:XSR] Where REQNUM=[F:REQ]REQNUM
If fstat Then GOK=0 : Call FSTA("XSR")From GLOCK : Rollback : Goto FIN_TRS Endif
#Le numero de lignes faisant parti du numero de texte, il ne faut pas renumeroter les lignes
#Ce sorta inhibe le sorta de l'action $DEBUT (qui presente les enreg. par date)

#A revoir V.140 car Pb d'ÃĐcriture TXC
#Sorta NBLIG NBLIG Order By [M:XSR]NUMLIG(indice)

Delete [F:TXC] Where [F:TXC]IDENT1="XSR" & [F:TXC]IDENT2=[F:REQ]REQNUM
If !find(fstat,0,4,5)
  GOK=0
  Call FSTA("TXC") From GLOCK
  Rollback
  Goto FIN_TRS
Endif

For [L]I=1 To [M:XSR]NBLIG
  nolign=[L]I
  Raz [F:XSR]
  [F:XSR]=[M:XSR]
  [F:XSR]REQNUM=[F:REQ]REQNUM
  [F:XSR]NUMLIG=[L]I

  Read [F:XSC]XSC0=[V]GIDENT;[F:REQ]REQNUM;[M:XSR]NUMLIG([L]I-1)
  If !fstat & [F:XSC]COMMTXT<>""

    # CrÃĐation du texte dans TEXCLOB
    If [F:XSR]COMM=""
      Call NUM_TXC("XSR",[L]XNUM,[L]XSTAT) From TRTX3TEX
      If ![L]XSTAT
        [F:XSR]COMM="XSR~"+format$("N0:8#",[L]XNUM)
        [M:XSR]COMM([L]I-1)=[F:XSR]COMM
      Else
        GOK=0
        Call ERREUR(mess(60,199,1)) From GESECRAN
        Rollback
        Break
      Endif
    Endif
    Raz [F:TXC]
    [F:TXC]TEXTE  =[F:XSC]COMMTXT
    [F:TXC]CODE   =[F:XSR]COMM
    [F:TXC]IDENT1 ="XSR"
    [F:TXC]IDENT2 =[F:XSR]REQNUM
    [F:TXC]IDENT3 =num$([F:XSR]NUMLIG)
    [F:TXC]CREUSR =[V]GUSER
    [F:TXC]CREDAT =date$
    [F:TXC]CREDATTIM =datetime$
    Write [TXC]
    If fstat
      GOK=0
      Call FSTA("TXC") From GLOCK
      Break
      Rollback
    Endif

  Endif

  Write [F:XSR]
  If fstat Then GOK=0 : Call FSTA("XSR")From GLOCK : Rollback : Break Endif

Next
If GOK=0 Then Goto FIN_TRS Endif
Commit
$FIN_TRS
Raz REP
Return

################################################################################
$FIN
Gosub DEL_TABTMP
Kill GXAUTMOD, GXAUZFCY, GXNOL
Close File [XSC], [XSR], [XLO]
Return



################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$IMGTXT_ON

If [M:XSR]XFLGMODIF=1 | [V]GXAUTMOD=0 Then #Non modifiable
  Call SET_IMAGE(5)From GESECRAN
Else
  Call RESET_IMAGE(5)From GESECRAN
Endif
Return

################################################################################
$GRIZE_ZON

If !GIMPORT Then
  Actzo [M:XSR]
  If [M:XSR]XFLGMODIF<>2 Then
    Diszo [M:XSR]10-25
    If GXAUTMOD=1 Then Actzo [M:XSR]XFLGMODIF Endif
  Endif
  If !GXAUTMOD Then Diszo [M:XSR] Endif
Endif
Return

################################################################################
$CHARGE_ZON

[M:XSR]XREQNUM    = [M:XSR]REQNUM(GXNOL)
[M:XSR]XNUMLIG    = [M:XSR]NUMLIG(GXNOL)
[M:XSR]XCOMM      = [M:XSR]COMM(GXNOL)
[M:XSR]XCREADAT   = [M:XSR]CREADAT(GXNOL)
[M:XSR]XCREATIM   = [M:XSR]CREATIM(GXNOL)
[M:XSR]XCREUSR    = [M:XSR]CREUSR(GXNOL)
[M:XSR]XNUMENULOC = [M:XSR]NUMENULOC(GXNOL)
[M:XSR]XEVFORMAT  = [M:XSR]EVFORMAT(GXNOL)
[M:XSR]XEVENEM    = [M:XSR]EVENEM(GXNOL)
[M:XSR]XEVENTIM   = [M:XSR]EVENTIM(GXNOL)
[M:XSR]XEVINTIT   = ""+string$(val([M:XSR]EVENEM(GXNOL))>0, mess(val([M:XSR]EVENEM(GXNOL)),[M:XSR]NUMENULOC(GXNOL),1) )
[M:XSR]XDETAIL    = [M:XSR]DETAIL(GXNOL)
[M:XSR]XUPDDAT    = [M:XSR]UPDDAT(GXNOL)
[M:XSR]XUPDTIM    = [M:XSR]UPDTIM(GXNOL)
[M:XSR]XUPDUSR    = [M:XSR]UPDUSR(GXNOL)
[M:XSR]XFLGMANU   = [M:XSR]FLGMANU(GXNOL)
[M:XSR]XFLGMODIF  = [M:XSR]FLGMODIF(GXNOL)

Read [F:XSC]XSC0=[V]GIDENT;[M:XSR]REQNUM(GXNOL);[M:XSR]NUMLIG(GXNOL)
If !fstat
  [M:XSR]XCOMMTXT=[F:XSC]COMMTXT
Else
  Raz [M:XSR]XCOMMTXT
Endif

If !GIMPORT Then Affzo [M:XSR] Endif
Return

################################################################################
# Appel en APRES_MODIF
$CHARGE_XZON

[M:XSR]REQNUM(GXNOL)    = [M:XSR]XREQNUM
[M:XSR]NUMLIG(GXNOL)    = [M:XSR]XNUMLIG
[M:XSR]COMM(GXNOL)      = [M:XSR]XCOMM
[M:XSR]CREADAT(GXNOL)   = [M:XSR]XCREADAT
[M:XSR]CREATIM(GXNOL)   = [M:XSR]XCREATIM
[M:XSR]CREUSR(GXNOL)    = [M:XSR]XCREUSR
[M:XSR]NUMENULOC(GXNOL) = [M:XSR]XNUMENULOC
[M:XSR]EVFORMAT(GXNOL)  = [M:XSR]XEVFORMAT
[M:XSR]EVENEM(GXNOL)    = [M:XSR]XEVENEM
[M:XSR]EVENTIM(GXNOL)   = [M:XSR]XEVENTIM
[M:XSR]EVINTIT(GXNOL)   = [M:XSR]XEVINTIT
[M:XSR]DETAIL(GXNOL)    = [M:XSR]XDETAIL
[M:XSR]UPDDAT(GXNOL)    = [M:XSR]XUPDDAT
[M:XSR]UPDTIM(GXNOL)    = [M:XSR]XUPDTIM
[M:XSR]UPDUSR(GXNOL)    = [M:XSR]XUPDUSR
[M:XSR]FLGMANU(GXNOL)   = [M:XSR]XFLGMANU
[M:XSR]FLGMODIF(GXNOL)  = [M:XSR]XFLGMODIF

If !GIMPORT Then Affzo [M:XSR] Endif

Return

################################################################################
################################################################################
################################################################################
################################################################################

########################################
Subprog AS_NBLIG

If !GIMPORT & [M:XSR]NBLIG=0 Then Effzo [M:XSR] Endif

GXNOL=nolign-1

# Charge les donnÃĐes du tableau dans les champs prÃĐvus
Gosub CHARGE_ZON
Gosub GRIZE_ZON

# Affichage icone Croix Rouge
Gosub IMGTXT_ON From XSUIVIREQ
End

########################################
Subprog C_NBLIG

Local Integer NOL : NOL=GXNOL

Raz mkstat
Case status
When 65     : # Suppression d'une ligne
              Gosub CNBLIG From XSUIVIREQ
              If mkstat Then End Endif

When 68, 83 : # Suppression de plusieurs lignes
              For NOL=nolign-1 To nolign1-1
                Gosub CNBLIG From XSUIVIREQ
                If mkstat Then Break Endif
              Next NOL
              If mkstat Then End Endif
Endcase
End
#=======================================
$CNBLIG
If [M:XSR]FLGMODIF(NOL)=1 Then
  GMESSAGE=mess(244,[V]GXMSGPSA,1)
  mkstat=1
Endif
Return

########################################
Subprog APRES_NBLIG

# SpÃĐcifique Ã  l'import --> Recharger indice pour sortir de la boucle de saisie
If GIMPORT Then
  indice = [M:XSR]NBLIG -1
Endif
End

########################################
Subprog AS_EVENDAT(VALEUR)
Variable Date    VALEUR
Raz mkstat
If VALEUR<>[0/0/0] Then
  If [M:XSR]FLGMODIF(GXNOL)<>2 Then mkstat=2 Endif
Else

  VALEUR=date$

  Raz [M:XSR]UPDDAT(GXNOL), [M:XSR]UPDTIM(GXNOL), [M:XSR]UPDUSR(GXNOL)

  [M:XSR]XEVENTIM=left$(time$,2)+mid$(time$,4,2)
  [M:XSR]EVENTIM(GXNOL)=[M:XSR]XEVENTIM
  [M:XSR]XREQNUM=[F:REQ]REQNUM
  [M:XSR]REQNUM(GXNOL)=[M:XSR]XREQNUM
  [M:XSR]XNUMLIG=GXNOL+1
  [M:XSR]NUMLIG(GXNOL)=[M:XSR]XNUMLIG
  [M:XSR]XNUMENULOC=1780
  [M:XSR]NUMENULOC(GXNOL)=[M:XSR]XNUMENULOC
  [M:XSR]XEVFORMAT="LA1780f:30X"
  [M:XSR]EVFORMAT(GXNOL)=[M:XSR]XEVFORMAT
  [M:XSR]XCREUSR=GUSER
  [M:XSR]CREUSR(GXNOL)=[M:XSR]XCREUSR
  [M:XSR]XCREADAT=date$
  [M:XSR]CREADAT(GXNOL)=[M:XSR]XCREADAT
  [M:XSR]XCREATIM=left$(time$,2)+mid$(time$,4,2)
  [M:XSR]CREATIM(GXNOL)=[M:XSR]XCREATIM
  [M:XSR]COMM(GXNOL)=[M:XSR]XCOMM

  If GXAUTMOD=1 Then
    [M:XSR]XFLGMODIF=2
    [M:XSR]FLGMODIF(GXNOL)=[M:XSR]XFLGMODIF
  Endif

  If !GIMPORT Then
    [M:XSR]XFLGMANU=2
    [M:XSR]FLGMANU(GXNOL)=[M:XSR]XFLGMANU
  Endif
Endif

Gosub GRIZE_ZON
End

########################################
Subprog AS_EVENTIM(VALEUR)
Variable Char    VALEUR()
Raz mkstat
If VALEUR<>"" Then
  If [M:XSR]FLGMODIF(GXNOL)<>2 Then mkstat=2 Endif
Endif
End

########################################
Subprog AS_EVINTIT(VALEUR)
Variable Char    VALEUR()
Raz mkstat
If VALEUR<>"" Then
  If [M:XSR]FLGMODIF(GXNOL)<>2 Then mkstat=2 Endif
Endif
End

########################################
$DEL_TABTMP
GOK=1
Trbegin [XSC]
Delete [XSC] Where [XSC]IDENT=GIDENT
If !find(fstat,0,4,5) : GOK=0 : Call FSTA("XSC") From GLOCK : Endif
If GOK=0 : Rollback : Else Commit : Endif
Return

########################################
$ECR_TABTMP

GOK=1
Trbegin [XSC]

For [XSR]XSR0 Where [F:XSR]REQNUM=[F:REQ]REQNUM & [F:XSR]COMM<>""
  Read [F:TXC]TXC0=[F:XSR]COMM
  If !fstat
    Raz [F:XSC]
    [F:XSC]=[F:XSR]
    [F:XSC]COMMTXT=[F:TXC]TEXTE
    [F:XSC]IDENT=GIDENT
    Write [F:XSC]
    If fstat : GOK=0 : Call FSTA("XSC") From GLOCK : Break : Endif
  Endif
Next
If GOK=0 : Rollback : Else Commit : Endif

Return

######################################################################################
Subprog AM_XCOMMTXT(VALEUR)
Variable Clbfile VALEUR

GOK=1
Trbegin [XSC]
Delete [XSC] Where [F:XSC]IDENT=GIDENT & [F:XSC]REQNUM=[M:XSR]REQNUM & [F:XSC]NUMLIG=[M:XSR]NUMLIG([V]GXNOL)
If !find(fstat,0,4,5) : GOK=0 : Call FSTA("XSC") From GLOCK : Rollback : mkstat=2 : End : Endif
If VALEUR<>""
  Raz [F:XSC]
  [F:XSC]IDENT   =[V]GIDENT
  [F:XSC]REQNUM  =[M:XSR]REQNUM
  [F:XSC]NUMLIG  =[M:XSR]NUMLIG([V]GXNOL)
  [F:XSC]COMMTXT =VALEUR
  Write [F:XSC]
  If fstat : GOK=0 : Call FSTA("XSC") From GLOCK : Rollback : mkstat=2 : End : Endif
Endif
Commit
End

######################################################################################
Subprog AV_EVENDAT(VALEUR)
Variable Date    VALEUR
Local Integer ZI
For [L]ZI=1 To [M:XSR]NBLIG+1
  If [M:XSR]NUMLIG([L]ZI-1)<>[M:XSR]XNUMLIG
    Chgstl [M:XSR]NBLIG([L]ZI-1) With ""
  Else
    Chgstl [M:XSR]NBLIG([L]ZI-1) With "AMKCUR"
  Endif
Next
End
