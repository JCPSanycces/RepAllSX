#<AdxTL>@(#)0.0.0.0 $Revision$ Consulta líneas pedidos
#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################
# CNSCPPSTD : Consultation des lignes de commandes d'achat MAE 19/03/08 #
# ECRAN 1   : CONSCPP1                                                  #
# ECRAN 2   : CONSCPP2                                                  #
# ECRAN CRIT: CRITCPP                                                   #
#########################################################################
Local Char PARAM(20)(1..2)
PARAM(1) = "2204"
PARAM(2) = "GAL"
Call GCONSULT("CPP","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  #---------------------------#
  # Actions champs modèlisées #
  #---------------------------#
  When "AB1_NBLIG"    : Gosub AB1_NBLIG
  When Default
Endcase
Return

############################################################
$AUTORIS
Return

###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
NAVIG="CONSCPP"
# Issue X3-65552 - 2018-05-14 by MUARN : ajout WFIL3
Local Char    WFIL(250),WFIL1(250),WFIL2(250), WFIL3(250)
Local Char    DEBNUM(GLONPOH), FINNUM(GLONPOH)
Local Date    DEBDAT, FINDAT
Local Integer DEBLIN, FINLIN :# 69747

Gosub DEFCRIT
If !clalev([F:BPR])  Local File BPARTNER [BPR] : Endif
#MAE, exi 91193
If clalev([F:TCU])= 0 : Local File TABCUR [TCU] : Endif
# Issue 91075 - 2013-07-23 by SR
If clalev([F:ITM])= 0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:FCY])= 0 : Local File FACILITY  [FCY] : Endif
Return

# --------------------------------------------------------------------------#
# Analyse paramètres, initialisations                                       #
# --------------------------------------------------------------------------#
$DEFCRIT
# Issue 81125 - 2012-03-29 by MUARN : consultation lignes
#If GNBAUZ=1 : PARAM(2)=GUSRFCY(1) : Endif
If GNBAUZ=1 : PARAM(3)=GUSRFCY(1) : Endif
For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre Article
      If PARAM(I) <> ""
        If [F:ITM]ITMREF <> PARAM(I) Read [ITM]ITM0 = PARAM(I)
                                     If fstat  Raz [F:ITM], PARAM(I) : Endif
        Endif
        [M:CPP1]ITMREF = PARAM(I)
      Endif

    When 2 :    : # Parametre Fournisseur
      If PARAM(I) <> ""
        If [F:BPS]BPSNUM <> PARAM(I) Read [BPS] BPS0 = PARAM(I)
                                     If fstat  Raz [F:BPS], PARAM(I) : Endif
        Endif
#US 71069/138  by RBA
#        [M:CPP1]BPSNUM = PARAM(I)
        [M:CPP1]BPSNUMDEB = PARAM(I)
        [M:CPP1]BPSNUMFIN = PARAM(I)
#/US 71069/138  by RBA
      Endif
    When 3 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [FCY] FCY0 = PARAM(I)
                                     If fstat  Raz [F:FCY], PARAM(I) : Endif
        Endif

        If (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
          [M:CPP1]POHFCY = PARAM(I)
          [M:CPP1]CPY = GSOCIETE
        Endif
      Endif
    When 4 :    : # Parametre commande
      If PARAM(I) <> ""
        [M:CPP1]POHNUMDEB=PARAM(I)
        [M:CPP1]POHNUMFIN=PARAM(I)
      Endif
  Endcase

Next I

# soldée oui
If !find([M:CPP1]CLEFLGO,1,2) : [M:CPP1]CLEFLGO= 1 : Endif
# non soldée
If !find([M:CPP1]CLEFLGN,1,2) : [M:CPP1]CLEFLGN= 2 : Endif
# signée oui
If !find([M:CPP1]APPFLGO,1,2) : [M:CPP1]APPFLGO= 2 : Endif
# signée non
If !find([M:CPP1]APPFLGN,1,2) : [M:CPP1]APPFLGN= 2 : Endif
# reçue oui
If !find([M:CCPP]RCPFLGO,1,2) : [M:CCPP]RCPFLGO= 2 : Endif
# reçue non
If !find([M:CCPP]RCPFLGN,1,2) : [M:CCPP]RCPFLGN= 2 : Endif
# facturée oui
If !find([M:CCPP]INVFLGO,1,2) : [M:CCPP]INVFLGO= 2 : Endif
# facturée non
If !find([M:CCPP]INVFLGN,1,2) : [M:CCPP]INVFLGN= 2 : Endif
# imprimée oui
If !find([M:CCPP]PRNFLGO,1,2) : [M:CCPP]PRNFLGO= 2 : Endif
# imprimée non
If !find([M:CCPP]PRNFLGN,1,2) : [M:CCPP]PRNFLGN= 2 : Endif
If !find([M:CCPP]TRI,1,2)     : [M:CCPP]TRI = 1   : Endif
#----- Initialisation dates début et fin -----#
Gosub INIT_DATES From TRTACHGRH1
[M:CPP1]ORDDATDEB=WDATDEB
[M:CPP1]ORDDATFIN=WDATFIN

# Issue 84130 - 2013-04-23 by MUARN : landed cost - descente des flags
If GPILNAV>1
  If find(GNAVIG(GPILNAV),"CONSCPO")
    [M:CPP1]CLEFLGO=[M:CPO1]CLEFLGO
    [M:CPP1]CLEFLGN=[M:CPO1]CLEFLGN
    [M:CPP1]APPFLGO=[M:CPO1]APPFLGO
    [M:CPP1]APPFLGN=[M:CPO1]APPFLGN
    [M:CPP1]ORDDATDEB=[M:CPO1]ORDDATDEB
    [M:CPP1]ORDDATFIN=[M:CPO1]ORDDATFIN
  Endif
Endif

#----- Copie du masque 1 (CPP1) vers l'écran critères (CCPP) -----#
Gosub CRITENT From =PROGCNS
Return
############################################################
$DEB_CRIT
#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM","GESITF")
        If find(GNAVIG(GPILNAV-1),"GESITM")
            Diszo [M:CCPP]ITMREF
        Elsif find(GNAVIG(GPILNAV-1),"GESITF")
            Diszo [M:CCPP]ITMREF
            Diszo [M:CCPP]POHFCY
            Diszo [M:CCPP]CPY
        Endif
        If dim([M:CCPP]TSICOD) > 0
          For I = 0 To dim([M:CCPP]TSICOD)-1
            Diszo [M:CCPP]TSICOD(I)
          Next I
        Endif
    Endif
    #acces depuis clients ou fournisseurs
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
#        Diszo [M:CCPP]BPSNUM
         Diszo [M:CCPP]BPSNUMDEB : Diszo [M:CCPP]BPSNUMFIN
        If dim([M:CCPP]TSICOD) > 0
          For I = 0 To dim([M:CCPP]TSICOD)-1
            Diszo [M:CCPP]TSICOD(I)
          Next I
        Endif
    Endif
    # Issue 84130 - 2013-01-31 by MAE : Si on vient de la consultation des commandes, les nums de commande sont grisés
    If find(GNAVIG(GPILNAV-1),"CONSCPO")
         Diszo [M:CCPP]POHNUMDEB
         Diszo [M:CCPP]POHNUMFIN
    Endif
Endif

Return
############################################################
$LECTURE
Local   Decimal  WMNTORG(0..1), WMNTDES(0..1)
Local   Integer  SPSTAT
Local   Char     WBPRNAM(GLONNAM)(2)

#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:CPP1]ITMREF
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:CPP1]ITMREF
        Diszo [M:CPP1]POHFCY
        Diszo [M:CPP1]CPY
    Endif

    #acces depuis clients ou fournisseurs
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
#        Diszo [M:CPP1]BPSNUM
        Diszo [M:CPP1]BPSNUMDEB : Diszo [M:CPP1]BPSNUMFIN
    Endif
    # Issue 84130 - 2013-01-31 by MAE : Si on vient de la consultation des commandes, les nums de commande sont grisés
    If find(GNAVIG(GPILNAV-1),"CONSCPO")
         Diszo [M:CPP1]POHNUMDEB
         Diszo [M:CPP1]POHNUMFIN
    Endif
Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

Link [POQ] With [POH]POH0=[POQ]POHNUM,
&               [POP]POP0=[POQ]POHNUM;[POQ]POPLIN;[POQ]POQSEQ
&          As [LNK]



# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCPP]TRI
      When 1 : # tri par numéro
        # Issue X3-65552 - 2018-05-14 by MUARN : ajout WFIL3
        #Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key POQ0
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) Order By Key POQ0
      When 2 : # tri par date
        # Issue X3-65552 - 2018-05-14 by MUARN : ajout WFIL3
        #Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                     Order By Key CLE=[F:POQ]ORDDAT;[F:POQ]POHNUM;[F:POQ]POPLIN :# 69747
#&                     Order By Key CLE=[F:POQ]ORDDAT;[F:POQ]POHNUM
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCPP]TRI
      When 1 : # tri par numéro
        # Issue X3-65552 - 2018-05-14 by MUARN : ajout WFIL3
        #Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key POQ0 Desc
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) Order By Key POQ0 Desc
      When 2 : # tri par date
        # Issue X3-65552 - 2018-05-14 by MUARN : ajout WFIL3
        #Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                     Order By [F:POQ]ORDDAT Desc ;[F:POQ]POHNUM Desc;[F:POQ]POPLIN Desc :# 69747
#&                     Order By [F:POQ]ORDDAT Desc ;[F:POQ]POHNUM Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CPP2] : Endif

#-- lecture
$BOUCLE

For [LNK]

# Filtre sur la société
  If [M:CPP1]CPY <> ""
      If [F:FCY]FCY <> [F:POH]POHFCY Read [FCY] FCY0 = [F:POH]POHFCY
                                     If fstat  Raz [F:FCY] : Endif
                                     Endif
      If [F:FCY]LEGCPY <> [M:CPP1]CPY Goto SUIV : Endif
  Endif

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CPP2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         #69747
         If CHGPAG=2
           If [F:POQ]POHNUM=FINNUM and [F:POQ]POPLIN<=FINLIN : NOL-=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         DEBNUM = [F:POH]POHNUM
         DEBDAT = [F:POH]ORDDAT
         DEBLIN = [F:POQ]POPLIN :# 69747
     Endif
     FINNUM = [F:POH]POHNUM
     FINDAT = [F:POH]ORDDAT
     FINLIN = [F:POQ]POPLIN :# 69747
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         #69747
         If CHGPAG=-2
           If [F:POQ]POHNUM=DEBNUM and [F:POQ]POPLIN>=DEBLIN : NOL+=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         FINNUM = [F:POH]POHNUM
         FINDAT = [F:POH]ORDDAT
         FINLIN = [F:POQ]POPLIN :# 69747
     Endif
     DEBNUM = [F:POH]POHNUM
     DEBDAT = [F:POH]ORDDAT
     DEBLIN = [F:POQ]POPLIN :# 69747
  Endif
  nolign = NOL+1

  If NOL>0  [L]WBPRNAM(0)=[M:CPP2]BPRNAM(0) : Endif
  If NOL>1  [L]WBPRNAM(1)=[M:CPP2]BPRNAM(1) : Endif
  [M:CPP2]=[F:POH] : # trans classe sur PORDER
  [M:CPP2]=[F:POQ] : # trans classe sur PORDERQ
  [M:CPP2]=[F:POP] : # trans classe sur PORDERP
  If NOL=1  [M:CPP2]BPRNAM(1)=[F:POH]BPRNAM(0) : Endif
  If NOL>0  [M:CPP2]BPRNAM(0)=[L]WBPRNAM(0) : Endif
  If NOL>1  [M:CPP2]BPRNAM(1)=[L]WBPRNAM(1) : Endif


  If [M:CPP2]BPRNAM(NOL)=""
    If [F:BPR]BPRNUM<>[M:CPP2]BPSNUM(NOL)
      Read [BPR] BPR0=[M:CPP2]BPSNUM(NOL) : If fstat  Raz [F:BPR] : Endif
    Endif
    [M:CPP2]BPRNAM(NOL)=[F:BPR]BPRNAM(0)
  Endif
#MAE, exi 91193
If GLOCALDEV <> [F:POH]CUR
  Read [TCU] TCU0 = GLOCALDEV
       If fstat Raz [F:TCU] : Endif
Endif


#conversion en devise document (société pour LINAMT)
If GLOCALDEV <> [F:POH]CUR & [F:POH]CHGCOE<>0
  [M:CPP2]LINAMTSOC(nolign-1) = arr([M:CPP2]LINAMT(nolign-1)*[F:POH]CHGCOE,[F:TCU]CURRND)
  [M:CPP2]CSTPURDOC(nolign-1) = arr([M:CPP2]CSTPUR(nolign-1)/[F:POH]CHGCOE,[F:TCU]CURRND)
  [M:CPP2]REACSTPURDOC(nolign-1) = arr([M:CPP2]REACSTPUR(nolign-1)/[F:POH]CHGCOE,[F:TCU]CURRND)
  [M:CPP2]LINCSTPURDOC(nolign-1) = arr([M:CPP2]LINCSTPUR(nolign-1)/[F:POH]CHGCOE,[F:TCU]CURRND)
  # MUARN, exi 91193
  [M:CPP2]LINATISOC(nolign-1) = arr([M:CPP2]LINATI(nolign-1)*[F:POH]CHGCOE,[F:TCU]CURRND)
Else
  [M:CPP2]LINAMTSOC(nolign-1) = [M:CPP2]LINAMT(nolign-1)
  [M:CPP2]CSTPURDOC(nolign-1) = [M:CPP2]CSTPUR(nolign-1)
  [M:CPP2]REACSTPURDOC(nolign-1) = [M:CPP2]REACSTPUR(nolign-1)
  [M:CPP2]LINCSTPURDOC(nolign-1) = [M:CPP2]LINCSTPUR(nolign-1)
  # MUARN, exi 91193
  [M:CPP2]LINATISOC(nolign-1) = [M:CPP2]LINATI(nolign-1)
Endif

#fin MAE 91193

  #US 71069/10  PJT by RBA
  [M:CPP2]PJT(nolign-1)       = [F:POP]PJT
  #/US 71069/10  PJT by RBA
$SUIV
Next
Filter [LNK]

Return

############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"
# Issue X3-65552 - 2018-05-14 by MUARN : ajout WFIL3
WFIL3 = "1=1"

#on ne prend pas les commandes ouvertes
WFIL += "&[F:POH]POHTYP<>2"

# Site de commande
If [M:CPP1]POHFCY <> ""
   WFIL += "&[F:POH]POHFCY=[M:CPP1]POHFCY"
Endif
# Autorisation site
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
   WFIL += "& find([F:POH]POHFCY,GUSRFCY(1..GNBAUZ))"
Endif
## Numéro de fournisseur
#If [M:CPP1]BPSNUM <> ""
#   WFIL += "&[F:POH]BPSNUM =[M:CPP1]BPSNUM"
#Endif

# Numéro de fournisseur
If [M:CPP1]BPSNUMDEB <> ""
   WFIL += "&[F:POH]BPSNUM >=[M:CPP1]BPSNUMDEB"
Endif
If [M:CPP1]BPSNUMFIN <> ""
   WFIL += "&[F:POH]BPSNUM <=[M:CPP1]BPSNUMFIN"
Endif

# Article
If [M:CPP1]ITMREF <> ""
   WFIL += "&[F:POQ]ITMREF =[M:CPP1]ITMREF"
Endif
# Issue 84130 - 2013-01-31 by MAE : Filtre sur les commandes
If [M:CPP1]POHNUMDEB <> ""
   WFIL += "&[F:POH]POHNUM>=[M:CPP1]POHNUMDEB"
Endif
If [M:CPP1]POHNUMFIN <> ""
   WFIL += "&[F:POH]POHNUM<=[M:CPP1]POHNUMFIN"
Endif

#################################################################################################
# YA027 - Añadir Fecha Confirmada Recepción a filtros de Consulta de Línea de Pedidos de Compra #
#         (Jon Erkoreka - Erik Fernandez)
#---------------------------------------------------#
If [M:CPP1]EXTRCPDATDEB <> [0/0/0]
   WFIL += "&[F:POQ]EXTRCPDAT >= [M:CPP1]EXTRCPDATDEB"
Endif
If [M:CPP1]EXTRCPDATFIN <> [0/0/0]
   WFIL += "&[F:POQ]EXTRCPDAT <= [M:CPP1]EXTRCPDATFIN"
Endif

If [M:CPP1]YRCPLGO = 1
   WFIL1 += "&[F:POQ]YRCPDAT<>2"
Endif
If [M:CPP1]YRCPLGN = 1
   WFIL1 += "&[F:POQ]YRCPDAT=2"
Endif

#---------------------------------------------------#

#    Prise en compte des commandes soldées
#    si la commande est soldée CLEFLG = 2
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPP1]CLEFLGO = 1
# Issue 79806 - 2012-02-03 by MUARN : prise en compte des lignes et non commandes
   #WFIL1 += "&[F:POH]CLEFLG<>2"
   WFIL1 += "&[F:POQ]LINCLEFLG<>2"
Endif

#    Prise en compte des commandes non soldées
#    si la commande n'est pas soldée CLEFLG = 1
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPP1]CLEFLGN = 1
# Issue 79806 - 2012-02-03 by MUARN : prise en compte des lignes et non commandes
   #WFIL1 += "&[F:POH]CLEFLG=2"
   WFIL1 += "&[F:POQ]LINCLEFLG=2"
Endif

#    Prise en compte des commandes signées
#    si la commande est totalement signée APPFLG > 2
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPP1]APPFLGO = 1
   WFIL1 += "&[F:POH]APPFLG<3"
Endif

#    Prise en compte des commandes non signées
#    si la commande n'est pas totalement signée APPFLG <3
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPP1]APPFLGN = 1
   WFIL1 += "&[F:POH]APPFLG>2"
Endif

#    Prise en compte des commandes recues
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPP]RCPFLGO= 1
   WFIL1 += "&[F:POH]RCPFLG<3"
Endif

#    Prise en compte des commandes non recues
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPP]RCPFLGN= 1
   WFIL1 += "&[F:POH]RCPFLG>2"
Endif


#    Prise en compte des commandes facturées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPP]INVFLGO= 1
   WFIL1 += "&[F:POH]INVFLG<3"
Endif

#    Prise en compte des commandes non facturées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPP]INVFLGN= 1
   WFIL1 += "&[F:POH]INVFLG>2"
Endif


#    Prise en compte des commandes imprimées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPP]PRNFLGO= 1
   WFIL1 += "&[F:POH]PRNFLG<>2"
Endif

#    Prise en compte des commandes non imprimées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPP]PRNFLGN= 1
   WFIL1 += "&[F:POH]PRNFLG=2"
Endif

# Issue 84130 - 2013-04-23 by MUARN : déja fait sur entête
#If [M:CCPP]POHNUMDEB <> ""
#   WFIL += "&[F:POH]POHNUM>=[M:CCPP]POHNUMDEB"
#Endif
#If [M:CCPP]POHNUMFIN <> ""
#   WFIL += "&[F:POH]POHNUM<=[M:CCPP]POHNUMFIN"
#Endif

# Issue X3-65552 - 2018-05-14 by MUARN : WFIL3 au lieu de WFIL
If [M:CCPP]ORDDATDEB <> [0/0/0]
   WFIL3 += "&[F:POH]ORDDAT>=[M:CCPP]ORDDATDEB"
Endif
If [M:CCPP]ORDDATFIN <> [0/0/0]
   WFIL3 += "&[F:POH]ORDDAT<=[M:CCPP]ORDDATFIN"
Endif
# End issue X3-65552

If dim([M:CCPP]TSICOD) > 0
  For I = 0 To dim([M:CCPP]TSICOD)-1
    If [M:CCPP]TSICOD(I) <> ""
      If len(WFIL) > 200
        WFIL2 += "&[F:POP]TSICOD("+num$(I)+")='"+[M:CCPP]TSICOD(I)+"'"
      Else
        WFIL += "&[F:POP]TSICOD("+num$(I)+")='"+[M:CCPP]TSICOD(I)+"'"
      Endif
    Endif
  Next I
Endif

If dim([M:CCPP]TSSCOD) > 0
  For I = 0 To dim([M:CCPP]TSSCOD)-1
    If [M:CCPP]TSSCOD(I) <> ""
      If len(WFIL) > 200
        WFIL2 += "&[F:POH]TSSCOD("+num$(I)+")='"+[M:CCPP]TSSCOD(I)+"'"
      Else
        WFIL += "&[F:POH]TSSCOD("+num$(I)+")='"+[M:CCPP]TSSCOD(I)+"'"
      Endif
    Endif
  Next I
Endif

#US 71069/10  PJT by RBA
If [M:CCPP]PJTDEB <> ""
   WFIL += "&[F:POP]PJT>=[M:CCPP]PJTDEB"
Endif
If [M:CCPP]PJTFIN <> ""
   WFIL += "&[F:POP]PJT<=[M:CCPP]PJTFIN"
Endif
#/US 71069/10  PJT by RBA

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCPP]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:POH]POHNUM>=DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:POH]ORDDAT>DEBDAT | ([F:POH]ORDDAT=DEBDAT & [F:POH]POHNUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCPP]TRI
       When 1 : # tri par numéro
           #WFIL += "&[F:POH]POHNUM>FINNUM"
           WFIL += "&[F:POH]POHNUM>=FINNUM" :# 69747
       When 2 : # tri par date
           #WFIL += "&([F:POH]ORDDAT>FINDAT | ([F:POH]ORDDAT=FINDAT & [F:POH]POHNUM>FINNUM))"
           WFIL += "&([F:POH]ORDDAT>FINDAT | ([F:POH]ORDDAT=FINDAT & [F:POH]POHNUM>=FINNUM))" :# 69747
     Endcase
   When -2 : # retour
     Case [M:CCPP]TRI
       When 1 : # tri par numéro
           #WFIL += "&[F:POH]POHNUM<DEBNUM"
           WFIL += "&[F:POH]POHNUM<=DEBNUM" :# 69747
       When 2 : # tri par date
           #WFIL += "&([F:POH]ORDDAT<DEBDAT | ([F:POH]ORDDAT=DEBDAT & [F:POH]POHNUM<DEBNUM))"
           WFIL += "&([F:POH]ORDDAT<DEBDAT | ([F:POH]ORDDAT=DEBDAT & [F:POH]POHNUM<=DEBNUM))" :# 69747
     Endcase
Endcase

Return

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT

Return


#############################################################
##     Etiquettes masques CONSCPO1 & CONSCPO2 & CRITCPO    ##
#############################################################
Subprog AV_CPY(VALEUR)
Variable Char     VALEUR
If GNBAUZ=1 : Diszo [M]CPY, POHFCY : Endif

End


Subprog C_CPY(VALEUR)
#-------------------------------#
# Contrôle de la société        #
#-------------------------------#
Variable Char     VALEUR
If VALEUR <> ""
    GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]POHFCY = ""
  GSOCIETE="" : GLOCALDEV=""
Endif
End

Subprog AM_CPY(VALEUR)
#-------------------------------#
# Après modif de la société     #
#-------------------------------#
Variable Char     VALEUR
Affzo ZCPY                      : # Utilisé par 2 écrans
Raz [M]POHFCY, [M]ZPOHFCY
Affzo POHFCY, ZPOHFCY
If VALEUR<>""  GSOCIETE=VALEUR : Endif
End

Subprog C_POHFCY(VALEUR)
#------------------------------------------------#
# Contrôle du site par defaut pour achat         #
# on regarde en fonction des autorisations sites #
# uniquement dans le cas site par defaut = ""    #
# complément de l'action VERIFCY en avant saisie #
#------------------------------------------------#
Variable Char    VALEUR()
If VALEUR <> ""
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
Elsif [M]CPY = ""
    GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

#-------------------------------#
# Après modif du site           #
#-------------------------------#
Subprog AM_POHFCY(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
  Affzo CPY, ZCPY  : # Utilisé par 2 écrans
Endif
End

#-----------------#
# Init bouton     #
#-----------------#
Subprog IB_NBLIG
Raz GBOUT1, GBOUT2
If [M:CPP2]NBLIG<>0
   If clalev([M:POH0])=0
     GBOUT1=mess(2,306,1) : # Commandes
   Endif
    If [M:CPP2]SOHNUM(nolign-1) <> ""
        GBOUT2 = mess(1,306,1)-[M]SOHNUM(nolign-1)
    Endif
Endif
End

$AB1_NBLIG
#------------------------------------------------------#
# Avant exécution du bouton Tunnel commandes, contrats #
#------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1(GLONPOH)
Local Char     WCLE2(GLONPOH)
If [M:CPP2]POHTYP(NOL) = 2
  WOBJET="POD"
  WCLE1 =num$(1)
  WCLE2 =[M:CPP2]POHNUM(NOL)
Else
  WOBJET="POH"
  WCLE1=[M:CPP2]POHNUM(NOL)
  WCLE2=""
Endif
Return

#-------------------------------------#
# Après modification de la date début #
#-------------------------------------#
Subprog AM_ORDDATDEB(VALEUR)
Variable Date     VALEUR
#----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
If dim([M]PERCOD)>0
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]ORDDATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]ORDDATFIN=WDATE : Affzo ORDDATFIN
  Endif
Elsif VALEUR>[M]ORDDATFIN
  [M]ORDDATFIN=VALEUR
Endif
End

#-----------------------------------#
# Après modification de la date fin #
#-----------------------------------#
Subprog AM_ORDDATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)<1  End : Endif
#----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
Local Date WDATE
Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]ORDDATFIN,VALEUR,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]ORDDATDEB=WDATE : Affzo ORDDATDEB
Endif
#-----
End

#---------------------------------------------------#
#      Controle du numéro de commande fin           #
# ------------------------------------------------- #
Subprog C_POHNUMFIN(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]POHNUMDEB
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End


#########################################################################
# Pour exécution de la validation des consultations en gestion de patch #
#########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2 End : Endif
Call VALGTC(APPLI,"CPP") From SUBGTC
End
