$ACTION

Case ACTION
  When "FINSAI"      : Gosub FINSAI
 When Default
Endcase
Return



$FINSAI
  If clalev([M:SIH0]) Then
    # solo para INDRA
    Local File EDIBPRCPYD [ZEBCD]    # Filling administrative centres collection
    Read [ZEBCD]EBCD0=[M:SIH0]BPCINV;[F:CPY]CPY;[M:EIS0]PARCOD
    If fstat=[V]CST_AOK
      If [F:ZEBCD]FLOCOD = 'FACINDRA' Then
         Gosub LECTURA_XML
      Endif
    Endif
    LogicClose File [ZEBCD]
  Endif


Return

#**
#* Busqueda del fichero  XML generado
#*!
$LECTURA_XML
  Local Char DIR(GDIMFIC), FILELIST(GDIMFIC)(1..100)
  Local Integer LNGTH
  Local Integer COUNT
  Local Char EFICHERO(200)
  Local Char LFECHA
  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,7,4)+ mid$(LFECHA,4,2)+mid$(LFECHA,1,2)
  Local Char DIRBAT(GDIMFIC)

  DIR =filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER
  DIRBAT = DIR + "\EDI\"
  DIR = DIR + "\EDI\ISSUETEST\"
  Call SYSTEME2(adxmac(0), "lsadx"-DIR,"",LNGTH,FILELIST) From ORDSYS
  For I=3 To LNGTH
       #  Buscamos los ficheros con extensión .unl
      # Infbox mid$(FILELIST(I),len(FILELIST(I))-3,4)
       If mid$(FILELIST(I),len(FILELIST(I))-3,4) = ".xml" Then
          # Infbox "Fichero:" + FILELIST(I)
          # call sendmail2()
          #For A=0 To COUNT-1
          #Infbox "*"+mid$(FILELIST(I),1,len([M:SIH0]NUM)-1) + " - " + mid$([M:SIH0]NUM,1,len([M:SIH0]NUM)-1)+"*"
          If mid$(FILELIST(I),1,len([M:SIH0]NUM)-1) = mid$([M:SIH0]NUM,1,len([M:SIH0]NUM)-1) Then
            #Call ECR_TRACE("Fichero ENTREGAS encontrado: " + FILELIST(I) , 0) From GESECRAN
            #Call LEER_FICHERO(DIR, FILELIST(I) )
            #Infbox "*"+mid$(FILELIST(I),1,len(FILELIST(I))-4) + " - " + mid$([M:SIH0]NUM,1,len([M:SIH0]NUM)-1)+LFECHA+"*"
            If mid$(FILELIST(I),1,len(FILELIST(I))-4) = [M:SIH0]NUM + LFECHA Then
                #Call LEER_FICHERO(DIR,FILELIST(I))
                #Infbox DIR+FILELIST(I)
                #Infbox 'powersell -command "(gc '+DIR+FILELIST(I)+') -replace "<extIndra>", "<ext:ExtIndra xmlns:ext=""ExtensionIndra"">" | Out-File -encoding ASCII '+DIR+FILELIST(I)
                System CHAINE=DIRBAT + 'replace_indra.bat ' +DIR+FILELIST(I)
                #System CHAINE='powersell -command "(gc '+DIR+FILELIST(I)+') -replace "</extIndra>", "</ext:ExtIndra>" | Out-File -encoding ASCII '+DIR+FILELIST(I)
                # powershell -Command "(gc SI-ES1-190399820200113.xml) -replace 'extIndra', 'extIndra:mab' | Out-File -encoding ASCII SI-ES1-190399820200113.xml
            Endif
          Endif
       Endif
   Next


Return



#**
#* Lectura fichero XML encontrado
#*
#* @param PDIRECTORIO
#* @param PFICHERO
#*!
Subprog LEER_FICHERO(PDIRECTORIO, PFICHERO)

Local Char LDIRMPORT(250) : LDIRIMPORT = PDIRECTORIO
Local Char LFILE_R(200)   : LFILE_R = PDIRECTORIO + PFICHERO

#Local Char LFILE_R(200)   : LFILE_R = LDIRIMPORT + "ImportXRT.txt"  # para pruebas
Local Char CAMPO(200)(30)
Local Char XPRODUCT(250)
Local Integer LFACINDRA
Local Char PLANTA(3)
Local Char SENTIDO(2)
Local Clbfile INFO_ADICIONAL(1)
Local Integer LNUMEXP, LECOK, SUCCESS : Raz LNUMEXP, LECOK, SUCCESS
Local Char LFECHA(10), LHORA(10), DESPATH(200) : Raz LFECHA, LHORA
Local Char LAUX(255) # MAB
Local Integer LPOS
Sleep 3
# abrir fichero para lectura
Gosub OPEN_FILE_R
# si el fichero existe y contiene información
Call ECR_TRACE("Lectura fichero ", 0) From GESECRAN

If filinfo(LFILE_R, 7) > 0 Then
  LECOK = 1
  LFACINDRA = 0
  Repeat
    # Libelle XPRODUCT
    Rdseq XPRODUCT Using [ZIMP_R]
    If fstat = 0 Then
          If  instr(1,XPRODUCT,'<extIndra>')>0 Then
            # Seek Curr Using [ZIMP_R]
            Infbox "FACTURA DE INDRA"
            XPRODUCT = '<extIndra:mab>'
            Putseq  1, XPRODUCT  Using [ZIMP_R]
            LFACINDRA = 1
            Gosub CLOSE_FILE_R
            LECOK = 0
          Endif

    Else
      LECOK = 0
    Endif
  Until LECOK = 0
Endif

# Gosub CERRAR_TBL


## mueve el archivo a la carpeta de históricos
#If filinfo(LFILE_R,7) > 0 Then
#  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
#  LHORA = vireblc(num$(time$),4) : LHORA = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
#  DESPATH = LDIRIMPORT+"\Procesados\" + PFICHERO + "_" + LFECHA+LHORA + ".csv"
#  SUCCESS = renameFile(LFILE_R,DESPATH)
#Endif
#
## Call MOVEFILE(LDIRIMPORT, LFILE_R, PFICHERO)
#
#Call ECR_TRACE("FIN INSERCIÓN " , 0 ) From GESECRAN

End



########################################################
$OPEN_FILE_R

#adxifs = ";"
adxirs = chr$(10)

Openio LFILE_R Using [ZIMP_R]
Iomode adxium 50 Using [ZIMP_R] # 50 = ASCII 0 = UTF8

Return

########################################################
$CLOSE_FILE_R

Openio Using [ZIMP_R]

Return

