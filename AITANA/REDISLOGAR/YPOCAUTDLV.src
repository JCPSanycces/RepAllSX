####################################################################################
# Program Name: YPOCAUTDLV
# Description : Specific Processing - Automatic Delivery
# Author      : GT NDEV 
# Date        : AUG 28th, 2018
# Type        : Entrypoint for process "FUNAUTDLV"
####################################################################################
$ACTION
 Case ACTION
  When "AUTDLVMAJ" : Gosub AUTDLVMAJ
  When default
 Endcase
Return

$AUTDLVMAJ
If dim(ZDLVARR)> 0 & dim(ZDLVARRCNT)>0
 If find([F:SDH]SDHNUM,ZDLVARR) = 0
  ZDLVARR(ZDLVARRCNT) = [F:SDH]SDHNUM 
  ZDLVARRCNT+=1
 Endif
Endif
Return








