#<AdxTL>@(#)4.0.0.0 $Revision:   1.20  $ Gestion du masque PSGPARZON
#ACV#X11
#TIT#Gestion de l'action PSGPARZON

#LBO 04/2003

GBIDC1=""
GBIDC2=""
Call OBJET("OPP",GBIDC1,GBIDC2) From GOBJET
End


Local Char PARAM(30)(1..16),VALEUR(10) 

PARAM(1)=""
PARAM(2)="VP2"
PARAM(3)="AGE"
PARAM(4)="AGE" 
PARAM(5)="" 

Call SAISIE_CHAR(VALEUR,PARAM,"PSGPARZON","XPSGPZON2") From GSAISIE
End


#-----------------------------------------------------------------------
# Ecran PSGPARZON [PSGZ]
#-----------------------------------------------------------------------

#--------------------------
Subprog AS_NBDEC
Local Integer ZLIG

[L]ZLIG=nolign-1

Effzo [M:PSGZ] 20

Gosub AFFECT From XPSGPZON2

Affzo [M:PSGZ]20

nolign=[L]ZLIG+1

End


#--------------------------
Subprog AS_XCONDSAI(VALEUR)
Variable Char     VALEUR
Call ASXZON
If [M:PSGZ]FLGSAI<>2 & !mkstat
  [M:PSGZ]CONDSAI([M:PSGZ]XNUMLIG-1)=""
  mkstat=1
Endif
End


Subprog ASXZON()
If [M:PSGZ]XNUMLIG<=0
  mkstat=2
Else
  If [M:PSGZ]CONDLIG([M:PSGZ]XNUMLIG-1)=""
    mkstat=2
  Endif
Endif
End

#--------------------------
Subprog D_CONDLIG(VALEUR)
Variable Char     VALEUR
If nolign=1
  VALEUR="1"
Endif
End


#--------------------------
Subprog AS_XFLGDEFF(VALEUR)
Variable Integer VALEUR
Call ASXZON
If [M:PSGZ]FLGSAI=2 & !mkstat
  [M:PSGZ]FLGDEFF([M:PSGZ]XNUMLIG-1)=1
  mkstat=1
Endif
End

#--------------------------
Subprog AS_XFLGSAI(VALEUR)
Variable Integer VALEUR
Call ASXZON
If [M:PSGZ]FLGDEFF=2 & !mkstat
  [M:PSGZ]FLGSAI([M:PSGZ]XNUMLIG-1)=1
  mkstat = 1
Endif
End

#--------------------------
Subprog C_TYPOBJ(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
  Call CONTROLE([M:PSGZ]OBJET,"!",VALEUR,[M:PSGZ]LNKOBJ,mkstat) From CONTOBJ
Endif
If !mkstat
  If !find(VALEUR,"",[V]GXTYPORIG)
    mkstat=1
  Else
    # Déverrouillage ancien symbole
    Gosub DEVERROU From XPSGPZON2
    Call LECTYP([M:PSGZ]PSGCOD,[M:PSGZ]OBJCOD,[M:PSGZ]ZONCOD,VALEUR) From XPSGPZON2
  Endif
Endif
End

#--------------------------
Subprog AS_TYPOBJ(VALEUR)
Variable Char    VALEUR()
If [M:PSGZ]OBJET=""
  mkstat=1
Elsif [V]GXREP="M"
  mkstat=2
Endif
End


#--------------------------
Subprog AS_ENAFLG(VALEUR)
Variable Integer VALEUR
Local File PARSAIGAS [XPSG]
Read [F:XPSG]PSG0(3)=[M:PSGZ]PSGCOD;[M:PSGZ]OBJCOD;[M:PSGZ]TYPOBJ
If !fstat
  mkstat=2
Endif
End


#--------------------------
Subprog AS_TRTSPE(VALEUR)
Variable Char    VALEUR()
Local File PARSAIGAS [XPSG]
Read [F:XPSG]PSG0(3)=[M:PSGZ]PSGCOD;[M:PSGZ]OBJCOD;[M:PSGZ]TYPOBJ
If !fstat
  mkstat=2
Endif
End


#--------------------------
Subprog AM_XFLGOBL(VALEUR)
Variable Integer VALEUR
[M:PSGZ]FLGOBL([M:PSGZ]XNUMLIG-1)=VALEUR
End

#--------------------------
Subprog AM_XVALDEF(VALEUR)
Variable Char    VALEUR()
[M:PSGZ]VALDEF([M:PSGZ]XNUMLIG-1)=VALEUR
End

#--------------------------
Subprog AM_XFLGDEFF(VALEUR)
Variable Integer VALEUR
[M:PSGZ]FLGDEFF([M:PSGZ]XNUMLIG-1)=VALEUR
End

#--------------------------
Subprog AM_XFLGSAI(VALEUR)
Variable Integer VALEUR
[M:PSGZ]FLGSAI([M:PSGZ]XNUMLIG-1)=VALEUR
End

#--------------------------
Subprog AM_XCONDSAI(VALEUR)
Variable Char    VALEUR()
[M:PSGZ]CONDSAI([M:PSGZ]XNUMLIG-1)=VALEUR
End

#--------------------------
Subprog AM_XCTRLSAI(VALEUR)
Variable Char    VALEUR()
[M:PSGZ]CTRLSAI([M:PSGZ]XNUMLIG-1)=VALEUR
End

#--------------------------
Subprog AM_XFLGCTRLB(VALEUR)
Variable Integer VALEUR
[M:PSGZ]FLGCTRLB([M:PSGZ]XNUMLIG-1)=VALEUR
End

#--------------------------
Subprog AM_XMSGERR(VALEUR)
Variable Char    VALEUR()
[M:PSGZ]MSGERR([M:PSGZ]XNUMLIG-1)=VALEUR
End

#--------------------------
Subprog AM_XTSTFLG(VALEUR)
Variable Integer VALEUR
[M:PSGZ]TSTFLG([M:PSGZ]XNUMLIG-1)=VALEUR
End


#--------------------------
Subprog AS_XTSTFLG(VALEUR)
Variable Integer VALEUR
Call ASXZON
End

#--------------------------
Subprog AS_XFLGOBL(VALEUR)
Variable Integer VALEUR
Call ASXZON
End

#--------------------------
Subprog AS_XVALDEF(VALEUR)
Variable Char    VALEUR()
Call ASXZON
End

#--------------------------
Subprog AS_XCTRLSAI(VALEUR)
Variable Char    VALEUR()
Call ASXZON
End

#--------------------------
Subprog AS_XFLGCTRLB(VALEUR)
Variable Integer VALEUR
Call ASXZON
End

#--------------------------
Subprog AS_XMSGERR(VALEUR)
Variable Char    VALEUR()
Call ASXZON
End

#--------------------------
Subprog AV_ZTYPOBJ(VALEUR)
Variable Char    VALEUR()
If [M:PSGZ]LNKOBJ<>""
  Call INT_AOB(1,[M:PSGZ]OBJET,[M:PSGZ]LNKOBJ,[M:PSGZ]TYPOBJ,VALEUR)From XTRTAOB
Else
  Call INT_AOB(1,[M:PSGZ]OBJET,[M:PSGZ]TYPOBJ,"",VALEUR)From XTRTAOB
Endif
End

