#<AdxTL>@(#)3.0.0.0 $Revision:   1.11  $ Gestion du masque QUSGAS1
#ACV#X11
#TIT#Gestion des questions

#CGUES 11/2000
#Action sur champs
#==========================================================================================
# Gestion de l'objet   : Gestion de l'objet question
#                        
# Auteur               : 
# Date de création     :       
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 02/09/2002    CGUES        Modélisation Web       
# 14/02/2005    CPERR        Gestion des textes traduisibles 
#==========================================================================================

$ACTION
Case ACTION
 When "INICRE"  :  Gosub INICRE    From SPVOBJQUS
 When "INIMOD"  :  Gosub INIMOD    From SPVOBJQUS
 When "CHANGE"  :  Gosub CHANGE    From SPVOBJQUS 
 When "DEFBOUT" :  Gosub DEFBOUT   From SPVOBJQUS
 When "SETBOUT" :  Gosub SETBOUT   From SPVOBJQUS
 When "EXEBOUT" :  Gosub EXEBOUT   From SPVOBJQUS
Endcase

Return

########################################
Subprog D_TEXQUSSHO(VALEUR)
Variable Char    VALEUR()

If VALEUR=""
  VALEUR=[M]TEXQUS
Endif
End

########################################
Subprog D_LIBQUSSHO(VALEUR)
Variable Char     VALEUR

If VALEUR=""
  VALEUR=[M:QUS0]LIBQUS
Endif
End
