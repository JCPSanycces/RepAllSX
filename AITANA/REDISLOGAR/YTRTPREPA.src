#####################################################################################
# CODACT: YA015 - Adaptación del plan de preparación
#####################################################################################
$ACTION
Case ACTION
  When "CRIT_SOQ"         : Gosub CRIT_SOQ
  When "ALI-PREP-SOQ"     : Gosub ALI_PREP_SOQ
  When "ORD_PREP"         : Gosub ORD_PREP
  When "CTRL_ITM"         : Gosub CTRL_ITM
  When "BEFWRIPRH"        : Gosub BEFWRIPRH
  When "BEFWRIPRE"        : Gosub BEFWRIPRE
Endcase
Return
#####################################################################################
$CRIT_SOQ
# aqui puedo entrar a añadir criterios a la busqueda

###
If clalev([F:YPRE]) =0 Local File YPREPTEMP   [YPRE]  Endif
If clalev([F:YSOH]) =0 Local File SORDER      [YSOH]  Endif
If clalev([F:YBPC]) =0 Local File BPCUSTOMER  [YBPC]  Endif
If !clalev([F:ZTXC])  Local File TEXCLOB  [ZTXC] Endif

Gosub $BORRAR_INTERMEDIOS

#JPL - Modificado en el arranque - Excluyo líneas de pedidos en ruptura total
CRITSOQ = "([F:SOQ]QTY-[F:SOQ]OPRQTY-[F:SOQ]PREQTY-[F:SOQ]ODLQTY-[F:SOQ]DLVQTY) > [F:SOQ]SHTQTY "

Return
#####################################################################################
$ALI_PREP_SOQ
#Tras añadir cada línea a la pantalla de preparación.

# Relleno el campo de precio de la línea del pedido de la pantalla PREP
[M:PREP]YGROPRI(NOL) = [F:SOP]YGROPRI
[M:PREP]YAMTALL(NOL) = [F:SOP]NETPRI*[F:SOQ]ALLQTY
[M:PREP]YAMTLIN(NOL) = [F:SOP]NETPRI*[F:SOQ]QTY 				#JPL - Añado importe de línea
[M:PREP]YAMTLINP(NOL) = [F:SOP]NETPRI*([F:SOQ]QTY-[F:SOQ]OPRQTY-[F:SOQ]PREQTY-[F:SOQ]ODLQTY-[F:SOQ]DLVQTY) #JPL - Añado importe de línea pte entregar
[M:PREP]YSOQTEX(NOL) = [F:SOQ]SOQTEX
[M:PREP]YPOSCLI(NOL) = [F:SOQ]YPOSCLI  #JPL - Añado Posición del cliente de la línea

If [F:SOQ]SOQTEX <> ''
  Read [F:ZTXC]TXC0 = [F:SOQ]SOQTEX
  If fstat = 0
    [M:PREP]YSOHTEXDES(nolign-1) = func F_RTF2TEXT([F:ZTXC]TEXTE)
  Endif
Endif

#Escribo el numero de pedido en mi tabla de cabeceras
Raz [F:YPRE]
[F:YPRE]YUSR = GUSER
[F:YPRE]YSOHNUM = [M:PREP]ORINUM(NOL)
Write [YPRE]

## Grabo toda la lista de líneas en la nueva lista
## ...

Affzo [M:PREP]

Return
#########################################################################
$ORD_PREP
#It is called when clicking 'SEARCH' in the preparation plan after loading the lines to be picked that match the selection criteria.
# Muestro los valores de mi tabla

Local Integer NLL
Local Integer WCDTSTA
Local Decimal WOST, WOSTAUZ

Raz NLL
Raz [M:PREP]KBLIG
Raz [M:PREP]YBLIG

Filter [YPRE] Where [F:YPRE]YUSR = GUSER
For [YPRE]
  NLL+=1
  Insa NLL,1 [M:PREP]KBLIG
  [M:PREP]KBLIG +=1
  nolign = NLL + 1
  status = 0

  [M:PREP]YORNUM(KBLIG-1)  = [F:YPRE]YSOHNUM

  #Traigo los datos del pedido
  Read [F:YSOH]SOH0 = [F:YPRE]YSOHNUM
  If fstat = 0
    [M:PREP]YORDINVNOT(KBLIG-1) = [F:YSOH]ORDINVNOT
    [M:PREP]YIMPUESTO(KBLIG-1)  = [F:YSOH]ORDINVATI - [F:YSOH]ORDINVNOT
    [M:PREP]YORDINVATI(KBLIG-1) = [F:YSOH]ORDINVATI
    [M:PREP]YDLRNOT(KBLIG-1)    = [F:YSOH]DLRNOT
    [M:PREP]YDME(KBLIG-1)       = [F:YSOH]DME
    [M:PREP]YCUSORDREF(KBLIG-1) = [F:YSOH]CUSORDREF #JPL - Añado referencia del pedido

    Raz WCDTSTA
    Raz WOST, WOSTAUZ

    Call SDCDTSTA('', [F:YSOH]BPCORD, 1, 0, [F:YSOH]CUR, [F:YSOH]ORDDAT, 0, 1, WCDTSTA, WOST, WOSTAUZ) From TRTVENCDT

    [M:PREP]YOSTAUZ(KBLIG-1)    = WOSTAUZ
    [M:PREP]YOST(KBLIG-1)       = WOST

    If WOST > WOSTAUZ
      [M:PREP]YOSTAUZSO(KBLIG-1)     = 2
    Else
      [M:PREP]YOSTAUZSO(KBLIG-1)     = 1
    Endif

    [M:PREP]YSOHTEX(KBLIG-1)       = [F:YSOH]YSOHTEX

    [M:PREP]YBPCORD(KBLIG-1)       = [F:YSOH]BPCORD

  Endif

Next
Affzo [M:PREP]45
Return

#########################################################################
$CTRL_ITM
# Punto justo antes de entrar al LOAD_SOQ y cargar la linea en pantalla

# Si no se dejan los campos en blanco, lo comprobamos
If [M:PREP]YBPSSTR <>"" | [M:PREP]YBPSEND <>""
  #Infbox('Pedido'-[F:SOQ]SOHNUM-'Linea'-num$([F:SOQ]SOPLIN)-'FMI'-num$([F:SOQ]FMI)-'FMINUM'-[F:SOQ]FMINUM)

  GPE=1
#  If clalev([F:YMLK]) =0 Local File MTOLINK   [YMLK]  Endif
#  #Read [F:YMLK]MLK0 = [F:SOQ]STOFCY;[F:SOQ]ITMREF;2;[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
#  Filter [YMLK] Where [F:YMLK]STOFCY = [F:SOQ]STOFCY and [F:YMLK]ITMREF = [F:SOQ]ITMREF
#&                     and [F:YMLK]DEMNUM = [F:SOQ]SOHNUM and [F:YMLK]DEMLIN = [F:SOQ]SOPLIN and [F:YMLK]DEMSEQ = [F:SOQ]SOQSEQ
#  For [YMLK]
#    If clalev([F:YPOH]) =0 Local File PORDER   [YPOH]  Endif
#    Read [F:YPOH]POH0 = [F:YMLK]RESSNUM
#    If fstat = 0
#      If ([M:PREP]YBPSSTR <>"" & [F:YPOH]BPSNUM >= [M:PREP]YBPSSTR & [M:PREP]YBPSEND ="" )
#&         | ([M:PREP]YBPSSTR ="" & [M:PREP]YBPSEND <>"" & [F:YPOH]BPSNUM <= [M:PREP]YBPSEND)
#&         | ([M:PREP]YBPSSTR <>"" & [F:YPOH]BPSNUM >= [M:PREP]YBPSSTR & [M:PREP]YBPSEND <>"" & [F:YPOH]BPSNUM <= [M:PREP]YBPSEND)
#         GPE=0
#         Break
#      Else
#        # No le dejamos guardar la línea
#       GPE=1
#      Endif
#    Else
#      # No le dejamos guardar la línea
#     GPE=1
#    Endif
#  Next
#  Filter [YMLK]  
##############################JPL - MODIFICADO EN ARRANQUE ##########################################

    If clalev([F:YITM]) =0 Local File ITMMASTER   [YITM]  Endif
    Read [F:YITM]ITM0 = [F:SOQ]ITMREF
    If fstat = 0	
       If ([M:PREP]YBPSSTR <>"" & [F:YITM]TSICOD(0) >= [M:PREP]YBPSSTR & [M:PREP]YBPSEND ="" )
&        | ([M:PREP]YBPSSTR ="" & [M:PREP]YBPSEND <>"" & [F:YITM]TSICOD(0) <= [M:PREP]YBPSEND)
&        | ([M:PREP]YBPSSTR <>"" & [F:YITM]TSICOD(0) >= [M:PREP]YBPSSTR & [M:PREP]YBPSEND <>"" & [F:YITM]TSICOD(0) <= [M:PREP]YBPSEND)
         GPE=0
      Else
        # No le dejamos guardar la línea
        GPE=1
       Endif
     Else
       # No le dejamos guardar la línea
      GPE=1
    Endif

######################################################################################################

  ## ANTES LO COMPROBABAMOS POR LA CONTRAMARCA
  ##-------------------------------------------------------
#  If [F:SOQ]FMI = 3 & [F:SOQ]FMINUM <> ""
#    If clalev([F:YPOH]) =0 Local File PORDER   [YPOH]  Endif
#    Read [F:YPOH]POH0 = [F:SOQ]FMINUM
#    If fstat = 0
#      If ([M:PREP]YBPSSTR <>"" & [F:YPOH]BPSNUM >= [M:PREP]YBPSSTR) | ([M:PREP]YBPSEND <>"" & [F:YPOH]BPSNUM <= [M:PREP]YBPSEND)
#        Return
#      Else
#        # No le dejamos guardar la línea
#        GPE=1
#      Endif
#    Endif
#  Else
#    # No le dejamos guardar la línea
#    GPE=1
#  Endif
  ##-------------------------------------------------------

Endif

Return
#########################################################################

$BORRAR_INTERMEDIOS
Trbegin [YPRE]
   Delete  [YPRE] Where [F:YPRE]YUSR=GUSER
Commit
Return

#########################################################################

$BEFWRIPRH

Case [F:PRW1]ORITYP
    When 1,2
      If !clalev([F:YSOH]) : Local File SORDER [F:YSOH] : Endif
      Read [F:YSOH]SOH0=[F:PRW1]ORI1
      If !fstat
        If [F:PRH]YPRHTEX <> "" | [F:YSOH]YSOHTEX <> ""
         [F:PRH]YPRHTEX = [F:YSOH]YSOHTEX
        Endif
        [F:PRH]YBPCNAM = [F:SOH]BPCNAM
      Endif
Endcase

Return

#########################################################################
###########################################################################
# Función para quitar el formato rtf del campo clob
Funprog F_RTF2TEXT(CLOB)
Variable Clbfile CLOB
  Local Integer LENTXMT : LENTXMT = 250
  Local Integer NRIGHE : NRIGHE = 4 # 4 = 250x4 char
  Local Char XOUT(LENTXMT)(NRIGHE)
  Call S_RTF2TEXT(LENTXMT,CLOB,XOUT,NRIGHE) From RTF2TEXT
  #Concatenate the row with plain text, by removing the empty space
  Local Char XRET(250) : Raz XRET
  For XI = 0 To NRIGHE
    XRET += vireblc(XOUT(XI),2)
  Next
End XRET
###########################################################################

$BEFWRIPRE

Case [F:PRW]ORITYP
    When 1,2
      If !clalev([F:YSOP]) : Local File SORDERP [F:YSOP] : Endif
      Read [F:YSOP]SOP0=[F:PRE]ORINUM; [F:PRE]ORILIN; [F:PRE]ORISEQ
      If !fstat
        #Llevo importes de línea del pedido al vale
        [F:PRE]YNETPRI = [F:SOP]NETPRI
        [F:PRE]YAMTNOTLIN = [F:SOP]NETPRI * [F:PRE]QTYSTU
      Endif
Endcase

Return






