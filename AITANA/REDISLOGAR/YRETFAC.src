#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Gestión de la máscara YRECFAC
# Retener entrega para que no se pueda facturar y pedir motivo
# Para marcar como retenido de facturación, tiene que estar validada la entrega
######################################################################################ç
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "TITRE"         : Gosub TITLE
 When "DEBUT"         : Gosub DEBUT
 When "OK"            : Gosub OK
 When "ABA"           : Gosub ABA
Endcase
Return
#########################################################################
$OUVRE
Case GACTION
 When "YRETFAC"  : Gosub OUV_YRETFAC
Endcase
Return
########################################################
$TITLE
  Case GACTION
   When "YRETFAC"  : TIT="Motivo para retener la entrega y no se facture"
  Endcase
Return
########################################################
$DEBUT
Case GACTION
 When "YRETFAC" : Gosub DEB_YRETFAC
Endcase
Return
########################################################
$OK
Case GACTION
 When "YRETFAC"  : Gosub OK_YRETFAC
Endcase
Return
########################################################
$ABA
Case GACTION
 When "YRETFAC"  : Gosub ABA_YRETFAC
Endcase
Return
########################################################
$OUV_YRETFAC
Return
########################################################
$DEB_YRETFAC
If !clalev ([F:YSDH]) : Local File SDELIVERY  [YSDH] : Endif
Read [F:YSDH]SDH0=[M:SDH0]SDHNUM
[M:YREF]YRETTXT=[F:YSDH]YRETTXT
Affzo [YREF]1-99
Return
########################################################
$OK_YRETFAC
If !clalev ([F:YSDH]) : Local File SDELIVERY  [YSDH] : Endif
Read [F:YSDH]SDH0=[M:SDH0]SDHNUM
If [F:YSDH]CFMFLG < 2
  Infbox('Entrega no validada, no se puede retener factuación')
Else
  [F:YSDH]YRETTXT=[M:YREF]YRETTXT
  [F:YSDH]YRETFAC = 2
  [F:YSDH]INVFLG = 2
  Rewrite [YSDH]
Endif
[M:SDH0]YRETFAC = [F:YSDH]YRETFAC
[M:SDH1]INVFLG  = [F:YSDH]INVFLG
[M:SDH1]YRETTXT = [F:YSDH]YRETTXT
Affzo [M:SDH0]1-99
Affzo [M:SDH1]1-99
#
FIN=1
Return
########################################################
$ABA_YRETFAC
[M:YREF]=[M:YREFW]
Affzo [YREF]1-99
Return
#########################################################################
#########################################################################
#########################################################################
$PROCESO_YRETFAC
Call DEBTRANS From GLOCK
$TR_SDH_YRETFAC
Trbegin [SDH]
  Readlock [SDH]SDH0=[M:SDH0]SDHNUM
  If fstat=1
    GOK=-1 : GLOCK="$DELIVERY"-[M:SDH0]SDHNUM             : Goto ROLL_YRETFAC
  Elsif fstat
    GOK=0  : Call RSTA("SDH",[M:SDH0]SDHNUM) From GLOCK : Goto AB_YRETFAC
  Endif
  If [F:SDH]CFMFLG < 2
    Infbox('Entrega no validada, no se puede retener factuación')
    GOK = 0
    Goto AB_YRETFAC
  Else
    [F:SDH]YRETTXT=[M:YRETW]YRETTXT
    [F:SDH]YRETFAC = 2
    [F:SDH]INVFLG = 2
    Rewrite [SDH]
  Endif
  If fstat GOK=0 : Call FSTA("SDH") From GLOCK : Goto AB_YRETFAC : Endif
Commit
Return
#########################################################################
$ROLL_YRETFAC
Rollback : Call ROLL From GLOCK
If GROLL : Return  : Endif
#########################################################################
$AB_YRETFAC
Rollback
Return
#########################################################################

