#<AdxTL>@(#)0.0.0.0 $Revision$
# Clase OPPOR

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE" : Gosub AINSERT_CONTROL_BEFORE
        When "AINSERT_AFTER"          : Gosub AINSERT_AFTER
      Endcase
  Endcase
Return

#------------------------------------------------------------------------------#

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!

$PROPERTIES
  Case [L]CURPRO
    When "OPPNUM" : Gosub PROP_OPPNUM
  Endcase
Return

#------------------------------------------------------------------------------#

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!

$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#------------------------------------------------------------------------------#

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!

$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#------------------------------------------------------------------------------#

$PROP_OPPNUM
  Case [L]ARULE
    When "INIT"    : Gosub OPPNUM_INIT
  Endcase
Return

#------------------------------------------------------------------------------#

$OPPNUM_INIT
  # Viene de la acción "Copiar proyecto"
  If (func YALIVELIB.COME_FROM_TRT("XX03SOPPCOP"))>0
    If clalev([M:XX03SC0])>0
      this.YREVNUM = [M:XX03SC0]YREVNUM
      this.YSUBPJTNUM = [M:XX03SC0]YSUBPJTNUM
      If [M:XX03SC0]YFATHERPJT<>""
        this.OPPNUM = func YXX03SOPPCOP.GET_FATHER([M:XX03SC0]YFATHERPJT)
      Else
        this.OPPNUM = ""
      Endif
    Else
      this.YREVNUM = "00"
      this.YSUBPJTNUM = "000"
      this.OPPNUM = ""
    Endif
  Endif
Return

#------------------------------------------------------------------------------#

$AINSERT_CONTROL_BEFORE
  # Viene de la acción "Copiar proyecto"
  If (func YALIVELIB.COME_FROM_TRT("XX03SOPPCOP"))>0
    If clalev([M:XX03SC0])>0
      this.YREVNUM = [M:XX03SC0]YREVNUM
      this.YSUBPJTNUM = [M:XX03SC0]YSUBPJTNUM
      If [M:XX03SC0]YFATHERPJT<>""
        this.OPPNUM = func YXX03SOPPCOP.GET_FATHER([M:XX03SC0]YFATHERPJT)
      Endif
    Else
      this.YREVNUM = "00"
      this.YSUBPJTNUM = "000"
    Endif
  Endif

  If this.OPPNUM=""
    Gosub AINSERT_CONTROL_BEFORE From OPPOR_CSTD_EVENTS
    If this.AERROR<>null : Return : Endif
  Endif

  this.OPPNUM += "-" + this.YREVNUM + this.YSUBPJTNUM

  If this.CRM(1)<>null
    this.CRM(1).OPPNUM = this.OPPNUM
  Endif
  If this.TCHISPJM=[V]CST_ATRUE and this.PJM(1)<>null
    this.PJM(1).OPPNUM = this.OPPNUM
  Endif
Return

#------------------------------------------------------------------------------#

$AINSERT_AFTER
  If (func YALIVELIB.COME_FROM_TRT("XX03SOPPCOP"))>0
    If clalev([M:XX03SC0])>0
      If [M:XX03SC0]YFATHERPJT<>""
        Local File XOPPASS [ZXOH]
        Read [F:ZXOH]XOH0=[M:XX03SC0]YFATHERPJT;this.OPPNUM
        If fstat
          Raz [F:ZXOH]
          [F:ZXOH]FATHER = [M:XX03SC0]YFATHERPJT
          [F:ZXOH]OPPNUM = this.OPPNUM
          Write [F:ZXOH]
          If fstat<>[V]CST_AOK
            [L]ASTATUS = fmet this.ASETERROR("XOPPASS", mess(7,6100,1), [V]CST_AERROR)
          Endif
        Endif
      Endif
    Endif
  Endif
Return

