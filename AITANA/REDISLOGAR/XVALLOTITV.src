#<AdxTL>@(#)2.0.0.0 $Revision$
#ACV#X12
#TIT#Validation en lot des inters

# CGUES 30/01/01
# MAJ Othyr 21/02/02 DS 35180 + 35027
# OTHYR 24/10/2002
# CGUES 20/12/2002 suppression du verrou global acr le verrou est propre à chaque validation d'intervention

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$ACTION
#--- Actions liées au scénario GTRAITE
Case ACTION
 When "INIT"       : Gosub INIT
 When "AVANT_PAR"  : Gosub AVANT_PAR
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "TERMINE"    : Gosub TERMINE
 When "OK"         : Gosub A_OK
 When "END"        : Gosub A_END
 When "DEBUT"      : Gosub A_DEBUT
 When Default
Endcase
Return

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$INIT
If [V]GSERVEUR
    Onerrgo ERR_BATCH
Endif
Gosub OUVRE
Return

################################################################################
$AVANT_PAR
Return

################################################################################
$CONTROLE
If [V]GOK < 1 Then
    FIN = 1
Else
    TMP = 1
    If [M:DIA]TSSITE <> 2 & [M:DIA]FCYBEG = "" Then
        GERR = 1
        GMESSAGE = mess(165,GXMSGPSA(0),1)
    Endif
Endif
Return

################################################################################
$EXEC
Gosub OUV_TRACE
#Gosub VERROU
#If OK = 1 Then
#    Return
#Endif

Gosub VALLOTITV

#Gosub DEVERROU
Return

################################################################################
$TERMINE
If ![V]GSERVEUR
    Call FERME_TRACE From LECFIC
    TRA = 1
Endif
Return

################################################################################
$A_OK
FIN = 1
[V]GOK = 1
Return

################################################################################
$A_END
FIN = 1
[V]GOK = 0
Return

################################################################################
$A_DEBUT
Affzo [M:DIA]
Return

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$ERR_BATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
GERR=1
End

################################################################################
$VALLOTITV

Gosub FILTRE

# On referme le masque ici, car dans XVALGAS2 on ré-ouvre un mask avec l'abreviation DIA
Close Local Mask [DIA]

# Pour appel par Pt d'entrée
$AV_FILTER

# On filtre les DS suivant les critères saisis
Filter [F:REQ] Where [F:REQ]FLGREQCLO<>2 & [F:REQ]FLGREQCAN<>2
&                  & evalue([L]CRITREQ1) & evalue([L]CRITREQ2) & evalue([L]SPECRITREQ) Order By Key REQ0

# On filtre les interventions suivant les critères saisis
Filter [F:XITR] Where [F:XITR]FLGITVVAL = 1 & evalue([L]CRITITR1) & evalue([L]CRITITR2) & evalue([L]SPECRITITR)

For [F:XITR]ITR4
    Read [F:REQ]REQ0 = [F:XITR]REQNUM
    # Si pas de problème de lecture, ceci veut dire que la DS répond aux critères saisis des DS (elle est dans le filtre)
    If !fstat Then
        If FLG_TSSITE = 2 Then
            Call CTL_AUZFCY([F:REQ]FCY,"GESITV","V",[L]AUZFCY) From XTRTFCY
            # Pas les droits de validation sur tel site si [L]AUZFCY = 0
            If [L]AUZFCY = 0 Then
                Goto SUIV_ITR
            Endif
        Endif

        # Vérification si validation possible
        Call VERIF_VALID([F:XITR]ITVNUM,[L]OK)From SPVOBJITV
        If [L]OK
            [V]GOK=1

            Call MAJ_CSTSTD([F:XITR]ITVNUM,[L]OK)From XMAJCSTITV #-- CLAVA 01/08/11 calcul prix de revient

            If [V]GOK=1 : Call B_VALID([F:XITR]ITVNUM,2)From SPVOBJITV2 : Endif

            If [V]GOK=1
                Call ECR_TRACE(mess(200,GXMSGPSA(0),1)-[F:XITR]ITVNUM,0) From GESECRAN
            Else
                Call ECR_TRACE(mess(201,GXMSGPSA(0),1)-[F:XITR]ITVNUM,1) From GESECRAN
            Endif
        Endif
    Endif

$SUIV_ITR
Next

Filter [XITR]
Filter [REQ]

# LBORN 17/08/2010 - Génération des documents en direct / GIDENT
Call GENDOC_DIR From XVALGAS2

Return

################################################################################
$OUVRE
If !clalev([F:XITR]) : Local File ITVREQ    [XITR] : Endif
If !clalev([F:ITD])  : Local File ITVREQD   [ITD]  : Endif
If !clalev([F:REQ])  : Local File REQUEST   [REQ]  : Endif
If !clalev([F:X7Y])  : Local File PARINTTYP [X7Y]  : Endif

Local Integer OK
Local Char TIT(100)
Local Char CRITITR1(200)
Local Char CRITITR2(200)
Local Char CRITREQ1(250)
Local Char CRITREQ2(250)
Local Char SPECRITITR(250) : #Réservé client
Local Char SPECRITREQ(250) : #Réservé client
Local Integer AUZFCY

Local Integer ESS
Local Integer FLG_TSSITE

Local Mask VALITV [DIA]

TIT=mess(7,[V]GXMSGPSA,1)
TMP=1

Return

################################################################################
$FILTRE

[L]CRITITR1   = "1"
[L]CRITITR2   = "1"
[L]CRITREQ1   = "1"
[L]CRITREQ2   = "1"
[L]SPECRITITR = "1"
[L]SPECRITREQ = "1"

If [M:DIA]TSSITE = 2 Then
    FLG_TSSITE = 2
Else
    FLG_TSSITE = 1
    If [M:DIA]FCYBEG <> "" Then
        [L]CRITITR1 -= "& [F:XITR]FCY='"+[M:DIA]FCYBEG+"'"
    Endif
Endif

[L]CRITITR1 -= "& [F:XITR]FLGITVCAN<>2"

If [M:DIA]ITVTYPDEB <> "" Then
    [L]CRITITR1 -= "& [F:XITR]ITVTYP>='"+[M:DIA]ITVTYPDEB+"'"
Endif
If [M:DIA]ITVTYPFIN <> "" Then
    [L]CRITITR1 -= "& [F:XITR]ITVTYP<='"+[M:DIA]ITVTYPFIN+"'"
Endif

If [M:DIA]ITVNUMDEB <> "" Then
    [L]CRITITR1 -= "& [F:XITR]ITVNUM>='"+[M:DIA]ITVNUMDEB+"'"
Endif
If [M:DIA]ITVNUMFIN <> "" Then
    [L]CRITITR1 -= "& [F:XITR]ITVNUM<='"+[M:DIA]ITVNUMFIN+"'"
Endif

If [M:DIA]DATITVDEB <> [0/0/0] Then
    [L]CRITITR2 -= "& [F:XITR]ITVDAT>=["+right$([M:DIA]DATITVDEB,7)+"/"+mid$([M:DIA]DATITVDEB,5,2)+"/"+left$([M:DIA]DATITVDEB,4)+"]"
Endif
If [M:DIA]DATITVFIN <> [0/0/0] Then
    [L]CRITITR2 -= "& [F:XITR]ITVDAT<=["+right$([M:DIA]DATITVFIN,7)+"/"+mid$([M:DIA]DATITVFIN,5,2)+"/"+left$([M:DIA]DATITVFIN,4)+"]"
Endif

If [M:DIA]QUEUEDEB <> "" Then
    [L]CRITITR2 -= "& [F:XITR]QUEUEITV>='"+[M:DIA]QUEUEDEB+"'"
Endif
If [M:DIA]QUEUEFIN <> "" Then
    [L]CRITITR2 -= "& [F:XITR]QUEUEITV<='"+[M:DIA]QUEUEFIN+"'"
Endif

If [M:DIA]BPCINVBEG <> "" Then
    [L]CRITREQ1 -= "& [F:REQ]BPCINV>='"+[M:DIA]BPCINVBEG+"'"
Endif
If [M:DIA]BPCINVEND <> "" Then
    [L]CRITREQ1 -= "& [F:REQ]BPCINV<='"+[M:DIA]BPCINVEND+"'"
Endif

If [M:DIA]REQNUMBEG <> "" Then
    [L]CRITREQ1 -= "& [F:REQ]REQNUM>='"+[M:DIA]REQNUMBEG+"'"
Endif
If [M:DIA]REQNUMEND <> "" Then
    [L]CRITREQ1 -= "& [F:REQ]REQNUM<='"+[M:DIA]REQNUMEND+"'"
Endif

If [M:DIA]REQTYPDEB <> "" Then
    [L]CRITREQ1 -= "& [F:REQ]REQTYP>='"+[M:DIA]REQTYPDEB+"'"
Endif
If [M:DIA]REQTYPFIN <> "" Then
    [L]CRITREQ1 -= "& [F:REQ]REQTYP<='"+[M:DIA]REQTYPFIN+"'"
Endif

If [M:DIA]OPPNUMBEG <> "" Then
    [L]CRITREQ2 -= "& [F:REQ]OPPNUM>='"+[M:DIA]OPPNUMBEG+"'"
Endif
If [M:DIA]OPPNUMEND <> "" Then
    [L]CRITREQ2 -= "& [F:REQ]OPPNUM<='"+[M:DIA]OPPNUMEND+"'"
Endif

If [M:DIA]CONNUMBEG <> "" Then
    [L]CRITREQ2 -= "& [F:REQ]CONREV>='"+[M:DIA]CONNUMBEG+"'"
Endif
If [M:DIA]CONNUMEND <> "" Then
    [L]CRITREQ2 -= "& [F:REQ]CONREV<='"+[M:DIA]CONNUMEND+"'"
Endif

If [M:DIA]LOTPJTBEG <> "" Then
    [L]CRITREQ2 -= "& [F:REQ]LOTPJT>='"+[M:DIA]LOTPJTBEG+"'"
Endif
If [M:DIA]LOTPJTEND <> "" Then
    [L]CRITREQ2 -= "& [F:REQ]LOTPJT<='"+[M:DIA]LOTPJTEND+"'"
Endif

# ajout des critères du client
GPOINT="F_VALLOT" : Gosub ENTREE From EXEFNC

Return

################################################################################
$OUV_TRACE

# Ouverture du fichier Trace

If !GSERVEUR
   Call OUVRE_TRACE(TIT) From LECFIC
Endif

# Ecriture des critères de lancements
Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call PRTSCR("VALITV","DIA","",0,1) From ATRTX3
Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Return

################################################################################
$VERROU

# Verrou

SYMBOLE = "XTRTVALITV/"+[M:DIA]FCYBEG
Lock = SYMBOLE With lockwait = 0
OK=2
If fstat Then
    Call ECR_TRACE(mess(30,100,1),1) From GESECRAN
    OK=1
Endif
Return

################################################################################
$DEVERROU

# deverrou

Unlock =SYMBOLE
Return



################################################################################
################################################################################
################################################################################
################################################################################

########################################
Subprog AV_TSSITE(VALEUR)
Variable Integer  VALEUR
Call AP_TSSITE(VALEUR)
End

########################################
Subprog AP_TSSITE(VALEUR)
Variable Integer  VALEUR
If VALEUR=2 Then
    Effzo [M]FCYBEG
    Diszo [M]FCYBEG
Else
    Actzo [M]FCYBEG
Endif
End

########################################
Subprog D_FCYBEG(VALEUR)
Variable Char     VALEUR
VALEUR=GUSRFCY
End

########################################
Subprog C_FCYBEG(VALEUR)
Variable Char     VALEUR
If [M]TSSITE<>2 & VALEUR="" Then
    mkstat=2
Endif
End

########################################
Subprog AV_DATITVFIN(VALEUR)
Variable Date    VALEUR

VALEUR=[M]DATITVDEB
End
