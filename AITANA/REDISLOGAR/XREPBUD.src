Local Char VALBOUT(250) , PARBOUT(250)(1..20)
PARBOUT(1) = ""
PARBOUT(2)="FRL-0000000637"
GACTION   = "XREPBUD"
Call SAISIE_CHAR(VALBOUT,PARBOUT,"XREPBUD","XREPBUD","") From GSAISIE
End

#########################################################################################

$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE       From XREPBUD2
  When "DEBUT"       : Gosub DEBUT       From XREPBUD2
  When "SETBOUT"     : Gosub SETBOUT     From XREPBUD2
  When "APRES_MODIF" : Gosub APRES_MODIF From XREPBUD2
  When "ABA"         : Gosub ABA         From XREPBUD2
  When "ENR"         : Gosub ENR         From XREPBUD2
  When "MEN"         : Gosub A_MEN       From XREPBUD2
Endcase
Return

######################################################################################
Subprog IB_NBLIG
If ([M:XRB]BUDMNT(nolign-1)<>0 | [M:XRB]BUDRAF(nolign-1)<>0) & [M:XRB]SITNUM<>""
  [V]GBOUT5=mess(134,[V]GXMSGOPP,1)
Else
  Raz [V]GBOUT5
Endif
End

######################################################################################
Subprog B5_NBLIG
Call TEMPON("") From GESECRAN
Call REPART_FRL(nolign) From XREPBUD2
Call AFFSTYL From XREPBUD2
Affzo [M:XRB]10
Call TEMPOFF From GESECRAN
mkstat=4
End
