#<AdxTL>@(#)10.0.0.0 $Revision$
#ACV#X11
#TIT#Paramètre de la génération des documents

Local Char PARAM(30)(1..16),VALEUR(10)
Raz PARAM , VALEUR
GFONCTION="XPARAMVGA"
Call TRAITE_CHAR(VALEUR,PARAM,"","XPARAMVGA","XPARAMVGA",4) From GTRAITE
End

################################################################################
################################################################################
################################################################################

################################################################################
$ACTION
    #--- ACTIONS liées au scénarion GTRAITE
    Case ACTION
         When "INIT"       : Gosub INIT
         When "CONTROLE"   : Gosub CONTROLE
         When "EXEC"       : Gosub EXEC
         When "TERMINE"    : Gosub TERMINE
         When Default
              Case BOITE
                   When "XPARAMVGA"  : Gosub FEN_PRIN
              Endcase
    Endcase
Return

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$FEN_PRIN
    Case ACTION
         When "OK"         : Gosub A_OK
         When "END"        : Gosub A_END
         When "DEBUT"      : Gosub A_DEBUT
         When Default      :
    Endcase
Return

################################################################################
$A_OK
    FIN = 1
    GOK = 1
Return

################################################################################
$A_END
    FIN = 1
    GOK = 0
Return

################################################################################
$A_DEBUT
    Affzo [M:XPV]
Return

################################################################################
$INIT
    Local Mask XPARAMVGA [XPV]
    Raz [M:XPV]
    TIT=mess(299,[V]GXMSGPSA,1)
    TMP=1               : # Affichage d'un message de temporisation

    Local Char X_VAL(10)
    If !clalev([F:ADW]) : Local File ADOVAL : Endif
Return

################################################################################
$CONTROLE
    If GOK<1
        FIN = 1
    Else
        TMP = 1
    Endif
Return

################################################################################
$EXEC
    Call PARAM("","XTPSVGA",X_VAL) From ADOVAL
    If val(X_VAL)=[M:XPV]TPSVGA
        Return
    Endif

    Call DEBTRANS From GLOCK
    Trbegin [ADW]
    Readlock [ADW]ADW0="";"";"XTPSVGA"
    If fstat=1
        Call ECR_TRACE("[ADW]PARAM=XTPSVGA"-mess(297,[V]GXMSGPSA,1),1) From GESECRAN
        Return
    Elsif fstat
        Raz [F:ADW]
        [F:ADW]PARAM="XTPSVGA"
        [F:ADW]CREUSR=GUSER
        [F:ADW]CREDAT=date$
        [F:ADW]CREDATTIM=datetime$
        [F:ADW]VALEUR=num$([M:XPV]TPSVGA)
        Write [ADW]
    Elsif fstat=0
        [F:ADW]UPDUSR=GUSER
        [F:ADW]UPDDAT=date$
        [F:ADW]UPDDATTIM=datetime$
        [F:ADW]VALEUR=num$([M:XPV]TPSVGA)
        Rewrite [ADW]
    Endif
    If fstat
        Call FSTA("ADW") From GLOCK
        Rollback
        Return
    Else
        Commit
    Endif
Return

################################################################################
$TERMINE
    If !GSERVEUR
        If GERRTRACE
           TRA=1
        Else
           Raz [V]GTRACE
        Endif
    Endif
Return

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
# arrêt de XGENVGA
Subprog ARRET
    Local Integer Z_REP

    Z_REP=1
    Call OUINON(mess(300,[V]GXMSGPSA,1),Z_REP) From GESECRAN

    If Z_REP<>2 : End : Endif

    If !clalev([F:ADO]) : Local File ADOVAL : Endif
    Local Integer VAL_GENVGA

    VAL_GENVGA=-99999
    Gosub MAJ_ADOVAL_XGENVGA
End


################################################################################
# MàJ de XGENVGA dans ADOVAL
$MAJ_ADOVAL_XGENVGA
    Call DEBTRANS From GLOCK
    Trbegin [ADW]
    Readlock [ADW]ADW0="";"";"XGENVGA"
    If fstat=1
        Call ECR_TRACE("[ADW]PARAM=XGENVGA"-mess(297,[V]GXMSGPSA,1),1) From GESECRAN
        Return
    Elsif fstat
        Raz [F:ADW]
        [F:ADW]PARAM="XGENVGA"
        [F:ADW]CREUSR=GUSER
        [F:ADW]CREDAT=date$
        [F:ADW]CREDATTIM=datetime$
        Gosub MAJ_VALEUR
        Write [ADW]
    Elsif fstat=0
        Gosub MAJ_VALEUR
        Rewrite [ADW]
    Endif
    If fstat
        Call FSTA("ADW") From GLOCK
        Rollback
        Return
    Else
        Commit
    Endif
Return

$MAJ_VALEUR
    [F:ADW]VALEUR=num$(val([F:ADW]VALEUR)+VAL_GENVGA)
    If val([F:ADW]VALEUR)<=0
        [F:ADW]VALEUR=""
    Endif
Return

################################################################################
################################################################################
################################################################################
################################################################################

########################################
Subprog AV_TPSVGA(VALEUR)
    Variable Decimal VALEUR

    If !clalev([F:ABR]) : Local File ="X3.ABATRQT" [ABR] : Endif

    Local Char X_VAL(10)

    Call PARAM("","XTPSVGA",X_VAL) From ADOVAL
    VALEUR=val(X_VAL)

    Call PARAM("","XGENVGA",X_VAL) From ADOVAL
    II=0
    For [ABR] Where TACHE="XGENVGA"
&                &  DOSSIER=nomap
&                &  FLAG<=2
        II+=1
    Next

    If X_VAL<>""
        [M]STA=2
    Else
        If II=0
            [M]STA=1
        Else
            [M]STA=3
        Endif
    Endif
    [M]RQT=num$(II)
    Affzo [M]STA , RQT
End
