#ACV#X12
#TIT#Gestion de l'objet Opérations PSA

#==========================================================================================
# Gestion de l'objet   : Gestion de l'objet Opérations PSA (codes opérations)
#
# Auteur               :
# Date de création     :
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 30/01/2012    SOUCH        [Planner] Synchronisation
# 08/08/2002    OTHYR        Modélisation Web
# 22/12/2004    CPERR        Gestion des textes traduisibles
#==========================================================================================
GBIDC1=""
GBIDC2=""
GFONC1="GESOPE"
Call OBJET("OPE",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

#########################################################
$ACTION

# Appel fonctions complémentaires GFI pour l'objet OPE
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

#===== Actions scénario objet
Case ACTION
    When "INICRE"     : Gosub INICRE      From SPVOBJOPE
    When "INIMOD"     : Gosub INIMOD      From SPVOBJOPE
    When "CHANGE"     : Gosub CHANGE      From SPVOBJOPE
    When "ANNULE"     : Gosub ANNULE      From SPVOBJOPE
    When "OUVRE"      : Gosub OUVRE       From SPVOBJOPE
    When "AVANTBOUT"  : Gosub AVANTBOUT   From SPVOBJOPE
    When "EXEBOUT"    : Gosub EXEBOUT     From SPVOBJOPE
    When "SETBOUT"    : Gosub SETBOUT     From SPVOBJOPE
    When "APRES_CRE"  : Gosub APRES_CRE   From SPVOBJOPE
    When "LIENS"      : Gosub LIENS       From SPVOBJOPE
    When "RAZDUP"     : Gosub RAZDUP      From SPVOBJOPE
Endcase

#-----------------------------------------------------#
# Synchronisation Planner                             #
#-----------------------------------------------------#

If GXOPTAGE=1 & GXAPPNAMPLA<>""
    Case ACTION
        When "APRES_CRE"    : Gosub X3PLANNER_MAJ_OPE From SPVOBJOPE
        When "APRES_MOD"    : Gosub X3PLANNER_MAJ_OPE From SPVOBJOPE
        When "APRES_ANNULE" : Gosub X3PLANNER_DEL_OPE From SPVOBJOPE
    Endcase
Endif
#------------------------------------------------------#


#===== Actions scénario sélection liste et dans table
Case ACTION
    When "SEL_TABLE"  : Gosub SEL_TABLE   From SPVOBJOPE
    When "VERF_TABLE" : Gosub VERF_TABLE  From SPVOBJOPE
    When "SEL_LISTE"  : Gosub SEL_LISTE   From SPVOBJOPE
    When "VERF_LISTE" : Gosub VERF_LISTE  From SPVOBJOPE
Endcase

Return


########################################
Subprog C_OPTTYP(VALEUR)
Variable Char    VALEUR()

Local File AOBJET [AOB]

Case [M]OPETYP
    When 1
        Call LECTURE("AOB","ITM","")From CONTOBJ
    When 2
        Call LECTURE("AOB","IUS","")From CONTOBJ
    When 3
        Call LECTURE("AOB","RSE","")From CONTOBJ
Endcase

For I = 1 To len(VALEUR)
    If !find(mid$(VALEUR,I,1),[F:AOB]OPTCOD(0..dim([F:AOB]OPTCOD)-1))
        GMESSAGE = mess(206,[V]GXMSGPSA,1)-mid$(VALEUR,I,1)        :# Option inexistante
        mkstat   = 1
        Break
    Endif
    If instr(I+1,VALEUR,mid$(VALEUR,I,1)) <> 0 Then
        GMESSAGE = mess(207,[V]GXMSGPSA,1)-mid$(VALEUR,I,1)        :# Option déjà sélectionnée
        mkstat   = 1
        Break
    Endif
Next I

Close Local File [AOB]

End

########################################
Subprog AV_OPETYP(VALEUR)
Variable Integer VALEUR

If VALEUR = 1 Then
    [M]RECMOD = 4
    Grizo [M]15
Else
    Actzo [M]15
Endif

End

########################################
Subprog AP_OPETYP(VALEUR)
Variable Integer VALEUR

If VALEUR = 1 Then
    [M]RECMOD = 4
    Grizo [M]15
Else
    Actzo [M]15
Endif

End

########################################
Subprog AS_ITVTYP(VALEUR)
Variable Char    VALEUR()
mkstat=2 : #conserve le lien
End


########################################
Subprog AS_UPDAGE(VALEUR)
Variable Integer VALEUR
If [M]OPETYP<2 : mkstat=1 : Endif
End



