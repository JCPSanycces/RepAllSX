######################################################################################
Subprog AV_REO(VALEUR)
Variable Integer VALEUR
If [M]OPETYP<>1
  VALEUR=1
  Grizo [M]REO
Else
  Actzo [M]REO
Endif
End

######################################################################################
Subprog AV_FLGTES(VALEUR)
Variable Integer VALEUR
If [M]OPETYP<>2 | !find([M]RECMOD,4,5)
  VALEUR=1
  Grizo [M]FLGTES
Else
  Actzo [M]FLGTES
Endif
End
