#####################################################################################
# CodAct: YA039 - Campos específicos
#####################################################################################

$ACTION
Case ACTION
    When "ALISDDSIH"    : Gosub LOAD_LINES
    When "ALISID"       : Gosub LOAD_LINES #pasa datos de desde el tratamiento masivo
    When "ALISRDSIH"    : Gosub ALISRDSIH
Endcase
Return
######YA032 - Tratamiento de la cabecera traspasable ########
#Pasamos los datos entre pantallas
$LOAD_LINES
If ACTION = 'ALISDDSIH'
  If [M:SIH0]YSIHTEX<>"" | [F:SDH]YSDHTEX <> ""
   [M:SIH0]YSIHTEX = [F:SDH]YSDHTEX
   [F:SIH]YSIHTEX = [M:SIH0]YSIHTEX
  Endif
Elsif ACTION = 'ALISID'
  Case INVORI
    When 2
      If [M:SIH0]YSIHTEX<>"" | [F:SOH]YSOHTEX <> ""
       [M:SIH0]YSIHTEX = [F:SOH]YSOHTEX
       [F:SIH]YSIHTEX = [M:SIH0]YSIHTEX
      Endif
    When 3
      If [M:SIH0]YSIHTEX<>"" | [F:SDH]YSDHTEX <> ""
       [M:SIH0]YSIHTEX = [F:SDH]YSDHTEX
       [F:SIH]YSIHTEX = [M:SIH0]YSIHTEX
      Endif
  Endcase
Endif
Return
