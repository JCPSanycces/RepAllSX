#####################################################################################
# CodAct: # YA001 - Contador objeto "Proyecto"
#####################################################################################

$ACTION

  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "RAZCRE"      : Gosub RAZCRE
    When "VERIF_CRE"   : Gosub VERIF_CRE
    When "AFF_XOPPHIE" : Gosub AFF_XOPPHIE
    When "MAJ_XOPPHIE" : Gosub MAJ_XOPPHIE
    When "SETBOUT"     : Gosub SETBOUT
    When "STATUT"      : Gosub STATUT
    When "AVANTBOUT"   : Gosub AVANTBOUT               ## GT_RM Code added for Sales Margin Validation
  Endcase
Return
#####################################################################################
$AVANTBOUT
  ##\b GT_RM Code added for Sales Margin Validation
  Case BOUT
    When "a"
      Local Integer ZDETCOUNT : ZDETCOUNT = 0
      For I = 0 To [M:XOP1]XNBS-1
        If [M:XOP1]XFRMNUMLIG(I) <> ""
          ZDETCOUNT = ZDETCOUNT + 1
        Endif
      Next
      If ZDETCOUNT = [M:XOP1]XNBS
        Infbox mess(3,6003,1)
        BOUT = ""
      Elsif ZDETCOUNT > 0
        Infbox mess(2,6003,1)
      Endif
  Endcase
  ##\e GT_RM Code added for Sales Margin Validation
Return
#####################################################################################

$OUVRE
  If clalev([F:YAOPP])=0 : Local File OPPOR     [YAOPP] : Endif  # YA001
  If clalev([F:YPFM])=0  : Local File PARFRMTYP  [YPFM] : Endif

  Local Integer NBRCL
Return

#####################################################################################

$RAZCRE
  # YA001
  # SPV
  For IPE=1 To dim(PROGSPV)
    If PROGSPV(IPE)="" : Break : Endif
    Gosub ACTION From =PROGSPV(IPE)
  Next IPE
  GPV = 1 # Desactiva SPV

  If !GPE
    Gosub ACTION From =PROGSUB
    GPE = 1 # Desactiva STD
  Endif

  Actzo [M:OPP1]YREVNUM, YSUBPJTNUM
  GZINSOPP.YREVNUM = "00"
  GZINSOPP.YSUBPJTNUM = "000"
  [M:OPP1]YREVNUM = "00"
  [M:OPP1]YSUBPJTNUM = "000"
  Affzo [M:OPP1]YREVNUM, YSUBPJTNUM
  # Fin YA001
Return

#####################################################################################

$VERIF_CRE
  # YA001
  If (func CHK_FATHER)=0
    If [M:OPP1]YREVNUM=""
      GERR = 1 : GMESSAGE = mess(1,6100,1)
      zonsui = "[M:OPP1]YREVNUM"
    Elsif [M:OPP1]YSUBPJTNUM=""
      GERR = 1 : GMESSAGE = mess(2,6100,1)
      zonsui = "[M:OPP1]YSUBPJTNUM"
    Else
      Local Char PADRE(GLONVCR), AUXOPPNUM(GLONVCR)
      PADRE = func GET_FATHER
      AUXOPPNUM = PADRE + "-" + [M:OPP1]YREVNUM + [M:OPP1]YSUBPJTNUM
      Read [F:YAOPP]OPP0 = AUXOPPNUM
      If !fstat
        GERR = 1 : GMESSAGE = AUXOPPNUM + ":" - mess(3,6100,1) + ".\" + mess(4,6100,1)
        zonsui = "[M:OPP1]YREVNUM"
      Else
        [M:OPP0]OPPNUM = PADRE
        GZINSOPP.OPPNUM = PADRE
      Endif
    Endif
  Else
    Raz [M:OPP0]OPPNUM
    [M:OPP1]YREVNUM = "00"
    [M:OPP1]YSUBPJTNUM = "000"
  Endif
  If GERR
    OK = 0 : GPV = 1 : GPE = 1
    SUIZON = zonsui
  Endif
  # Fin YA001
Return

######################################################################################
# YA002: Simula un LIENS
$AFF_XOPPHIE
  [M:XOP1]XYBPSNUM([M:XOP1]XNBS)    = [F:XHO]YBPSNUM
  [M:XOP1]XYEXTRCPDAT([M:XOP1]XNBS) = [F:XHO]YEXTRCPDAT
  [M:XOP1]YGROPRI([M:XOP1]XNBS)     = [F:XHO]YGROPRI
  [M:XOP1]YDISPUR([M:XOP1]XNBS)     = [F:XHO]YDISPUR
  [M:XOP1]YDISPUR2([M:XOP1]XNBS)    = [F:XHO]YDISPUR2
  [M:XOP1]YDISPUR3([M:XOP1]XNBS)    = [F:XHO]YDISPUR3
  [M:XOP1]YDISPUR4([M:XOP1]XNBS)    = [F:XHO]YDISPUR4
  [M:XOP1]YDISPUR5([M:XOP1]XNBS)    = [F:XHO]YDISPUR5
  [M:XOP1]YCOEPUR([M:XOP1]XNBS)     = [F:XHO]YCOEPUR
  [M:XOP1]XYPROYECTAR([M:XOP1]XNBS) = [F:XHO]YPROYECTAR
Return

######################################################################################
# YA002: Antes de ejecutar el método AINSERT o AUPDATE
$MAJ_XOPPHIE
  NBRCL = GZINSOPP.XX03SOPP.HIE(INDEX).NUMLIG - 1

  If NBRCL>=0
    GZINSOPP.XX03SOPP.HIE(INDEX).YBPSNUM    = [M:XOP1]XYBPSNUM(NBRCL)
    GZINSOPP.XX03SOPP.HIE(INDEX).YEXTRCPDAT = [M:XOP1]XYEXTRCPDAT(NBRCL)
    GZINSOPP.XX03SOPP.HIE(INDEX).YGROPRI    = [M:XOP1]YGROPRI(NBRCL)
    GZINSOPP.XX03SOPP.HIE(INDEX).YDISPUR    = [M:XOP1]YDISPUR(NBRCL)
    GZINSOPP.XX03SOPP.HIE(INDEX).YDISPUR2   = [M:XOP1]YDISPUR2(NBRCL)
    GZINSOPP.XX03SOPP.HIE(INDEX).YDISPUR3   = [M:XOP1]YDISPUR3(NBRCL)
    GZINSOPP.XX03SOPP.HIE(INDEX).YDISPUR4   = [M:XOP1]YDISPUR4(NBRCL)
    GZINSOPP.XX03SOPP.HIE(INDEX).YDISPUR5   = [M:XOP1]YDISPUR5(NBRCL)
    GZINSOPP.XX03SOPP.HIE(INDEX).YCOEPUR    = [M:XOP1]YCOEPUR(NBRCL)
    GZINSOPP.XX03SOPP.HIE(INDEX).YPROYECTAR = [M:XOP1]XYPROYECTAR(NBRCL)
  Endif
Return

######################################################################################
# YA002
$SETBOUT
  Gosub ACTION From SUBOPP : GPE = 1
  CHMEN += "7"
  CHMEN += "Ga"               #GT_RM_2Aug18 : To activate "Update margin" option
Return

######################################################################################
# YA002
$STATUT
  Case BOUT
    When "7"
      If [M:XOP1]XNBS>0
        For I=0 To [M:XOP1]XNBS-1
          Call UPD_XPRIX(I)
        Next I
        Gosub ENTRE_MODIF From GOBJSUB
      Endif
  Endcase
Return

######################################################################################
# YA001
Subprog AS_YREVNUM(VALEUR)
Variable Char    VALEUR()
  If find(GREP, "", "M")
    mkstat = 2
  Else
    mkstat = func CHK_FATHER
  Endif
End

######################################################################################
# YA001
Subprog C_YREVNUM(VALEUR)
Variable Char    VALEUR()
Local Integer AUXINT

  If VALEUR<>""
    AUXINT = val(VALEUR)
    VALEUR = format$("N0:2#", AUXINT)
  Endif
End

######################################################################################
# YA001
Subprog AM_YREVNUM(VALEUR)
Variable Char    VALEUR()

  GZINSOPP.YREVNUM = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP) From SUBOPPA
  If GERR = 1 Then
    GZINSOPP.YREVNUM = GZINSOPP.snapshot.YREVNUM
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_OPPOR_HEADER() From SUBOPPA
  Endif
End

######################################################################################
# YA001
Subprog AS_YSUBPJTNUM(VALEUR)
Variable Char    VALEUR()
  If find(GREP, "", "M")
    mkstat = 2
  Else
    mkstat = func CHK_FATHER
  Endif
End

######################################################################################
# YA001
Subprog C_YSUBPJTNUM(VALEUR)
Variable Char    VALEUR()
Local Integer AUXINT

  If VALEUR<>""
    AUXINT = val(VALEUR)
    VALEUR = format$("N0:3#", AUXINT)
  Endif
End

######################################################################################
# YA001
Subprog AM_YSUBPJTNUM(VALEUR)
Variable Char    VALEUR()

  GZINSOPP.YSUBPJTNUM = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP) From SUBOPPA
  If GERR = 1 Then
    GZINSOPP.YSUBPJTNUM = GZINSOPP.snapshot.YSUBPJTNUM
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_OPPOR_HEADER() From SUBOPPA
  Endif
End

######################################################################################
# YA002
Subprog IB_XNBS
  If [M:XOP1]XFRMNUMLIG(nolign-1)<>"" : Raz GBOUT15 : Endif
End

######################################################################################
# YA002
Subprog B15_XNBS
  Call UPD_XPRIX(nolign-1)
  mkstat = 4
End

######################################################################################
# YA002
Subprog AM_XPRIX(VALEUR)
Variable Decimal VALEUR
Local Integer NOL : NOL = nolign-1
Local Decimal AUXDEC

  AUXDEC = sum([M:XOP1]YGROPRI(NOL), [M:XOP1]YDISPUR(NOL), [M:XOP1]YDISPUR2(NOL),
&              [M:XOP1]YDISPUR3(NOL), [M:XOP1]YDISPUR4(NOL), [M:XOP1]YDISPUR5(NOL))

  If AUXDEC<>0
    Raz [M:XOP1]YGROPRI(NOL)
    Raz [M:XOP1]YDISPUR(NOL)
    Raz [M:XOP1]YDISPUR2(NOL)
    Raz [M:XOP1]YDISPUR3(NOL)
    Raz [M:XOP1]YDISPUR4(NOL)
    Raz [M:XOP1]YDISPUR5(NOL)
  Endif
End

######################################################################################
# YA002
Subprog AS_XYBPSNUM(VALEUR)
Variable Char    VALEUR()
  Gosub CHECK_TYPFRM1
End

######################################################################################
# YA002
Subprog AM_XYBPSNUM(VALEUR)
Variable Char    VALEUR()
  If VALEUR=""
    Raz [M:XOP1]YCOEPUR(nolign-1)     : Affzo [M:XOP1]YCOEPUR(nolign-1)
    Raz [M:XOP1]XYEXTRCPDAT(nolign-1) : Affzo [M:XOP1]XYEXTRCPDAT(nolign-1)
    Raz [M:XOP1]XYPROYECTAR(nolign-1) : Affzo [M:XOP1]XYPROYECTAR(nolign-1)
  Else
    [M:XOP1]XYBPSNUM(nolign-1) = VALEUR
    Call UPD_XPRIX(nolign-1)
  Endif
End

######################################################################################
# YA002
Subprog AS_YCOEPUR(VALEUR)
Variable Decimal VALEUR
  Gosub CHECK_TYPFRM0
End

######################################################################################
# YA002
Subprog AS_XYEXTRCPDAT(VALEUR)
Variable Date    VALEUR
  Gosub CHECK_TYPFRM0
End

######################################################################################
# YA002
Subprog AS_XYPROYECTAR(VALEUR)
Variable Char    VALEUR()
  Gosub CHECK_TYPFRM0
End

######################################################################################
# YA001
Funprog CHK_FATHER
Local Integer I, RET

  RET = 2
  I = find(2, [M:OPP5]SBBTYP(0..[M:OPP5]NBOPP5-1))
  If I>0 : Raz RET : Endif
End RET

######################################################################################
# YA001
Funprog GET_FATHER
Local Integer I
Local Char RET(GLONPIM)

  RET = ""
  I = find(2, [M:OPP5]SBBTYP(0..[M:OPP5]NBOPP5-1))
  If I>0
    RET = [M:OPP5]SBBPJT(I-1)
    I = instr(1,RET,"-")
    If I>0
      RET = left$(RET,I-1)
    Endif
  Endif
End RET

######################################################################################
# YA002
$CHECK_TYPFRM0
  If [M:XOP1]XYBPSNUM(nolign-1)=""
    mkstat = 1
  Else
    Gosub CHECK_TYPFRM1
  Endif
Return

######################################################################################
# YA002
$CHECK_TYPFRM1
  If [F:YPFM]TYPFRM<>[M:XOP1]XTYPFRM(nolign-1)
    Read [F:YPFM]PFM0=[M:XOP1]XTYPFRM(nolign-1)
    If fstat : Raz [F:YPFM] : Endif
  Endif
  If [F:YPFM]YGENPURLINE<>2
    mkstat = 1
  Endif
Return

######################################################################################
#
Subprog UPD_XPRIX(WLIN)
Value Integer WLIN

Local Integer SAVNOLIGN

  If [M:XOP1]XFRMNUMLIG(WLIN)<>"" : End : Endif

  If [M:XOP1]XYBPSNUM(WLIN)<>""
    Local Integer I
    Local Decimal WGROPRI, WNETPRI, WDISCRGVAL(0..8)
    Local Char    WPJT(GLONOPP)

    WPJT = [M:XOP1]XYPROYECTAR(WLIN)
    If WPJT=""
      WPJT = [M:OPP0]OPPNUM
    Endif

    SAVNOLIGN = nolign
    Call P_SEARCH([M:XOP1]XNIV3(WLIN), date$, [M:XOP1]XYBPSNUM(WLIN),
&                 [M:XOP1]XCUR(WLIN), [M:OPP0]SALFCY, [M:XOP1]XQTY(WLIN),
&                 [M:XOP1]XSAU(WLIN), WPJT, WGROPRI, WDISCRGVAL, WNETPRI) From YSEAPOHTAR
    nolign = SAVNOLIGN

    [M:XOP1]YGROPRI(WLIN) = WGROPRI
    [M:XOP1]YDISPUR(WLIN) = WDISCRGVAL(0)
    For I=2 To 9
      If evalue("dim([M:XOP1]YDISPUR" + num$(I) + ")")>0
        Assign "[M:XOP1]YDISPUR" + num$(I) + "(WLIN)" With WDISCRGVAL(I-1)
      Endif
    Next I
    [M:XOP1]XPRIX(WLIN) = WNETPRI
    Affzo [M:XOP1]XPRIX(WLIN)
  Endif
End

######################################################################################

Subprog AM_XNIV3(VALEUR)
Variable Char    VALEUR()
  [M:XOP1]XNIV3(nolign-1) = VALEUR
  Call UPD_XPRIX(nolign-1)
End

######################################################################################

Subprog AM_XSAU(VALEUR)
Variable Char    VALEUR()
  [M:XOP1]XSAU(nolign-1) = VALEUR
  Call UPD_XPRIX(nolign-1)
End

######################################################################################

Subprog AM_XQTY(VALEUR)
Variable Decimal VALEUR
  [M:XOP1]XQTY(nolign-1) = VALEUR
  Call UPD_XPRIX(nolign-1)
End

######################################################################################

Subprog AM_XCUR(VALEUR)
Variable Char    VALEUR()
  [M:XOP1]XCUR(nolign-1) = VALEUR
  Call UPD_XPRIX(nolign-1)
End

######################################################################################

Subprog AM_XYPROYECTAR(VALEUR)
Variable Char    VALEUR()
  [M:XOP1]XCUR(nolign-1) = XYPROYECTAR
  Call UPD_XPRIX(nolign-1)
End

######################################################################################

