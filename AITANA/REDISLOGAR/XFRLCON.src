#ACV#X16
#TIT#Saisie paramétrage contrat dans le détail

#==========================================================================================
# Gestion de l'objet   : Saisie paramétrage contrat dans le détail
#
# Auteur               : Laurent Bornes
# Date de création     : 09/01/2014
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

GBIDC1=""
GBIDC2=""
GFONC1="GESFRL"
GFLAG="#"
Call OBJET("FRL",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

## Action XFRLCON
Local Char PARMSK(250)(1..20), SAVACT(20), VALEUR
GACTION="XFRLCON"
Call SAISIE_CHAR(VALEUR,PARMSK,"XFRLCON","XFRLCON","YFRLCON") From GSAISIE
End

#==========================================================================================
$ACTION

Gosub ACTION From XFRLCON2

Return

#==========================================================================================
Subprog AS_TER(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1
If [M:XFC]ORINUM=""
  GMENLOC(4)=1
Endif
End

#==========================================================================================
Subprog AM_ORIFRL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Actzo [M:XFC]ORINUM
Else
  Effzo [M:XFC]ORINUM
  Grizo [M:XFC]ORINUM
Endif
[M:XFC]ORIFRL=VALEUR : # A cause du $SETBOUT
End

#==========================================================================================
Subprog AS_PERIOD(VALEUR)
Variable Integer VALEUR
GMENLOC(8)=1
GMENLOC(9)=1
If [M:XFC]ORINUM=""
  GMENLOC(10)=1
Endif
End

#==========================================================================================
Subprog AS_PERIODPU(VALEUR)
Variable Integer VALEUR
GMENLOC(8)=1
GMENLOC(9)=1
If [M:XFC]ORINUM=""
  GMENLOC(10)=1
Endif
If VALEUR=0
  VALEUR=[M:XFC]PERIOD
Endif
End

#==========================================================================================
Subprog C_ORINUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [F:FRL]FRL0=VALEUR
  If !fstat
    If [F:FRL]INVMOD<>9
      [V]GMESSAGE=mess(334,[V]GXMSGOPP,1)
      [V]GERR=1
      mkstat=1
    Elsif [F:FRL]ORINUM<>""
      [V]GMESSAGE=mess(336,[V]GXMSGOPP,1)-"("+[F:FRL]ORINUM+")"
      [V]GERR=1
      mkstat=1
    Elsif [F:FRL]CPCENUM<>""
      [V]GMESSAGE=mess(337,[V]GXMSGOPP,1)
      [V]GERR=1
      mkstat=1
    Endif
  Endif
Endif
End

#==========================================================================================
Subprog AS_ORINUM(VALEUR)
Variable Char    VALEUR()
If [M:XFC]ORIFRL<>2
  mkstat=1
Endif
End

#==========================================================================================
Subprog AS_PSE(VALEUR)
Variable Integer VALEUR
If [M:XFC]ORINUM=""
  GMENLOC(3)=1
  GMENLOC(4)=1
Endif
End

#==========================================================================================
Subprog AM_ORINUM(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""

  Read [F:FRL]FRL0=VALEUR
  If fstat : Raz [F:FRL] : Endif

  [M:XFC]TER      =4
  [M:XFC]PERIOD   =10
  [M:XFC]PERIODPU =10
  [M:XFC]PSE      =3
  [M:XFC]EFFDAT   =[F:FRL]EFFDAT

  If [M:XFC]EFFDAT<>[0/0/0]
    Grizo [M:XFC]EFFDAT
  Else
    Actzo [M:XFC]EFFDAT
  Endif

Else

  [M:XFC]TER      =1
  [M:XFC]PERIOD   =1
  [M:XFC]PERIODPU =1
  [M:XFC]PSE      =1
  Actzo [M:XFC]EFFDAT

Endif

[M:XFC]ORINUM=VALEUR

Affzo [M:XFC]

End

#==========================================================================================
Subprog C_CBEGDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:XFC]EFFDAT & VALEUR<>[0/0/0]
  [V]GMESSAGE=mess(1,104,1)
  [V]GERR=1
  mkstat=1
Endif
End

#==========================================================================================
Subprog C_CENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:XFC]EFFDAT & VALEUR<>[0/0/0]
  [V]GMESSAGE=mess(1,104,1)
  [V]GERR=1
  mkstat=1
Endif
End

#==========================================================================================
Subprog AV_CPCEICO(VALEUR)
Variable Char    VALEUR()
If [M:XFC]CPCENUM=""
  VALEUR=""
  Raz GBIDC1
Else
  VALEUR="21"
  If [M:XFC]ORIFRL=1
    GBIDC1="XON"
  Else
    GBIDC1="COP"
  Endif
Endif
End
