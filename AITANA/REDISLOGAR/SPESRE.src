# Gestión de la máscara SRE9 (Especifico)
######################################################################################
## Etiqueta añadida por el supervisor (pantalla SRE9) 17/11/2016 12:13:20 (ADMIN)
######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return
######################################################################################
# YA040 - Tarifas de reparación
######################################################################################
Subprog BUSCAR_PRECIO(WPARQUE, WCONSUMO, WCANTIDAD, WPRECIO)
Value Char WPARQUE
Value Char WCONSUMO
Value Decimal WCANTIDAD
Variable Decimal WPRECIO

Raz WPRECIO

If clalev ([F:YMAC])  = 0 : Local File MACHINES   [YMAC] : Endif
If clalev ([F:YSPL])  = 0 : Local File SPRICLIST  [YSPL] : Endif

#Infbox('Art. Consumo:' - WCONSUMO - '\\' - 'Cantidad:' - num$(WCANTIDAD) - '\\' - 'Parque:' - WPARQUE)

# Obtener articulo del parque
Read [F:YMAC]MAC0 = WPARQUE
If fstat = 0
  #Infbox([F:YMAC]MACPDTCOD)

  # Obtener el precio
  Filter [YSPL] Where [F:YSPL]PLI = 'T90' and [F:YSPL]PLICRI1 = WCONSUMO and [F:YSPL]PLICRI2 = [F:YMAC]MACPDTCOD
&                         and WCANTIDAD >= [F:YSPL]MINQTY and WCANTIDAD <= [F:YSPL]MAXQTY
&                         and [F:YSPL]PLISTRDAT <= date$ and [F:YSPL]PLIENDDAT >= date$
    For [YSPL]
      # Sobreescribimos el precio
      WPRECIO = [F:YSPL]PRI
      #Infbox('Precio encontrado: ' + num$(WPRECIO))
    Next
  Filter [YSPL]
Endif

End

