#<AdxTL>@(#)1.0.0.0 $Revision$
#ACV#X16
#TIT#Consultation Affaire

#==========================================================================================
# Gestion de la consultation : OPP -- Affaire
#                        
# Auteur                     : 
# Date de création           :       
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 24/02/2003    OTHYR        Modélisation Web + ajout PE consultation       
#==========================================================================================

Local Char PARAM(30)(2)

Call GCONSULT("OPA","",PARAM)From GCONSULT
End


$ACTION

Case ACTION
    When "AUTORIS"    : Gosub AUTORIS
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "SETBOUT"    : Gosub SETBOUT
    When "FIN_CRIT"   : Gosub FIN_CRIT
    When default
Endcase
Return

#-----------------------------------------------------------------#
#    Gestion des étiquettes liées a ACTION                        #
#-----------------------------------------------------------------#
###################################################################
$AUTORIS
Return

###################################################################
$SETBOUT
Return

###################################################################
$OUVRE
Local Char CRIT1(250), CRIT2(250), CRIT3(250), CRITSPE(250), CRITXOP(250)
Local Char DEBNUM,FINNUM

If !clalev([F:ADI]) : Local File ATABDIV  [ADI] : Endif
If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif

If !clalev([F:XOP]) : Local File OPPORX3S : Endif

Gosub DEFCRIT

Return

###################################################################
$DEFCRIT

For I = 1 To dim(PARAM)
    Case I
        When 1    :# Parametre Client
            If PARAM(I) <> "" Then
                If [F:BPR]BPRNUM <> PARAM(I) Then
                    Read [F:BPR]BPR0 = PARAM(I)
                    If fstat Then
                        Raz [F:BPR], PARAM(I)
                    Endif
                Endif
                [M:COP0]BPCNUM = PARAM(I)
            Endif
        When 2 :    : # Parametre Site
            If PARAM(I) <> "" Then
                If [F:FCY]FCY <> PARAM(I) Then   
                    Read [F:FCY]FCY0 = PARAM(I)
                    If fstat  Raz [F:FCY] : Endif
                Endif
#                If !fstat & ((PARAM(I) = GFCYDEF & GUSRACC(1) <> 0) | (PARAM(I) <> GFCYDEF & GUSRACC(2) <> 0)) Then
                 If !fstat & (PARAM(I) = GFCYDEF  | PARAM(I) <> GFCYDEF  ) Then
                    [M:COP0]SALFCY = PARAM(I) 
                    Call GETDEV([M:COP0]SALFCY) From DEVSUB
                    [M:COP0]CPY    = GSOCIETE
                Endif
            Endif
    Endcase
Next

If !find([M:COP0]FLGOPPCLO,1,2)  : [M:COP0]FLGOPPCLO  = 2 : Endif
If !find([M:COP0]FLGOPPCLON,1,2) : [M:COP0]FLGOPPCLON = 2 : Endif
If !find([M:COP0]FLGOPPACT,1,2)  : [M:COP0]FLGOPPACT  = 2 : Endif
If !find([M:COP0]FLGOPPACTN,1,2) : [M:COP0]FLGOPPACTN = 2 : Endif

# Copie de l'écran critère (COPP) vers la masque 0 d'entete (COP0)
Gosub CRITENT From =PROGCNS

Return

###################################################################
$LECTURE

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 Then
    NOL = MAXLIG
Endif    

Call TEMPON("R") From GESECRAN

# Positionnement des filtres
Gosub LOAD_FILTER
# Appel au filtre spécifique client
ACTION = "FILTRE"
Gosub ACTION From XOBJCNS
ACTION = "LECTURE"

#***********************************#
# RAPPEL : valeur CHGPAG :          #
#    1 : Recherche                  #
#    2 : Suite                      #
#    3 : F5 (Rafraichissement)      #
#   -1  : Dernier                   #
#   -2  : Retour (Page précédente)  #
#***********************************#
# Application des filtres
If CHGPAG > 0 Then
    SUITE = 1
    If CHGPAG = 1 Then
        RETOUR = 1
    Elsif CHGPAG = 2 Then
        RETOUR = 2
    Endif
    Filter [OPP] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE) Order By Key OPP0
    Filter [XOP] Where evalue([L]CRITXOP)
Else
    RETOUR = 1
    If CHGPAG = -1 Then
        SUITE = 1
    Else
        SUITE = 2
    Endif
    Filter [OPP] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE) Order By Key OPP0 Desc
    Filter [XOP] Where evalue([L]CRITXOP)
Endif
# RAZ du masque
If CHGPAG <> 2 & CHGPAG <> -2 Then
    Raz [M:COP1]
Endif

# Lecture
For [OPP]
  Read [XOP]XOP0=[F:OPP]OPPNUM
  If !fstat
    If NBLU = 1 Then
        If CHGPAG = 2 | CHGPAG = -2 Then
            Raz [M:COP1]
        Endif
        NBLU = 2
    Endif
    If CHGPAG > 0 Then
        If NOL >= MAXLIG-1 Then
            SUITE = 2
            Break
        Endif
        NOL += 1
        If NOL = 0 Then
            DEBNUM = [F:OPP]OPPNUM
        Endif
        FINNUM = [F:OPP]OPPNUM
    Else
        If NOL <= 0 Then
            RETOUR = 2
            Break
        Endif
        NOL -= 1
        If NOL = MAXLIG-1 Then
            FINNUM = [F:OPP]OPPNUM
        Endif
        DEBNUM = [F:OPP]OPPNUM
    Endif

    nolign = NOL+1

    [M:COP1] = [F:OPP]

    For I = 0 To dim([F:OPP]OPPREP)-1
        If evalue("dim([M:COP1]OPPREP"+num$(I+1)+")>0") Then
            Assign "[M:COP1]OPPREP"+num$(I+1)+"(nolign-1)" With evalue("[F:OPP]OPPREP("+num$(I)+")")
        Endif
    Next
  Endif
Next

Filter [OPP]
Filter [XOP]

Call TEMPOFF From GESECRAN

Return

###################################################################
$LOAD_FILTER
[L]CRIT1   = "1"    :# Critere sur societe, site, tiers, client facturé, type, etape en cours
[L]CRIT2   = "1"    :# Critere sur bornes de date
[L]CRIT3   = "1"    :# Critere sur flag actif et cloturé
[L]CRITSPE = "1"    :# Critère Spécifique client
[L]CRITXOP = "1"    :# Critère OPPORX3S


# 1er critere
If [M:COP0]SALFCY <> "" Then
    [L]CRIT1 += "& [F:OPP]SALFCY=[M:COP0]SALFCY"
Endif
If [M:COP0]BPCNUM <> "" Then
    [L]CRIT1 += "&[F:OPP]OPPCMP=[M:COP0]BPCNUM"
Endif
If [M:COP0]OPPSTE <> "" Then
    [L]CRIT1 += "&[F:OPP]OPPSTE=[M:COP0]OPPSTE"
Endif
If [M:COP0]OPPTYP <> "" Then
    [L]CRIT1 += "&[F:OPP]OPPTYP=[M:COP0]OPPTYP"
Endif
If [M:COPP]BPCINV <> "" Then
    [L]CRITXOP += "&[F:XOP]BPCINV=[M:COPP]BPCINV"
Endif

# 2eme critere
If [M:COPP]DEBDAT <> [0/0/0] Then
    [L]CRIT2 += "&[F:OPP]OPPCDA>=[M:COPP]DEBDAT"
Endif
If [M:COPP]FINDAT <> [0/0/0] Then
    [L]CRIT2 += "&[F:OPP]OPPCDA<=[M:COPP]FINDAT"
Endif

# 3eme critere
# Prise en compte des affaires "actives"
# --> Si 1, On exclut les affaires actives 
If [M:COPP]FLGOPPACT = 1 Then
    [L]CRIT3 += "&[F:OPP]ENAFLG<>2"
Endif
# Prise en compte des affaires non "actives"
# --> Si 1, On exclut les affaires non actives
If [M:COPP]FLGOPPACTN = 1 Then
    [L]CRIT3 += "&[F:OPP]ENAFLG<>1"
Endif
# Prise en compte des affaires cloturées
# --> Si 1, On exclut les affaires cloturées
If [M:COP0]FLGOPPCLO = 1 Then
    [L]CRIT3 += "&[F:OPP]OPPCLO<>2"
Endif
# Prise en compte des affaires non cloturées
# --> Si 1, On exclut les affaires non cloturées
If [M:COP0]FLGOPPCLON = 1 Then
    [L]CRIT3 += "&[F:OPP]OPPCLO<>1"
Endif

Case CHGPAG
    When 3 : #Rafraichissement
        [L]CRIT1 += "&[F:OPP]OPPNUM>=DEBNUM"
    When 2 : #Suite
        [L]CRIT1 += "&[F:OPP]OPPNUM>FINNUM"
    When -2 : #Retour
        [L]CRIT1 += "&[F:OPP]OPPNUM<DEBNUM"
Endcase

Return

###################################################################
$FIN_CRIT
Return


#-----------------------------------------------------------------#
#    Gestion des étiquettes liées aux masques COP0, COP1 et COPP  #
#-----------------------------------------------------------------#
###################################################################
Subprog C_CPY(VALEUR)
Variable Char     VALEUR

If VALEUR = "" & [M:COP0]SALFCY = "" Then
    GERR     = 2
    GMESSAGE = mess(9,109,1)        :#Vous devez saisir 1 société ou 1 site
Endif

End

###################################################################
Subprog C_FCY(VALEUR)
Variable Char     VALEUR

If VALEUR <> "" Then
    If GUSRFCY(1) <> "\" & !find(VALEUR,GUSRFCY(1..GNBAUZ)) Then
        GMESSAGE = VALEUR-mess(2,104,1)    :# Vous n'avez pas les droits sur ce site
        mkstat   = 2 
        End
    Endif

    #Alimentation société
    Call GETDEV(VALEUR) From DEVSUB
    [M:COPP]CPY = GSOCIETE

    If !GIMPORT Then
        Affzo [M:COPP]CPY
    Endif

Elsif [M:COPP]CPY = "" Then
    GMESSAGE = mess(9,109,1)        :#Vous devez saisir une société ou un site
    mkstat   = 2
Else
    Call CONTALLFCY([M:COPP]CPY) From CPTSUB    :# Acces a tous les sites d'une société?
Endif

End

###################################################################
Subprog IB_NBLIG

Raz GBOUT1

If [M:COP1]NBLIG <> 0 Then
    GBOUT1 = mess(162,[V]GXMSGPSA,1)        :# Affaire
Endif

End

