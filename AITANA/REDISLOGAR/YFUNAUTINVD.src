#####################################################################################
# CodAct: YA048 - Rangos Periodicidad Facturación
#####################################################################################

$ACTION

Case ACTION
  When "AUTINVDSEL"  : Gosub AUTINVDSEL
Endcase

Return

#####################################################################################

$AUTINVDSEL

# <YA048> Rangos Periodicidad Facturación
If [F:SDH]INVPER = 7 & [M]YINVPER25  = 1 OK = 1 : Return : Endif
If [F:SDH]INVPER = 8 & [M]YINVPERFM  = 1 OK = 1 : Return : Endif

# </YA048>

Return

