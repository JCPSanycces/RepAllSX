GBIDC1=""
GBIDC2=""
Call OBJET("X7K",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

Gosub ACTION From SPVOBJX7K

Return

################################################################################
Subprog IB_DATATYPE
Local Char VALEUR : VALEUR=[M]DATATYPE
Local Integer OK, NOL2
Local Char    ACT(GLONACT)

If VALEUR="" : End : Endif
Raz GBOUT3, GBOUT4, OK
Call LECTURE("ATY",VALEUR,"") From CONTOBJ
OK = ([F:ATY]NBTYP>0) : # Et tant pis s'il n'y a pas de paramètres
If [F:ATY]OBJLIEN<>""
 Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
 If [F:AOB]LIBPAR<>0 : OK=1 : Endif
 If [F:AOB]NBOPT<>0
  GBOUT3 = mess(127,124,1) : # Options
 Endif
Endif

OK += ([F:ATY]PARTAB<>"")
If OK
 GBOUT4 = mess(174,100,1) : # Paramètres
Endif
End

################################################################################
Subprog AM_TYPCTL(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 1
        Grizo [M]35-45 : Effzo [M]35-45
        Actzo [M]25
    When 2
        Grizo [M]25,40-45 : Effzo [M]25,40-45
        Actzo [M]35
    When 3
        Grizo [M]25,35    : Effzo [M]25,35
        Actzo [M]40-45
    When 4
        Grizo [M]25,35-45 : Effzo [M]25,35-45
Endcase

End

################################################################################
Subprog C_VALUES(VALEUR)
Variable Char VALEUR

Local Integer  I, NOL
NOL  = nolign-1

Case [M]TYPVAL
 When 4 : # Menu local
  I = val(num$(VALEUR))
  If I<1 or I>len(mess(0,[M]NOLIB,1))
   GMESSAGE = mess(83,123,1) : mkstat=2 : End
#  Valeur incorrecte
  Endif
Endcase

Call UNICITE(num$(VALEUR),[M]VALUES(0..[M]NBVAL-1)) From OBJDIV

End

################################################################################
Subprog AP_DATATYPE(VALEUR)
Variable Char     VALEUR

If [M]TYPVAL=4
  Actzo [M]NOLIB
  Actzo [M]TYPGRAPH
Else
  Raz   [M]NOLIB,TEXLIB
  [M]TYPGRAPH=1
  Diszo [M]NOLIB
  Diszo [M]TYPGRAPH
Endif

[M]SUPP=""
For [F:AMP] Where TYPAFF=1 & CODAFF="XA"+[M]CODASW & CODZON="XTYP_"+VALEUR
  If [F:AMP]CODPAR="ADI" Then
    [M]SUPP=num$([F:AMP]VALPAR)
    Break
  Endif
Next

If !GIMPORT
  Affzo [M]NOLIB,TEXLIB
Endif
End

################################################################################
Subprog AM_DATATYPE(VALEUR)
Variable Char     VALEUR

Local File ATYPE  [XATY]

Read [XATY]CODTYP = VALEUR
If !fstat
  Case[XATY]TYPTYP
    When 1 : [M]TYPVAL=4
    When 2,3,4,5,6 : [M]TYPVAL=2
    When 7 : [M]TYPVAL=1
    When 8 : [M]TYPVAL=3
  Endcase

  [M]OBJET=[XATY]OBJLIEN
  If [M]OBJET<>"" & [M]TYPVAL<>4
    [M]LIEN=2
  Else
    [M]LIEN=1
  Endif
Endif

[M]OPTSAI=[F:XATY]OPTION
[M]NOLIB= [F:XATY]NOLIB
[M]TYPGRAPH=1

[M]ODATATYPE=[M]DATATYPE
Close File [XATY]
Call AP_DATATYPE(VALEUR)

[M:ASW1]NBVAL=0
Raz [M:ASW1]VALUES
Raz [M:ASW1]LNGTYP
Affzo [M:ASW1]NBVAL

Call FMT_INTIT([M:ASW1]TYPVAL) From SPVOBJX7K

End

################################################################################
Subprog AV_NOLIB(VALEUR)
Variable Decimal VALEUR

If VALEUR
    [M]TEXLIB=mess(VALEUR-(200 * (VALEUR>200)),0+(200 * (VALEUR>200)),1)
Endif

End

################################################################################
Subprog AP_NOLIB(VALEUR)
Variable Decimal VALEUR

If VALEUR
    [M]TEXLIB=mess(VALEUR-(200 * (VALEUR>200)),0+(200 * (VALEUR>200)),1)
Endif

End


################################################################################
Subprog AS_TYPGRAPH(VALEUR)
Variable Integer  VALEUR
Local Integer I

  For I=1 To len(mess(0,43,1))
    If !find(I,1,2,5)
      GMENLOC(I)=1
    Endif
  Next
End

################################################################################
Subprog AP_TYPGRAPH(VALEUR)
Variable Integer  VALEUR

  Raz GMENLOC
End

################################################################################
Subprog D_LIBASWSHO(VALEUR)
Variable Char     VALEUR
# LBORN 19/12/2006 - On teste valeur, sinon bug chargement (la designation
# longue est chargée au lieu de la désignation courte)
If VALEUR=""
  VALEUR=[M:ASW0]LIBASW
Endif
End

################################################################################
Subprog CONTRES(VALEUR,XCODQSN,XCODQUS,XCODASW)
Value Char VALEUR()
Value Char XCODQSN
Value Char XCODQUS
Value Char XCODASW

  If !clalev([QSN]) : Local File QSNPSA [QSN] : Endif

  Local Char INTIT
  mkstat=0

  Read [F:QSN]QSN1=[L]XCODQSN;[L]XCODQUS
  If fstat > 2
    mkstat=2
    End
  Endif

  If [F:QSN]EXPCTL<>"" & evalue([F:QSN]EXPCTL)=0
    mkstat=2
    End
  Endif

  Call CONTRES2([L]XCODASW,VALEUR,INTIT)
  If !mkstat

  Endif

End

$ERREUR
 Resume
Return

################################################################################
#Contrôle
################################################################################
Subprog CONTRES2(CODASW,RESULT,INTRES)
Value Char CODASW
Variable Char RESULT
Variable Char INTRES

# LBORN 05/11/2014 - Mantis 27066
# Local Char VALEURC
Local Char VALEURC(50)

Local Char    SUPP(50)
Local Decimal VALEURD
Local Integer VALEURI

Local Integer XSTAT
Local Integer I

If !clalev([X73]) : Local File ASWPSA : Endif

[L]VALEURC=[L]RESULT
[L]VALEURD=val(RESULT)

# LBORN 05/11/2014 - Mantis 27066
# [L]VALEURI=val(RESULT)
If len(RESULT)<=20
  [L]VALEURI=val(RESULT)
Endif

[L]INTRES=""

#Call LECTURE("ASW",[L]CODASW,"")From CONTOBJ
Read [F:X73]X730=[L]CODASW
If [F:X73]SUPP<>""
    [L]SUPP=num$(evalue([F:X73]SUPP))
Else
    [L]SUPP=""
Endif

If [F:X73]ASWOBL=2 & [L]RESULT=""
    mkstat=2
Elsif [L]RESULT<>""
    Case [F:X73]TYPCTL
        When 1
            Onerrgo ERREUR

            Local File =[F:X73]NOMFIC
            If [F:X73]FILTRE<>""
                Filter [F] Where evalue([F:X73]FILTRE)
            Endif

            Onerrgo
        When 2
            Case [F:X73]TYPVAL
                When 2,4
                     If !([L]VALEURI>=val([F:X73]STRVAL) & [L]VALEURI<=val([F:X73]ENDVAL))
                        mkstat=2
                     Endif
                When Default
                     If !(num$([L]RESULT)>=[F:X73]STRVAL & num$([L]RESULT)<=[F:X73]ENDVAL)
                        mkstat=2
                     Endif
             Endcase
        When 3
            If [F:X73]VALFLG=1 & [F:X73]AUZVAL=1
                If !find([L]RESULT,[F:X73]VALUES)
                    mkstat=2
                Endif
            Elsif [F:X73]AUZVAL=2
                If find([L]RESULT,[F:X73]VALUES)
                    mkstat=2
                Endif
            Endif
        When 4
    Endcase
    If mkstat<>2
        If [F:X73]TYPVAL<>3 & [F:X73]TYPCTL<>1
            #[L]INTRES=format$([F:X73]FMTASW,[L]RESULT)
            [L]INTRES=num$([L]RESULT)
        Elsif [F:X73]TYPCTL<>1
            [L]INTRES=right$([L]RESULT,7)+"-"+mid$([L]RESULT,5,2)+"-"+left$([L]RESULT,4)
        Endif
    Endif
Endif

If dim([M]INTRES(nolign-1))>0
    If [M]INTRES(nolign-1)<>""
        [L]INTRES=evalue([M]INTRES(nolign-1))
    Endif
Endif

If mkstat=2
    GMESSAGE=mess(6,199,1)
Endif

Close Local File [X73]
End

################################################################################
# Recherche du libelle associe a une reponse de questionnaire
# Notamment dans le cas ou la reponse est de type Objet
# (TAG:100521-NGOUD-RQ108831)
################################################################################
Subprog RESLABEL(CODASW,RESULT,INTRES)
Value    Char CODASW() # Code reponse
Variable Char RESULT() # Valeur reponse
Variable Char INTRES() # Intitule associe

  ## OUVERTURE  DE TABLES

  If !clalev([YASW]) : Local File ASWPSA  [YASW] : Endif
  If !clalev([YATY]) : Local File ATYPE   [YATY] : Endif
  If !clalev([YAOB]) : Local File AOBJET  [YAOB] : Endif
  If !clalev([YATB]) : Local File ATABLE  [YATB] : Endif
  If !clalev([YATZ]) : Local File ATABZON [YATZ] : Endif

  ## VARIABLES LOCALES

  Local Char    YCODOBJ  # Code objet
  Local Integer FLG_STOP # Flag d'arret

  ## INITIALISATIONS

  [L]INTRES=""
  [L]FLG_STOP=0

  ## RECHERCHE DU LIBELLE

  If [L]RESULT<>""

     Read [YASW]X730=[L]CODASW
     If !fstat

        ## Si le type de controle specifie sur la fiche "Reponse"
        ## est "Objet", alors on recherche le libelle associe

        If [F:YASW]TYPCTL=1

           If ![L]FLG_STOP

              ## Si un code objet figure sur la fiche "Reponse"
              ## on l'utilise, sinon on recupere le code objet
              ## qui figure sur le type de donnee de la reponse

              If [F:YASW]OBJET<>""
                 [L]YCODOBJ=[F:YASW]OBJET
              Else
                 Read [YATY]CODTYP=[F:YASW]DATATYPE
                 If !fstat
                    [L]YCODOBJ=[YATY]OBJLIEN
                 Else
                    [L]FLG_STOP=1
                 Endif
              Endif

           Endif

           ## Lecture de la fiche "Objet"

           If ![L]FLG_STOP
              Read [YAOB]ABREV=[L]YCODOBJ
              If fstat : Raz [YAOB] : [L]FLG_STOP=1 : Endif
           Endif

           ## Lecture de la fiche "Table"

           If ![L]FLG_STOP
              Read [YATB]CODFIC=[F:YAOB]NOMFIC
              If fstat : Raz [YATB] : [L]FLG_STOP=1 : Endif
           Endif

           ## Lecture de la fiche "Zones de table"

           If ![L]FLG_STOP
              Read [YATZ]CODZONE=[F:YATB]CODFIC;[F:YATB]INTIT
              If fstat : Raz [YATZ] : [L]FLG_STOP=1 : Endif
           Endif

           ## Ouverture de la table liee a l'objet

           If ![L]FLG_STOP
              Onerrgo FILE_ERROR
              Local File =[F:YATB]CODFIC
              Onerrgo
           Endif

           ## Lecture de l'enregistrement dont le code correspond
           ## a la reponse et recuperation de l'intitule associe

           If ![L]FLG_STOP

              Onerrgo EVALUE_ERROR

              Call LECTURE([L]YCODOBJ,[L]RESULT,"") From CONTOBJ

              Case [F:YATZ]CODTYP
                When "ATX"
                    Call TEXTE(evalue("[F]"+[F:YATB]INTIT),[L]INTRES) From OBJDIV
                When "AXT"
                    Call LECTURE([L]INTRES,evalue("[F]"+[F:YATB]INTIT)) From TEXTE
                When "AXX"
                    Call LECTEXTRA([L]INTRES,[F:YATB]CODFIC,[F:YATB]INTIT,[L]RESULT,"") From ATEXTRA
                When Default
                    [L]INTRES=evalue("[F]"+[F:YATB]INTIT)
              Endcase

              Onerrgo

           Endif

        Else

           ## Si le controle n'est pas de type "Objet", alors
           ## on construit l'intitule a partir de la reponse

           If [F:YASW]TYPVAL<>3
               [L]INTRES=num$([L]RESULT)
           Else
               [L]INTRES=right$([L]RESULT,7)+"-"+mid$([L]RESULT,5,2)+"-"+left$([L]RESULT,4)
           Endif

        Endif

     Endif

  Endif

  ## FERMETURE DE TABLES

  Close Local File [YASW]
  Close Local File [YATY]
  Close Local File [YAOB]
  Close Local File [YATB]
  Close Local File [YATZ]

End

$FILE_ERROR
 [L]FLG_STOP=1
Resume

$EVALUE_ERROR
 [L]INTRES=""
Resume

################################################################################
# SVG contexte
################################################################################
Funprog SVG_CONTEXTE(F1,ABREV)
Value Char F1
Value Char ABREV

Local Integer J,K
Local Char CHARTMP(100)

If clalev([F:XCTX]) Then
  Close File [XCTX]
Endif

Local File =F1 [XCTX]

## Boucle sur le nombre de zones du fichier
For J=0 To [G:XCTX]nbzon-1
## Boucle sur la dimension de chaque zone
   For K=0 To evalue("dim([F:XCTX]"+[G:XCTX]adxfname(J)+")-1")
   CHARTMP='[F:'+ABREV+']'+evalue('[G:'+ABREV+']adxfname(J)')+'('+(num$(K)+')')
    Assign "[F:XCTX]"+[G:XCTX]adxfname(J)+"(K)" With evalue(CHARTMP)
  Next K
Next J

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ASWPSA1) 19/12/2006 15:20:45 (LBORN)
######################################################################################
Subprog AV_LNGTYP(VALEUR)
Variable Decimal VALEUR
If !clalev([F:ATY]) : Local File ATYPE : Endif
Read [F:ATY]CODTYP=[M]DATATYPE
If !fstat
  If [F:ATY]LNGTYP<>0 | [F:ATY]TYPTYP=8
    If VALEUR=0
      # LBORN 05/11/2014 - Mantis 27066
      # VALEUR=min([F:ATY]LNGTYP,20)
      VALEUR=min([F:ATY]LNGTYP,50)
    Endif
    Grizo [M]LNGTYP
  Else
    Actzo [M]LNGTYP
  Endif
Else
  Actzo [M]LNGTYP
Endif
End

Subprog AS_LNGTYP(VALEUR)
Variable Decimal VALEUR

# LBORN 05/11/2014 - Mantis 27066
If VALEUR<>0 : End : Endif

If !clalev([F:ATY]) : Local File ATYPE : Endif
Read [F:ATY]CODTYP=[M]DATATYPE
If !fstat & [F:ATY]LNGTYP=0 & [F:ATY]TYPTYP<>8
  Case [F:ATY]TYPTYP
    When 1  : VALEUR = 15
    When 2  : VALEUR = 3
    When 3  : VALEUR = 8
    When 4  : VALEUR = 9.2
    When 5  : VALEUR = 5
    When 6  : VALEUR = 10

    When 7  : # LBORN 05/11/2014 - Mantis 27066
              # VALEUR = 20
              VALEUR = 30

    When 9  : VALEUR = 1
    When 10 : VALEUR = 1
  Endcase
Endif
End

################################################################################
Subprog SELRES(VALEUR,XCODQSN,XCODQUS,XCODASW)
Value    Char    VALEUR
Value    Char    XCODQSN
Value    Char    XCODQUS
Value    Char    XCODASW

# LBORN 05/11/2014 - Mantis 27066
# Local Char TABVAL(20)(50)
Local Char TABVAL(50)(50)

Local Integer I

If !clalev([X73]) : Local File ASWPSA [X73] : Endif
If !clalev([QSN]) : Local File QSNPSA [QSN] : Endif

Read [F:QSN]QSN1=[L]XCODQSN;[L]XCODQUS
If fstat > 2
    End
Endif

#Call LECTURE("ASW",[L]XCODASW,"")From CONTOBJ
Read [F:X73]X730=[L]XCODASW
If fstat : Raz [F:X73] : Endif

[L]VALEUR = ""
Case [F:X73]TYPCTL
    When 3
        If [F:X73]VALFLG=1 & [F:X73]AUZVAL=1
            For I=0 To dim([F:X73]VALUES)-1
                If [F:X73]TYPVAL=3
                    [L]TABVAL(I+1)=right$([F:X73]VALUES(I),7)+"-"+mid$([F:X73]VALUES(I),5,2)+"-"+left$([F:X73]VALUES(I),4)
                Else
                    [L]TABVAL(I+1)=[F:X73]VALUES(I)
                Endif
            Next I
            I=0
            Call SAITEX([F:X73]NBVAL,[L]TABVAL,I,mess([F:X73]AUZVAL,1707,1))From GESECRAN
            If I
                [L]VALEUR=[F:X73]VALUES(I-1)
            Else
                [L]VALEUR=""
            Endif
        Endif
Endcase
If [F:X73]TYPVAL = 2 Then #-- Numérique
    zc = val([L]VALEUR)
Else
    zc = [L]VALEUR
Endif
End

######################################################################################
Subprog AV_INTIT(VALEUR)
Variable Char    VALEUR()
If [M]TYPVAL=4 & val([M]VALUES(nolign-1))>0
  VALEUR=mess(val([M]VALUES(nolign-1)),[M]NOLIB,1)
Else
  VALEUR=""
Endif
End


######################################################################################
Subprog C_LNGTYP(VALEUR)
Variable Decimal VALEUR

# LBORN 05/11/2014 - Mantis 27066
# If VALEUR>20 : mkstat=1 : Endif
If VALEUR>50 : mkstat=1 : Endif

End
