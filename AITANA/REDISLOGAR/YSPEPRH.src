#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################################################
# Program Name: YSPEPRH
# Description : Specific Processing - Picking Ticket
# Author      :
# Date        : AUG 22nd, 2018
######################################################################################

$ACTION
 Case ACTION
  When "SETBOUT"       : Gosub SETBOUT
  When "AFFMASK"       : Gosub AFFMASK
  When Default
 Endcase
Return
######################################################################################

$SETBOUT
If func AFNC.PARAM("ZAPPPRH",[F:PRH]STOFCY)<>"1"
 Gosub SETBOUT From SUBPRHA :  GPE = 1
 If [F:PRH]ZAPPFLG<3
  Call VIREBOUT(CHAINE,"V") From GOBJET
 Endif
 #Gosub APRES_CRE
Endif
Return
######################################################################################

$APRES_CRE
 If dim(ZARRPRH)>0 : Kill ZARRPRH : Endif
 Global Char ZARRPRH(250)(0..) : Raz ZARRPRH
 Local Integer ZARRPRHCNT : ZARRPRHCNT= 0
 For I = 0 To [M:PRH1]NBLIG - 1
  ZARRPRH(ZARRPRHCNT) = [M:PRH1]ORINUM : ZARRPRHCNT+=1
 Next
Return

$AFFMASK
If func AFNC.PARAM("ZAPPPRH",[F:PRH]STOFCY)<>"1"
 Gosub AFFMASK From SUBPRHA
 Local Char PATH1(250),ZPATH(250),URL(250),HEADER(250)
 Call SET_FICNAM(PATH1,ZPATH,URL) From ORDSYS
 Openo ZPATH Using [FACS]
 
 HEADER = "H;"+ [F:PRH]PRHNUM + chr$(13)
 Wrseq HEADER  Using [FACS]
 Openo Using [FACS]
 GWEBSERV = 1
 Call IMPORTSIL("YPOCPRH",ZPATH) From GIMPOBJ
 If dim(ZSTAT) < 0 : Local Integer ZSTAT : Endif :  ZSTAT = 0
 Call SYSTEME(adxmac(1),'ae_rm ' + ZPATH, "",ZSTAT) FROM ORDSYS
 GWEBSERV = 0
 GPE = 1
Endif
Return









