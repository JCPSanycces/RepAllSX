GBIDC1=""
GBIDC2=""
GFONC1="GESPV1"
Call OBJET("PV1",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

#########################################################
$ACTION

Gosub ACTION From SPVOBJPV1

Return


#===============================================================================
# SECTION CONTENANT LES SOUS-PROGRAMMES DE CONTROLE SUR CHAMPS  : Ecran PARVGA1 (Gestion)
#===============================================================================

#########################################################
Subprog C_PARAM1(VALEUR)
Variable Char VALEUR()
Call CONPARAM(VALEUR, [M:PV10]CODVAL) From SPVOBJOTI
End

#########################################################
Subprog C_PARAM2(VALEUR)
Variable Char VALEUR()
Call CONPARAM2(VALEUR, [M:PV10]CODVAL) From SPVOBJOTI
End

#########################################################
Subprog AV_FLGMAJOBJ(VALEUR)
Variable Integer VALEUR

#FM le 24.01
[M:PV1]FLGMAJOBJ=VALEUR
Gosub AFFMAJOBJ
End

#########################################################
Subprog AP_FLGMAJOBJ(VALEUR)
Variable Integer VALEUR

#FM le 24.01
If VALEUR=2 Then
  [M:PV1]TYPDOC="OBJ"
  [M:PV1]FLGMAJCTL=2
Endif
[M:PV1]FLGMAJOBJ=VALEUR
Gosub AFFMAJOBJ
End

#########################################################
Subprog AP_TYPDOC(VALEUR)
Variable Char     VALEUR
#FM le 24.01
[M:PV1]FLGMAJOBJ=1
If VALEUR="OBJ" Then
  [M:PV1]FLGMAJOBJ=2
  [M:PV1]FLGMAJCTL=2
Endif
Gosub AFFMAJOBJ
If !GIMPORT Then Affzo [M:PV1]FLGMAJOBJ, FLGMAJCTL Endif
End

#########################################################
$AFFMAJOBJ
#FM le 24.01
If !GIMPORT Then
    Case [M:PV1]FLGMAJOBJ
    When 0,1 : Actzo [M:PV1]TYPDOC, CODVALI
               Grizo [M:PV12]
               Effzo [M:PV12]
               #FM le 26.04.05
               Effzo [M:PV1]FLGMAJCTL
               Grizo [M:PV1]FLGMAJCTL

    When 2   : Grizo [M:PV1]TYPDOC, CODVALI
               Effzo [M:PV1]CODVALI
               Actzo [M:PV12]
               #FM le 26.04.05
               Actzo [M:PV1]FLGMAJCTL
    Endcase
    Affzo [M:PV1]TYPDOC, CODVALI
    If dim([M:PV1]ZTYPDOC)>=0 Then Affzo [M:PV1]ZTYPDOC Endif
    Affzo [M:PV12]
Endif
Return


#===============================================================================
# SECTION CONTENANT LES SOUS-PROGRAMMES DE CONTROLE SUR CHAMPS  : Ecran PARVGA12 (Mise à jour objet)
#===============================================================================

########################################
Subprog C_NBLIG
Local Integer NOL
Case status
When 65     : #Suppression d'1 ligne

              NOL=nolign-1 : Gosub TEST_ANU
When 68, 83 : #Suppression d'x lignes
              For NOL=nolign-1 To nolign1-1
                Gosub TEST_ANU : If mkstat Then Break Endif
              Next
Endcase
End

#=======================================
$TEST_ANU
Gosub TSTKEY : If GERR Then GERR=0 : mkstat=2 Endif
Return

########################################
Subprog D_TRTSPE(VALEUR)
Variable Char    VALEUR()
VALEUR = "YPVA"+[M:PV10]CODVAL
End

########################################
Subprog AS_CODQUS(VALEUR)
Variable Char    VALEUR()

If [M:PV12]FLGMAJ(nolign-1)=1
&| [M:PV12]QUESTION(nolign-1)=""
    mkstat = 1
Endif
End

########################################
Subprog AS_PVAVAL(VALEUR)
Variable Char    VALEUR()

If VALEUR = "" Then
    If [M:PV12]CODQUS(nolign-1) = "" Then
        EXPR = "dim([F:VGA]"+[M:PV12]PVAZON(nolign-1)+")>0"
        If evalue(EXPR) Then
            VALEUR = "[F:VGA]"+[M:PV12]PVAZON(nolign-1)
        Endif
    Else
        VALEUR = "[F:XX03RES]RESULT"
    Endif
Endif
If [M]FLGMAJ(nolign-1)<>2 Then mkstat=2 Endif
End

########################################
Subprog AM_OBJCOD(VALEUR)
Variable Char    VALEUR()

[M:PV12]OBJCOD=VALEUR

Local Integer I,J,X,NBK
Local Char    TABK(30)(500)
Local Char    ZONK(30)(500)

If !clalev([F:GOB]) Then Local File GASOBJ  [GOB] Endif
If !clalev([F:GOD]) Then Local File GASOBJD [GOD] Endif

Call LECTURE("GOB", VALEUR, "") From CONTOBJ
If !fstat Then
    Call XKEYGOB([M]OBJCOD,TABK,ZONK,NBK)From SPVOBJGOB
    For I=0 To NBK-1
        [M:PV12]PVALIG(I) = (I+1)*1000
        [M:PV12]PVATAB(I) = [L]TABK(I)
        [M:PV12]PVAZON(I) = [L]ZONK(I)
        [M:PV12]FLGMAJ(I) = 2
    Next
    X = 0
    For [GOD]GOD1 Where [GOD]OBJCOD = [GOB]OBJCOD
&                     & [GOD]TABCOD <>""
        If !find([F:GOD]ZONCOD,[M:PV12]PVAZON) Then
            [M:PV12]PVALIG(X+I)    = (X+I+1)*1000
            [M:PV12]PVAZON(X+I)    = [F:GOD]ZONCOD
            [M:PV12]FLGMAJ(X+I)    = 1
            J=X+I : Gosub MAJ_PVATAB
            X += 1
        Endif
    Next I
    [M:PV12]NBLIG = X
    If !GIMPORT Then Affzo [M:PV12]20 Endif
Endif
End

$MAJ_PVATAB
Read [GOD]GOD0 = [M:PV12]OBJCOD;[M:PV12]PVAZON(J)
If !fstat Then [M:PV12]PVATAB(J)=[F:GOD]TABCOD Endif
Return

########################################
Subprog AS_VALFLGUPD(VALEUR)
Variable Integer VALEUR

If find([M:PV1]VALVGASTA,2,3) Then
    mkstat = 1
Elsif [M:PV1]VALVGASTA = 4 Then
    VALEUR = 2
    mkstat = 2
Endif
End

########################################
Subprog C_CODQUS(VALEUR)
Variable Char    VALEUR()

Read [F:QSN]QSN1=[M:PV12]QUESTION(nolign-1);VALEUR
If fstat Then mkstat=2 Endif
End

########################################
Subprog AM_PVATAB(VALEUR)
Variable Char    VALEUR()
[M]PVATAB(nolign-1)=VALEUR
Gosub INI_WPVATABZON
End

########################################
Subprog AM_PVAZON(VALEUR)
Variable Char    VALEUR()
#FM le 08.06.05
[M]PVAZON(nolign-1)=VALEUR
Gosub INI_WPVATABZON
End

########################################
Subprog AV_WPVATABZON(VALEUR)
Variable Char    VALEUR()
#FM le 08.06.05
Gosub INI_WPVATABZON
VALEUR=[M]WPVATABZON(nolign-1)
End

########################################
Subprog AS_PVATAB(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL
NOL=nolign-1
If VALEUR="" Then
    Local File GASOBJ [X1_]
    For [F:X1_]GOB0 Where [F:X1_]OBJCOD=[M]OBJCOD
        Case [M:PV12]NBLIG
        When 0 : VALEUR=[F:X1_]FILCOD
        When Default : If nolign>1 Then VALEUR=[M]PVATAB(nolign-2) Endif
        Endcase
    Break
    Next
    Close Local File [F:X1_]
Endif
[M]PVATAB(NOL)=VALEUR
Gosub TSTKEY : If GERR Then GERR=0 : mkstat=2 Endif
End

########################################
Subprog AS_PVAZON(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL
NOL=nolign-1
[M]PVAZON(NOL)=VALEUR
Gosub TSTKEY : If GERR Then GERR=0 : mkstat=2 Endif
End

########################################
Subprog AS_FLGMAJ(VALEUR)
Variable Integer VALEUR
Local    Integer NOL
NOL=nolign-1
Gosub TSTKEY
If GERR Then GERR=0
  # LBORN 12/04/2013 Mantis 19094 - Pas de raison que CONREV ne soit pas transmis pour ajouter des COP - à revoir
  If [M]OBJCOD<>"COP" | [M]PVAZON(nolign-1)<>"CONREV"
    mkstat=2
  Endif
Endif
End

########################################
Subprog C_PVAZON(VALEUR)
Variable Char    VALEUR()

  Local    Integer NOL , DIME , I, ZDIME
  Local    Char    ZZ(15), ZNC

  VALEUR = toupper(VALEUR)
  NOL = nolign-1

#---------------------------------------

  I = instr(1,VALEUR,"(")
  If I<>0
   ZZ     = left$(VALEUR,I-1)
   DIME   = val(right$(VALEUR,I+1))
   VALEUR = ZZ+"("+num$(DIME)+")"
  Else
   ZZ = VALEUR : DIME = 0
  Endif
  If DIME=0 Then VALEUR=ZZ Endif

#---------------------------------------

  Local File ATABZON [X__]
  Local File ACTIV   [X_1]
  ZDIME = 0
  Read [X__]CODZONE = [M]PVATAB(NOL);ZZ
  If !fstat Then
    If [F:X__]DIME=0 Then
    Read [X_1]CODACT = [F:X__]CODACT
    If !fstat Then ZDIME = [F:X_1]DIME Endif
    Else
      ZDIME = [F:X__]DIME
    Endif
  Endif
  Close Local File [X__], [X_1]

#---------------------------------------
#---------------------------------------
# Gestion des Erreurs

  If ZDIME=0 | DIME>ZDIME-1 Then
    GERR=1 : GMESSAGE = mess(41,100,1) #Champ inexistant
  Endif
  If GERR=1 Then Goto FIN_CTLZON Endif

#---------------------------------------

  Call UNICITE(vireblc([M]PVATAB(NOL)+VALEUR,4),[M]WPVATABZON)From OBJDIV
  If mkstat Then GERR=1 Endif
  If GERR=1 Then Goto FIN_CTLZON Endif

#---------------------------------------
### FM le 13.06.05 / Il n'est pas nécessaire que la zone soit paramétrée dans le param. Objet PSA
###GERR=1
###GMESSAGE = ZZ-mess(35,[V]GXMSGPSA,1)-[M]OBJCOD
###For [F:GOD]GOD1 Where OBJCOD=[M]OBJCOD
###&                   & TABCOD=[M]PVATAB(NOL)
###&                   & ZONCOD=ZZ
###    Raz GERR, GMESSAGE
###    Break
###Next
###If GERR=1 Then Goto FIN_CTLZON Endif

$FIN_CTLZON
If GERR Then mkstat=2 Endif
End


################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$INI_WPVATABZON

#FM le 08.06.05
[M]WPVATABZON(nolign-1)=vireblc([M]PVATAB(nolign-1)+[M]PVAZON(nolign-1),4)
Return


################################################################################
$TSTKEY

#FM le 10.06.05
Local Integer X
Local Integer NBK
Local Char    TABK(30)(500)
Local Char    ZONK(30)(500)

If [M]PVATAB(NOL)<>""
&& [M]PVAZON(NOL)<>""
    Call XKEYGOB([M]OBJCOD,TABK,ZONK,NBK)From SPVOBJGOB
    For X=0 To NBK-1
        If vireblc(TABK(X)+ZONK(X),4)=vireblc([M]PVATAB(NOL)+[M]PVAZON(NOL),4) Then
            GERR=1
            Break
        Endif
    Next
Endif
Return

################################################################################
Subprog C_PARAM1S(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Call CONPARAM(VALEUR,[M:PV10]CODVAL) From SPVOBJOTI
Endif
End

#########################################################
Subprog C_PARAM2S(VALEUR)
Variable Char VALEUR()
If VALEUR<>""
  Call CONPARAM2(VALEUR,[M:PV10]CODVAL) From SPVOBJOTI
Endif
End

