#<AdxTL>@(#)3.0.0.0 $Revision:   1.11  $ Gestion du masque RESQSNS
#ACV#X11
#TIT#Gestion questionnaire

GBIDC1='STATITM'
Call OBJET("QSN",[V]GBIDC1,[V]GBIDC2)From GOBJET
End

#CGUES 11/2000
#Actions sur champs

$ACTION
Return

########################################
Subprog AS_CODQSN(VALEUR)
Variable Char    VALEUR()
mkstat=2
End

########################################
Subprog C_RESULT
Local Char VALEUR(20)
Local Integer OK
Local Char QSNACTION

# LBORN 05/11/2014 - Mantis 27066
Local Char VALEUR(50)

VALEUR=num$(zc)

mkstat=0
Call CONTRES([M]CODASW(nolign-1),VALEUR,[M]TEXRES(nolign-1)) From SPVRESS2
If !mkstat
    Gosub EVAL_CTRL From SPVRESS2
    If ![L]OK : mkstat=2 : Endif
Endif
If ![V]GIMPORT & !mkstat
    Affzo [M]TEXRES(nolign-1)
Endif
End

########################################
Subprog S_RESULT
Local Char VALEUR(20)

# LBORN 05/11/2014 - Mantis 27066
Local Char VALEUR(50)

VALEUR=num$(zc)

Call SELRES([M]CODASW(nolign-1),VALEUR) From SPVRESS2

If VALEUR<>""
    If left$([M]FMTASW(nolign-1),1)="N"
        zc=val(VALEUR)
    Else
        zc=VALEUR
    Endif
Endif

End


########################################
Subprog AS_RESULT
Local Integer OK
Local Char QSNACTION

Gosub EVAL_CONDSAI From SPVRESS2
If ![L]OK
    mkstat=2
Endif
End

########################################
Subprog AVANT_NBLIG
Local Integer OK
Local Char QSNACTION

Gosub EVAL_CONDSAI From SPVRESS2
If ![L]OK
     pcolor=GCOUL(2)
Endif

End

########################################
Subprog AV_RESULT

GFMTASW=[M]FMTASW(nolign-1)
End
