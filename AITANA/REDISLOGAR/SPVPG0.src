#<AdxTL>@(#)12.0.0.0 $Revision:   1.20  $ Gestion du masque PG00
#ACV#X11
#TIT#Gestion de l'objet PG0 (Identifiant PSG)


#==========================================================================================
# Gestion de l'objet   : Gestion de l'objet Identifiant Paramètre Saisie GAS (PG0)
#                        
# Auteur               : 
# Date de création     :       
#==========================================================================================
# Modifications significatives : 
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 05/11/2002    OTHYR                
#==========================================================================================


GBIDC1=""
GBIDC2=""
Call OBJET("PG0",[V]GBIDC1,[V]GBIDC2) From GOBJET
End




##################################################################
$ACTION

Case ACTION
  When "SEL_TABLE"  : Gosub SEL_TABLE  From SPVOBJPG0
  When "MODIF"      : Gosub MODIF      From SPVOBJPG0
Endcase

Return


##################################################################
Subprog C_PSGCOD(VALEUR)
Variable Char    VALEUR()

Call UNICITE(VALEUR,[M:PG00]PSGCOD) From OBJDIV

End

