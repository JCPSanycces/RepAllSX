Subprog AM_YSOHNUMSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  [M]YSOHNUMEND=VALEUR
  Affzo YSOHNUMEND
Endif
End

Subprog AM_YMFGNUMSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  [M]YMFGNUMEND=VALEUR
  Affzo YMFGNUMEND
Endif
End


