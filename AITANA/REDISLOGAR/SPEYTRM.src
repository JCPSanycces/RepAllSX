Filter [YSGH] Where [YSGH]IPTDAT = WDATE and [YSGH]VCRDES = 'Traslado para OFs ('+WTIME+')'
For[YSGH]
[L]WCHG = [YSGH]VCRNUM
Next
Filter [YSGH]

# Debemos obtener dos informes y enviarlos por email.
