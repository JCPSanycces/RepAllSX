#########################################################################
$TRASLADO

Local Char TIT(50)
Local Integer FIC_GEN : Raz FIC_GEN

Local Char WDIR : WDIR = "IMPORT\MOV_UBIC"
Local Char WFIC : WFIC = GUSER+"_UBICACION_OF"
Local Char WEXT : WEXT = "TXT"
Local Char SAVIFS(10), SAVIRS(10)

SAVIFS = adxifs
SAVIRS = adxirs

adxifs = ";"
adxirs = chr$(10)

#Tratamiento
Local Integer ERR : Raz ERR

If ERR = 0
  #Infbox('Crear fichero')
  Gosub EXPORTAR
  If FIC_GEN = 1
    #Infbox('Importación')
    Gosub INTEGRAR_FICHERO
  Endif
Endif

Return
#########################################################################
$BORRAR_INTERMEDIOS
Trbegin [YTRMT]
   Delete  [YTRMT] Where [F:YTRMT]YUSR=GUSER
Commit
Trbegin [YSTAT]
   Delete  [YSTAT] Where [F:YSTAT]YUSR =GUSER
Commit
Return
#########################################################################
$COMPROBAR_IMPORTACION
#Comprobar que se ha realizado la importación

Call ECR_TRACE(string$(70,"-"),0) From GESECRAN


#me copio la traza
#Gosub COPIAR_TRAZA
#
#Openi filpath(WDIR,WFIC2,WEXT2),0 Using [FI2]
#
#Local Char    LIGNE(250)
#Local Integer CORRECTO: Raz CORRECTO
#
#Rdseq LIGNE Using [FI2]
# While fstat=0
#  # Como la traza no se escribe hasta al final, a menos que halla habido un error, busco la primera frase de la traza.
#  # Si lo encuentro, es que la importación ha debuelto algún error.
#  If instr(0,LIGNE,"OF a tratar según asignaciones")<>0
#   #Infbox('Encontrado: '+LIGNE)
#   CORRECTO = 1
#  Endif
#  Rdseq LIGNE Using [FI2]
# Wend
#Openi


# Si la importación falla, lso campos CUMWIPQTY_0 ,CUMWIPQTA_0 de la tabla STOCK se quedan con valor.
For [YTRMT]
  Read [YSTO]STO0 = [YTRMT]YSTOFCY;[F:YTRMT]YSTOCOU
  If fstat = 0
    If [YSTO]CUMWIPQTY <> 0 | [YSTO]CUMWIPQTA <> 0
      CORRECTO = 1

      # Como no se ha podido realizar la importación, reinicializamos los campos de STOCK
      Trbegin [YSTO]
      Readlock [YSTO]STO0 = [YTRMT]YSTOFCY;[F:YTRMT]YSTOCOU
      [YSTO]CUMWIPQTY = 0
      [YSTO]CUMWIPQTA = 0
      Rewrite [YSTO]
      If fstat = 0
        Commit
      Else
        Rollback
      Endif

    Endif
  Endif
Next


Return
#########################################################################
$COPIAR_TRAZA
#####################################################################

Local Char WDIR1(250) : WDIR1 = "Z:\Sage\X3V11\folders\"+nomap+"\TRA\"
Local Char WFIC1      : WFIC1 =  GTRACE
Local Char WEXT1      : WEXT1 = 'tra'
#
Local Char WDIR2(250) : WDIR2 = "Z:\Sage\X3V11\folders\"+nomap+"\IMPORT\MOV_UBIC\"
Local Char WFIC2      : WFIC2 = 'traza'
Local Char WEXT2      : WEXT2 = 'txt'

Local Char ZFILE(250)
ZFILE = WDIR1 +WFIC1+"."+WEXT1+ " "+ WDIR2 +WFIC2+"."+WEXT2

System "ae_cp " + ZFILE

Return
#####################################################################
$EXPORTAR
Local Integer DEL
DEL = Delfile(filpath(WDIR,WFIC,WEXT))
Openo filpath(WDIR,WFIC,WEXT),0 Using [FI1]

Local Integer LINEA : Raz LINEA

Local Date WDATE : WDATE = date$
Local Char WTIME : WTIME = time$

#Escribir la cabecera
Gosub ESCRIBIR_CABECERA
FIC_GEN = 1

Call ECR_TRACE("Traslados para OF a tratar según asignaciones",0) From GESECRAN

Filter [YTRMT] Where [YTRMT]YUSR = GUSER
  For [YTRMT]
    LINEA += 1000
    #Escribir las lineas
    Gosub ESCRIBIR_LINEA_L
    Gosub ESCRIBIR_LINEA_S
    Call ECR_TRACE("OF:"-[YTRMT]YMFGNUM-" / Componente:"-[YTRMT]YITMREF-" / Cantidad a trasladar:"-num$([YTRMT]YALLQTY)-" / [LOTE]:"-num$([YTRMT]YLOT),0) From GESECRAN
  Next
Filter [YTRMT]
Gosub FIN
Openo Using [FI1]

Return
#########################################################################
$INTEGRAR_FICHERO

# Ejecutamos Importación

If clalev([M:IMP2])=0 : Local Mask IMPOBJ2 [IMP2] : Endif

[M:IMP2]MODIMP = "YSCSV1"
[M:IMP2]TYPEXP = 2

Call IMPORTSIL([M:IMP2]MODIMP,filpath(WDIR,WFIC,WEXT)) From GIMPOBJ

Return
#########################################################################
$ESCRIBIR_CABECERA
