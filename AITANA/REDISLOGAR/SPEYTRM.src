#<AdxTL>@(#)0.0.0.0 $Revision$ 
#########################################################################
# YA045 - Traslado de mercancias para OF                                #
#########################################################################
# Función : YTRAMER                                                     #
# Acción  : YTRAMER                                                     #
# Ventana : OYTRM                                                       #
#########################################################################

$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "BOUTON"        : Gosub BOUTON
 When Default
Endcase
#########################################################################
$OUVRE
#Declaración de las tablas a utilizar

# Órdenes fabricación-artículos
If clalev([F:YMFI])  =0 Local File MFGITM  [YMFI]  Endif
# Órdenes fabricación-materiales
If clalev([F:YMFM])  =0 Local File MFGMAT  [YMFM]  Endif
#Mi tabla temporal
If clalev([F:YTRMT]) =0 Local File YTRMTEMP [YTRMT] Endif
#Asignaciones
If clalev([F:YSTA])  =0 Local File STOALL  [YSTA]  Endif
If clalev([F:WYSTA]) =0 Local File STOALL  [WYSTA] Endif

If clalev([F:YSTAT]) =0 Local File YSTATEMP  [YSTAT] Endif

#Stock
If clalev([F:YSTO])  =0 Local File STOCK   [YSTO]  Endif

#Cabecera cambio ubi. stock
If clalev([F:YSGH])  =0 Local File SCHGH   [YSGH]  Endif
#Detalles cambios stock
If clalev([F:YSGD])  =0 Local File SCHGD   [YSGD]  Endif

Local Integer WOK

#Variables las asgnaciones/desasignaciones
Variable Integer WRET
Local Decimal WQTA, WSHT

Local Char  WCHG : Raz WCHG

Return
#########################################################################
$DEBUT
#Declaración de las variables
Local Char    WCRIT1(250), WCRIT2(250), WCRIT3(250)

Raz [M:YTRM]

Return
#########################################################################
$SETBOUT
Call VIREBOUT(CHBOU,"O") From GOBJET
Return
#########################################################################
$BOUTON
#----------------------------
# R : Busqueda
# I : Incluir todo
# J : Excluir todo
# T : Trasladar
#----------------------------
Case BOUT
 When "R" : Gosub SEARCH
 When "I" : Gosub ALL_INC
 When "J" : Gosub ALL_EXC
 When "T" : Gosub BOTON_TRASLADAR
Endcase
Return
#########################################################################
$SEARCH

#primero desmarcamos todo
Gosub ALL_EXC

#Selección de las OF en base al filtro y otros criterios
WCRIT1 = "1=1"
WCRIT2 = "1=1"
If [M:YTRM]YSOHNUMSTR<>""
   WCRIT1+="&[F:YMFI]VCRNUMORI >=[M]YSOHNUMSTR"
Endif
If [M:YTRM]YSOHNUMEND<>""
   WCRIT1+="&[F:YMFI]VCRNUMORI <=[M]YSOHNUMEND"
Endif
If [M:YTRM]YMFGNUMSTR<>""
   WCRIT1+="&[F:YMFM]MFGNUM>=[M]YMFGNUMSTR"
Endif
If [M:YTRM]YMFGNUMEND<>""
   WCRIT1+="&[F:YMFM]MFGNUM<=[M]YMFGNUMEND"
Endif
# 1:En espera / 2:En curso / 3:Saldada / 4:Excluida
WCRIT2 += "&[F:YMFI]ITMSTA<=2"

Link [YMFM]   With [YMFI]MFI2= [YMFM]MFGNUM
&             As [KYMFM]
&             Where evalue(WCRIT1) & evalue(WCRIT2)

Local Integer NLL
Raz NLL
Raz [M:YTRM]NBLIG

For [KYMFM]
  NLL+=1
  Insa NLL,1 [M:YTRM]NBLIG
  [M:YTRM]NBLIG +=1
  nolign = NLL + 1
  status = 0

  [M:YTRM]YSOHNUM(NBLIG-1) = [YMFI]VCRNUMORI
  [M:YTRM]YMFGNUM(NBLIG-1) = [YMFM]MFGNUM
  [M:YTRM]YMFGLIN(NBLIG-1) = [YMFM]MFGLIN
  [M:YTRM]YBOMSEQ(NBLIG-1) = [YMFM]BOMSEQ
  [M:YTRM]YITM(NBLIG-1)    = [YMFI]ITMREF
  [M:YTRM]YITMSTA(NBLIG-1) = [YMFI]ITMSTA
  [M:YTRM]YITMREF(NBLIG-1) = [YMFM]ITMREF

  [M:YTRM]YRETQTY(NBLIG-1) = [YMFM]RETQTY
  [M:YTRM]YALLQTY(NBLIG-1) = [YMFM]ALLQTY
  [M:YTRM]YSTU(NBLIG-1)    = [YMFM]STU
  [M:YTRM]YSNDQTY(NBLIG-1) = [YMFM]YSNDQTY


  #  If ([YMFM]ALLQTY < [YMFM]RETQTY) | ([YMFM]YSNDQTY = [YMFM]RETQTY) # Si no está completamente asignado, o si está ya enviado, no dejamos marcar la línea

  Actzo [M:YTRM]YSEL(NBLIG-1)
  Affzo [M:YTRM]YSEL(NBLIG-1)

  # Si no tiene nada asignado, o si está ya todo enviado, no dejamos marcar la línea
  If ([YMFM]ALLQTY <= 0) | ([YMFM]YSNDQTY = [YMFM]RETQTY)

   Diszo [M:YTRM]YSEL(NBLIG-1)
   Affzo [M:YTRM]YSEL(NBLIG-1)
  Else

    WOK = 0

    # Si encontramos al menos una asignación que cumple los criterios, permitimos marcar la línea
    Link [YSTA] With  [YSTO]STO0=[F:YSTA]STOFCY;[F:YSTA]STOCOU
&               As    [YLNK1]
&               Where [YSTA]ITMREF = [YMFM]ITMREF
&                 and [YSTA]VCRNUM = [YMFM]MFGNUM
&                 and [YSTA]ALLTYP = 2
&                 and [YSTO]LOC = 'STOCK' #Solo las asignadas de la ubicación STOCK (No contamos las ya enviadas)
    For [YLNK1]
      WOK = 1
    Next

    If WOK = 0
       Diszo [M:YTRM]YSEL(NBLIG-1)
       Affzo [M:YTRM]YSEL(NBLIG-1)
    Endif

  Endif


  If [M:YTRM]NBLIG = 499 : Break : Endif
Next
Affzo [M:YTRM]
Return
#########################################################################
$ALL_INC
# Marcar todas las líneas (Posibles)
Infbox('Solo se marcarán las líneas que tengan asignación detallada, y no estén ya enviadas.')
For Z=0 To [M:YTRM]NBLIG-1
   #If ([M:YTRM]YALLQTY(Z) >= [M:YTRM]YRETQTY(Z)) | ([M:YTRM]YSNDQTY(Z) = [M:YTRM]YRETQTY(Z))
   If ([M:YTRM]YALLQTY(Z) > 0) and ([M:YTRM]YSNDQTY(Z) < [M:YTRM]YRETQTY(Z))
    Filter [WYSTA] Where [WYSTA]ITMREF = [M:YTRM]YITMREF(Z) and [WYSTA]VCRNUM = [M:YTRM]YMFGNUM(Z)
      For [WYSTA]
        # Solo comprobamos las asignaciones que sigan en la ubicación STOCK
        Read [YSTO]STO0 = [WYSTA]STOFCY;[WYSTA]STOCOU
        If fstat = 0
          If [YSTO]LOC <> 'MONTA'
            If [WYSTA]ALLTYP = 2     # 2 = detallada
              [M:YTRM]YSEL(Z)=2
              Affzo [M:YTRM]YSEL(Z)
            Endif
          Endif
        Endif
      Next
    Filter [WYSTA]
   Endif
Next

Return
#########################################################################
$ALL_EXC
# Desmarcar todas las líneas
For Z=0 To [M:YTRM]NBLIG-1
   [M:YTRM]YSEL(Z)=1
   Affzo [M:YTRM]YSEL(Z)
Next
Return
#########################################################################
$BOTON_TRASLADAR

#Comprobar si se ha marcado alguna línea
Local Integer MARCAS : Raz MARCAS
For I=0 To [M:YTRM]NBLIG-1
   If [M:YTRM]YSEL(I)=2
      MARCAS +=1
   Endif
Next

If MARCAS = 0
  Infbox('Se debe seleccionar al menos una línea de materiales')
Else

  If GSERVEUR
    Onerrgo ERRBATCH
  Endif
  ###Traza
  If !GSERVEUR
    Call OUVRE_TRACE("Traslado de materiales para OF") From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    #Call PRTSCR("YTRAMER","YTRM","",0,1) From ATRTX3
    Call ECR_TRACE("Traslado de materiales para OF",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
  Endif
  If GSERVEUR
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(TIT + " " + date$ + " " + time$,0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
  Endif
  ###

  # Vaciamos la tabla intermedia
  Gosub BORRAR_INTERMEDIOS

  # Cogemos las líneas que estaban marcadas y las metemos en la tabla intermedia
  For I=0 To [M:YTRM]NBLIG-1
    If [M:YTRM]YSEL(I)=2
      #Si tienen lote o varias asignaciones, metemos una línea por cada asignación
      Link [YSTA] With [YSTO]STO0=[F:YSTA]STOFCY;[F:YSTA]STOCOU
&                  As [YLNK]
&                        Where    [YSTA]ITMREF = [M:YTRM]YITMREF(I)
&                             and [YSTA]VCRNUM = [M:YTRM]YMFGNUM(I) and [YSTA]VCRSEQ = [M:YTRM]YBOMSEQ(I)
&                             and [YSTA]ALLTYP = 2
&                             and [YSTO]LOC = 'STOCK' #Solo las asignadas de la ubicación STOCK (No contamos las ya enviadas)


        For [YLNK]

          [F:YTRMT]YUSR = GUSER
          [F:YTRMT]YSOHNUM  = [M:YTRM]YSOHNUM(I)
          [F:YTRMT]YMFGNUM  = [M:YTRM]YMFGNUM(I)
          [F:YTRMT]YITM     = [M:YTRM]YITM(I)
          [F:YTRMT]YITMREF  = [M:YTRM]YITMREF(I)
          [F:YTRMT]YRETQTY  = [M:YTRM]YRETQTY(I)
          [F:YTRMT]YSTU     = [M:YTRM]YSTU(I)

          [F:YTRMT]YALLQTY  = [F:YSTA]QTYSTU
          [F:YTRMT]YSNDQTY  = [F:YSTA]QTYSTU
          [F:YTRMT]YSTOFCY  = [F:YSTA]STOFCY
          [F:YTRMT]YLOT     = [F:YSTO]LOT

          # los guardamos para la comprobación posterior
          [F:YTRMT]YSLO     = [F:YSTO]SLO
          [F:YTRMT]YSERNUM  = [F:YSTO]SERNUM
          [F:YTRMT]YSTOCOU  = [F:YSTA]STOCOU
          [F:YTRMT]YSEQ     = [F:YSTA]SEQ
          [F:YTRMT]YMFGLIN  = [M:YTRM]YMFGLIN(I)
          [F:YTRMT]YBOMSEQ  = [M:YTRM]YBOMSEQ(I)

          #Ubicación

          Write [YTRMT]
        Next

    Endif
  Next

  Local Integer CORRECTO: Raz CORRECTO

  #Guardamos las asignaciones y las eliminamos
  Gosub DESASIGNAR

  If CORRECTO = 0
    #Hacer el traslado de ubicaciones
    Gosub TRASLADO

    #Comprobar si se ha podido importar
    Gosub COMPROBAR_IMPORTACION

    If CORRECTO = 0
       Gosub ASIGNAR
      Gosub ACTUALIZAR_COMP_ASIG

      Gosub INFORMES
    Else
      Call ECR_TRACE("IMPORTACIÓN ERRONEA, no se continuará con los procesos",0) From GESECRAN
    Endif
  Else
    Call ECR_TRACE("ERROR AL DESASIGNAR, no se continuará con los procesos",0) From GESECRAN
  Endif

  Call ECR_TRACE("Fin de la traza.",0) From GESECRAN
  ###Fin traza
  If !GSERVEUR
    Call FERME_TRACE From LECFIC
    TRA=1
  Endif
  Call LEC_TRACE From LECFIC

  #Limpio la pantalla
  Raz [M:YTRM]
  Affzo [M:YTRM]
  ### Salgo
  End
  ##
Endif
Return
#########################################################################
$DESASIGNAR
#################
# DELALL         Suppression des allocations d'une ligne de document
#                DELALL(LTYP,LNUM,LLIN,LSEQ,LITM,LOPT,LQTA,LSHT,LRET)
# Paramètres E : LTYP = Type de pièce (M.701) (OF:10)
#                LNUM = Numéro pièce
#                LLIN = Numero ligne pièce
#                LSEQ = Numero sequence pièce
#                LITM = Article
#                LOPT = Option suppression : 0 allocations + manquants
#                                            1 allocations seules
#                                            2 manquants seuls
#                       +10 si pas de suppression des allocations/manquants
#                           en cours de réapprovisionnement (SRGNUM<>"")
#                           --> 10, 11 ou 12
#            S : LQTA = Total allocations supprimées  (en UA)
#                LSHT = Total manquants supprimées    (en UA)
#                LRET = Code retour (0=OK / 1=Erreur)
#################


Call ECR_TRACE('>>> Eliminar asignaciones detalladas:',0) From GESECRAN

Trbegin [YSTA]
#Guardar asignaciones
Filter [YTRMT] Where [YTRMT]YUSR = GUSER Order By Key WKEY = [YTRMT]YSTOFCY;[YTRMT]YITMREF
For [YTRMT]WKEY(1)
For [YTRMT]WKEY(2)
  #Pasamos una vez por cada articulo planta
  #Call ECR_TRACE('PLANTA:[YTRMT]'-[YTRMT]YSTOFCY-'Artículo'-[YTRMT]YITMREF,0) From GESECRAN

  #Metemos una línea por cada asignación
  Filter [YSTA] Where [YSTA]STOFCY = [YTRMT]YSTOFCY and [YSTA]ITMREF = [YTRMT]YITMREF and ([YSTA]ALLTYP = 2 or [YSTA]ALLTYP = 4) and [YSTA]VCRNUM = [YTRMT]YMFGNUM
  For [YSTA]
    #Call ECR_TRACE('>>> ITM:'-[YSTA]ITMREF-'STOCOU:'-num$([F:YSTA]STOCOU)-'SEQ'-num$([F:YSTA]SEQ)-[YSTA]VCRNUM-num$([YSTA]QTYSTU)-[YSTO]LOC,0) From GESECRAN

    Read [YSTO]STO0 = [F:YSTA]STOFCY;[F:YSTA]STOCOU

    If fstat = 0
      #If [YSTO]LOC = 'STOCK' #solo las asignaciones que apuntes a "stock"
        #Call ECR_TRACE('ITM:'-[YSTA]ITMREF-'STOCOU:'-num$([F:YSTA]STOCOU)-'SEQ'-num$([F:YSTA]SEQ)-[YSTA]VCRNUM-num$([YSTA]QTYSTU)-[YSTO]LOC,0) From GESECRAN
        #Guardar asignaciones
        [F:YSTAT] = [YSTA]
        [F:YSTAT]YUSR = GUSER
        Write [YSTAT]
      #Endif
    Endif
  Next
  Filter [YSTA]
Next
Next
Filter [YTRMT]

#Borramos las asignaciones que nos hemos copiado
Filter [YSTAT] Where [YSTAT]YUSR = GUSER
For [YSTAT]
Raz WRET
 Raz WQTA, WSHT
 Call DELALL([YSTAT]VCRTYP,[YSTAT]VCRNUM,[YSTAT]VCRLIN,[YSTAT]VCRSEQ,[YSTAT]ITMREF,0,WQTA,WSHT,WRET) From STKALL
 If WQTA <> 0
  Call ECR_TRACE('Documento asignación: '-num$([YSTAT]VCRNUM)-'/ Artículo:'-num$([YSTAT]ITMREF)-'/ Desasignado:'-num$(WQTA)-num$(WRET),0) From GESECRAN
 Endif

 If WRET <> 0 : CORRECTO = 1 : Endif
Next
Filter [YSTAT]

If CORRECTO = 0
  Commit
Else
  Rollback
Endif

Return
#########################################################################
$ASIGNAR
#################
# CREALL         Création d'une allocation
#                Subprog CREALL(LALL,LFCY,LITM,LCHR,LDAT,LQTY,LQTA,LTYP,LNUM,LLIN,LSEQ,
#                               LPRE,LDTE,LLOT,LSLO,LSTA,LLOC,LSER,LWRH,LALLQTY,LALLQTA,
#                               LDEFLOC,LDEFLOCTYP,LBPR,LADD,LSCO,LRET)
#################
# Paramètres E : LALL       = Type allocation (M.294)
#                LFCY       = Site
#                LITM       = Article
#                LCHR       = Chrono stock
#                LDAT       = Date fin réservation
#                LQTY       = Quantité en US
#                LQTA       = Quantité active
#                LTYP       = Type de pièce (M.701)
#                LNUM       = Numéro pièce
#                LLIN       = Numero ligne pièce
#                LSEQ       = Numero sequence pièce
#                LPRE       = Numéro préparation
#                LDTE       = Date du besoin
#                LLOT       = Lot (si rupture)
#                LSLO       = Sous-lot (si rupture)
#                LSTA       = Statut (si rupture)
#                LLOC       = Emplacement (si rupture)
#                LSER       = Série (si rupture)
#                LWRH       = Dépôt (si rupture)
#                LALLQTY    = Quantité US déjà allouée
#                LALLQTA    = Quantité active déjà allouée
#                LDEFLOC    = Emplacement de consommation
#                LDEFLOCTYP = Type emplacement de consommation
#                LBPR       = Tiers (si sous-traitance)
#                LADD       = Adresse de livraison (si sous-traitance)
#                LSCO       = Sous-traitance (2=matière à livrer)
#                ...
#            S : LRET       = Code retour (0=OK / 1=Erreur)
#################

Local Integer WFIRST : Raz WFIRST
#Revisar si se han creado nuevas asignaciones mientras ha pasado el proceso
Filter [YTRMT] Where [YTRMT]YUSR = GUSER Order By Key WKEY = [YTRMT]YSTOFCY;[YTRMT]YITMREF
For [YTRMT]WKEY(1)
For [YTRMT]WKEY(2)
  #Pasamos una vez por cada articulo planta
  #Call ECR_TRACE('PLANTA:[YTRMT]'-[YTRMT]YSTOFCY-'Artículo'-[YTRMT]YITMREF,0) From GESECRAN

  #
  Filter [YSTA] Where [YSTA]STOFCY = [YTRMT]YSTOFCY and [YSTA]ITMREF = [YTRMT]YITMREF and ([YSTA]ALLTYP = 2 or [YSTA]ALLTYP = 4) and [YSTA]VCRNUM = [YTRMT]YMFGNUM
  For [YSTA]
    #Call ECR_TRACE('>>> ITM:'-[YSTA]ITMREF-'STOCOU:'-num$([F:YSTA]STOCOU)-'SEQ'-num$([F:YSTA]SEQ)-[YSTA]VCRNUM-num$([YSTA]QTYSTU)-[YSTO]LOC,0) From GESECRAN
    #solo las asignaciones que apuntes a "stock"
    Read [YSTO]STO0 = [F:YSTA]STOFCY;[F:YSTA]STOCOU
    If fstat = 0
      #If [YSTO]LOC = 'STOCK'
        If WFIRST = 0
          Call ECR_TRACE('>>> ATENCIÓN: Asignaciones creadas durante el proceso que han tenido que ser eliminadas:',0) From GESECRAN
          WFIRST = 1
        Endif
        #Eliminar asignaciones (si es que las hay)
        Raz WRET
        Raz WQTA, WSHT
        Call DELALL([YSTA]VCRTYP,[YSTA]VCRNUM,[YSTA]VCRLIN,[YSTA]VCRSEQ,[YSTA]ITMREF,0,WQTA,WSHT,WRET) From STKALL
        Call ECR_TRACE('Documento asignación: '-num$([YSTA]VCRNUM)-'/ Artículo:'-num$([YSTA]ITMREF)-'/ Desasignado:'-num$(WQTA)-'/ OK:'-num$(WRET),0) From GESECRAN
      #Endif
    Endif
  Next
  Filter [YSTA]
Next
Next
Filter [YTRMT]

Call ECR_TRACE('>>> Recrear asignaciones detalladas modificadas:',0) From GESECRAN


# Creamos las asignaciones traspasadas
Filter [YSTAT] Where [YSTAT]YUSR = GUSER
For [YSTAT]

  Filter [YTRMT] Where [YTRMT]YUSR = GUSER and [YTRMT]YMFGNUM = [YSTAT]VCRNUM and [YTRMT]YBOMSEQ = [YSTAT]VCRSEQ
&                  and [YTRMT]YITMREF = [YSTAT]ITMREF and [YSTAT]STOCOU = [YTRMT]YSTOCOU and [YSTAT]SEQ = [YTRMT]YSEQ
  For [YTRMT]
    Filter [YSTO]  Where [YSTO]STOFCY = [YSTAT]STOFCY and [YSTO]ITMREF = [YSTAT]ITMREF
&                      and [YSTO]LOC = "MONTA" and [YSTO]LOT = [YTRMT]YLOT
&                      and [YSTO]SLO = [YTRMT]YSLO and [YSTO]SERNUM = [YTRMT]YSERNUM

            For [YSTO]

             Call CREALL([YSTAT]ALLTYP,[YSTAT]STOFCY,[YSTAT]ITMREF,[YSTO]STOCOU,[YSTAT]ALLDAT,[YSTAT]QTYSTU,[YSTAT]QTYSTUACT,[YSTAT]VCRTYP,[YSTAT]VCRNUM,[YSTAT]VCRLIN,[YSTAT]VCRSEQ,
&                 [YSTAT]PRENUM,[YSTAT]BESDAT,[YSTAT]LOT,[YSTAT]SLO,[YSTAT]STA,[YSTAT]LOC,[YSTAT]SERNUM,[YSTAT]WRH,0,0,
&                 [YSTAT]DEFLOC,[YSTAT]DEFLOCTYP,[YSTAT]BPRNUM,[YSTAT]BPAADD,[YSTAT]SCOFLG,"",WRET) From STKALL

             Call ECR_TRACE('MODIF. Documento asignación: '-num$([YSTAT]VCRNUM)-'/ Artículo:'-num$([YSTAT]ITMREF)-'/ Cantidad:'-num$([YSTAT]QTYSTU)-'/ OK:'-num$(WRET),0) From GESECRAN
            Next
    Filter [YSTO]
    #marcamos la línea como modificada para que no la volvamos a tratar
    [YSTAT]YMODIF = 1
    Rewrite [YSTAT]
  Next
  Filter [YTRMT]
Next
Filter [YSTAT]

Call ECR_TRACE('>>> Recrear resto de asignaciones detalladas:',0) From GESECRAN
# Creamos el resto de asignaciones
Filter [YSTAT] Where [YSTAT]YUSR = GUSER and [YSTAT]YMODIF = 0
For [YSTAT]

  Raz WRET
  Call CREALL([YSTAT]ALLTYP,[YSTAT]STOFCY,[YSTAT]ITMREF,[YSTAT]STOCOU,[YSTAT]ALLDAT,[YSTAT]QTYSTU,[YSTAT]QTYSTUACT,[YSTAT]VCRTYP,[YSTAT]VCRNUM,[YSTAT]VCRLIN,[YSTAT]VCRSEQ,
&             [YSTAT]PRENUM,[YSTAT]BESDAT,[YSTAT]LOT,[YSTAT]SLO,[YSTAT]STA,[YSTAT]LOC,[YSTAT]SERNUM,[YSTAT]WRH,0,0,
&             [YSTAT]DEFLOC,[YSTAT]DEFLOCTYP,[YSTAT]BPRNUM,[YSTAT]BPAADD,[YSTAT]SCOFLG,"",WRET) From STKALL

  Call ECR_TRACE('Documento asignación: '-num$([YSTAT]VCRNUM)-'/ Artículo:'-num$([YSTAT]ITMREF)-'/ Cantidad:'-num$([YSTAT]QTYSTU)-'/ OK:'-num$(WRET),0) From GESECRAN

Next

Return
#########################################################################
$ACTUALIZAR_COMP_ASIG
# Actualizamos la línea del componente de la OF, para indicar la cantidad enviada
# También debemos modificar las asignaciones, para que apunten a la nueva ubicación.
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE("Líneas de componentes de la OF actualizados:",0) From GESECRAN

If 1=2 Then # JC.22042021
Filter [YTRMT] Where [YTRMT]YUSR = GUSER Order By Key WKEY = [YTRMT]YSTOFCY;[YTRMT]YITMREF;[YTRMT]YBOMSEQ
For [YTRMT]WKEY(1)
For [YTRMT]WKEY(2)
For [YTRMT]WKEY(3)
    #Actualizar la línea de componente para indicar la cantidad enviada
    Trbegin [YMFM]
    Readlock [YMFM]MFM0 = [YTRMT]YMFGNUM;[YTRMT]YMFGLIN;[YTRMT]YBOMSEQ;[F:YTRMT]YITMREF
    If fstat > 0
      Rollback
    Else
      #Infbox('ARTICULO:'-[YMFM]ITMREF-' Cantidad:'-num$([YMFM]RETQTY))

      If [YMFM]YSNDQTY <> [YMFM]RETQTY
        [YMFM]YSNDQTY += [YTRMT]YSNDQTY # Sumamos la cantidad enviada en el traslado
        Rewrite [YMFM]
        If fstat = 0
          Commit
          Call ECR_TRACE("OF:"-[YTRMT]YMFGNUM-" / Componente:"-[YTRMT]YITMREF-" / Cantidad enviada:"-num$([YTRMT]YSNDQTY),0) From GESECRAN
        Else
          Rollback
        Endif
      Else
        Commit
      Endif
    Endif

    #Actualizar asignaciones
#    Filter [YSTAT] Where [YSTAT]YUSR = GUSER and [YSTAT]STOFCY = [YTRMT]YSTOFCY and [YSTAT]ITMREF = [YTRMT]YITMREF
#&                     and [YSTAT]STOCOU = [YTRMT]YSTOCOU #and [YSTAT]SEQ = [YTRMT]YSEQ
#    For [YSTAT]
#      #eliminamos la asignación y la creamos de nuevo
#      Raz WRET
#      Raz WQTA, WSHT
#      Call DELALL([YSTAT]VCRTYP,[YSTAT]VCRNUM,[YSTAT]VCRLIN,[YSTAT]VCRSEQ,[YSTAT]ITMREF,0,WQTA,WSHT,WRET) From STKALL
#
#      If WRET = 0
#        #Obtenemos el stocou de Monta
#        Filter [YSTO]  Where [YSTO]STOFCY = [YSTA]STOFCY and [YSTO]ITMREF = [YSTA]ITMREF
#&                      and [YSTO]LOC = "MONTA" and [YSTO]LOT = [YTRMT]YLOT
#&                      and [YSTO]SLO = [YTRMT]YSLO and [YSTO]SERNUM = [YTRMT]YSERNUM
#
#        For [YSTO]
#
#         Call CREALL([YSTAT]ALLTYP,[YSTAT]STOFCY,[YSTAT]ITMREF,[YSTO]STOCOU,[YSTAT]ALLDAT,[YSTAT]QTYSTU,[YSTAT]QTYSTUACT,[YSTAT]VCRTYP,[YSTAT]VCRNUM,[YSTAT]VCRLIN,[YSTAT]VCRSEQ,
#&             [YSTAT]PRENUM,[YSTAT]BESDAT,[YSTAT]LOT,[YSTAT]SLO,[YSTAT]STA,[YSTAT]LOC,[YSTAT]SERNUM,[YSTAT]WRH,0,0,
#&             [YSTAT]DEFLOC,[YSTAT]DEFLOCTYP,[YSTAT]BPRNUM,[YSTAT]BPAADD,[YSTAT]SCOFLG,"",WRET) From STKALL
#
#        Next
#        Filter [YSTO]
#      Endif
#    Next
#    Filter [YSTAT]
Next
Next
Next
Filter [YTRMT]

#JC.22042021.STR
Else
  If !clalev([F:YMCE]) Then : Local File YMFGCANTENV [F:YMCE] : Endif
  Filter [F:YMCE] Where YMFGNUM = [YTRMT]YMFGNUM
  For [F:YMCE]
    Trbegin [YMFM]
    Readlock [YMFM]MFM0 = [F:YMCE]YMFGNUM;[F:YMCE]YMFGLIN;[F:YMCE]YBOMSEQ;[F:YMCE]YITMREF
    If fstat > 0
      Rollback
    Else
      If [YMFM]YSNDQTY <> [YMFM]RETQTY
        [YMFM]YSNDQTY = [F:YMCE]YSUMCTDENV
        Rewrite [YMFM]
        If fstat = 0
          Commit
          Call ECR_TRACE("OF:"-[F:YMCE]YMFGNUM-" / Componente:"-[F:YMCE]YITMREF-" / Cantidad enviada:"-num$([F:YMCE]YSUMCTDENV),0) From GESECRAN
        Else
          Rollback
        Endif
      Else
        Commit
      Endif
    Endif
  Next
  Filter [F:YMCE]
  Close Local File [YMCE]
Endif
#JC.22042021.END

Return
