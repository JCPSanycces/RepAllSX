#####################################################################################

$ACTION
##b/- GT NDEV 27AUG2018 Customization for ACTIVITY Code YPOC
If func AFNC.ACTIV("YPOC"): Gosub ACTION From YSPEPRH : Endif
##e/- GT NDEV 27AUG2018 Customization for ACTIVITY Code YPOC

Case ACTION
  When "SETBOUT"      : Gosub SETBOUT
  When "AVANTBOUT"    : Gosub AVANTBOUT
  When "STATUT"       : Gosub STATUT
  When "AVANT_MODFIC" : Gosub AVANT_MODFIC
  When "INIMOD"       : Gosub INIMOD
  When "ANNULE"       : Gosub ANNULE
  When Default
Endcase

Return

############################################################################

$SETBOUT
# <YA032> - Textos Traspasables
CHMEN += 'z'

# </YA032>
Return

############################################################################

$AVANTBOUT
Case BOUT
 When "z"
  If [M]PRHNUM = ""
     GERR = 1 : GMESSAGE = "" : Return
  Endif
Endcase

Return

$AVANT_MODFIC
# <YA032> Textos Traspasables
If [M:PRH0]YPRHTEX="" & left$([F:PRH]YPRHTEX,3)="PRH"
    Call SUP_CLOB([F:PRH]YPRHTEX,WRET) From TRTX3TEX
Endif
# </YA032>

#Recalculo importe de línea
[M:PRH1]YAMTNOTLIN = [M:PRH1]YNETPRI * [M:PRH1]QTYSTU
Affzo [M:PRH1]YAMTNOTLIN

Return

############################################################################

$STATUT

Case BOUT
 When "z" :
  If mkstat=4 & GREP=""                    : # Texto Traspasable
     Gosub ENTRE_MODIF From GOBJSUB
  Endif
Endcase

Return

############################################################################

$INIMOD
# <YA032> Textos Traspasables
If [M:PRH0]YPRHTEX<>""
   If left$([M:PRH0]YPRHTEX,3)="PRH"
      Call CRE_CLOB([M:PRH0]YPRHTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif left$([M:PRH0]YPRHTEX,3)<>"BPD"
      Call DUP_CLOB("PRH",[M:PRH0]YPRHTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:PRH]YPRHTEX = [M:PRH0]YPRHTEX
Endif
# </YA032>
Return

############################################################################

$ANNULE
# <YA032> Textos Traspasables
Local Integer WRET

If left$([F:PRH]YPRHTEX,3)="PRH"
   Call SUP_CLOB([F:PRH]YPRHTEX,WRET) From TRTX3TEX
Endif

# </YA032>
Return

############################################################################




