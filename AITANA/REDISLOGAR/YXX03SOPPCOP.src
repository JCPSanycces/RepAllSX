#<AdxTL>@(#)0.0.0.0 $Revision$

$ACTION
  Case ACTION
    When "DEBUT"    : Gosub DEBUT
    When "AVANT_OK" : Gosub AVANT_OK
  Endcase
Return

#------------------------------------------------------------------------------#

$DEBUT
  [M:XX03SC0]YFATHERPJT = ""
  [M:XX03SC0]YREVNUM = "00"
  [M:XX03SC0]YSUBPJTNUM = "000"
Return

#------------------------------------------------------------------------------#

$AVANT_OK
  If clalev([F:YAOPP])=0 : Local File OPPOR [YAOPP] : Endif

  FOK = 1
  If [M:XX03SC0]YFATHERPJT<>""
    If [M:XX03SC0]YREVNUM=""
      GERR = 1 : GMESSAGE = mess(1,6100,1)
      zonsui = "[M:XX03SC0]YREVNUM" : FOK = 0
    Elsif [M:XX03SC0]YSUBPJTNUM=""
      GERR = 1 : GMESSAGE = mess(2,6100,1)
      zonsui = "[M:XX03SC0]YSUBPJTNUM" : FOK = 0
    Else
      Local Char PADRE(GLONVCR), AUXOPPNUM(GLONVCR)
      PADRE = func GET_FATHER([M:XX03SC0]YFATHERPJT)
      AUXOPPNUM = PADRE + "-" + [M:XX03SC0]YREVNUM + [M:XX03SC0]YSUBPJTNUM
      Read [F:YAOPP]OPP0 = AUXOPPNUM
      If !fstat
        GERR = 1 : GMESSAGE = AUXOPPNUM + ":" - mess(3,6100,1) + ".\" + mess(4,6100,1)
        zonsui = "[M:XX03SC0]YREVNUM" : FOK = 0
      Endif
    Endif
  Else
    [M:XX03SC0]YREVNUM = "00"
    [M:XX03SC0]YSUBPJTNUM = "000"
  Endif

  If !FOK : FIN = 0 : Endif
Return

#------------------------------------------------------------------------------#

Funprog GET_FATHER(WOPPNUM)
Value Char WOPPNUM

Local Integer I
Local Char    RET(GLONPIM)

  RET = WOPPNUM
  I = instr(1,RET,"-")
  If I>0
    RET = left$(RET,I-1)
  Endif
End RET

