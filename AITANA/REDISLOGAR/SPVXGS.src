#ACV#X12
#TIT#Gestion du paramétrage des transaction de saisie des visas CRA

#==========================================================================================
# Gestion de l'objet   : Gestion spécifiques de l'objet XGS (Transactions visas CRA)
# Date de création     : 29/10/2013
# Auteur               : Laurent Bornes
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

GBIDC1=""
GBIDC2=""
GFONC1="GESXGS"
GFLAG="#"
Call OBJET("XGS",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet ILT
Gosub ACTION From XOBJSPE
If GPE=1 : GPE = 0 : Return : Endif

Gosub ACTION From SPVOBJXGS

Return

######################################################################################
Subprog AM_FLGCTLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Actzo [M:XGS1]10
Else
  Effzo [M:XGS1]10
  Grizo [M:XGS1]10
Endif
End

######################################################################################
Subprog AS_NBRLIG(VALEUR)
Variable Decimal VALEUR
Call AS_NBRLIG(VALEUR) From SUBGTC
End
