#####################################################################################
#Fecha: 20/06/2019
#Desarrollador: ALIVE
#Marca: <YA055>
#Subir a 8 decimales el cálculo de los precios unitarios
######################################################################################
$ACTION
Case ACTION
 When "PICKE"  :  Gosub PICKE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "FIN_ACTION" : Gosub FIN_ACTION
 When "LIENS" :Gosub LIENS
 When Default
Endcase
Return
######################################################################################
## YA020 - Tipo de precio
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
Read [F:ZITM]ITM0 = VALEUR
If fstat = 0
  [M:PIH3]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
  Affzo [M:PIH3]YTIPPRI(nolign -1)
Endif

#En el caso de las facturas, actualizamos el precio neto.
Case [M:PIH3]YTIPPRI(nolign -1)
  When 1 : [M:PIH3]YGROPRI(nolign -1) = [M:PIH3]NETPRI(nolign -1)
  When 2 : [M:PIH3]YGROPRI(nolign -1) = [M:PIH3]NETPRI(nolign -1) * 10
  When 3 : [M:PIH3]YGROPRI(nolign -1) = [M:PIH3]NETPRI(nolign -1) * 100
  When 4 : [M:PIH3]YGROPRI(nolign -1) = [M:PIH3]NETPRI(nolign -1) * 1000
Endcase
Affzo [M:PIH3]YGROPRI(nolign -1)

End
######################################################################################
## YA020 - Tipo de precio
######################################################################################
Subprog AM_YGROPRI(VALEUR)
Variable Decimal VALEUR

Variable Decimal PRECIO

  Case [M:PIH3]YTIPPRI(nolign -1)
    When 1 : PRECIO  = VALEUR
    When 2 : PRECIO  = VALEUR / 10
    When 3 : PRECIO  = VALEUR / 100
    When 4 : PRECIO  = VALEUR / 1000
  Endcase

  #En el caso de las facturas, actualizamos el precio neto.

  # Llamamos a las funciones del campo NETPRI, como si se hubiese modificdo en pantalla
  Call PAMVATFLG("PIH3",nolign-1,"NETPRI") From TRTACHFAC1
  Call AM_NETPRI(PRECIO) From SUBPIH

  # Finalmente actualizamos el campo standard
  [M:PIH3]NETPRI(nolign -1) = PRECIO
  Affzo [M:PIH3]NETPRI(nolign -1)

End
######################################################################################
#<YA055>
$PICKE
GPE=1
Local Integer LDECPRI
LDECPRI=GDECPRI
If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
Read [ATY]CODTYP="YMD8"
If !fstat
  GDECPRI = mod([F:ATY]LNGTYP,1)*10
Endif
If GDECPRI=0 : GDECPRI=8 : Endif
Gosub PICKE From SUBPIHA
GDECPRI=LDECPRI
Return

$INICRE
GPE=1
GDECPRI=8
Gosub INICRE From SUBPIHA
Return

$INIMOD
GPE=1
GDECPRI=8
Gosub INIMOD From SUBPIHA
Return

$FIN_ACTION
  Call GET_GDECPRI From YFNC
Return
#<\YA055>
######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla PIH1) 08/07/2019 12:06:02 (LLL)
######################################################################################
Subprog C_YBPAENV(VALEUR)
Variable Char    VALEUR()
#<Y999> LUIS 08/07/2019 validar Codigo dirección de envio de la mercancia.
  If VALEUR<>""
    Read [BPA] BPA0=1;[M:PIH0]BPR;VALEUR
    If fstat : Raz [F:BPA] : mkstat=1 : End : Endif
  Endif

  If VALEUR = "AD" or VALEUR = "AC"
    If VALEUR="": mkstat=1 :Endif
  Endif
#</Y999>
End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla PIH1) 08/07/2019 12:06:02 (LLL)
######################################################################################
$LIENS
#If GUSER='LLL': Infbox("LIENS: [M:PIH0]PIVTYP:"+num$([M:PIH0]PIVTYP)):Endif
#<Y999>
#Controla activación del campo YBPAENV
  If [M:PIH0]PIVTYP = "AD" or [M:PIH0]PIVTYP = "AC"
    Actzo [M:PIH1]YBPAENV
  Else
    Grizo [M:PIH1]YBPAENV
  Endif
  #</Y999>
Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla PIH1) 08/07/2019 13:21:12 (LLL)
######################################################################################
Subprog AS_YBPAENV(VALEUR)
Variable Char    VALEUR()
End
