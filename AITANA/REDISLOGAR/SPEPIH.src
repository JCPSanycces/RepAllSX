Subprog AM_PIVTYP(VALEUR)
Variable Char    VALEUR()
#If GUSER='LLL': Infbox("AM_PIVTYP("+VALEUR+")"):Endif
#<Y999>
#Controla activación del campo YBPAENV
  If VALEUR = "AD" or VALEUR = "AC"
    Actzo [M:PIH1]YBPAENV
  Else
    Grizo [M:PIH1]YBPAENV
  Endif
#</Y999>
End


