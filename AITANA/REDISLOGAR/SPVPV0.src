GBIDC1=""
GBIDC2=""
GFONC1="GESPV0"
GFLAG="#"
Call OBJET("PV0",[V]GBIDC1,[V]GBIDC2) From GOBJET
End


############################################################
$ACTION
Case ACTION
  When "SETBOUT" : Gosub SETBOUT From SPVOBJPV0
Endcase
Return


############################################################
Subprog C_TYPDOC(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:PV0]TYPDOC)From OBJDIV
End

############################################################
Subprog C_EXPRGPSTD(VALEUR)
Variable Char    VALEUR()

If VALEUR = "" Then
    VALEUR = '""'
Endif

End

