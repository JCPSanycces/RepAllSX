#TIT#Gestion objet coût intervenant

#===============================================================================
# Gestion de l'objet   : IHC
#                        
# Auteur               : ???
# Date de création     : ???      
#===============================================================================
# Modifications significatives
#-------------------------------------------------------------------------------
# Date        Auteur       Description
#-------------------------------------------------------------------------------
# 31.08.2007  OTHYR        Ajout de l'appel automatique a YSPEIHC      
#-------------------------------------------------------------------------------
# 
#===============================================================================

GBIDC1=""
GBIDC2=""
Call OBJET("IHC",GBIDC1, GBIDC2) From GOBJET
End

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$ACTION

Gosub ACTION From XOBJSPE
If GPE=1 Then Return Endif

Case ACTION
   When "OUVRE": Gosub OUVRE From SPVOBJIHC
Endcase

Return

################################################################################
################################################################################
################################################################################
################################################################################

########################################
Subprog D_CATCUR(VALEUR)
Variable Char    VALEUR()
Call GETDEV([M]FCY(nolign-1)) From DEVSUB
VALEUR=[V]GLOCALDEV
End

########################################
Subprog C_UOM(VALEUR)
Variable Char    VALEUR()

Local Integer NOL, I

[L]NOL=nolign-1

For [L]I=0 To [M]NBLIG-1
  If [L]I<>[L]NOL
&  & [M]UOM(I)=VALEUR
&  & [M]CATINT(I)=[M]CATINT([L]NOL)
&  & [M]FCY(I)=[M]FCY([L]NOL)
&  & ([M]DATBEG(I)<[M]DATEND([L]NOL) | [M]DATEND([L]NOL)=[0/0/0])
&  & ([M]DATEND(I)>[M]DATBEG([L]NOL) | [M]DATEND([L]I)=[0/0/0])
    [V]GMESSAGE=mess(155,[V]GXMSGPSA,1)-num$(I+1)
    mkstat=2
    Break 1
  Endif
Next

End

########################################
Subprog C_DATEND(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M]DATBEG(nolign-1)
  mkstat=1
Endif
End

######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & [M]CATCUR(nolign-1)<>""
  [M]FCY(nolign-1)=VALEUR
  Effzo [M]CATCUR(nolign-1)
  Affzo [M]CATCUR(nolign-1)
Endif
End


######################################################################################

