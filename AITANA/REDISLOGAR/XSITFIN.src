Endif
End

######################################################################################
Subprog CL_ICO1(VALEUR)
Variable Char    VALEUR()
Local Date ZDAT
[L]ZDAT=date$
Gosub CLIC_ICODAT From XSITFIN2
End

######################################################################################
Subprog CL_ICO2(VALEUR)
Variable Char    VALEUR()
Local Date ZDAT
[L]ZDAT=eomonth(addmonth(date$,-1))
Gosub CLIC_ICODAT From XSITFIN2
End

######################################################################################
Subprog C_CALDAT(VALEUR)
Variable Date    VALEUR

If GREP="C"
  Filter [F:XSF] Where [F:XSF]OPPNUM=[M:XSF0]OPPNUM
  Read [F:XSF]XSF1 Last
  If !fstat & [F:XSF]CALDAT>VALEUR
    [V]GMESSAGE=mess(329,[V]GXMSGPSA,1)-[F:XSF]SITFIN-mess(330,[V]GXMSGPSA,1)-format$("D:DD[/]MM[/]YYYY",[F:XSF]CALDAT)
    [V]GERR=1
    mkstat=1
  Endif
  Filter [F:XSF]
Endif

End

######################################################################################
Subprog AM_CALDAT(VALEUR)
Variable Date    VALEUR

If GREP<>"C"

  Filter [F:XSF] Where [F:XSF]OPPNUM=[M:XSF0]OPPNUM & [F:XSF]CALDAT<=VALEUR

  # LBORN 04/06/2015 - Mantis 29849
  # Read [F:XSF]XFT1 Last
  Read [F:XSF]XSF1 Last
  If fstat>2 : Raz [F:XSF] : Else VALEUR=[F:XSF]CALDAT : Endif

Else
  Filter [F:XSF] Where [F:XSF]OPPNUM=[M:XSF0]OPPNUM
  Read [F:XSF]XSF1 Last
  If !fstat & [F:XSF]CALDAT=VALEUR
    Raz [F:XSF]
  Else
    Filter [F:XSF] Where [F:XSF]OPPNUM=[M:XSF0]OPPNUM & [F:XSF]CALDAT=VALEUR
    Read [F:XSF]XSF1 Last
    If fstat>2 : Raz [F:XSF] : Endif
  Endif
Endif
Filter [F:XSF]

If GREP="M"
  [V]GMESSAGE=mess(7,126,1)+"\"+mess(9,126,1)
  GSTATUS=1 : Call OUINON([V]GMESSAGE,GSTATUS) From GESECRAN
  If GSTATUS=2
    [M:XSF0]SITFIN=[F:XSF]SITFIN
    [M:XSF0]CALDAT=VALEUR
    Call RAFFRAICHI([M:XSF0]OPPNUM,[M:XSF0]SITFIN) From XSITFIN2
  Else
    VALEUR=[M:XSF0]CALDAT
    mkstat=2
    Raz [V]GMESSAGE
  Endif
Else
  [M:XSF0]SITFIN=[F:XSF]SITFIN
  [M:XSF0]CALDAT=VALEUR
  Call RAFFRAICHI([M:XSF0]OPPNUM,[M:XSF0]SITFIN) From XSITFIN2
Endif

End

######################################################################################
Subprog IB_NBSIT

Local Integer ZNOL, ZOK, J

[L]ZNOL=nolign

Raz [V]GBOUT7, [V]GBOUT8, [V]GBOUT9, [V]GBOUT12, [V]GBOUT14

Read [F:OPP]OPP0=[M:XSF0]OPPNUM
If fstat : Raz [F:OPP] : Endif
Read [F:XSF]XSF0=[M:XSF0]SITFIN
If fstat : Raz [F:XSF] : Endif

# Recalcul de la situation
If func XSITFIN2.AUTOR_MODIF & GREP="" & [M:XSF1]SITFIN([L]ZNOL-1)<>""
  [V]GBOUT7=mess(338,[V]GXMSGPSA,1)
Endif

# Création des situations
If func XOBJOPPX11.AUTOR_CRESITFIN([M:XSF0]OPPNUM,GREP) & ![V]XVERROU & [M:XSF1]SITFIN([L]ZNOL-1)=""
  Read [F:PPT]PPT0=[F:OPP]OPPTYP
  If !fstat
    [L]ZOK=1
    If [F:PPT]SITOPP=2
      # Situation par affaire
      For [L]J=0 To [M:XSF1]NBSIT-1
        If [M:XSF1]SITFIN([L]J)<>""
          Read [F:XSF]XSF0=[M:XSF1]SITFIN([L]J)
          If !fstat & [F:XSF]VLYFLG<>2 & [F:XSF]CANFLG<>2
            [L]ZOK=0 : Break : # Situation en cours
          Endif
        Endif
      Next
    Else
      # Situation par niveau
      # Structure à vérifier (à developper) pour voir s'il y a qq chose à créer
      # [L]ZOK=0
    Endif
    If [L]ZOK
      [V]GBOUT8=mess(113,[V]GXMSGOPP,1)
    Endif
  Endif
Endif

# Supprimer
If !func XSITFIN2.NOBOUT_SUP & GREP="" & [M:XSF1]SITFIN([L]ZNOL-1)<>""
  GBOUT9=mess(4,123,1)
Endif

# Info situation
If [M:XSF1]SITFIN([L]ZNOL-1)<>""
  GBOUT12=mess(118,[V]GXMSGOPP,1)
Endif

# Traçabilité pièces
If [M:XSF1]SITFIN([L]ZNOL-1)<>"" & GREP="" & [F:XSF]CANFLG<>2 & func AFNC.ACTIV("TRA")
  GBOUT14=mess(19,723,1)
Endif

Read [F:XSF]XSF0=[M:XSF0]SITFIN
If fstat : Raz [F:XSF] : Endif

End

######################################################################################
Subprog AS_NBSIT

If [M:XSF1]SITFIN(nolign-1)="" | find(GREP,"M","C") | status<>71 | [M:XSF1]SITFIN(nolign-1)=[M:XSF0]SITFIN : End : Endif

[M:XSF0]SITFIN=[M:XSF1]SITFIN(nolign-1)
Call RAFFRAICHI([M:XSF0]OPPNUM,[M:XSF0]SITFIN) From XSITFIN2

End

######################################################################################
Subprog B7_NBSIT
Call RECALSIT([M:XSF0]OPPNUM,[M:XSF0]SITFIN) From XSITFIN2
If [V]XBOUTOK
  Call RAFFRAICHI([M:XSF0]OPPNUM,[M:XSF0]SITFIN) From XSITFIN2
Endif
End

######################################################################################
Subprog B8_NBSIT

Case [M:XSF1]TYPLIG(nolign-1)
  When 2
    Call CRESIT([M:XSF0]OPPNUM,[M:XSF1]NIV1(nolign-1),"") From XSITFIN2
  When 3
    Call CRESIT([M:XSF0]OPPNUM,[M:XSF1]NIV1(nolign-1),[M:XSF1]NIV2(nolign-1)) From XSITFIN2
  When Default
    Call CRESIT([M:XSF0]OPPNUM,"","") From XSITFIN2
Endcase

If [V]XBOUTOK
  Call RAFFRAICHI([M:XSF0]OPPNUM,[M:XSF0]SITFIN) From XSITFIN2
Endif
End

######################################################################################
Subprog B9_NBSIT
Call B_SUPPR([M:XSF0]SITFIN) From XSITFIN2
Call RAFFRAICHI([M:XSF0]OPPNUM,[M:XSF0]SITFIN) From XSITFIN2
End

######################################################################################
Subprog B12_NBSIT
Call INFOSIT([M:XSF0]SITFIN,1) From XSITFIN2
End

#==========================================================================================
Subprog B14_NBSIT
Call TRAPCE([M:XSF0]SITFIN) From XSITFIN2
End

######################################################################################
Subprog AS_NBLIG

If status<>71 | nolign=0 | [M:XSF0]XNUMLIG2=0 : End : Endif

Local Integer ZI

If nolign<>[M:XSF0]XNUMLIG2
  [M:XSF0]XNUMLIG2=nolign

  Call AFFTAB(2) From XSITFIN2
  Affzo [M:XSF2]

  # Pour raffraichir info
  [V]GMESSAGE=string$(70," ")
  GERR=4

Endif

End

######################################################################################
Subprog AV_BUDPCT(VALEUR)
Variable Decimal VALEUR

Raz VALEUR

If nolign>0 & nolign<11 & [M:XSF2]BUDMNT(0)<>0
  If [M:XSF2]BUDMNT(nolign-1)<>0
    VALEUR=arr([M:XSF2]BUDMNT(nolign-1)*100/[M:XSF2]BUDMNT(0),1)
  Endif
Endif

Gosub DEF_COULEUR From XSITFIN2

End

######################################################################################
Subprog AV_ANTPCT(VALEUR)
Variable Decimal VALEUR
Raz VALEUR
If find(nolign,1,2,4,5)
  If [M:XSF2]BUDMNT(nolign-1)<>0
    VALEUR=arr([M:XSF2]ANTMNT(nolign-1)*100/[M:XSF2]BUDMNT(nolign-1),1)
  Endif
Endif
End

######################################################################################
Subprog AV_ARIPCT(VALEUR)
Variable Decimal VALEUR
Raz VALEUR
If nolign>0 & nolign<10
  If [M:XSF2]BUDMNT(nolign-1)<>0
    VALEUR=arr([M:XSF2]ARIMNT(nolign-1)*100/[M:XSF2]BUDMNT(nolign-1),1)
  Endif
Endif
End

######################################################################################
Subprog AV_ARFPCT(VALEUR)
Variable Decimal VALEUR
Raz VALEUR
If nolign>0 & nolign<10
  If [M:XSF2]BUDMNT(nolign-1)<>0
    VALEUR=arr([M:XSF2]ARFMNT(nolign-1)*100/[M:XSF2]BUDMNT(nolign-1),1)
  Endif
Endif
End

######################################################################################
Subprog AV_CATPCT(VALEUR)
Variable Decimal VALEUR
Raz VALEUR
If nolign>0 & nolign<10
  If [M:XSF2]BUDMNT(nolign-1)<>0
    VALEUR=arr([M:XSF2]CATMNT(nolign-1)*100/[M:XSF2]BUDMNT(nolign-1),1)
  Endif
Endif
End

######################################################################################
Subprog AS_COFMNT(VALEUR)
Variable Decimal VALEUR
If [M:XSF2]TYPLIG([M:XSF0]XNUMLIG2-1)<>4
  # Si on n'est pas au niveau le plus fin, pas de saisie pour la répartition si revenu=0
  If [M:XSF2]BUDMNT(0)=0
    mkstat=2
  Endif
Endif
End

######################################################################################
Subprog AM_COFMNT(VALEUR)
Variable Decimal VALEUR

Local Integer SVGLIG, ZNBLIG

[L]SVGLIG=indice

Case [L]SVGLIG
  When 1
    [M:XSF2]COFCIR([M:XSF0]XNUMLIG2-1)=VALEUR
  When 2
    [M:XSF2]COFCIE([M:XSF0]XNUMLIG2-1)=VALEUR
Endcase

Call TEMPON("L") From GESECRAN

If [M:XSF2]TYPLIG([M:XSF0]XNUMLIG2-1)<>4

  Local Integer J

  For [L]J=[M:XSF0]XNUMLIG2 To [M:XSF2]NBLIG-1
    If [M:XSF2]NIV([L]J)<=[M:XSF2]NIV([M:XSF0]XNUMLIG2-1)
      Break
    Elsif [M:XSF2]TYPLIG([L]J)=4
      Case [L]SVGLIG
        When 1
          [M:XSF2]COFCIR([L]J)=arr([M:XSF2]BUDREV([L]J)*VALEUR/[M:XSF2]BUDMNT(0),1)
        When 2
          [M:XSF2]COFCIE([L]J)=arr([M:XSF2]BUDREV([L]J)*VALEUR/[M:XSF2]BUDMNT(0),1)
      Endcase

      # Recalcul des montant de la ligne de détail
      Call RECAL_LIG([L]J+1) From XSITFIN2

    Endif
  Next

  # Recalcul des cumuls (les montants du détail ont été recalculés au préalable)
  Raz [M:XSF2]BUDMNT, BUDPCT, ANTMNT, ANTPCT, REAMNT, AVTMNT, CORMNT, ARIMNT, ARIPCT, ARFMNT, ARFPCT, RAFMNT, CATMNT, CATPCT
  Gosub CUM_PRODUITS From XSITFIN2

Else

  # Recalcul des montants de la ligne de détail (partie invisible du tableau)
  Call RECAL_LIG([M:XSF0]XNUMLIG2) From XSITFIN2

  # Réaffecation
  Gosub AFF_PRODUIT From XSITFIN2
Endif

Call TEMPOFF From GESECRAN

Affzo [M:XSF2]BUDMNT, BUDPCT, ANTMNT, ANTPCT, REAMNT, AVTMNT, CORMNT, ARIMNT, ARIPCT, ARFMNT, ARFPCT, RAFMNT, CATMNT, CATPCT

nolign=[L]SVGLIG+1
indice=[L]SVGLIG

End

