Endif
End

######################################################################################
Subprog AV_ICOSIT(VALEUR)
Variable Char    VALEUR()
If !func XSITFIN2.AUTOR_MODIF & [M:XSF0]OPPNUM<>"" & [M:XSF0]SITFIN<>""
  VALEUR="146"
Else
