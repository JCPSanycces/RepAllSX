Local Char VALBOUT(250) , PARBOUT(250)(1..20)
PARBOUT(1) = "AFF1206PSF00004"
GACTION = "XSITFIN"
Call SAISIE_CHAR(VALBOUT,PARBOUT,"XSITFIN","XSITFIN","YSITFIN") From GSAISIE
End

GBIDC1=""
GBIDC2=""
GFONC1="GESOPPGAS"
Call OBJET("OPP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
  When "AVANT_OUVRE"  : Gosub AVANT_OUVRE  From XSITFIN2
  When "OUVRE"        : Gosub OUVRE        From XSITFIN2
  When "DEBUT"        : Gosub DEBUT        From XSITFIN2
  When "SETBOUT"      : Gosub SETBOUT      From XSITFIN2
  When "AVANT_BOUTON" : Gosub AVANT_BOUTON From XSITFIN2
  When "BOUTON"       : Gosub BOUTON       From XSITFIN2
  When "APRES_MODIF"  : Gosub APRES_MODIF  From XSITFIN2
  When "FINSAI"       : Gosub FINSAI       From XSITFIN2
  When "FIR"          : Gosub FIR          From XSITFIN2
  When "PRE"          : Gosub PRE          From XSITFIN2
  When "SUI"          : Gosub SUI          From XSITFIN2
  When "LAS"          : Gosub LAS          From XSITFIN2
  When "ABA"          : Gosub ABA          From XSITFIN2
  When "ENR"          : Gosub ENR          From XSITFIN2
  When "MEN"          : Gosub A_MEN        From XSITFIN2
  When "FIN"          : Gosub FIN          From XSITFIN2 : # LBORN 14/12/2015 - Mantis 31398
Endcase

Return

######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
GSOCIETE=VALEUR
Raz [M:XSF0]SALFCY
End

######################################################################################
Subprog AS_OPPNUM(VALEUR)
Variable Char    VALEUR()
Call CRITOPP([V]GBIDC1) From XSITFIN2
End

######################################################################################
Subprog C_OPPNUM(VALEUR)
Variable Char    VALEUR()

Read [F:OPP]OPP0=VALEUR
If fstat
  Call CONTROLE("OPP","#",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : End : Endif
Endif

Read [F:XOP]XOP0=VALEUR
If fstat : End : Endif

Read [F:FCY]FCY0=[F:OPP]SALFCY
If fstat : Raz [F:FCY] : Endif

If [M:XSF0]CPY<>"" & [F:FCY]LEGCPY<>[M:XSF0]CPY
  [V]GMESSAGE=mess(99,[V]GXMSGOPP,1)
  [V]GERR=1
  mkstat=1
  End
Endif

If [M:XSF0]SALFCY<>"" & [F:OPP]SALFCY<>[M:XSF0]SALFCY
  [V]GMESSAGE=mess(100,[V]GXMSGOPP,1)
  [V]GERR=1
  mkstat=1
  End
Endif

If [M:XSF0]OPPREP<>"" & [F:OPP]OPPREP<>[M:XSF0]OPPREP
  [V]GMESSAGE=mess(114,[V]GXMSGOPP,1)
  [V]GERR=1
  mkstat=1
  End
Endif

If [M:XSF0]GESINT<>"" & [F:XOP]GESINT<>[M:XSF0]GESINT
  [V]GMESSAGE=mess(101,[V]GXMSGOPP,1)
  [V]GERR=1
  mkstat=1
  End
Endif

End

######################################################################################
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()

Gosub DEVERROU From XSITFIN2

Effzo [M:XSF0]CALDAT

Filter [F:XSF] Where [F:XSF]OPPNUM=VALEUR & [F:XSF]CANFLG<>2
Read [F:XSF]XSF1 Last
If fstat>2 : Raz [F:XSF] : Endif
Filter [F:XSF]

Gosub LECOPP From XSITFIN2

[M:XSF0]OPPNUM=VALEUR
[M:XSF0]SITFIN=[F:XSF]SITFIN
[M:XSF0]CALDAT=[F:XSF]CALDAT
If [M:XSF0]CALDAT=[0/0/0]
  [M:XSF0]CALDAT=date$
Endif
[M:XSF0]XNUMLIG2=1

Gosub TRISIT From XSITFIN2

Call RAFFRAICHI([M:XSF0]OPPNUM,[M:XSF0]SITFIN) From XSITFIN2

End

######################################################################################
Subprog AV_ICOOPP(VALEUR)
Variable Char    VALEUR()
If [M:XSF0]OPPNUM=""
  VALEUR=""
Else
  VALEUR="65"
Endif
End

######################################################################################
Subprog AV_CHGTYP(VALEUR)
Variable Integer VALEUR

# LBORN 09/02/2017
# Read [F:XOP]XOP0=[M:XSF0]OPPNUM
# If fstat : Raz [F:XOP] : Endif
# VALEUR=max([F:XOP]CHGTYP,1)
Read [F:OPP]OPP0=[M:XSF0]OPPNUM
If fstat : Raz [F:OPP] : Endif
VALEUR=max([F:OPP]CHGTYP,1)

End

######################################################################################
Subprog AV_CUR(VALEUR)
Variable Char    VALEUR()
Read [F:OPP]OPP0=[M:XSF0]OPPNUM
If fstat : Raz [F:OPP] : Endif
Call GETDEV([F:OPP]SALFCY) From DEVSUB
VALEUR=[V]GLOCALDEV
End

######################################################################################
Subprog AV_ICOOPP2(VALEUR)
Variable Char    VALEUR()
If GREP<>"" | [M:XSF0]OPPNUM=""
  VALEUR=""
Else
  VALEUR="10"
Endif
End

######################################################################################
Subprog CL_ICOOPP2(VALEUR)
Variable Char    VALEUR()

Local Char ZOPP, ZCRIT(240)

Filter [F:OPP] Where find([F:OPP]OPPSTEA2,'WIN','LOS','FOR')=0

Call CRITOPP([L]ZCRIT) From XSITFIN2

[L]ZOPP=[M:XSF0]OPPNUM

While 1
  Read [F:OPP]OPP0<[L]ZOPP
  If fstat<=2 & [F:OPP]OPPNUM<>[L]ZOPP
    Read [F:XOP]XOP0=[F:OPP]OPPNUM
    If fstat : Raz [F:XOP] : Endif
    Read [F:FCY]FCY0=[F:OPP]SALFCY
    If fstat : Raz [F:FCY] : Endif
    If !evalue([L]ZCRIT)
      [L]ZOPP=[F:OPP]OPPNUM
    Else
      fstat=0
      Break
    Endif
  Else
    Break
  Endif
Wend

Gosub SUIVPREC

End

$SUIVPREC
If fstat>2 | [F:OPP]OPPNUM=[M:XSF0]OPPNUM
  [V]GMESSAGE=mess(11,100,1)
  [V]GERR=2
Else
  Call AM_OPPNUM([F:OPP]OPPNUM)
  [M:XSF0]OPPNUM=[F:OPP]OPPNUM
Endif
Filter [F:OPP]
Return

######################################################################################
Subprog AV_ICOOPP3(VALEUR)
Variable Char    VALEUR()
If GREP<>"" | [M:XSF0]OPPNUM=""
  VALEUR=""
Else
  VALEUR="11"
Endif
End

######################################################################################
Subprog CL_ICOOPP3(VALEUR)
Variable Char    VALEUR()

Local Char ZOPP, ZCRIT(240)

Filter [F:OPP] Where find([F:OPP]OPPSTEA2,'WIN','LOS','FOR')=0

Call CRITOPP([L]ZCRIT) From XSITFIN2

[L]ZOPP=[M:XSF0]OPPNUM

While 1
  Read [F:OPP]OPP0>[L]ZOPP
  If fstat<=2 & [F:OPP]OPPNUM<>[L]ZOPP
    Read [F:XOP]XOP0=[F:OPP]OPPNUM
    If fstat : Raz [F:XOP] : Endif
    Read [F:FCY]FCY0=[F:OPP]SALFCY
    If fstat : Raz [F:FCY] : Endif
    If !evalue([L]ZCRIT)
      [L]ZOPP=[F:OPP]OPPNUM
    Else
      fstat=0
      Break
    Endif
  Else
    Break
  Endif
Wend

Gosub SUIVPREC

End

######################################################################################
Subprog CL_TRI(VALEUR)
Variable Char    VALEUR()
If [M:XSF0]TRIDAT=2
  [M:XSF0]TRIDAT=1
Else
  [M:XSF0]TRIDAT=2
Endif
Gosub ICOTRI From XSITFIN2
VALEUR=[M:XSF0]TRI
Call RAFFRAICHI([M:XSF0]OPPNUM,[M:XSF0]SITFIN) From XSITFIN2
End

