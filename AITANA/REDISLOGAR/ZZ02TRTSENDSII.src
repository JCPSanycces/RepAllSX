#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
   When "WVARPOST" :  Gosub  WVARPOST   # PERMITE MODIFICAR VARIABLES DEPUES DE QUE HAYAN SIDO CARGADAS POR EL PROCESO ESTANDAR
   When "WSIIFILE" :  Gosub  WSIIFILE   # PROCESO DE ENVIO DE FICHERO
   When Default
  Endcase
Return


$WVARPOST
  If !clalev([ZBPA]) Then : Local File BPARTNER [ZBPA] : Endif
  If !clalev([ZSIV]) Then : Local File SINVOICE [ZSIV] : Endif
  # MODIFICACIÓN PARA QUE EL PAIS QUE SE ENVIA EN EL FICHERO XML SEA EL QUE SE INDICA EN EL CLIENTE Y NO LA DIRECCION DE ENTREGA DE FACTURA
  # 30/03/2020. MAB. AITANA
  If WLIBRO = 1 Then # FACTURAS EMITIDAS
    For WIND = 0 To IND
      Read [ZSIV]SIH0 = WNUMFACID(WIND)
      If !fstat Then
        Read [ZBPA]BPR0 = [F:ZSIV]BPR
        If !fstat Then
          If WPAIST(WIND) <> [F:ZBPA]CRY Then
            WPAIST(WIND) = [F:ZBPA]CRY
          Endif
        Endif
      Endif
    Next
  Endif

  Close File [ZBPA], [ZSIV]


Return

$WSIIFILE
  # WFILE=1 # NO SE ENVIA EL FICHEOR A HACIENDA
  #PENO filpath("BQT", "XXX", "XML"), 0 Using [XXX]
  # Wrseq DATAXML Using [XXX]
  # Openo Using [XXX]


Return

