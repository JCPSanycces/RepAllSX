#<AdxTL>@(#)2.0.0.0 $Revision:   1.20  $ Gestion du masque PRT6
#ACV#X13
#TIT#Gestion de l'objet XRT

#LBO 09/2002

GBIDC1=""
GBIDC2=""
Call OBJET("XRT",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION
Return

Subprog C_PLANCOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR, [M:XRT6]PLANCOD) From OBJDIV
End

