#<AdxTL>@(#)7.0.0.0 $Revision:   1.20  $ Gestion du masque MCT0
#ACV#X12
#TIT#Gestion du paramétrage des transaction de saisie des interventions

$ACTION

# Appel fonctions complémentaires GFI pour l'objet ITT
Gosub ACTION From XOBJSPE
If GPE=1 : GPE = 0 : Return : Endif

Case ACTION
 When "OUVRE"      : Gosub OUVRE From SPVOBJITT
 When "RAZCRE"     : Gosub RAZCRE From SPVOBJITT
 When "INICRE"     : Gosub INICRE From SPVOBJITT
                     Gosub INI_CRE_MOD From XTRPSA
 When "INIMOD"     : Gosub INIMOD From SPVOBJITT
                     Gosub INI_CRE_MOD From XTRPSA
 When "CREATION"   : Gosub CREATION From SPVOBJITT
 When "MODIF"      : Gosub MODIF From SPVOBJITT
 When "ANNULE"     : Gosub ANNULE From SPVOBJITT
                     Gosub ANNULE     From XTRPSA
 When "CHANGE"     : Gosub CHANGE     From XTRPSA

 When "LIENS"      : Gosub LIENS From SPVOBJITT
 When "SETBOUT"    : Gosub SETBOUT From XTRPSA
 When "EXEBOUT"    : Gosub EXEBOUT From XTRPSA
 When "FILTRE"     : Gosub FILTRE  From SPVOBJITT
 When "AJOUT_ZONE" : Gosub AJOUT_ZONE From SPVOBJITT
 When "SEL_TABLE"  : Gosub SELRQTTIT From SPVOBJITT
Endcase

Return

######################################################################################
Subprog AV_IMACNUM(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=1 : Endif
End

######################################################################################
Subprog AV_ICPRPRI(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=3 : Endif
End

######################################################################################
Subprog AV_ILOT(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=1 : Endif
End

