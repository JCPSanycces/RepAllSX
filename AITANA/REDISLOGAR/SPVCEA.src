#<AdxTL>@(#)1.0.0.0 $Revision:   1.16  $ Gestion du masque CCEAUT1
#ACV#X00
#TIT#Génération sections analytiques

# LBO 12/2001

GBIDC1=""
GBIDC2=""
Call OBJET("CEA",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet FRL
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Gosub ACTION From SPVOBJCEA

Return


########################################
# Masque CCEAUT1
########################################

#-------------------------
Subprog C_CODOBJ(VALEUR)
Variable Char    VALEUR()

Local Char LISOBJ(5)(100)
Local Integer NBOBJ

Call OBJAUTOR([L]LISOBJ,[L]NBOBJ) From SPVOBJCEA

If !find(VALEUR,[L]LISOBJ)
  GMESSAGE=mess(142,[V]GXMSGPSA,1)
  mkstat=1
Endif
End

#-------------------------
Subprog AS_CCEEXP(VALEUR)
Variable Char    VALEUR()
If !clalev([F:AOB]) : Local File AOBJET : Endif
Read [F:AOB]ABREV=[M:CEA1]CODOBJ
If !fstat
  [V]GBIDC1=[F:AOB]NOMFIC
Else
  Raz [V]GBIDC1
Endif
End

#-------------------------
Subprog AS_CONDLIG(VALEUR)
Variable Char    VALEUR()
If !clalev([F:AOB]) : Local File AOBJET : Endif
Read [F:AOB]ABREV=[M:CEA1]CODOBJ
If !fstat
  [V]GBIDC1=[F:AOB]NOMFIC
Else
  Raz [V]GBIDC1
Endif
End

#-------------------------
Subprog AS_UPDOBJ(VALEUR)
Variable Integer VALEUR
If [M:CEA1]CODOBJ="OPP" & ![V]GXOPTOPP
  VALEUR=1
  mkstat=2
Endif
End

######################################################################################
Subprog AP_CODOBJ(VALEUR)
Variable Char    VALEUR()
Call AFFDST(VALEUR) From SPVOBJCEA
End

######################################################################################
Subprog AM_UPDOBJ(VALEUR)
Variable Integer VALEUR

[M:CEA1]DSTPUR(nolign-1)=1+(VALEUR=2)
[M:CEA1]DSTPRE(nolign-1)=1+(VALEUR=2)
[M:CEA1]DSTVTE(nolign-1)=1+(VALEUR=2)
[M:CEA1]DSTGES(nolign-1)=1+(VALEUR=2)
[M:CEA1]DSTINV(nolign-1)=1+(VALEUR=2)
[M:CEA1]DSTREQ(nolign-1)=1+(VALEUR=2)

If [V]GXOPTOPR
  [M:CEA1]DSTMFG(nolign-1)=1+(VALEUR=2)
Endif

End
