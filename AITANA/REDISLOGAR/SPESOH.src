######################################################################################
## YA034 - Tipo precio en Ventas
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
Read [F:ZITM]ITM0 = VALEUR
If fstat = 0
  [M:SOH4]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
  Affzo [M:SOH4]YTIPPRI(nolign -1)

    # R25.MAB.16042020.SNEW - Mostrar categoria Fabricación
  If [F:ZITM]TCLCOD = 'FAB' Then
    [M:SOH4]YCATITM(nolign-1) = 2
  Else
    [M:SOH4]YCATITM(nolign-1) = 1
  Endif
  Affzo [M:SOH4]YCATITM(nolign-1)
  # R25.MAB.16042020.SNEW

Endif

 Case [M:SOH4]YTIPPRI(nolign -1)
  When 1 : [M:SOH4]YGROPRI(nolign -1) = [M:SOH4]GROPRI(nolign -1)
  When 2 : [M:SOH4]YGROPRI(nolign -1) = [M:SOH4]GROPRI(nolign -1) * 10
  When 3 : [M:SOH4]YGROPRI(nolign -1) = [M:SOH4]GROPRI(nolign -1) * 100
  When 4 : [M:SOH4]YGROPRI(nolign -1) = [M:SOH4]GROPRI(nolign -1) * 1000
Endcase
Affzo [M:SOH4]YGROPRI(nolign -1)
End
######################################################################################
## YA034 - Tipo precio en Ventas
######################################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
Case [M:SOH4]YTIPPRI(nolign -1)
  When 1 : [M:SOH4]YGROPRI(nolign -1) = [M:SOH4]GROPRI(nolign -1)
  When 2 : [M:SOH4]YGROPRI(nolign -1) = [M:SOH4]GROPRI(nolign -1) * 10
  When 3 : [M:SOH4]YGROPRI(nolign -1) = [M:SOH4]GROPRI(nolign -1) * 100
  When 4 : [M:SOH4]YGROPRI(nolign -1) = [M:SOH4]GROPRI(nolign -1) * 1000
Endcase
Affzo [M:SOH4]YGROPRI(nolign -1)
End
######################################################################################
## YA034 - Tipo precio en Ventas
######################################################################################
Subprog AM_YGROPRI(VALEUR)
Variable Decimal VALEUR
Variable Decimal PRECIO

  Case [M:SOH4]YTIPPRI(nolign -1)
    When 1 : PRECIO  = VALEUR
    When 2 : PRECIO  = VALEUR / 10
    When 3 : PRECIO  = VALEUR / 100
    When 4 : PRECIO  = VALEUR / 1000
  Endcase

  # Actualizamos el campo standard
  [M:SOH4]GROPRI(nolign -1) = PRECIO
  Affzo [M:SOH4]GROPRI(nolign -1)

  #La acción es DIVDISCRG, pero llama al punto D_DISCRG
      Local Char    WABMSK    :    WABMSK="SOH4"
      Local Integer DISCRGNUM :    DISCRGNUM = 0
      Local Integer NOLIG     :    NOLIG=nolign-1

      If DISCRGNUM > 0 & DISCRGNUM < 10
         Assign "[M:"+WABMSK+"]DISCRGREN"+num$(DISCRGNUM)+"(NOLIG)" With GDACMANSAL
      Elsif DISCRGNUM = 0
         Assign "[M:"+WABMSK+"]PRIREN(NOLIG)" With GDACMANSAL
      Endif


  #Para suplir la acción DIVPRIPFM, llamamos a los siguientes subprogramas
  Call CLCNETPRI([M]QTY(nolign-1), [M:SOH0]CUR, nolign-1) From TRTVENPRI
  If GDACLOK = 1
      Call CTLNETPRI([M:SOH0]BPCORD,[M:SOH0]CHGTYP,[M:SOH0]ORDDAT,[M:SOH0]CUR,nolign-1) From TRTVENPRI
      If mkstat=2 [M]SAUSTUCOE(nolign-1)=WANC_SAUSTUCOE : End : Endif
  Endif
  # --> Calcul de la marge
  Call CLCPFM([M]DSTOFCY(nolign-1), [M]PRITYP, [M]CHGTYP, [M:SOH0]ORDDAT, [M:SOH0]CUR, nolign-1, 2) From TRTVENPRI
  If GDACLOK = 1
      Call CTLPFM([M:SOH0]CUR,[M:SOH4]CPRPRI(nolign-1), nolign-1) From TRTVENPRI
      If mkstat=2 [M]SAUSTUCOE(nolign-1)=WANC_SAUSTUCOE : End : Endif
  Endif
  If dim([M:SOH4]DISCRGVAL1(nolign-1))>0 Affzo [M:SOH4]DISCRGVAL1(nolign-1) Endif
  If dim([M:SOH4]DISCRGVAL2(nolign-1))>0 Affzo [M:SOH4]DISCRGVAL2(nolign-1) Endif
  If dim([M:SOH4]DISCRGVAL3(nolign-1))>0 Affzo [M:SOH4]DISCRGVAL3(nolign-1) Endif
  If dim([M:SOH4]DISCRGVAL4(nolign-1))>0 Affzo [M:SOH4]DISCRGVAL4(nolign-1) Endif
  If dim([M:SOH4]DISCRGVAL5(nolign-1))>0 Affzo [M:SOH4]DISCRGVAL5(nolign-1) Endif
  If dim([M:SOH4]DISCRGVAL6(nolign-1))>0 Affzo [M:SOH4]DISCRGVAL6(nolign-1) Endif
  If dim([M:SOH4]DISCRGVAL7(nolign-1))>0 Affzo [M:SOH4]DISCRGVAL7(nolign-1) Endif
  If dim([M:SOH4]DISCRGVAL8(nolign-1))>0 Affzo [M:SOH4]DISCRGVAL8(nolign-1) Endif
  If dim([M:SOH4]DISCRGVAL9(nolign-1))>0 Affzo [M:SOH4]DISCRGVAL9(nolign-1) Endif
  Affzo [M:SOH4]CPRPRI(nolign-1), PFM(nolign-1), NETPRI(nolign-1)

End
