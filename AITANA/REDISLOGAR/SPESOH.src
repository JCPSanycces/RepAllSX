Subprog AP_ORDDAT(VALEUR)
Variable Date    VALEUR
For LI = 0 To [M:SOH4]NBLIG-1
  Case [M:SOH4]YTIPPRI(LI)
    When 1 : [M:SOH4]YGROPRI(LI) = [M:SOH4]GROPRI(LI)
    When 2 : [M:SOH4]YGROPRI(LI) = [M:SOH4]GROPRI(LI) * 10
    When 3 : [M:SOH4]YGROPRI(LI) = [M:SOH4]GROPRI(LI) * 100
    When 4 : [M:SOH4]YGROPRI(LI) = [M:SOH4]GROPRI(LI) * 1000
  Endcase
  Affzo [M:SOH4]YGROPRI(LI)
Next
End

