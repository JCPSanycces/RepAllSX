    When 4 : [M:SOH4]YGROPRI(LI) = [M:SOH4]GROPRI(LI) * 1000
  Endcase
  Affzo [M:SOH4]YGROPRI(LI)
Next
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################
# YRE12 - JC - 11/05/2020 - comprobar el check 'Confirmada'
Subprog CHECK_CONFIRMADA(PSOHNUM,PITMREF,PSOPLIN,PQTY,PALLQTY,PRES)
Value     Char     PSOHNUM
Value     Char     PITMREF
Value     Integer  PSOPLIN
Value     Decimal  PQTY
Value     Decimal  PALLQTY
Variable  Integer  PRES

Local Decimal LQTYAS      : Raz LQTYAS
If !clalev([F:SOQ0]) Then : Local File SORDERQ [F:SOQ0] : Endif
If !clalev([F:POQ0]) Then : Local File PORDERQ [F:POQ0] : Endif
If !clalev([F:MLK0]) Then : Local File MTOLINK [F:MLK0] : Endif

  Raz PRES
  If GREP <> "C" and GREP <> "M" and GREP <> "A" Then
    # comprueba la tabla de asignaciones y busca en todos los pedidos de compra
    Filter [F:MLK0] Where ITMREF = PITMREF and DEMNUM = PSOHNUM and DEMLIN = PSOPLIN
    Read [F:MLK0] First
    If !fstat Then
      # suma la cantidad asignada desde stock (este valor entra como parámetro)
      LQTYAS = PALLQTY
      For [MLK0]
        # busca todas las líneas de ese/esos pedido/s de compra
        Filter [F:POQ0] Where POHNUM = [F:MLK0]RESSNUM and POPLIN = [F:MLK0]RESSLIN and POQSEQ = [F:MLK0]RESSSEQ
        For [POQ0]
          # si la/s línea/s está confirmada, suma la cantidad
          If [F:POQ0]YRCPDAT = 2 Then
            LQTYAS += [F:POQ0]QTYUOM
          Endif
        Next
        Filter [F:POQ0]
      Next
    Endif
    Filter [F:MLK0]
    # si la cantidad sumada de todas las líneas confirmadas (más el stock) es igual a la cantidad total del pedido de venta, se marca el flag 'Confirmada'
    If LQTYAS = PQTY Then
      PRES = 2
    Endif
  Endif

Close File [SOQ0],[MLK0],[POQ0]

End

