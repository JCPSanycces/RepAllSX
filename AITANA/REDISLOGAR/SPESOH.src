##############################################################
######################################################################################
## YA046 - Consulta de situación de OF desde el pedido de venta
######################################################################################
$LIENS_LIG
# Siempre hace primero la parte del SPE, asi que le indicamos que valla al SUB
Gosub ACTION From SUBSOH

If clalev ([F:ZMFI])  = 0 : Local File MFGITM  [ZMFI] : Endif

Filter [F:ZMFI]  Where [F:ZMFI]ITMREF = [M:SOH4]ITMREF(nolign -1) and [F:ZMFI]VCRNUMORI = [M:SOH0]SOHNUM
&                      and [F:ZMFI]VCRLINORI = [M:SOH4]SOPLIN(nolign -1) and [F:ZMFI]VCRTYPORI = 2
  For [F:ZMFI]MFI2
    [M:SOH4]YMFGNUM(nolign -1) = [F:ZMFI]MFGNUM
  Next
Filter [F:ZMFI]

#Affzo [M:SOH4]YMFGNUM(nolign -1)

  # R25.MAB.16042020.SNEW - Mostrar categoria Fabricación
  If !clalev([ZITM]) Then : Local File ITMMASTER [ZITM] : Endif
  Read [ZITM]ITM0=[M:SOH4]ITMREF(nolign-1)
  If !fstat Then
    If [F:ZITM]TCLCOD = 'FAB' Then
      [M:SOH4]YCATITM(nolign-1) = 2
    Else
      [M:SOH4]YCATITM(nolign-1) = 1
    Endif
    Affzo [M:SOH4]YCATITM(nolign-1)
  Endif
  # R25.MAB.16042020.SNEW

  # YRE12 - JC - 11/05/2020 - comprobar el check 'Confirmada' - STR
  Call CHECK_CONFIRMADA([M:SOH0]SOHNUM,[M:SOH4]ITMREF(nolign-1),[M:SOH4]SOPLIN(nolign-1),[M:SOH4]QTY(nolign-1),[M:SOH4]ALLQTY(nolign-1),[M:SOH4]YCONFIRMADA(nolign-1))
  Affzo [M:SOH4]YCONFIRMADA(nolign-1)
  # YRE12 - JC - 11/05/2020 - comprobar el check 'Confirmada' - END

# Dejo como default el SOP. Ya que el programa lo estaba usando
Default File [SOP]

# GPE=1 es Para que no vuelva a ejecutar el la parte del SUB, ya que la hemos llamado antes
GPE=1
Return

##############################################################
######################################################################################
#YA032 - Textos de cabecera traspasables JEL
#######################################################
$SETBOUT
Global Char TABLETEX
# Le indicamos que valla primero al SUB
Gosub ACTION From SUBSOH
#boton cabecera traspasable
CHMEN += "B"
Gosub SET_BOUT_SPE From GSAISIE

# Que no vuelva a ejecutar el la parte del SUB
GPE=1

  # la acción FIN_PICKE se ejecuta sólo una vez por picking
  # Modificar fechas al hacer picking JC 02/01/2020
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
#  If currbox = "GAU_CHE1" or YGVIENEDEPPTO = 2 Then
  If currbox = "GAU_CHE1" Then
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
    If !clalev([F:SQD0]) Then : Local File SQUOTED [F:SQD0] : Endif
    Local Integer I
    For I = 0 To [M:SOH4]NBLIG-1
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
#      Read [F:SQD0]SQD0 = [F:SQD]SQHNUM;[M:SOH4]SQDLIN(I)
      Read [F:SQD0]SQD0 = [M:SOH4]DETSQHNUM(I);[M:SOH4]SQDLIN(I)
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
      If !fstat Then
        [M:SOH4]DSHIDAT(I)    = [F:SQD0]DDEMDLVDAT
        [M:SOH4]MAXDLVDAT(I)  = [F:SQD0]DYEXTDLVDAT
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
        [M:SOH4]DDEMDLVDAT(I) = [F:SQD0]DDEMDLVDAT
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
        Affzo [M:SOH4]DSHIDAT(I)
        Affzo [M:SOH4]MAXDLVDAT(I)
        Affzo [M:SOH4]NBLIG(I)
      Endif
    Next
    If clalev([F:SQD0])  Then : Close Local File   [F:SQD0] : Endif
  Endif
  # Modificar fechas al hacer picking JC 02/01/2020

Return

##############################################################
$INIMOD

Gosub ACTION From SUBSOH
If [M:SOH0]YSOHTEX<>""
      Call CRE_CLOB([M:SOH0]YSOHTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
      [F:SOH]YSOHTEX = [M:SOH0]YSOHTEX
Else
   #borra la cabecera traspasable vacia
   If left$(TABLETEX,3)="SOH"
      Call SUP_CLOB(TABLETEX,WRET) From TRTX3TEX
   Endif
Endif

GPE=1
Return

##############################################################
$INICRE
# Actualizo el campo de portes en función del indicado en el cliente
Read [BPC]BPC0 = [F:SOH]BPCORD
If fstat = 0
  [F:SOH]YCARR = [F:BPC]YCARR
Endif
##

Gosub ACTION From SUBSOH

If [M:SOH0]YSOHTEX<>""

      #si no existe creamos el clob
      Call CRE_CLOB([M:SOH0]YSOHTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif

   [F:SOH]YSOHTEX = [M:SOH0]YSOHTEX
Else
   #borra la cabecera traspasable vacia
   Call SUP_CLOB(TABLETEX,WRET) From TRTX3TEX
Endif


GPE=1

Return

##############################################################
$STATUT
TABLETEX = [F:SOH]YSOHTEX
Gosub ACTION From SUBSOH
Case BOUT
    When "B"  :   If mkstat=4 & GREP=""
#                      GREP="M" : REP="M"
#                      Gosub SETBOUT From GOBJSUB
                       Gosub ENTRE_MODIF From GOBJSUB
                   Endif
                   If [M]YSOHTEX <> "" & !GIMPORT
                       Call SET_IMAGE (4) From GESECRAN
                   Elsif !GIMPORT
                       Call RESET_IMAGE (4) From GESECRAN
                   Endif

Endcase
GPE=1
Return

##############################################################
$RAZCRE
Gosub ACTION From SUBSOH
Raz [M:SOH0]YSOHTEX

GPE=1
Return

##############################################################
$RAZDUP
Gosub ACTION From SUBSOH
If left$([M:SOH0]YSOHTEX,3)="SOH"
  Call DUP_CLOB("SOH",[M:SOH0]YSOHTEX,WRET) From TRTX3TEX
  If WRET<1 Raz [M:SOH0]YSOHTEX Endif
Endif

GPE=1
Return

##############################################################
$ANNULE
Gosub ACTION From SUBSOH
If left$([F:SOH]YSOHTEX,3)="SOH"
   Call SUP_CLOB([F:SOH]YSOHTEX,WRET) From TRTX3TEX
Endif
GPE=1
Return

##############################################################
$ABANDON
Gosub ACTION From SUBSOH
If GREP = "D" & GREP <> "M"
  If left$([M:SOH0]YSOHTEX,3)="SOH"
        Call SUP_CLOB([M:SOH0]YSOHTEX,WRET) From TRTX3TEX
  Endif
Endif
GPE=1
Return
########## YA032 ########################################################

# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
##############################################################
$APRES_CRE
  # la acción FIN_PICKE se ejecuta sólo una vez por picking
  # Modificar fechas al hacer picking JC 02/01/2020
  If GFONCTION1 = "GESSQH" Then
    If !clalev([F:SQD0]) Then : Local File SQUOTED [F:SQD0] : Endif
    If !clalev([F:SOQ0]) Then : Local File SORDERQ [F:SOQ0] : Endif
    Local Integer I
    For I = 0 To [M:SOH4]NBLIG-1
      Read [F:SQD0]SQD0 = [M:SOH4]DETSQHNUM(I);[M:SOH4]SQDLIN(I)
      If !fstat Then
#        # añade la información en pantalla
#        [M:SOH4]DSHIDAT(I)    = [F:SQD0]DDEMDLVDAT
#        [M:SOH4]MAXDLVDAT(I)  = [F:SQD0]DYEXTDLVDAT
#        Affzo [M:SOH4]DSHIDAT(I)
#        Affzo [M:SOH4]MAXDLVDAT(I)
#        Affzo [M:SOH4]NBLIG(I)
        # añade la información en tabla (SORDERQ)
        Filter [F:SOQ0] Where SOHNUM = [F:SQD0]SOHNUM and SOPLIN = [F:SQD0]SOPLIN
        Read   [F:SOQ0] First
        If !fstat Then
          Trbegin [F:SOQ0]
          #[F:SOQ0]SHIDAT    = [F:SQD0]DDEMDLVDAT
          #[F:SOQ0]MAXDLVDAT = [F:SQD0]DYEXTDLVDAT
          #[F:SOQ0]DEMDLVDAT = [F:SQD0]DDEMDLVDAT
          [F:SOQ0]DEMDLVDAT = [F:SQD0]DDEMDLVDAT                        # Fecha de entrega solicitada (cuando el producto llega al cliente)
          [F:SOQ0]DAYLTI    = 0                                         # Diferencia entre fecha entrega solicitada - fecha de expedición
          [F:SOQ0]SHIDAT    = [F:SQD0]DDEMDLVDAT                        # Fecha de expedición = fecha de salida de Redislogar
          [F:SOQ0]MAXDLVDAT = [F:SQD0]DDEMDLVDAT                        # La fecha máxima es la fecha de entrega solicitada (cuando el producto llega al cliente)
          [F:SOQ0]EXTDLVDAT = [F:SQD0]DDEMDLVDAT                        # Fecha de entrega prevista (cuando el producto llega al cliente)
          Rewrite [F:SOQ0]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
        Endif
        Filter [F:SOQ0]
      Endif
    Next
    If clalev([F:SQD0])  Then : Close Local File   [F:SQD0] : Endif
    If clalev([F:SOQ0])  Then : Close Local File   [F:SOQ0] : Endif
  Endif
  # Modificar fechas al hacer picking JC 02/01/2020
Return
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################

##############################################################
$FIN

# Modificar fechas al hacer picking JC 02/01/2020
# utilizo esta variable para que actualice las fechas si se genera el pedido desde presupuesto
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
#  Raz YGVIENEDEPPTO
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
# Modificar fechas al hacer picking JC 02/01/2020

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
Subprog IB_NBLIG
#Si no hay OF asociada a la línea, no se muestra la opción.
If [M:SOH4]YMFGNUM(nolign -1) <> ''
    GBOUT19 = 'Consulta situación OF'
Else
    Raz GBOUT19
Endif
End
######################################################################################
## YA037 - Traer el código de articulo para el cliente
######################################################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()

If clalev ([F:ZITU])  = 0 : Local File ITMBPC  [ZITU] : Endif
Read [F:ZITU]ITU0 = VALEUR;[M:SOH0]BPCORD
If !fstat
  [M:SOH4]YITMCLI(nolign -1)    = [F:ZITU]ITMDESBPC
  [M:SOH4]YITMDESCLI(nolign -1) = [F:ZITU]ITMDESBPC
  Affzo [M:SOH4]YITMCLI(nolign -1)
  Affzo [M:SOH4]YITMDESCLI(nolign -1)
Endif
End


######################################################################################
## YA044 - Control de modificaciones de Pedidos de Venta con OF asociada [EFS/JEL]
######################################################################################
## Control de Cantidad ##
#########################
Subprog C_QTY(VALEUR)
  Variable Decimal VALEUR

  #-- Comprobar que tiene OF asociada al Pedido
  If [M:SOH4]YMFGNUM(nolign -1) <> ''

    If clalev ([F:ZMFI]) = 0 : Local File MFGITM  [ZMFI] : Endif

    #-- Búsqueda de la línea de OF segun el Pedido para conseguir la ctdad lanzamiento
    Filter [F:ZMFI] Where [F:ZMFI]ITMREF = [M:SOH4]ITMREF(nolign -1) and [F:ZMFI]VCRNUMORI = [M:SOH0]SOHNUM
&                     and [F:ZMFI]VCRLINORI = [M:SOH4]SOPLIN(nolign -1) and [F:ZMFI]MFGNUM = [M:SOH4]YMFGNUM(nolign -1)
    Read [ZMFI]First
    #-- Si es mayor que la cantidad en el OF
    If VALEUR > [M:SOH4]QTY(nolign-1)
      Call MESSAGE("La posición" - num$(nolign) - "del Pedido '" + num$([M:SOH0]SOHNUM) +
&                  "' que tiene asignada la OF '" + num$([M:SOH4]YMFGNUM(nolign-1)) +
&                  "' con" - num$([F:ZMFI]UOMEXTQTY) - "unidades se va a aumentar" -
&                  "de" - num$([M:SOH4]QTY(nolign-1)) - "a" - num$(VALEUR)) From GESECRAN
    Endif
    #-- Si es menor que la cantidad en el OF
    If VALEUR < [M:SOH4]QTY(nolign-1)
      # Si la cantidad en el Pedido es igual a la de OF
      If [F:ZMFI]UOMEXTQTY > VALEUR
        Call ERREURT("La posición" - num$(nolign) - "del Pedido '" + num$([M:SOH0]SOHNUM) +
&                    "' que tiene asignada la OF '" + num$([M:SOH4]YMFGNUM(nolign-1)) +
&                    "' con" - num$([F:ZMFI]UOMEXTQTY) - "unidades se va a disminuir" -
&                    "de" - num$([M:SOH4]QTY(nolign-1)) - "a" - num$(VALEUR), 1) From GESECRAN
        mkstat=2
      Endif
    Endif
  Endif
End

######################################################################################
## YA044 - Control de modificaciones de Pedidos de Venta con OF asociada [EFS/JEL]
######################################################################################
## Control de Fecha Entrega en líneas ##
##############################
Subprog C_DDEMDLVDAT(VALEUR)
  Variable Date    VALEUR
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
If 1=2
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
  Local Char VARGLB : VARGLB = "YMDFPVOFF"
  #-- Comprobar que tiene OF asociada al Pedido
  If [M:SOH4]YMFGNUM(nolign -1) <> ''
    #-- Si se atrasa la fecha de entrega respecto a la OF
    If VALEUR > [M:SOH4]DDEMDLVDAT(nolign-1)
      If clalev ([F:ZMFI]) = 0 : Local File MFGITM  [ZMFI] : Endif
      #-- Búsqueda de la línea de OF segun el Pedido para conseguir la ctdad lanzamiento
      Filter [F:ZMFI] Where [F:ZMFI]ITMREF = [M:SOH4]ITMREF(nolign -1) and [F:ZMFI]VCRNUMORI = [M:SOH0]SOHNUM
&                       and [F:ZMFI]VCRLINORI = [M:SOH4]SOPLIN(nolign -1) and [F:ZMFI]MFGNUM = [M:SOH4]YMFGNUM(nolign -1)
      Read [ZMFI]First

      Call MESSAGE("La posición" - num$(nolign) - "del Pedido '" + num$([M:SOH0]SOHNUM) +
&                  "' que tiene asignada la OF '" + num$([M:SOH4]YMFGNUM(nolign-1)) +
&                  "' con" - num$([F:ZMFI]UOMEXTQTY) - "unidades se ha cambiado de" -
&                  format$("D:DD[/]MM[/]YYYY",[M:SOH4]DDEMDLVDAT(nolign-1)) - "a" -
&                  format$("D:DD[/]MM[/]YYYY",VALEUR)) From GESECRAN
    Endif

    #-- Si se adelanta la fecha de entrega respecto a la OF
    If VALEUR < [M:SOH4]DDEMDLVDAT(nolign-1)

      If clalev ([F:ZMFI]) = 0 : Local File MFGITM  [ZMFI] : Endif
      #-- Búsqueda de la línea de OF segun el Pedido para conseguir la ctdad lanzamiento
      Filter [F:ZMFI] Where [F:ZMFI]ITMREF = [M:SOH4]ITMREF(nolign -1) and [F:ZMFI]VCRNUMORI = [M:SOH0]SOHNUM
&                       and [F:ZMFI]VCRLINORI = [M:SOH4]SOPLIN(nolign -1) and [F:ZMFI]MFGNUM = [M:SOH4]YMFGNUM(nolign -1)
      Read [ZMFI]First

      If clalev ([F:ZAGB]) = 0 : Local File AGLOBVAR [ZAGB] : Endif
      #-- Búsqueda del nº días maximo para la fecha entrega solicitada
      Read [F:ZAGB]AGB0 = VARGLB
      If fstat = 0 Then
        # Si la fecha introducida es menor de XX dias (Variable Global YMDFPVOFF)
        If num$([M:SOH4]DDEMDLVDAT(nolign-1) - VALEUR) < [F:ZAGB]FORINI Then
          Call MESSAGE("La posición" - num$(nolign) - "del Pedido '" + num$([M:SOH0]SOHNUM) +
&                      "' que tiene asignada la OF '" + num$([M:SOH4]YMFGNUM(nolign-1)) +
&                      "' con" - num$([F:ZMFI]UOMEXTQTY) - "unidades se ha cambiado de" -
&                      format$("D:DD[/]MM[/]YYYY",[M:SOH4]DDEMDLVDAT(nolign-1)) - "a" -
&                      format$("D:DD[/]MM[/]YYYY",VALEUR)) From GESECRAN
        # Si la diferencia de fecha introducida es igual o mayor de XX dias
        Else
          Call ERREURT("La posición" - num$(nolign) - "del Pedido '" + num$([M:SOH0]SOHNUM) +
&                      "' que tiene asignada la OF '" + num$([M:SOH4]YMFGNUM(nolign-1)) +
&                      "' con" - num$([F:ZMFI]UOMEXTQTY) - "unidades, no se puede adelantar la fecha entrega en" -num$([F:ZAGB]FORINI)-
&                      "o más días", 1) From GESECRAN
          VALEUR = [M:SOH4]DDEMDLVDAT(nolign-1)
          mkstat=2
        Endif
      Endif
    Endif
  Endif
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
Endif
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
End
######################################################################################
## Control de Fecha Entrega en cabecera ##
##############################
Subprog C_DEMDLVDAT(VALEUR)
  Variable Date    VALEUR
  Local Char VARGLB : VARGLB = "YMDFPVOFF"


  #-- Comprobar que tiene OF asociada al Pedido
  For I= 0 To [M:SOH4]NBLIG-1
    If [M:SOH4]YMFGNUM(I) <> ''
      #-- Si se atrasa la fecha de entrega respecto a la OF
      If VALEUR > [M:SOH4]DDEMDLVDAT(I)
        If clalev ([F:ZMFI]) = 0 : Local File MFGITM  [ZMFI] : Endif
        #-- Búsqueda de la línea de OF segun el Pedido para conseguir la ctdad lanzamiento
        Filter [F:ZMFI] Where [F:ZMFI]ITMREF = [M:SOH4]ITMREF(I) and [F:ZMFI]VCRNUMORI = [M:SOH0]SOHNUM
&                       and [F:ZMFI]VCRLINORI = [M:SOH4]SOPLIN(I) and [F:ZMFI]MFGNUM = [M:SOH4]YMFGNUM(I)
        Read [ZMFI]First

        Call MESSAGE("La posición" - num$(I+1) - "del Pedido '" + num$([M:SOH0]SOHNUM) +
&                  "' que tiene asignada la OF '" + num$([M:SOH4]YMFGNUM(I)) +
&                  "' con" - num$([F:ZMFI]UOMEXTQTY) - "unidades se cambiará de" -
&                  format$("D:DD[/]MM[/]YYYY",[M:SOH4]DDEMDLVDAT(I)) - "a" -
&                  format$("D:DD[/]MM[/]YYYY",VALEUR)) From GESECRAN
      Endif

      #-- Si se adelanta la fecha de entrega respecto a la OF
      If VALEUR < [M:SOH4]DDEMDLVDAT(I)

        If clalev ([F:ZMFI]) = 0 : Local File MFGITM  [ZMFI] : Endif
        #-- Búsqueda de la línea de OF segun el Pedido para conseguir la ctdad lanzamiento
        Filter [F:ZMFI] Where [F:ZMFI]ITMREF = [M:SOH4]ITMREF(I) and [F:ZMFI]VCRNUMORI = [M:SOH0]SOHNUM
&                       and [F:ZMFI]VCRLINORI = [M:SOH4]SOPLIN(I) and [F:ZMFI]MFGNUM = [M:SOH4]YMFGNUM(I)
        Read [ZMFI]First

        If clalev ([F:ZAGB]) = 0 : Local File AGLOBVAR [ZAGB] : Endif
        #-- Búsqueda del nº días maximo para la fecha entrega solicitada
        Read [F:ZAGB]AGB0 = VARGLB
        If fstat = 0 Then
          # Si la fecha introducida es menor de XX dias (Variable Global YMDFPVOFF)
          If num$([M:SOH4]DDEMDLVDAT(I) - VALEUR) < [F:ZAGB]FORINI Then
            Call MESSAGE("La posición" - num$(I+1) - "del Pedido '" + num$([M:SOH0]SOHNUM) +
&                      "' que tiene asignada la OF '" + num$([M:SOH4]YMFGNUM(I)) +
&                      "' con" - num$([F:ZMFI]UOMEXTQTY) - "unidades se cambiará de" -
&                      format$("D:DD[/]MM[/]YYYY",[M:SOH4]DDEMDLVDAT(I)) - "a" -
&                      format$("D:DD[/]MM[/]YYYY",VALEUR)) From GESECRAN
          # Si la diferencia de fecha introducida es igual o mayor de XX dias
          Else
            Call ERREURT("La posición" - num$(I+1) - "del Pedido '" + num$([M:SOH0]SOHNUM) +
&                      "' que tiene asignada la OF '" + num$([M:SOH4]YMFGNUM(I)) +
&                      "' con" - num$([F:ZMFI]UOMEXTQTY) - "unidades, no se puede adelantar la fecha entrega en" -num$([F:ZAGB]FORINI)-
&                      "o más días", 1) From GESECRAN
            [M:SOH2]DEMDLVDAT = [M:SOH2]DEMDLVDAT
            Affzo [M:SOH2]DEMDLVDAT
            mkstat=2
          Endif
        Endif
      Endif

    Endif
  Next

End
