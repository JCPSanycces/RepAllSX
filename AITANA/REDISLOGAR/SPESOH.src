$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
##b/- GT NDEV 06JUL2018 Customization for ACTIVITY Code YA007
If func AFNC.ACTIV("YA007"): Gosub ACTION From ZSPESOH : Endif
##e/- GT NDEV 06JUL2018 Customization for ACTIVITY Code YA007
Case ACTION
  When "FIN_PICK"   : Gosub FIN_PICK
  When "LIENS_LIG"  : Gosub LIENS_LIG
  When "SETBOUT"    : Gosub SETBOUT
  When "INIMOD"     : Gosub INIMOD
  When "INICRE"     : Gosub INICRE
  When "STATUT"     : Gosub STATUT
  When "RAZCRE"     : Gosub RAZCRE
  When "RAZDUP"     : Gosub RAZDUP
  When "ANNULE"     : Gosub ANNULE
  When "ABANDON"    : Gosub ABANDON
# 1###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
  When "APRES_CRE"  : Gosub APRES_CRE
# 2###########################  MODIFICACIÓN CONF. PEDIDOS 27/02/2020  ############################
  When "FIN"        : Gosub FIN
  When Default
Endcase
Return

