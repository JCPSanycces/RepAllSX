$ACTION

# Appel fonctions complémentaires GFI pour l'objet FRL
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Gosub ACTION From SPVOBJX1C

Return

######################################################################################
Subprog C_CREREQ(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M:X1C]CREITV(nolign-1)=2
  Affzo [M:X1C]CREITV(nolign-1)
Endif
End

######################################################################################
Subprog AS_CREITV(VALEUR)
Variable Integer VALEUR
If [M:X1C]CREREQ(nolign-1)=2
  VALEUR=2
  mkstat=2
Endif
End
