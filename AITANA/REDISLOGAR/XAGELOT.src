#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque SCHGAS0
#ACV#X13
#TIT#Gestion de l'action SCHSAILOT

#LBO 03/2003

Local Char PARAM(30)(1..16),VALEUR(10)

PARAM(1)=""
PARAM(2)=""
PARAM(3)=""
PARAM(4)=""
Call TRAITE_CHAR(VALEUR,PARAM,"SCHSAILOT","XAGELOT2","",1) From GTRAITE
End


#-----------------------------------------------------------------------
# Ecran SCHAGELOT [AGL1]
#-----------------------------------------------------------------------

#-------------------------
Subprog AS_VP1C(VALEUR)
Variable Char    VALEUR()
If [M:AGL1]NBLIG : mkstat=2 : Endif
End

#-------------------------
Subprog AS_VP2C(VALEUR)
Variable Char    VALEUR()
If [M:AGL1]NBLIG : mkstat=2 : Endif
End

#-------------------------
Subprog AS_VP3C(VALEUR)
Variable Char    VALEUR()
If [M:AGL1]NBLIG : mkstat=2 : Endif
End

#-------------------------
Subprog AS_CODICOC(VALEUR)
Variable Char    VALEUR()
If [M:AGL1]NBLIG : mkstat=2 : Endif
End

#-------------------------
Subprog AS_CODCOLC(VALEUR)
Variable Char    VALEUR()
If [M:AGL1]NBLIG : mkstat=2 : Endif
End

#-------------------------
Subprog AS_VP1(VALEUR)
Variable Char    VALEUR()
If [M:AGL1]VP1C<>""
  VALEUR=[M:AGL1]VP1C
  Call AM_VP1(VALEUR)
  If mkstat
    mkstat=0
  Else
    mkstat=2
  Endif
Endif
End

#-------------------------
Subprog AM_VP1(VALEUR)
Variable Char    VALEUR()
Call SPAM_VP(1,VALEUR)
End

Subprog SPAM_VP(ZNUM,VALEUR)
Value Integer ZNUM
Value Char    VALEUR()

Local Integer I
Local Char XVAR(50)

Case [L]ZNUM
  When 1 : Read [F:SHL]SHL1(2)=[V]GXPLAN;VALEUR
  When 2 : Read [F:SHL]SHL1(3)=[V]GXPLAN;[M:AGL1]VP1(nolign-1);VALEUR
  When 3 : Read [F:SHL]SHL1=[V]GXPLAN;[M:AGL1]VP1(nolign-1);[M:AGL1]VP2(nolign-1);VALEUR
Endcase
If !fstat
  [M:AGL1]SVPRUB(nolign-1)=[F:SHL]NUMSVP
  [M:AGL1]CODCHO(nolign-1)=[F:SHL]CODCHO
  For [L]I=1 To 9
    [L]XVAR="[M:AGL1]VS"+num$([L]I)+"(nolign-1)"
    If evalue([L]XVAR)<>evalue("[F:SHL]VS"+num$([L]I))
      Assign [L]XVAR With evalue("[F:SHL]VS"+num$([L]I))
      Affzo =[L]XVAR
    Endif
  Next
Else
  mkstat=1
Endif
End


#-------------------------
Subprog AS_VP2(VALEUR)
Variable Char    VALEUR()
If [M:AGL1]VP2C<>""
  VALEUR=[M:AGL1]VP2C
  Call AM_VP2(VALEUR)
  If mkstat
    mkstat=0
  Else
    mkstat=2
  Endif
Endif
End

#-------------------------
Subprog AM_VP2(VALEUR)
Variable Char    VALEUR()
Call SPAM_VP(2,VALEUR)
End


#-------------------------
Subprog AS_VP3(VALEUR)
Variable Char    VALEUR()
If [M:AGL1]VP3C<>""
  VALEUR=[M:AGL1]VP3C
  Call AM_VP3(VALEUR)
  If mkstat
    mkstat=0
  Else
    mkstat=2
  Endif
Endif
End

#-------------------------
Subprog AM_VP3(VALEUR)
Variable Char    VALEUR()
Call SPAM_VP(3,VALEUR)
End


#-------------------------
Subprog AV_VD1(VALEUR)
Variable Char    VALEUR()
Call SPAV_VD(1,VALEUR)
End

Subprog SPAV_VD(ZNUM,VALEUR)
Value Integer ZNUM
Variable Char    VALEUR()

Case [L]ZNUM
  When 1 : Read [F:SHL]SHL1(2)=[V]GXPLAN;[M:AGL1]VP1C
  When 2 : Read [F:SHL]SHL1(3)=[V]GXPLAN;[M:AGL1]VP1C;[M:AGL1]VP2C
  When 3 : Read [F:SHL]SHL1=[V]GXPLAN;[M:AGL1]VP1C;[M:AGL1]VP2C;[M:AGL1]VP3C
Endcase
If !fstat
  VALEUR=evalue("[F:SHL]VD"+num$([L]ZNUM))
Else
  VALEUR=""
Endif
End

#-------------------------
Subprog AV_VD2(VALEUR)
Variable Char    VALEUR()
Call SPAV_VD(2,VALEUR)
End

#-------------------------
Subprog AV_VD3(VALEUR)
Variable Char    VALEUR()
Call SPAV_VD(3,VALEUR)
End


#-------------------------
Subprog AS_CODICO(VALEUR)
Variable Char    VALEUR()
If [M:AGL1]CODICOC<>""
  VALEUR=[M:AGL1]CODICOC
  Call AM_CODICO(VALEUR)
  If mkstat
    mkstat=0
  Else
    mkstat=2
  Endif
Endif
End

#-------------------------
Subprog AS_CODCOL(VALEUR)
Variable Char    VALEUR()
If [M:AGL1]CODCOLC<>""
  VALEUR=[M:AGL1]CODCOLC
  Call C_CODCOL(VALEUR)
  If mkstat
    mkstat=0
  Else
    mkstat=2
  Endif
Endif
End

#-------------------------
Subprog IB_NBLIG
If [M:AGL1]REQNUM(nolign-1)=""
  [V]GBOUT1=""
Endif
If nolign>[M:AGL1]NBLIG
  [V]GBOUT2=""
Endif
End

#-------------------------
Subprog D_BEGDAT(VALEUR)
Variable Date    VALEUR
VALEUR=date$
End

#-------------------------
Subprog AS_BEGHOU(VALEUR)
Variable Char    VALEUR()
If [M]ICOTYP(nolign-1)=1 & [M]CODICO(nolign-1)<>""
  mkstat=2
Elsif VALEUR=""
  Read [F:SRC]SRC1=[F:SHP]PLANCOD;[M]CODCHO(nolign-1)
  If !fstat
    If [F:SRC]DAYTRA(dayn([M]BEGDAT(nolign-1))-1)=2
      VALEUR=[F:SRC]HDAM(dayn([M]BEGDAT(nolign-1))-1)
    Elsif [V]XMORBEG<>""
      VALEUR=ctrans([V]XMORBEG,":","")
    Endif
  Endif
Endif
End

#-------------------------
Subprog C_BEGHOU(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,".")
  mkstat=1 : End
Elsif VALEUR=""
  Read [F:SRC]SRC1=[F:SHP]PLANCOD;[M]CODCHO(nolign-1)
  If !fstat
    If [F:SRC]DAYTRA(dayn([M]BEGDAT(nolign-1))-1)=2 & [F:SRC]HDAM(dayn([M]BEGDAT(nolign-1))-1)<>""
      VALEUR=[F:SRC]HDAM(dayn([M]BEGDAT(nolign-1))-1)
    Elsif [V]XMORBEG<>""
      VALEUR=ctrans([V]XMORBEG,":","")
    Endif
  Endif
Endif
End


#-------------------------
Subprog D_ENDDAT(VALEUR)
Variable Date    VALEUR
VALEUR=[M:AGL1]BEGDAT(nolign-1)
End

#-------------------------
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:AGL1]BEGDAT(nolign-1)
  mkstat=1
Elsif [M:AGL1]CODICO(nolign-1)=""
  Gosub DEF_ICO From XAGELOT2
Endif
End

#-------------------------
Subprog AS_ENDHOU(VALEUR)
Variable Char    VALEUR()
If [M]ICOTYP(nolign-1)=1 & [M]CODICO(nolign-1)<>""
  mkstat=2
Elsif VALEUR=""
  Read [F:SRC]SRC1=[F:SHP]PLANCOD;[M]CODCHO(nolign-1)
  If !fstat
    If [F:SRC]DAYTRA(dayn([M]ENDDAT(nolign-1))-1)=2 & ([F:SRC]HFPM(dayn([M]ENDDAT(nolign-1))-1)>[M]BEGHOU(nolign-1) | [F:SHP]BEGDAT(nolign-1)<[M]ENDDAT(nolign-1))
      VALEUR=[F:SRC]HFPM(dayn([M]ENDDAT(nolign-1))-1)
    Else
      If [V]GXAFTEND<>"" & (ctrans([V]GXAFTEND,":","")>[M]BEGHOU(nolign-1) | [F:SHP]BEGDAT(nolign-1)<[M]ENDDAT(nolign-1))
        VALEUR=ctrans([V]GXAFTEND,":","")
      Endif
    Endif
  Endif
Endif
End


#-------------------------
Subprog C_ENDHOU(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,".") : mkstat=1 : End : Endif
If VALEUR=""
  Read [F:SRC]SRC1=[F:SHP]PLANCOD;[M]CODCHO(nolign-1)
  If !fstat
    If [F:SRC]DAYTRA(dayn([M]ENDDAT(nolign-1))-1)=2
&   & ([F:SRC]HFPM(dayn([M]ENDDAT(nolign-1))-1)>[M]BEGHOUJ(nolign-1) | [M]BEGDAT(nolign-1)<[M]ENDDAT(nolign-1))
      VALEUR=[F:SRC]HFPM(dayn([M]ENDDAT(nolign-1))-1)
    Else
      If [V]GXAFTEND<>"" & (ctrans([V]GXAFTEND,":","")>[M]BEGHOU(nolign-1) | [M]BEGDAT(nolign-1)<[M]ENDDAT(nolign-1))
        VALEUR=ctrans([V]GXAFTEND,":","")
      Else
        VALEUR="2359"
      Endif
    Endif
  Endif
Endif
End

#-------------------------
Subprog C_CODICO(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  If [F:SHP]SYNFLG=2
    [V]GMESSAGE=mess(10,123,1)
    mkstat=1
  Else
    Gosub DEF_ICO From XAGELOT2
  Endif
Endif
End

#-------------------------
Subprog AM_CODICO(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Filter [F:SHI] Where [F:SHI]PLANCOD=[V]GXPLAN & ([F:SHI]NUMSVP<>0 | [F:SHP]SYNFLG<>2) & [F:SHI]ICOSTA<=1
  Read [F:SHI]SHI0(2)=[V]GXPLAN;VALEUR
  If fstat
    [V]GMESSAGE=mess(23,100,1)
    mkstat=1
  Else
    [M:AGL1]SVPICO(nolign-1)=[F:SHI]NUMSVP
    [M:AGL1]ICOTYP(nolign-1)=[F:SHI]ICOTYP
    [M:AGL1]ICOWKD(nolign-1)=[F:SHI]ICOWKD
    Case [F:SHI]ICOTYP
      When 1 : # Jour
        [M]BEGHOU(nolign-1)="0000"
        [M]ENDHOU(nolign-1)="2359"
        Affzo BEGHOU(nolign-1), ENDHOU(nolign-1)
    Endcase
  Endif
  Filter [F:SHI]
Else
  Gosub DEF_ICO From XAGELOT2
Endif
End

#-------------------------
Subprog C_CODCOL(VALEUR)
Variable Char    VALEUR()
Filter [F:SHC] Where [F:SHC]PLANCOD=[V]GXPLAN & ([F:SHC]SYNFLG<2 | [F:SHP]SYNFLG<>2 | [F:SHC]NUMSVP<>0) & [F:SHC]COLSTA<=1
Read [F:SHC]SHC0(2)=[V]GXPLAN;VALEUR
If fstat
  # Ne devrait jamais se produire, contrôlé par type donnée
  [V]GMESSAGE=mess(23,100,1)
  mkstat=1
Else
  [M:AGL1]SVPCOL(nolign-1)=[F:SHC]NUMSVP
  [M:AGL1]OPECOD(nolign-1)=[F:SHC]OPECOD
  [M:AGL1]SYNFLG(nolign-1)=[F:SHC]SYNFLG
  Read [F:OPE]OPE0=[F:SHC]OPECOD
  If fstat : Raz [F:OPE] : Endif
Endif
Filter [F:SHC]
End

#-------------------------
Subprog AM_CODCOL(VALEUR)
Variable Char    VALEUR()
If [F:SHP]OPENOT<>""
  Raz [M:AGL1]COMMENT(nolign-1)
Endif
End

#-------------------------
Subprog D_COMMENT(VALEUR)
Variable Char    VALEUR()
If instr(1,[F:SHP]OPENOT,"OPEDES")
  Read [F:AXX]AXX0="OPERATION";"OPEDES";GLANGUE;[F:OPE]OPECOD;""
  If !fstat & [F:AXX]TEXTE<>""
    VALEUR=[F:AXX]TEXTE
  Endif
Elsif instr(1,[F:SHP]OPENOT,chr$(34)) | instr(1,[F:SHP]OPENOT,"'") | instr(1,[F:SHP]OPENOT,"[")
  Onerrgo PB_COMMENT
  VALEUR=num$(evalue([F:SHP]OPENOT))
  Onerrgo
Else
  VALEUR=[F:SHP]OPENOT
Endif
End

$PB_COMMENT
[V]GMESSAGE="Initialisation de la note"
[V]GMESSAGE+="\Pb évaluation expression"-[F:SHP]OPENOT
Call ECR_TRACE([V]GMESSAGE,1) From GESECRAN
End


#-------------------------
Subprog AV_ZDUR(VALEUR)
Variable Char    VALEUR()

Local Shortint XSTAT
Local Integer  ZDJDEB, ZDJFIN
Local Decimal  ZDUR, ZDUR2

Case [M]ICOTYP(nolign-1)
  When 1 : Call CAL_DURJOU([V]GXPLAN,[M]CODCHO(nolign-1),[M]BEGDAT(nolign-1),[M]ENDDAT(nolign-1),[M]ICOWKD(nolign-1),[F:SHP]UVYCOD
&                         ,[M]DURDAY(nolign-1),[M]DURHOU(nolign-1),[M]DURMIN(nolign-1)) From XSCHSAIEVT
           VALEUR=num$([M]DURDAY(nolign-1))-"Jr(s)"
  When 2 : Call INIT_HDJ([M]BEGDAT(nolign-1),[M]BEGHOU(nolign-1),[M]ENDDAT(nolign-1),[M]ENDHOU(nolign-1),[L]ZDJDEB,[L]ZDJFIN,[V]GXPLAN,[M]CODCHO(nolign-1),[L]XSTAT) From XSCHSAIEVT
           If ![L]XSTAT
             Call CAL_DURDJ([V]GXPLAN,[M]CODCHO(nolign-1),[M]BEGDAT(nolign-1),[L]ZDJDEB,[M]ENDDAT(nolign-1),[L]ZDJFIN,[M]ICOWKD(nolign-1),[F:SHP]UVYCOD
&                          ,[L]ZDUR,[M]DURHOU(nolign-1),[M]DURMIN(nolign-1)) From XSCHSAIEVT
             [M]DURDAY(nolign-1)=[L]ZDUR/2
             VALEUR=num$([M]DURDAY(nolign-1))-"Jr(s)"
           Else
             Raz [M]DURDAY(nolign-1),DURHOU(nolign-1),DURMIN(nolign-1),[L]VALEUR
           Endif
  When 3 : Call CAL_DURH([V]GXPLAN,[M]CODCHO(nolign-1),[M]BEGDAT(nolign-1),[M]BEGHOU(nolign-1),[M]ENDDAT(nolign-1)
&                       ,[M]ENDHOU(nolign-1),[M]ICOWKD(nolign-1),[F:SHP]UVYCOD,[L]ZDUR,[L]ZDUR2) From XSCHSAIEVT
           VALEUR=num$(ar2([L]ZDUR+[L]ZDUR2/60))-"Hr(s)"
Endcase

End
