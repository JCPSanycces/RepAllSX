#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################################################
$ACTION
Case ACTION
  When "ADDLIN"     : Gosub ADDLIN
Endcase
Return
#####################################################################################
# CODACT: YA021 - Observaciones de ventas en planificación de compras (Planning Global)
# CODACT: YA051 - Campo Semana en Planning Global
#####################################################################################
$ADDLIN
If clalev([F:ZSOQ])  <=0 : Local File SORDERQ    [ZSOQ]   : Endif
If !clalev([F:ZTXC])  Local File TEXCLOB  [ZTXC] Endif

If [M:MGB]VCRTYPORI(nolign-1) = 2  #'1742600576'

  Read [ZSOQ]SOQ0 = [M:MGB]VCRNUMORI(nolign-1);[M:MGB]VCRLINORI(nolign-1);[M:MGB]VCRLINORI(nolign-1)
  If fstat = 0
    If [F:ZSOQ]SOQTEX <> ''
      Read [F:ZTXC]TXC0 = [F:ZSOQ]SOQTEX
      If fstat = 0
        [M:MGB]YSOQTEX(nolign-1) = func F_RTF2TEXT([F:ZTXC]TEXTE)
      Endif
    Endif
  Endif
Endif

# YA022 - Mostrar precio de compra
If [M:MGB]WIPTYP (nolign-1) = 2 and [M:MGB]WIPSTA(nolign-1) = 3
  # Si el tipo orden es pedido de compra, y es sugerido
  Gosub OBTENER_TARIFA_COMPRA
Endif

# <YA051> - Campo Semana en Planning
If dim([M:MGB]YSEMREQDAT) > 0
  [M:MGB]YSEMREQDAT (nolign-1) = week ([M:MGB]REQDAT (nolign-1))
Endif
# </YA051>

Return
###########################################################################
# CODACT: YA021
###########################################################################
# Función para quitar el formato rtf del campo clob
Funprog F_RTF2TEXT(CLOB)
Variable Clbfile CLOB
  Local Integer LENTXMT : LENTXMT = 250
  Local Integer NRIGHE : NRIGHE = 4 # 4 = 250x4 char
  Local Char XOUT(LENTXMT)(NRIGHE)
  Call S_RTF2TEXT(LENTXMT,CLOB,XOUT,NRIGHE) From RTF2TEXT
  #Concatenate the row with plain text, by removing the empty space
  Local Char XRET(250) : Raz XRET
  For XI = 0 To NRIGHE
    XRET += vireblc(XOUT(XI),2)
  Next
End XRET
###########################################################################
# YA022 - Mostrar precio de compra
###########################################################################
$OBTENER_TARIFA_COMPRA

Local Decimal PRECIO

Gosub OUVRE_SAISPSI
Gosub DEBUT_SAISPSI
Gosub APPLIQUER
Gosub FIN_SAISPSI

[M:MGB]YPRICE(nolign-1) = PRECIO

Return

############################################################################
$OUVRE_SAISPSI

If clalev([M:POH0])=0 Local Mask POH0     [POH0] : Endif
If clalev([M:POH1])=0 Local Mask POH1     [POH1] : Endif
If clalev([M:POH2])=0 Local Mask POH2     [POH2] : Endif
If clalev([M:POH3])=0 Local Mask POH3     [POH3] : Endif

Default Mask [POH3]
Default Mask [POH2]
Default Mask [POH1]
Default Mask [POH0]

If clalev([F:BPR])=0 Local File BPARTNER   [BPR] : Endif
If clalev([F:BPS])=0 Local File BPSUPPLIER [BPS] : Endif
If clalev([F:MVS])=0 Local File BPSUPPMVT  [MVS] : Endif
If clalev([F:ITM])=0 Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITP])=0 Local File ITMBPS     [ITP] : Endif
If clalev([F:ITV])=0 Local File ITMMVT     [ITV] : Endif
If clalev([F:ITF])=0 Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITS])=0 Local File ITMSALES   [ITS] : Endif
If clalev([F:FCY])=0 Local File FACILITY   [FCY] : Endif
If clalev([F:TCU])=0 Local File TABCUR     [TCU] : Endif
If clalev([F:TVT])=0 Local File TABVAT     [TVT] : Endif
If clalev([F:TRA])=0 Local File TABRATVAT  [TRA] : Endif
If clalev([F:PRS])=0 Local File PRICSTRUCT [PRS] : Endif
If clalev([F:PPC])=0 Local File PPRICCONF  [PPC] : Endif
If clalev([F:PPF])=0 Local File PPRICFICH  [PPF] : Endif
If clalev([F:PPL])=0 Local File PPRICLIST  [PPL] : Endif
If clalev([F:PPK])=0 Local File PPRICLINK  [PPK] : Endif
If clalev([F:PFI])=0 Local File PFOOTINV   [PFI] : Endif
If clalev([F:AXX])=0 Local File ATEXTRA    [AXX] : Endif
If clalev([F:POH])=0 Local File PORDER     [POH] : Endif
If clalev([F:PPR])=0 Local File PPREASON   [PPR] : Endif

GPLISTC=""
Call COLREM("C",2,"") From TRTPRICE
Call TYPREM(2,"")     From TRTPRICE
Call TARIFCHGT(6)     From TRTPRICE
GFCY=GFCYDEF(6)
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
#Call GETDEV(GFCY)     From DEVSUB    : If GFINRSP="" GFINRSP=GFCY : Endif
If GFINRSP="" GFINRSP=GFCY : Endif
Call DEFRCPFCY(GFCY)  From TRTACHDEF1
Call GLOBVAR(GFCY)    From WWGLOBACH

Return
############################################################################
$DEBUT_SAISPSI
Return
############################################################################
$APPLIQUER

NOL = nolign

[M:POH0]BPSNUM = [M:MGB]BPRNUM(NOL-1)

[M:POH0]POHFCY = [M:MGB]FCY

[M:POH0]ORDDAT = [M:MGB]STRDAT(NOL-1)
#
[M:POH1]CHGCOE = 1
#
GFCY    = [M:MGB]FCY
GFINRSP = [M:MGB]FCY
#

nolign=1

[M:POH2]ITMREF(0)= [M:MGB]ITMREF(NOL-1)
[M:POH2]UOM(0)   = [M:MGB]STU(NOL-1)
[M:POH2]PUU(0)   = [M:MGB]STU(NOL-1)
[M:POH2]STU(0)   = [M:MGB]STU(NOL-1)
[M:POH2]QTYUOM(0) =[M:MGB]RMNEXTQTY(NOL-1)
[M:POH2]QTYPUU(0) = 1
[M:POH2]QTYSTU(0) = 1
[M:POH2]PRHFCY(0) = [M:MGB]FCY


Read [BPR] BPR0= [M:MGB]BPRNUM(NOL-1)


[M:POH0]LAN = [F:BPR]LAN

GCUR = [F:BPR]CUR

#----- Lecture BPSUPPLIER si nécessaire -----#
Read [BPS]BPS0= [M:MGB]BPRNUM(NOL-1)

[M:POH1]VACBPR = [F:BPS]VACBPR
[M:POH1]CHGTYP = [F:BPS]CHGTYP

#----- Chargement zones provenant du BPSUPPLIER -----#
If [F:BPS]BPRPAY="" [M:POH1]BPRPAY=[F:BPS]BPSNUM
                 Else [M:POH1]BPRPAY=[F:BPS]BPRPAY    : Endif
If [F:BPS]BPSINV="" [M:POH1]BPSINV=[F:BPS]BPSNUM
                 Else [M:POH1]BPSINV=[F:BPS]BPSINV    : Endif
[M:POH0]BPRNAM = [F:BPS]BPSNAM
[M:POH1]PTE    = [F:BPS]PTE
[M:POH1]MDL    = [F:BPS]MDL
[M:POH1]BPTNUM = [F:BPS]BPTNUM
[M:POH1]CHGTYP = [F:BPS]CHGTYP

#----- Chargement du régime taxe du fournisseur -----#
Call INIT_REGIME([M:POH0]BPSNUM,[M:POH0]POHFCY,"F",[M:POH1]VACBPR) From CPTSUB
#----- Chargement du cours devise -----#
Call COURSITE(GCUR,GFCY,[M:POH1]CHGTYP,[M:POH0]ORDDAT,[M:POH1]CHGCOE,GBIDI1) From TRTDEV
#----- Chargement formats frais-remises tarif -----#
Call FMTREM("POH2",GCUR) From TRTPRICE
#----- Conversion Mt mini commande et Mt encours autorisé -----#
If GSYSCUR<>GCUR
   Local Integer STAT
   Call CONVERT(GSYSCUR,GCUR,GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&               [F:BPS]ORDMINAMT,[M:POH2]ORDMINAMT,STAT) From TRTDEV
   Call CONVERT(GSYSCUR,GCUR,GLOCALDEV,[M:POH1]CHGTYP,[M:POH0]ORDDAT,
&               [F:BPS]OSTAUZAMT,[M:POH0]OSTAUZAMT,STAT) From TRTDEV
Else
   [M:POH2]ORDMINAMT=[F:BPS]ORDMINAMT
   [M:POH0]OSTAUZAMT=[F:BPS]OSTAUZAMT
Endif
#------ Chargement des éléments de facturation -----#
#Local Integer NBPOSTE : NBPOSTE=dim([M:POH3]SHO)
#Call SAISFOOT (3,"POH3",NBPOSTE,[M:POH1]CHGTYP,[F:BPR]CUR,GCUR,"SI") From TRTACHELT1
Call INIT_ELEMENTS (3,[M:POH1]CHGTYP,[F:BPS]CUR,GCUR) From TRTACHELT1
#[M:POH3]NBFAC=NBPOSTE
#----- Initialisation des sections analytiques -----#
If dim([M:POH1]NBAXE)>=0
  Local Char SECTION(GLONCCE)
  [M:POH1]NBAXE=GOPTCANA
  For I=1 To GOPTCANA
    GAXE=I : Call INISEC(SECTION,"POH",num$(I)) From SUBCDE
    [M:POH1]CCE(I-1)=SECTION
  Next I
Endif
#----- Lecture fichiers article, article-site et article-fourn si nécessaire -----#
Read [ITM] ITM0=[M:MGB]ITMREF(NOL-1)

Read [ITF] ITF0=[M:MGB]ITMREF(NOL-1);GFCY

Read [ITP] ITP0=[M:MGB]ITMREF(NOL-1);[F:BPS]BPSNUM

#---------------------------------------------------------------------------------#
If [F:ITM]BUY<>"" [M:POH2]LINBUY(0)=[F:ITM]BUY : Endif
If [F:ITF]BUY<>"" [M:POH2]LINBUY(0)=[F:ITF]BUY : Endif
[M:POH2]ITMDES(0)   =[F:ITM]ITMDES1
[M:POH2]STOMGTCOD(0)=[F:ITM]STOMGTCOD
If [F:ITF]QUAFLG>1 [M:POH2]QUAFLG(0)=2  Else [M:POH2]QUAFLG(0)=1 : Endif
If dim([M:POH2]TSICOD1(0))>0 [M:POH2]TSICOD1(0)=[F:ITM]TSICOD(0) : Endif
If dim([M:POH2]TSICOD2(0))>0 [M:POH2]TSICOD2(0)=[F:ITM]TSICOD(1) : Endif
If dim([M:POH2]TSICOD3(0))>0 [M:POH2]TSICOD3(0)=[F:ITM]TSICOD(2) : Endif
If dim([M:POH2]TSICOD4(0))>0 [M:POH2]TSICOD4(0)=[F:ITM]TSICOD(3) : Endif
If dim([M:POH2]TSICOD5(0))>0 [M:POH2]TSICOD5(0)=[F:ITM]TSICOD(4) : Endif
[M:POH2]PUU(0)     =[F:ITM]PUU
[M:POH2]STU(0)     =[F:ITM]STU
[M:POH2]LINTEX(0)  =""
If [F:ITP]PUU<>""      [M:POH2]PUU(0)      =[F:ITP]PUU          : Endif
If [F:ITP]ITMREF<>""   If [F:ITP]QUAFLG>1 [M:POH2]QUAFLG(0)=2
                                     Else [M:POH2]QUAFLG(0)=1   : Endif
                         [M:POH2]PURMINQTY(0)=[F:ITP]PURMINQTY    : Endif
If GACTDEB=2
   If [F:ITP]EECINCRAT<>0 [M:POH2]EECINCRAT(0)=[F:ITP]EECINCRAT : Endif
Endif
#----- Calcul des quantités UA et US -----#
Call PCAL_QTY([M:POH2]QTYUOM(0),[M:POH2]UOM(0),[M:POH2]QTYPUU(0),[M:POH2]PUU(0),
&             [M:POH2]ITMREF(0),[M:POH0]BPSNUM,1,GCOEUOM) From TRTACHQTE1
[M:POH2]UOMPUUCOE(0)=GCOEUOM
Call PCAL_QTY([M:POH2]QTYPUU(0),[M:POH2]PUU(0),[M:POH2]QTYSTU(0),[M:POH2]STU(0),
&             [M:POH2]ITMREF(0),[M:POH0]BPSNUM,1,GBIDD1)  From TRTACHQTE1
If [M:POH2]UOM(0)=[M:POH2]PUU(0)
  [M:POH2]UOMFLG(0)=1
Else
  [M:POH2]UOMFLG(0)=2
Endif
#----- Chargement des code taxes -----#
Local Char VAT(GLONVAT)(3) : Raz VAT
Call ALITAXE([M:POH1]VACBPR,[F:ITM]VACITM,VAT) From TRTX3
[M:POH2]VAT1(0)=VAT(0)
[M:POH2]VAT2(0)=VAT(1)
[M:POH2]VAT3(0)=VAT(2)
#----- Pour chargement des indicateurs inter-sites/inter-sociétés -----#
#GRCPFCY=[M:ZPR0]ZFCY
#Call CTRL_INTERSITE([M:POH0]POHFCY,[M:POH0]BPSNUM,2,[M:POH0]BETFCY,[M:POH0]BETCPY,
#&                   [M:POH0]SALFCY,[M:POH1]STOFCY,[M:POH0]BPCORD,[M:POH1]INVFCY,
#&                   [M:POH1]BPCINV,[M:POH0]DME) From TRTACHCTL1
#If mkstat  Raz mkstat : Endif
#----- Recherche du tarif (utilisation de la ligne 1 de l'écran commande POH2) -----#
[M:POH2]RETQTYSTU(0)=0 : [M:POH2]LINFLG(0)=0

GPUU=[M:POH2]PUU(0) : nolign=1 : Call RECH_TARIF ("POH",0) From TRTACHTAR1

# Precio menos descuento
PRECIO = [M:POH2]GROPRI(0) - (([M:POH2]DISCRGVAL1(0)*[M:POH2]GROPRI(0))/100)

nolign = NOL

Return
############################################################################
$FIN_SAISPSI
Default Mask [MGB]
Return

