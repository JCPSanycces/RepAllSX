#<AdxTL>@(#)8.0.0.0 $Revision$
#ACV#X11
#TIT#Gestion de l'écran VALGAS


################################################################################
Subprog AP_TSSITE(VALEUR)
Variable Integer  VALEUR
If VALEUR=2 Then
  If dim([M]ZFCYBEG)>0
    Effzo [M]ZFCYBEG
    Grizo [M]ZFCYBEG
  Endif
  Effzo [M]FCYBEG
  Grizo [M]FCYBEG
Else
  Actzo [M]FCYBEG
  If dim([M]ZFCYBEG)>0
    Actzo [M]ZFCYBEG
  Endif
Endif
End

########################################
Subprog AP_TSCODVAL(VALEUR)
Variable Integer  VALEUR
If VALEUR=2 Then
    Effzo [M]CODVALBEG
    Grizo [M]CODVALBEG
Else
    Actzo [M]CODVALBEG
Endif
End

########################################
Subprog AV_INITZON(VALEUR)
Variable Decimal  VALEUR
Call AP_TSTYPDOC([M]TSTYPDOC)
Call AP_TSCODVAL([M]TSCODVAL)
Call AP_TSSITE([M]TSSITE)
Call AP_TSSSTOFCY([M]TSSSTOFCY)
Call AP_TSSFINFCY([M]TSSFINFCY)
End


########################################
Subprog C_CODVALBEG(VALEUR)
Variable Char     VALEUR
If [M]TSCODVAL<>2 & VALEUR="" Then
    mkstat=2
Endif
End

########################################
Subprog AM_PCEDATBEG(VALEUR)
Variable Date    VALEUR
[M]PCEDATEND=VALEUR
End

########################################
Subprog AP_TSSFINFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2 Then
    Effzo [M]FINFCYBEG
    Grizo [M]FINFCYBEG
Else
    Actzo [M]FINFCYBEG
Endif
End

########################################
Subprog AP_TSSSTOFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2 Then
    Effzo [M]STOFCYBEG
    Grizo [M]STOFCYBEG
Else
    Actzo [M]STOFCYBEG
Endif
End

########################################
Subprog C_FLGGENDIFF(VALEUR)
Variable Integer VALEUR

If VALEUR = 2 Then
    If !clalev([F:ABT]) : Local File ABATTAC [ABT] : Endif
    Local Integer TROUVE

    [L]TROUVE = 0
    For [F:ABT]CODTAC Where [F:ABT]FONCTION = GFONCTION & [F:ABT]ENAFLG = 2
        [L]TROUVE = 1
        Break
    Next

    If ![L]TROUVE Then
        mkstat = 2
        GMESSAGE = mess(238,[V]GXMSGPSA,1)
    Endif
Endif

End

########################################
Subprog AV_FLGABTDIFF(VALEUR)
    Variable Integer  VALEUR
    If [M]FLGGENDIFF<>2
        VALEUR=1
        mkstat=2
    Endif
End

######################################################################################
Subprog AP_TSTYPDOC(VALEUR)
Variable Integer VALEUR
If VALEUR=2 Then
  Effzo [M]TYPDOCBEG
  Grizo [M]TYPDOCBEG
Else
  Actzo [M]TYPDOCBEG
Endif
End

######################################################################################
Subprog C_TYPDOCBEG(VALEUR)
Variable Char    VALEUR()
If [M]TSTYPDOC<>2 & VALEUR=""
  mkstat=2
Endif
End

######################################################################################
Subprog AS_CODVALBEG(VALEUR)
Variable Char    VALEUR()
[V]GBIDC1="1"
If [M]TYPDOCBEG<>""
  [V]GBIDC1="[F:PV1]TYPDOC='"+[M]TYPDOCBEG+"'"
Endif
End
