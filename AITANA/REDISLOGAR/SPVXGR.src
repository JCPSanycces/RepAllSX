######################################################################################
$ACTION
Gosub ACTION From SPVOBJXGR
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran XGRPUSR) 27/04/2011 15:34:47 (GPELE)
######################################################################################
Subprog IB_XNBGRP
    Local Integer PEUTSUP

    # Affichage clic droit "Creer sous-groupe"
    If [M:XGR]XRUBRIQUE=2 : Raz GBOUT5 : Else : GBOUT5="Création sous-groupe" : Endif

    # Affichage clic droit "Suppression"
    If !clalev ([F:XXGR]) : Local File XGRPUSR [XXGR] : Endif
    [L]PEUTSUP = 2
    For [F:XXGR] Where [F:XXGR]XCODEP=[M:XGR]XCODE
        [L]PEUTSUP = 0 : Break
    Next
    If [L]PEUTSUP : GBOUT7="Suppression" : Else : Raz GBOUT7 : Endif

    # Si on vient en tunnel depuis les utilisateur pour ajouter un nouveau groupe a l utilisateur en cours
#    If GNAVIG(GPILNAV-1) = "GESAUS"
     If find(GNAVIG(GPILNAV),"GESAUS","GESOPR","GESFNE")
        Raz GBOUT5, GBOUT7, GBOUT6

        If [M:XGR]XALLOUE(nolign-1) = 2
            Raz GBOUT8
        Else
            # NSARK : On garde tout le temps le bouton supprimer alloc
            Raz GBOUT9
        Endif
    Else
        Raz GBOUT8, GBOUT9
    Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran XGRPUSR) 27/04/2011 16:29:33 (GPELE)
######################################################################################
Subprog AV_XNBGRP

    If !clalev([XXGR]) : Local File XGRPUSR [XXGR] : Endif


    # Si on est sur un element de dernier niveau on affiche les elements details
    Read [F:XXGR]XGR0 = [M:XGR]XCLE(nolign-1)
    If !fstat
        If [F:XXGR]XRUBRIQUE = 2
            [M:XGR]XALPHA1   = [F:XXGR]XALPHA1D
            If [F:XXGR]XALPHA1I <> "" : Chgtzn[M:XGR]XALPHA1 With [F:XXGR]XALPHA1I
            Else                      : Chgtzn[M:XGR]XALPHA1 With "Non renseigné" : Endif

            [M:XGR]XALPHA2   = [F:XXGR]XALPHA2D
            If [F:XXGR]XALPHA2I <> "" : Chgtzn[M:XGR]XALPHA2 With [F:XXGR]XALPHA2I
            Else                      : Chgtzn[M:XGR]XALPHA2 With "Non renseigné" : Endif

            [M:XGR]XNUM1     = [F:XXGR]XNUM1D
            If [F:XXGR]XNUM1I<> "" : Chgtzn[M:XGR]XNUM1   With [F:XXGR]XNUM1I
            Else                   : Chgtzn[M:XGR]XNUM1   With "Non renseigné" : Endif

            [M:XGR]XNUM2     = [F:XXGR]XNUM2D
            If [F:XXGR]XNUM2I <> "" : Chgtzn[M:XGR]XNUM2   With [F:XXGR]XNUM2I
            Else                    : Chgtzn[M:XGR]XNUM2   With "Non renseigné" : Endif

            [M:XGR]XDATE1    = [F:XXGR]XDATE1D
            If [F:XXGR]XDATE1I <> "" : Chgtzn[M:XGR]XDATE1  With [F:XXGR]XDATE1I
            Else                     : Chgtzn[M:XGR]XDATE1  With "Non renseigné" : Endif

            [M:XGR]XDATE2    = [F:XXGR]XDATE2D
            If [F:XXGR]XDATE2I <> "" : Chgtzn[M:XGR]XDATE2  With [F:XXGR]XDATE2I
            Else                     : Chgtzn[M:XGR]XDATE2  With "Non renseigné" : Endif

            [M:XGR]XRUBRIQUE = 2

            Affzo [M:XGR]XALPHA1 : Affzo [M:XGR]XALPHA2
            Affzo [M:XGR]XNUM1   : Affzo [M:XGR]XNUM2
            Affzo [M:XGR]XDATE1  : Affzo [M:XGR]XDATE2

            #If [M:XGR]XALPHA1="" & [M:XGR]XALPHA2="" & [M:XGR]XNUM1=0 & [M:XGR]XNUM2=0 & [M:XGR]XDATE1=[00/00/0000] & [M:XGR]XDATE2=[00/00/0000]
            #    Grizo [M:XGR]XICODEF
            #Endif
        Else
            Raz [M:XGR]XALPHA1   : Chgtzn[M:XGR]XALPHA1 With [F:XXGR]XALPHA1I
            Raz [M:XGR]XALPHA2   : Chgtzn[M:XGR]XALPHA2 With [F:XXGR]XALPHA2I
            Raz [M:XGR]XNUM1     : Chgtzn[M:XGR]XNUM1   With [F:XXGR]XNUM1I
            Raz [M:XGR]XNUM2     : Chgtzn[M:XGR]XNUM2   With [F:XXGR]XNUM2I
            Raz [M:XGR]XDATE1    : Chgtzn[M:XGR]XDATE1  With [F:XXGR]XDATE1I
            Raz [M:XGR]XDATE2    : Chgtzn[M:XGR]XDATE2  With [F:XXGR]XDATE2I
            Raz [M:XGR]XRUBRIQUE

            Affzo [M:XGR]XALPHA1 : Affzo [M:XGR]XALPHA2
            Affzo [M:XGR]XNUM1   : Affzo [M:XGR]XNUM2
            Affzo [M:XGR]XDATE1  : Affzo [M:XGR]XDATE2

        Endif
        [M:XGR]XCODE = [F:XXGR]XCODE : Diszo [M:XGR]XCODE : Affzo [M:XGR]XCODE

    Endif

End


#####################################################################################
## Etiquette ajoutée par le superviseur (écran XGRPUSR) 28/04/2011 16:59:42 (GPELE)
######################################################################################
# Pour memoriser les valeur et les rafficher quand on passe en modif et que le std remet l enreg de la liste
# gauche dans la partie droite
Subprog AM_XALPHA1(VALEUR)
Variable Char    VALEUR()
    Call MEMO_VAL(VALEUR,[M:XGR]XALPHA2,[M:XGR]XNUM1,[M:XGR]XNUM2,[M:XGR]XDATE1,[M:XGR]XDATE2,nolign) From SPVOBJXGR
End

Subprog AM_XALPHA2(VALEUR)
Variable Char    VALEUR()
    Call MEMO_VAL(XALPHA1,VALEUR,[M:XGR]XNUM1,[M:XGR]XNUM2,[M:XGR]XDATE1,[M:XGR]XDATE2,nolign) From SPVOBJXGR
End

Subprog AM_XNUM1(VALEUR)
Variable Decimal VALEUR
    Call MEMO_VAL(XALPHA1,[M:XGR]XALPHA2,VALEUR,[M:XGR]XNUM2,[M:XGR]XDATE1,[M:XGR]XDATE2,nolign) From SPVOBJXGR
End

Subprog AM_XNUM2(VALEUR)
Variable Decimal VALEUR
    Call MEMO_VAL(XALPHA1,[M:XGR]XALPHA2,[M:XGR]XNUM1,VALEUR,[M:XGR]XDATE1,[M:XGR]XDATE2,nolign) From SPVOBJXGR
End

Subprog AM_XDATE1(VALEUR)
Variable Date    VALEUR
    Call MEMO_VAL(XALPHA1,[M:XGR]XALPHA2,[M:XGR]XNUM1,[M:XGR]XNUM2,VALEUR,[M:XGR]XDATE2,nolign)  From SPVOBJXGR
End

Subprog AM_XDATE2(VALEUR)
Variable Date    VALEUR
    Call MEMO_VAL(XALPHA1,[M:XGR]XALPHA2,[M:XGR]XNUM1,[M:XGR]XNUM2,[M:XGR]XDATE1,VALEUR,nolign)  From SPVOBJXGR
End
