#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# SUBSQHB : GESTION DES DEVIS                         EB - MARS     1998#
#########################################################################
#                                                                       #
# Etiquettes appelées par SUBSQH                                        #
#                                                                       #
#  $TEST_INS       : Test d'insertion d'une ligne de devis              #
#  $TEST_ANU       : Test de suppression d'une ligne de devis           #
#  $TEST_MOD       : Test de modification d'une ligne de devis          #
#  $CTR_QTY        : Contrôle qtée cdée avec qtée mini et maxi          #
#  $VERIF_LIGNE    : Vérification lignes devis (recherche interdit      #
#  $RECALC_LIGNE   : Recalcul lignes devis                              #
#  $CONV_LIGNE     : Conversion des montants ligne                      #
#  $RECALC_TOT     : Recalcul des totaux                                #
#  $RECALC_TARIF   : Recalcul des tarifs                                #
#  $TRTGRA         : Traitement des gratuits                            #
#  $CONV_INVDTAAMT : Conversion des mnts de facturation si chgmt devise #
#  $VERIF_LIGNE_ITF: Vérif.existence article-site pr le tableau SQH2    #
#                                                                       #
# Etiquettes appelées par SUBSQHA                                       #
#                                                                       #
#  $RECALC_GROUPE : Recalcul des lignes suite à tarif groupé            #
#  $MAJADRESSE    : Mise à jour de l'adresse                            #
#  $CHARGE_ADRBPC : Chargement de l'adresse                             #
#  $CHARGE_ADRBPD : Chargement de l'adresse livraison                   #
#  $MAJSTASQH     : Recalcul de l'etat du devis                         #
#                                                                       #
# Traitements communs                                                   #
#                                                                       #
#  Subprog LECT_FIC(NLIG)                                               #
#       Lecture de tous les fichiers utiles à une ligne                 #
#  Subprog INIT_SQH(NLIG)                                               #
#       Init. des zones détails venant de l'entête                      #
#  Subprog INIT_ITM(NLIG, ITMREF)                                       #
#       Init. des zones détails venant de l'article                     #
#  Subprog VERIF_VATCOD(NLIG)                                           #
#       Vérification des codes taxes                                    #
#  Subprog APRES_LIGNE(NLIG, AFF)                                       #
#       Traitement d'apres lignes                                       #
#  Subprog ADD_TOT(NLIG, AFF)                                           #
#       Calcul des montants total de la commande en +                   #
#  Subprog SUB_TOT(NLIG, AFF)                                           #
#       Calcul des montants total de la commande en -                   #
#  Subprog SUP_LIG(NLIG)                                                #
#       Suppression d'une ligne dans le tableau                         #
#  Subprog ALIQUO(VALEUR)                                               #
#       Alimentation des masques SQH à partir du client                 #
#                                                                       #
#  $CALC_QUO     : Calcul mnts ht et ttc d'une ligne devis              #
#                                                                       #
#########################################################################
#---------------------------#
# Test d'insertion de ligne #
#---------------------------#
$TEST_INS
If GREP="D"
# --> Ctrl particulier en dupli. pour l'euro : vérifier que ce n'est pas une devise "in"
    Call CONTDEV([M:SQH1]CUR,[M:SQH0]QUODAT) From TRTDEV
    If mkstat=2 Return Endif
Endif
If    [M:SQH1]STOFCY="" GMESSAGE = mess(174,192,1) : mkstat=2 : Return : Endif
If    [M:SQH1]VACBPR="" GMESSAGE = mess(263,192,1) : mkstat=2 : Return : Endif
#If    [M:SQH3]PTE=""    GMESSAGE = mess(264,192,1) : mkstat=2 : Return : Endif
# --> pas d'insertion si composant
If   ([M:SQH2]LINTYP(NOL)>2 & [M:SQH2]LINTYP(NOL)<=5) | ([M:SQH2]LINTYP(NOL)>10 & [M:SQH2]LINTYP(NOL)<=13)
      GMESSAGE = mess(97,192,1) : mkstat=2
Endif
If    [M:SQH2]LINTYP(NOL) > 6 & [M:SQH2]LINTYP(NOL) <=9
      GMESSAGE = mess(97,192,1) : mkstat=2
Endif
# --> pas d'insertion si gratuit
If    [M:SQH2]FOCFLG(NOL) = 3
      GMESSAGE = mess(98,192,1) : mkstat=2
Endif
Return

#------------------------------#
# Test de suppression de ligne #
#------------------------------#
$TEST_ANU
# --> pas de suppression si ligne passée en commande
If    [M:SQH2]DSOHNUM(NOL) <> ""
      GMESSAGE = mess(38,192,1) : mkstat=2
Endif
# --> pas de suppression sur un composant kit/sous-traité
If  ([M:SQH2]LINTYP(NOL)>2 & [M:SQH2]LINTYP(NOL)<=5) | ([M:SQH2]LINTYP(NOL)>10 & [M:SQH2]LINTYP(NOL)<=13)
     GMESSAGE = mess(26,192,1) : mkstat=2
Endif
# --> Pas de Suppression multiple s'il y a des composants de nomenclatures
If status = 83 & find([M]LINTYP(NOL),7,8,9)
   GMESSAGE = mess(172,192,1) : mkstat=2 : Return
Endif
# --> Pas de Suppression multiple s'il y a des gratuits
If status = 83 & [M]FOCFLG(NOL) = 3
    GMESSAGE = mess(172,192,1) : mkstat=2 : Return
Endif
Return

#-------------------------------#
# Test de modification de ligne #
#-------------------------------#
$TEST_MOD
NOL=nolign-1

# --> pas de modification si ligne passée en commande
If    [M:SQH2]DSOHNUM(NOL) <> ""
      GMESSAGE = mess(38,192,1) : mkstat=2
Endif
# --> pas de modification sur un composant kit
If   ([M:SQH2]LINTYP(NOL)>2 & [M:SQH2]LINTYP(NOL)<=5)
# --> Test pour ne pas avoir le message en creation !
      If [M:SQH2]CREFLG(NOL) <> 0 GMESSAGE = mess(26,192,1) Endif
      mkstat=2
Endif
Return

#----------------------------------------#
# Contrôle qte avec qte mini et qte maxi #
#----------------------------------------#
$CTR_QTY
Local    Decimal QTY_UV

If [M:SQH2]SAU(NOL) <> [F:ITM]SAU
     Call SCAL_QUV(VALEUR,[M]ITMREF(NOL),[M]BPCORD,[M]SAU(NOL),[F:ITM]SAU,QTY_UV,GBIDD1) From TRTVENQTE
Else
     QTY_UV = VALEUR
Endif

# --> Controle qte commandée >= a la qte minimale
If QTY_UV < [F:ITS]MINQTY & [F:ITS]MINQTY > 0
    GMESSAGE = sum(mess(12,192,1), format$("N:11.4[ ]", num$([F:ITS]MINQTY)), [F:ITM]SAU)
    If GDACLOK = 1 mkstat=2 : Return
    Else           GERR=2 : Endif
Endif

# --> Controle qte cdee <= a la qte maximale
If QTY_UV > [F:ITS]MAXQTY & [F:ITS]MAXQTY > 0
    If GERR=2 GMESSAGE += "\" Endif
    GMESSAGE += sum(mess(13,192,1), format$("N:"+GFMTQTY, num$([F:ITS]MAXQTY)), " ", [F:ITM]SAU)
    If GDACLOK = 1 mkstat=2
    Else           GERR=2 : Endif
Endif
Return

# 79705 : SAT in SPRICLINK : Step 2
#-------------------------------------------------------------------------------------#
# Etiquette de recherche des interdits pour un devis                                  #
#-------------------------------------------------------------------------------------#
# Déclenchée suite à modification de l'addresse de liv de l'entête                    #
# Avec répercussion sur les lignes détails                                            #
#                                                                                     #
# Appelée par l'action de répercussion TRTMAJDET avant lancement de la répercussion   #
# TRTMAJDET est appelée en am_modif BPAADD                                            #
#                                                                                     #
# Si interdit alors Refus de la repercussion si SDACLOK=1, Avertissement si SDACLOK=2 #
#                                                                                     #
#      FFLGMOD = 1            : Modification de la zone détail                        #
#      FFLGMOD = 3            : Comparaison et modification de la zone détail         #
#      FFLGMOD = "",2         : Sur BPAADD, Répercution forcée car GLINREP=1          #
#-------------------------------------------------------------------------------------#
$VERIF_LIGNES
Local Char     NOMD, NOME
Local Integer  NLIG
Local Char     WREP(GLONREP), WBPAADD (GLONBPD)
Local Integer  WOK

Local Integer  SAVNOLIGN : SAVNOLIGN=nolign

Raz NLIG
While NLIG < [M:SQH2]NBLIG
    If FFLGMOD <> ""
        NOME = WZONCOU
        If NOME <> "REP"
           NOMD = sum ("D", NOME)
        Else
           WIND  = indice
           NOMD = sum(NOME, num$(WIND+1))
           NOME = sum(NOME, "(", num$(WIND), ")")
        Endif
        Gosub VERIF_ZON
    Endif
    NLIG+=1
Wend
If GERR=1 mkstat=2 Endif

nolign=SAVNOLIGN

Return

#-------------------------------------#
# Vérification de la zone détail      #
#-------------------------------------#
$VERIF_ZON

#--- Comparaison zone entête/zone détail
If FFLGMOD="3"
  If evalue("dim([M:SQH2]"+NOMD+"(NLIG))") >0 & evalue("dim([M]"+NOME+")") >0
     If evalue("[M:SQH2]"+NOMD+"(NLIG)") <> evalue("[M]"+NOME) : Return : Endif
  Endif
Endif

# --- Modification de l'adresse de livraison
If NOME = "BPAADD"
    # Recherche interdit suite modification de l'adresse
    If dim([M:SQH2]REP1(NLIG)) > 0
      WREP=[M:SQH2]REP1(NLIG)
      If GLINREP=2
          # Alimentation des représentants s'ils n'ont pas été alimentés par le client commande
          If [F:BPC]BPCNUM <> [M:SQH0]BPCORD
              Read [BPC]BPC0 = [M:SQH0]BPCORD
              If fstat <> 0 Raz [F:BPC] : Endif
          Endif
          # Alimentation du 1er représentant
          If [F:BPC]REP(0) = ""
              WREP= [F:BPD]REP(0)
          Endif
      Endif
    Endif
    WBPAADD=[M:SQH2]DBPAADD(NLIG)
    [M:SQH2]DBPAADD(NLIG)=VALEUR  : # Il faut affecter le champ pour que la recherche interdit ait la bonne valeur
    nolign=NLIG+1                 : # La recherche interdit utilise nolign
    Call RECH_INTERDIT ([M:SQH2]ITMREF(NLIG), VALEUR, WREP, 1) From TRTVENTAR
    If mkstat=2
      GERR=1 : GMESSAGE=[M:SQH2]ITMREF(NLIG)-":"-GMESSAGE
      If GTRACE <> "" Call ECR_TRACE(GMESSAGE, 0) From GESECRAN Endif
      mkstat=0 : Raz GMESSAGE
    Endif
    [M:SQH2]DBPAADD(NLIG)=WBPAADD : # Recherche terminée : Réaffectation de la valeur
Endif

Return
# 79705 : SAT IN SPRICLINK : Step 2

#------------------------------------------------------------------------------#
#     Recalcul des lignes de devis                                             #
#------------------------------------------------------------------------------#
# Appelé en am_modif : Devise, Régime, Type prix,                              #
#                      Représ., Demdlvdat, Daylti,                             #
#                      Adr livraison si GLINBPD = 1                            #
#  --> Si dde Recherche tarif : GTARFLG= "1"                                   #
#  --> Si modif.régime        : Recalc. prix, marge, totaux                    #
#  --> Si modif.type prix     : Bascule prix                                   #
#  --> Si modif.devise        : Conversion des montants                        #
#  --> Si modif.des zones entêtes reportées dans les zones détails             #
#      FFLGMOD = 1            : Modification de la zone détail                 #
#      FFLGMOD = 3            : Comparaison et modification de la zone détail  #
#      FFLGMOD = "",2         : Sur BPAADD, Répercution forcée car GLINREP=1   #
#  --> Appelé en dupplication d'un devis avec changement du client             #
#------------------------------------------------------------------------------#
$RECALC_LIGNE

Local Integer  NLIG, WIND
Local Char     NOME, NOMD
Local Char     WFLGTOT(1): WFLGTOT="N"
Local Integer  INICPRPRI : INICPRPRI=1
Local Char     WVACITM(GLONTVI)(3), WREP(GLONREP)
Local Char     VAT(GLONVAT)(3)
Raz WFLGTOT

#- X3Suivi 76514 --#
If GTARFLG="1" | [M:SQH1]CUR<>WANCCUR | [M:SQH1]VACBPR<>WANCVACBPR | WZONCOU="BPCORD" |(GACTION='TRTMAJDET' & PARAM(1)='SQH' & PARAM(2)='STOFCY' )
    Raz [M]QUONOT,QUOATI,PFMTOT
    Raz [M:SQH0]DSPTOTQTY,DSPTOTVOL,DSPTOTWEI       :#--CPO 80622 Il faut refaire les totaux
Endif

#--------------------------------- #
# Modification des lignes détails  #
#--------------------------------- #
Raz NLIG
While NLIG < [M:SQH2]NBLIG
  If [M:SQH2]DLVFLG(NLIG)<>1 or !find(WZONCOU,"DAYLTI")  # 107890 : Scheduled invoices : (LC:18/11/16)
    If FFLGMOD <> ""
        NOME = WZONCOU
        If NOME <> "REP"
            NOMD = sum ("D", NOME)
        Else
            WIND  = indice
            NOMD = sum(NOME, num$(WIND+1))
            NOME = sum(NOME, "(", num$(WIND), ")")
        Endif
        If FFLGMOD  = "3" Gosub COMP_ZON Endif
        If FFLGMOD <> "3" Gosub MOD_ZON  Endif
    Endif
#    If find(WZONCOU, "BPAADD", "REP")
#        If WZONCOU = "BPAADD"
#            NOMD = sum("D", WZONCOU)
#            If evalue ("dim([M:SQH2]"+NOMD+"(NLIG))")>0
#                Assign "[M:SQH2]"+NOMD+"(NLIG)" With VALEUR
#            Endif
#        Else
#            NOMD = sum(WZONCOU, num$(indice+1))
#            If evalue ("dim([M:SQH2]"+NOMD+"(NLIG))")>0
#                Assign "[M:SQH2]"+NOMD+"(NLIG)" With VALEUR
#                Assign ("[M:SQH2]REPRAT"+num$(indice+1)+"(NLIG)") With 0
#                If VALEUR <> ""
#                    If [F:REP]REPNUM <> VALEUR
#                        Read [F:REP]REP0 = VALEUR
#                        If fstat Raz [F:REP] : Endif
#                    Endif
#                    If [F:BPC]BPCNUM<>[M:SQH0]BPCORD
#                        Read [F:BPC]BPC0=[M:SQH0]BPCORD
#                        If fstat : Raz [F:BPC] : Endif
#                    Endif
#                    If [F:BPC]COMCAT <> 0
#                        Assign ("[M:SQH2]REPRAT"+num$(indice+1)+"(NLIG)") With evalue("[F:REP]COMRAT"+num$(indice+1)+"([F:BPC]COMCAT-1)")
#                    Endif
#                Endif
#            Endif
#        Endif
    If WZONCOU = "BPCORD"
        Gosub REINIT_LIGNE : If mkstat=2 Break : Endif
    Endif
    If GTARFLG="1" | [M:SQH1]CUR <> WANCCUR | [M:SQH1]VACBPR <> WANCVACBPR |
&                    [M:SQH1]PRITYP <> WANCPRITYP
        Call LECT_FIC(NLIG)
#   --> Modification du régime de taxe : Réalimentation des codes taxes
        If [M:SQH1]VACBPR <> WANCVACBPR
            #WVACITM(0) = [M]VACITM1(NLIG)
            #WVACITM(1) = [M]VACITM2(NLIG)
            #WVACITM(2) = [M]VACITM3(NLIG)
            #Call ALITAXEV([M:SQH1]VACBPR,WVACITM,VAT) From TRTX3
            Call RECHVATCOD(1,1,[M:SQH0]BPCORD,[M:SQH2]ITMREF(NLIG),"SQH2",NLIG,VAT) From TRTX3
            [M]VAT1(NLIG) = VAT(0)
            [M]VAT2(NLIG) = VAT(1)
            [M]VAT3(NLIG) = VAT(2)
        Endif
#       --> Recherche tarif
        If GTARFLG = "1"
            Gosub RECALC_TARIF
        Else
#           --> Modification de la devise     : Conversion des montants + recalcul totaux
            If [M:SQH1]CUR <> WANCCUR
                Gosub CONV_LIGNE
                WFLGTOT = "O"
            Endif
#           --> Modif. regime de taxe         : Recalcul des prix, de la marge et des totaux
                If [M:SQH1]VACBPR <> WANCVACBPR
                    WFLGTOT="O"
                Endif
#           --> Modification du type de prix  : Bascule des prix HT et TTC
            If [M:SQH1]PRITYP <> WANCPRITYP
                If [M:SQH1]PRITYP = 1
                    [M]NETPRI(NLIG) = [M]NETPRINOT(NLIG)
                Else
                    [M]NETPRI(NLIG) = [M]NETPRIATI(NLIG)
                Endif
#                WFLGTOT = "N"
            Endif
        Endif
    Endif
#   --> Nécessité de refaire les totaux
    If WFLGTOT="O"  Gosub RECALC_TOT Endif
    [M]UPDFLG(NLIG) = 1
  Endif  # 107890 : Scheduled invoices : (LC:18/11/16)
  NLIG+=1
Wend
If mkstat=2 Return Endif

# 101874 : V9 : Taxe code control
#If dim(GVALTTCSQH)>0 & dim(GVALTTC)>0 : GVALTTC=GVALTTCSQH : Endif
#If !GIMPORT : Call VALTTC ("GESSQH") From TRTVENFACR : Endif
If !GIMPORT
    # Valuation is always done in this case
    GVALTTC=2
    #---- Paramètres complementaires appel valorisation
    # PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
    # PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non/2=Oui)
    # PARAM_T(2) : Flag retour                         (1=KO/2=OK)
    Local    Char     PARAM_T (25) (0..10)
    PARAM_T(0)="1"      : # Pas de contrôle des taxes
    PARAM_T(1)="1"      : # Pas de lecture de la trace
    PARAM_T(2)="0"
    Call VALTTC ("GESSQH", PARAM_T) From TRTVENFACR
    If PARAM_T(2)="1" mkstat=2 : Return Endif
Endif
# 101874

Affzo [M:SQH2]5,10,15,20

Return

#------------------------------------------------------#
# Reinitialisation d'une ligne lors d'une dupplication #
#------------------------------------------------------#
$REINIT_LIGNE
Local Char    WSTOFCY(GLONFCY)

nolign=NLIG+1
WSTOFCY=[M:SQH2]DSTOFCY(NLIG)
Call INIT_SQH (NLIG)
# On vérifie au moins que l'article n'est pas interdit
If dim([M]REP1(NLIG)) > 0 WREP = [M]REP1(NLIG) : Endif
[M:SQH0]BPCORD=VALEUR
Call RECH_INTERDIT ([M]ITMREF(NLIG), [M]DBPAADD(NLIG), WREP, 1) From TRTVENTAR
If mkstat = 2
    GMESSAGE = [M]ITMREF(NLIG)-" : "-GMESSAGE
    GMESSAGE += "\" + mess(206,192,1)
    Return
Endif

# 102681 : Duplication devis avec changement de client
# --> Réinitialisation ligne devis à partir de la fiche article-client
Gosub REINIT_ITU
# 102681

# On recherche la désignation traduite si le client a changé de langue
If WANCLAN<>[M:SQH0]LAN
    Call CHARGE_ITMDES("DES1AXX",[M:SQH0]LAN,[F:ITM]ITMREF,[M:SQH2]ITMDES(NLIG)) From TRTX3   # FGR 29/06/2009 : X3SUIVI56129 : celui-là reste comme ça
    If [M:SQH2]ITMDES(NLIG) = "" [M:SQH2]ITMDES(NLIG) = [M:SQH2]ITMDES1(NLIG) Endif
Endif

# 102681 : Duplication devis avec changement de client
# Le client a changé : On recharge les textes du nouveau client
#If find(GSALTEXLIN,1,5) & find(left$([M:SQH2]SQDTEX(NLIG),3),"ITS","ITU")
If find(GSALTEXLIN,1,5)
    If [F:ITU]ITMREF<>[M:SQH2]ITMREF (NLIG) | [F:ITU]BPCNUM<>[M:SQH0]BPCORD
        Read [F:ITU]ITU0 = [M:SQH2]ITMREF (NLIG);[M:SQH0]BPCORD
        If fstat  Raz [F:ITU] : Endif
    Endif
    If [F:ITU]ITSTEX <> ""
       # Récup du texte article du nouveau client s'il existe
       [M:SQH2]SQDTEX(NLIG) = [F:ITU]ITSTEX
    Elsif left$([M:SQH2]SQDTEX(NLIG),3)="ITU"
       # Ecrasement texte article ancien client
       [M:SQH2]SQDTEX(NLIG) = [F:ITS]ITSTEX
    Endif
Endif
# 102681 : Duplication devis avec changement de client

# Changement de site : il faudra reinitialiser le prix de revient
If WSTOFCY <> [M:SQH2]DSTOFCY(NLIG) INICPRPRI=2 Endif
# 89275 : Duplication cde et ctrl des prix
# Faire un ctrl prix si pas de recherche tarif et si nécessaire
Raz GNETMAR
If GREP= "D" & WZONCOU= "BPCORD" & GTARFLG<>"1" & GDACLOK=1
  GNETMAR=1
  # --> Ctrl prix net
  Call CTLNETPRI([M:SQH0]BPCORD, [M]CHGTYP, [M]QUODAT, [M:SQH0]CUR,NLIG) From TRTVENPRI
  Raz GNETMAR : Raz GMESSAGE
Endif
# 89275
[M]UPDFLG(NLIG)=1
If GTARFLG <> "1" WFLGTOT="O" Endif
Return

# 102681 : Duplication devis avec changement de client
#  --------------------------------------------------------------------  #
#  Réinitialisation ligne devis à partir de la fiche article-client  #
#  --------------------------------------------------------------------- #
$REINIT_ITU

If [F:ITM]ITMREF <> [M:SQH2]ITMREF(NLIG)
   Read [ITM] ITM0=[M:SQH2]ITMREF(NLIG)
   If fstat Raz [F:ITM] Endif
Endif
If [F:ITU]ITMREF <> [M:SQH2]ITMREF(NLIG) | [F:ITU]BPCNUM <> [M:SQH0]BPCORD
   Read [ITU] ITU0=[M:SQH2]ITMREF(NLIG);[M:SQH0]BPCORD
   If fstat Raz [F:ITU] Endif
Endif

#  Réinitialisation de l'unité de vente si nécessaire
Gosub REINIT_SAU

Return

#  -------------------------------------------------------------------  #
#  Réinitialisation de l'unité de vente                                 #
#  -------------------------------------------------------------------- #
$REINIT_SAU
Local Char    WSAUORI(GLONUOM) : WSAUORI       = [M:SQH2]SAU(NLIG)
Local Decimal WSAUSTUCOEORI    : WSAUSTUCOEORI = [M:SQH2]SAUSTUCOE(NLIG)
Local Decimal WDACSAUCOEORI    : WDACSAUCOEORI = [M:SQH2]DACSAUCOE(NLIG)
Local Decimal WQTYORI          : WQTYORI       = [M:SQH2]QTY(NLIG)
Local Decimal WQTYSTUORI

Local Char    WSAU
Local Decimal WSAUSTUCOE, WQTYSAU, WQTY, WQTYSTU, WCOEINVERSE
Local Integer WDACSAUCOE

# On vérifie tout d'abord que l'UV est bien une unité de l'article
# (Dans le cas où elle était l'UV définie pour le client du devis dupliqué)
WSAU=WSAUORI
WSAUSTUCOE=WSAUSTUCOEORI
WDACSAUCOE=WDACSAUCOEORI
WQTYSAU=[M:SQH2]QTY(NLIG)
# Conversion de la qté cdée UV en US, c'est la qté en US qui va être la qté de référence
WQTYSTUORI=WQTYSAU * WSAUSTUCOE
Call QTEARR(WQTYSTUORI,[M:SQH2]STU(NLIG)) From TRTDIV

Call CTLUOM([M:SQH2]ITMREF(NLIG), 2, [M:SQH0]BPCORD, WSAU, WSAUSTUCOE, GBIDC1, GBIDC2, WDACSAUCOE) From STKACT
If mkstat=2
    # L'UV de la ligne de devis d'origine n'est pas une unité de l'article
    # On réinitialise l'UV avec l'UV de l'article client si elle existe ou avec l'UV de l'article
    mkstat=0 : Raz GMESSAGE
    WSAU       = [F:ITM]SAU
    WSAUSTUCOE = [F:ITM]SAUSTUCOE
    WDACSAUCOE = [F:ITM]DACSAUCOE
    If [F:ITU]SAU <> "" & find([M:SQH2]LINTYP(NLIG),1,2,6,10) & [M:SQH2]FOCFLG(NLIG) <> 3
        WSAU       = [F:ITU]SAU
        WSAUSTUCOE = [F:ITU]SAUSTUCOE
        WDACSAUCOE = 1
    Endif
Endif

# L'UV est une unité de l'article
# L'UV n'est pas une unité de l'article et elle a été réinitialisée
While WSAUSTUCOEORI<>WSAUSTUCOE
    # Le coefficient de conversion a changé
    # --> Il faut recalculer la qté cdée en UV

    # On recalcule la nouvelle la qté cdée UV en repartant de la qté US et du nouveau coefficient de conversion
    WQTYSAU=WQTYSTUORI / WSAUSTUCOE
    Call QTEARR(WQTYSAU,WSAU) From TRTDIV
    # Conversion de la nvelle qté cdée UV en US pour voir si on obtient le même résultat
    WQTYSTU=WQTYSAU * WSAUSTUCOE
    Call QTEARR(WQTYSTU,[M:SQH2]STU(NLIG)) From TRTDIV
    If WQTYSTU=WQTYSTUORI
        # On obtient la même qté US                     : On conserve l'unité
        Break
    Else
        # On obtient pas la même qté US                 : On change l'unité
        If WSAU=[F:ITU]SAU
            # Si l'UV était l'UV de l'article client, on prend l'UV de l'article
            WSAU=[F:ITM]SAU
            WSAUSTUCOE = [F:ITM]SAUSTUCOE
            WDACSAUCOE = [F:ITM]DACSAUCOE
        Elsif WSAU=[F:ITM]SAU
            # Si l'UV était l'UV de l'article, on prend l'US de l'article
            WSAU=[F:ITM]STU
            WSAUSTUCOE = 1
            WDACSAUCOE = 1
            WQTYSAU=WQTYSTUORI
            Break
        Else
            # Si l'UV était une unité de conditionnement, on prend l'UV de l'article client
            WSAU=[F:ITU]SAU
            WSAUSTUCOE = [F:ITU]SAUSTUCOE
            WDACSAUCOE = 1
        Endif
    Endif
Wend

# On a gardé l'unité de vente et le coefficient d'origine
If WSAUORI=WSAU & WSAUSTUCOEORI=WSAUSTUCOE Return Endif

# On a modifié l'unité de vente ou le coefficient de conversion

# --> Réinitialisation de la ligne avec les nouvelles valeurs
[M:SQH2]SAU(NLIG)=WSAU
[M:SQH2]SAUSTUCOE(NLIG)=WSAUSTUCOE
[M:SQH2]DACSAUCOE(NLIG)=WDACSAUCOE
[M:SQH2]QTY(NLIG)=WQTYSAU

WFLGTOT="O"

# On a gardé le coefficient d'origine
If WSAUSTUCOEORI=WSAUSTUCOE Return Endif

# On a modifié le coefficient de conversion

If [M:SQH2]FOCFLG(NLIG)=3 Return Endif
# --> Réinitialisation des prix
Gosub REINIT_PRI

Return

#  -------------------------------------------------------------------  #
#  Réinitialisation des prix                                            #
#  -------------------------------------------------------------------  #
$REINIT_PRI
Local Decimal WGROPRIORI       : WGROPRIORI    = [M:SQH2]GROPRI(NLIG)
Local Decimal WNETPRIORI       : WNETPRIORI    = [M:SQH2]NETPRI(NLIG)
Local Decimal WNETPRINOTORI    : WNETPRINOTORI = [M:SQH2]NETPRINOT(NLIG)
Local Decimal WNETPRIATIORI    : WNETPRIATIORI = [M:SQH2]NETPRIATI(NLIG)

# --> Recalcul des montants de base calcul de taxe
If WQTYORI<>[M:SQH2]QTY(NLIG)
    Local    Decimal WUNTCLCAMT1, WUNTCLCAMT2 : Raz WUNTCLCAMT1, WUNTCLCAMT2
    If WQTYORI <> 0
        WUNTCLCAMT1=[M:SQH2]CLCAMT1(NLIG): WQTYORI : WUNTCLCAMT2=[M:SQH2]CLCAMT2(NLIG)/WQTYORI
    Endif
    Call ALICLCAMT([M:SQH2]ITMREF(NLIG), [M:SQH2]QTY(NLIG), NLIG, "SQH2", [M:SQH2]CLCAMT1(NLIG), [M:SQH2]CLCAMT2(NLIG)) From TRTX3
Endif

# --> Recalcul du prix brut
If WGROPRIORI<>0
    [M:SQH2]GROPRI(NLIG)=WGROPRIORI*(1/WSAUSTUCOEORI)*[M:SQH2]SAUSTUCOE(NLIG)
Endif

# --> Recalcul du prix net
If WGROPRIORI<>[M:SQH2]GROPRI(NLIG)
    # Bug 70861 : Recalcul prix net si recherche tarif ou si ligne directe (car impact des frais/remise par ligne sur le prix net)
    WNETPRIORI   =[M:SQH2]NETPRI(NLIG)
    WNETPRINOTORI=[M:SQH2]NETPRINOT(NLIG) : WNETPRIATIORI=[M:SQH2]NETPRIATI(NLIG)
    Call CLCNETPRI([M:SQH2]QTY(NLIG), [M:SQH0]CUR, NLIG) From TRTVENPRI
Endif

Return
# 102681


# V6.1 Modification code adresse de livraison
#-------------------------------------#
# Comparaison zone entête/zone détail #
#-------------------------------------#
$COMP_ZON
If evalue("dim([M:SQH2]"+NOMD+"(NLIG))") >0 & evalue("dim([M:SQH1]"+NOME+")") >0
    If evalue("[M:SQH2]"+NOMD+"(NLIG)") <> evalue("[M]"+NOME) : Return : Endif
Else
    Return
Endif

#-------------------------------------#
# Modification de la zone détail      #
#-------------------------------------#
$MOD_ZON

# Particularité sur BPAADD : Bien que FFLGMOD="" ou "2" (non) on passe ici :
# car GLINREP=1 et il faut de toute façon répercuter les représentants
If find(FFLGMOD,"1","3")
    If evalue("dim([M:SQH2]"+NOMD+"(NLIG))") >0
        Assign "[M:SQH2]"+NOMD+"(NLIG)" With VALEUR
    Endif
Endif

[M:SQH2]UPDFLG(NLIG) = 1

# --- Modification du siet d'expédition
If NOME = "STOFCY"
    If GTARFLG <> "1" WFLGTOT="O" Endif
Endif
# --- Modification de l'adresse de livraison
If NOME = "BPAADD"
    If W_ALICDE=2
#       Réalimentation des zones issues du client
        Gosub MOD_BPAADD
#   Elsif find(FFLGMOD,"1","3") # 107890 : Scheduled invoices : (LC:13/12/16)
    Elsif find(FFLGMOD,"1","3") and [M:SQH2]DLVFLG(NLIG)=2  # 107890 : Scheduled invoices : (LC:13/12/16)
#       Pas de réalimentation des zones issues du client on récupère uniquement le contact
        If dim([M:ADB2]CNTNAM)>0 [M:SQH2]CNDNAM(NLIG) = [M:ADB2]CNTNAM : Endif
    Endif
Endif
# --- Modification des représentants : Recherche des taux de commissions
If find(NOME,"REP(0)","REP(1)")
    Assign ("[M:SQH2]REPRAT"+num$(WIND+1)+"(NLIG)") With 0
    WREP=VALEUR
    Gosub MOD_REP
Endif

Return

#--------------------------------------------------------#
# Modification de l'adresse de livraison                 #
#--------------------------------------------------------#
$MOD_BPAADD

#If find(FFLGMOD,"1","3")                            # 107890 : Scheduled invoices : (LC:13/12/16)
If find(FFLGMOD,"1","3") and [M:SQH2]DLVFLG(NLIG)=2  # 107890 : Scheduled invoices : (LC:13/12/16)
    [M:SQH2]DDAYLTI(NLIG) = [M:SQH1]DAYLTI
    If dim([M:ADB2]CNTNAM)>0
        [M:SQH2]CNDNAM(NLIG) = [M:ADB2]CNTNAM
    Endif
Endif
# Particularité si GLINREP=1 il faut de toute façon répercuter les représentants
# --> Alimentation des commissions représentants
For WIND=0 To dim([M:SQH1]REP)-1
  WREP = evalue("[M:SQH1]REP("+num$(WIND)+")")
  Assign ("[M:SQH2]REP"+num$(WIND+1)+"(NLIG)") With WREP
  Assign ("[M:SQH2]REPRAT"+num$(WIND+1)+"(NLIG)") With 0
  Gosub MOD_REP
Next
Return

#--------------------------------------------------------#
# Modification des représentants                         #
#--------------------------------------------------------#
$MOD_REP
If WREP <> ""
    If [F:REP]REPNUM <> WREP
        Read [F:REP]REP0 = WREP
        If fstat Raz [F:REP] : Endif
    Endif
    If [F:BPC]BPCNUM <> [M:SQH0]BPCORD
        Read [F:BPC]BPC0 = [M:SQH0]BPCORD
        If fstat Raz [F:BPC] :Endif
    Endif
    #---------------------------------------------------------------------------------#
    #  Suite à la modification d'un représentant : Recherche des taux de commissions  #
    #---------------------------------------------------------------------------------#
    If [F:BPC]COMCAT <> 0
        Assign ("[M:SQH2]REPRAT"+num$(WIND+1)+"(NLIG)") With evalue("[F:REP]COMRAT"+num$(WIND+1)+"([F:BPC]COMCAT-1)")
    Endif
Endif
Return
# V6.1 Modification code adresse de livraison

#-------------------------------------#
# Convertion des montants lignes      #
#-------------------------------------#
$CONV_LIGNE
Local Decimal MNTORI, MNTDES

# --> prix brut
Call CONVERT2(WANCCUR,[M:SQH1]CUR,GLOCALDEV,[M]CHGTYP,date$,[M]GROPRI(NLIG),MNTDES,GBIDI1) From TRTDEV
[M]GROPRI(NLIG) = arr(MNTDES, 10^-GDECPRI)

# --> frais remise en montant
For I = 1 To 9
   If evalue ("dim([M:SQH2]DISCRGVAL"+num$(I)+"(nlig))")>0
      If GFMTREM(I-1)="M"
         MNTORI = evalue("[M:SQH2]DISCRGVAL"+num$(I)+"(NLIG)")
         Call CONVERT(WANCCUR,[M:SQH1]CUR,GLOCALDEV,[M]CHGTYP,date$,MNTORI,MNTDES,GBIDI1) From TRTDEV
         Assign "[M:SQH2]DISCRGVAL"+num$(I)+"(NLIG)" With MNTDES
      Endif
   Endif
Next

# --> prix net
Call CONVERT2(WANCCUR,[M:SQH1]CUR,GLOCALDEV,[M]CHGTYP,date$,[M]NETPRI(NLIG),MNTDES,GBIDI1) From TRTDEV
[M]NETPRI(NLIG) = arr(MNTDES, 10^-GDECPRI)
# --> prix de revient
Call CONVERT2(WANCCUR,[M:SQH1]CUR,GLOCALDEV,[M]CHGTYP,date$,[M]CPRPRI(NLIG),MNTDES,GBIDI1) From TRTDEV
[M]CPRPRI(NLIG) = arr(MNTDES, 10^-GDECPRI)
# --> Traitement des montants de base de calcul
If [M]CLCAMT1(NLIG) <> 0 | [M]CLCAMT2(NLIG) <> 0
    # Ces montants dépendent d'une formule donc d'opérandes divers
    # Pas de conversion mais Recalcul
    Call ALICLCAMT([M]ITMREF(NLIG), [M]QTY(NLIG), NLIG, "SQH2", [M]CLCAMT1(NLIG), [M]CLCAMT2(NLIG)) From TRTX3
Endif

Return

#-------------------------------------#
# Recalcul des totaux                 #
#-------------------------------------#
$RECALC_TOT
Local Integer AFF

# FGR 13/01/2013 : X3SUIVI94756 : WFLGTOT doit exister ET valoir "O"
#If WFLGTOT="O"                                               : # 89275 : Duplication cde et ctrl des prix
If dim(WFLGTOT) >= 0 and WFLGTOT="O" Then
    Call CLCPFM([M:SQH2]DSTOFCY(NLIG), [M:SQH1]PRITYP, [M:SQH0]CHGTYP, [M:SQH0]QUODAT, [M:SQH0]CUR,
&           NLIG,INICPRPRI) From TRTVENPRI
Endif                                                         : # 89275

If dim(WZONCOU) >= 0 Then  # FGR 13/01/2013 : X3SUIVI94756 : WZONCOU doit exister
  If GREP= "D" & WZONCOU= "BPCORD" & GDACLOK=1 GNETMAR=1 Endif  : # 89275
Endif

Call CTLPFM([M:SQH0]CUR,[M:SQH2]CPRPRI(NLIG), NLIG) From TRTVENPRI
# 89275
#If GREP= "D" & WZONCOU= "BPCORD" & GDACLOK=1
If GREP= "D" & dim(WZONCOU) >= 0 and WZONCOU= "BPCORD" & GDACLOK=1  # FGR 13/01/2013 : X3SUIVI94756 : WZONCOU doit exister
  Raz GNETMAR : Raz GMESSAGE
Endif
# 89275

mkstat=0
Gosub CALC_QUO
Gosub CALC_DSP From TRTVENDIV
Call ADD_TOT(NLIG)
[M]UPDFLG(NLIG) = 1
Return

#-------------------------------------#
# Recalcul des tarifs                 #
#-------------------------------------#
$RECALC_TARIF
Local Integer TYPRECH
Local Decimal GROPRI
Local Char    ACT
Local Integer ORI

# --> identification du type tarif : 1 normal / 4 composant
If   find([M]LINTYP(NLIG), 1,2,6,10)
    TYPRECH = 1
Else
    ORI=NLIG
    While !find([M]LINTYP(ORI),2,6,10) & ORI >= 0 ORI-=1 Wend
    If find([M]LINTYP(ORI),2,6,10) GPNTITMREF=[M]ITMREF(ORI) Endif
    TYPRECH = 4
Endif
# --> pas de recalcul tarif sur les gratuits
If   [M]FOCFLG(NLIG) = 3 : Return : Endif
Call ALICLCAMT([M:SQH2]ITMREF(NLIG), [M]QTY(NLIG), NLIG, "SQH2", [M:SQH2]CLCAMT1(NLIG), [M:SQH2]CLCAMT2(NLIG)) From TRTX3
# --> recherche tarif
Call RECH_TARIF(TYPRECH,[M]ITMREF(NLIG),NLIG,[M]QTY(NLIG),"SQH",GROPRI) From TRTVENTAR
# --> Action sur les gratuits : S suppression / C correction / I insertion
If GFOCITMREF  = "" & [M]FOCFLG(NLIG) = 2 :ACT = "S":[M]FOCFLG(NLIG)=1:Endif
If GFOCITMREF <> "" & [M]FOCFLG(NLIG) = 2 :ACT = "C":Endif
If GFOCITMREF <> "" & [M]FOCFLG(NLIG) = 1 :ACT = "I":Endif
[M]GROPRI(NLIG)= GROPRI
Call CLCNETPRI([M]QTY(NLIG), [M:SQH0]CUR, NLIG) From TRTVENPRI
Call CLCPFM([M]DSTOFCY(NLIG), [M]PRITYP, [M]CHGTYP, [M]QUODAT, [M]CUR, NLIG,INICPRPRI) From TRTVENPRI
# 89275 : Duplication cde et ctrl des prix
# Avec chgmnt de client
# --> Ctrl prix net
If GREP= "D" & WZONCOU= "BPCORD" & GDACLOK=1
    GNETMAR=1
    Call CTLNETPRI([M:SQH0]BPCORD, [M]CHGTYP, [M]QUODAT, [M:SQH0]CUR,NLIG) From TRTVENPRI
    Raz GNETMAR : Raz GMESSAGE
Endif
#If find(GUSER, "LD","ZLD")
#  Infbox "GMESSAGE="-GMESSAGE-"GNETMAR="-num$(GNETMAR)
#Endif
# --> Recalcul des totaux avec ctrl de la marge
Gosub RECALC_TOT
#Call APRES_LIGNE(NLIG, 0)
# 89275

[M]UPDFLG(NLIG) = 1
ORI = NLIG
Gosub TRTGRA
Return

#-------------------------------------#
# Traitement des gratuits             #
#-------------------------------------#
$TRTGRA
Local Integer LIGGRA
Local Integer RET

If ACT = "S" | ACT = "C"
    LIGGRA = find(3, [M]FOCFLG(NLIG+1..[M]NBLIG-1))
    If LIGGRA <> 0
        LIGGRA = LIGGRA + NLIG
#       Suppression du gratuit
        If ACT = "S"
            Call SUPGRA(ORI, 1, RET) From TRTVENBOM
            If RET = 0 [M]FOCFLG(ORI)=1 : Endif
        Endif
#       Remplacement du gratuit : Suppression et création
        If ACT = "C" & [M]ITMREF(LIGGRA) <> GFOCITMREF
            Call SUPGRA(LIGGRA-1, 1, RET) From TRTVENBOM
            If RET = 0
                Call CREGRA("G",0, ORI, [M:SQH0]QUODAT, 1,LIGGRA, RET) From TRTVENBOM
                If RET = 0 [M]UPDFLG(LIGGRA-1) = 1:Endif
            Endif
#       Creation du gratuit
        Elsif ACT = "C" & [M]QTY(LIGGRA) <> GFOCQTY
            [M]QTY(LIGGRA) = GFOCQTY
            [M]UPDFLG(LIGGRA) = 1
        Endif
    Endif
Endif
If ACT = "I"
    LIGGRA = NLIG + 1
    While LIGGRA < [M:SQH2]NBLIG & !find([M:SQH2]LINTYP(LIGGRA),1,2,6,10)
        LIGGRA += 1
    Wend
    Call CREGRA("G", 0, ORI, [M:SQH0]QUODAT, 1,LIGGRA, RET) From TRTVENBOM
Endif
Raz ACT
Return

# -------------------------------------------------------------------- #
#     Recalcul des montants de facturation si changement de devise     #
# -------------------------------------------------------------------- #
$CONV_INVDTAAMT
Local Integer I, SPSTAT
Local Decimal MNTDES

If [M:SQH3]NBFAC <> 0
   For I = 0 To [M:SQH3]NBFAC-1
      If [M:SQH3]AMTCOD(I) = 2
         [M:SQH3]FORMAT(I) = "NZ:"+[F:TCU]CURFMT1
         Call CONVERT(WANCCUR, VALEUR, GLOCALDEV, [M]CHGTYP, date$, [M:SQH3]INVDTAAMT(I),
&                     MNTDES,SPSTAT) From TRTDEV
         [M:SQH3]INVDTAAMT(I) = MNTDES
         Affzo [M:SQH3]15
      Endif
   Next I
Endif
Return

#########################################################################
# Traitements appelés par SUBSQHA                                       #
#########################################################################

#------------------------------------------#
# Recalcul des lignes suite à tarif groupé #
#------------------------------------------#
$RECALC_GROUPE
Local Integer I

# --> Recalcul prix net, marge des lignes modifiées et recalcul totaux
If sum([M:SQH2]GRPFLG) <> 0
    For I=0 To [M]NBLIG-1
        If  [M:SQH2]GRPFLG(I) = 1
            Call SUB_TOT(I)
            GNETMAR = 0
            Call CLCNETPRI([M]QTY(I), [M:SQH0]CUR, I) From TRTVENPRI
            Call CLCPFM([M]DSTOFCY(I), [M]PRITYP, [M]CHGTYP, [M]QUODAT, [M]CUR, I,0) From TRTVENPRI
            Call APRES_LIGNE(I,0)
            GNETMAR = 1
            [M:SQH2]UPDFLG(I) = 1
        Endif
    Next
    Raz [M:SQH2]GRPFLG
Endif

Return

#------------------------------------------#
# Génération de la proforma sur le devis   #
#------------------------------------------#
$PROFORMA
Local Char WBID
Call OBJET("SIH",WBID,"") From GOBJET

Return

#--------------------------------------------------------------------#
# Mise à jour de l'adresse                                           #
#--------------------------------------------------------------------#
$MAJADRESSE
Call DEBTRANS From GLOCK
$TR_ADR
GOK=1
Trbegin [SQH]
  Readlock [SQH] SQH0=[M]SQHNUM
  If fstat=1  GOK=-1 : GLOCK="$SQUOTE"-[M]SQHNUM             : Goto ROLL_ADR
  Elsif fstat GOK=0  : Call RSTA("SQH",[M]SQHNUM) From GLOCK : Goto AB_ADR : Endif
  If BOUT = "H"
      [F:SQH]CNCNAM = [M:ADB1]CNTNAM
      If [M:ADB1]ADBFLG=2 Gosub CHARGE_ADRBPC Endif
  Else
      [F:SQH]CNDNAM = [M:ADB2]CNTNAM
      If [M:ADB2]ADBFLG=2 Gosub CHARGE_ADRBPD Endif
  Endif
  Rewrite [SQH]
  If fstat GOK=0 : Call FSTA("SQH") From GLOCK : Goto AB_ADR : Endif
Commit
Gosub RELIT From GOBJSUB  # FGR 24/07/2014 : X3SUIVI100377
Return

$ROLL_ADR
Rollback : Call ROLL From GLOCK
#if GROLL Gosub RELIT From GOBJSUB
#else     Goto TR_ADR : ENDIF
If !GROLL Goto TR_ADR : Endif
Return

$AB_ADR
Rollback
#osub RELIT From GOBJSUB
Return

$CHARGE_ADRBPC
# -------------------------------------- #
# Alimentation de l'adresse              #
# -------------------------------------- #
[F:SQH]BPAORD       = [M:ADB1]BPAADD
#If GACTSAD=2 : # Bug 67868
    [F:SQH]BPCNAM(0)    = [M:ADB1]BPRNAM(0)
    [F:SQH]BPCNAM(1)    = [M:ADB1]BPRNAM(1)
    [F:SQH]BPCADDLIG(0) = [M:ADB1]BPAADDLIG(0)
    [F:SQH]BPCADDLIG(1) = [M:ADB1]BPAADDLIG(1)
    [F:SQH]BPCADDLIG(2) = [M:ADB1]BPAADDLIG(2)
    [F:SQH]BPCPOSCOD    = [M:ADB1]POSCOD
    [F:SQH]BPCCTY       = [M:ADB1]CTY
    [F:SQH]BPCSAT       = [M:ADB1]SAT
    [F:SQH]BPCCRY       = [M:ADB1]CRY
    [F:SQH]BPCCRYNAM    = [M:ADB1]CRYNAM
#Endif        : # Bug 67868
Return
# -------------------------------------- #
# Alimentation de l'adresse livraison    #
# -------------------------------------- #
$CHARGE_ADRBPD
#If GACTSAD=2 : # Bug 67868
    [F:SQH]BPDNAM(0)    = [M:ADB2]BPRNAM(0)
    [F:SQH]BPDNAM(1)    = [M:ADB2]BPRNAM(1)
    [F:SQH]BPDADDLIG(0) = [M:ADB2]BPAADDLIG(0)
    [F:SQH]BPDADDLIG(1) = [M:ADB2]BPAADDLIG(1)
    [F:SQH]BPDADDLIG(2) = [M:ADB2]BPAADDLIG(2)
    [F:SQH]BPDPOSCOD    = [M:ADB2]POSCOD
    [F:SQH]BPDCTY       = [M:ADB2]CTY
    [F:SQH]BPDSAT       = [M:ADB2]SAT
    [F:SQH]BPDCRY       = [M:ADB2]CRY
    [F:SQH]BPDCRYNAM    = [M:ADB2]CRYNAM
    If dim([M:ADB2]ADRVAL) > 0 : [F:SQH]ADRVAL = [M:ADB2]ADRVAL : Endif #LTA.n
#Endif        : # Bug 67868
Return

#-----------------------------------------------------------------------#
# Recalcul de l'etat du devis                                           #
# ---------------------------                                           #
#                                                                       #
# Appelé depuis LIENS,CREATION,MODIF                                    #
#-----------------------------------------------------------------------#
$MAJSTASQH
Local Integer I
Local Integer WCFMLINNBR    : WCFMLINNBR=0
Local Integer WQUOSTA       : WQUOSTA = 1

For I=0 To [M:SQH2]NBLIG-1
    If [M:SQH2]ORDQTY(I) <> 0 WQUOSTA = 2 : Endif
#   --- Incrémentation du nbre de lignes commandée
    If [M:SQH2]ORDQTY(I) >= [M:SQH2]QTY(I)
        WCFMLINNBR += 1
    Endif
Next
If WCFMLINNBR >= [M:SQH2]NBLIG WQUOSTA = 3 : Endif

If WQUOSTA <> [F:SQH]QUOSTA | WCFMLINNBR <> [F:SQH]CFMLINNBR
    Readlock [SQH]SQH0=[M:SQH0]SQHNUM
    If !fstat
        Update [SQH] Where SQHNUM=[M:SQH0]SQHNUM With QUOSTA=WQUOSTA, CFMLINNBR=WCFMLINNBR
        If fstat GOK=0 : Call FSTA("SQH") From GLOCK : Endif
    Endif
    [M:SQH1]QUOSTA = WQUOSTA
Endif
Return


#########################################################################
# Traitements communs                                                   #
#########################################################################

#--------------------------------------------------------------------#
# Lecture de ts les fichiers utiles à une ligne                      #
#--------------------------------------------------------------------#
Subprog LECT_FIC(NLIG)
Value Integer NLIG

If [F:ITS]ITMREF <> [M:SQH2]ITMREF(NLIG)
     Read [F:ITS]ITS0 = [M:SQH2]ITMREF(NLIG)
     If fstat  Raz [F:ITS] : Endif
Endif
If [F:ITM]ITMREF <> [M:SQH2]ITMREF(NLIG)
     Read [F:ITM]ITM0 = [M:SQH2]ITMREF(NLIG)
     If fstat  Raz [F:ITM] : Endif
Endif

End
#--------------------------------------------------------------------#
# Initialisation des zones venant de l'entete devis                  #
#--------------------------------------------------------------------#
Subprog INIT_SQH(NLIG)
Value Integer NLIG

Local Integer I
Local Char    WREP(GLONREP)             # hcb v6

[M:SQH2]DBPAADD(NLIG)         = [M:SQH1]BPAADD
If dim([M:ADB2]CNTNAM)>0
    [M:SQH2]CNDNAM(NLIG)      = [M:ADB2]CNTNAM
Endif
[M:SQH2]DSTOFCY(NLIG)         = [M:SQH1]STOFCY
[M:SQH2]DDAYLTI(NLIG)         = [M:SQH1]DAYLTI

# --> Alimentation des commissions représentants
For I=0 To dim([M:SQH1]REP)-1

  WREP = evalue("[M:SQH1]REP("+num$(I)+")")

  Assign ("[M:SQH2]REP"+num$(I+1)+"(NLIG)") With WREP

  If WREP <> ""
        If [F:REP]REPNUM <> WREP
            Read [F:REP]REP0 = WREP
            If fstat Raz [F:REP] : Endif
        Endif
        If [F:BPC]BPCNUM<>[M:SQH0]BPCORD
            Read [F:BPC]BPC0 = [M:SQH0]BPCORD
            If fstat Raz [F:BPC] : Endif
        Endif
        If [F:BPC]COMCAT <> 0
            Assign ("[M:SQH2]REPRAT"+num$(I+1)+"(NLIG)") With evalue("[F:REP]COMRAT"+num$(I+1)+"([F:BPC]COMCAT-1)")
        Endif
  Endif

Next

End

#--------------------------------------------------------------------#
# Initialisation des zones venant de l'article dans une ligne        #
#--------------------------------------------------------------------#
Subprog INIT_ITM(NLIG, ITMREF)
Value    Integer NLIG
Value    Char    ITMREF

Local Char VAT(GLONVAT)(3)

# Alimentation à partir article-maître
[M:SQH2]VACITM1(NLIG)   = [F:ITM]VACITM(0)
[M:SQH2]VACITM2(NLIG)   = [F:ITM]VACITM(1)
[M:SQH2]VACITM3(NLIG)   = [F:ITM]VACITM(2)
#Call ALITAXEV([M:SQH1]VACBPR,[F:ITM]VACITM,VAT) From TRTX3
Call RECHVATCOD(1,1,[M:SQH0]BPCORD,ITMREF,"SQH2",NLIG,VAT) From TRTX3
[M:SQH2]VAT1(NLIG)      = VAT(0)
[M:SQH2]VAT2(NLIG)      = VAT(1)
[M:SQH2]VAT3(NLIG)      = VAT(2)

[M:SQH2]SAU(NLIG)       = [F:ITM]SAU
[M:SQH2]SAUSTUCOE(NLIG) = [F:ITM]SAUSTUCOE
[M:SQH2]DACSAUCOE(NLIG) = [F:ITM]DACSAUCOE
[M:SQH2]STU(NLIG)       = [F:ITM]STU
[M:SQH2]STOMGTCOD(NLIG) = [F:ITM]STOMGTCOD
If dim([M:SQH2]SSTCOD)>0 : [M:SQH2]SSTCOD(NLIG)  = [F:ITM]SSTCOD : Endif    #101380.n
# Désignation standard
#[M:SQH2]ITMDES1(NLIG)   = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SQH2]ITMDES1(NLIG), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
# Désignation traduite
#Call CHARGE_ITMDES("DES1AXX",[M:SQH0]LAN,[F:ITM]ITMREF,[M:SQH2]ITMDES(NLIG)) From TRTX3
#If [M:SQH2]ITMDES(NLIG) = "" [M:SQH2]ITMDES(NLIG) = [M:SQH2]ITMDES1(NLIG) Endif
Call CHARGE_DEFITMDES("DES1AXX",[M:SQH0]LAN,[F:ITM]ITMREF,[M:SQH2]ITMDES(NLIG), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
# Si contrat de service --> article non géré en stock
If [F:ITM]TPLCONSRV <> "" [M:SQH2]STOMGTCOD(NLIG) = 1 Endif

# Alimentation à partir article-vente
If [F:ITU]ITMREF <> ITMREF | [F:ITU]BPCNUM <> [M:SQH0]BPCORD
   Read [ITU] ITU0=ITMREF;[M:SQH0]BPCORD
   If fstat Raz [F:ITU] Endif
Endif

# TS - Nouvelle gestion de texte
Raz [M:SQH2]SQDTEX(NLIG)
If find(GSALTEXLIN,1,5)
   [M:SQH2]SQDTEX(NLIG) = [F:ITU]ITSTEX
   If [M:SQH2]SQDTEX(NLIG)=""
      [M:SQH2]SQDTEX(NLIG) = [F:ITS]ITSTEX
   Endif
Endif

If [F:ITU]SAU <> "" & find([M:SQH2]LINTYP(NLIG), 1,2,6,10) & [M:SQH2]FOCFLG(NLIG) <> 3
    [M:SQH2]SAU(NLIG) = [F:ITU]SAU
    [M:SQH2]SAUSTUCOE(NLIG) = [F:ITU]SAUSTUCOE
    [M:SQH2]DACSAUCOE(NLIG) = 1
Endif
#Call ALISAUCOE(ITMREF, [M:SQH0]BPCORD, [M:SQH2]SAU(NLIG), [M:SQH2]STU(NLIG), [M:SQH2]SAUSTUCOE(NLIG)) From TRTVENQTE

# 107890 : Scheduled invoices : (LC:18/12/16)
[M:SQH2]DLVFLG(NLIG)       = [F:ITM]DLVFLG
If [M:SQH2]DLVFLG(NLIG)=1
   Raz [M:SQH2]CNDNAM(NLIG)
   Raz [M:SQH2]DDAYLTI(NLIG)
Else
   If [M:SQH2]DBPAADD(NLIG)="": [M:SQH2]DBPAADD(NLIG) = [M:SQH1]BPAADD: Endif
   If dim([M:ADB2]CNTNAM)>0
     If [M:SQH2]CNDNAM(NLIG)="": [M:SQH2]CNDNAM(NLIG) = [M:ADB2]CNTNAM: Endif
   Endif
   If [M:SQH2]DSTOFCY(NLIG)="" :[M:SQH2]DSTOFCY(NLIG) = [M:SQH1]STOFCY: Endif
   If [M:SQH2]DDAYLTI(NLIG)=0: [M:SQH2]DDAYLTI(NLIG)  = [M:SQH1]DAYLTI: Endif
Endif
# 107890 : Scheduled invoices : (LC:18/12/16) (End)
End

#----------------------------------------------------------------------------------#
# Vérification des codes taxes :                                                   #
# Appelé en fin de saisie de ligne pour vérifier si les codes taxes ont changé     #
#        suite à modification d'un champs entrant dans la détermination de la taxe #
# --> Si changement : Chargement des codes taxes                                   #
#                     Recalcul des montants de base calcul taxe (CLCAMT1 et 2)     #
#                     Dde recherche tarif si TTC                                   #
#                     Recalcul de la marge                                         #
#----------------------------------------------------------------------------------#
Subprog VERIF_VATCOD (NLIG)
Value Integer NLIG

Local Char    WVAT(GLONVAT)(3)
Local Integer INICPRPRI : INICPRPRI=1

Call RECHVATCOD(1,1,[M:SQH0]BPCORD,[M:SQH2]ITMREF(NLIG),"SQH2",NLIG,WVAT) From TRTX3

If [M:SQH2]VAT1(NLIG)<>WVAT(0) | [M:SQH2]VAT2(NLIG)<>WVAT(1) | [M:SQH2]VAT3(NLIG)<>WVAT(2)
    [M:SQH2]VAT1(NLIG) = WVAT(0)
    [M:SQH2]VAT2(NLIG) = WVAT(1)
    [M:SQH2]VAT3(NLIG) = WVAT(2)
    # 101874 : V9 : Taxe code control
    #Call TRTRECTARD("SQH", [M:SQH1]CUR, NLIG) From TRTVENTAR
    Local Integer WOK : WOK=1
    If !GIMPORT Call OUINON (mess(247,191,1)-":"-mess(21,191,1),WOK) From GESECRAN : Endif
    If WOK=2
      Call TRTRECTARD("SQH", [M:SQH1]CUR, NLIG) From TRTVENTAR
    Endif
    # 101874
    Call CLCPFM([M:SQH2]DSTOFCY(NLIG), [M:SQH1]PRITYP, [M]CHGTYP, [M:SQH0]QUODAT, [M:SQH0]CUR,
&           NLIG,INICPRPRI) From TRTVENPRI
Endif

End

#-------------------------------------#
# Traitement apres ligne              #
#-------------------------------------#
Subprog APRES_LIGNE(NLIG, AFF)
Value Integer NLIG
Value Integer AFF

Local Integer I
Local Decimal MAJREM (0..8)
Local Char    VAT(GLONVAT)(3)

Call CTLNETPRI([M:SQH0]BPCORD, [M]CHGTYP, [M]QUODAT, [M:SQH0]CUR,NLIG) From TRTVENPRI
#If mkstat=2 End Endif
Call CTLPFM([M:SQH0]CUR,[M:SQH2]CPRPRI(NLIG), NLIG) From TRTVENPRI
#If mkstat=2 End Endif
# --> Calcul du montant devis ht et ttc de la ligne
Gosub CALC_QUO
Gosub CALC_DSP From TRTVENDIV
# --> calcul des montants total des devis
Call ADD_TOT(NLIG)
If AFF = 1
    Affzo [M:SQH2]LINQUONOT(NLIG),LINQUOATI(NLIG),LINPFM(NLIG)
    Affzo [M]QUONOT, QUOATI, PFMTOT
Endif
End

#-------------------------------------------------------------#
# Calcul des montants total de la commande                    #
#-------------------------------------------------------------#
Subprog ADD_TOT(NLIG)
Value Integer NLIG
[M:SQH2]QUONOT += [M:SQH2]LINQUONOT(NLIG)
[M:SQH2]QUOATI += [M:SQH2]LINQUOATI(NLIG)
[M:SQH2]PFMTOT += [M:SQH2]LINPFM(NLIG)
[M:SQH0]DSPTOTQTY += [M:SQH2]QTY(NLIG)
[M:SQH0]DSPTOTWEI += [M:SQH2]DSPLINWEI(NLIG)
[M:SQH0]DSPTOTVOL += [M:SQH2]DSPLINVOL(NLIG)

End

Subprog SUB_TOT(NLIG)
Value Integer NLIG
[M:SQH2]QUONOT -= [M:SQH2]LINQUONOT(NLIG)
[M:SQH2]QUOATI -= [M:SQH2]LINQUOATI(NLIG)
[M:SQH2]PFMTOT -= [M:SQH2]LINPFM(NLIG)
[M:SQH0]DSPTOTQTY -= [M:SQH2]QTY(NLIG)
[M:SQH0]DSPTOTWEI -= [M:SQH2]DSPLINWEI(NLIG)
[M:SQH0]DSPTOTVOL -= [M:SQH2]DSPLINVOL(NLIG)

End

#-----------------------------------------#
# Suppression d'une ligne dans le tableau #
#-----------------------------------------#
Subprog SUP_LIG(NLIG, WRET)
Value Integer NLIG
Variable Integer WRET    : WRET = 0

Call SUB_TOT(NLIG)
If   dim([M]ITMREF) = [M]NBLIG
     Dela NLIG,1 [M:SQH2]NBLIG
Else Dela NLIG,1,[M:SQH2]NBLIG-1 [M:SQH2]NBLIG:Endif
[M:SQH2]NBLIG -=1

End

#-------------------------------------------------------------#
# Calcul des montants commande ht et ttc d'une ligne devis    #
#-------------------------------------------------------------#

$CALC_QUO
Local Decimal MNTCALC

# Bug 65534
Local Char VAT(GLONVAT)(3)
VAT (0) = [M]VAT1(NLIG)
VAT (1) = [M]VAT2(NLIG)
VAT (2) = [M]VAT3(NLIG)

If [M:SQH1]PRITYP=1
    # Montant net HT de la ligne
    MNTCALC = [M]QTY(NLIG) * [M]NETPRINOT(NLIG)
    Call ARRDEV (MNTCALC, [M]CUR) From TRTDIV
    [M]LINQUONOT(NLIG) = MNTCALC

    # Montant net TTC de la ligne
    #MNTCALC = [M]QTY(NLIG) * [M]NETPRIATI(NLIG)
    # Bug 45662 : Calcul Montant TTC en repartant du Montant HT pr éviter les pbs d'arrondis
#    Call CLCTAXEMNT([M]LINQUONOT(NLIG),VAT,[M:SQH1]PRITYP,GSOCIETE,[M:SQH0]QUODAT,[M]CLCAMT1(NLIG),[M]CLCAMT2(NLIG),    : # Bug 71296
#&                   MNTCALC) From TRTX3                                                                                 : # Bug 71296
    Call CLCTAXEMNTV([M]LINQUONOT(NLIG),VAT,[M:SQH1]PRITYP,GSOCIETE,[M:SQH0]QUODAT,[M:SQH1]VACBPR,[M]CLCAMT1(NLIG),[M]CLCAMT2(NLIG),
&                   MNTCALC) From TRTX3                                                                                  : # Bug 71296
    Call ARRDEV (MNTCALC, [M]CUR) From TRTDIV
    [M]LINQUOATI(NLIG) = MNTCALC
Else
    # Bug 65534
    # Montant net TTC de la ligne
    MNTCALC = [M]QTY(NLIG) * [M]NETPRIATI(NLIG)
    Call ARRDEV (MNTCALC, [M]CUR) From TRTDIV
    [M]LINQUOATI(NLIG) = MNTCALC

    # Montant net HT de la ligne
    # Calcul Montant HT en repartant du Montant TTC pr éviter les pbs d'arrondis
#    Call CLCTAXEMNT([M]LINQUOATI(NLIG),VAT,[M:SQH1]PRITYP,GSOCIETE,[M:SQH0]QUODAT,[M]CLCAMT1(NLIG),[M]CLCAMT2(NLIG),     : # Bug 71296
#&                   MNTCALC) From TRTX3                                                                                  : # Bug 71296
    Call CLCTAXEMNTV([M]LINQUOATI(NLIG),VAT,[M:SQH1]PRITYP,GSOCIETE,[M:SQH0]QUODAT,[M:SQH1]VACBPR,[M]CLCAMT1(NLIG),[M]CLCAMT2(NLIG),
&                   MNTCALC) From TRTX3                                                                                   : # Bug 71296
    Call ARRDEV (MNTCALC, [M]CUR) From TRTDIV
    [M]LINQUONOT(NLIG) = MNTCALC
Endif

# Marge de la ligne
MNTCALC = [M]QTY(NLIG) * [M]PFM(NLIG)
Call ARRDEV (MNTCALC, [M]CUR) From TRTDIV
[M]LINPFM(NLIG) = MNTCALC

# Unités répartition
#MNTCALC = [F:ITM]ITMWEI * [M]QTY(NLIG) * [M]SAUSTUCOE(NLIG)
#Call CONVERT_QTY ([F:ITM]WEU,GSALDSPWEU,MNTCALC) From TRTX3
#[M]DSPLINWEI(NLIG) = MNTCALC
#
#MNTCALC = [F:ITM]ITMVOU * [M]QTY(NLIG) * [M]SAUSTUCOE(NLIG)
#Call CONVERT_QTY ([F:ITM]VOU,GSALDSPVOU,MNTCALC) From TRTX3
#[M]DSPLINVOL(NLIG) = MNTCALC

GPOINT="CALC_QUO" : Gosub ENTREE From EXEFNC

Return

#-----------------------------------------------------------#
# Alimentation des masques SQH                              #
# à partir du client commande                               #
#-----------------------------------------------------------#
Subprog ALIQUO (VALEUR)
Value   Char    VALEUR

Local   Decimal COURS, MONTANT
Local   Integer SPSTAT, NBPOSTE
Local   Char TYPCLI : TYPCLI = "C"
[M:SQH0]LAN = GLANGUE
# Utile pour l'init. des sections : La Section par défaut "SQH" utile [M:SQH0]BPCORD
[M:SQH0]BPCORD = VALEUR
#--CPO 88325 Problème : Champ BPAORD de SQUOTE non alimenté si GACTSAD=1
#--du coup on ne passe pas par le CHARGE_ADRMSK depuis INICRE->CHARGENTETE
#  Alimentation code adresse client facture dans [M:ADB1]
If dim([M:ADB1]BPAADD) > 0
  If !GIMPORT | [M:ADB1]BPAADD="" : [M:ADB1]BPAADD = [F:BPC]BPAADD : Endif
Endif
#--/CPO
If !GIMPORT & dim([M:ADB2]BPAADD) > 0 & [F:BPC]BPCTYP<>2 Raz [M:ADB2] : Endif

Read [BPR]BPR0 = VALEUR
If   fstat = 0
    [M:SQH0]LAN = [F:BPR]LAN
Endif
If dim([M:ADB1]CNTNAM)>0 & [M:ADB1]CNTNAM=""
    #--CPO 88325 Problème : Champ BPAORD de SQUOTE non alimenté si GACTSAD=1
    #--L'appel se fait pour [M:ADB1]BPAADD
    If dim([M:ADB1]BPAADD) > 0 and [M:ADB1]BPAADD<>""
      Call RECH_CNTNAM(VALEUR, [M:ADB1]BPAADD, [M:ADB1]CNTNAM) From TRTVENDIV
    Else
    #--/CPO
      Call RECH_CNTNAM(VALEUR, [F:BPC]BPAADD, [M:ADB1]CNTNAM) From TRTVENDIV
    Endif :#--CPO 88325
Endif

# Initialisation du code condition de paiement
Call INIPTE ([F:BPC]BPCPYR, [F:BPC]BPCINV, "C", [M:SQH3]PTE) From TRTX3

# --> Alimentation du 1er représentant
If dim([M:SQH1]REP) > 0
    [M:SQH1]REP(0) = [F:BPC]REP(0)
Endif
# --> Alimentation du 2eme représentant
If dim([M:SQH1]REP) > 1
    If [M:SQH1]REP(0) <> ""
        [M:SQH1]REP(1) = [F:BPC]REP(1)
    Endif
Endif

# Alimentation à partir du modèle d'édition
Call ALI_PRTMOD("SQH0",1) From TRTX3
If [M:SQH0]COPNBR=0 [M:SQH0]COPNBR=1 Endif

# --> Recherche du client livré
If [F:BPC]BPCTYP=4
    [M:SQH1]BPAADD = [F:BPC]BPAADD
    [M:SQH1]BPDNAM = [F:BPC]BPCNAM
    # Alimentation code adresse (client livré) dans [M:ADB2] pour saisie adresse libre
    If dim([M:ADB2]BPAADD) > 0 & [M:ADB2]CNTNAM=""
        [M:ADB2]BPAADD    = [F:BPC]BPAADD
        Call RECH_CNTNAM(VALEUR, [F:BPC]BPAADD, [M:ADB2]CNTNAM) From TRTVENDIV
    Endif
Else
    Filter [BPD] Where [BPD]BPCNUM = VALEUR & [BPD]ENAFLG=2
    Read [BPD]BPD0 = VALEUR;[F:BPC]BPDADD
    If   fstat = 0
        Gosub TRTBPD
    Else
         Read [BPD]BPD0 First
         If fstat = 0 Gosub TRTBPD Endif
    Endif
    Filter [F:BPD]
Endif
# ------------------------------------------- #
#    Alimentation depuis le client facture    #
# ------------------------------------------- #
# -- Lecture client facture lié au client pour alimentation
If ([F:BPC]BPCINV<>VALEUR) & [F:BPC]BPCINV <> ""
   Read [BPC]BPC0 = [F:BPC]BPCINV
   If fstat <> 0 End Endif
Endif
#  -- Lecture tiers
If [F:BPR]BPRNUM<>[F:BPC]BPCNUM
   Read [BPR]BPR0 = [F:BPC]BPCNUM
   If fstat <> 0 End Endif
Endif
If [M:SQH1]CUR = "" : [M:SQH1]CUR = GLOCALDEV : Endif
[M:SQH0]CUR = [F:BPC]CUR
[M:SQH1]CUR = [F:BPC]CUR

[M:SQH0]CHGTYP = [F:BPC]CHGTYP
[M:SQH1]PRITYP = [F:BPC]PRITYP
# Initialisation des escomptes et agios
Call INIT_ESCOMPTE([F:BPC]BPCNUM, GSOCIETE, "C", [M:SQH3]DEP) From CPTSUB

#--> init. du tableau des éléments de facturation
NBPOSTE=dim([M:SQH3]INVDTA)
Raz [M:SQH3]INVDTAAMT
Call STRUFOOT (3,"SQH3",NBPOSTE,[M:SQH0]CHGTYP,[M:SQH0]CUR, [M:SQH0]CUR, "OUI") From SUBSFIT
[M:SQH3]NBFAC = NBPOSTE
# Il faut se repositionner sur le clt devis
If [F:BPC]BPCNUM<>VALEUR
    Read [BPC]BPC0 = VALEUR
Endif

# 102681 : Duplication devis avec changement de client
# Initialisation des textes client
Raz [M]SQHTEX1, [M]SQHTEX2
If GSALTEXORD=1
   [M]SQHTEX1 = [F:BPC]ORDTEX
Elsif GSALTEXORD=2
   [M]SQHTEX2 = [F:BPC]ORDTEX
Endif
# 102681

# Initialisation sections analytiques une fois tout chargé (la devise)
If dim([M:SQH3]NBAXE)>0
    If [M:SQH3]NBAXE>0
        For I=1 To [M:SQH3]NBAXE Raz [M:SQH3]CCE(I-1) : Next
    Endif
    Call INIT_CCEH("SQH3","NBAXE","SQH") From TRTX3CPT
Endif
End

# ------------------------------------------- #
#    Alimentation depuis le client livré      #
# ------------------------------------------- #
$TRTBPD
Local Char WBPCORD(GLONBPC)
If TYPCLI="C"
    WBPCORD=VALEUR
    [M:SQH1]BPAADD = [F:BPD]BPAADD
Else
    WBPCORD=[M:SQH0]BPCORD
Endif
[M:SQH1]BPDNAM = [F:BPD]BPDNAM(0)
#  On récupère le site si aucune ligne n'a été saisie ou si on dupplique avec changement de client
If (([F:BPD]STOFCY <> "" & [M:SQH1]STOFCY <> [F:BPD]STOFCY)|([F:BPD]STOFCY="" & GFCYDEF(7) <> "" & [M:SQH1]STOFCY <> GFCYDEF(7)))
&  & ([M:SQH2]NBLIG = 0 | (GREP="D" & TYPCLI="C"))                  # bug 120236
#If [F:BPD]STOFCY <> ""
   If [F:BPD]STOFCY<>""                                           # bug 120236
    If [F:FCY]FCY <> [F:BPD]STOFCY Read [FCY]FCY0=[F:BPD]STOFCY : Endif
   Else                                                           # bug 120236
    If [F:FCY]FCY <> GFCYDEF(7)                                   # bug 120236
       Read [FCY]FCY0=GFCYDEF(7)                                  # bug 120236
       If fstat: Raz [F:FCY]: Endif                               # bug 120236
     Endif # bug 120236
   Endif                                                          # bug 120236
    If [F:FCY]LEGCPY=GSOCIETE
        #[M:SQH1]STOFCY = [F:BPD]STOFCY                           # bug 120236
        [M:SQH1]STOFCY = [F:FCY]FCY                               # bug 120236
    Endif
Endif
[M:SQH1]DAYLTI = [F:BPD]DAYLTI
#  Alimentation des représentants s'ils n'ont pas été alimentés par le client commande
If [F:BPC]BPCNUM<>WBPCORD
    Read [BPC]BPC0 = WBPCORD
    If fstat <> 0 Raz [F:BPC] : Endif
Endif
# Alimentation du 1er représentant
If dim([M:SQH1]REP) > 0 & [F:BPC]REP(0) = ""
    [M:SQH1]REP(0) = [F:BPD]REP(0)
Endif
# Alimentation du 2eme représentant
If dim([M:SQH1]REP) > 1
    If [M:SQH1]REP(0) <> "" & [F:BPC]REP(1) = ""
        [M:SQH1]REP(1) = [F:BPD]REP(1)
    Endif
   # 81661 : Le second représentant ne doit être alimenté si le 1er réprésentant est alimenté
   If [M:SQH1]REP(0)="" [M:SQH1]REP(1) = "" Endif
Endif
# Alimentation code adresse (client livré) dans [M:ADB2] pour saisie adresse libre
If dim([M:ADB2]BPAADD) > 0 & [M:ADB2]CNTNAM=""
    [M:ADB2]BPAADD    = [F:BPD]BPAADD
    Call RECH_CNTNAM(WBPCORD, [F:BPD]BPAADD, [M:ADB2]CNTNAM) From TRTVENDIV
Endif
If [F:BPD]VACBPR<>""
    # Alimentation régime de taxe à partir du client livré
    [M:SQH1]VACBPR = [F:BPD]VACBPR
Else
    # JPGA : 16/06/2008 - Recherche Régime taxe s'il est renseigné dans le tiers société
    Call INIT_REGIME(WBPCORD, GSOCIETE, "C", [M:SQH1]VACBPR) From CPTSUB
Endif

# Alimentation des champs relatifs au infos douanières
[M:SQH0]EECICT=[F:BPD]EECICT
#-- CPO 65018
If dim([M:SQH1]EECICT)>0 : [M:SQH1]EECICT=[F:BPD]EECICT : Endif
[M:SQH0]ICTCTY=[F:BPD]ICTCTY
#-- CPO 65018
If dim([M:SQH1]ICTCTY)>0 : [M:SQH1]ICTCTY=[F:BPD]ICTCTY : Endif
[M:SQH0]FFWNUM=[F:BPD]FFWNUM
[M:SQH0]FFWADD=[F:BPD]FFWADD
If dim([M:SQH0]BPIEECNUM)>0
    If [F:BPC]BPCNUM<>WBPCORD
        Read [BPC]BPC0 = WBPCORD
        If fstat<>0 : Return : Endif
    Endif
    Call INIEECNUM (WBPCORD,[F:BPD]BPAADD,[F:BPC]BPCINV,[M:SQH0]BPIEECNUM,[M:SQH0]EECNUMCRY) From TRTVENDIV
    [M:SQH0]EECLOC=[F:BPD]EECLOC
Endif
#LTA.sn
If dim([M:SQH1]SSTENTCOD)>0
  # Only override if default exists
  If [F:BPD]SSTENTCOD<>""  [M:SQH1]SSTENTCOD = [F:BPD]SSTENTCOD Endif
  # On new Order w new customer need default ship to country to display SSTENTCOD
  If [F:BPD]BPAADD<>"" & [M:ADB2]CRY =""
      Call CHARGE_ADRMSK("ADB2", WBPCORD) From TRTVENDIV
  Endif
  Gosub SHOW_HIDE_ENTCOD From TRTADRLIB
Endif
#LTA.en
Return

# ------------------------------------------------------------------ #
#   Verification de l'existence des articles sur le site expédition  #
# ------------------------------------------------------------------ #
$VERIF_LIGNE_ITF
WOK=1
Local Integer I
For I=0 To [M:SQH2]NBLIG-1
    If [F:ITM]ITMREF <> [M]ITMREF(I)
        Read [ITM]ITM0=[M]ITMREF(I)
        If fstat Raz [F:ITM] Endif
    Endif
    If [F:ITM]STOMGTCOD> 1
       If clalev ([F:ITF]) <= 0 Local File ITMFACILIT [ITF] : Endif
       Look [ITF]ITF0 = [M]ITMREF(I);WFCY
       If fstat
           WOK=0:GMESSAGE=[M]ITMREF(I) : Break
       Endif
    Endif
Next
Return

