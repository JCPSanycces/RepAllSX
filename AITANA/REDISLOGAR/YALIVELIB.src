#<AdxTL>@(#)0.0.0.0 $Revision$
Funprog COME_FROM_TRT(WTRT)
Value Char WTRT

  Local Integer WYIX, WFOUND, WLO, NAMTRT_INI, NAMTRT_FIN
  Local Char    NAMTRT(GLONADC)

  Raz WYIX, WFOUND
  If WTRT<>""
    While adxpno(WYIX)<>""
      # adxpno(n): @X3.TRT/SUBSDHC$adx
      WLO = len(adxpno(WYIX))
      While WLO>0
        If seg$(adxpno(WYIX), WLO, WLO)="/"  : NAMTRT_INI = WLO : Endif
        If seg$(adxpno(WYIX), WLO, WLO)="$"  : NAMTRT_FIN = WLO : Endif
        WLO -= 1
      Wend
      NAMTRT = seg$(adxpno(WYIX), NAMTRT_INI+1, NAMTRT_FIN-1)
      If NAMTRT = WTRT
        WFOUND = 1 : Break
      Endif
      WYIX += 1
    Wend
  Endif
End WFOUND

#------------------------------------------------------------------------------#

Subprog LECTRA_ERR
Local Char    NOMFIC(GDIMFIC)
Local Char    TMP(250), CRLF(2)
Local Integer I , K , ER , ERL

  If GTRACE="" : End : Endif
  #CRLF = chr$(13) + chr$(10)
  CRLF = "| "
  If GERRTRACE>0
    NOMFIC = filpath("TRA",GTRACE,"tra",nomap,"",adxmac(0))
    Onerrgo ERFIL
    K = filinfo(NOMFIC,0)
    Onerrgo
    If !ER & K>0
      Openi NOMFIC Using [TRA_]
      Iomode adxifs "" Using [TRA_]
      Iomode adxirs chr$(10) Using [TRA_]
      Iomode adxium GUTF8 Using [TRA_]
      Rdseq TMP Using [TRA_]
      Iomode adxium GTRAFOR Using [TRA_]
      While fstat=0
        If left$(TMP,1)="<"
          TMP = right$(TMP,6)
          If TMP<>"" : ER = 1 : Break : Endif
        Endif
        Onerrgo ERL
        Rdseq TMP Using [TRA_]
        Onerrgo
      Wend
      Openi Using [TRA_]
      If !ER : TMP = "" : Endif
    Endif
  Endif

  GMESSAGE = ""
  If GTRACE<>""
    GMESSAGE = mess(21,134,1) - GTRACE : # Trace
  Endif
  If GERRTRACE>0
    If GMESSAGE<>"" : GMESSAGE += CRLF : Endif
    GMESSAGE += mess(159,115,1)-num$(GERRTRACE) : # Number of errors
    If TMP<>"" : GMESSAGE += CRLF + TMP : Endif
  Endif
End

$ERFIL
    ER = errn
Resume

$ERL
  ERL = errn
  TMP = "Read error"
Resume

#------------------------------------------------------------------------------#

Subprog IMPORT(MODELE, NOMFIC)
Value Char    MODELE
Value Char    NOMFIC
#--
Local Integer IMPSTA
Local Char    MESSAGE(255)

  Gosub OUVRE From GIMPOBJ
  Raz [M:IMP2]
  Raz [M:AOE0], [M:AOE1], [M:AOE2]
  Call CHARGE_MODELE(MODELE,IMPSTA) From GIMPOBJ
  If IMPSTA
    MESSAGE = GMESSAGE
    Gosub ERR_EXEC
    End
  Endif
  If [F:AOE]OBJ<>""
    Read [AOB_]ABREV = [F:AOE]OBJ
    If fstat
      MESSAGE = MODELE : IMPSTA = 18
      Gosub ERR_EXEC
      End
    Endif
  Endif
  [M:IMP2]MODIMP = MODELE
  [M:IMP2]NOMIMP = NOMFIC
  [M:IMP2]TYPEXP = 2
  Call IMPORTSIL([M:IMP2]MODIMP,[M:IMP2]NOMIMP) From GIMPOBJ
  IMPSTA = [M:IMP2]STAT
  If IMPSTA : Gosub ERR_EXEC : Endif
  Call EFFACE(NOMFIC, IMPSTA) From ORDSYS
End

$ERR_EXEC
  Call ERR_IMPORT(IMPSTA,MESSAGE) From GIMPOBJ
  Call ECR_TRACE(mess(6,123,1)- ":" - MESSAGE, 1) From GESECRAN
Return

