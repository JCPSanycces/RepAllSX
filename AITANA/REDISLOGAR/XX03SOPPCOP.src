# Appel                : Action XX03SAFCP (Copie d'affaire)
#
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

$ACTION

Gosub ACTION From XX03SOPPCOP2

Return

#==========================================================================================
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()
Call INIT_ENVIRONMENT(VALEUR) From XX03SOPPCOP2
End

#==========================================================================================
Subprog AP_DESTAFF(VALEUR)
Variable Char    VALEUR()

If VALEUR=[M:XX03SC0]OPPNUM
  GMESSAGE = mess(170,2260,1)
  GERR=1
  mkstat=1
Endif

End

#==========================================================================================
Subprog AM_FRLALL(VALEUR)
Variable Integer VALEUR

Local Integer NI

For [L]NI=0 To [M:XX03SC1]NBLIGD-1
  [M:XX03SC1]SELFRL([L]NI)=VALEUR
Next

Affzo [M:XX03SC1]SELFRL

End

