#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "AUTALLFIL"    :   Gosub AUTALLFIL
  When "SOQMODTRI"    :   Gosub SOQMODTRI
Endcase
Return


#############################################
$AUTALLFIL
# Si he marcado el flago de Solo PV con fecha sol<5 días, solamente tengo en cuenta las líneas de pedidos que la
# fecha entrega solicitada sea menor a hoy + 5 dias. Sino 6<=fecha<=90
If [M:DIA]YSOLO5 = 2
  FILSUP += "& [F:SOQ]DEMDLVDAT<=(DATE$+5)"
Else
  FILSUP += "& [F:SOQ]DEMDLVDAT>=(DATE$+6) & [F:SOQ]DEMDLVDAT<=(DATE$+90)"
Endif
Return


#############################################
$SOQMODTRI
# Si he marcado el flago de Solo PV con fecha sol<5 días, ordeno por número de pedido ascendente
If [M:DIA]YSOLO5 = 2
   Link [SOQ] With
&    [SOP]SOP0=[SOQ]SOHNUM;[SOQ]SOPLIN;[SOQ]SOQSEQ,
&    [SOC]SOC0=[SOQ]SOHNUM;[SOQ]SOPLIN
&    As [KSOQ] Order By Key KEY1=SOHNUM;SOPLIN;SOQSEQ
  GPE=1
Else
   Link [SOQ] With
&    [SOP]SOP0=[SOQ]SOHNUM;[SOQ]SOPLIN;[SOQ]SOQSEQ,
&    [SOC]SOC0=[SOQ]SOHNUM;[SOQ]SOPLIN
&    As [KSOQ] Order By Key KEY1=DEMDLVDAT;SOHNUM;SOPLIN;SOQSEQ
  GPE=1
Endif
Return

