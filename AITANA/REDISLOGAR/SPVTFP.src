#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du masque SCHGAS0
#ACV#X11
#TIT#Transfert paramètrage PSA

#LBO 08/2003

GBIDC1=""
GBIDC2=""
Call OBJET("TFP",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet TFP
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "INICRE"        : Gosub INICRE        From SPVOBJTFP
  When "RAZCRE"        : Gosub RAZCRE        From SPVOBJTFP
  When "RAZDUP"        : Gosub RAZDUP        From SPVOBJTFP
  When "SETBOUT"       : Gosub SETBOUT       From SPVOBJTFP
  When "LIENS"         : Gosub LIENS         From SPVOBJTFP
  When "APRES_CRE"     : Gosub APRES_CRE     From SPVOBJTFP
  When "APRES_MOD"     : Gosub APRES_MOD     From SPVOBJTFP
  When "EXEBOUT"       : Gosub EXEBOUT       From SPVOBJTFP
  When "AB5_PSGZCOD"   : Gosub AB5_PSGZCOD   From SPVOBJTFP
  When "BB5_PSGZCOD"   : Gosub BB5_PSGZCOD   From SPVOBJTFP
  When "AB5_PSGZOBJ"   : Gosub AB5_PSGZOBJ   From SPVOBJTFP
  When "BB5_PSGZOBJ"   : Gosub BB5_PSGZOBJ   From SPVOBJTFP
  When "AB5_PSGZTYP"   : Gosub AB5_PSGZTYP   From SPVOBJTFP
  When "BB5_PSGZTYP"   : Gosub BB5_PSGZTYP   From SPVOBJTFP
  When "BB5_REQOPEITV" : Gosub BB5_REQOPEITV From SPVOBJTFP
Endcase

Return



#----------------------------------------------------------------
# Ecran TFP1
#----------------------------------------------------------------

#--------------------------
Subprog C_FICREP(VALEUR)
Variable Char    VALEUR()
Call C_FICHIER(VALEUR) From PATCH
End

#--------------------------
Subprog S_FICREP(VALEUR)
Variable Char    VALEUR()
Call S_FICHIER(VALEUR) From PATCH
End

#--------------------------
Subprog AS_FICREP(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  VALEUR=filpath("tmp","","",[S]nomap,"",adxmac(0))
Endif
End

#--------------------------
Subprog AV_XCRETIM(VALEUR)
Variable Char    VALEUR()
If [M:TFP1]CRETIM=0
  VALEUR=""
Else
  VALEUR=format$("N0:2#",fix([M:TFP1]CRETIM/3600))+format$("N0:2#",mod(fix([M:TFP1]CRETIM/60),60))
Endif
End

#--------------------------
Subprog AV_XUPDTIM(VALEUR)
Variable Char    VALEUR()
If [M:TFP1]UPDTIM=0
  VALEUR=""
Else
  VALEUR=format$("N0:2#",fix([M:TFP1]UPDTIM/3600))+format$("N0:2#",mod(fix([M:TFP1]UPDTIM/60),60))
Endif
End


#----------------------------------------------------------------
# Ecran TFP4
#----------------------------------------------------------------

#--------------------------
Subprog AS_REQOPEITV(VALEUR)
Variable Char    VALEUR()
# Pour annuler filtre en tunnel de l'objet OTI (cas ou 1ère composante de la clé vide)
[V]GBIDC1="TFP_NOFILTRE"
End


#--------------------------
Subprog AS_REQTOPEITV(VALEUR)
Variable Char    VALEUR()
# Pour annuler filtre en tunnel de l'objet OTI (cas ou 1ère composante de la clé vide)
If [M]REQOPEITV<>""
  [V]GBIDC1=[M]REQOPEITV
Else
  [V]GBIDC1="TFP_NOFILTRE"
Endif
End


#----------------------------------------------------------------
# Ecran TFP6
#----------------------------------------------------------------

#--------------------------
Subprog C_TSVGAMVT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Grizo [M]VGAMVT
Else
  Actzo [M]VGAMVT
Endif
End


#----------------------------------------------------------------
# Ecran TFP8
#----------------------------------------------------------------


#--------------------------
Subprog C_TSPZCOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M]PSGZCOD=""
  [M]TSPZOBJ=2
  [M]PSGZOBJ=""
  [M]TSPZTYP=2
  [M]PSGZTYP=""
  Grizo [M]PSGZCOD,TSPZOBJ,PSGZOBJ,TSPZTYP,PSGZTYP
Else
  Actzo [M]PSGZCOD,TSPZOBJ
  If [M]TSPZOBJ=2
    Grizo [M]PSGZOBJ
  Else
    Actzo [M]PSGZOBJ
  Endif
Endif
End


#--------------------------
Subprog C_TSPZOBJ(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M]PSGZOBJ=""
  [M]TSPZTYP=2
  [M]PSGZTYP=""
  Grizo [M]PSGZOBJ,TSPZTYP,PSGZTYP
Else
  Actzo [M]PSGZOBJ,TSPZTYP
  If [M]TSPZTYP=2
    Grizo [M]PSGZTYP
  Else
    Actzo [M]PSGZTYP
  Endif
Endif
End


#--------------------------
Subprog C_TSPZTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M]PSGZTYP=""
  Grizo [M]PSGZTYP
Else
  Actzo [M]PSGZTYP
Endif
End


#--------------------------
Subprog AS_PSGZTYP(VALEUR)
Variable Char    VALEUR()

Global Char GXLISTTYP(10)(200)
Global Integer GXNBTYP

Local Char XZON(20)

Raz [V]GBIDC1,[V]GBIDC2,[V]GBIDC3,[V]GBOUT1

If !clalev([F:GOB]) : Local File GASOBJ  : Endif
If !clalev([F:AOB]) : Local File AOBJET  : Endif
If !clalev([F:ADV]) : Local File ATABTAB : Endif
If !clalev([F:AXX]) : Local File ATEXTRA : Endif
If !clalev([F:ATI]) : Local File ATABIND : Endif
If !clalev([F:ATZ]) : Local File ATABZON : Endif

Read [F:GOB]GOB0=[M]PSGZOBJ
If !fstat
  [V]GBIDC1=[F:GOB]OBJET
  [V]GBIDC2=[F:GOB]LNKOBJ
Endif

If [V]GBIDC1="ADI"
  Read [F:ADV]CODE=val([V]GBIDC2)
  If !fstat
    Read [F:AXX]AXX0=[V]GLANGUE;[F:ADV]DES
    If !fstat
      [V]GBOUT1=[F:AXX]TEXTE
    Endif
  Endif
Elsif [V]GBIDC1<>""
  Read [F:AOB]ABREV=[V]GBIDC1
  If !fstat
    Call TEXTE([F:AOB]LIBEL,[V]GBOUT1) From OBJDIV
  Endif
Endif

Call LISTTYP([M]PSGZCOD,[M]PSGZOBJ,[V]GXLISTTYP,[V]GXNBTYP) From SPVOBJTFP
If [V]GXNBTYP
  Read [F:AOB]ABREV=[V]GBIDC1
  If !fstat
    Read [F:ATI]NUMLIG=[F:AOB]NOMFIC;1
    If !fstat
      If [V]GBIDC2<>""
        [L]XZON=right$([F:ATI]DESCRIPT,instr(1,[F:ATI]DESCRIPT,"+")+1)
      Else
        [L]XZON=[F:ATI]DESCRIPT
      Endif
      Read [F:ATZ]CODZONE=[F:AOB]NOMFIC;[L]XZON
      If !fstat
        [V]GBIDC3="find("+[L]XZON+",[V]GXLISTTYP(0..[V]GXNBTYP-1))"
      Endif
    Endif
  Endif
Else
  [V]GBIDC3="1=0"
Endif

End

