#<AdxTL>@(#)2.0.0.0 $Revision$
#ACV#X12
#TIT#Consultation File d'attente

#==========================================================================================
# Gestion de la consultation : GFA -- File d'attente
#
# Auteur                     :
# Date de création           :
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 28/02/2003    OTHYR        Modélisation Web + ajout PE
#==========================================================================================

Local Char PARAM(30)(2)

Call GCONSULT("GFA","",PARAM)From GCONSULT
End


###################################################################
$ACTION

Case ACTION
    When "AUTORIS"    : Gosub AUTORIS
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "SETBOUT"    : Gosub SETBOUT
    When "FIN_CRIT"   : Gosub FIN_CRIT
Endcase
Return

#-----------------------------------------------------------------#
#    Gestion des étiquettes liées a ACTION                        #
#-----------------------------------------------------------------#
###################################################################
$AUTORIS
Return

###################################################################
$SETBOUT

If [M:GFA2]NBLIG = 0 Then
    Call VIREBOUT(CHAINE,"E") From GCONSULT
Endif

Return

###################################################################
$OUVRE

Local Char    CRIT1(250), CRIT2(250), CRIT3(250), CRITSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG,STAT
Local Char    DEBNUM,FINNUM,DEBRES,FINRES,DEBQUEUE,FINQUEUE
Local Date    DEBDAT,FINDAT

Gosub DEFCRIT

Return

###################################################################
$DEFCRIT

SUITE  = 1
RETOUR = 1
nolign = 1

For I = 1 To dim(PARAM)
    Case I
        When 1 :    : # Parametre Site
            If PARAM(I) <> "" Then
                If [F:FCY]FCY <> PARAM(I) Then
                    Read [F:FCY]FCY0 = PARAM(I)
                    If fstat  Raz [F:FCY] : Endif
                Endif
#                If !fstat & ((PARAM(I) = GFCYDEF & GUSRACC(1) <> 0) | (PARAM(I) <> GFCYDEF & GUSRACC(2) <> 0)) Then
                    [M:GFA1]FCYDEB = PARAM(I)
                    [M:GFA1]FCYFIN = PARAM(I)
                    Call GETDEV([M:GFA1]FCYDEB) From DEVSUB
#                Endif
            Endif
   Endcase
Next

If !find([M:CGFA]TRI,1,2,3,4)      : [M:CGFA]TRI   = 4   : Endif
If !find([M:CGFA]PRIORITY,1,2,3)   : [M:CGFA]TPRIO = 2   : Endif
If !find([M:CGFA]ORIREQ,1,2,3,4,5) : [M:CGFA]TORI  = 2   : Endif

# -- copie de l'écran critères (CGFA) vers le masque 1 (GFA1)
Gosub CRITENT From =PROGCNS

Return

###################################################################
$LECTURE

If [M:GFA1]FCYDEB = "" & [M:GFA1]FCYFIN = "" &
&  [M:GFA1]DATDSDEB = [0/0/0] & [M:GFA1]DATDSFIN = [0/0/0] &
&  [M:GFA1]BPRDEB = "" & [M:GFA1]BPRFIN = "" &
&  [M:GFA1]RESDEB = "" & [M:GFA1]RESFIN = "" &
&  [M:GFA1]REQSTADEB = "" & [M:GFA1]REQSTAFIN = "" &
&  [M:GFA1]QUEUEDEB = "" & [M:GFA1]QUEUEFIN = "" Then
    NBLU = 0
    Return
Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

Call TEMPON("R") From GESECRAN

#-- Positionnement des Filtres
Gosub LOAD_FILTER
# Appel au filtre spécifique client
ACTION = "FILTRE"
Gosub ACTION From XOBJCNS
ACTION = "LECTURE"

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

If CHGPAG > 0 Then
    SUITE = 1
    If CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CGFA]TRI
        When 1 : # tri par numéro
            Filter [F:REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                          Order By Key REQ0
        When 2 : # tri par date
            Filter [F:REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                          Order By Key CLE=[F:REQ]CREADAT;[F:REQ]REQNUM
        When 3 : # tri par responsable
            Filter [F:REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                          Order By Key REQ3
        When 4: # tri par file d'attente

# LBORN 06/09/2017 - Mantis 34517 (index remplacé)
#            Filter [F:REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE)
#&                          Order By Key REQ5
             Filter [F:REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                           Order By QUEUE Asc;INTROW Asc;REQNUM Asc

  Endcase
Else
    RETOUR=1
    If CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CGFA]TRI
        When 1 : # tri par numéro
            Filter [F:REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                          Order By Key REQ0 Desc
        When 2 : # tri par date
            Filter [F:REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                          Order By Key CLE=[F:REQ]CREADAT;[F:REQ]REQNUM Desc
        When 3 : # tri par responsable
            Filter [F:REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                          Order By Key REQ3 Desc
        When 4: # tri par file d'attente

# LBORN 06/09/2017 - Mantis 34517 (index remplacé)
#            Filter [F:REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE)
#&                          Order By Key REQ5 Desc
            Filter [F:REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                          Order By QUEUE Desc;INTROW Desc;REQNUM Desc

  Endcase
Endif

#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:GFA2] : Endif

For [F:REQ]
    Call CTL_AUZFCY([F:REQ]FCY,"GESREQ","M",STAT) From XTRTFCY
    If STAT = 0 Then
        Goto NEX
    Endif

    If NBLU = 1 Then
        If CHGPAG = 2 | CHGPAG = -2 : Raz [M:GFA2] : Endif
        NBLU = 2
    Endif

    If CHGPAG > 0 Then
        If NOL >= MAXLIG-1 : SUITE = 2 : Break : Endif
        NOL += 1
        If NOL = 0 Then
            DEBNUM   = [F:REQ]REQNUM
            DEBDAT   = [F:REQ]CREADAT
            DEBQUEUE = [F:REQ]QUEUE
            DEBRES   = [F:REQ]RESINT
        Endif
        FINNUM   = [F:REQ]REQNUM
        FINDAT   = [F:REQ]CREADAT
        FINQUEUE = [F:REQ]QUEUE
        FINRES   = [F:REQ]RESINT
    Else
        If NOL <= 0 : RETOUR=2 : Break : Endif
        NOL -= 1
        If NOL = MAXLIG-1 Then
            FINNUM   = [F:REQ]REQNUM
            FINDAT   = [F:REQ]CREADAT
            FINQUEUE = [F:REQ]QUEUE
            FINRES   = [F:REQ]RESINT
        Endif
        DEBNUM   = [F:REQ]REQNUM
        DEBDAT   = [F:REQ]CREADAT
        DEBQUEUE = [F:REQ]QUEUE
        DEBRES   = [F:REQ]RESINT
    Endif

    nolign = NOL+1

    [M:GFA2] = [F:REQ]

    [M:GFA2]DATDS(nolign-1) = [F:REQ]CREADAT

$NEX
Next

Filter [F:REQ]

Call TEMPOFF From GESECRAN

Return

###################################################################
$LOAD_FILTER
# Préparation filtre [REQ]
[L]CRIT1   = "1"        :#
[L]CRIT2   = "1"        :#
[L]CRIT3   = "1"        :#
[L]CRITSPE = "1"        :# Critère spécifique client

If [M:GFA1]FCYDEB <> "" | [M:GFA1]FCYFIN <> "" Then
    [L]CRIT1 += "&[F:REQ]FCY>=[M:GFA1]FCYDEB&[F:REQ]FCY<=[M:GFA1]FCYFIN"
Endif
If [M:GFA1]BPRDEB <> "" | [M:GFA1]BPRFIN <> "" Then
    [L]CRIT1 += "&[F:REQ]BPCNUM>=[M:GFA1]BPRDEB&[F:REQ]BPCNUM<=[M:GFA1]BPRFIN"
Endif
If [M:GFA1]REQSTADEB <> "" | [M:GFA1]REQSTAFIN <> "" Then
    [L]CRIT2 += "&[F:REQ]REQSTA>=[M:GFA1]REQSTADEB&[F:REQ]REQSTA<=[M:GFA1]REQSTAFIN"
Endif
If [M:GFA1]QUEUEDEB <> "" | [M:GFA1]QUEUEFIN <> "" Then
    [L]CRIT2 += "&[F:REQ]QUEUE>=[M:GFA1]QUEUEDEB&[F:REQ]QUEUE<=[M:GFA1]QUEUEFIN"
Endif
If [M:GFA1]RESDEB <> "" | [M:GFA1]RESFIN <> "" Then
    [L]CRIT2 += "&[F:REQ]RESINT>=[M:GFA1]RESDEB&[F:REQ]RESINT<=[M:GFA1]RESFIN"
Endif

If [M:GFA1]DATDSDEB <> [0/0/0] Then
    [L]CRIT1 += "&[F:REQ]CREADAT>=[M:GFA1]DATDSDEB"
Endif
If [M:GFA1]DATDSFIN <> [0/0/0] Then
    [L]CRIT1 += "&[F:REQ]CREADAT<=[M:GFA1]DATDSFIN"
Endif

If [M:GFA1]OPPNUM <> "" Then
    [L]CRIT3 += "&[F:REQ]OPPNUM>=[M:GFA1]OPPNUM"
Endif
If [M:GFA1]BDWCOD <> "" Then
    [L]CRIT3 += "&[F:REQ]BDWCOD>=[M:GFA1]BDWCOD"
Endif
If [M:GFA1]PRIORITY <> 0 & [M:GFA1]TPRIO <> 2 Then
    [L]CRIT3 += "&[F:REQ]PRIORITY=[M:GFA1]PRIORITY"
Endif
If [M:GFA1]ORIREQ <> 0 & [M:GFA1]TORI <> 2 Then
    [L]CRIT3 += "&[F:REQ]ORIREQ=[M:GFA1]ORIREQ"
Endif


Case CHGPAG
    When 3 : # rafraichissement
        Case [M:CGFA]TRI
            When 1     : # tri par numéro
                [L]CRIT3 += "&[F:REQ]REQNUM>=DEBNUM"
            When 2     : # tri par date
                [L]CRIT3 += "&[F:REQ]CREADAT>=DEBDAT&[F:REQ]REQNUM>=DEBNUM"
            When 3     : # tri par responsable
                [L]CRIT3 += "&[F:REQ]RESINT>=DEBRES&[F:REQ]REQNUM>=DEBNUM"
            When 4     : # tri par file d'attente
                [L]CRIT3 += "&[F:REQ]QUEUE>=DEBQUEUE&[F:REQ]REQNUM>=DEBNUM"
        Endcase
    When 2 : # suite
        Case [M:CGFA]TRI
            When 1     : # tri par numéro
                [L]CRIT3 += "&[F:REQ]REQNUM>FINNUM"
            When 2     : # tri par date
                [L]CRIT3 += "&[F:REQ]CREADAT>=FINDAT&[F:REQ]REQNUM>FINNUM"
            When 3     : # tri par responsable
                [L]CRIT3 += "&[F:REQ]RESINT>=FINRES&[F:REQ]REQNUM>FINNUM"
            When 4     : # tri par file d'attente
                [L]CRIT3 += "&[F:REQ]QUEUE>=FINQUEUE&[F:REQ]REQNUM>FINNUM"
        Endcase
    When -2 : # retour
        Case [M:CGFA]TRI
            When 1     : # tri par numéro
                [L]CRIT3 += "&[F:REQ]REQNUM<DEBNUM"
            When 2     : # tri par date
                [L]CRIT3 += "&[F:REQ]CREADAT<=DEBDAT&[F:REQ]REQNUM<DEBNUM"
            When 3     : # tri par responsable
                [L]CRIT3 += "&[F:REQ]RESINT<=DEBRES&[F:REQ]REQNUM<DEBNUM"
            When 4     : # tri par file d'attente
                [L]CRIT3 += "&[F:REQ]QUEUE<=DEBQUEUE&[F:REQ]REQNUM<DEBNUM"
        Endcase
Endcase

Return

###################################################################
$FIN_CRIT
Return


#-----------------------------------------------------------------#
#    Gestion des étiquettes liées aux masques GFA1, GFA2 et CGFA  #
#-----------------------------------------------------------------#
###################################################################
Subprog C_FCYFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]FCYDEB Then
    mkstat = 2
Endif
End

###################################################################
Subprog C_BPRFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]BPRDEB Then
    mkstat = 2
Endif
End


###################################################################
Subprog C_RESFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]RESDEB Then
    mkstat = 2
Endif
End

###################################################################
Subprog C_DATDSFIN(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]DATDSDEB Then
    mkstat = 2
Endif
End

###################################################################
Subprog C_REQSTAFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]REQSTADEB Then
    mkstat = 2
Endif
End

###################################################################
Subprog C_QUEUEFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]QUEUEDEB Then
    mkstat = 2
Endif
End

###################################################################
Subprog AM_FCYDEB(VALEUR)
Variable Char    VALEUR()
[M]FCYFIN = VALEUR
End

###################################################################
Subprog AM_BPRDEB(VALEUR)
Variable Char    VALEUR()
[M]BPRFIN = VALEUR
End

###################################################################
Subprog AM_RESDEB(VALEUR)
Variable Char    VALEUR()
[M]RESFIN = VALEUR
End

###################################################################
Subprog AM_DATDSDEB(VALEUR)
Variable Date    VALEUR
[M]DATDSFIN = VALEUR
End

###################################################################
Subprog AM_REQSTADEB(VALEUR)
Variable Char    VALEUR()
[M]REQSTAFIN = VALEUR
End

###################################################################
Subprog AM_QUEUEDEB(VALEUR)
Variable Char    VALEUR()
[M]QUEUEFIN = VALEUR
End

###################################################################
Subprog AM_TPRIO(VALEUR)
Variable Integer VALEUR

If VALEUR = 2 Then
    Grizo [M:CGFA]PRIORITY
Else
    Actzo [M:CGFA]PRIORITY
Endif

End

###################################################################
Subprog AM_TORI(VALEUR)
Variable Integer VALEUR

If VALEUR = 2 Then
    Grizo [M:CGFA]ORIREQ
Else
    Actzo [M:CGFA]ORIREQ
Endif

End

###################################################################
Subprog AS_BPCNUM(VALEUR)
Variable Char     VALEUR
If !GIMPORT Then
    mkstat = 2
Endif
End


#-----------------------------------------------------------------#
#               Gestion des programmes necessaires                #
#-----------------------------------------------------------------#
###################################################################
Subprog SAVEREQ()
Local File REQUEST [ZREQ]

Call DEBTRANS From GLOCK
$TRT1
GOK=1
Trbegin [ZREQ]

For A =0 To [M:GFA2]NBLIG-1
    If [M:GFA2]REQNUM(A) = "" Then
        Break
    Endif
    For [F:ZREQ] Where [F:ZREQ]REQNUM = [M:GFA2]REQNUM(A)
        Readlock [F:ZREQ]REQ0 = [F:ZREQ]REQNUM
        If fstat = 1 Then
            GOK=-1 : GLOCK="REQUEST"-[F:ZREQ]REQNUM
            Rollback
            End
        Elsif fstat Then
            GOK=0
            Call RSTA("ZREQ",[F:ZREQ]REQNUM) From GLOCK
            Rollback
            End
        Endif

        [F:ZREQ]CREADAT = [M:GFA2]DATDS(A)
        [F:ZREQ]QUEUE   = [M:GFA2]QUEUE(A)
        [F:ZREQ]RESINT  = [M:GFA2]RESINT(A)
        [F:ZREQ]BPAADD  = [M:GFA2]BPAADD(A)
        [F:ZREQ]MAXDAT  = [M:GFA2]MAXDAT(A)
        [F:ZREQ]MAXTIM  = [M:GFA2]MAXTIM(A)
        [F:ZREQ]INTDAT  = [M:GFA2]INTDAT(A)
        [F:ZREQ]INTROW  = [M:GFA2]INTROW(A)

        Rewrite [ZREQ]
        If fstat Then
            GOK=0
            Call FSTA("ZREQ") From GLOCK
            Rollback
            End
        Endif
    Next
Next

Commit

End

