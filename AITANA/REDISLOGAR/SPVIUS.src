CLE1=""
GBIDC1=""
GBIDC2=""
Call OBJET("AUS",GBIDC1,GBIDC2) From GOBJET
End


$ACTION

# Appel fonctions complémentaires GFI pour l'objet FRL
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "FILTRE" : Gosub FILTRE From SPVOBJIUS
Endcase

Return
