#<AdxTL>@(#)5.0.0.0 $Revision$
#ACV#X11
#TIT#GÃĐnÃĐration en lot des transactions de saisie PSA

#==========================================================================================
# Gestion de l'objet   : ModÃĻle de traitement standard pour les modes intÃĐractif et serveur
#                        --> Pour le mode serveur, il faut impÃĐrativement :
#                        * CrÃĐer une fonction pour brancher cette action et renseigner ses paramÃĻtres
#                        * CrÃĐer une tÃĒche
#
# Auteur               : Cperr
# Date de crÃĐation     : Le 20/02/2003
# Modifs OTHYR pour gestion des codes activitÃĐs prÃĐsents, le 24.08.2006
#==========================================================================================
Local Char PARAM(15)(10),VALEUR(10)
PARAM(0)=""
PARAM(1)=""
PARAM(2)=""
PARAM(3)=""

Call TRAITE_CHAR(VALEUR,PARAM,"","XTRTWPSA","DDOSWPSA",4) From GTRAITE    :# Appel avec ouverture de la fenetre
End

################################
$ACTION

Case ACTION
    When "INIT"      : Gosub INIT
    When "AVANT_PAR" : Gosub AVANT_PAR
    When "CONTROLE"  : Gosub CONTROLE
    When "EXEC"      : Gosub EXEC
    When "TERMINE"   : Gosub TERMINE
    When "SORTIE"    : Gosub SORTIE
    When Default :
        Case BOITE
            When "DDOSWPSA" : Gosub FEN_CRIT
            When Default
        Endcase
Endcase

Return

###############################
$FEN_CRIT

Case ACTION
    When "DEBUT" : Gosub D_DEBUT
    When "END"   : Gosub D_FIN
    When "OK"    : Gosub D_OK
Endcase

Return

###############################
$INIT

Local File PSATRS [PST]
Local Mask PST0 [PST0]

#Gestion des erreurs
Onerrgo ERR_PRG
# DÃĐcalartion des variables pour la gestion de la trace
Gosub INIT_TRACE
TIT=mess(322,GXMSGPSA,1)-format$("D:DD[/]MM[/]YYYY",date$)-time$

Return

###############################
$AVANT_PAR
Return

###############################
$CONTROLE
    If ![V]GSERVEUR
        TMP=1
    Endif
Return

###############################
$EXEC

    If GOK
        Gosub OUV_TRACE
        For J=1 To 7
            If PARAM(J)="2" & J=1
              # Parc matÃĐriel (standard Sage)
              Call PATCH(nomap) From SUBCMA
            Elsif PARAM(J)="2" & J=7
              # Ecrans de consultation (visas CRA)
                Call VALGTC(nomap,"VGS") From SUBGTC
            Elsif PARAM(J)="2"
                Trbegin ADOVAL
                For [F:PST]PST0 Where [F:PST]PTRTYP=J
                    [M:PST0]PTRNUM=[F:PST]PTRNUM
                    [M:PST0]PTRTYP=[F:PST]PTRTYP
                    If [L]J=7
                      If [F:PST]ENAFLG=2
                        Call VALIDATION("VGS",[M:PST0]PTRNUM,nomap,0) From SUBGTC
                      Endif
                    Else
                      Gosub TRT_ECRAN From XTRPSA
                      If !GOK Then
                        GMESSAGE=mess([M:PST0]PTRTYP,1781,1)-[M:PST0]PTRNUM
                        Gosub ERR_TRACE
                        Break
                      Else
                        GMESSAGE=mess([M:PST0]PTRTYP,1781,1)-[M:PST0]PTRNUM
                        Gosub MSG_TRACE
                      Endif
                    Endif
                Next
                If GOK Then
                    Commit
                Else
                  Rollback
                Endif
            Endif
        Next
    Else
        FIN=1
    Endif

Return

###############################
$TERMINE
    If ![V]GSERVEUR
        GMESSAGE=mess(322,GXMSGPSA,1)-format$("D:DD[/]MM[/]YYYY",date$)-time$
        Gosub MSG_TRACE
        TRA=1 # Ouvre la trace. TRA=0 pour fermer la trace
        TMP=0 # Ferme le message Tempon.
    Endif

Return

###############################
$SORTIE
Onerrgo

    Close Local File [F:PST]
    Close Local Mask [M:PST0]
Return

###############################
$D_DEBUT
    Raz [M:DIA]
    Affzo [M:DIA]
Return

###############################
$D_OK

FIN = 1
GOK = 1

# [M]MCT = Parc matÃĐriel = X11, donc pas besoin de tester
If dim([M]MCT)>0
  PARAM(1) = num$([M]MCT)
Endif

# [M]OPT = Affaire = X16
If [V]GXOPTOPP Then
  PARAM(2) = num$([M]OPT)
Else
  PARAM(2) = "0"
Endif

# [M]CTR = Contrat = X15
If [V]GXOPTCON Then
  PARAM(3) = num$([M]CTR)
Else
  PARAM(3) = "0"
Endif

# [M]RQT = Demande de service = X12
# [M]ITT = Intervention = X12
If [V]GXOPTACT Then
  PARAM(4) = num$([M]RQT)
  PARAM(5) = num$([M]ITT)
  PARAM(6) = num$([M]ITL)
  PARAM(7) = num$([M]VGS)
Else
  PARAM(4) = "0"
  PARAM(5) = "0"
  PARAM(6) = "0"
  PARAM(7) = "0"
Endif

Return

##############################
$D_FIN
    FIN=1
    GOK=0
Return

#-----------------------------------------------------------------------
# Outils de gestion pour le fichier Trace :
# --> DÃĐclaration des variables de gestion de trace
# --> CrÃĐation d'une trace si aucune n'est ouverte ( Ã  brancher dans dans $EXEC )
# --> Routine de redirection pour les erreurs de traitement ( Ã  brancher dans $INIT )
# --> Ecriture d'un message d'erreur dans la trace ( Ã  brancher lorqu'on dÃĐsire ÃĐcriture une erreur dans la trace )
# --> Ecriture d'un message d'inforamtion dans le trace ( Ã  brancher lorqu'on dÃĐsire ÃĐcriture un message dans la trace )
#-----------------------------------------------------------------------

######################################
$INIT_TRACE
# Varibales pour la gestion de la trace

Local    Char        XTRACE
Local    Integer     XTRAOUV, XSTAT  #flag permettant de savoir si un fichier trace est deja ouvert
Return

######################################
$OUV_TRACE
# Ouvre un fichier trace, si celui-ci n'existe pas en mode intÃĐractif
# Imprime les bornes de sÃĐlection saisies dans la fenÃŠtre de critÃĻres

[L]XTRAOUV=1
If !GSERVEUR & [V]GTRACE=""
   Call OUVRE_TRACE(TIT) From LECFIC
   [L]XTRACE=filpath("TRA",[V]GTRACE,"tra","","",adxmac(0))
   [L]XTRAOUV=0
Endif
Call PRTSCR("DOSWPSA","DIA","",0,1) From ATRTX3
Return

######################################
$ERR_PRG
# Gestion des erreurs standards redirigÃĐes en mode interactif

Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN

# Force la fermeture du message tempon
# Force aussi la fermeture du fichier trace
# Force enfin l'affichage Ã  l'ÃĐcran du fichier trace
If !GSERVEUR
    [L]XSTAT=1
    Call FERME_BOITE From GESECRAN
    # Lecture du fichier trace
    Openo XTRACE
    Call LEC_TRACE From LECFIC
Else
    GERR=1
Endif

End

######################################
$ERR_TRACE
# Affiche un message d'erreur dans la trace.
# Pour cela, il faut alimenter la variable GMESSAGE avant d'appeller cette routine

Call REMPCH([V]GMESSAGE,"\"," - ") From XBIBCH : # Pour ÃĐviter que le Std compte l'erreur 2 fois dans [V]GERRTRACE
Call ECR_TRACE([V]GMESSAGE,1) From GESECRAN
GERR=1
Raz [V]GMESSAGE
Return

######################################
$MSG_TRACE
# Affiche un message d'information dans la trace.
# Pour cela, il faut alimenter la variable GMESSAGE avant d'appeller cette routine

Call ECR_TRACE([V]GMESSAGE,0) From GESECRAN
Return
