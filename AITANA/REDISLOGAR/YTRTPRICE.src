#####################################################################################
# CODACT: YA019 - Campo de referencia de oferta
#####################################################################################
#####################################################################################
#Fecha: 20/06/2019
#Desarrollador: ALIVE
#Marca: <YA055>
#Subir a 8 decimales el cálculo de los precios unitarios
#####################################################################################
$ACTION
Case ACTION
  When "CPLTARIF"     : Gosub CPLTARIF
  When "CALNET"       : Gosub CALNET
Endcase
Return
#####################################################################################
$CPLTARIF

If TRAIT = 'POH'

  If clalev ([F:YPPL])  = 0 : Local File PPRICLIST  [YPPL] : Endif
  Read [F:YPPL]PPL0 = PLI(0);PLICRD(0);PLILIN(0)
  If fstat = 0
    # Pasamos a la línea de pedido de compra, la refeerncia que encontramos en la tarifa.
    [M:POH2]YQOTREF(nolign -1) = [F:YPPL]YQOTREF
    Affzo [M:POH2]YQOTREF(nolign -1)
  Endif

  #Infbox(num$(PLI(0)) - num$(PLICRD(0)) - num$(PLILIN(0)))
Endif
Return

#####################################################################################
#<YA055>
$CALNET
  ### Evitamos el redondeo del precio neto
  GPE_RND = 1
Return
#<\YA055>

