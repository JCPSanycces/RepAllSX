Local Char VALBOUT(250) , PARBOUT(250)(1..20)
PARBOUT(1) = "AFF1002SAL00001"
PARBOUT(1)="AFF1001LYO00001"
PARBOUT(1)="AFF1004LYO00003"
PARBOUT(1)="AFF1002SFR00001"
PARBOUT(1)="AFF1006LYO00006"
#Raz PARBOUT
GACTION = "XSITUATION"
Call SAISIE_CHAR(VALBOUT,PARBOUT,"XSITUAG","XSITUAG","YSITUAG") From GSAISIE
End

#########################################################################################

$ACTION
Case ACTION
  When "INIT"       : Gosub INIT      From XINFOSIT2
  When "AVANT_PAR"  : Gosub AVANT_PAR From XINFOSIT2
  When "OK"         : Gosub OK        From XINFOSIT2
  When "DEBUT"      : Gosub DEBUT     From XINFOSIT2
Endcase
Return

