#<AdxTL>@(#)11.0.0.0 $Revision:   1.20  $ Gestion du masque CONSGFP1
#ACV#X11
#TIT#Consultation des factures lié à une affaire

Local Char PARAM(20)(1..3)
PARAM(1) = "0"
PARAM(2) = "GAL"
PARAM(3) = ""
Call GCONSULT("GFP","",PARAM) From GCONSULT
End

$ACTION

Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
 When default
Endcase
Return

############################################################
$AUTORIS
Return
############################################################
$SETBOUT
Return

###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
Local Char    WFIL(250),WFIL1(250),WFIL2(250), CRITSPE(250)
Local Char    DEBNUM, FINNUM
Local Date    DEBDAT, FINDAT

If clalev([F:DUD])=0 Local File GACCDUDATE [DUD] : Endif
If clalev([F:TCU])=0 Local File TABCUR [TCU]  : Endif

Gosub DEFCRIT
[M:GFP1]CURD=GSYSCUR
Return
# --------------------------------------------------------------------------#
# Analyse paramères, initialisations                                        #
# --------------------------------------------------------------------------#
$DEFCRIT
If [M:GFP1]SALFCY<>"" & GUSRFCY(1)<>"\" & !find([M:GFP1]SALFCY,GUSRFCY(1..GNBAUZ))
 [M:GFP1]SALFCY=""
Endif

For I = 1 To dim(PARAM)
  Case I  
    When 1 :    : # Parametre Affaire
      If PARAM(I) <> ""
          Call LECTURE("OPP",PARAM(I),"")From CONTOBJ
          If !fstat
              [M:GFP1]OPPNUM = PARAM(I)
          Endif   
      Endif

    When 2 :    : # Parametre Site
      If PARAM(I) <> "" 
        If [F:FCY]FCY <> PARAM(I) Then   
            Read [F:FCY]FCY0 = PARAM(I)
            If fstat  Raz [F:FCY] : Endif
        Endif
#        If !fstat & ((PARAM(I) = GFCYDEF & GUSRACC(1) <> 0) | (PARAM(I) <> GFCYDEF & GUSRACC(2) <> 0)) Then
         If !fstat & (PARAM(I) = GFCYDEF | PARAM(I) <> GFCYDEF ) Then
            [M:GFP1]SALFCY = PARAM(I) 
            Call GETDEV([M:GFP1]SALFCY) From DEVSUB
            [M:GFP1]CPY    = GSOCIETE
            [M:GFP1]CURS   = GLOCALDEV
        Endif
      Endif
  Endcase
Next I   

If !find([M:GFP1]INVTYPFAC,1,2) : [M:GFP1]INVTYPFAC = 2 : Endif
If !find([M:GFP1]INVTYPAVO,1,2) : [M:GFP1]INVTYPAVO = 2 : Endif
If !find([M:GFP1]INVTYPPRF,1,2) : [M:GFP1]INVTYPPRF = 2 : Endif
If !find([M:GFP1]INVSTAO,1,2)   : [M:GFP1]INVSTAO = 2 : Endif
If !find([M:GFP1]INVSTAN,1,2)   : [M:GFP1]INVSTAN = 2 : Endif

If !find([M:CGFP]ORIMODVEN,1,2) : [M:CGFP]ORIMODVEN = 2 : Endif
If !find([M:CGFP]ORIMODTIE,1,2) & clalev([M:BPC0]) 
    [M:CGFP]ORIMODTIE = 2 
Else
    [M:CGFP]ORIMODTIE = 1
Endif
If !find([M:CGFP]TRI,1,2)    : [M:CGFP]TRI = 1   : Endif

# -- copie de l'écran critères (CGFP) vers le masque 1 (GFP1)
Gosub CRITENT From =PROGCNS

Return

############################################################
$LECTURE
Local   Decimal  WMNTORG(0..5), WMNTDES(0..5)
Local   Integer  SPSTAT

If [M:GFP1]CPY="" & [M:GFP1]SALFCY=""
 NBLU=0 : Return
Endif

Gosub CHANGE_MSK From GCONSULT 
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
# Appel au filtre spécifique client
ACTION = "FILTRE"
Gosub ACTION From XOBJCNS
ACTION = "LECTURE"

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CGFP]TRI
      When 1 : # tri par numéro
        Filter [SIH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SIH0
      When 2 : # tri par date
        Filter [SIH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) 
&                    Order By Key CLE=[F:SIH]BPRDAT;[F:SIH]NUM
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CGFP]TRI
      When 1 : # tri par numéro
        Filter [SIH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SIH0 Desc
      When 2 : # tri par date
        Filter [SIH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) 
&                    Order By [F:SIH]BPRDAT Desc ;[F:SIH]NUM Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:GFP2] : Endif

#-- lecture 
$BOUCLE
For [SIH]

Read [SIV] SIV0=[F:SIH]NUM
If fstat & [F:SIH]ORIMOD=5 
    Goto SUIV  
Elsif !fstat & [M:GFP1]OPPNUM<>"" & [F:SIV]PJT<>[M:GFP1]OPPNUM
    Goto SUIV
Else
Endif 

# Filtre sur la société
  If [M:GFP1]CPY <> "" & ([M:GFP1]CPY <> [F:SIH]CPY) Goto SUIV : Endif

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:GFP2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1 
     If NOL=0 
         DEBNUM = [F:SIH]NUM 
         DEBDAT = [F:SIH]BPRDAT
     Endif
     FINNUM = [F:SIH]NUM
     FINDAT = [F:SIH]BPRDAT
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1 
     If NOL=MAXLIG-1 
         FINNUM = [F:SIH]NUM 
         FINDAT = [F:SIH]BPRDAT
     Endif
     DEBNUM = [F:SIH]NUM
     DEBDAT = [F:SIH]BPRDAT
  Endif

  nolign = NOL+1
  [M:GFP2]ORIMOD(nolign-1)     = [F:SIH]ORIMOD
  [M:GFP2]NUM(nolign-1)        = [F:SIH]NUM
  [M:GFP2]OPPNUM(nolign-1)     = [F:SIV]PJT
  [M:GFP2]BPCINV(nolign-1)     = [F:SIH]BPR
  [M:GFP2]INVDAT(nolign-1)     = [F:SIH]BPRDAT
  [M:GFP2]INVTYP(nolign-1)     = [F:SIH]INVTYP
  [M:GFP2]INVSTA(nolign-1)     = [F:SIH]STA
  [M:GFP2]AMTATI(nolign-1)     = [F:SIH]AMTATI
  [M:GFP2]CUR(nolign-1)        = [F:SIH]CUR

  Raz WMNTORG
  WMNTORG (0) = [F:SIH]AMTATI
#    Recherche du montant réglé
  For [DUD]DUD0 Where TYP=[F:SIH]GTE & NUM=[F:SIH]NUM
      WMNTORG (1) += [F:DUD]PAYCUR
  Next
  [M:GFP2]AMTPAY(nolign-1)    = WMNTORG (1)
#    Calcul des montants en devise société
  If [F:SIH]CUR <> [M:GFP1]CURS
      Call CONVERT2_TAB([F:SIH]CUR, [M:GFP1]CURS, [M:GFP1]CURS, [F:SIH]CURTYP, date$, WMNTORG, WMNTDES,SPSTAT) From TRTDEV
      If [F:TCU]CUR <> [M:GFP1]CURS
         Read [F:TCU]TCU0 = [M:GFP1]CURS
         If fstat Raz [F:TCU] : Endif
      Endif
      [M:GFP2]AMTATISOC(nolign-1)  = arr(WMNTDES(0),[F:TCU]CURRND)
      [M:GFP2]AMTPAYSOC(nolign-1)  = arr(WMNTDES(1),[F:TCU]CURRND)
  Else
      [M:GFP2]AMTATISOC(nolign-1)  = WMNTORG (0)
      [M:GFP2]AMTPAYSOC(nolign-1)  = WMNTORG (1)
  Endif
#    Calcul des montants en devise dossier
  If [F:SIH]CUR <> [M:GFP1]CURD
      Call CONVERT2_TAB([F:SIH]CUR, [M:GFP1]CURD, [M:GFP1]CURS, [F:SIH]CURTYP, date$, WMNTORG, WMNTDES,SPSTAT) From TRTDEV
      If [F:TCU]CUR <> [M:GFP1]CURD
         Read [F:TCU]TCU0 = [M:GFP1]CURD
         If fstat Raz [F:TCU] : Endif
      Endif
      [M:GFP2]AMTATIDOS(nolign-1)  = arr(WMNTDES(0),[F:TCU]CURRND)
      [M:GFP2]AMTPAYDOS(nolign-1)  = arr(WMNTDES(1),[F:TCU]CURRND)
  Else
      [M:GFP2]AMTATIDOS(nolign-1)  = WMNTORG (0)
      [M:GFP2]AMTPAYDOS(nolign-1)  = WMNTORG (1)
  Endif
  If [F:SIH]ORIMOD=5 [M:GFP2]BPCGRU(nolign-1) = [F:SIV]BPCGRU Endif
  [M:GFP2]BPRPAY(nolign-1)    = [F:SIH]BPRPAY
  [M:GFP2]PTE(nolign-1)       = [F:SIH]PTE
  [M:GFP2]STRDUDDAT(nolign-1) = [F:SIH]STRDUDDAT
  [M:GFP2]SALFCY(nolign-1)    = [F:SIH]FCY

 
  $SUIV  
Next
Filter [SIH]

Return
############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"
CRITSPE="1"
If [M:GFP1]SALFCY <> ""
    WFIL += "&[F:SIH]FCY=[M:GFP1]SALFCY"
Endif
#    Autorisation site
If GUSRFCY(1)<>"\" & [M:GFP1]SALFCY <> "" & GNBAUZ<>GNBSITE
 WFIL += "& find([F:SIH]FCY,GUSRFCY(1..GNBAUZ))"
Endif

WFIL += "&[F:SIH]INVTYP<>3 & [F:SIH]INVTYP<>4"
# Prise en compte des factures
# --> Si 1 (Non) On exclut les factures
If [M:GFP1]INVTYPFAC = 1
   WFIL += "&[F:SIH]INVTYP<>1"
Endif
# Prise en compte des avoirs
# --> Si 1 (Non) On exclut les avoirs
If [M:GFP1]INVTYPAVO = 1
   WFIL += "&[F:SIH]INVTYP<>2"
Endif
# Prise en compte des proformas
# --> Si 1 (Non) On exclut les proformas
If [M:GFP1]INVTYPPRF = 1
   WFIL += "&[F:SIH]INVTYP<>5"
Endif
# Prise en compte des factures validées
# --> Si 1 (Non) On exclut les factures validées
If [M:GFP1]INVSTAO = 1
   WFIL += "&[F:SIH]STA<>3"
Endif
# Prise en compte des factures non validées
# --> Si 1 (Non) On exclut les factures non validées
If [M:GFP1]INVSTAN = 1
   WFIL += "&[F:SIH]STA>2"
Endif
# Prise en compte des factures vente
# --> Si 1 (Non) On exclut les factures vente
If [M:CGFP]ORIMODVEN = 1
   WFIL += "&[F:SIH]ORIMOD<>5"
Endif
# Prise en compte des factures tiers
# --> Si 1 (Non) On exclut les factures tiers
If [M:CGFP]ORIMODTIE = 1
   WFIL += "&[F:SIH]ORIMOD<>3"
Endif
If [M:CGFP]NUMDEB <> ""
   WFIL += "&[F:SIH]NUM>=[M:CGFP]NUMDEB"
Endif
If [M:CGFP]NUMFIN <> ""
   WFIL += "&[F:SIH]NUM<=[M:CGFP]NUMFIN"
Endif

If [M:CGFP]INVDATDEB <> [0/0/0]
   WFIL += "&[F:SIH]BPRDAT>=[M:CGFP]INVDATDEB"
Endif
If [M:CGFP]INVDATFIN <> [0/0/0]
   WFIL += "&[F:SIH]BPRDAT<=[M:CGFP]INVDATFIN"
Endif

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CGFP]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SIH]NUM>=DEBNUM"
       When 2 : # tri par date
           WFIL1 += "&([F:SIH]BPRDAT>DEBDAT | ([F:SIH]BPRDAT=DEBDAT & [F:SIH]NUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CGFP]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SIH]NUM>FINNUM"
       When 2 : # tri par date
           WFIL1 += "&([F:SIH]BPRDAT>FINDAT | ([F:SIH]BPRDAT=FINDAT & [F:SIH]NUM>FINNUM))"
     Endcase
   When -2 : # retour
     Case [M:CGFP]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SIH]NUM<DEBNUM"
       When 2 : # tri par date
           WFIL1 += "& ([F:SIH]BPRDAT<DEBDAT | ([F:SIH]BPRDAT=DEBDAT & [F:SIH]NUM<DEBNUM))"
     Endcase
Endcase

Return

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT


Return

#############################################################################
##     Etiquettes masques CONSGFP1 & CONSGFP2 & CRITGFP                    ##
#############################################################################
############################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  [M]CURS = [F:CPY]ACCCUR
Elsif [M]SALFCY = ""
  GERR=2 : GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
  Raz [M]CURS
Endif
Affzo [M]CURS
End
############################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
# -- Controle autorisation sur le site
    If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
        GMESSAGE=VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        mkstat=2 : End
    Endif
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE 
    [M]CURS = GLOCALDEV
    Affzo [M]CPY, ZCPY, CURS
Elsif [M]CPY = ""
    GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    mkstat = 2
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif

End
########################################
Subprog IB_NBLIG
If [M]ORIMOD(nolign-1)=5
    GBOUT1 = mess(193, 198,1) : Raz GBOUT2
Else
    GBOUT2 = mess(193, 198,1) : Raz GBOUT1
Endif
End
########################################
Subprog AM_NUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]NUMFIN= VALEUR : Endif
End

########################################
Subprog AM_INVDATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M]INVDATFIN= VALEUR : Endif
End



