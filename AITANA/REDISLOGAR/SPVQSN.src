$MAIN
#  Errbox num$(func FACTORIEL(10))
#Local Char HM
 
#HM=func SPEQSN.HEURE(func FACTORIEL(10))
#Errbox HM

#Call MESSAGE(func SPEQSN.HEURE(func FACTORIEL(10))) From GESECRAN
#End

GBIDC1=""
GBIDC2=""
GFONC1="GESQSN"
Call OBJET("QSN",GBIDC1,GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet QSN
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "INICRE"  :  Gosub INICRE     From SPVOBJQSN
  When "INIMOD"  :  Gosub INIMOD     From SPVOBJQSN
  When "CHANGE"  :  Gosub CHANGE     From SPVOBJQSN
  When "SETBOUT"   : Gosub SETBOUT   From SPVOBJQSN
  When "SEL_LISTE" : Gosub SEL_LISTE From SPVOBJQSN
Endcase

Return

########################################
Subprog C_CODQUS(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char TABLO(20)(100)

For I=0 To [M]NBLIG-1
   TABLO(I) = [M]CODQUS(I)
Next I
  
Call UNICITE(VALEUR,TABLO) From OBJDIV

End

########################################
Subprog D_LIBQSNSHO(VALEUR)
Variable Char     VALEUR
# LBORN 19/12/2006 - On teste valeur, sinon bug chargement (la designation longue est chargée au lieu
# de la désignation courte)
If VALEUR=""
  VALEUR=[M:QSN]LIBQSN
Endif
End

########################################
Subprog D_TRTSPE(VALEUR)
Variable Char    VALEUR()
VALEUR="YQSN"+left$([M]CODQSN,min(6,len([M]CODQSN)))
End

########################################
Funprog FACTORIEL(X)
Value Integer X
Local Integer Y
  If X > 0
    Y=X*func FACTORIEL(X-1)
  Else
    Y=1
  Endif
End Y

########################################
Funprog HEURE(X)
Value Integer X
Local Char HM
Local Char H
Local Char M
Local Char S

H=num$(int(X/3600))
M=num$(int(mod(X,3600)/60))
S=num$(mod(mod(X,3600),60))
HM=right$("0"+H,len(H))+right$("0"+M,len(M))+right$("0"+S,len(S))
End HM
