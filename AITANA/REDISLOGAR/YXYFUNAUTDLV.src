#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################################################
# Program Name: YXYFUNAUTDLV
# Description : Specific Processing - Order Delivery Generation
# Author      :
# Date        : AUG 29th, 2018
######################################################################################

$ACTION
 Case ACTION
  When "EXEC"        : Gosub EXEC
  When "TERMINE"     : Gosub TERMINE
  When default
 Endcase
Return

$EXEC
If func AFNC.PARAM("ZAPPSDH",[F:SDH]STOFCY)<>"1"
 If dim(ZDLVARR)> 0 : Kill ZDLVARR : Endif
 If dim(ZDLVARRCNT)> 0 : Kill ZDLVARRCNT : Endif
 Global Char ZDLVARR(50)(0..)
 Global Integer ZDLVARRCNT
Endif
Return

$TERMINE
If func AFNC.PARAM("ZAPPSDH",[F:SDH]STOFCY)<>"1"
 Gosub TERMINE_TRTAUTDLV From FUNAUTDLV
 Local Char PATH1(250),ZPATH(250),URL(250),HEADER(250)
 Call SET_FICNAM(PATH1,ZPATH,URL) From ORDSYS
 Openo ZPATH Using [FACS]
 
 HEADER = ""
 For I = 0 To ZDLVARRCNT-1
  HEADER = "H;"+ ZDLVARR(I) + chr$(13)
  Wrseq HEADER  Using [FACS]
 Next
 
 Openo Using [FACS]
 Call LEC_TRACE() From LECFIC
 GWEBSERV = 1
 Call IMPORTSIL("YPOCSDH",ZPATH) From GIMPOBJ
 If dim(ZSTAT) < 0 : Local Integer ZSTAT : Endif :  ZSTAT = 0
 Call SYSTEME(adxmac(1),'ae_rm ' + ZPATH, "",ZSTAT) FROM ORDSYS
 GWEBSERV = 0
 GPE = 1
Endif
Return








