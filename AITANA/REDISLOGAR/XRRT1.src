#<AdxTL>@(#)5.0.0.0 $Revision$
#ACV#X12
#TIT#Recherche DS encours

GBIDC1=""
GBIDC2=""
GFONC1="GESREQ"
Call OBJET("REQ",[V]GBIDC1,[V]GBIDC2)From GOBJET
End

#===============================================================================
# Gestion de l'objet   : -
# Date de création     : 28.09.06
#===============================================================================
# Modifications significatives
#-------------------------------------------------------------------------------
# Date          Auteur       Description
#-------------------------------------------------------------------------------
#===============================================================================

$ACTION
Return

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
Subprog XRRT1()

#Création d'un critere de filtre des DS

Local Char    TIT   : TIT=mess(18,1823,1) #"Recherche DS"
Local Integer REP   : Raz REP
Local Inpbox  "XRRT1"
&From GFONCTION
&At    ""
&With  ""
&Mask  "XRRT1"
&As    [XRR1]
Titled [XRR1] TIT
Boxact [XRR1]
Raz    [M:XRR1]
Affzo  [M:XRR1]
Boxinp [XRR1] Using REP
Case REP
When 4, 1801 : #<Entrée> ou Bouton 'OK' (spé)
               Gosub LOOKUP
Endcase
Close Local Inpbox [XRR1]
End

################################################################################
$LOOKUP
Gosub DECVAR
Gosub INIVAR
Gosub TRT    : If GOK=0 Then Goto FIN_LOOKUP Endif
$FIN_LOOKUP
Gosub CLOVAR
End

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$DECVAR
Local Char    TDBA
Local Char    RQ(255)(1..9)
Local Integer II
Local Integer NBPAR
Return

################################################################################
$CLOVAR
Return

################################################################################
$INIVAR
Raz TDBA, RQ, NBPAR
Case GTYPDBA
When 1 : TDBA="3"
When 2 : TDBA="5"
When 3 : TDBA="2"
When 4 : TDBA="4"
Endcase
GOK=1
Return

################################################################################
$TRT
RQ(1) ="select   req.REQNUM_0"
&     -"from     REQUEST req"
RQ(2)-="where    1=1 and req.FLGREQCLO_0 != 2 and req.FLGREQCAN_0 != 2"
Gosub MAJFILTRE : If NBPAR=0 Then Goto FIN_TRT Endif
RQ(3) ="order by req.REQNUM_0"
#---------
Raz II
If dim(GXRRTFLG)>0 & dim(GXRRTLIS)>0 Then Raz GXRRTFLG, GXRRTLIS Endif

#*RQ Prévoir PE

For (Char REQNUM(100))From TDBA Sql RQ(1..9) As [WSQL]
  If dim(GXRRTLIS)>0 & nolign>dim([V]GXRRTLIS) Then Break Endif

  #*RQ Prévoir PE

  If dim(GXRRTLIS)>0 & !find([F:WSQL]REQNUM,[V]GXRRTLIS)Then
      [V]GXRRTLIS(II)=[F:WSQL]REQNUM
  Endif
  II+=1
Next
$FIN_TRT
GMESSAGE=mess(19,1823,1) #"Aucun résultat"

#*RQ Prévoir PE

If II>0 Then
    If dim(GXRRTFLG)>0 Then
        [V]GXRRTFLG=2
    Endif
Elsif GMESSAGE<>""
    Call ECR_TRACE(GMESSAGE,1)From GESECRAN
Endif
Raz GMESSAGE
Return


################################################################################
$MAJFILTRE
#Mettre à jour la variable RQ(2) (/!\ ini à '1=1')
#Ex. RQ(2)-="and BPR.BPRNUM_0 like 'B%'"
If [M:XRR1]BPRNUM<>"" Then
  NBPAR+=1
  RQ(2)-=string$(RQ(2)<>"","and")-"upper(req.BPCNUM_0) like upper('"+ctrans([M:XRR1]BPRNUM,"*","%")+"')"
Endif
If [M:XRR1]REQTYP<>"" Then
  NBPAR+=1
  RQ(2)-=string$(RQ(2)<>"","and")-"upper(req.REQTYP_0) like upper('"+ctrans([M:XRR1]REQTYP,"*","%")+"')"
Endif
If [M:XRR1]FCY<>"" Then
  NBPAR+=1
  RQ(2)-=string$(RQ(2)<>"","and")-"upper(req.FCY_0) like upper('"+ctrans([M:XRR1]FCY,"*","%")+"')"
Endif
If [M:XRR1]CREADAT<>[0/0/0] Then
    NBPAR+=1
    Case GTYPDBA
    When 1 : #Oracle
             RQ(2)-=string$(RQ(2)<>"","and")-"req.CREADAT_0 = to_date('"+right$(num$([M:XRR1]CREADAT),7)
&                                                                       +mid$(num$([M:XRR1]CREADAT),4,2)
&                                                                       +left$(num$([M:XRR1]CREADAT),2)
&                                                                       +"','YYYYMMDD')"
    When 2 : #SQL
             


    When Default
    Endcase
Endif
If [M:XRR1]CONREV<>"" Then
  NBPAR+=1
  RQ(2)-=string$(RQ(2)<>"","and")-"upper(req.CONREV_0) like upper('"+ctrans([M:XRR1]CONREV,"*","%")+"')"
Endif
If [M:XRR1]OPPNUM<>"" Then
  NBPAR+=1
  RQ(2)-=string$(RQ(2)<>"","and")-"upper(req.OPPNUM_0) like upper('"+ctrans([M:XRR1]OPPNUM,"*","%")+"')"
Endif
Return



