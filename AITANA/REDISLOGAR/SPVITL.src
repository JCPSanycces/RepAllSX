################################################################################
Subprog AM_IUSCOD(VALEUR)
Variable Char    VALEUR()
###
[M:ITL0]IUSCOD=VALEUR
###
Gosub BOUCLE_SUP
End
########################################
$BOUCLE_SUP
For nolign=1 To [M:ITL1]NBLIG
    Gosub SUPERIEURS From SPVITL
Next
If !GIMPORT Then Affzo [M:ITL1] Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran ITVLOT1) 31/10/2008 16:37:21 (LBORN)
######################################################################################
Subprog AS_CURPUR(VALEUR)
Variable Char    VALEUR()
Local Integer FLGMOD

If VALEUR=""
  If [M:ITL1]BPSNUM(nolign-1)<>""
    If !clalev([F:BPR]) : Local File BPARTNER : Endif
    Read [F:BPR]BPR0=[M:ITL1]BPSNUM(nolign-1)
    If !fstat & [F:BPR]CUR<>""
      VALEUR=[F:BPR]CUR
    Elsif [M:ITL1]CUR(nolign-1)<>""
      VALEUR=[M:ITL1]CUR(nolign-1)
    Else
      VALEUR=[F:REQ]CURINV
    Endif
  Else
    VALEUR=[M:ITL1]CUR(nolign-1)
  Endif
Endif

Call VAL_FLGMOD([M:ITL1]CODOPE(nolign-1),[M:ITL1]ITVTYP(nolign-1),"CURPUR",[L]FLGMOD) From SPVOBJOTI
If [L]FLGMOD<>2
  mkstat=2
Endif

End

######################################################################################
Subprog AV_CURTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=0 & nolign>0
  If !clalev([REQ]) : Local File REQUEST : Endif
  Read [REQ]REQ0=[M:ITL1]REQNUM(nolign-1)
  If !fstat
    VALEUR=[F:REQ]CURTYP
  Endif
Endif
End

######################################################################################
Subprog AV_CURTYPPUR(VALEUR)
Variable Integer VALEUR
If VALEUR=0 & nolign>0
  VALEUR=[M:ITL1]CURTYP(nolign-1)
Endif
End

########################################
Subprog AM_ASSLIB(VALEUR)
Variable Char    VALEUR()

#FM le 09.03.10
If !clalev([OTI]) Then Local File OPETIT  Endif
If !clalev([AUS]) Then Local File AUTILIS Endif
#--
Case [M]OPETYP(nolign-1)
When 2 : #Vérifier si site est paramétré /intervenant
         #Si oui, réini du site
         #M2897

         # ATTENTION si modif, VERIFIER trt SPVOBJITV2 (Chgt_lig) + SPVITV (AM_ASSLIB)

         Call LECTURE("OTI",[M]ITVTYP(nolign-1),[M]CODOPE(nolign-1))From CONTOBJ
         # Init du Site
         Case [F:OTI]ORIFCYOTI
         When 6 : # Site intervenant
                  Call LECTURE("AUS",VALEUR,"")From CONTOBJ
                  [M]FCY(nolign-1)=[F:AUS]FCYT
                  ###
                  #verif si site pas depot , on va chercher le site depot
                  Call LECTURE("FCY",[M]FCY(nolign-1),"")From CONTOBJ
                  If [F:FCY]WRHFLG<>2 & !fstat
                      If [F:OTI]ROLEFCY=0
                          [F:OTI]ROLEFCY=1
                      Endif
                      If find([F:OTI]ROLEFCY,[F:FCY]ROLEFCY)
                          [M]FCY(nolign-1)=[F:FCY]STOFCY(find([F:OTI]ROLEFCY,[F:FCY]ROLEFCY)-1)
                      Endif
                  Endif
                  If !GIMPORT Then Affzo [M]FCY(nolign-1) Endif
          Endcase
Endcase

End

########################################
Subprog C_ASSLIB(VALEUR)
Variable Char    VALEUR()

# LBORN 15/10/2012
If !func XCLOPER2.AUTORIS_DAT([M]CODOPE(nolign-1),VALEUR,[M]DATITV(nolign-1),[M]DATITV(nolign-1))
  mkstat=1 : End
Endif

# LBORN 18/10/2012 - Contrôles supplementaire pour les saisies de frais
If !func SPVOBJITL.VALID_FRAIS([M]FCY(nolign-1), [M]CODOPE(nolign-1), [M]ITVTYP(nolign-1), VALEUR, [M]DATITV(nolign-1),"*")
  mkstat=1 : End
Endif

End


