Subprog IB_REQNUM
If ![V]GXOPTSOF | [M:ITL0]IUSCOD=""
  Raz [V]GBOUT5
Else
  [V]GBOUT5=mess(2,[V]GXMSGSOF,1)-[M:ITL0]IUSCOD
Endif
End

######################################################################################
Subprog B6_NBLIG
If [V]GXOPTCON
  Call AJOUT_FNE([M:ITL0]IUSCOD,[M:ITL0]DATBEG,[M:ITL0]DATEND,[M:ITL0]OPPNUM,[M:ITL0]CONREV) From SPVOBJITL
Else
  Call AJOUT_FNE([M:ITL0]IUSCOD,[M:ITL0]DATBEG,[M:ITL0]DATEND,[M:ITL0]OPPNUM,"") From SPVOBJITL
Endif
End

