################################################################################
################################################################################

################################################################################
$ACTION

# Appel fonctions complémentaires GFI pour l'objet ITL
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
    When "AVANT_OUVRE" : Gosub AVANT_OUVRE From SPVOBJITL
    When "OUVRE"       : Gosub OUVRE       From SPVOBJITL
    When "FERME"       : Gosub FERME       From SPVOBJITL
    When "SETBOUT"     : Gosub SETBOUT     From SPVOBJITL
    When "EXEBOUT"     : Gosub EXEBOUT     From SPVOBJITL
    When "LIENS"       : Gosub LIENS       From SPVOBJITL
    When "DEFLIG"      : Gosub DEFLIG      From SPVOBJITL
    When "RAZDUP"      : Gosub RAZDUP      From SPVOBJITL
    When "INIMOD"      : Gosub INIMOD      From SPVOBJITL
    When "INICRE"      : Gosub INICRE      From SPVOBJITL
    When "INICRE_LIG"  : Gosub INICRE_LIG  From SPVOBJITL
    When "CREATION"    : Gosub CREATION    From SPVOBJITL
    When "APRES_CRE"   : Gosub APRES_CRE   From SPVOBJITL
    When "VERIF_CRE"   : Gosub VERIF_CRE   From SPVOBJITL
    When "VERIF_MOD"   : Gosub VERIF_MOD   From SPVOBJITL
    When "INIMOD_LIG"  : Gosub INIMOD_LIG  From SPVOBJITL
    When "MODIF"       : Gosub MODIF       From SPVOBJITL
    When "APRES_MOD"   : Gosub APRES_MOD   From SPVOBJITL
    When "ANNULE"      : Gosub ANNULE      From SPVOBJITL
    When "DEFTRANS"    : Gosub DEFTRANS    From SPVOBJITL
    When "VARIANTE"    : Gosub VARIANTE    From SPVOBJITL
    When "SETTRANS"    : Gosub SETTRANS    From SPVOBJITL
    When "AV_IMPRIME"  : Gosub AV_IMPRIME  From SPVOBJITL
    When "AV_LISTE"    : Gosub AV_LISTE    From SPVOBJITL
    When "FILTRE"      : Gosub FILTRE      From SPVOBJITL
    When "AFFMASK"     : Gosub AFFMASK     From SPVOBJITL
    When "ABANDON"     : Gosub ABANDON     From SPVOBJITL
    When "BB5_NBLIG"   : Gosub BB5_NBLIG   From SPVOBJITL
    When "SEL_TABLE"   : Gosub SEL_TABLE   From SPVOBJITL
Endcase

Return

