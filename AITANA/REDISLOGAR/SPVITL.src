End

########################################
Subprog C_NBLIG

# LBORN 23/02/2018 - Mantis 34955
If GWEBSERV & dim([V]XWSLIGITL)>0 & nolign>0
  If nolign<[V]XWSLIGITL
    Local Integer ZZ_I
    If !clalev([F:AMZ]) : Local File AMSKZON : Endif
    For [F:AMZ]CODE Where [F:AMZ]CODMSK="ITVLOT1" & [F:AMZ]SAIAFF=1 & [F:AMZ]CODZON<>"NBLIG"
      Grizo ="[M:ITL1]"+[F:AMZ]CODZON+"("+num$(nolign-1)+")"
    Next
  Endif
Endif

If [M:ITL1]FLGVAL(nolign-1)=2 & status<>92 & GWEBSERV<>1
    #status92=Bouton Enreg.
    mkstat=2 : End
Else
    mkstat=0
Endif

# LBORN 15/10/2012
# LBORN 24/09/2014 - Mantis 26502
# If [M]CLOPER(nolign-1)=2
# If [M]CLOPER(nolign-1)=2 & (![V]GWEBSERV | dim([V]XWSLIGITL)<=0 | [V]XWSLIGITL=nolign)
If [M]CLOPER(nolign-1)=2 & ![V]GWEBSERV
  If status=65
    [V]GMESSAGE=mess(101,[V]GXMSGACT,1)+"\"+mess(54,123,1)
    mkstat=1
  Elsif status=75
    [V]GMESSAGE=mess(101,[V]GXMSGACT,1)+"\"+mess(9,123,1)
    mkstat=1
  Elsif status = 68 | status= 83
    For NOL=nolign-1 To nolign1-1
      If [M]CLOPER(NOL)=2
        [V]GMESSAGE=mess(101,[V]GXMSGACT,1)+"\"+mess(54,123,1)
        mkstat=1
        Break
      Endif
    Next
  Endif
Endif

End

########################################
Subprog APRES_NBLIG

# SOUCH # Compatibilité WEBSERVICES
#-----------------------------------------
#If dim(GWEBSERV)=1 & GWEBSERV=1
#  Local Integer NOL : NOL = nolign-1
#  Call AV_DES([M:ITL1]DES(NOL))
#  If [M:ITL1]NBDAY(NOL)<>0
#      Call AM_NBDAY([M:ITL1]NBDAY(NOL)) From XSAIITVD
#  Elsif [M:ITL1]HMLEN(NOL)<>"00000"
#      Call AM_HMLEN([M:ITL1]HMLEN(NOL)) From XSAIITVD
#  Endif
#  Call AV_QTY([M:ITL1]QTY(NOL))
#Endif
##-----------------------------

# LBORN 24/09/2012
If dim(GWEBSERV)=1 & GWEBSERV=1
  Local Integer NOL : NOL = nolign-1
  Call AM_HMLEN([M:ITL1]HMLEN(nolign-1)) From XSAIITVD
  Call CAL_QTY([M:ITL1]UOM(nolign-1),[M:ITL1]QTY(nolign-1),[M:ITL1]RECMOD(nolign-1),[M:ITL1]ITVLEN(nolign-1),[M:ITL1]STRHOU(nolign-1)
&               ,[M:ITL1]STRDAT(nolign-1),[M:ITL1]ENDHOU(nolign-1),[M:ITL1]ENDDAT(nolign-1),[M:ITL1]NBDAY(nolign-1)
&               ,[M:ITL1]HMLEN(nolign-1),[M:ITL1]ASSLIB(nolign-1)) From SPVOBJITV2

  # LBORN 22/10/2012
  If [M:ITL1]OPETYP(NOL)=2 & [M:ITL1]ASSLIB(NOL)<>[M:ITL1]ASSITV(NOL) & [M:ITL1]ASSLIB(NOL)<>""
    [M:ITL1]ASSITV(NOL)=[M:ITL1]ASSLIB(NOL)
  Endif

  Call CHGT_LIG_PREST(
&                        [M:ITL1]RECMOD(NOL)
&                      , [M:ITL1]OPETYP(NOL)
&                      , [M:ITL1]ASSITV(NOL)
&                      , [M:ITL1]STRDAT(NOL)
&                      , [M:ITL1]STRHOU(NOL)
&                      , [M:ITL1]ENDDAT(NOL)
&                      , [M:ITL1]ENDHOU(NOL)
&                      , [M:ITL1]HMLEN(NOL)
&                      , [M:ITL1]DES(NOL)
&                      , [M:ITL1]BPSNUM(NOL)
&                       )
&   From SPVOBJITV2
Endif

Gosub PSGITL
Gosub SUPERIEURS

[M:ITL1]FLGTPS(nolign-1)=0

End

########################################
Subprog AV_DATITV(VALEUR)
Variable Date    VALEUR
Gosub PSGITL
End

########################################
Subprog AV_BPRCOD(VALEUR)
Variable Char    VALEUR()
Gosub PSGITL
End

########################################
Subprog AV_CONREVLIG(VALEUR)
Variable Char    VALEUR()
If GXOPTCON Then
    Gosub PSGITL
Endif
End

########################################
Subprog AV_OPPNUMLIG(VALEUR)
Variable Char    VALEUR()
If GXOPTOPP Then
    Gosub PSGITL

    #construction du filtre de selection des affaires
    GCRITDIV="OPPCLO<>2"
    If [M:ITL1]BPRCOD(nolign-1)<>"" Then GCRITDIV-="& OPPCMP='"+[M:ITL1]BPRCOD(nolign-1)+"'" Endif
Endif
End

########################################
Subprog AV_REQNUM(VALEUR)
Variable Char    VALEUR()

Gosub PSGITL

#Construction du filtre pour la selection des DS
GCRITDIV="FLGREQCLO<>2 & FLGREQCAN<>2"
If [M:ITL0]FCYDEF              <>"" Then GCRITDIV+="& FCY=[M:ITL0]FCYDEF"                 Endif
If GXOPTCON Then If [M:ITL1]CONREVLIG(nolign-1) <>"" Then GCRITDIV+="& CONREV=[M:ITL1]CONREVLIG(nolign-1)" Endif Endif
If GXOPTOPP Then If [M:ITL1]OPPNUMLIG(nolign-1) <>"" Then GCRITDIV+="& OPPNUM=[M:ITL1]OPPNUMLIG(nolign-1)" Endif Endif
If [M:ITL1]BPRCOD(nolign-1)    <>"" Then GCRITDIV+="& BPCNUM=[M:ITL1]BPRCOD(nolign-1)"    Endif
# OTHYR - ajout dans sélection des DS, du type précedemment renseigné
If [M:ITL1]REQTYP(nolign-1)    <>"" Then GCRITDIV+="& REQTYP=[M:ITL1]REQTYP(nolign-1)"    Endif
End

########################################
Subprog AV_ITVTYP(VALEUR)
Variable Char    VALEUR()
Gosub PSGITL
End

########################################
Subprog AV_CODOPE(VALEUR)
Variable Char    VALEUR()
Gosub PSGITV
End

########################################
Subprog AV_ASSLIB(VALEUR)
Variable Char    VALEUR()

Gosub PSGITV

#Non en Init car CodOpe peut initialiser cette zone à vide
If [F:OPE]OPETYP=2 & VALEUR="" Then VALEUR=[M:ITL0]IUSCOD Endif
End

########################################
Subprog AV_UOM(VALEUR)
Variable Char    VALEUR()
Gosub PSGITV
End

########################################
Subprog AV_QTY(VALEUR)
Variable Decimal VALEUR

Gosub PSGITV

If [M:ITL1]FLGTPS(nolign-1)=2 Then
    Call CAL_QTY(
&                 [M:ITL1]UOM(nolign-1)
&               , VALEUR
&               , [M:ITL1]RECMOD(nolign-1)
&               , [M:ITL1]ITVLEN(nolign-1)
&               , [M:ITL1]STRHOU(nolign-1)
&               , [M:ITL1]STRDAT(nolign-1)
&               , [M:ITL1]ENDHOU(nolign-1)
&               , [M:ITL1]ENDDAT(nolign-1)
&               , [M:ITL1]NBDAY(nolign-1)
&               , [M:ITL1]HMLEN(nolign-1)
&               , [M:ITL1]ASSLIB(nolign-1)
&                )
&   From SPVOBJITV2
    If ![V]GIMPORT Then Affzo [M:ITL1]ITVLEN(nolign-1) Endif
Endif
End

########################################
Subprog AV_QUESTION(VALEUR)
Variable Char    VALEUR()
Gosub PSGITV
End

########################################
Subprog AV_ITLSUM(VALEUR)
Variable Char    VALEUR()
Gosub PSGITV
End

########################################
Subprog AV_DES(VALEUR)
Variable Char    VALEUR()

Gosub PSGITV

#Si modif dans le cadre de saisie produit
If [M:ITL1]FLGTPS(nolign-1)=3
&& [M:ITL1]OPETYP(nolign-1)=1

    Call CHGT_LIG_PRO([M:ITL1]ASSLIB(nolign-1),VALEUR)
&   From SPVOBJITV2

    [M:ITL1]ASSPRD(nolign-1)=[M:ITL1]ASSLIB(nolign-1)
    [M:ITL1]ASSITV(nolign-1)=""
    [M:ITL1]RSCCOD(nolign-1)=""
    [M:ITL1]ITMDES(nolign-1)=VALEUR

Elsif [M:ITL1]FLGTPS(nolign-1)=2
&   & [M:ITL1]OPETYP(nolign-1)<>1

    If   [M:ITL1]OPETYP(nolign-1)=2
&   Then [M:ITL1]ASSITV(nolign-1)=[M:ITL1]ASSLIB(nolign-1)
         [M:ITL1]RSCCOD(nolign-1)=""
    Else [M:ITL1]ASSITV(nolign-1)=""
         [M:ITL1]RSCCOD(nolign-1)=[M:ITL1]ASSLIB(nolign-1)
    Endif
Endif

#Signifie qu'une modif a été faite
If find([M:ITL1]FLGTPS(nolign-1),2,3)

    Call CHGT_LIG_PREST(
&                        [M:ITL1]RECMOD(nolign-1)
&                      , [M:ITL1]OPETYP(nolign-1)
&                      , [M:ITL1]ASSITV(nolign-1)
&                      , [M:ITL1]STRDAT(nolign-1)
&                      , [M:ITL1]STRHOU(nolign-1)
&                      , [M:ITL1]ENDDAT(nolign-1)
&                      , [M:ITL1]ENDHOU(nolign-1)
&                      , [M:ITL1]HMLEN(nolign-1)
&                      , VALEUR
&                      , [M:ITL1]BPSNUM(nolign-1)
&                       )
&   From SPVOBJITV2
    If !GIMPORT Then Affzo [M:ITL1]NBDAY(nolign-1),ITVLEN(nolign-1),BPSNUM(nolign-1) Endif
Endif
End


########################################
Subprog D_FLGPJT(VALEUR)
Variable Integer VALEUR

If !clalev([OTI]) Then Local File OPETIT [OTI] Endif
Call LECTURE("OTI",[M:ITL1]ITVTYP(nolign-1),[M:ITL1]CODOPE(nolign-1)) From CONTOBJ

If [F:OTI]FLGPJT=2 Then VALEUR=2 Endif

End

########################################
Subprog D_FLGHIE(VALEUR)
Variable Integer VALEUR
If !clalev([OTI]) Then Local File OPETIT [OTI] Endif
Call LECTURE("OTI",[M:ITL1]ITVTYP(nolign-1),[M:ITL1]CODOPE(nolign-1))
&From CONTOBJ
If [F:OTI]FLGHIE=2 Then VALEUR=2 Endif
End

########################################
Subprog AV_CPY(VALEUR)
Variable Char    VALEUR()

Gosub PSGITL

VALEUR=""
If [M:ITL0]FCYDEF<>"" Then
  If !clalev([CPY]) Then Local File COMPANY [CPY] Endif
  Call GETDEV([M:ITL0]FCYDEF)From DEVSUB
  Call LECTURE("CPY",[V]GSOCIETE,"")From CONTOBJ
  VALEUR=[V]GSOCIETE
Endif

End

########################################
Subprog D_FCYDEF(VALEUR)
Variable Char    VALEUR()
VALEUR=GFCY
End

########################################
Subprog AP_ASSLIB(VALEUR)
Variable Char    VALEUR()
Local    Integer OK

#Permet le déclenchement de la saise des temps
If [M:ITL1]OPETYP(nolign-1)<>1 Then [M:ITL1]FLGTPS(nolign-1)=1 Endif
End

########################################
Subprog AV_FCY(VALEUR)
Variable Char    VALEUR()

Gosub PSGITV

#Non en Init car CodOpe peut initialiser cette zone à vide
If VALEUR="" & [M:ITL0]FCYDEF<>"" Then VALEUR=[M:ITL0]FCYDEF Endif
End

########################################
Subprog AS_ASSLIB(VALEUR)
Variable Char    VALEUR()
Local    Integer FLGMOD
Local    Integer OK
Local    Integer NOL

NOL=nolign-1
Case [M:ITL1]OPETYP(NOL)
When 1 : Call VAL_FLGMOD([M:ITL1]CODOPE(NOL),[M:ITL1]ITVTYP(NOL),"ASSPRD",[L]FLGMOD)From SPVOBJOTI
When 2 : Call VAL_FLGMOD([M:ITL1]CODOPE(NOL),[M:ITL1]ITVTYP(NOL),"ASSITV",[L]FLGMOD)From SPVOBJOTI
When 3 : Call VAL_FLGMOD([M:ITL1]CODOPE(NOL),[M:ITL1]ITVTYP(NOL),"RSCCOD",[L]FLGMOD)From SPVOBJOTI
Endcase

If [L]FLGMOD<>2 Then mkstat=2 Endif
End

########################################
Subprog AS_DES(VALEUR)
Variable Char    VALEUR()
Local    Integer FLGMOD
Local    Integer NOL

NOL=nolign-1

If [M:ITL1]RECMOD(NOL)<>4 Then
  mkstat=2
Else
  Call VAL_FLGMOD([M:ITL1]CODOPE(NOL),[M:ITL1]ITVTYP(NOL),"DES",[L]FLGMOD)From SPVOBJOTI
  If [L]FLGMOD<>2 Then mkstat=2 Endif
Endif
End

