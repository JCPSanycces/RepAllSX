######################################################################################
Subprog C_ITLSUM(VALEUR)
Variable Char    VALEUR()
If !func SPVOBJITL.VALID_FRAIS([M]FCY(nolign-1), [M]CODOPE(nolign-1), [M]ITVTYP(nolign-1), [M]ASSLIB(nolign-1), [M]DATITV(nolign-1), VALEUR)
  mkstat=1 : End
Endif

# M33703 # 2017-10-02 # SOUCH
#------
#M29070 - souch - 2 déc. 2015
#------
If GWEBSERV
  Local Integer NOL
  [L]NOL = nolign-1

  Local Integer UVYDAY(7)
  Local Char UVYCOD
  Local Decimal HOUWKD(7)
  Local Date DATAC

  Local File REQUEST
  Read [F:REQ]REQ0 = [M:ITL1]REQNUM([L]NOL)

  Call RECUP_DISPO([M:ITL1]REQNUM([L]NOL),[F:REQ]FCY,[M:ITL1]CODOPE([L]NOL),[M:ITL1]ITVTYP([L]NOL)
&                 ,[M:ITL1]ASSLIB([L]NOL),[L]UVYDAY,[L]UVYCOD,[L]HOUWKD)From SPVOBJITV3
  [L]DATAC = [M:ITL1]DATITV(NOL)

  # LBORN 14/06/2016 - Mantis 32918
  # Call CTL_JOU([L]DATAC,[L]UVYDAY,[L]UVYCOD,0)From CONTX3
  # If [L]DATAC <> VALEUR
  Call CTL_JOU([L]DATAC,[L]UVYDAY,[L]UVYCOD,0) From XX03SCONTX3
  If [L]DATAC<>[M:ITL1]DATITV(NOL) | mkstat
#    Call ADDMESSWARN(VALEUR-mess(137,1821,1)) From AWEB
    GMESSAGE = [M:ITL1]DATITV(NOL)-mess(137,1821,1)
    GERR=2
  Endif
Endif
#------

End

