Call VAL_FLGMOD([M:ITL1]CODOPE(NOL),[M:ITL1]ITVTYP(NOL),"QTY",[L]FLGMOD)From SPVOBJOTI
If [L]FLGMOD<>2 Then mkstat=2 Endif
End

