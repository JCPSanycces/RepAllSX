########################################
Subprog AP_CODOPE(VALEUR)
Variable Char    VALEUR()

If !clalev([OPE]) Then Local File OPERATION [OPE] Endif
Call LECTURE("OPE",VALEUR,"")From CONTOBJ
[M:ITL1]OPETYP(nolign-1)=[F:OPE]OPETYP
[M:ITL1]RECMOD(nolign-1)=[F:OPE]RECMOD
End

########################################
Subprog D_UNTPRI(VALEUR)
Variable Decimal VALEUR

#=======================================
#Prix de vente
#=======================================

Local Char    ACTION
Local Integer NBREM
Local Integer I
Local Integer NOL

[L]NOL=nolign-1

If !clalev([ACV]) Then Local File ACTIV [ACV] Endif
Call LECTURE("ACV","SPR","")From CONTOBJ
If [F:ACV]FLACT = 2 Then
  [L]NBREM = [F:ACV]DIME
Endif

Gosub INIT_PARAM
[L]DEVISE=[M:ITL1]CUR(nolign-1)
[L]CURTYP=[M:ITL1]CURTYP(nolign-1)
Call RECH_PRIX([L]PARAMC,[L]PARAMD,[L]PRIX,[L]REMISE,[L]DEVISE,[L]CURTYP,1)
&From SPVOBJITV2

# Actions spécifiques
# Renseigner las var. PRIX et REMISE() en se servant de la var. DEVISE
GPOINT="D_UNTPRI"
Gosub ENTREE From EXEFNC

VALEUR=[L]PRIX
For I=1 To [L]NBREM
    Assign "[M:ITL1]DISCRGVAL"+num$(I)+"([L]NOL)" With [L]REMISE(I-1)
    #Web
    If ![V]GIMPORT Then Affzo ="[M:ITL1]DISCRGVAL"+num$(I)+"([L]NOL)" Endif
Next
End

########################################
Subprog AV_UNTPRI(VALEUR)
Variable Decimal VALEUR
Gosub PSGITV
End

