########################################
Subprog D_PRIPUR(VALEUR)
Variable Decimal VALEUR

# LBORN 18/10/2012
Local Char ZCODEXP, ZDEV
[L]ZCODEXP=func SPVOBJITL.CODEXP_FRAIS([M]CODOPE(nolign-1), [M]ITVTYP(nolign-1))
If [L]ZCODEXP<>""

  # LBORN 04/09/2013 - Mantis 20886
  If [M]CURPUR(nolign-1)<>""
    [L]ZDEV=[M]CURPUR(nolign-1)
  Elsif [M]CUR(nolign-1)<>""
    [L]ZDEV=[M]CUR(nolign-1)
  Else
    If !clalev([REQ]) : Local File REQUEST : Endif
    Read [REQ]REQ0=[M]REQNUM(nolign-1)
    If !fstat
      [L]ZDEV=[F:REQ]CURINV
    Endif
  Endif

  Call INIT_FRAIS([M]FCY(nolign-1), [L]ZCODEXP, [M]ASSLIB(nolign-1), [L]ZDEV, [M:ITL1]QTY(nolign-1), VALEUR) From SPVOBJITL
  If VALEUR<>0 : End : Endif
Endif

#=======================================
#Prix d'achat
#=======================================

Local Char    ACTION
Local Integer NBREM
Local Integer I
Local Integer NOL

[L]NOL=nolign-1

If !clalev([ACV]) Then Local File ACTIV [ACV] Endif
Call LECTURE("ACV","PPR","")From CONTOBJ
If [F:ACV]FLACT = 2 Then
  [L]NBREM = [F:ACV]DIME
Endif

Gosub INIT_PARAM
[L]DEVISE=[M:ITL1]CURPUR(nolign-1)
[L]CURTYP=[M:ITL1]CURTYPPUR(nolign-1)
Call RECH_PRIX([L]PARAMC,[L]PARAMD,[L]PRIX,[L]REMISE,[L]DEVISE,[L]CURTYP,2)
&From SPVOBJITV2

# Actions spécifiques
# Renseigner las var. PRIX et REMISE() en se servant de la var. DEVISE
GPOINT="D_PRIPUR"
Gosub ENTREE From EXEFNC

VALEUR=[L]PRIX
For I=1 To [L]NBREM
    Assign "[M:ITL1]DISPUR"+num$(I)+"([L]NOL)" With [L]REMISE(I-1)
    #Web
    If ![V]GIMPORT Then Affzo ="[M:ITL1]DISPUR"+num$(I)+"([L]NOL)" Endif
Next
End

