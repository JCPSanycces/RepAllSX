################################################################################

########################################
Subprog D_TYPITL(VALEUR)
Variable Char    VALEUR()

If dim([V]NBCTLTYPCRA)>=0 & [V]NBCTLTYPCRA=1

  VALEUR=[V]TABCTLTYPCRA(0)

Else

  If !clalev([F:PLT]) : Local File PARITLTYP : Endif

  Local Integer I
  Raz [L]I
  For [F:PLT]PLT0 Where [F:PLT]ENAFLG=2
    [L]I+=1
    If [L]I>1 : Break : Endif
  Next
  If [L]I=1
    VALEUR=[F:PLT]ITLTYP
  Endif

Endif

End


########################################
Subprog AS_ITLNUM(VALEUR)
Variable Char    VALEUR()

If find(GREP,"C","D") & GMANCOU <> 2 Then mkstat=2 Endif
End

########################################
Subprog C_ITLNUM(VALEUR)
Variable Char    VALEUR()

#----- VéRIF si un enregistrement existe -----#
If !GIMPORT
  If VALEUR<>""
     Look [ITL]ITL0=VALEUR
     If fstat Then GMESSAGE=mess(178,199,1) : mkstat=1 : End Endif
  Elsif [M:ITL0]ITLNUM=""
    # LBORN 23/12/2011 - Pour éviter de saisir un CRA en ayant omis de faire <Nouveau>
    GMESSAGE=mess(178,199,1)
    mkstat=1
    GERR=1
    End
  Endif
Endif
End

########################################
Subprog C_TYPITL(VALEUR)
Variable Char    VALEUR()

If [F:PLT]ACS<>"" Then Call CTLACS([F:PLT]ACS,"M")From CONTX3 Endif

End

########################################
Subprog AM_TYPITL(VALEUR)
Variable Char    VALEUR()

[M:ITL0]ACS=[F:PLT]ACS

End

########################################
Subprog C_OPPNUMLIG(VALEUR)
Variable Char    VALEUR()

If !GXOPTOPP Then End Endif

Local    Integer OK

#=======================================
If VALEUR<>""
&& [M:ITL1]BPRCOD(nolign-1)<>""
&& [F:OPP]OPPCMP<>[M:ITL1]BPRCOD(nolign-1)
    [L]OK=2 : GERR=3 : [V]GMESSAGE=mess(151,[V]GXMSGPSA,1)
Endif

#=======================================
If VALEUR<>""
&&[M:ITL1]BPRCOD(nolign-1)=""
    [M:ITL1]BPRCOD(nolign-1)=[F:OPP]OPPCMP
    If ![V]GIMPORT Then
      # LBO 26/12/2002 - Ajout 3 lignes (affichage du lien "Raison Sociale")
      Affzo [M:ITL1]BPRCOD(nolign-1)
      If dim([M:ITL1]ZBPRCOD)>indice Then Affzo [M:ITL1]ZBPRCOD(nolign-1) Endif
    Endif
Endif

#=======================================
If VALEUR<>"" & [M:ITL1]REQNUM(nolign-1)<>""
  Read [REQ]REQ0=[M:ITL1]REQNUM(nolign-1)
  If fstat | [F:REQ]OPPNUM<>VALEUR Then mkstat=2 Endif
Endif
End

########################################
Subprog D_REQNUM(VALEUR)
Variable Char    VALEUR()

If GXOPTOPP & [M:ITL1]OPPNUMLIG(nolign-1)="" Then
  End
Else
  Local Char CRITERE(250)
  [L]CRITERE="FLGREQCLO<>2 & FLGREQCAN<>2"
  If [M:ITL0]FCYDEF              <>"" Then [L]CRITERE-="& FCY=[M:ITL0]FCYDEF"                 Endif

  If GXOPTCON Then If [M:ITL1]CONREVLIG(nolign-1) <>"" Then [L]CRITERE+="& CONREV=[M:ITL1]CONREVLIG(nolign-1)" Endif Endif

  If GXOPTOPP Then If [M:ITL1]OPPNUMLIG(nolign-1) <>"" Then [L]CRITERE+="& OPPNUM=[M:ITL1]OPPNUMLIG(nolign-1)" Endif Endif

  If [M:ITL1]BPRCOD(nolign-1)    <>"" Then [L]CRITERE-="& BPCNUM=[M:ITL1]BPRCOD(nolign-1)"    Endif
  If !clalev([REQ]) Then Local File REQUEST [REQ] Endif
  Filter [REQ] Where evalue([L]CRITERE)
  Local Integer ZNB
  Raz [L]ZNB
  For [F:REQ]REQ0
    If func SPVOBJITV.AUTOR_CREITV([F:REQ]REQNUM)
      [L]ZNB+=1
      If [L]ZNB>1
        VALEUR="" : Break
      Else
        [L]ZNB+=1
        VALEUR=[F:REQ]REQNUM
      Endif
    Endif
  Next
  Raz [V]GMESSAGE
  Filter [REQ]
Endif
End

########################################
Subprog C_REQNUM(VALEUR)
Variable Char    VALEUR()

Local    Char    CRITERE(250)

#=======================================

# LBORN 03/05/2010 - Option B
# [L]CRITERE="FLGREQCLO<>2 & FLGREQCAN<>2"
[L]CRITERE="1"

If [M:ITL0]FCYDEF              <>"" Then [L]CRITERE-="& FCY=[M:ITL0]FCYDEF"                 Endif

If GXOPTCON
  If [M:ITL1]CONREVLIG(nolign-1) <>""
    [L]CRITERE+="& CONREV=[M:ITL1]CONREVLIG(nolign-1)"
  Endif
Endif

If GXOPTOPP
  If [M:ITL1]OPPNUMLIG(nolign-1)<>""
    [L]CRITERE+="& OPPNUM=[M:ITL1]OPPNUMLIG(nolign-1)"
  Endif
Endif

If [M:ITL1]BPRCOD(nolign-1)<>""
  [L]CRITERE-="& BPCNUM=[M:ITL1]BPRCOD(nolign-1)"
Endif

If !clalev([REQ]) Then Local File REQUEST [REQ] Endif

Filter [REQ] Where evalue([L]CRITERE)

# LBORN 03/05/2010 - Bug Std, sinon si classe en ligne pas de message d'erreur
Raz [F:REQ]
Call CONTROLE("REQ","B",VALEUR,"",mkstat) From CONTOBJ

Filter [REQ]
If mkstat : GERR=1 : End : Endif

If !func SPVOBJITV.AUTOR_CREITV(VALEUR)
  mkstat=1
  [V]GERR=1
  End
Endif

#=======================================
[M:ITL1]REQTYP(nolign-1)=[F:REQ]REQTYP
If ![V]GIMPORT Then Affzo [M:ITL1]REQTYP(nolign-1) Endif

#=======================================
If GXOPTCON Then
    If [M:ITL1]CONREVLIG(nolign-1)="" Then
        [M:ITL1]CONREVLIG(nolign-1)=[F:REQ]CONREV
        If ![V]GIMPORT Then Affzo [M:ITL1]CONREVLIG(nolign-1) Endif
    Endif
Endif
#=======================================
If [M:ITL1]BPRCOD(nolign-1)="" Then
    [M:ITL1]BPRCOD(nolign-1)=[F:REQ]BPCNUM
    If ![V]GIMPORT Then Affzo [M:ITL1]BPRCOD(nolign-1) Endif
Endif

#=======================================
If GXOPTOPP Then
    If [M:ITL1]OPPNUMLIG(nolign-1)="" Then
        [M:ITL1]OPPNUMLIG(nolign-1)=[F:REQ]OPPNUM
        If ![V]GIMPORT Then Affzo [M:ITL1]OPPNUMLIG(nolign-1) Endif
    Endif
Endif
End

#######################################
Subprog AM_CODOPE(VALEUR)
Variable Char    VALEUR()
Local    Integer FLGMOD
Local    Integer OK
Local    Integer MOTINV
Local    Decimal NBPT
Local    Decimal NBLOD

Call LECTURE("REQ",[M:ITL1]REQNUM(nolign-1),"")
&From CONTOBJ

#Permet de recupérer la nouvelle désignation
If ![V]GIMPORT Then Effzo [M:ITL1]DES(nolign-1) Endif

#=======================================
Call CHGT_LIG(
&              [M:ITL1]ITVTYP(nolign-1)
&            , VALEUR
&            , [M:ITL1]REQNUM(nolign-1)
&            , [M:ITL1]FCY(nolign-1)
&            , [M:ITL1]ASSLIB(nolign-1)
&            , [M:ITL1]ASSPRD(nolign-1)
&            , [M:ITL1]ASSITV(nolign-1)
&            , [M:ITL1]RSCCOD(nolign-1)
&            , [M:ITL1]ITMDES(nolign-1)
&            , [M:ITL1]UOM(nolign-1)
&            , [M:ITL1]QTY(nolign-1)
&            , [M:ITL1]QUESTION(nolign-1)
&            , [L]MOTINV
&            , [L]NBPT
&            , [L]NBLOD
&            , [M:ITL1]BPSNUM(nolign-1)
&             )
&From SPVOBJITV2

#=======================================
#Web
If ![V]GIMPORT Then
    Affzo [M:ITL1]UOM(nolign-1),QTY(nolign-1)
    Affzo [M:ITL1]FCY(nolign-1),BPSNUM(nolign-1),QUESTION(nolign-1)
Endif

#=======================================
If    [M:ITL1]OPETYP(nolign-1)<>1
&Then [M:ITL1]FLGTPS(nolign-1)=1
Else  [M:ITL1]FLGTPS(nolign-1)=3
Endif
End

########################################
Subprog AM_DATITV(VALEUR)
Variable Date    VALEUR
[M:ITL1]STRDAT(nolign-1)=VALEUR
If !GIMPORT Then Affzo [M:ITL1]STRDAT(nolign-1) Endif
End

########################################
Subprog D_CONREVLIG(VALEUR)
Variable Char    VALEUR()
If GXOPTCON Then If [M:ITL0]CONREV<>"" Then VALEUR=[M:ITL0]CONREV Endif Endif
End

########################################
Subprog D_OPPNUMLIG(VALEUR)
Variable Char    VALEUR()
If GXOPTOPP & [M:ITL0]OPPNUM<>"" Then VALEUR=[M:ITL0]OPPNUM Endif
End

########################################
Subprog D_DATITV(VALEUR)
Variable Date    VALEUR

Case nolign-1
When 0             : VALEUR=[M:ITL0]DATBEG
When [M:ITL1]NBLIG : VALEUR=[M:ITL1]DATITV(nolign-2)+1*([M:ITL1]DATITV(nolign-2)<[M:ITL0]DATEND)
When Default       : VALEUR=[M:ITL1]DATITV(nolign-2)
Endcase
End

########################################
Subprog C_DATITV(VALEUR)
Variable Date    VALEUR

If VALEUR>[M:ITL0]DATEND
&| VALEUR<[M:ITL0]DATBEG
    mkstat=2
Endif

# M33703 # 2017-10-02 # SOUCH
#------
# Déplacement du contrôle dans C_ITLSUM
# car ce contrôle est appelé trop tôt en création

##M29070 - souch - 2 déc. 2015
