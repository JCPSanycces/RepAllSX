Subprog D_ITVTYP(VALEUR)
Variable Char    VALEUR()
If !clalev([F:PRT]) : Local File PARRQTTYP : Endif
Read [F:PRT]PRT0=[M:ITL1]REQTYP(nolign-1)
If !fstat & [F:PRT]DEFINTTYP<>""
  VALEUR=[F:PRT]DEFINTTYP
Endif
