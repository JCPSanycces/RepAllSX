########################################
Subprog AV_NEXSTA(VALEUR)
Variable Char    VALEUR()
Gosub PSGITV
End

########################################
Subprog IB_NBLIG

Gosub PSGITV

# LBORN 12/09/2013 - Mantis 21092
If ![V]GXOPTSOF | [M:ITL1]NBLIG<>0 | (!instr(1,GCHAINE,"M") & GREP<>"C") | !find(GREP,"C","D","M") | [M:ITL0]IUSCOD="" | [M:ITL0]DATBEG=[0/0/0] | [M:ITL0]DATEND=[0/0/0]
  Raz [V]GBOUT6
Else
  [V]GBOUT6=mess(3,[V]GXMSGSOF,1)-[M:ITL0]IUSCOD
Endif

If [M:ITL1]DATITV(nolign-1)=[0/0/0]
  Raz GBOUT5
Endif

Raz GBOUT3, GBOUT4
If [M:ITL1]NBLIG<>0 & [M:ITL0]FLGITLCLO<>2
  [V]GBOUT4=mess(132,[V]GXMSGPSA,1)
  If ([M:ITL1]ASSITV(nolign-1)<>"" & [M:ITL1]ASSITV(nolign-1)=[M:ITL1]ASSLIB(nolign-1))
&  | ([M:ITL1]RSCCOD(nolign-1)<>"" & [M:ITL1]RSCCOD(nolign-1)=[M:ITL1]ASSLIB(nolign-1))
    [V]GBOUT3=string$(([F:OPE]RECMOD<>4),mess(16,[V]GXMSGPSA,1))
    [M:ITL1]FLGTPS(nolign-1)=1
  Endif
Endif

End

########################################
Subprog AS_IMPUTVCR(VALEUR)
Variable Char    VALEUR()
Local    Integer XOK
Local    Integer SENS
Local    Char    CODOPE
Local    Char    ITVTYP
Local    Char    PARDOC
Local    Char    PARVAL
Local    Decimal QTY

#N° imputation saisisable si code validtion = avoir ou facture avec qté<0

If !clalev([OTM]) Then Local File OPETITMVT [OTM] Endif

[L]CODOPE =[M:ITL1]CODOPE(nolign-1)
[L]ITVTYP =[M:ITL1]ITVTYP(nolign-1)
[L]QTY    =[M:ITL1]QTY(nolign-1)
[L]XOK    =0

For [OTM]OTM1 Where [OTM]OPECOD=[L]CODOPE
&                 & [OTM]INTTYP=[L]ITVTYP
&                 & [OTM]EVENT=1
&                 & [OTM]ENAFLG=2
    If [F:OTM]PARAM1<>"" Then
        [L]PARVAL=[F:OTM]CODVAL
        [L]PARDOC=[F:OTM]PARAM1
        Gosub RECUP_TYP
        If ([L]SENS=1 & [L]QTY<0) | ([L]SENS=2 & [L]QTY>=0) Then
            [L]XOK=1 : Break 1
        Endif
    Endif
Next

If [L]XOK Then End Endif

For [OTM]OTM1 Where [OTM]OPECOD=[L]CODOPE
&                 & [OTM]INTTYP=[L]ITVTYP
&                 & [OTM]EVENT=2
&                 & [OTM]ENAFLG=2
    If [F:OTM]PARAM1<>"" Then
        [L]PARVAL=[F:OTM]CODVAL
        [L]PARDOC=[F:OTM]PARAM1
        Gosub RECUP_TYP
        If ([L]SENS=1 & [L]QTY<0) | ([L]SENS=2 & [L]QTY>=0) Then
            [L]XOK=1 : Break 1
        Endif
    Endif
Next

If ![L]XOK Then mkstat=2 : End Endif
End

########################################
Subprog C_IMPUTVCR(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
&& [M:ITL1]BPRCOD(nolign-1)<>""
  If !clalev([SIV]) Then Local File SINVOICEV Endif
  Filter [SIV] Where BPCINV=[M:ITL1]BPRCOD(nolign-1)
  Call CONTROLE("SIH","AB",VALEUR,"",mkstat)From CONTOBJ
  Filter [SIV]
Endif
End

########################################
Subprog AS_FCYDEF(VALEUR)
Variable Char    VALEUR()

# Risque d'incohérence entre le site et celui des DS
If [M:ITL1]NBLIG Then mkstat=2 Endif
End

########################################
Subprog AS_TYPITL(VALEUR)
Variable Char    VALEUR()

If !find(GREP,"C","D") Then mkstat=2 Endif

If dim([V]NBCTLTYPCRA)>=0 & [V]NBCTLTYPCRA=1
  VALEUR=[V]TABCTLTYPCRA(0)
  mkstat=2
Endif

End

########################################
Subprog AM_REQNUM(VALEUR)
Variable Char    VALEUR()

If !clalev([REQ]) Then Local File REQUEST [REQ] Endif
Read [REQ]REQ0=VALEUR
If !fstat
  [M:ITL1]CUR(nolign-1)=[F:REQ]CURINV
  [M:ITL1]CURTYP(nolign-1)=[F:REQ]CURTYP
  [M:ITL1]CURTYPPUR(nolign-1)=[F:REQ]CURTYP
Endif
End

########################################
Subprog D_CUR(VALEUR)
Variable Char    VALEUR()
If !clalev([REQ]) Then Local File REQUEST [REQ] Endif
Read [REQ]REQ0=[M:ITL1]REQNUM(nolign-1)
If !fstat VALEUR=[F:REQ]CURINV Endif
End



################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$PSGITL

#Réaffectation pour controle objet sur ligne
[V]GCODPARCTL ="ITL"          # Code paramétrage à utiliser
[V]GXCODOBJ    ="ITL"          # Code objet à contrôler
[V]GTYPOBJ    =[M:ITL0]TYPITL

Return

################################################################################
$PSGITV

#Réaffectation pour controle objet sur ligne
[V]GCODPARCTL ="ITL"          # Code paramétrage à utiliser
[V]GXCODOBJ    ="ILD"          # Code objet à contrôler
[V]GTYPOBJ    =[M:ITL1]ITVTYP(nolign-1)
Return

################################################################################
$SUPERIEURS
If !GXOPTOPP : Return : Endif

# LBORN 05/02/2010 On efface seulement si visa projet implicite à "Non"
If !clalev([OTI]) Then Local File OPETIT [OTI] Endif
Read [F:OTI]OTI0=[M:ITL1]CODOPE(nolign-1);[M:ITL1]ITVTYP(nolign-1)
If fstat | [F:OTI]FLGPJT<>2
  Raz [M:ITL1]FLGPJT(nolign-1)
Endif


###
#FM le 25.09.08
# Appelé en Apres_ligne et AM_IUSCOD
#---------------------------------------
#mise à jour du superieur hiérarchque et de projet
#---------------------------------------
Raz [M:ITL1]IUSPJT(nolign-1), [M:ITL1]IUSHIE(nolign-1)
###
Local File OPPORX3S [OPPX]
&        , AUTILIS [AUSX]
Local Char XUSR
###
Read [OPPX]XOP0=[M:ITL1]OPPNUMLIG(nolign-1)
If fstat Then
    [M:ITL1]FLGPJT(nolign-1)=2
Else
    [M:ITL1]IUSPJT(nolign-1)=[F:OPPX]TECRES
Endif
###
#---------------------------------------
# Si un intervenant est associé dans le paramétrage des codes opé par type d'inter
# Alors on regarde le supérieur hiérarchique de cet intervenant
# Sinon on regarde le sup. de l'intervenant saisi en entete
#---------------------------------------
XUSR=[M:ITL0]IUSCOD
If [M:ITL1]ASSITV(nolign-1)<>"" Then XUSR=[M:ITL1]ASSITV(nolign-1) Endif
###
Read [AUSX]CODUSR=XUSR
If fstat Then Raz [AUSX] Endif
[M:ITL1]IUSHIE(nolign-1)=[F:AUSX]IUSHIE
###

#FM le 15.02.10
GPOINT = "AP_SUPERIEURS" : Gosub ENTREE From EXEFNC

Close Local File [OPPX],[AUSX]
Return

################################################################################
$INIT_PARAM

#initialisation des paramètres pour la recherche des prix
Local Decimal PRIX
Local Char    PARAMC(30)(10)
Local Char    DEVISE
Local Date    PARAMD(10)
Local Integer CURTYP

Case [L]NBREM
When 0       : Local Decimal REMISE
When Default : Local Decimal REMISE([L]NBREM)
Endcase

[L]PARAMC(0)=[M:ITL1]REQNUM (nolign-1)
[L]PARAMC(1)=[M:ITL1]ASSLIB (nolign-1)
[L]PARAMC(2)=[M:ITL1]ASSPRD (nolign-1)
[L]PARAMC(3)=[M:ITL1]UOM    (nolign-1)
[L]PARAMC(4)=[M:ITL1]CODOPE (nolign-1)
[L]PARAMC(5)=[M:ITL1]ITVTYP (nolign-1)
[L]PARAMC(6)=[M:ITL1]BPSNUM (nolign-1)
#FM le 14.03.06
[L]PARAMC(7)=num$([M:ITL1]QTY(nolign-1))
[L]PARAMC(8)=num$([M:ITL1]FCY(nolign-1))
#\FM

# LBORN 04/02/2015 - Mantis 27890
If !clalev([REQ]) : Local File REQUEST : Endif
Read [REQ]REQ0=[M:ITL1]REQNUM(nolign-1)
If !fstat
  [L]PARAMC(9)=[F:REQ]BPAADD
Endif

[L]PARAMD(0)=[M:ITL1]DATITV (nolign-1)
[L]PARAMD(1)=[M:ITL1]STRDAT (nolign-1)

Raz [L]PRIX, [L]REMISE
Return

################################################################################
$RECUP_TYP
If !clalev([PV1]) Then Local File PARVGA1   [PV1] Endif
If !clalev([TSV]) Then Local File TABSIVTYP [TSV] Endif
If !clalev([F:TPV]) : Local File TABPIVTYP  : Endif

Read [F:PV1]PV10 = [L]PARVAL
If !fstat
  If find([F:PV1]TYPDOC,"AC1","FC1")
    # LBORN 22/09/2014 - Mantis 26417
    # Read [TSV]TSV0=[L]PARDOC;GCURLEG
    # If !fstat Then [L]SENS=[F:TSV]INVTYP Endif
    Read [TSV]TSV0=[L]PARDOC;GCURLEG
    If fstat
      Read [TSV]TSV0=[L]PARDOC;""
    Endif
    If !fstat : [L]SENS=[F:TSV]INVTYP : Endif
  Elsif find([F:PV1]TYPDOC,"AF1","FF1")
    # LBORN 22/09/2014 - Mantis 26417
    # Read [TPV]TPV0=[L]PARDOC;GCURLEG
    # If !fstat Then [L]SENS=[F:TPV]INVTYP Endif
    Read [TPV]TPV0=[L]PARDOC;GCURLEG
    If fstat
      Read [TPV]TPV0=[L]PARDOC;""
    Endif
    If !fstat : [L]SENS=[F:TPV]INVTYP : Endif
  Endif
Endif
Return


