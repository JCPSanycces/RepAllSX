If VALEUR<>"" : End : Endif
If !clalev([F:ANM]) : Local File ACODNUM : Endif
Read [F:ANM]ANM0=GCPT
If !fstat & [F:ANM]NIVDEF<>1
  [V]GMESSAGE=mess(10,123,1)
  [V]GERR=1
  mkstat=1
Endif
End

