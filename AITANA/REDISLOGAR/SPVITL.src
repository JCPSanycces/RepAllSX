#&                 ,[M:ITL1]ASSLIB([L]NOL),[L]UVYDAY,[L]UVYCOD,[L]HOUWKD)From SPVOBJITV3
#  [L]DATAC = VALEUR
#
#  # LBORN 14/06/2016 - Mantis 32918
#  # Call CTL_JOU([L]DATAC,[L]UVYDAY,[L]UVYCOD,0)From CONTX3
#  # If [L]DATAC <> VALEUR
#  Call CTL_JOU([L]DATAC,[L]UVYDAY,[L]UVYCOD,0) From XX03SCONTX3
