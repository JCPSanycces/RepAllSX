#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque SCHGAS0
#ACV#X12
#TIT#Saisie Info DS à partir des Brd et des Situations

#LBO 02/2003

Local Char PARAM(250)(1..16),VALEUR(10) 
Raz [L]PARAM

[L]PARAM(1)="LBO5"
[L]PARAM(2)="CIMENT"
[L]PARAM(3)="TITI"
[L]PARAM(4)="TATA"
[L]PARAM(5)="colmmme"
[L]PARAM(6)="1"
[L]PARAM(7)="FRL3"
[L]PARAM(8)="1"
Call TRAITE_CHAR(VALEUR,[L]PARAM,"","XSITINFDS2","SITINFOREQ",4) From GTRAITE    :# Appel avec ouverture de la fenetre
End


#-----------------------------------------------------------------------
# Ecran SITINFOREQ
#-----------------------------------------------------------------------
########################################
Subprog AV_FLGM(VALEUR)
Variable Decimal VALEUR
If VALEUR=1
  Actzo [M:DIA]
Else
  Grizo [M:DIA]
Endif
End

########################################
Subprog AM_QUEUE(VALEUR)
Variable Char    VALEUR()

If !clalev([F:XQU]) : Local File XQUEUE : Endif

Call LECTURE("XQU",VALEUR,"") From CONTOBJ
If !fstat & [M:DIA]RESINT<>[F:XQU]QUERES & [F:XQU]QUERES<>""
  [M:DIA]RESINT=[F:XQU]QUERES
Endif
[V]XMODINFODS=1
End

########################################
Subprog AM_RESINT(VALEUR)
Variable Char    VALEUR()
[V]XMODINFODS=1
End

########################################
Subprog AM_REQSUM(VALEUR)
Variable Char    VALEUR()
[V]XMODINFODS=1
End

