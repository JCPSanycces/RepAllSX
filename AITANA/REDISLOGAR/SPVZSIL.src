#<AdxTL>@(#)1.0.0.0 $Revision:   1.18  $ Gestion du masque ZOOMQTYSIL
#ACV#X16
#TIT#Zoom sur qtés situations

GBIDC1=""
GBIDC2=""
Call OBJET("OPP",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When Default
Endcase
Return

########################################
Subprog AV_PCEDAT(VALEUR)
Variable Date    VALEUR
If [M:DIA]PCEDAT(nolign-1)>[M:DIA]DATSIT
  pcolor=GCOUL(1)
Else
  pcolor=GCOUL(0)
Endif
End

########################################
Subprog IB_NBLIG

Raz [V]GBIDC1,[V]GBIDC3

[V]GBIDC2=[M:DIA]PCENUM(nolign-1)

Case [M:DIA]TYPDOC(nolign-1)
  When "FC1","AC1" : # LBORN 18/02/2015 - Mantis 28392
                     If !clalev([F:SIH]) : Local File SINVOICE : Endif
                     Read [F:SIH]SIH0=[M:DIA]PCENUM(nolign-1)
                     If !fstat & [F:SIH]ORIMOD=3
                       [V]GBIDC1="BIC"
                     Else
                       [V]GBIDC1="SIH"
                     Endif
  When "DA1"       : [V]GBIDC1="PSH"
  When "CA1"       : [V]GBIDC1="POH"
  When "DS1"       : [V]GBIDC1="REQ"
  When "OF1"       : [V]GBIDC1="MFG"
  When "LP1","LV1","RC1","RE1","RP1","RV1","RX1"
    Case [M:DIA]ORIVAL(nolign-1)
      When 1  : [V]GBIDC1="REQ"
      When 2  : [V]GBIDC1="REQ"
                Read [F:VGA]VGA1=[M:DIA]VALNUM(nolign-1)
                If fstat
                  Raz [V]GBIDC1,[V]GBIDC2,[V]GBIDC3
                Else
                  [V]GBIDC2=[F:VGA]REQNUM
                Endif
      When 3    : [V]GBIDC1="XON"
      When 4    : [V]GBIDC1="PTH"
      When 5,30 : [V]GBIDC1="SDH"
      When 6    : [V]GBIDC1="FRL"
      When 13   : [V]GBIDC1="PIH"
      When 20   : [V]GBIDC1="PNH"
      When 21   : [V]GBIDC1="SRH"
      When 26   : [V]GBIDC1="MTK"
      When 27   : [V]GBIDC1="SIH"
    Endcase
Endcase

If [M:DIA]PCENUM(nolign-1)=""
  Raz [V]GBOUT5
Else
  [V]GBOUT5=func XOBJDIV.DES_OBJET([V]GBIDC1)
Endif

If [M:DIA]VALNUM(nolign-1)=""
  Raz [V]GBOUT6
Else
  [V]GBOUT6=mess(68,GXMSGPSA,1)
Endif

End
