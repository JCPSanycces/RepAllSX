########################################
Subprog D_OBJDES(VALEUR)
Variable Char     VALEUR
Call TITOBJ([M:GOB0]OBJCOD,"!",VALEUR)From CONTOBJ
End

########################################
Subprog D_OBJDESSHO(VALEUR)
Variable Char     VALEUR
VALEUR=[M:GOB0]OBJDES
End

########################################
Subprog AS_FILCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR="" Then
    Call LECTURE("AOB",[M:GOB0]OBJCOD,"")From CONTOBJ
    If !fstat Then VALEUR=[F:AOB]NOMFIC Endif
Endif
End

########################################
Subprog AM_FILCOD(VALEUR)
Variable Char    VALEUR()
Call SEEKABR([M]FILCOD,[M]WABREV)
End

########################################
Subprog AV_WABREV(VALEUR)
Variable Char    VALEUR()
Call SEEKABR([M]FILCOD,VALEUR)
End

########################################
Subprog AV_GESPSP(VALEUR)
Variable Integer VALEUR
Gosub GRIPSP
End

########################################
Subprog AM_GESPSP(VALEUR)
Variable Integer VALEUR
Gosub GRIPSP
End


Subprog AV_OBJET(VALEUR)
Variable Char    VALEUR()
Gosub GRILNKOBJ
End


Subprog AM_OBJET(VALEUR)
Variable Char    VALEUR()
Gosub GRILNKOBJ
End




########################################
Subprog C_TABFIC(VALEUR)
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
If VALEUR=[M]FILCOD Then GERR=1 : mkstat=2 : End Endif
Call UNICITE(VALEUR,[M]TABFIC)From OBJDIV
If mkstat Then GERR=1 : End Endif
End

########################################
Subprog AM_TABFIC(VALEUR)
Variable Char    VALEUR()
Call SEEKABR(VALEUR,[M]TABABR(nolign-1))
End

########################################
Subprog AS_TABCLE(VALEUR)
Variable Char    VALEUR()
Local File ATABIND [X__]
If VALEUR="" Then
  Read [X__]NUMLIG(2) = [M]TABFIC(nolign-1);1
  If !fstat Then VALEUR = [F:X__]CODIND Endif
Endif
Close Local File [X__]
End

########################################
Subprog C_TABLIEN(VALEUR)
Variable Char    VALEUR()
Local    File    ATABZON [X__]
Local    File    ATABIND [X_1]
Local    Char    XZON(30)(20) #zones saisies pour le lien
Local    Char    XABR         #Abreviation saisie
Local    Integer XNBZON       #nbre de zones saisies
Local    Char    XELT(30)(20) #elt de la clé de la table principale
Local    Integer XNBELT       #nbre d'elt
Local    Char    XLISABR(30)(dim([M:GOB1]TABFIC)+1)
VALEUR=toupper(VALEUR)
For I=0 To nolign-2 : [L]XLISABR(I)=[M:GOB1]TABABR(I) : Next
[L]XLISABR(I)=[M:GOB1]WABREV
Read [X_1]CODIND=[M:GOB1]TABFIC(nolign-1);[M:GOB1]TABCLE(nolign-1)
If fstat Then Raz [X_1] Endif
Call EXTELT([X_1]DESCRIPT,"+-",[L]XELT,[L]XNBELT)From XTRTDIV
Call EXTELT(VALEUR,";",[L]XZON,[L]XNBZON)From XTRTDIV
If [L]XNBELT=[L]XNBZON Then
  For I=0 To [L]XNBZON-1
    F=instr(1,[L]XZON(I),"]")
    If F Then
        [L]XABR=left$([L]XZON(I),F) : [L]XABR=ctrans(ctrans([L]XABR,"[F:",""),"]","")
        [L]XZON(I)=right$([L]XZON(I),F+1)
    Endif
    If [L]XABR<>"" & !find([L]XABR,[L]XLISABR) Then GERR=1 : Goto NEXT_I Endif
    Read [X__]CODZONE=[M:GOB1]FILCOD;[L]XZON(I)
    If fstat Then GERR=1 : GMESSAGE=[L]XZON(I)-mess(8,124,1) : Goto NEXT_I Endif
  $NEXT_I
  If GERR Then Break Endif
  Next
Else
  GERR=1
Endif
If GERR=1 Then GMESSAGE+=string$(GMESSAGE<>"","\")+mess(101,123,1) : mkstat=2 Endif
Close Local File [X__], [X_1]
End


#===============================================================================
# AMK GASOBJ2
#===============================================================================

########################################
Subprog IB_NBLIG
Raz GBOUT1
If [M]TABCOD(nolign-1)<>"" Then GBOUT1=mess(247,[V]GXMSGPSA,1)-[M]TABCOD(nolign-1) Endif
End

########################################
Subprog AS_TABCOD(VALEUR)
Variable Char    VALEUR()
#FM le 25.05.05
If VALEUR<>"" Then End Endif
Case [M:GOB2]NBLIG
When 0 : VALEUR=[M:GOB1]FILCOD
When Default : If nolign>1 Then VALEUR=[M]TABCOD(nolign-2) Endif
Endcase
End

########################################
Subprog AM_TABCOD(VALEUR)
Variable Char    VALEUR()
[M]TABCOD(nolign-1)=VALEUR
Gosub INI_WTABZONCOD
End

########################################
Subprog C_ZONCOD(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL

VALEUR = toupper(VALEUR)
NOL = nolign-1

If [M]TABCOD(NOL)<>"" Then
    Local File ATABZON [X1_]
    Read [X1_]CODZONE=[M]TABCOD(NOL);VALEUR
    If fstat Then GERR=1 : GMESSAGE=mess(41,100,1) Endif
    Close Local File [X1_]
Endif
If GERR=1 Then Goto FIN_CTLZON Endif

# FM le 25.05.05
Call UNICITE(vireblc([M]TABCOD(NOL)+VALEUR,4),[M]WTABZONCOD)From OBJDIV
If mkstat Then GERR=1 Endif
If GERR=1 Then Goto FIN_CTLZON Endif

$FIN_CTLZON
If GERR Then mkstat=2 Endif
End

########################################
Subprog AM_ZONCOD(VALEUR)
Variable Char    VALEUR()
[M]ZONCOD(nolign-1)=VALEUR
Gosub INI_WTABZONCOD
End

########################################
Subprog AV_WTABZONCOD(VALEUR)
Variable Char    VALEUR()
Gosub INI_WTABZONCOD
VALEUR=[M]WTABZONCOD(nolign-1)
End



################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$GRIPSP
Case VALEUR
When 2       : Actzo [M]PSGCOD, OBJET, LNKOBJ
When Default : Diszo [M]PSGCOD, OBJET, LNKOBJ
Endcase
Return

################################################################################
$GRILNKOBJ
Local Char PARAM
Actzo [M]LNKOBJ
Case VALEUR
When ""      : Effzo [M]LNKOBJ : Diszo [M]LNKOBJ
When Default : If !clalev([AOB]) Then Local File AOBJET Endif
               If !clalev([ATX]) Then Local File ATEXTE Endif
               Call LECTURE ("AOB",VALEUR,"") From CONTOBJ
               Call TEXTE([F:AOB]LIBPAR,[L]PARAM) From OBJDIV
               If [L]PARAM="" Then Effzo [M]LNKOBJ : Diszo [M]LNKOBJ Endif
Endcase
Return

################################################################################
$INI_WTABZONCOD
[M]WTABZONCOD(nolign-1)=vireblc([M]TABCOD(nolign-1)+[M]ZONCOD(nolign-1),4)
Return

################################################################################
Subprog SEEKABR(FIC,ABR)
Value    Char FIC()
Variable Char ABR()

Local File ATABLE [X__]
Read [X__]CODFIC=FIC
If !fstat Then
  ABR=[X__]ABRFIC
Endif
Close Local File [X__]
End


