#ACV#X11
#TIT#Objets GAS

GBIDC1=""
GBIDC2=""
Call OBJET("GOB",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$ACTION

# Appel fonctions complémentaires GFI pour l'objet ITV
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
When "OUVRE"      : Gosub OUVRE       From SPVOBJGOB
When "LIENS"      : Gosub LIENS       From SPVOBJGOB
When "VERIF_CRE"  : Gosub VERIF       From SPVOBJGOB
When "CREATION"   : Gosub CREATION    From SPVOBJGOB
When "VERIF_MOD"  : Gosub VERIF       From SPVOBJGOB
When "MODIF"      : Gosub MODIF       From SPVOBJGOB
When "ANNULE"     : Gosub ANNULE      From SPVOBJGOB
When "SETBOUT"    : Gosub SETBOUT     From SPVOBJGOB
Endcase

#===== Actions scénario sélection dans table
Case ACTION
When "SEL_TABLE"  : Case GACTION
                     When "SELTABGOB"  : Gosub SELTABGOB   From SPVOBJGOB
                     When "SELTABGOB2" : Gosub SELTABGOB2  From SPVOBJGOB
                     When "SELGOBZON2" : Gosub SELGOBZON2  From SPVOBJGOB
                     When Default      : Gosub SEL_TABLE   From SPVOBJGOB
                    Endcase
Endcase

#===== Actions scénario Trt standard
Case ACTION
When "AVANT_PAR"  : Case GACTION 
                    When "TRTZONCOD"  : Gosub AVPTRTZCOD  From SPVOBJGOB
                    Endcase
When "CONTROLE"   : Case GACTION 
                    When "TRTZONCOD"  : Gosub CONTRTZCOD  From SPVOBJGOB
                    Endcase
When "EXEC"       : Case GACTION 
                    When "TRTZONCOD"  : Gosub EXETRTZCOD  From SPVOBJGOB
                    Endcase
Endcase
Return

