########################################
Subprog C_MTH(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] Then mkstat=2 Endif
End

########################################
Subprog C_FIC(VALEUR)
Variable Char    VALEUR()
If VALEUR="" Then mkstat=2 Endif
End

