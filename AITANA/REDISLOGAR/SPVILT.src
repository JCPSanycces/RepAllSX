#<AdxTL>@(#)10.0.0.0 $Revision:   1.20  $ Gestion du masque MCT0
#ACV#X12
#TIT#Gestion du paramétrage des transaction de saisie des CRA

#==========================================================================================
# Gestion de l'objet   : Gestion spécifiques de l'objet ILT (Transactions CRA)
# Date de création     : 23/080/2010
# Auteur               : Laurent Bornes
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

GBIDC1=""
GBIDC2=""
GFONC1="GESILT"
GFLAG="#"
Call OBJET("ILT",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet ILT
Gosub ACTION From XOBJSPE
If GPE=1 : GPE = 0 : Return : Endif

Case ACTION

  When "OUVRE"      : Gosub OUVRE       From SPVOBJILT   
  When "RAZCRE"     : Gosub RAZCRE      From SPVOBJILT
  When "INICRE"     : Gosub INICRE      From SPVOBJILT
                      Gosub INI_CRE_MOD From XTRPSA 
  When "INIMOD"     : Gosub INIMOD      From SPVOBJILT      
                      Gosub INI_CRE_MOD From XTRPSA
  When "CREATION"   : Gosub CREATION    From SPVOBJILT
  When "MODIF"      : Gosub MODIF       From SPVOBJILT
  When "ANNULE"     : Gosub ANNULE      From SPVOBJILT   
                      Gosub ANNULE      From XTRPSA 
  When "CHANGE"     : Gosub CHANGE      From XTRPSA
  When "LIENS"      : Gosub LIENS       From SPVOBJILT 
  When "SETBOUT"    : Gosub SETBOUT     From XTRPSA 
  When "EXEBOUT"    : Gosub EXEBOUT     From XTRPSA
  When "FILTRE"     : Gosub FILTRE      From SPVOBJILT 
  When "AJOUT_ZONE" : Gosub AJOUT_ZONE  From SPVOBJILT   
  When "SEL_TABLE"  : Gosub SELRQTTIT   From SPVOBJILT

Endcase

Return



