End



######################################################################################
Subprog AM_FINRSPFCY(VALEUR)
Variable Char    VALEUR()
Local Integer I
GFCY=VALEUR
Gosub CHARG_PARAM From SPVOBJVGA
If dim([M:VGA4]NBANA)>0
  [M:VGA4]FINRSPFCY=VALEUR
  Effzo [M:VGA4]10
  For [L]I=1 To GOPTCANA
    If [L]I<=GNBDIE
      [M:VGA4]DIE([L]I-1)=GDIE([L]I)
    Endif
    Assign "[M:VGA4]CCE"+num$([L]I) With ""
  Next
  [M:VGA4]NBANA=GNBDIE
  Affzo [M:VGA4]10
Endif
End

######################################################################################
Subprog AM_VGAANA(VALEUR)
Variable Char    VALEUR()
Assign "[M:VGA4]CCE"+num$(nolign) With VALEUR
End
