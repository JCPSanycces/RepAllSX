########################################
Subprog AM_BPCINV(VALEUR)
Variable Char    VALEUR()

Call LECTURE("BPC",[M:VGA1]BPCINV,"") From CONTOBJ
If fstat : Raz [F:BPC] : Endif

# chargement du masque d'adresse
Read [F:BPR]BPR0=VALEUR
If fstat : Raz [F:BPR] : Endif
Call CHARGE_ADB("F",VALEUR,[F:BPR]BPAADD) From XTRTBPA
#
#If [M:ADB3]BPRNAM(0)<>"" 
#  [M:CON1]BPINAM = [M:ADB3]BPRNAM(0) 
#Else 
#  [M:CON1]BPINAM = [F:BPC]BPCNAM  
#Endif

End

########################################
Subprog AM_BPCNUM(VALEUR)
    Variable Char    VALEUR()
    Call LECTURE("BPC",[M:VGA1]BPCNUM,"") From CONTOBJ
    If fstat : Raz [F:BPR] : Endif

    Call CHARGE_ADB("L",VALEUR,[F:BPR]BPAADD) From XTRTBPA

End

