########################################
Subprog AV_BPCNAM(VALEUR)
    Variable Char    VALEUR()
    VALEUR=""
    If [M:VGA1]BPAINV<>""
      If !clalev([F:BPA]) : Local File BPADDRESS : Endif
      Read [F:BPA]BPA0=1;[M:VGA1]BPCINV;[M:VGA1]BPAINV
      If !fstat
        VALEUR=[F:BPA]BPADES
      Endif
    Elsif [M:VGA1]BPCINV<>""
      If !clalev([F:BPC]) : Local File BPCUSTOMER : Endif
      Read [F:BPC]BPC0=[M:VGA1]BPCINV
      If !fstat
        VALEUR=[F:BPC]BPCNAM
      Endif
    Endif
End

