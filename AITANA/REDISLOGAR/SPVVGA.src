#ACV#X11
#TIT#Gestion de la table VALGAS

GBIDC1=""
GBIDC2=""
Call OBJET("VGA",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

#==========================================================================================
# Gestion de l'objet   : Gestion de l'objet VGA : Données de validation
#                        
# Auteur               : 
# Date de création     :       
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 11/09/2003    OTHYR        Ajout de l'action objet AVANTBOUT pour gérer les textes
#==========================================================================================

######################################################################
$ACTION

    # Appel fonctions complémentaires GFI pour l'objet VGA
    Gosub ACTION From XOBJSPE
    If GPE=1 : Return : Endif

    Case ACTION
      When "AVANT_OUVRE" : Gosub AVANT_OUVRE  From SPVOBJVGA
      When "OUVRE"       : Gosub OUVRE        From SPVOBJVGA
      When "OUVRE_BOITE" : Gosub OUVRE_BOITE  From SPVOBJVGA
      When "AVANTBOUT"   : Gosub AVANTBOUT    From SPVOBJVGA
      When "STATUT"      : Gosub STATUT       From SPVOBJVGA
      When "INICRE"      : Gosub INICRE       From SPVOBJVGA
      When "INIMOD"      : Gosub INIMOD       From SPVOBJVGA
      When "APRES_CRE"   : Gosub APRES_CRE    From SPVOBJVGA
      When "SETBOUT"     : Gosub SETBOUT      From SPVOBJVGA
      When "EXEBOUT"     : Gosub EXEBOUT      From SPVOBJVGA
      When "FERME"       : Gosub FERME        From SPVOBJVGA
      When "LIENS"       : Gosub LIENS        From SPVOBJVGA
      When "RAZCRE"      : Gosub RAZCRE       From SPVOBJVGA
      When "RAZDUP"      : Gosub RAZDUP       From SPVOBJVGA
      When "ABANDON"     : Gosub ABANDON      From SPVOBJVGA
      When "INIMOD"      : Gosub INIMOD       From SPVOBJVGA
      When "FILGAUCHE"   : Gosub FILGAUCHE    From SPVOBJVGA
      When "ANNULE"      : Gosub ANNULE       From SPVOBJVGA
    Endcase
    
Return


#-------------------------------------------------------
# Ecran VALGAS0
#-------------------------------------------------------

########################################
Subprog AS_VALNUM(VALEUR)
    Variable Char    VALEUR()
     If find(GREP , "C","D")  Then
       mkstat=2
     Endif
End

########################################
Subprog C_VALNUM(VALEUR)
    Variable Char    VALEUR()
    
    #----- Rien d'affiché, vérif si un enregistrement existe -----#
    If VALEUR<>""
        If [V]GABREV="VGA"
           Look [VGA]VGA1=VALEUR
           If fstat GMESSAGE=mess(178,199,1) : mkstat=1 : End : Endif
        Elsif [V]GABREV="VGH"
           Look [VGH]VGH1=VALEUR
           If fstat GMESSAGE=mess(178,199,1) : mkstat=1 : End : Endif
        Endif
    Endif
End


