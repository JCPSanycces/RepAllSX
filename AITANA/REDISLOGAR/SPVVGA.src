########################################
Subprog AS_CONREV(VALEUR)
Variable Char     VALEUR
    If !GIMPORT Then mkstat=2 Endif
End

########################################
Subprog AM_CONREV(VALEUR)
    Variable Char    VALEUR()
    Call LECTURE("XON",VALEUR,"") From CONTOBJ
    If fstat
       Raz [F:XON]
    Else
       [M:VGA3]CONNUM=[F:XON]CONNUM
       [M:VGA3]TYPREV=[F:XON]TYPREV
       If !GIMPORT Then Affzo [M:VGA3]CONNUM, TYPREV Endif
    Endif
End

########################################
Subprog AS_COPNUM(VALEUR)
Variable Char    VALEUR()
If !GIMPORT Then mkstat = 2 Endif
End

########################################
Subprog AS_ITVNUM(VALEUR)
Variable Char     VALEUR
    If !GIMPORT Then mkstat=2 Endif
End

########################################
Subprog AM_ITVNUM(VALEUR)
    Variable Char    VALEUR()
    Call LECTURE("ITV",VALEUR,"") From CONTOBJ
    If fstat
       Raz [F:ITR]
    Else
       [M:VGA3]ITVTYP=[F:ITR]ITVTYP
       [M:VGA3]REQNUM=[F:ITR]REQNUM
       Call LECTURE("REQ",[M:VGA3]REQNUM,"") From CONTOBJ
       If fstat
          Raz [F:REQ]
       Else
          [M:VGA3]REQTYP=[F:REQ]REQTYP
       Endif
       If !GIMPORT Then Affzo [M:VGA3]REQNUM, ITVTYP, REQTYP Endif
    Endif
End

########################################
Subprog AS_REQNUM(VALEUR)
    Variable Char     VALEUR
    If !GIMPORT Then mkstat=2 Endif
End

########################################
Subprog AM_REQNUM(VALEUR)
    Variable Char    VALEUR()
    Call LECTURE("REQ",VALEUR,"") From CONTOBJ
    If fstat
       Raz [F:REQ]
    Else
       [M:VGA3]REQTYP=[F:REQ]REQTYP
       Call LECTURE("ITV",[M:VGA3]ITVNUM,"") From CONTOBJ
       If !fstat Then
          If [F:ITR]REQNUM<>VALEUR
             Raz [M:VGA3]ITVTYP, ITVNUM
          Endif
       Endif
       If !GIMPORT Then Affzo [M:VGA3] REQTYP,ITVTYP, ITVNUM Endif
    Endif
End


########################################
Subprog AM_RGPCOD(VALEUR)
    Variable Char     VALEUR
    
    Local Shortint XSTAT
    If !clalev([F:RGT])  : Local File RGT     [RGT] : Endif
    If !clalev([F:PV1])  : Local File PARVGA1 [PV1] : Endif
    Local File VALGAS [VGA]
    
    Call CONTROLE("RGT","#",VALEUR,"",[L]XSTAT) From CONTOBJ
    If [L]XSTAT
       [V]GMESSAGE="Code regroupement"-VALEUR+":"-[V]GMESSAGE
       mkstat=1
       End
    Endif
    
    [M:VGA3]VALRUP =[F:VGA]VALRUP
    [M:VGA3]RGPCODV=[F:RGT]RGPCODV
        
    If !GIMPORT Then Affzo [M:VGA3]VALRUP, RGPCODV Endif
    
End


