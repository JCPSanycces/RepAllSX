#----------------------------------
Subprog IB_NBLIG
If [M:CAG2]REQNUM(nolign-1)=""
  [V]GBOUT1=""
Endif
End

#----------------------------------
Subprog AV_VP1(VALEUR)
Variable Char    VALEUR()
If [M:CAG2]DAT(nolign-1)=date$
  pcolor=GCOUL(1)
Else
  pcolor=GCOUL(0)
Endif
End



