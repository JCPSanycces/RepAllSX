#----------------------------------
Subprog AV_GRIZON(VALEUR)
Variable Decimal VALEUR

If [V]GXNBR<1
  Effzo [M:CAG1]VP1
  Effzo [M:CAG2]VP1
  Grizo [M:CAG1]VP1
  Grizo [M:CAG2]VP1
Else
  Actzo [M:CAG1]VP1
  Actzo [M:CAG2]VP1
Endif

If [V]GXNBR<2
  Effzo [M:CAG1]VP2
  Effzo [M:CAG2]VP2
  Grizo [M:CAG1]VP2
  Grizo [M:CAG2]VP2
Else
  Actzo [M:CAG1]VP2
  Actzo [M:CAG2]VP2
Endif

If [V]GXNBR<3
  Effzo [M:CAG1]VP3
  Effzo [M:CAG2]VP3
  Grizo [M:CAG1]VP3
  Grizo [M:CAG2]VP3
Else
  Actzo [M:CAG1]VP3
  Actzo [M:CAG2]VP3
Endif

#If [M:CAG1]DAYCOU=2 | [M:CAG1]WEECOU=2
#  Grizo [M:CAG1]WEE
#  Grizo [M:CAG1]YEA
#  Grizo [M:CAG1]DATBEG
