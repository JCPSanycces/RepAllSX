#Else
#  Actzo [M:CAG1]WEE
#  Actzo [M:CAG1]YEA
#  Actzo [M:CAG1]DATBEG
#  Actzo [M:CAG1]DATEND
#Endif

End


#---------------------------------------
Subprog AV_VD1(VALEUR)
Variable Char    VALEUR()
Call AV_VD(VALEUR,1)
End

#---------------------------------------
Subprog AV_VD2(VALEUR)
Variable Char    VALEUR()
Call AV_VD(VALEUR,2)
End

#---------------------------------------
Subprog AV_VD3(VALEUR)
Variable Char    VALEUR()
Call AV_VD(VALEUR,3)
End


###################################################################
