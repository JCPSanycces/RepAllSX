###################################################################

#----------------------------------
Subprog AV_GRIZONC(VALEUR)
Variable Decimal VALEUR

# Rubriques principales
If [V]GXNBR<1
  Effzo [M:CAGE]VP1
  Grizo [M:CAGE]VP1
Else
  Actzo [M:CAGE]VP1
Endif
If [V]GXNBR<2
  Effzo [M:CAGE]VP2
  Grizo [M:CAGE]VP2
Else
  Actzo [M:CAGE]VP2
Endif
If [V]GXNBR<3
  Effzo [M:CAGE]VP3
  Grizo [M:CAGE]VP3
Else
  Actzo [M:CAGE]VP3
Endif

# Rubriques secondaires
If [V]GXNBRS<1
  Effzo [M:CAGE]VS1
  Grizo [M:CAGE]VS1
Else
  Actzo [M:CAGE]VS1
Endif
If [V]GXNBRS<2
  Effzo [M:CAGE]VS2
  Grizo [M:CAGE]VS2
Else
  Actzo [M:CAGE]VS2
Endif
If [V]GXNBRS<3
  Effzo [M:CAGE]VS3
  Grizo [M:CAGE]VS3
Else
  Actzo [M:CAGE]VS3
Endif
If [V]GXNBRS<4
  Effzo [M:CAGE]VS4
  Grizo [M:CAGE]VS4
Else
  Actzo [M:CAGE]VS4
Endif
If [V]GXNBRS<5
  Effzo [M:CAGE]VS5
  Grizo [M:CAGE]VS5
Else
  Actzo [M:CAGE]VS5
Endif
If [V]GXNBRS<6
  Effzo [M:CAGE]VS6
  Grizo [M:CAGE]VS6
Else
  Actzo [M:CAGE]VS6
Endif
If [V]GXNBRS<7
  Effzo [M:CAGE]VS7
  Grizo [M:CAGE]VS7
Else
  Actzo [M:CAGE]VS7
Endif
If [V]GXNBRS<8
  Effzo [M:CAGE]VS8
  Grizo [M:CAGE]VS8
Else
  Actzo [M:CAGE]VS8
Endif

#If [M:CAGE]DAYCOU=2 | [M:CAGE]WEECOU=2
#  Grizo [M:CAGE]WEE
#  Grizo [M:CAGE]YEA
#  Grizo [M:CAGE]DATBEG
#  Grizo [M:CAGE]DATEND
#Else
#  Actzo [M:CAGE]WEE
#  Actzo [M:CAGE]YEA
#  Actzo [M:CAGE]DATBEG
#  Actzo [M:CAGE]DATEND
#Endif
End


###################################################################
# Zones communes (écran CRITAGE et CONSAGE1)
###################################################################

#----------------------------------
Subprog AV_VD(VALEUR,ZNUM)
Value Integer ZNUM
Variable Char    VALEUR()
If [L]ZNUM>[V]GXNBR
  VALEUR=""
Else
  Case [L]ZNUM
    When 1 : Read [F:SHL]SHL1(2)=[V]GXPLAN;[M]VP1
    When 2 : Read [F:SHL]SHL1(3)=[V]GXPLAN;[M]VP1;[M]VP2
    When 3 : Read [F:SHL]SHL1=[V]GXPLAN;[M]VP1;[M]VP2;[M]VP3
  Endcase
  If !fstat
    VALEUR=evalue("[F:SHL]VD"+num$([L]ZNUM))
  Else
    VALEUR=""
  Endif
Endif
End


#----------------------------------
Subprog AP_DAYCOU(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M]DATBEG=date$
  [M]DATEND=date$
  Call INIZON([M]DATBEG,[M]DATEND,[M]DAYCOU,[M]WEECOU,[M]YEA,[M]WEE)
  Affzo WEE,YEA,DATBEG,DATEND,WEECOU
# Grizo WEE,YEA,DATBEG,DATEND
Elsif [M]WEECOU<>2
# Actzo WEE,YEA,DATBEG,DATEND
Endif
End

End

#----------------------------------
Subprog AP_WEECOU(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M]DATBEG=aweek(week(date$),year(date$))
  [M]DATEND=[M]DATBEG+6
  Call INIZON([M]DATBEG,[M]DATEND,[M]DAYCOU,[M]WEECOU,[M]YEA,[M]WEE)
  Affzo WEE,YEA,DATBEG,DATEND,DAYCOU
# Grizo WEE,YEA,DATBEG,DATEND
Elsif [M]DAYCOU<>2
# Actzo WEE,YEA,DATBEG,DATEND
Endif
End



#----------------------------------
Subprog AM_WEE(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 & [M]YEA<>0
  [M]DATBEG=aweek(VALEUR,[M]YEA)
  [M]DATEND=[M]DATBEG+6
  Affzo [M]DATBEG
  Affzo [M]DATEND
Endif
End

#----------------------------------
Subprog AS_YEA(VALEUR)
Variable Decimal VALEUR
If [M]WEE=0
  mkstat=1
Endif
End

#----------------------------------
Subprog AM_YEA(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 & [M]WEE<>0
  [M]DATBEG=aweek([M]WEE,VALEUR)
  [M]DATEND=[M]DATBEG+6
  Affzo [M]DATBEG
  Affzo [M]DATEND
Endif
End

#----------------------------------
Subprog C_DATEND(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]DATBEG & VALEUR<>[0/0/0] & [M]DATBEG<>[0/0/0]
  mkstat=1
Else
  Call INIZON([M]DATBEG,VALEUR,[M]DAYCOU,[M]WEECOU,[M]YEA,[M]WEE)
  Affzo DAYCOU,WEECOU,WEE,YEA
Endif
End


#---------------------------------------------------------------------------------------
# Init de zones à partir de date debut/fin
#---------------------------------------------------------------------------------------
Subprog INIZON(ZDATBEG,ZDATEND,ZDAYCOU,ZWEECOU,ZYEA,ZWEE)
Value Date ZDATBEG, ZDATEND
Variable Integer ZDAYCOU, ZWEECOU
Variable Decimal ZYEA, ZWEE

Local Date DATCOU

[L]ZDAYCOU=1
[L]ZWEECOU=1
[L]ZWEE=0
[L]ZYEA=0

[L]DATCOU=date$

If [L]ZDATBEG=[L]DATCOU & [L]ZDATEND=[L]DATCOU
  [L]ZDAYCOU=2
  If week(aweek(week([L]DATCOU),year([L]DATCOU)))=week(aweek(week([L]DATCOU)+1,year([L]DATCOU)))-1
    [L]ZWEE=week([L]DATCOU)
    [L]ZYEA=year([L]DATCOU)
  Endif
Elsif aweek(week([L]ZDATBEG),year([L]ZDATBEG))=aweek(week([L]ZDATEND),year([L]ZDATEND))
  If week(aweek(week([L]ZDATBEG),year([L]ZDATBEG)))=week(aweek(week([L]ZDATBEG)+1,year([L]ZDATBEG)))-1
    [L]ZWEE=week([L]ZDATBEG)
    [L]ZYEA=year([L]ZDATBEG)
  Endif
  If aweek(week([L]DATCOU),year([L]DATCOU))=[L]ZDATBEG & [L]ZDATEND=[L]ZDATBEG+6
    [L]ZWEECOU=2
  Endif
Endif
End
