#<AdxTL>@(#)2.0.0.0 $Revision:   1.10  $ Consultation CSI
#ACV#X13
#TIT#Consultation Agenda

#==========================================================================================
# Gestion de la consultation Agenda
#
# Auteur                     : LBORN
# Date de création           : 21/02/2003
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#==========================================================================================

Local Char PARAM(30)(1..6)

PARAM(1)=""
PARAM(2)=""
PARAM(3)=""
PARAM(4)=""
PARAM(5)=""
PARAM(6)=""
Call GCONSULT("XAG","",PARAM)From GCONSULT
End


###################################################################
# Actions objet de consultation
###################################################################

$ACTION

Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
 When Default
Endcase

Return


#-----------------------------------------
$AUTORIS
#-----------------------------------------

# En attendant correction Bug Adonix, car pas possible d'activer action suite à partir d'une fonction
# les paramètres de l'actions suite ne sont pas saisissables dans la fonction, seulement les paramètres
# de l'action principale sont saisissables
If PARAM(1)=""
  Local Char ZPARAM(250)(1..20) , SAVACT(10)
  SAVACT = GACTION : GACTION = "CONSAGETRS"
  Raz [V]GBIDC1
  Call S_LIS_CHAR([V]GBIDC1,[L]ZPARAM,"CONSAGETRS","SPVAGE","") From GACTION
  GACTION=SAVACT
  PARAM(1)=[V]GBIDC1
Endif

If !clalev([F:SHP]) : Local File SCHPARGAS : Endif
Read [F:SHP]SHP0=PARAM(1)
If fstat : OK=0 : Return : Endif
If [L]PARAM(6)<[L]PARAM(5) & [L]PARAM(6)<>"" : OK=0 : Return : Endif

# Affection des écrans / Agenda
Local Integer ZNUMTR
Call RECH_NUMTR([F:SHP]PLANCOD,[L]ZNUMTR) From XSCHVALID2
If ![L]ZNUMTR : OK=0 : Return : Endif
NOMMSK(0)  ="WCONSAGE"   + num$([L]ZNUMTR) + "1"
NOMMSK(1)  ="WCONSAGE"   + num$([L]ZNUMTR) + "2"
CNOMMSK(0) ="WCRITAGE"   + num$([L]ZNUMTR)
WINPROG    ="WGOFCNSAGE" + num$([L]ZNUMTR)
WINPROG2   ="WGODCNSAGE" + num$([L]ZNUMTR)
BOITE      ="WOFCNSAGE"  + num$([L]ZNUMTR)
GBOITE     ="WOFCNSAGE"  + num$([L]ZNUMTR)
CBOITE     ="WODCNSAGE"  + num$([L]ZNUMTR)

Return


#-----------------------------------------
$OUVRE
#-----------------------------------------

Local Char    CRITAGE(250), CRITAGE1(250), CRITAGD(250), CRITAGD1(250), ZCRIT(250), CRITDAT(100)
Local Char    ZBEGHOU(6), ZENDHOU(6), ZCOMMENT(250)
Local Date    ZDAT, ZDEB, ZFIN
Local Integer I

# Sauvegarde des bornes début/fin
Local Char    DEBVP1(30), DEBVP2(30), DEBVP3(30)
Local Char    DEBHOUD(5), DEBHOUF(5), DEBICO(30), DEBCOL(30)
Local Decimal DEBQID, FINQID
Local Date    DEBDAT, FINDAT
Local Char    FINVP1(30), FINVP2(30), FINVP3(30)
Local Char    FINHOUD(5), FINHOUF(5), FINICO(30), FINCOL(30)

# Déclaration / Init variables globales
Gosub DEC_GLOBVAR

# Préchargement masque / Paramètres envoyés
Gosub PRECH_MSK

# Lancement automatique de la recherche
CHARGMT=0

Return


#-----------------------------------------
$LECTURE
#-----------------------------------------

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
# Appel au filtre spécifique client
ACTION = "FILTRE"
Gosub ACTION From XOBJCNS
ACTION = "LECTURE"

# -------------------------------------------------------
# CHGPAG = 1    :    Recherche
# ------ = 2    :    Suite
#        = 3    :    F5 (Rafraichissement page courante)
# CHGPAG = -1   :    Dernier
# ------ = -2   :    Retour (Page précédente)
# -------------------------------------------------------

#-- Application des Filtres
If CHGPAG>0
  SUITE=1
  If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
  Case [M:CAGE]TRI1
    When 2       : # tri par rubrique
                   Filter [AGE] Where evalue([L]CRITAGE) & evalue([L]CRITAGE1) Order By Key AGE0
                   Filter [AGD] Where evalue([L]CRITAGD) Order By Key AGD0
    When Default : # tri par date
                   Filter [AGE] Where evalue([L]CRITAGE) & evalue([L]CRITAGE1) Order By Key AGE4
                   Filter [AGD] Where evalue([L]CRITAGD) Order By Key AGD0
  Endcase
Else
  RETOUR=1
  If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
  Case [M:CAGE]TRI1
    When 2       : # tri par rubrique
                   Filter [AGE] Where evalue([L]CRITAGE) & evalue([L]CRITAGE1) Order By Key AGE0 Desc
                   Filter [AGD] Where evalue([L]CRITAGD) Order By Key AGD0 Desc
    When Default : # tri par date
                   Filter [AGE] Where evalue([L]CRITAGE) & evalue([L]CRITAGE1) Order By Key AGE4 Desc
                   Filter [AGD] Where evalue([L]CRITAGD) Order By Key AGD0 Desc
  Endcase
Endif

#-- Raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CAG2] : Endif

# Remplissage du détail
Call TEMPON("L") From GESECRAN
Gosub REMP_TAB
Call TEMPOFF From GESECRAN

Return



###################################################################
# Divers
###################################################################

#------------------------------------------------------------------
# Déclaration et initialisation des variables globales
#------------------------------------------------------------------
$DEC_GLOBVAR
# Rub principales
If dim([V]GXRUBDES)<0
  Global Char GXRUBDES(30)(3)
Endif
If dim([V]GXNBR)<0
  Global Integer GXNBR
Endif
If dim([V]GXRUBVDEF)<0
  Global Char GXRUBVDEF(50)(3)
Endif


# Rub secondaires
If dim([V]GXRUBDESS)<0
  Global Char GXRUBDESS(30)(9)
Endif
If dim([V]GXNBRS)<0
  Global Integer GXNBRS
Endif

# Planning transaction
If dim([V]GXPLAN)<0
  Global Char GXPLAN(20)
Endif

Raz [V]GXRUBDES,[V]GXNBR
&  ,[V]GXRUBDESS,[V]GXNBRS
&  ,[V]GXPLAN

For [F:SRP]SRP0 Where [F:SRP]PLANCOD=[F:SHP]PLANCOD
  If [F:SRP]RUBTYP=1
    [V]GXRUBDES([V]GXNBR) =[F:SRP]RUBDES
    [V]GXRUBVDEF([V]GXNBR)=[F:SRP]RUBVDEF
    [V]GXNBR+=1
  Else
    [V]GXRUBDESS([V]GXNBRS) =[F:SRP]RUBDES
    [V]GXNBRS+=1
  Endif
Next

[V]GXPLAN=[F:SHP]PLANCOD

# Format rubrique
Call INIT_GXFMTRUB([F:SHP]PLANCOD) From SPVOBJAGE

Return


#------------------------------------------------------------------
# Préchargement écran
#------------------------------------------------------------------
$PRECH_MSK

Raz [L]ZDEB, [L]ZFIN

If PARAM(2)<>""
  [M:CAG1]VP1=PARAM(2)
Endif
If PARAM(3)<>""
  [M:CAG1]VP2=PARAM(3)
Endif
If PARAM(4)<>""
  [M:CAG1]VP3=PARAM(4)
Endif

If PARAM(5)<>""
  [M:CAG1]DATBEG=gdat$(val(right$(PARAM(5),7)),val(mid$(PARAM(5),5,2)),val(left$(PARAM(5),4)))
Endif
If PARAM(6)<>""
  [M:CAG1]DATEND=gdat$(val(right$(PARAM(6),7)),val(mid$(PARAM(6),5,2)),val(left$(PARAM(6),4)))
Endif
If PARAM(5)="" & PARAM(6)=""
  [M:CAG1]DATBEG=aweek(week(date$),year(date$))
  [M:CAG1]DATEND=aweek(week(date$)+1,year(date$))-1
Endif

Call INIZON([M:CAG1]DATBEG,[M:CAG1]DATEND,[M:CAG1]DAYCOU,[M:CAG1]WEECOU,[M:CAG1]YEA,[M:CAG1]WEE)

# Val déf des rubriques si <Vide>
If [M:CAG1]VP1="" & [M:CAG1]VP2="" & [M:CAG1]VP3=""
  Gosub DEF_CLE
Endif

# Copie de l'écran d'entête vers l'écran critère
Gosub CRITENT From =PROGCNS

Return



#------------------------------------------------------------------
# Préparation du filtre
#------------------------------------------------------------------
$LOAD_FILTER

[L]CRITAGE1="1"
[L]CRITAGD1="1"
[L]CRITDAT="1"

# Critère table SCHGAS (en-tête)
[L]CRITAGE="[F:AGE]PLANCOD='"+[V]GXPLAN+"'"
For [L]I=1 To 3
  If evalue("[M:CAGE]VP"+num$([L]I))<>""
    [L]CRITAGE-="& [F:AGE]VP"+num$([L]I)+"='"+evalue("[M:CAGE]VP"+num$([L]I))+"'"
  Endif
Next
If [M:CAGE]DATBEG<>[0/0/0]
  [L]CRITAGE-="& ([F:AGE]YEA>"+num$(year([M:CAGE]DATBEG))-"| ([F:AGE]YEA="+num$(year([M:CAGE]DATBEG))-"& [F:AGE]WEE>="+num$(week([M:CAGE]DATBEG))+"))"
Endif
If [M:CAGE]DATEND<>[0/0/0]
  [L]CRITAGE-="& ([F:AGE]YEA<"+num$(year([M:CAGE]DATEND))-"| ([F:AGE]YEA="+num$(year([M:CAGE]DATEND))-"& [F:AGE]WEE<="+num$(week([M:CAGE]DATEND))+"))"
Endif
For [L]I=1 To 8
  If evalue("[M:CAGE]VS"+num$([L]I))<>""
    [L]CRITAGE-="& [F:AGE]VS"+num$([L]I)+"='"+evalue("[M:CAGE]VS"+num$([L]I))+"'"
  Endif
Next

# Critère table SCHGASD (détail)
[L]CRITAGD="[F:AGD]PLANCOD='"+[V]GXPLAN+"'"
For [L]I=1 To 3
  If evalue("[M:CAGE]VP"+num$([L]I))<>""
    [L]CRITAGD-="& [F:AGD]VP"+num$([L]I)+"='"+evalue("[M:CAGE]VP"+num$([L]I))+"'"
  Endif
Next
If [M:CAGE]DATEND<>[0/0/0]
  [L]CRITAGD-="& [F:AGD]BEGDAT<=[M:CAGE]DATEND"
Endif
If [M:CAGE]DATBEG<>[0/0/0]
  [L]CRITAGD-="& [F:AGD]ENDDAT>=[M:CAGE]DATBEG"
Endif
If [M:CAGE]CODICO<>""
  [L]CRITAGD-="& [F:AGD]CODICO='"+[M:CAGE]CODICO+"'"
Endif
If [M:CAGE]CODCOL<>""
  [L]CRITAGD-="& [F:AGD]CODCOL='"+[M:CAGE]CODCOL+"'"
Endif
If [M:CAGE]COMMENT<>""
  [L]ZCOMMENT=toupper(ctrans([M:CAGE]COMMENT))
  Call REMPCH([L]ZCOMMENT,"*","") From XBIBCH
  If [L]ZCOMMENT<>""
    [L]CRITAGD-="& pat(toupper(ctrans([F:AGD]COMMENT)),'*"+[L]ZCOMMENT+"*')"
  Endif
Endif
If [M:CAGE]REQNUM<>""
  [L]CRITAGD-="& [F:AGD]REQNUM='"+[M:CAGE]REQNUM+"'"
Endif

[L]CRITDAT="[L]ZDAT>=[M:CAGE]DATBEG & ([L]ZDAT<=[M:CAGE]DATEND | [M:CAGE]DATEND=[0/0/0])"

# Critères debut/fin de page

Case CHGPAG

  When 3 : # rafraichissement

    Case [M:CAGE]TRI1
      When 2       : # tri par rubrique
                     [L]CRITAGE1="[F:AGE]VP1>'"+[L]DEBVP1+"' | ([F:AGE]VP1='"+[L]DEBVP1+"' & ("
                     [L]CRITAGE1+="[F:AGE]VP2>'"+[L]DEBVP2+"' | ([F:AGE]VP2='"+[L]DEBVP2+"' & ("
                     [L]CRITAGE1+="[F:AGE]VP3>'"+[L]DEBVP3+"' | ([F:AGE]VP3='"+[L]DEBVP3+"' & ("
                     [L]CRITAGE1+="[F:AGE]YEA>"+num$(year([L]DEBDAT))-"| ([F:AGE]YEA="+num$(year([L]DEBDAT))
                     [L]CRITAGE1-="& [F:AGE]WEE>="+num$(week([L]DEBDAT))+")))))))"

                     [L]CRITAGD1="([F:AGD]VP1+'~'+[F:AGD]VP2+'~'+[F:AGD]VP3+'~'+[L]ZDAT+'~'"
                     [L]CRITAGD1+="+[L]ZBEGHOU+'~'+[L]ZENDHOU+'~'+[F:AGD]CODICO"
                     [L]CRITAGD1+="+'~'+[F:AGD]CODCOL+'~'+num$([F:AGD]CHRQID))>='"
                     [L]CRITAGD1+=[L]DEBVP1+'~'+[L]DEBVP2+'~'+[L]DEBVP3+'~'+[L]DEBDAT+'~'
                     [L]CRITAGD1+=[L]DEBHOUD+'~'+[L]DEBHOUF+'~'+[L]DEBICO+'~'+[L]DEBCOL+'~'
                     [L]CRITAGD1+=num$([L]DEBQID)+"'"

      When Default : # tri par date
                     [L]CRITAGE1="[F:AGE]YEA>"+num$(year([L]DEBDAT))-"| ([F:AGE]YEA="+num$(year([L]DEBDAT))-"& ("
                     [L]CRITAGE1+="[F:AGE]WEE>"+num$(week([L]DEBDAT))-"| ([F:AGE]WEE="+num$(week([L]DEBDAT))-"& ("
                     [L]CRITAGE1+="[F:AGE]VP1>'"+[L]DEBVP1+"' | ([F:AGE]VP1='"+[L]DEBVP1+"' & ("
                     [L]CRITAGE1+="[F:AGE]VP2>'"+[L]DEBVP2+"' | ([F:AGE]VP2='"+[L]DEBVP2+"'"
                     [L]CRITAGE1-="& [F:AGE]VP3>='"+[L]DEBVP3+"')))))))"

                     [L]CRITAGD1="([L]ZDAT+'~'+[L]ZBEGHOU+'~'+[L]ZENDHOU+'~'"
                     [L]CRITAGD1+="+[F:AGD]VP1+'~'+[F:AGD]VP2+'~'+[F:AGD]VP3+'~'"
                     [L]CRITAGD1+="+[F:AGD]CODICO+'~'+[F:AGD]CODCOL+'~'+num$([F:AGD]CHRQID))>='"
                     [L]CRITAGD1+=[L]DEBDAT+'~'+[L]DEBHOUD+'~'+[L]DEBHOUF+'~'
                     [L]CRITAGD1+=[L]DEBVP1+'~'+[L]DEBVP2+'~'+[L]DEBVP3+'~'
                     [L]CRITAGD1+=[L]DEBICO+'~'+[L]DEBCOL+'~'+num$([L]DEBQID)+"'"
    Endcase

  When 2 : # suite

    Case [M:CAGE]TRI1
      When 2       : # tri par rubrique
                     [L]CRITAGE1="[F:AGE]VP1>'"+[L]FINVP1+"' | ([F:AGE]VP1='"+[L]FINVP1+"' & ("
                     [L]CRITAGE1+="[F:AGE]VP2>'"+[L]FINVP2+"' | ([F:AGE]VP2='"+[L]FINVP2+"' & ("
                     [L]CRITAGE1+="[F:AGE]VP3>'"+[L]FINVP3+"' | ([F:AGE]VP3='"+[L]FINVP3+"' & ("
                     [L]CRITAGE1+="[F:AGE]YEA>"+num$(year([L]FINDAT))-"| ([F:AGE]YEA="+num$(year([L]FINDAT))
                     [L]CRITAGE1-="& [F:AGE]WEE>="+num$(week([L]FINDAT))+")))))))"

                     [L]CRITAGD1="([F:AGD]VP1+'~'+[F:AGD]VP2+'~'+[F:AGD]VP3+'~'+[L]ZDAT+'~'"
                     [L]CRITAGD1+="+[L]ZBEGHOU+'~'+[L]ZENDHOU+'~'+[F:AGD]CODICO"
                     [L]CRITAGD1+="+'~'+[F:AGD]CODCOL+'~'+num$([F:AGD]CHRQID))>'"
                     [L]CRITAGD1+=[L]FINVP1+'~'+[L]FINVP2+'~'+[L]FINVP3+'~'+[L]FINDAT+'~'
                     [L]CRITAGD1+=[L]FINHOUD+'~'+[L]FINHOUF+'~'+[L]FINICO+'~'+[L]FINCOL+'~'
                     [L]CRITAGD1+=num$([L]FINQID)+"'"

      When Default : # tri par date
                     [L]CRITAGE1="[F:AGE]YEA>"+num$(year([L]FINDAT))-"| ([F:AGE]YEA="+num$(year([L]FINDAT))-"& ("
                     [L]CRITAGE1+="[F:AGE]WEE>"+num$(week([L]FINDAT))-"| ([F:AGE]WEE="+num$(week([L]FINDAT))-"& ("
                     [L]CRITAGE1+="[F:AGE]VP1>'"+[L]FINVP1+"' | ([F:AGE]VP1='"+[L]FINVP1+"' & ("
                     [L]CRITAGE1+="[F:AGE]VP2>'"+[L]FINVP2+"' | ([F:AGE]VP2='"+[L]FINVP2+"'"
                     [L]CRITAGE1-="& [F:AGE]VP3>='"+[L]FINVP3+"')))))))"

                     [L]CRITAGD1="([L]ZDAT+'~'+[L]ZBEGHOU+'~'+[L]ZENDHOU+'~'"
                     [L]CRITAGD1+="+[F:AGD]VP1+'~'+[F:AGD]VP2+'~'+[F:AGD]VP3+'~'"
                     [L]CRITAGD1+="+[F:AGD]CODICO+'~'+[F:AGD]CODCOL+'~'+num$([F:AGD]CHRQID))>'"
                     [L]CRITAGD1+=[L]FINDAT+'~'+[L]FINHOUD+'~'+[L]FINHOUF+'~'
                     [L]CRITAGD1+=[L]FINVP1+'~'+[L]FINVP2+'~'+[L]FINVP3+'~'
                     [L]CRITAGD1+=[L]FINICO+'~'+[L]FINCOL+'~'+num$([L]FINQID)+"'"

    Endcase

  When -2 : # retour
    Case [M:CAGE]TRI1
      When 2       : # tri par rubrique
                     [L]CRITAGE1="[F:AGE]VP1<'"+[L]DEBVP1+"' | ([F:AGE]VP1='"+[L]DEBVP1+"' & ("
                     [L]CRITAGE1+="[F:AGE]VP2<'"+[L]DEBVP2+"' | ([F:AGE]VP2='"+[L]DEBVP2+"' & ("
                     [L]CRITAGE1+="[F:AGE]VP3<'"+[L]DEBVP3+"' | ([F:AGE]VP3='"+[L]DEBVP3+"' & ("
                     [L]CRITAGE1+="[F:AGE]YEA<"+num$(year([L]DEBDAT))-"| ([F:AGE]YEA="+num$(year([L]DEBDAT))
                     [L]CRITAGE1-="& [F:AGE]WEE<="+num$(week([L]DEBDAT))+")))))))"

                     [L]CRITAGD1="([F:AGD]VP1+'~'+[F:AGD]VP2+'~'+[F:AGD]VP3+'~'+[L]ZDAT+'~'"
                     [L]CRITAGD1+="+[L]ZBEGHOU+'~'+[L]ZENDHOU+'~'+[F:AGD]CODICO"
                     [L]CRITAGD1+="+'~'+[F:AGD]CODCOL+'~'+num$([F:AGD]CHRQID))<'"
                     [L]CRITAGD1+=[L]DEBVP1+'~'+[L]DEBVP2+'~'+[L]DEBVP3+'~'+[L]DEBDAT+'~'
                     [L]CRITAGD1+=[L]DEBHOUD+'~'+[L]DEBHOUF+'~'+[L]DEBICO+'~'+[L]DEBCOL+'~'
                     [L]CRITAGD1+=num$([L]DEBQID)+"'"

      When Default : # tri par date
                     [L]CRITAGE1="[F:AGE]YEA<"+num$(year([L]DEBDAT))-"| ([F:AGE]YEA="+num$(year([L]DEBDAT))-"& ("
                     [L]CRITAGE1+="[F:AGE]WEE<"+num$(week([L]DEBDAT))-"| ([F:AGE]WEE="+num$(week([L]DEBDAT))-"& ("
                     [L]CRITAGE1+="[F:AGE]VP1<'"+[L]DEBVP1+"' | ([F:AGE]VP1='"+[L]DEBVP1+"' & ("
                     [L]CRITAGE1+="[F:AGE]VP2<'"+[L]DEBVP2+"' | ([F:AGE]VP2='"+[L]DEBVP2+"'"
                     [L]CRITAGE1-="& [F:AGE]VP3<='"+[L]DEBVP3+"')))))))"

                     [L]CRITAGD1="([L]ZDAT+'~'+[L]ZBEGHOU+'~'+[L]ZENDHOU+'~'"
                     [L]CRITAGD1+="+[F:AGD]VP1+'~'+[F:AGD]VP2+'~'+[F:AGD]VP3+'~'"
                     [L]CRITAGD1+="+[F:AGD]CODICO+'~'+[F:AGD]CODCOL+'~'+num$([F:AGD]CHRQID))<'"
                     [L]CRITAGD1+=[L]DEBDAT+'~'+[L]DEBHOUD+'~'+[L]DEBHOUF+'~'
                     [L]CRITAGD1+=[L]DEBVP1+'~'+[L]DEBVP2+'~'+[L]DEBVP3+'~'
                     [L]CRITAGD1+=[L]DEBICO+'~'+[L]DEBCOL+'~'+num$([L]DEBQID)+"'"
    Endcase
Endcase
Return




#------------------------------------------------------------------
# Remplissage du détail
#------------------------------------------------------------------
$REMP_TAB

For [F:AGE]

  For [L]I=0 To 6

    If CHGPAG=-2
      [L]ZDAT=[F:AGE]DATBEG+6-[L]I
    Else
      [L]ZDAT=[F:AGE]DATBEG+[L]I
    Endif

    If evalue([L]CRITDAT)

      [L]ZCRIT="[F:AGD]PLANCOD='"+[F:AGE]PLANCOD+"'"
      [L]ZCRIT-="& [F:AGD]VP1='"+[F:AGE]VP1+"'"
      [L]ZCRIT-="& [F:AGD]VP2='"+[F:AGE]VP2+"'"
      [L]ZCRIT-="& [F:AGE]VP3='"+[F:AGE]VP3+"'"
      [L]ZCRIT-="& [F:AGD]BEGDAT<=[L]ZDAT"
      [L]ZCRIT-="& [F:AGD]ENDDAT>=[L]ZDAT"

      For [F:AGD] Where evalue([L]ZCRIT) & evalue([L]CRITAGD)

        Gosub DEF_HOUJ

        If evalue([L]CRITAGD1)

          If NBLU=1
            If CHGPAG=2 | CHGPAG=-2 : Raz [M:CAG2] : Endif
            NBLU = 2
          Endif
          If CHGPAG>0
            If NOL>=MAXLIG-1 : SUITE=2 : Break 3 : Endif
            NOL+=1
          Else
            If NOL<=0 : RETOUR=2 : Break 3 : Endif
            NOL-=1
          Endif

          nolign=NOL+1
          [M:CAG2]=[F:AGE]
          [M:CAG2]=[F:AGD]
          [M:CAG2]DAT(nolign-1)=[L]ZDAT
          [M:CAG2]BEGHOUJ(nolign-1)=[L]ZBEGHOU
          [M:CAG2]ENDHOUJ(nolign-1)=[L]ZENDHOU
          [M:CAG2]ZDAY(nolign-1)=day$([L]ZDAT)
          [M:CAG2]NBLIG+=1

        Endif

      Next
    Endif
  Next
Next

Filter [AGE]
Filter [AGD]

If [M:CAG2]NBLIG>0

  Case [M:CAGE]TRI1
    When 2
      Sorta [M:CAG2]NBLIG [M:CAG2]NBLIG
&     Order By [M:CAG2]VP1(indice),[M:CAG2]VP2(indice),[M:CAG2]VP3(indice),[M:CAG2]DAT(indice),[M:CAG2]BEGHOUJ(indice),[M:CAG2]ENDHOUJ(indice)
&             ,[M:CAG2]CODICO(indice),[M:CAG2]CODCOL(indice),[M:CAG2]CHRQID(indice)
    When Default
      Sorta [M:CAG2]NBLIG [M:CAG2]NBLIG
&     Order By [M:CAG2]DAT(indice),[M:CAG2]BEGHOUJ(indice),[M:CAG2]ENDHOUJ(indice),[M:CAG2]VP1(indice),[M:CAG2]VP2(indice),[M:CAG2]VP3(indice)
&             ,[M:CAG2]CODICO(indice),[M:CAG2]CODCOL(indice),[M:CAG2]CHRQID(indice)
  Endcase

  [L]DEBVP1  =[M:CAG2]VP1(0)
  [L]DEBVP2  =[M:CAG2]VP2(0)
  [L]DEBVP3  =[M:CAG2]VP3(0)
  [L]DEBDAT  =[M:CAG2]DAT(0)
  [L]DEBCOL  =[M:CAG2]CODCOL(0)
  [L]DEBICO  =[M:CAG2]CODICO(0)
  [L]DEBQID  =[M:CAG2]CHRQID(0)
  [L]DEBHOUD =[M:CAG2]BEGHOUJ(0)
  [L]DEBHOUF =[M:CAG2]ENDHOUJ(0)

  [L]FINVP1  =[M:CAG2]VP1([M:CAG2]NBLIG-1)
  [L]FINVP2  =[M:CAG2]VP2([M:CAG2]NBLIG-1)
  [L]FINVP3  =[M:CAG2]VP3([M:CAG2]NBLIG-1)
  [L]FINDAT  =[M:CAG2]DAT([M:CAG2]NBLIG-1)
  [L]FINCOL  =[M:CAG2]CODCOL([M:CAG2]NBLIG-1)
  [L]FINICO  =[M:CAG2]CODICO([M:CAG2]NBLIG-1)
  [L]FINQID  =[M:CAG2]CHRQID([M:CAG2]NBLIG-1)
  [L]FINHOUD =[M:CAG2]BEGHOUJ([M:CAG2]NBLIG-1)
  [L]FINHOUF =[M:CAG2]ENDHOUJ([M:CAG2]NBLIG-1)

Endif

Return


$DEF_HOUJ
If [F:AGD]BEGDAT=[L]ZDAT
  [L]ZBEGHOU=[F:AGD]BEGHOU
Else
  [L]ZBEGHOU="0000"
Endif
If [F:AGD]ENDDAT=[L]ZDAT
  [L]ZENDHOU=[F:AGD]ENDHOU
Else
  [L]ZENDHOU="2359"
Endif
Return



#------------------------------------------------------------------
# Préchargement Auto des rubriques principales
#------------------------------------------------------------------
$DEF_CLE
For [L]I=1 To [V]GXNBR
  Gosub INIT_CLE
Next
Return

$INIT_CLE
If [V]GXRUBVDEF([L]I-1)="" : Return : Endif
Onerrgo PB_RUBVDEF
Assign "[M:CAG1]VP"+num$([L]I) With num$(evalue([V]GXRUBVDEF([L]I-1)))
Onerrgo
Return

$PB_RUBVDEF
Resume


