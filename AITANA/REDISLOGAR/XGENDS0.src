#<AdxTL>@(#)6.0.0.0 $Revision$
#ACV#X12
#TIT#Génération DS
#####CGUES 27/01/03

$ACTION
Return

########################################
Subprog C_GENCOP(VALEUR)
Variable Integer  VALEUR
If [M]GENCON=1 & VALEUR=1 Then
   GMESSAGE=mess(121,[V]GXMSGPSA,1)
   mkstat=1
Endif
End

########################################
Subprog C_FCYBEG(VALEUR)
Variable Char     VALEUR
If [M]TSSITE<>2 & VALEUR="" Then
    mkstat=2
Endif
End

########################################
Subprog D_FCYBEG(VALEUR)
Variable Char     VALEUR
If [M]TSSITE <> 2 Then
    VALEUR=GUSRFCY
Else
    VALEUR = ""
Endif
End

########################################
Subprog AV_INITZON(VALEUR)
Variable Char     VALEUR
Call AP_TSSITE([M]TSSITE)
End

########################################
Subprog AP_TSSITE(VALEUR)
Variable Integer  VALEUR
If VALEUR=2 Then
    Effzo [M]FCYBEG
    Grizo [M]FCYBEG
Else
    Actzo [M]FCYBEG
Endif
End

##################################
Subprog AV_GRIZON(VALEUR)

If GFONC1 = "GESXON" Then
  Grizo [M:XGD] 0-9,11-14,16-19
  If [M:XGD]COPNUMBEG <> "" Then
    Grizo [M:XGD]GENCON
    Grizo [M:XGD]GENCOP
  Else
    Actzo [M:XGD]GENCOP
    If !clalev([F:XON]) : Local File CONTRACT : Endif
    Read [F:XON]XON0 = [M:XGD]CONREVBEG
    If fstat | [F:XON]GNRFLGCON = 2
      Actzo [M:XGD]GENCON
    Else
      Grizo [M:XGD]GENCON
    Endif
  Endif  
Else
  Actzo [M:XGD] 0-9,11-14,16-19
  If [M]TSSITE = 2 : Grizo [M:XGD]FCYBEG : Endif
Endif

End

##################################
Subprog AS_COPNUMBEG(VALEUR)
Variable Char    VALEUR()

If [M:XGD]CONREVBEG = "" | [M:XGD]CONREVEND = "" | [M:XGD]CONREVBEG <> [M:XGD]CONREVEND
  mkstat = 1
Endif

End

##################################
Subprog AS_COPNUMEND(VALEUR)
Variable Char    VALEUR()

If [M:XGD]CONREVBEG = "" | [M:XGD]CONREVEND = "" | [M:XGD]CONREVBEG <> [M:XGD]CONREVEND
  mkstat = 1
Endif

End



