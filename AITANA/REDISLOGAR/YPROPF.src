#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# YA025
#
# Gestión de la máscara YPROPF
# Mofificar la fecha de recepción a todas las líneas marcadas del pedido de compra
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "TITRE"         : Gosub TITLE
 When "DEBUT"         : Gosub DEBUT
 When "OK"            : Gosub OK
Endcase
Return
######################################################################################
$OUVRE
Case GACTION
 When "YPROPF"  : Gosub OUV_YPROPF
Endcase
Return
########################################################
$TITLE
  Case GACTION
   When "YPROPF"  : TIT="Introduce la fecha de recepción a asignar"
  Endcase
Return
########################################################
$DEBUT
Case GACTION
 When "YPROPF" : Gosub DEB_YPROPF
Endcase
Return
#######################################################
$OK
Case GACTION
 When "YPROPF"  : Gosub OK_YPROPF
Endcase
Return
########################################################
$OUV_YPROPF
#Infbox('OUV_YPROPF')
Local Integer NUM
NUM = 0

For I = 0 To ([M:POH2]NBLIG -1)
  If [M:POH2]YPROPF(I) = 2
    NUM += 1
  Endif
Next I

If NUM = 0
  GMESSAGE= 'No se ha marcado ninguna línea a modificar. \Debe marcar al menos uno del los checks situados a la izquierda del artículo.'
  GERR = 2
  mkstat=2
Endif

Return
########################################################
$DEB_YPROPF
#Infbox('DEB_YPROPF')
Return
########################################################
$OK_YPROPF

#Infbox('OK_YPROPF  ' + [M:YPFR]YFERECE + ' ' + num$([M:POH2]NBLIG))

For I = 0 To ([M:POH2]NBLIG -1)
  If [M:POH2]YPROPF(I) = 2
    [M:POH2]EXTRCPDAT(I) = [M:YPFR]YFERECE
    [M:POH2]YPROPF(I) = 1
    Affzo [M:POH2]EXTRCPDAT(I)
    Affzo [M:POH2]YPROPF(I)
  Endif
Next I

Return
########################################################

