# Gestion de l'objet   : Planning semaine marges détail
#                        
# Auteur               : Laurent Bornes
# Date de création     : 15/03/2010      
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

GBIDC1=""
GBIDC2=""
GFONC1="GESFRL"
Call OBJET("FRL",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
  When "DEBUT"  : Gosub DEBUT  From XPLAWEE2
  When "BOUTON" : Gosub BOUTON From XPLAWEE2
Endcase

Return

######################################################################################
Subprog C_PERFIN(VALEUR)
Variable Date    VALEUR
If [M]PERDEB<>[0/0/0] & VALEUR<>[0/0/0] & VALEUR<[M]PERDEB
  [V]GMESSAGE=mess(90,121,1)
  [V]GERR=1
  mkstat=1
Else
  Call RAFFRAICHI([M:XPW]PERDEB,VALEUR,[M:XPW]ECH) From XPLAWEE2
Endif
End

######################################################################################
Subprog CL_ICO1(VALEUR)
Variable Char    VALEUR()
[M:XPW]ECH=max([M:XPW]ECH-1,1)
Call RAFFRAICHI([M:XPW]PERDEB,[M:XPW]PERFIN,[M:XPW]ECH) From XPLAWEE2
End

######################################################################################
Subprog CL_ICO2(VALEUR)
Variable Char    VALEUR()
[M:XPW]ECH=min([M:XPW]ECH+1,len(mess(0,1912,1)))
Call RAFFRAICHI([M:XPW]PERDEB,[M:XPW]PERFIN,[M:XPW]ECH) From XPLAWEE2
End

######################################################################################
Subprog AM_ECH(VALEUR)
Variable Integer VALEUR
Call RAFFRAICHI([M:XPW]PERDEB,[M:XPW]PERFIN,VALEUR) From XPLAWEE2
End

######################################################################################
Subprog AV_ICO1(VALEUR)
Variable Char    VALEUR()
If [M:XPW]ECH=1
  VALEUR=""
Else
  VALEUR="153"
Endif
End

######################################################################################
Subprog AV_ICO2(VALEUR)
Variable Char    VALEUR()
If [M:XPW]ECH=len(mess(0,1912,1))
  VALEUR=""
Else
  VALEUR="154"
Endif
End
