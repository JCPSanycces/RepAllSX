$ACTION
Case ACTION
 When "VERIF_CRE" : Gosub VERIF_CRE From SPVOBJX7H
 When "SETBOUT"   : Gosub SETBOUT   From SPVOBJX7H
 When Default
Endcase
Return


######################################################################################
Subprog C_CRTDEB(VALEUR)
Variable Char    VALEUR()

Local File AOBJET

Read [F:AOB]ABREV=[M:XWF1]OBJET(nolign-1)
If fstat
    Call RSTA("AOB",[M:XWF1]OBJET(nolign-1)) From GLOCK : XERR=1 : End
Endif
# Recherche de la clé primaire
Gosub CLE From XTRTFLXWS

Local File = [F:AOB]NOMFIC Where evalue("[F:"+[F:ATB]ABRFIC+"]"+CLE(1)+'="'+VALEUR+'"')
#Default File "["+[F:ATB]ABRFIC+"]"
Read [F] First
If fstat
    GMESSAGE=mess(00004,00120,1)
    GERR=1
    mkstat=2
Endif

End

######################################################################################
Subprog C_CRTFIN(VALEUR)
Variable Char    VALEUR()

Call C_CRTDEB(VALEUR)

End


######################################################################################
## Etiquette ajoutée par le superviseur (écran XWSFLUX1) 27/12/2011 09:54:18 (SOUCH)
