Subprog AM_XLEC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz [M]XCRE(nolign-1)
  Raz [M]XMOD(nolign-1)
  Raz [M]XSUP(nolign-1)
  Affzo [M]XCRE(nolign-1)
  Affzo [M]XMOD(nolign-1)
  Affzo [M]XSUP(nolign-1)
Endif

End

Subprog AM_XCRE(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz [M]XLEC(nolign-1)
  Raz [M]XMOD(nolign-1)
  Raz [M]XSUP(nolign-1)
  Affzo [M]XLEC(nolign-1)
  Affzo [M]XMOD(nolign-1)
  Affzo [M]XSUP(nolign-1)
Endif
End

Subprog AM_XMOD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz [M]XCRE(nolign-1)
  Raz [M]XLEC(nolign-1)
  Raz [M]XSUP(nolign-1)
  Affzo [M]XCRE(nolign-1)
  Affzo [M]XLEC(nolign-1)
  Affzo [M]XSUP(nolign-1)
Endif
End

Subprog AM_XSUP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz [M]XCRE(nolign-1)
  Raz [M]XMOD(nolign-1)
  Raz [M]XLEC(nolign-1)
  Affzo [M]XCRE(nolign-1)
  Affzo [M]XMOD(nolign-1)
  Affzo [M]XLEC(nolign-1)
Endif
End


