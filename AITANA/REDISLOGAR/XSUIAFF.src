#<AdxTL>@(#)9.0.0.0 $Revision$
#ACV#X16
#TIT#Trt init XSUIAFF

#==========================================================================================
# Gestion de l'objet   : Traitement d'initialisation état vente XSUIAFF.rpt
# Date de création     : 02/10/2006
# Auteur               : XROCC
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 03/10/2011    LBORN        Remplissage de la table de travail XPILOPP + Maj diverses
#==========================================================================================

######################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)
End

######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()()
Local Integer IMPR, TRAITAUTO, I

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

[L]TRAITAUTO = 0
[L]CRITERE = "[F:FRL]VLYFLG=2 & [F:FRL]ENAFLG=2"
[L]CRITSUP = "1=1"
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "__REQUETE"       : NUMREQ = val([L]VALEUR)
   When "X3ETA"           : [L]ETAT = [L]VALEUR

   #--- alimentation des paramètres utilisateur
   When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$(NUMREQ)
   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT

   #--- préparation du filtre à appliquer sur la table FRL
   When "sitedeb"         : [L]CRITERE -= "& SALFCY>='"+[L]VALEUR+"'"
   When "sitefin"         : [L]CRITERE -= "& SALFCY<='"+[L]VALEUR+"'"
   When "affairedeb"      : [L]CRITERE -= "& OPPNUM>='"+[L]VALEUR+"'"
   When "affairefin"      : [L]CRITERE -= "& OPPNUM<='"+[L]VALEUR+"'"
   When "statutdeb"       : [L]CRITERE -= "& STAFRM>="+num$([L]VALEUR)
   When "statutfin"       : [L]CRITERE -= "& STAFRM<="+num$([L]VALEUR)

   #--- préparation du filtre à appliquer sur l'affichage
   When "imp1flg"         : [L]FLG1 = val([L]VALEUR)
   When "imp2flg"         : [L]FLG2 = val([L]VALEUR)
   When "imp3flg"         : [L]FLG3 = val([L]VALEUR)
   When "imp4flg"         : [L]FLG4 = val([L]VALEUR)
   When "imp5flg"         : [L]FLG5 = val([L]VALEUR)
 Endcase
 Endif
Next

Filter [F:FRL] Where evalue([L]CRITERE)

Trbegin [F:XPO]
Delete [F:XPO] Where IDENT=[V]GIDENT
Commit

Raz WNUMLIG, WNUMLIG2, WNUMLIG3, WNUMLIG4, WNUMLIG5

For [F:FRL]FRL0

   GOK=1
   Call DEBTRANS From GLOCK
   Trbegin [F:ARM],[F:XPO]

    # LBORN 03/10/2011 - Alimentation d'une nouvelle table de travail (XPILOPP) - Il faudra à terme utiliser que celle-ci et supprimer tout le code en amont
    Gosub ALIM_XPILOPP

#####################
#####################
#  A REVOIR
#####################
#####################
Goto SUITE : # LBORN 05/10/2011 - Ancien code à revoir, s'appuyer désormais sur la table XPILOPP

    # 1ère évaluation pour remplissage tableau 1 : table SITUATIOND [SL2]
    If FLG1=1 or FLG4=1 or FLG5=1 Then
    For [F:FRA]FRA0 Where [F:FRA]FRMNUMLIG = [F:FRL]FRMNUMLIG
        # raz du fichier + alimentation FRA$

        WNUMLIG +=1
        WNUMLIG1 +=1

        #Raz [F:YA2]
        [F:ARM]USR    = GUSER
        [F:ARM]NUMREQ = NUMREQ
        [F:ARM]NUMLIG = WNUMLIG
        [F:ARM]RPTCOD = [L]ETAT

        [F:ARM]CLEN1  = 1   # CODTAB( c'est le premier tableau).
        [F:ARM]CLEN2  = WNUMLIG1
        [F:ARM]CLEA5  = [FRL]OPPNUM      : # AFFAIRE
        [F:ARM]CLEA6  = [F:FRA]FRMNUMLIG

        # saisie éléments
        [F:ARM]CLEA1  = [F:FRA]ITMREFPUR   : # réf article
        [F:ARM]CLEA2  = [F:FRA]ITMDESPUR   : # designation article
        [F:ARM]CLEMD3 = [F:FRA]GROPRINET                          : # Coût unitaire
        [F:ARM]CLEA3  = [F:FRA]UOM                              : # unité
        [F:ARM]CLEMD1 = [F:FRA]QTYUOM                           : # qté prévue
        [F:ARM]CLEMD4 = [F:FRA]NETAMTPUR            : # montant prévu
        [F:ARM]CREDAT = date$
        [F:ARM]CLEA4  = [F:FRA]CCE1        : # Axe analytique 1
        Raz YZ
        For [F:VGS]VGA8 Where [F:VGS]FRMNUMLIG = [F:FRA]FRMNUMLIG & LINFRMIND=[F:FRA]NUMLIGFRL2 & TYPDOC="RC1"
#        For [F:VGS]VGA8 Where [F:VGS]FRMNUMLIG = [F:FRA]FRMNUMLIG & LINFRMIND=[F:FRA]NUMLIGFRL2 & VGASTA=2 & TYPDOC="RC1"
            If YZ>0 Then
                WNUMLIG1 +=1
            Endif
            [F:ARM]CLEMD2 = [F:VGS]QTY                              : # qté réalisée
            If [F:VGS]UOM <>"" Then
                [F:ARM]CLEA3 = [F:VGS]UOM     : # unité
            Endif
            [F:ARM]CLEMD4 = [F:VGS]PRIPUR*[F:VGS]QTY                : # montants réalisés
            #[F:arm]DAT1 = [F:VGS]PCEDAT      : # date de mise à disposition
            If [F:VGS]CCE1 <> "" Then
                [F:ARM]CLEA4 = [F:VGS]CCE1 Endif       : # Axe analytique 1
            Call PRORATA(2,[F:VGS]BEGDAT,[F:VGS]ENDDAT,([F:FRA]NETAMTPUR*[F:FRA]QTYUOM),([F:VGS]UNTPRI*[F:VGS]QTY),GOK)
            Gosub YA21
            If GOK<1 Then
               Errbox "Erreur en prorata phase 1" Titled "XSUIAFF"
               Break
            Endif
            YZ +=1
        Next
        If YZ=0 Then
           Gosub YA21
           If GOK<1 Then
           Errbox "Erreur en tableau 1" Titled "XSUIAFF"
           Break
           Endif
        Endif
    Next
     Endif
    # 2eme évaluation pour remplissage tableau 2 : : table SITUATIONR [SL3]
    If FLG2=1 or FLG4=1 or FLG5=1 Then
    For [F:FRR]FRR0 Where [F:FRR]FRMNUMLIG = [F:FRL]FRMNUMLIG
        #Raz [F:YA2]

        WNUMLIG +=1
        WNUMLIG2 +=1

        [F:ARM]USR    = GUSER
        [F:ARM]NUMREQ = NUMREQ
        [F:ARM]NUMLIG = WNUMLIG
        [F:ARM]RPTCOD = [L]ETAT

        [F:ARM]CLEN1  = 2   # CODTAB( c'est le 2é tableau).
        [F:ARM]CLEN2  = WNUMLIG2
        [F:ARM]CLEA5  = [FRL]OPPNUM      : # AFFAIRE
        [F:ARM]CLEA6  = [F:FRR]FRMNUMLIG

        # saisie éléments
        [F:ARM]CLEA1 = [F:FRR]ITEM        : # réf article
        Read [F:ITM]ITM0 = [F:FRR]ITEM
        If !fstat Then
           [F:ARM]CLEA2 = [F:ITM]ITMDES1  : # designation article
        Endif
        [F:ARM]CLEMD1 = [F:FRR]EXTQTY                       : # qté prévue
        [F:ARM]CLEMD3 = [F:FRR]COST                 : # cout
        [F:ARM]CLEMD4 = [F:FRR]COST*[F:FRR]EXTQTY      : # montant prévu

        [F:ARM]CLEA3 = [F:FRR]UOMEXT      : # unité
        [F:ARM]CLEA4 = [F:FRR]CCEDS1      : # Axe analytique 1
        [F:ARM]CREDAT = date$
        Raz YZ
        For [F:VGS]VGA8 Where [F:VGS]FRMNUMLIG = [F:FRR]FRMNUMLIG & LINFRMIND=[F:FRR]NUMLIGFRL3 & TYPDOC="RE1"
#        For [F:VGS]VGA8 Where [F:VGS]FRMNUMLIG = [F:FRR]FRMNUMLIG & LINFRMIND=[F:FRR]NUMLIGFRL3 & VGASTA=2 & TYPDOC="RE1"
            If YZ>0 Then WNUMLIG2+=1 : Endif
            [F:ARM]CLEMD2 = [F:VGS]QTY         : # qté réalisée
            If [F:VGS]UOM <> "" Then
                [F:ARM]CLEA3 = [F:VGS]UOM
            Endif        : # unité
######
            #[F:YA2]DEC5 = [F:VGS]QTY+[F:VGS]PRIPUR : # montant réalisé
            #[F:YA2]DAT1 = [F:VGS]BEGDAT        : # date de début
            #[F:YA2]DAT2 = [F:VGS]ENDDAT       : # date de fin
#####
            If [F:VGS]CCE1 <> "" Then
                [F:ARM]CLEA4 = [F:VGS]CCE1
            Endif       : # Axe analytique 1
            Gosub YA22
            If GOK<1 Then
             Errbox "Erreur en tableau 2" Titled "XSUIAFF"
             Break
            Endif
            Call PRORATA(3,[F:VGS]BEGDAT,[F:VGS]ENDDAT,([F:FRR]COST*[F:FRR]EXTQTY),([F:VGS]QTY+[F:VGS]UNTPRI),GOK)
            If GOK<1 Then
             Errbox "Erreur en prorata phase 2" Titled "XSUIAFF"
             Break
            Endif
            YZ+=1
        Next
        If YZ=0 Then
            Gosub YA22
            If GOK<1 Then
               Errbox "Erreur en tableau 2" Titled "XSUIAFF"
               Break
            Endif
        Endif
    Next
    Endif
    # 3eme évaluation pour remplissage tableau 3 : : table SITUATIONL [SL3]
    If FLG3=1 or FLG4=1 or FLG5=1 Then
#Dbgaff
    For [F:FLD]FLD0 Where [F:FLD]FRMNUMLIG = [F:FRL]FRMNUMLIG
        WNUMLIG3 +=1
        #Raz [F:YA2]
        [F:ARM]USR    = GUSER
        [F:ARM]NUMREQ = NUMREQ
        [F:ARM]NUMLIG = WNUMLIG
        [F:ARM]RPTCOD = [L]ETAT

        [F:ARM]CLEN1  = 3   # CODTAB( c'est le 3é tableau).
        [F:ARM]CLEN2  = WNUMLIG3
        [F:ARM]CLEA5  = [FRL]OPPNUM      : # AFFAIRE
        [F:ARM]CLEA6  = [F:FLD]FRMNUMLIG

        # saisie éléments
        [F:ARM]CLEN3 = [F:FLD]STEPS       : # Etape
        [F:ARM]CLEA1 = mess([F:FLD]STEPS,1734,1)       : # Etape(pour analyse croisée)
        #[F:YA2]DAT1 = [F:FLD]EXTDAT      : # date prévue
        [F:ARM]CLEMD1 = [F:FLD]PRCINV      : # pourcentage facturé
        [F:ARM]CLEMD4 = [F:FLD]AMTINV                  : # montant prévus
        [F:ARM]CREDAT = date$
        Raz YZ

        For [F:VGA] Where [F:VGA]FRMNUMLIG = [F:FRL]FRMNUMLIG & LINFRMIND=[F:FLD]NUMLIGD
         If YZ>0 Then WNUMLIG3+=1 : Endif
         #[F:ARM]CLEMD5 = [F:VGA]UNTPRI*[F:VGA]QTY
         Gosub YA23
         If GOK<1 Then
            Errbox "Erreur en tableau 3" Titled "XSUIAFF"
            Break
         Endif
         Call PRORATA(1,[F:VGA]BEGDAT,[F:FLD]CPLDAT,[F:FLD]AMTINV,([F:VGA]UNTPRI*[F:VGA]QTY),GOK)
         If GOK<1 Then
            Errbox "Erreur en prorata phase 3" Titled "XSUIAFF"
            Break
         Endif
         YZ+=1
        Next

        If YZ=0 Then
         Gosub YA23
         If GOK<1 Then
          Errbox "Erreur en tableau 3" Titled "XSUIAFF"
          Break
         Endif
        Endif
     Next
    Endif

  $SUITE
  If GOK < 1 Then
     Rollback
     Call ROLL From GLOCK
     If GROLL : End : Endif
  Else
     Commit
  Endif

  Next

End


######################################################################
Subprog PRORATA(TYP,DATDEB,DATFIN,AMT, AMT_R, YOK)
Variable Integer YOK
Value Integer TYP
Value Date DATDEB
Value Date DATFIN
Value Decimal AMT
Value Decimal AMT_R
Local Integer ECART
Local Decimal YPRO, YPRO_R
Local Date YDAT
YOK = 1
If DATDEB=[00/00/0000] or DATFIN=[00/00/0000] Then
Else
  # évaluation du nombre de mois pour proratiser
   ECART = ar2((gdat$(1,month(DATFIN),year(DATFIN))-gdat$(1,month(DATDEB),year(DATDEB)))/30)
   If ECART<>0 Then
      YPRO   = AMT/(ECART+1)
      YPRO_R = AMT_R/(ECART+1)
      For I= 0 To (ECART)
          YDAT = gdat$(1,month(DATDEB)+I,year(DATDEB))
          Gosub ECR_TBL4
          If YOK<1 Then Break : Endif
          Gosub ECR_TBL5
          If YOK<1 Then Break : Endif
      Next
   Else
      YDAT   = gdat$(1,month(DATDEB),year(DATDEB))
      YPRO   = AMT
      YPRO_R = AMT_R
      Gosub ECR_TBL4
      Gosub ECR_TBL5
   Endif
Endif

End

######################################################################
# étiquette pour le stockage des informations du tableau 4
$ECR_TBL4

 #Raz  [F:YA2]
 YOK=1
 Local Integer YSEEK



 WNUMLIG +=1
 WNUMLIG4 +=1

 [F:ARM]USR    = GUSER
 [F:ARM]NUMREQ = NUMREQ
 [F:ARM]NUMLIG = WNUMLIG
 [F:ARM]RPTCOD = [L]ETAT

 [F:ARM]CLEN1  = 4   # CODTAB( c'est le 2é tableau).
 [F:ARM]CLEN2  = WNUMLIG4
 [F:ARM]CLEA5  = [FRL]OPPNUM      : # AFFAIRE
 [F:ARM]CLEA6  = [F:FRL]FRMNUMLIG

 [F:ARM]CLED1   = YDAT
 [F:ARM]CREDAT = date$
 [F:ARM]CLEA1 = "CA prévu"
 [F:ARM]CLEA2 = "Coût prévu"
 [F:ARM]CLEA3 = "CA Réalisé"
 [F:ARM]CLEA4 = "Coût réalisé"

 Raz YSEEK
 For [F:ARM2]ARM0 Where [F:ARM2]NUMREQ = [V]NUMREQ & [F:ARM2]USR    = GUSER & [F:ARM2]RPTCOD = [L]ETAT
 If [F:ARM2]CLEA5 = [F:FRL]OPPNUM & [F:ARM2]CLEN1=4 & [F:ARM2]CLED1=[L]YDAT Then
     YSEEK+=1
 Endif
 Next
 If YSEEK=0 Then
    If TYP=1 Then
       [F:ARM]CLEMD1 = YPRO
       [F:ARM]CLEMD3 = YPRO_R
    Else
       [F:ARM]CLEMD2 = YPRO
       [F:ARM]CLEMD4 = YPRO_R
    Endif
    Write [F:ARM]
    If fstat : YOK=0 : Endif
 Else

    If TYP=1 Then
       [F:ARM2]CLEMD1   +=  YPRO
       [F:ARM2]CLEMD3   +=  YPRO_R
    Else
       [F:ARM2]CLEMD2   +=  YPRO
       [F:ARM2]CLMED4   +=  YPRO_R

    Endif
    Rewrite [F:ARM2]
    If fstat Then
       YOK=0
    Endif
 Endif

Return

######################################################################
# étiquette pour le stockage des informations du tableau 5
$ECR_TBL5

 #Raz  [F:YA2]
 YOK=1
 Local Integer YSEEK

 WNUMLIG +=1
 WNUMLIG5 +=1

 [F:ARM]USR    = GUSER
 [F:ARM]NUMREQ = NUMREQ
 [F:ARM]NUMLIG = WNUMLIG
 [F:ARM]RPTCOD = [L]ETAT

 [F:ARM]CLEN1  = 5   # CODTAB( c'est le 2é tableau).
 [F:ARM]CLEN2  = WNUMLIG5
 [F:ARM]CLEA5  = [FRL]OPPNUM      : # AFFAIRE
 [F:ARM]CLEA6  = [F:FRL]FRMNUMLIG

 [F:ARM]CLEA1 = "Encaissements prévus"
 [F:ARM]CLEA2 = "Décaissements prévus"
 [F:ARM]CLEA3 = "Encaissements réels"
 [F:ARM]CLEA4 = "Décaissements réels"
 [F:ARM]CREDAT = date$

 Raz YSEEK

 For [F:ARM2]ARM0 Where [F:ARM2]NUMREQ = [V]NUMREQ &  [F:ARM2]USR = GUSER & [F:ARM2]RPTCOD = [L]ETAT

 If [F:ARM2]CLEA5 = [F:FRL]OPPNUM & [F:ARM2]CLEN1=5 & [F:ARM2]CLED1=[L]YDAT Then
     YSEEK+=1
 Endif
 Next
 If YSEEK=0 Then
    Case TYP
       When 1 : [F:ARM]CLEMD1 = YPRO
                [F:ARM]CLEMD3 = YPRO_R

       When 2 : [F:ARM]CLEMD2 = YPRO
                [F:ARM]CLEMD4 = YPRO_R

       When Default :   [F:ARM]CLEMD2 = YPRO
                        [F:ARM2]CLEMD4 = YPRO_R
    Endcase
    Write [F:ARM]
    If fstat : YOK=0 : Endif
 Else
    Case TYP
       When 1 : [F:ARM2]CLEMD1 += YPRO
                [F:ARM2]CLEMD3 += YPRO_R
       When 2 :
                [F:ARM2]CLEMD2 += YPRO
                [F:ARM2]CLEMD4 += YPRO_R

       When Default :      [F:ARM2]CLEMD2 += YPRO
                           [F:ARM2]CLEMD4 += YPRO_R

    Endcase
    Rewrite [F:ARM2]
    If fstat Then
       YOK=0
    Endif
 Endif

Return


######################################################################
$YA21
Write [F:ARM]
If fstat : Goto ROLL_YA21 : Endif
Return

$ROLL_YA21
GOK=0
Return

######################################################################
$YA22
Write [F:ARM]
If fstat : Goto ROLL_YA22 : Endif
Return

$ROLL_YA22
GOK=0
Return

######################################################################
$YA23
Write [F:ARM]
If fstat : Goto ROLL_YA23 : Endif
Return

$ROLL_YA23
GOK=0
Return

######################################################################
$OUVRE

Local File AREPORTM    [F:ARM]
Local File AREPORTM    [F:ARM2]
Local File XETATTMP    [F:XET]
Local File SITUATIONL  [F:SL1]
Local File SITUATIOND  [F:SL2]
Local File SITUATIONR  [F:SL3]
Local File SITUATIONB  [F:SIB]

Local File VALGASSIT [F:VGS]
Local File VALGAS    [F:VGA]
Local File FORMSL    [F:FRL]
Local File FORMSLA   [F:FRA]
Local File FORMSLD   [F:FLD]
Local File FORMSLR   [F:FRR]

Local File ITMMASTER [F:ITM]

# LBORN 04/10/2011
Gosub OUV_FIL From XPILOPP2
Local File XPILOPP

Return

######################################################################
$DECLARE
Local Char     CRITERE(255),CRITSUP(100),PARAM(30),VALEUR(30),ETAT(30)
Global Integer NUMREQ, WNUMLIG,WNUMLIG1,WNUMLIG2, WNUMLIG3, WNUMLIG4, WNUMLIG5
Local Integer  FLG1,FLG2,FLG3,FLG4,FLG5,YZ

# LBORN 04/10/2011
Local Char CURSOCOPP(30), CURSOCFRL(30), SVGLOCDEV(30)

Return

######################################################################
$ALIM_XPILOPP

Gosub INIT_CUR
#Dbgaff
# Achats
If [L]FLG1
  For [F:FRA]FRA0 Hint Key FRA0 Where [F:FRA]FRMNUMLIG=[F:FRL]FRMNUMLIG
    Raz [F:XPO]
    [F:XPO]FRMNUMLIG =[F:FRA]FRMNUMLIG
    [F:XPO]INDFRL    =[F:FRA]NUMLIGFRL2
    [F:XPO]STAFRM    =[F:FRL]STAFRM
    [F:XPO]OPPNUM    =[F:FRL]OPPNUM
    [F:XPO]SALFCY    =[F:FRL]SALFCY
    [F:XPO]ITMREF    =[F:FRA]ITMREFPUR
    [F:XPO]DES       =[F:FRA]ITMDESPUR
    [F:XPO]TYP       =1
    [F:XPO]CUR       =[L]CURSOCFRL
    [F:XPO]UOM       =[F:FRA]UOM
    [F:XPO]PRVMNT    =[F:FRA]NETAMTPUR
    [F:XPO]PRVQTY    =[F:FRA]QTYUOM
    [F:XPO]PRVDAT    =[F:FRA]EXTRCPDAT

    # LBORN 23/10/2015 - Mantis 30700
    # Call CAL_REALISE_ACHAT([F:XPO]FRMNUMLIG,[F:XPO]INDFRL,0,[F:XPO]CUR,[F:XPO]REAMNT,[F:XPO]UOM,[F:XPO]REAQTY,[F:XPO]PRVDAT) From XPILOPP2
    Call CAL_REALISE_ACHAT([F:XPO]FRMNUMLIG,[F:XPO]INDFRL,0,[F:XPO]CUR,[F:XPO]REAMNT,[F:XPO]UOM,[F:XPO]REAQTY,datesyst) From XPILOPP2

    If [F:XPO]PRVQTY<>0
      [F:XPO]CST       =func XPILOPP2.ARRDEV([L]CURSOCFRL,[L]CURSOCFRL,[F:XPO]PRVMNT/[F:XPO]PRVQTY)
    Endif
    [F:XPO]IDENT     =[V]GIDENT
    Write [F:XPO]
    If fstat
      GOK=0 : Call FSTA("XPO") From GLOCK : Break
    Endif
  Next
  If GOK=0 : Return : Endif
Endif

# Prestations
If [L]FLG2 & [V]GXOPTACT
  For [F:FRR]FRR0 Hint Key FRR0 Where [F:FRR]FRMNUMLIG=[F:FRL]FRMNUMLIG
    Raz [F:XPO]
    [F:XPO]FRMNUMLIG =[F:FRR]FRMNUMLIG
    [F:XPO]INDFRL    =[F:FRR]CHRDS
    [F:XPO]STAFRM    =[F:FRL]STAFRM
    [F:XPO]OPPNUM    =[F:FRL]OPPNUM
    [F:XPO]SALFCY    =[F:FRL]SALFCY
    [F:XPO]ITMREF    =[F:FRR]ITEM
    If [F:FRR]REQSUM<>""
      [F:XPO]DES     =[F:FRR]REQSUM
    Else
      [F:XPO]DES     =[F:FRR]WSTREQ+"/"+[F:FRR]REQTYP+"/"+[F:FRR]CODOPE
    Endif
    [F:XPO]TYP       =3
    [F:XPO]CUR       =[L]CURSOCFRL
    [F:XPO]UOM       =[F:FRR]UOMEXT
    [F:XPO]PRVMNT    =[F:FRR]BUYCOS
    [F:XPO]PRVQTY    =[F:FRR]EXTQTY
    [F:XPO]PRVDAT    =[F:FRR]BEGDAT

    # LBORN 23/01/2017 - Mantis 33027
    # Call CAL_REALISE_PREST([F:XPO]FRMNUMLIG,[F:FRR]WSTREQ,[F:FRR]REQTYP,[F:FRR]CODOPE,0,[F:XPO]CUR,[F:XPO]REAMNT,[F:XPO]UOM,[F:XPO]REAQTY,[F:XPO]PRVDAT) From XPILOPP2
    Call CAL_REALISE_PREST([F:XPO]FRMNUMLIG,[F:FRR]WSTREQ,[F:FRR]REQTYP,[F:FRR]CODOPE,0,[F:XPO]CUR,[F:XPO]REAMNT,[F:XPO]UOM,[F:XPO]REAQTY,datesyst) From XPILOPP2

    If [F:XPO]PRVQTY<>0
      [F:XPO]CST       =func XPILOPP2.ARRDEV([L]CURSOCFRL,[L]CURSOCFRL,[F:XPO]PRVMNT/[F:XPO]PRVQTY)
    Endif
    [F:XPO]IDENT     =[V]GIDENT
    Write [F:XPO]
    If fstat
      GOK=0 : Call FSTA("XPO") From GLOCK : Break
    Endif
  Next
Endif
If GOK=0 : Return : Endif

# Ventes
If [L]FLG3
  Raz [F:XPO]
  [F:XPO]FRMNUMLIG =[F:FRL]FRMNUMLIG
  [F:XPO]STAFRM    =[F:FRL]STAFRM
  [F:XPO]OPPNUM    =[F:FRL]OPPNUM
  [F:XPO]SALFCY    =[F:FRL]SALFCY
  [F:XPO]ITMREF    =[F:FRL]ITMREF
  [F:XPO]DES       =[F:FRL]ITMDES
  [F:XPO]TYP       =4
  [F:XPO]CUR       =[L]CURSOCFRL
  [F:XPO]UOM       =[F:FRL]SAU
  Call CAL_CAPREV([F:XPO]FRMNUMLIG,[L]CURSOCFRL,[F:XPO]CUR,[F:XPO]PRVMNT,[F:XPO]PRVQTY) From XPILOPP2
  [F:XPO]PRVDAT    =[F:FRL]BEGDAT
  Call CAL_CAREA([F:XPO]FRMNUMLIG,[F:XPO]ITMREF,[F:XPO]CUR,0,[F:XPO]REAMNT,[F:XPO]UOM,[F:XPO]REAQTY,0,datesyst) From XPILOPP2
  If [F:XPO]PRVQTY<>0
    [F:XPO]CST     =func XPILOPP2.ARRDEV([L]CURSOCFRL,[L]CURSOCFRL,[F:XPO]PRVMNT/[F:XPO]PRVQTY)
  Endif
  [F:XPO]IDENT     =[V]GIDENT
  Write [F:XPO]
  If fstat
    GOK=0 : Call FSTA("XPO") From GLOCK : Return
  Endif
Endif

Return

######################################################################
$INIT_CUR

# Init devise affaire et ligne détail

Read [F:OPP]OPP0=[F:FRL]OPPNUM
If fstat : Raz [F:OPP] : Endif
Call GETDEV([F:OPP]SALFCY) From DEVSUB
[L]CURSOCOPP=[V]GLOCALDEV

If [F:FRL]SALFCY<>""
  # Devise société de la ligne de détail
  Call GETDEV([F:FRL]SALFCY) From DEVSUB
  [L]CURSOCFRL=[V]GLOCALDEV
  [V]GLOCALDEV=[L]SVGLOCDEV
Else
  [L]CURSOCFRL=[L]CURSOCOPP
Endif

Return

