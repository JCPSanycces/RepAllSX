#ACV#X16
#TIT#Saisie code hiérarchie

#==========================================================================================
# Gestion de l'objet   : Saisie code hiérarchie
#
# Auteur               : Laurent Bornes
# Date de création     : 12/11/2009
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

GBIDC1=""
GBIDC2=""
GFONC1="GESOPP"
Call OBJET("OPP",GBIDC1,GBIDC2) From GOBJET
End


$ACTION

Case ACTION
  When "OUVRE"     : Gosub OUVRE     From XSAIHIE2
  When "DEBUT"     : Gosub DEBUT     From XSAIHIE2
  When "OK"        : Gosub OK        From XSAIHIE2
  When "SEL_TABLE" : Gosub SEL_TABLE From XSAIHIE2
  When "FIN_TABLE" : Gosub FIN_TABLE From XSAIHIE2
Endcase

Return

#==========================================================================================
Subprog C_XNIV3(VALEUR)
Variable Char    VALEUR()
Local Integer I
For [L]I=0 To [M:XOP1]XNBS-1
  If [M:XSH]XNIV1=[M:XOP1]XNIV1([L]I) & [M:XSH]XNIV2=[M:XOP1]XNIV2([L]I) & VALEUR=[M:XOP1]XNIV3([L]I) & VALEUR<>"" & ([M:XSH]ZREP="C" | [M:XSH]ZLIG<>([L]I+1))
    GERR=3
    GMESSAGE=mess(29,100,1)-num$([L]I+1)
#    mkstat=1
    Break
  Endif
Next
End

#==========================================================================================
Subprog AS_XITMDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  If !clalev([F:ITM]) : Local File ITMMASTER : Endif
  Read [ITM]ITM0=[M:XSH]XNIV3
  If !fstat
    VALEUR=[F:ITM]ITMDES1
  Endif
Endif
End

#==========================================================================================
Subprog C_XITMDES(VALEUR)
Variable Char    VALEUR()
Local Integer I
For [L]I=0 To [M:XOP1]XNBS-1
  If [M:XSH]XNIV1=[M:XOP1]XNIV1([L]I) & [M:XSH]XNIV2=[M:XOP1]XNIV2([L]I) & [M:XSH]XNIV3=[M:XOP1]XNIV3([L]I) & VALEUR=[M:XOP1]XITMDES([L]I) & ([M:XSH]ZREP="C" | [M:XSH]ZLIG<>([L]I+1))
    GERR=3
    GMESSAGE=mess(29,100,1)-num$([L]I+1)
#   mkstat=1
    Break
  Endif
Next
End

#==========================================================================================
Subprog AS_XSAU(VALEUR)
Variable Char    VALEUR()
If [M:XSH]XNIV3=""
  mkstat=1 : End
Endif
If VALEUR=""
  If !clalev([F:ITM]) : Local File ITMMASTER : Endif
  Read [ITM]ITM0=[M:XSH]XNIV3
  If !fstat
    VALEUR=[F:ITM]SAU
  Endif
Endif
End

#==========================================================================================
Subprog AS_XQTY(VALEUR)
Variable Decimal VALEUR
If [M:XSH]XNIV3=""
  mkstat=1 : End
Endif
End

#==========================================================================================
Subprog AS_XPRIX(VALEUR)
Variable Decimal VALEUR
If [M:XSH]XNIV3=""
  mkstat=1 : End
Endif
End

#==========================================================================================
Subprog AM_XNIV3(VALEUR)
Variable Char    VALEUR()

Call CTRLSTA_ITMFRL(VALEUR) From SPVOBJFRL
If mkstat : End : Endif

Effzo [M:XSH]XITMDES
End

#==========================================================================================
Subprog AS_XNIV2(VALEUR)
Variable Char    VALEUR()
If [M:XSH]XNIV1="" : mkstat=1 : Endif
End

#==========================================================================================
Subprog C_XLIGS(VALEUR)
Variable Decimal VALEUR
If !find(VALEUR,[M:XOP1]XLIGS(0..[M:XOP1]XNBS-1))
  GMESSAGE=mess(25,[V]GXMSGOPP,1)
  GERR=1
  mkstat=1
Endif
End

#==========================================================================================
Subprog AS_XTYPFRM(VALEUR)
Variable Char    VALEUR()
Call DEF_TYPFRM(VALEUR,[M:OPP1]OPPTYP,[M]XMOD) From XACTOPPX11
End

#==========================================================================================
Subprog AM_XLIGS(VALEUR)
Variable Decimal VALEUR
Local Integer ZI
[L]ZI=find(VALEUR,[M:XOP1]XLIGS(0..[M:XOP1]XNBS-1))
If [L]ZI<=0 : End : Endif
[M:XSH]XITMDES=[M:XOP1]XITMDES([L]ZI-1)
[M:XSH]XSAU=[M:XOP1]XSAU([L]ZI-1)
[M:XSH]XCUR=[M:XOP1]XCUR([L]ZI-1)
[M:XSH]XPRIX=[M:XOP1]XPRIX([L]ZI-1)
[M:XSH]XMOD=[M:XOP1]XMOD([L]ZI-1)
[M:XSH]XQTY=[M:XOP1]XQTY([L]ZI-1)
[M:XSH]XTYPFRM=[M:XOP1]XTYPFRM([L]ZI-1)
[M:XSH]XFRMNUMLIG=[M:XOP1]XFRMNUMLIG([L]ZI-1)
Affzo [M:XSH]XITMDES,XSAU,XCUR,XPRIX,XMOD,XQTY,XTYPFRM,XFRMNUMLIG
End

#==========================================================================================
Subprog AS_XCUR(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  VALEUR=[M:OPP0]CUR
Endif
End
