$ACTION
Gosub ACTION From SPVOBJX7G
Return


######################################################################################
Subprog AM_WSTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Diszo [M:XWA1]WSMET
  Diszo [M:XWA2]
  Diszo [M:XWA1]XSD
Else
  Actzo [M:XWA1]WSMET
  Actzo [M:XWA2]
  Actzo [M:XWA1]XSD
Endif
End

Subprog AM_WSMET(VALEUR)
Variable Integer VALEUR
If VALEUR=1
  Diszo [M:XWA2]
  Actzo [M:XWA3]
Else
  Actzo [M:XWA2]
  Diszo [M:XWA3]
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran XWSAPPINT1) 18/04/2011 10:09:10 (SOUCH)
######################################################################################
Subprog CL_TSTJVB(VALEUR)
Variable Char    VALEUR()

Local Integer EXISTE
EXISTE = func XTRTCALLWS.SRVEXISTS([M:XWA1]HOST,[M:XWA1]PORT)
If EXISTE=1
  Call MESSAGE("Serveur OK") From GESECRAN
Else
  Call MESSAGE("Serveur inconnu ou port fermé") From GESECRAN
Endif

End

#######################################################################################
Subprog CL_TSTAPP(VALEUR)
Variable Char    VALEUR()

Local Char RESPONSE
Local Char RETOUR(30)(3)
Local Char HIDS(30)(5)
Local Char HVAL(30)(5)
Onerrgo ERR_APP
Call GET_([M:XWA1]HOST,num$([M:XWA1]PORT),[M:XWA1]URL,RESPONSE,RETOUR,HIDS,HVAL) From XCIUHTTPCLI
Onerrgo

Infbox(RETOUR(1)-RETOUR(2))

End

ERR_APP
Infbox("FONCTION : Erreur ("+num$(errn)+") : ["+errm+"]")
End

