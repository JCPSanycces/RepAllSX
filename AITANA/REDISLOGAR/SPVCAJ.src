#<AdxTL>@(#)9.0.0.0 $Revision:   1.12  $ Gestion du masque CALAJOU
#ACV#X11
#TIT#Ajout d'une periode sur les calendrier

########################################
Subprog C_PEREND(VALEUR)
Variable Date    VALEUR
Local Integer OK

[L]OK=1
If !clalev([XCL]) : Local File CALGAS : Endif
For [XCL]XCL1 Where CAL=[M]CAL & CALDAT>=[M]PERBEG & CALDAT<=VALEUR
    Call AVERTIR("Des enregistrements existent déjà pour cette période",OK)From GESECRAN
    If [L]OK=1 : mkstat=2 : Endif
    Break 1
Next

End

########################################
Subprog D_DAYWEE(VALEUR)
Variable Integer VALEUR

If nolign=1
    VALEUR=1
Else
    VALEUR=[M]DAYWEE(nolign-2)
Endif
End

########################################
Subprog C_HDEB(VALEUR)
Variable Char    VALEUR()
Local Integer I,NUMERO

[L]NUMERO=nolign-1

For I=0 To [M]NBLIG-1
    If I<>[L]NUMERO & [M]DAYWEE([L]NUMERO)=[M]DAYWEE(I) & VALEUR>=[M]HDEB(I) & VALEUR<[M]HFIN(I)
        GMESSAGE=("Heure de début impossible pour cette date")
        mkstat=2
        Break
    Endif
Next

End

########################################
Subprog C_HFIN(VALEUR)
Variable Char    VALEUR()
Local Integer I,NUMERO

[L]NUMERO=nolign-1

If VALEUR < [M]HDEB(nolign-1) : GMESSAGE = mess(44,199,1) : mkstat = 1 : End : Endif

For I=0 To [M]NBLIG-1
    If I<>[L]NUMERO & [M]DAYWEE([L]NUMERO)=[M]DAYWEE(I) 
&      & ((VALEUR>[M]HDEB(I) & VALEUR<=[M]HFIN(I)) | ([M]HDEB([L]NUMERO)<[M]HDEB(I) & VALEUR>[M]HFIN(I)))
        GMESSAGE=("Chevauchement d'horaire pour cette date")
        mkstat=2
        Break
    Endif
Next

End

########################################
Subprog AV_PERTIM(VALEUR)
Variable Char    VALEUR()
Local Decimal NBMINUTE

[L]NBMINUTE=(int(val([M]HFIN(nolign-1))/100)*60+mod(val([M]HFIN(nolign-1)),100))
&           -(int(val([M]HDEB(nolign-1))/100)*60+mod(val([M]HDEB(nolign-1)),100))

VALEUR=num$(format$("N0:4#",int([L]NBMINUTE/60)*100+mod([L]NBMINUTE,60)))

End


########################################
Subprog AP_CAL(VALEUR)
Variable Char    VALEUR()

If !clalev([XCL]) : Local File CALGAS : Endif
Read [XCL]XCL0(1)=VALEUR
If !fstat
    [M]DESCAL=[F:XCL]CALDES
Endif
End

########################################
Subprog AS_DESCAL(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
    mkstat=2
Endif
End
