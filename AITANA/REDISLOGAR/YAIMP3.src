#<AdxTL>@(#)0.0.0.0 $Revision$ 

$ACTION
  Case ACTION
    When "IMPRIME" : Gosub IMPRIME
  Endcase
Return

#------------------------------------------------------------------------------#

$IMPRIME
  # GYWNOMFIC: Variable global declarada en la acción YSENDPDF
  If dim([V]GYWNOMFIC)>0
    Gosub SPE_YSENDPDF
  Endif
Return

#------------------------------------------------------------------------------#

$SPE_YSENDPDF
  If DESTINATION=4 and [V]GYWNOMFIC<>""
    FICHIER = [V]GYWNOMFIC
    FMTFIC  = 29
  Endif
Return




