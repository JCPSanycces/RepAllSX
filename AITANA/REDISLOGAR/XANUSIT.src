Local Char PARAM(30)(1..16),VALEUR(10) 

Raz [L]PARAM, [L]VALEUR

GACTION="TRTVALSIT"

[L]PARAM(1)=""
[L]PARAM(2)="" 
[L]PARAM(3)="" 
[L]PARAM(4)="" 
Call TRAITE_CHAR(VALEUR,PARAM,"","XANUSIT2","XANUSIT",4,"") From GTRAITE
End

$ACTION
Gosub ACTION From XANUSIT2
Return

#----------------------------------------------------------------------------------------------------
# Ecran XANUSIT
#----------------------------------------------------------------------------------------------------

########################
Subprog AP_ALLPJT(VALEUR)
Variable Integer VALEUR

If VALEUR=2
    Effzo [M]OPPINF,OPPSUP
    Grizo [M]OPPINF,OPPSUP
Else
    Actzo [M]OPPINF,OPPSUP
Endif
End

########################
Subprog AP_ALLTYPPJT(VALEUR)
Variable Integer VALEUR

If VALEUR=2
    Effzo [M]TYPPJTINF,TYPPJTSUP
    Grizo [M]TYPPJTINF,TYPPJTSUP
Else
    Actzo [M]TYPPJTINF,TYPPJTSUP
Endif
End

########################
Subprog AP_ALLFCY(VALEUR)
Variable Integer VALEUR

If VALEUR=2
    Effzo [M]FCYINF,FCYSUP
    Grizo [M]FCYINF,FCYSUP
Else
    Actzo [M]FCYINF,FCYSUP
Endif
End

########################
Subprog AP_ALLBPC(VALEUR)
Variable Integer VALEUR

If VALEUR=2
    Effzo [M]BPCINF,BPCSUP
    Grizo [M]BPCINF,BPCSUP
Else
    Actzo [M]BPCINF,BPCSUP
Endif
End

########################
Subprog AP_ALLGESINTO(VALEUR)
Variable Integer  VALEUR
If VALEUR=2
    Effzo [M]GESINTINFO,GESINTSUPO
    Grizo [M]GESINTINFO,GESINTSUPO
Else
    Actzo [M]GESINTINFO,GESINTSUPO
Endif
End


########################
Subprog AP_ALLSIT(VALEUR)
Variable Integer VALEUR

If VALEUR=2
    Effzo [M]SITINF,SITSUP
    Grizo [M]SITINF,SITSUP
Else
    Actzo [M]SITINF,SITSUP
Endif
End

########################
Subprog AV_INITZON(VALEUR)
Gosub INIZON
End

$INIZON
Call AP_ALLSIT([M]ALLSIT)
Call AP_ALLDAT([M]ALLDAT)
Call AP_ALLPJT([M]ALLPJT)
Call AP_ALLTYPPJT([M]ALLTYPPJT)
Call AP_ALLFCY([M]ALLFCY)
Call AP_ALLBPC([M]ALLBPC)
Call AP_ALLGESINTO([M]ALLGESINTO)
Return

########################
Subprog AM_SITINF(VALEUR)
Variable Char    VALEUR()
[M]SITSUP=VALEUR
End

########################
Subprog AM_CALDATINF(VALEUR)
Variable Date    VALEUR
[M]CALDATSUP=VALEUR
End

########################
Subprog AP_ALLDAT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    Effzo [M]CALDATINF,CALDATSUP
    Grizo [M]CALDATINF,CALDATSUP
Else
    Actzo [M]CALDATINF,CALDATSUP
Endif
End

########################
Subprog C_CALDATSUP(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]CALDATINF & VALEUR<>[0/0/0] & [M]CALDATINF<>[0/0/0]
  mkstat=1
Endif
End


