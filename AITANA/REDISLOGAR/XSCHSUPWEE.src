#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque SCHGAS0
#ACV#X13
#TIT#Gestion de l'action TRTSCHSUPW

#LBO 01/2003

Local Char PARAM(30)(1..16),VALEUR(10) 

PARAM(1)="LBO6"
PARAM(2)="MACON"
PARAM(3)=""
PARAM(4)="" 
Call TRAITE_CHAR(VALEUR,PARAM,"","XSCHSUPWE2","SCHSUPWEE",4) From GTRAITE    :# Appel avec ouverture de la fenetre
End


#-----------------------------------------------------------------------
# Ecran SCHAJWEE
#-----------------------------------------------------------------------
Subprog AV_ENDDAT(VALEUR)
Variable Date VALEUR
[M:DIA]FLGV=2 : Affzo [M:DIA]FLGV
VALEUR=gdat$(1,1,year(date$)+1)-1
End

Subprog D_ENDDAT(VALEUR)
Variable Date VALEUR
VALEUR=gdat$(1,1,year(date$)+1)-1
End

Subprog C_ENDDAT(VALEUR)
Variable Date VALEUR
If VALEUR<date$
  mkstat=1
Endif
End
