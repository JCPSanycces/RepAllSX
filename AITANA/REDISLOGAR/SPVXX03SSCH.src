  mkstat=1
Endif
End

#----------------------------
Subprog C_ICOMIN(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 | VALEUR>59
  mkstat=1
Endif
End


#----------------------------
Subprog C_ICOFNEEXP(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M:SCH1]UPDFNE=2 & [M:SCH1]SYNFLG=2
  [V]GMESSAGE=mess(10,123,1)
  mkstat=1
Endif
End


