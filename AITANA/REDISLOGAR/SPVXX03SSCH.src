Assign "[M:SCH5]DAYTRA"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
End

#----------------------------
Subprog AM_XHDAM(VALEUR)
Variable Char    VALEUR()
Assign "[M:SCH5]HDAM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
End

#----------------------------
Subprog AS_NBCAL

Local Integer ZLIG, ZI, I

[L]ZLIG=nolign-1

Effzo [M:SCH5]15-99

# Pas d'affectation en création, sinon pas d'init
If [M:SCH5]CODCHO([L]ZLIG)<>""
  Gosub AFFECT_CAL From SPVOBJXX03SSCH
  Affzo [M:SCH5]15-99
  Read [F:SHL]SHL7=[M:SCH0]PLANCOD;[M:SCH5]CODCHO([L]ZLIG)
  If !fstat
    mkstat=1
  Endif
Else
  [M:SCH5]XNUMLIG=[L]ZLIG+1
  [M:SCH5]NBDAY=7
  For [L]ZI=1 To 7
    [M:SCH5]XDAYNAM([L]ZI-1)=day$([L]ZI)
    [M:SCH5]XDAYTRA([L]ZI-1)=1
    Assign "[M:SCH5]DAYTRA"+num$([L]ZI)+"("+num$([L]ZLIG)+")" With [M:SCH5]XDAYTRA([L]ZI-1)
  Next
  Affzo [M:SCH5]XDAYNAM,XDAYTRA
Endif

nolign=[L]ZLIG+1
End

#----------------------------
Subprog C_NBCAL
If status=65
  # Ctrl annulation
  If [M:SCH5]CALNUMSVP([M:SCH5]XNUMLIG-1)=1
    mkstat=1
  Else
    Read [F:SHL]SHL7=[M:SCH0]PLANCOD;[M:SCH5]CODCHO([M:SCH5]XNUMLIG-1)
    If !fstat
      GMESSAGE=mess(19,115,1)-"SCHLIGGAS\"+mess(55,123,1)-":"-[F:SHL]PLANCOD-[F:SHL]VP1-[F:SHL]VP2-[F:SHL]VP3
      GMESSAGE+="\"+mess(1,115,1)
      GERR=1
      mkstat=1
    Endif
  Endif
Endif
End

#----------------------------
Subprog AS_CODCHO(VALEUR)
Variable Char    VALEUR()
Read [F:SRC]SRC1=[M:SCH0]PLANCOD;VALEUR
If !fstat
  mkstat=2
Endif
End


