#<AdxTL>@(#)0.0.0.0 $Revision$
#ACV#X13
#TIT#Gestion de l'objet SCH

#LBO 07/2002

GBIDC1=""
GBIDC2=""
Call OBJET("XX03SSCH",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet SCH
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Gosub ACTION From SPVOBJXX03SSCH

Return


#####################################################################################
# Ecran SCH0
#####################################################################################
Subprog C_PLANCOD(VALEUR)
Variable Char    VALEUR()

# Contrôle supplémentaire, interdit >8 car pb génération écran/fenêtre au cas ou l'on
# aurait augmenté la valeur du type de donnée
Local Integer ZNUMTR, MAXLNG

[L]MAXLNG=8

Read [F:SHP]SHP0=VALEUR
If fstat
  Call RECH_NUMTR(VALEUR,[L]ZNUMTR) From XSCHVALID2
  [L]MAXLNG-=len(num$([L]ZNUMTR))-1
Endif

If len(VALEUR)>[L]MAXLNG
  [V]GMESSAGE=num$([L]MAXLNG)-"caractères maximum"
  GERR=1
  mkstat=1
Endif
End


#####################################################################################
# Ecran SCH1
#####################################################################################

#----------------------------
Subprog C_USRVP(VALEUR)
Variable Char    VALEUR()

If VALEUR="" : End : Endif

If left$(VALEUR,1)>="0" & left$(VALEUR,1)<="9"
  [V]GMESSAGE="Chiffre interdit en premier caractère"
  GERR=1
  mkstat=1
  End
Endif

For [SHP]SHP0 Where [F:SHP]PLANCOD<>[M:SCH0]PLANCOD & [F:SHP]USRVP=VALEUR & [F:SHP]SYNFLG=2
  [V]GMESSAGE="Code déjà présent dans le planning"-[F:SHP]PLANCOD+"\Synchronisation VP impossible"
  mkstat=1
  Break 1
Next
If mkstat : End : Endif

Local Integer ZTROUV, ERRLEC
If !clalev([F:ADS]) : Local File ADOSSIER : Endif
For [F:ADS]DOSSIER Where [F:ADS]DOSSIER<>[S]nomap
  [L]ZTROUV=1
  Onerrgo FIC_NONTROUV
  Local File =[F:ADS]DOSSIER+".ATABLE" [XATB]
  Onerrgo
  If [L]ZTROUV
    Read [F:XATB]CODFIC="SCHPARGAS"
    If !fstat
      [L]ERRLEC=0
      Onerrgo ERR_LECFIC
      Local File =[F:ADS]DOSSIER+".SCHPARGAS" [XSHP]
      Onerrgo
      If ![L]ERRLEC
        For [F:XSHP]SHP0
          If dim([F:XSHP]USRVP)>0 & dim([F:XSHP]SYNFLG)>0 & [F:XSHP]USRVP=VALEUR & [F:XSHP]SYNFLG=2
            [V]GMESSAGE="Code déjà présent dans le dossier"-[F:ADS]DOSSIER+"\Synchronisation VP impossible"
            mkstat=1
            Break 2
          Endif
        Next
        Close Local File [XSHP]
      Endif
    Endif
    Close Local File [XATB]
  Endif
Next
If !mkstat
  Call VERF_EXIST_VP(VALEUR)From XSYNCHROVP
Endif
End

$FIC_NONTROUV
[L]ZTROUV=0
Resume

$ERR_LECFIC
[L]ERRLEC=1
Resume

#----------------------------
Subprog AS_USRVP(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M:SCH1]SYNFLG=2
  VALEUR=[M:SCH0]PLANCOD
Elsif [M:SCH1]SYNFLG<>2
  mkstat=1
Elsif [M:SCH1]SYNDAT<>[0/0/0]
  mkstat=2
Endif
End

#----------------------------
Subprog AS_EVTFLG(VALEUR)
Variable Integer VALEUR
If [M:SCH1]SYNFLG<>2
  mkstat=1
Endif
End

#----------------------------
Subprog D_PLANDESSHO(VALEUR)
Variable Char    VALEUR()
VALEUR=[M:SCH0]PLANDES
End

#----------------------------
Subprog D_PLANBEGDAT(VALEUR)
Variable Date    VALEUR
VALEUR=gdat$(1,1,year(datesyst))
End

#----------------------------
Subprog C_PLANBEGDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] & [M:SCH1]SYNFLG=2
  [V]GMESSAGE=mess(10,123,1)
  mkstat=1
  [V]GERR=1
Endif
End

#----------------------------
Subprog D_PLANENDDAT(VALEUR)
Variable Date    VALEUR
VALEUR=gdat$(31,12,year([M:SCH1]PLANBEGDAT))
End

#----------------------------
Subprog C_PLANENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] & [M:SCH1]SYNFLG=2
  [V]GMESSAGE=mess(10,123,1)
  mkstat=1
  [V]GERR=1
Elsif VALEUR<[M:SCH1]PLANBEGDAT & VALEUR<>[0/0/0]
  mkstat=1
  [V]GERR=1
Endif
End

#----------------------------
Subprog D_TRTSPE(VALEUR)
Variable Char    VALEUR()
VALEUR="YPARAGE"
End

#----------------------------
Subprog AP_SYNFLG(VALEUR)
Variable Integer VALEUR
[V]GXSYNFLG=VALEUR
End



#####################################################################################
# Ecran SCH2
#####################################################################################

#----------------------------
Subprog C_RUBDES(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:SCH2]RUBDES(0..[M]NBLIG-1)) From OBJDIV
End

#----------------------------
Subprog AS_RUBTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=0 | !varinit([M]RUBDES,indice)
  If !indice
    VALEUR=1 : mkstat=2
  Else
    VALEUR=2
    Local Integer NBRP, I
    [L]NBRP=0
    For [L]I=0 To [M:SCH2]NBLIG-1
      If [M:SCH2]RUBTYP([L]I)=1 & [L]I<>indice
        [L]NBRP+=1
      Endif
    Next
    If [L]NBRP>2
      mkstat=2
    Endif
  Endif
Elsif [M:SCH2]RUBNUMSVP(nolign-1)<>0
  mkstat=2
Endif
End

#----------------------------
Subprog C_RUBTYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>1 : End : Endif
Local Integer NBRP, I
[L]NBRP=0
For [L]I=0 To indice-1
  If [M:SCH2]RUBTYP([L]I)=1 : [L]NBRP+=1 : Endif
Next
If [L]NBRP>2
  [V]GMESSAGE="Nombre de rubriques principales : 3 Maximum"
  mkstat=1
Endif
End

#----------------------------
Subprog AS_RUBOBJ(VALEUR)
Variable Char    VALEUR()
If [M:SCH2]RUBTYP(nolign-1)=2
  mkstat=1
Endif
End


#----------------------------
Subprog C_RUBOBJ(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M:SCH2]RUBTYP=1
  [V]GMESSAGE=mess(10,123,1)
  mkstat=1
Else
  Local Integer I
  For [L]I=0 To indice-1
    If [M:SCH2]RUBOBJ([L]I)=VALEUR
      [V]GMESSAGE="Objet déjà utilisé en ligne"-num$([L]I+1)
      mkstat=1 : Break
    Endif
  Next
  If !mkstat
    Call INIT_FILOBJ(VALEUR,[M:SCH2]RUBFILOBJ(nolign-1)) From SPVOBJXX03SSCH
  Endif
Endif
End

#----------------------------
Subprog AV_RUBFILOBJ(VALEUR)
Variable Char    VALEUR()
Call INIT_FILOBJ([M:SCH2]RUBOBJ(nolign-1),VALEUR) From SPVOBJXX03SSCH
End


#----------------------------
Subprog AS_RUBVALEXP(VALEUR)
Variable Char    VALEUR()
If [M:SCH2]RUBTYP(nolign-1)=1 & [M:SCH2]RUBOBJ(nolign-1)=""
  mkstat=1
Else
  Call INIT_GXFILRUB From SPVOBJXX03SSCH
Endif
End


#----------------------------
Subprog C_RUBVALEXP(VALEUR)
Variable Char    VALEUR()
If [M:SCH2]RUBOBJ(nolign-1)<>"" & VALEUR=""
  [V]GMESSAGE=mess(10,123,1)
  mkstat=1
Endif
End


#----------------------------
Subprog AS_RUBSELTYP(VALEUR)
Variable Integer VALEUR
If [M:SCH2]RUBVALEXP(nolign-1)=""
  VALEUR=2 : mkstat=2
Endif
End

#----------------------------
Subprog AS_RUBSELEXP(VALEUR)
Variable Char    VALEUR()
If [M:SCH2]RUBOBJ(nolign-1)=""
  mkstat=1
Else
  Call INIT_GXFILRUB From SPVOBJXX03SSCH
Endif
End

#----------------------------
Subprog AS_RUBFMT(VALEUR)
Variable Integer VALEUR
If [M:SCH2]RUBNUMSVP(nolign-1)<>0
  mkstat=2
Endif
End


#----------------------------
Subprog AS_RUBLNG(VALEUR)
Variable Decimal VALEUR

If [M:SCH2]RUBNUMSVP(nolign-1)<>0
  mkstat=2
Else
  Case [M:SCH2]RUBFMT(nolign-1)
    When 1 : # Texte
    When 2 : # Entier
    When 3 : # Décimal
    When 4 : # Date
             VALEUR=8 : mkstat=2
    When 5 : # Heure
             VALEUR=6 : mkstat=2
  Endcase
Endif
End

#----------------------------
Subprog C_RUBLNG(VALEUR)
Variable Decimal VALEUR

Case [M:SCH2]RUBFMT(nolign-1)
  When 1   : # Texte
             If VALEUR<1 | VALEUR>30 : mkstat=1 : Endif
  When 2,3 : # Entier, Décimal
             If VALEUR<1 | VALEUR>10 : mkstat=1 : Endif
Endcase
End

#----------------------------
Subprog AS_RUBDEC(VALEUR)
Variable Decimal VALEUR
If [M:SCH2]RUBFMT(nolign-1)<>3
  VALEUR=0 : mkstat=2
Endif
End

#----------------------------
Subprog C_RUBDEC(VALEUR)
Variable Decimal VALEUR
If [M:SCH2]RUBFMT(nolign-1)=3 & (VALEUR<0 | VALEUR>5)
  mkstat=1
Endif
End

#----------------------------
Subprog AS_RUBOBY(VALEUR)
Variable Integer VALEUR
If [M:SCH2]RUBTYP(nolign-1)=1
  VALEUR=2 : mkstat=2
Elsif find([M:SCH2]RUBFMT(nolign-1),2,3)
  VALEUR=1 : mkstat=2
Endif
End

#----------------------------
Subprog AS_RUBFNEEXP(VALEUR)
Variable Char    VALEUR()
If [M:SCH2]RUBTYP(nolign-1)<>1 | [M:SCH1]UPDFNE<>2
  mkstat=1
Endif
End


#----------------------------
Subprog C_RUBFNEEXP(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M:SCH1]UPDFNE=2
  [V]GMESSAGE=mess(10,123,1)
  mkstat=1
Endif
End


#----------------------------
Subprog AS_RUBVDEF(VALEUR)
Variable Char    VALEUR()
If [M:SCH2]RUBTYP(nolign-1)<>1
  mkstat=1
Endif
End

#----------------------------
Subprog AS_RUBINTDES(VALEUR)
Variable Char    VALEUR()
If [M:SCH2]RUBTYP(nolign-1)<>1
  mkstat=1
Endif
