If [M:SCH2]RUBTYP(nolign-1)<>1
  mkstat=1
Endif
End




#####################################################################################
# Ecran SCH3
#####################################################################################

#----------------------------
Subprog AS_ICOLNG(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 : End : Endif
If !clalev([F:ATZ]) : Local File ATABZON : Endif
Read [F:ATZ]CODZONE=[M:SCH3]ICOFILOBJ(nolign-1);toupper(right$([M:SCH3]ICOVALEXP(nolign-1),instr(1,[M:SCH3]ICOVALEXP(nolign-1),"]")+1))
If !fstat
  If [F:ATZ]LONG<>0
    VALEUR=min([F:ATZ]LONG,25)
  Else
    If !clalev([F:ATY]) : Local File ATYPE : Endif
    Read [F:ATY]CODTYP=[F:ATZ]CODTYP
    If !fstat & [F:ATY]LNGTYP<>0
      VALEUR=min([F:ATY]LNGTYP,25)
    Endif
  Endif
Endif
End


#----------------------------
Subprog C_ICOLNG(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 | VALEUR>25
  mkstat=1
Endif
End

#----------------------------
Subprog C_ICOOBJ(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:SCH3]ICOOBJ(0..[M]NBICO-1)) From OBJDIV
If !mkstat
  Call INIT_FILOBJ(VALEUR,[M:SCH3]ICOFILOBJ(nolign-1)) From SPVOBJXX03SSCH
Endif
End


#----------------------------
Subprog AV_ICOFILOBJ(VALEUR)
Variable Char    VALEUR()
Call INIT_FILOBJ([M:SCH3]ICOOBJ(nolign-1),VALEUR) From SPVOBJXX03SSCH
End

#----------------------------
Subprog AM_ICOTYP(VALEUR)
Variable Integer VALEUR
Call DEFDURDES(VALEUR,[M:SCH3]ICODURDES(nolign-1))
[M:SCH3]ICOTYP(nolign-1)=VALEUR
Affzo [M:SCH3]ICODURDES(nolign-1)
End


#----------------------------
Subprog AV_ICODURDES(VALEUR)
Variable Char    VALEUR()
Call DEFDURDES([M:SCH3]ICOTYP(nolign-1),VALEUR)
End

Subprog DEFDURDES(ZICOTYP,ZVAL)
Value Integer ZICOTYP
Variable Char ZVAL
Case [L]ZICOTYP
  When 1 : [L]ZVAL="Jour(s)"
  When 2 : [L]ZVAL="1/2 Journée(s)"
  When 3 : [L]ZVAL="Heure(s)"
  When Default : [L]ZVAL=""
Endcase
End


#----------------------------
Subprog AS_ICOVALEXP(VALEUR)
Variable Char    VALEUR()
If [M:SCH3]ICOOBJ(nolign-1)=""
  mkstat=1
Else
  Call INIT_GXFILICO From SPVOBJXX03SSCH
Endif
End

#----------------------------
Subprog AM_ICOVALEXP(VALEUR)
Variable Char    VALEUR()
If toupper(right$([M:SCH3]ICOVALEXP(nolign-1),instr(1,[M:SCH3]ICOVALEXP(nolign-1),"]")+1))<>toupper(right$(VALEUR,instr(1,VALEUR,"]")+1))
  Effzo [M:SCH3]ICOLNG(nolign-1)
Endif
End



#----------------------------
Subprog C_ICOVALEXP(VALEUR)
Variable Char    VALEUR()
If [M:SCH3]ICOOBJ(nolign-1)<>"" & VALEUR=""
  [V]GMESSAGE=mess(10,123,1)
  mkstat=1
Endif
End


#----------------------------
Subprog AS_ICOSELTYP(VALEUR)
Variable Integer VALEUR
If [M:SCH3]ICOOBJ(nolign-1)=""
  VALEUR=2 : mkstat=2
Endif
End

#----------------------------
Subprog AS_ICOSELEXP(VALEUR)
Variable Char    VALEUR()
If [M:SCH3]ICOOBJ(nolign-1)=""
  mkstat=1
Else
  Call INIT_GXFILICO From SPVOBJXX03SSCH
Endif
End


#----------------------------
Subprog AS_ICOMIN(VALEUR)
Variable Decimal VALEUR
