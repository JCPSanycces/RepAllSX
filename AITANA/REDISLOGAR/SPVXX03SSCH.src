Subprog AS_OPENOT(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  VALEUR="[F:OPE]OPEDES"
Endif
End


#####################################################################################
# Ecran SCH5
#####################################################################################


#----------------------------
Subprog AS_XDAYTRA(VALEUR)
Variable Integer VALEUR
If evalue("[M:SCH5]JNTRA"+num$(nolign))=2
  VALEUR=1
  mkstat=2
Endif
End


#----------------------------
Subprog AS_XHDAM(VALEUR)
Variable Char    VALEUR()
If [M:SCH5]XDAYTRA(nolign-1)=1
  mkstat=1
  Assign "[M:SCH5]HDAM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With ""
Elsif VALEUR="" & [V]XMORBEG<>""
  VALEUR=ctrans([V]XMORBEG,":","")
  Assign "[M:SCH5]HDAM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
Endif
End

#----------------------------
Subprog C_XHDAM(VALEUR)
Variable Char    VALEUR()
Call ARR_HM(VALEUR,15) From SPVOBJXX03SSCH
Assign "[M:SCH5]HDAM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
End


#----------------------------
Subprog AS_XHFAM(VALEUR)
Variable Char    VALEUR()
If [M:SCH5]XDAYTRA(nolign-1)=1
  mkstat=1
  Assign "[M:SCH5]HFAM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With ""
Elsif VALEUR="" & [M:SCH5]XHDAM(nolign-1)<[V]XMOREND & [V]XMOREND<>""
  VALEUR=ctrans([V]XMOREND,":","")
  Assign "[M:SCH5]HFAM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
Endif
End

#----------------------------
Subprog AS_XHDPM(VALEUR)
Variable Char    VALEUR()
If [M:SCH5]XDAYTRA(nolign-1)=1 | [M:SCH5]XHFAM(nolign-1)=""
  mkstat=1
  Assign "[M:SCH5]HDPM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With ""
Elsif VALEUR="" & max([M:SCH5]XHDAM(nolign-1),[M:SCH5]XHFAM(nolign-1))<[V]XAFTBEG & [V]XAFTBEG<>""
  VALEUR=ctrans([V]XAFTBEG,":","")
  Assign "[M:SCH5]HDPM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
Endif
End

#----------------------------
Subprog AS_XHFPM(VALEUR)
Variable Char    VALEUR()
If [M:SCH5]XDAYTRA(nolign-1)=1
  mkstat=1
  Assign "[M:SCH5]HFPM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With ""
Elsif [M:SCH5]XHFAM(nolign-1)<>"" & [M:SCH5]XHDPM(nolign-1)=""
  VALEUR=[M:SCH5]XHFAM(nolign-1)
  Assign "[M:SCH5]HFPM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
  [M:SCH5]XHFAM(nolign-1)=""
  Assign "[M:SCH5]HFAM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With ""
  Affzo [M:SCH5]XHFAM(nolign-1)
  mkstat=2
Elsif VALEUR="" & max([M:SCH5]XHDAM(nolign-1),[M:SCH5]XHFAM(nolign-1),[M:SCH5]XHDPM(nolign-1))<[V]XAFTEND & [V]XAFTEND<>""
  VALEUR=ctrans([V]XAFTEND,":","")
  Assign "[M:SCH5]HFPM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
Endif
End


#----------------------------
Subprog AM_XHFAM(VALEUR)
Variable Char    VALEUR()
If VALEUR="0000"
  VALEUR=""
Endif
Assign "[M:SCH5]HFAM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
End

#----------------------------
Subprog AM_XHDPM(VALEUR)
Variable Char    VALEUR()
If VALEUR="0000"
  VALEUR=""
Endif
Assign "[M:SCH5]HDPM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
End

#----------------------------
Subprog AM_XHFPM(VALEUR)
Variable Char    VALEUR()
If VALEUR="0000"
  VALEUR="2359"
  If [M:SCH5]XHDAM(nolign-1)=""
    [M:SCH5]XHDAM(nolign-1)="0000"
    Assign "[M:SCH5]HDAM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With "0000"
    Affzo [M:SCH5]XHDAM(nolign-1)
  Endif
Endif
Assign "[M:SCH5]HFPM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
End


#----------------------------
Subprog C_XHFAM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Call ARR_HM(VALEUR,15) From SPVOBJXX03SSCH
  Assign "[M:SCH5]HFAM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
Endif
If VALEUR<=[M:SCH5]XHDAM(nolign-1) & VALEUR<>""
  mkstat=1
  Assign "[M:SCH5]HFAM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With ""
Elsif VALEUR<>"" & [M:SCH5]XHDAM(nolign-1)=""
  [M:SCH5]XHDAM(nolign-1)="0000"
  Assign "[M:SCH5]HDAM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With "0000"
  Affzo [M:SCH5]XHDAM(nolign-1)
Endif
End

#----------------------------
Subprog C_XHDPM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Call ARR_HM(VALEUR,15) From SPVOBJXX03SSCH
  Assign "[M:SCH5]HDPM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
Endif
If VALEUR<=max([M:SCH5]XHDAM(nolign-1),[M:SCH5]XHFAM(nolign-1)) & VALEUR<>""
  mkstat=1
  Assign "[M:SCH5]HDPM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With ""
Endif
End

#----------------------------
Subprog C_XHFPM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<"2345"
  Call ARR_HM(VALEUR,15) From SPVOBJXX03SSCH
  Assign "[M:SCH5]HFPM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With VALEUR
Elsif VALEUR>"2345"
  VALEUR="2359"
Endif
If VALEUR<=max([M:SCH5]XHDAM(nolign-1),[M:SCH5]XHFAM(nolign-1),[M:SCH5]XHDPM(nolign-1)) & VALEUR<>""
  mkstat=1
  Assign "[M:SCH5]HFPM"+num$(nolign)+"("+num$([M:SCH5]XNUMLIG-1)+")" With ""
Endif
End


#----------------------------
Subprog AS_XCALDES(VALEUR)
Variable Char    VALEUR()
Affzo [M:SCH5]ZCODCHO
End


