#----------------------------
Subprog C_OPETRAM(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 | VALEUR>7
  mkstat=1
Endif
End

#----------------------------
Subprog AS_OPETRAM(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
  VALEUR=1
Endif
End

#----------------------------
Subprog AS_OPESELTYP(VALEUR)
Variable Integer VALEUR
If [M:SCH4]OPEVALEXP=""
  VALEUR=2 : mkstat=2
Endif
End

#----------------------------
Subprog AM_OPEVALEXP(VALEUR)
Variable Char    VALEUR()
If toupper(right$([M:SCH4]OPEVALEXP,instr(1,[M:SCH4]OPEVALEXP,"]")+1))<>toupper(right$(VALEUR,instr(1,VALEUR,"]")+1))
  Effzo [M:SCH4]OPELNG
Endif
End

#----------------------------
Subprog AS_OPELNG(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 : End : Endif
If !clalev([F:ATZ]) : Local File ATABZON : Endif
Read [F:ATZ]CODZONE="OPERATION";toupper(right$([M:SCH4]OPEVALEXP,instr(1,[M:SCH4]OPEVALEXP,"]")+1))
If !fstat
  If [F:ATZ]LONG<>0
    VALEUR=min([F:ATZ]LONG,45)
  Else
    If !clalev([F:ATY]) : Local File ATYPE : Endif
    Read [F:ATY]CODTYP=[F:ATZ]CODTYP
    If !fstat & [F:ATY]LNGTYP<>0
      VALEUR=min([F:ATY]LNGTYP,45)
    Endif
  Endif
Endif
End

#----------------------------
Subprog C_OPELNG(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 | VALEUR>45
  mkstat=1
Endif
End

