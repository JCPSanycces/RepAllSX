Subprog AM_JNTRA(ZVAL,ZNUM)
Variable Integer ZVAL
Value Integer ZNUM
Local Integer I, ZNBCAL
Local Char ZCAL(5)(20)
Raz [L]ZNBCAL, [L]ZCAL
For [L]I=0 To [M:SCH5]NBCAL-1
  If [L]ZVAL=2 & evalue("[M:SCH5]DAYTRA"+num$([L]ZNUM)+"("+num$([L]I)+")")=2
    [V]GMESSAGE="Jour travaillé dans le code calendrier"-[M:SCH5]CODCHO([L]I)
    [V]GMESSAGE+=".\Passez au préalable ce jour à 'Non travaillé' dans ce calendrier pour valider votre choix."
    mkstat=1
    Break
  Elsif [L]ZVAL=1 & evalue("[M:SCH5]DAYTRA"+num$([L]ZNUM)+"("+num$([L]I)+")")<>2
    [L]ZCAL([L]ZNBCAL)=[M:SCH5]CODCHO([L]I)
    [L]ZNBCAL+=1
  Endif
Next
If [L]ZVAL=1 & [L]ZNBCAL
  If [L]ZNBCAL=1
    [V]GMESSAGE="Attention !\Jour non travaillé dans le code calendrier"-[L]ZCAL(0)+"."
    [V]GMESSAGE+="\Pensez à mettre à jour ce calendrier."
  Else
    [V]GMESSAGE="Attention !\Jour non travaillé dans les codes calendrier"-[L]ZCAL(0)
    For [L]I=1 To [L]ZNBCAL-1
      If [L]I=[L]ZNBCAL-1
        [V]GMESSAGE-="et"-[L]ZCAL([L]I)+"."
      Else
        [V]GMESSAGE+=","-[L]ZCAL([L]I)
      Endif
    Next
    [V]GMESSAGE+="\Pensez à mettre à jour ces calendriers."
  Endif
  GERR=2
Endif
End

#----------------------------
Subprog AV_JNTRA6(VALEUR)
Variable Integer VALEUR
If VALEUR=0 & GREP="C"
  VALEUR=2
Endif
End

