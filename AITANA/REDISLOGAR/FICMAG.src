End


  # X3-29237
########################################
# Fonction utilisée dans le fichier bancaire
Funprog ISR_SUBSCRIBER(BVRREFLINE)
Value Char BVRREFLINE
Local Char RTN(11)

Local     Char        CHAINE(100)
Local     Char        ISR_SUBSCRIBER(9)

CHAINE = BVRREFLINE
ISR_SUBSCRIBER = ""
If CHAINE <> "" Then
  If len(CHAINE) = 53 and mid$(CHAINE,14,1) = ">" and mid$(CHAINE,42,2) = "+ " and right$(CHAINE,53) = ">"
    ISR_SUBSCRIBER = seg$(CHAINE, 44, 52)
  Endif
  If len(CHAINE) = 43 and mid$(CHAINE,4,1) = ">" and mid$(CHAINE,32,2) = "+ " and right$(CHAINE,43) = ">"
    ISR_SUBSCRIBER = seg$(CHAINE, 34, 42)
  Endif
#  If len(CHAINE) = 41 and mid$(CHAINE,1,1)="<" and mid$(CHAINE,17,2) = "> " and mid$(CHAINE,34,2) = "+ " and right$(CHAINE,41)=">"
#    ISR_SUBSCRIBER = seg$(CHAINE, 36, 40)
#  Endif
#  If len(CHAINE) = 23 and mid$(CHAINE,16,2) = "+ " and right$(CHAINE,23) = ">"
#    ISR_SUBSCRIBER = seg$(CHAINE, 18, 22)
#  Endif
#  If len(CHAINE) = 6 and right$(CHAINE,6) = ">"
#    ISR_SUBSCRIBER = seg$(CHAINE, 1, 5)
#  Endif
  If len(CHAINE) = 42 and mid$(CHAINE,14,1) = ">" and mid$(CHAINE,31,2) = "+ " and right$(CHAINE,42) = ">"
    ISR_SUBSCRIBER = seg$(CHAINE, 33, 41)
  Endif
  If len(CHAINE) = 28 and mid$(CHAINE,17,2) = "+ " and right$(CHAINE,28) = ">"
    ISR_SUBSCRIBER = seg$(CHAINE, 19, 27)
  Endif
  If len(CHAINE) = 32 and mid$(CHAINE,4,1) = ">" and mid$(CHAINE,21,2) = "+ " and right$(CHAINE,32) = ">"
    ISR_SUBSCRIBER = seg$(CHAINE, 23, 31)
  Endif
Endif

# Avec tirets
#RTN = seg$(ISR_SUBSCRIBER,1,2)+"-"+seg$(ISR_SUBSCRIBER,3,8)+"-"+seg$(ISR_SUBSCRIBER,9,9)
# Sans tiret
RTN = ISR_SUBSCRIBER

End RTN



  # X3-29237
########################################
# Fonction utilisée dans le fichier bancaire
Funprog ISR_REFERENCE(BVRREFLINE)
Value Char BVRREFLINE
Local Char RTN(27)

Local     Char        CHAINE(100)
Local     Char        ISR_REFERENCE(27)

CHAINE = BVRREFLINE                # recherche BVRREFLINE
If CHAINE <> "" Then
  If len(CHAINE) = 53 and mid$(CHAINE,14,1) = ">" and mid$(CHAINE,42,2) = "+ " and right$(CHAINE,53) = ">"
    ISR_REFERENCE = seg$(CHAINE, 15, 41)
  Endif
  If len(CHAINE) = 43 and mid$(CHAINE,4,1) = ">" and mid$(CHAINE,32,2) = "+ " and right$(CHAINE,43) = ">"
    ISR_REFERENCE = seg$(CHAINE, 5, 31)
  Endif
  If len(CHAINE) = 41 and mid$(CHAINE,1,1)="<" and mid$(CHAINE,17,2) = "> " and mid$(CHAINE,34,2) = "+ " and right$(CHAINE,41)=">"
    ISR_REFERENCE = seg$(CHAINE, 19, 33)
  Endif
  If len(CHAINE) = 23 and mid$(CHAINE,16,2) = "+ " and right$(CHAINE,23) = ">"
    ISR_REFERENCE = seg$(CHAINE, 1, 15)
  Endif
  If len(CHAINE) = 6 and right$(CHAINE,6) = ">"
    ISR_REFERENCE = ""
  Endif
  If len(CHAINE) = 42 and mid$(CHAINE,14,1) = ">" and mid$(CHAINE,31,2) = "+ " and right$(CHAINE,42) = ">"
    ISR_REFERENCE = format$("N0:27",seg$(CHAINE, 15, 30))
  Endif
  If len(CHAINE) = 28 and mid$(CHAINE,17,2) = "+ " and right$(CHAINE,28) = ">"
    ISR_REFERENCE = format$("N0:27",seg$(CHAINE, 1, 16))
  Endif
  If len(CHAINE) = 32 and mid$(CHAINE,4,1) = ">" and mid$(CHAINE,21,2) = "+ " and right$(CHAINE,32) = ">"
    ISR_REFERENCE = format$("N0:27",seg$(CHAINE, 5, 20))
  Endif
Else
  ISR_REFERENCE = ""
Endif
#>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>

RTN = ISR_REFERENCE

End RTN


  # X3-29239
#########################################################################################################
## SET_PARAM_VALUE
#########################################################################################################
#**
#* Returns RTN a string that is the concatanation of a given string and a given decimal separated by a separator
#* Example : SET_PARAM_VALUE("CHF", 12345.27, ":") will return a string ":CHF:12345.27:"
#*
#* @param FLD1    String
#* @param FLD2    Decimal
#* @param SEP     Separator
#*!
Funprog SET_PARAM_VALUE(FLD1, FLD2, SEP)
Value Char FLD1
Value Decimal FLD2
Value Char SEP
Local Char RTN(100)

Local Char  CHAINE(100)
CHAINE  = SEP+FLD1+SEP
CHAINE += ctrans(format$("Nv:12.2",FLD2),",",".")+string$(instr(1,ctrans(format$("Nv:12.2",FLD2),",","."),".")=0,".")
CHAINE += SEP
RTN = CHAINE

End RTN

#JOJAC - 2018-08-21 - X3-104634 - START
#**
#* Returns RTN a string that is the concatanation of a given string and a given decimal based on currency setup separated by a separator
#* Example : func FICMAG.SET_CURAMT_VALUE("CHF", 12345.27, ":") will return a string ":CHF:12345.27:" (CHF setup decimal = 2)
#* Example : func FICMAG.SET_CURAMT_VALUE("JPY", 12345.27, ":") will return a string ":CHF:12345.27:" (JPY setup decimal = 0)
#* @param FLD1    String
#* @param FLD2    Decimal
#* @param SEP     Separator
#*!
Funprog SET_CURAMT_VALUE(FLD1, FLD2, SEP)
Value Char FLD1
Value Decimal FLD2
Value Char SEP
Local Char RTN(100)
Local Char  CHAINE(100)
Local Integer DCB

CHAINE  = SEP+FLD1+SEP
If clalev([TCU])=0 : Local File TABCUR [TCU] : Endif
Read [TCU]TCU0=FLD1
If !fstat
  Case [TCU]DECNBR
    When 0
      CHAINE += ctrans(format$("Nv:12",FLD2),",",".")
    When 1
      CHAINE += ctrans(format$("Nv:12.1",FLD2),",",".")+string$(instr(1,ctrans(format$("Nv:12.1",FLD2),",","."),".")=0,".")
    When 2
      CHAINE += ctrans(format$("Nv:12.2",FLD2),",",".")+string$(instr(1,ctrans(format$("Nv:12.2",FLD2),",","."),".")=0,".")
    When 3
      CHAINE += ctrans(format$("Nv:12.3",FLD2),",",".")+string$(instr(1,ctrans(format$("Nv:12.3",FLD2),",","."),".")=0,".")
    When 4
      CHAINE += ctrans(format$("Nv:12.4",FLD2),",",".")+string$(instr(1,ctrans(format$("Nv:12.4",FLD2),",","."),".")=0,".")
    When 5
      CHAINE += ctrans(format$("Nv:12.5",FLD2),",",".")+string$(instr(1,ctrans(format$("Nv:12.5",FLD2),",","."),".")=0,".")
    When Default
      CHAINE += ctrans(format$("Nv:12.2",FLD2),",",".")+string$(instr(1,ctrans(format$("Nv:12.2",FLD2),",","."),".")=0,".")
  Endcase
Else
  CHAINE += ctrans(format$("Nv:12.2",FLD2),",",".")+string$(instr(1,ctrans(format$("Nv:12.2",FLD2),",","."),".")=0,".")
Endif
CHAINE += SEP
RTN = CHAINE

End RTN
#JOJAC - 2018-08-21 - X3-104634 - END

#JOJAC - 2018-09-05 - X3-103764 - START
Funprog GET_ADDLINE()
Local Char RETVAL(250)
Local Integer LIGNO

For LIGNO = 0 To dim([F:BPA]BPAADDLIG)-1
  RETVAL = [F:BPA]BPAADDLIG(LIGNO)
  If RETVAL <> "" : Break  : Endif
Next

End RETVAL
#JOJAC - 2018-09-05 - X3-103764 - END




