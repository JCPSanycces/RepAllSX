Variable Integer VALEUR
Call D_TYPFIL(VALEUR) From SUBFRM
End

Subprog AS_TYPFIL(VALEUR)
Variable Integer VALEUR
mkstat = 2 : End
End

Subprog AM_TYPFIL(VALEUR)
Variable Integer VALEUR
Call AM_TYPFIL(VALEUR) From SUBFRM
End

########################################

Subprog AV_INI(VALEUR)
Variable Char VALEUR()
If [M]ALLCPY=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
Else
 Actzo CPY,ALLFCY
 If [M]ALLCPY=2
  Effzo FCY : Grizo FCY
 Else
  Actzo FCY
 Endif
Endif
If GBIDC1<>"" & dim([M]ALLTYP)>0
 [M]ALLTYP = 1 : [M]TYP = GBIDC1
 Affzo [M]ALLTYP, TYP
 If dim([M]ZTYP)>0 : Affzo ZTYP : Endif
 Grizo ALLTYP, TYP
Elsif dim([M]ALLTYP)>0
 Actzo [M]ALLTYP
 If [M]ALLTYP=2
  Effzo TYP : Grizo TYP
 Else
  Actzo TYP
 Endif
Endif
If GACTION="FICMAG"
 [M]TYPFIL=2 : Grizo [M]TYPFIL : Affzo [M]TYPFIL
Endif
End

########################################
# Type identifiant du compte du bénéficiaire
#   = 1 si le compte tiers est situé dans la zone Euro
#   = 2 sinon
# Utilisé dans le fichier bancaire VIRINTER enregistrement 04
Funprog TYPID(CRY)
Value Char CRY()
Local Char TYPCOD(5)

If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
 Call LEC_TCY(CRY) From CPTLEC
 # La vérif doit se faire non sur la devise
 # mais sur la zone "Gestion de l'IBAN" du pays du tiers
 If [F:TCY]FLIBAN=G_OUI
  TYPCOD="1"
 Else
  TYPCOD="2"
 Endif
End TYPCOD

########################################
Funprog IBAN(CRY,NUMBER)
Value    Char CRY()
Value    Char NUMBER()
Local    Char IBACOD(50), TYPCOD(5)

# L'IBAN est :
#     - soit calculé avec méthode CRE_IBAN si le compte tiers gère l'IBAN,
#     - soit concaténé avec 4 blancs + numéro de compte, sinon
TYPCOD = func TYPID(CRY)
If TYPCOD="1"
 Call CRE_IBAN(IBACOD,CRY,"",NUMBER) From SUBBID
 If IBACOD=""
  IBACOD = CRY+NUMBER
 Endif
Elsif TYPCOD="2"
 IBACOD = "    "+NUMBER
Endif
End IBACOD

########################################
Funprog IDENT_FRAIS(TYPIDFRAIS, BANQUE)
Value Char TYPIDFRAIS, BANQUE
Local Char IDFRAIS(30)

If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif

If TYPIDFRAIS="0"
 IDFRAIS=""
Endif
If TYPIDFRAIS="1"
 Call LEC_BAN(BANQUE) From CPTLEC
 IDFRAIS=[F:BAN]IBACOD : # Code IBAN du compte émetteur
Endif
If TYPIDFRAIS="0"
 Call LEC_BAN(BANQUE) From CPTLEC
 IDFRAIS=[F:BAN]BIDNUM : # RIB du compte émetteur
Endif
End IDFRAIS

########################################
# Concaténation du code nature économique et
# du pays, avec un espace devant et derrière
# Utilisé dans le fichier bancaire VIREMENT détail, n° ordre 1
Funprog BAL_PAIEMENT(BDFECO, TRS, ADR)
Value Char BDFECO, TRS, ADR
Local Char BALPAIE(30), CRY(30)

BALPAIE = ""
If BDFECO<>""
 CRY = ""
 If clalev([F:BID])=0 : Local File BID [BID] : Endif
 Filter [F:BID] Where BPATYP=1 and BPANUM=TRS and BPAADD=ADR
 Read [F:BID] First
 Filter [BID]
 If !fstat
  CRY = [F:BID]CRY
 Endif

 While len(BDFECO)<3 : BDFECO = " "+BDFECO : Wend
 While len(CRY)<3    : CRY    = " "+CRY    : Wend
 BALPAIE = " "+BDFECO+CRY+" "
Endif
End BALPAIE

########################################
# Si code activité VII à Oui et champ Mode règlement activé,
# on renseigne le code Mode règlement
# Utilisé dans le fichier bancaire VIRINTER détails, n° ordre 0
Funprog MODPAM(PAYTYP,TRS)
Value    Char    PAYTYP, TRS
Local    Char    PAM(30)
Local    Integer OK, SAISIE_PAM

PAM=""
If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
Call LEC_BPR(TRS) From CPTLEC
If !fstat
 PAM = [F:BPR]MODPAM
Endif
If PAM="" Then PAM="0" Endif
End PAM

########################################
# Utilisé dans le fichier bancaire VIRINTER détails, n° ordre 0
Funprog IMPUT_EXS(IPTEXS)
