Local    Char    IMPUT(30)
Local    Integer OK

IMPUT=IPTEXS
If IMPUT=""
 IMPUT="14"
Endif
End IMPUT

########################################
# Utilisé dans le fichier bancaire VIRINTER détails, n° ordre 0
Funprog TYPID_EXS(IPTEXS)
Value    Char    IPTEXS
Local    Char    TYPID(30)
Local    Integer OK

TYPID=""
If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
Call LEC_BAN([F:PYH]BAN) From CPTLEC
If !fstat
 If [F:BAN]BIDEXS<>"" and find(IPTEXS,"14","15","")
  TYPID="1"
 Endif
Endif
End TYPID

########################################
# Utilisé dans le fichier bancaire VIRINTER détails, n° ordre 0
Funprog CPT_EXS(BIDEXS,IPTEXS)
Value    Char    BIDEXS, IPTEXS
Local    Char    CPTEXS(34), IBACOD(34)
Local    Integer OK

If func AFNC.ACTIV("VII")
 CPTEXS  = ""
 # Le compte de frais ne doit sortir que si le type identifiant est à 14 ou 15
 If func TYPID_EXS(IPTEXS)<>""
  If IPTEXS="13"
   CPTEXS=""
  Endif
  If find(IPTEXS,"14","15","")
   If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
   Call LEC_BAN([F:PYH]BAN) From CPTLEC
   If !fstat
    If BIDEXS=""
     CPTEXS=[F:BAN]IBACOD
    Else
     Call CRE_IBAN(IBACOD,[F:BAN]CRY,"",[F:BAN]BIDEXS) From SUBBID
     CPTEXS=IBACOD
    Endif
   Endif
  Endif
 Endif
Endif
End CPTEXS

########################################
# Utilisé dans le fichier bancaire VIRINTER détails, n° ordre 0
Funprog CUR_EXS(BIDEXS,IPTEXS)
Value    Char    BIDEXS, IPTEXS
Local    Char    CUREXS(30)
Local    Integer OK

If func AFNC.ACTIV("VII")
 CUREXS  = ""
 If func TYPID_EXS(IPTEXS)<>""
  If IPTEXS="13"
   CUREXS=""
  Endif
  If (IPTEXS="14" or IPTEXS="15" or IPTEXS="")
   If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
   Call LEC_BAN([F:PYH]BAN) From CPTLEC
   If !fstat
    If BIDEXS=""
     CUREXS=[F:BAN]CUR
    Else
     CUREXS=[F:BAN]CUREXS
    Endif
   Endif
  Endif
 Endif
Endif
End CUREXS

