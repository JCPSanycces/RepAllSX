#<AdxTL>@(#)0.0.0.0 $Revision$ 
#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#
# Issue X3-52745 - 2017-08-24 by BEFOU : Adding  ON REPLCAR
# X3-118926 2018-12-06 Bader SEL_TABLE: Don't show remittances linked to payment entry types without bank file generation
#
#########################################################################
#Cod. Act: Y0030 Varios vencimientos en SDD
#Programador: OMM
#Fecha: 18/01/2019
#Marca: [Y0030]
#########################################################################
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"FICMAG"
 GFONCTION="FICMAG" : Call AUTORIS From EXEFNC
Endif
GACTION = "FICMAG"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","FICMAG","DFICMAG",3,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

##########################################################################
$ACTION
##########################################################################
Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE_BATCH" : Gosub INIT
 When "TIT_DIA"     : Gosub TIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "SEL_TABLE"   : Gosub SEL_TABLE
# X3-118926 2018-12-14 Bader begin Release global variable GPAYTYPARR (created in SEL_TABLE) if existent
 When "SORTIE"      : Gosub SORTIE
# X3-118926 2018-12-14 Bader end
Endcase
Return


# X3-118926 2018-12-14 Bader begin Release global variable GPAYTYPARR (created in SEL_TABLE) if existent
##########################################################################
$SORTIE
##########################################################################
If dim(GPAYTYPARR) > 0
    Kill GPAYTYPARR              # X3-118926 2018-12-14 Bader created in SEL_TABLE for selection of payment entry types
Endif
Return
# X3-118926 2018-12-14 Bader end


##########################################################################
$INIT
##########################################################################
Case GACTION
 When "FICMAG1" # Coming from GESFRM
  Onerrgo ERREUR From CONTROLE
  If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
  If clalev([F:TPY2])=0 : Local File TABPAYTYP [TPY2] : Endif
  If clalev([F:PYH])=0 : Local File PAYMENTH  [PYH] : Endif
  If clalev([F:BAN])=0 : Local File BANK      [BAN] : Endif
  If clalev([F:FRM])=0 : Local File PAYFRM    [FRM] : Endif
  If clalev([F:TFB])=0 : Local File TABFILBAN [TFB] : Endif
  If clalev([F:EDP])=0 : Local File EDIPAR    [EDP] : Endif
  If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif
  If filinfo(filpath("FIL","MANDATE","fde",nomap),0)>0
   If clalev([F:MDT])=0 : Local File MANDATE   [MDT] : Endif
  Endif
  Onerrgo
  If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

  Local Char    DIR_FICBAN(GDIMFIC)
  Local Char    VOLPATH(GDIMFIC)
  Local Char    MACHIN(GDIMFIC)                      : # Machine
  Local Char    IRS(2)                               : # Separator
  Local Char    OS(20)
  Local Char    L_NOM(20), NOM(20)                   : # Name of file to generate
  Local Integer L_NUM                                : # Extension number file to generate
  Local Char    L_EXT(5), EXT(5)                     : # Extension file to generate
  Local Integer TYPFIC                               : # 1=ETEBAC; 2=EDI; 3=SEPA
  Local Integer I


  Read [FRM]FRM0 = 1;PARAM(1)
  If fstat : FIN=1 : Return : Endif
  If [F:FRM]TFBFIL<>""
   If instr(1,"0123456789",mid$([F:FRM]TFBFIL,2,1))
    L_NUM=val(mid$([F:FRM]TFBFIL,2,5))
   Else
    L_NUM=val(mid$([F:FRM]TFBFIL,3,5))
   Endif
  Endif
  Call LEC_BAN([F:FRM]BAN) From CPTLEC
  # GCURLEG  is set when coming from FICMAG and not FICMAG1
  # so in this case fill in GCURLEG with the LEG of the CPY of the remittance
  Call LEC_CPY([F:FRM]CPY) From CPTLEC
  Call LEC_TPY_LEG([F:CPY]LEG,[F:FRM]PAYTYP) From CPTLEC

  # Condition with FILREF6 (ETEBAC)
  If [F:TPY]FILREF6<>"" & [F:TPY]FILREF8="" & [F:TPY]FILREF71=""
   If [F:TPY]NATPAY<=1  :  BCRIT = "" : Endif
   TYPFIC = 1
   Read [TFB]TFB0(5) = [F:TPY]FILREF6;[F:FRM]BAN;1;0;[F:CPY]LEG
    If fstat
     Read [TFB]TFB0(5) = [F:TPY]FILREF6;[F:FRM]BAN;1;0;""
     If fstat
      Read [TFB]TFB0(5) = [F:TPY]FILREF6;"";1;0;[F:CPY]LEG
      If fstat
       Read [TFB]TFB0(5) = [F:TPY]FILREF6;"";1;0;""
       If fstat : Raz [F:TFB] : Endif
      Endif
     Endif
    Endif
   Endif

  # Condition with FILREF71 (EDI)
  If [F:TPY]FILREF6="" & [F:TPY]FILREF8="" & [F:TPY]FILREF71<>""
   If [F:TPY]NATPAY<=1  :  BCRIT = "" : Endif
   TYPFIC = 2
   Read [EDP]EDP0 = [F:TPY]FILREF71;[F:FRM]BAN;0;1
   If fstat
    Read [EDP]EDP0 = [F:TPY]FILREF71;"";0;1
    If fstat : Raz [F:EDP] : Endif
   Endif
  Endif
  # Condition with FILREF8 (SEPA)
  If [F:TPY]FILREF6="" & [F:TPY]FILREF8<>"" & [F:TPY]FILREF71=""
   If [F:TPY]NATPAY<=1  :  BCRIT = "" : Endif
   TYPFIC = 3
   Read [TFB]TFB0(5) = [F:TPY]FILREF8;[F:FRM]BAN;1;0;[F:CPY]LEG
    If fstat
     Read [TFB]TFB0(5) = [F:TPY]FILREF8;[F:FRM]BAN;1;0;""
     If fstat
      Read [TFB]TFB0(5) = [F:TPY]FILREF8;"";1;0;[F:CPY]LEG
      If fstat
       Read [TFB]TFB0(5) = [F:TPY]FILREF8;"";1;0;""
       If fstat : Raz [F:TFB] : Endif
      Endif
     Endif
    Endif
  Endif

  L_EXT = [F:BAN]FILEXT
  If L_EXT=""
   If len([F:BAN]BAN)>3
    GERR=1 : GMESSAGE= func AFNC.MES1(mess(262,117,1), [F:BAN]BAN)
   Else
    L_EXT = [F:BAN]BAN
   Endif
  Endif

  If L_NUM=0
   L_NUM = [C]NUMFIL+1
  Endif

  If L_NUM>=100000
   L_NUM = 1
  Endif

 When "FICMAG","AFRQTPAB"
  Onerrgo CHUT From CONTROLE
  Local Integer TYPFIC
  If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
  If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
  If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
  If !clalev([F:TPY2]) : Local File TABPAYTYP [TPY2]  : Endif
  If !clalev([F:FRM])  : Local File PAYFRM     [FRM]  : Endif
  If !clalev([F:TFB])  : Local File TABFILBAN  [TFB]  : Endif
  If !clalev([F:TCA])  : Local File TABCOUAFF  [TCA]  : Endif
  If filinfo(filpath("FIL","MANDATE","fde",nomap),0)>0
   If !clalev([F:MDT]) : Local File MANDATE    [MDT] : Endif
  Endif
  Onerrgo
  If GERREUR : GERREUR=0 : Endif

  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
  # Folder one leg then GCURLEG = GDOSLEG
  If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif

Endcase

Return

##########################################################################
# Fields initialization
##########################################################################
$TIT_DIA
Case GACTION
 When "FICMAG1" # Coming from GESFRM
  If clalev([M:FRM0])
   If [M:DIA]CPY3=""
    [M:DIA]CPY3  = [M:FRM0]CPY
   Endif
   If [M:DIA]FRMFCY3=""
    [M:DIA]FRMFCY3 = [M:FRM0]FRMFCY
   Endif
   If [M:DIA]BAN3=""
    [M:DIA]BAN3    = [M:FRM0]BAN
   Endif
   If [M:DIA]PAYTYP3=""
    [M:DIA]PAYTYP3 = [M:FRM0]PAYTYP
   Endif
   Call AS_FILREF6([M:DIA]FILREF6)   From SUBFRM
   Call AS_FILREF71([M:DIA]FILREF71) From SUBFRM
   Call AS_FILREF8([M:DIA]FILREF8)   From SUBFRM
  Endif
Endcase
Local Char NOMFIL(GDIMFIC)
If !GBATCH & GACTION="FICMAG1"
 [M]TYPFIL=2
 If [M:DIA]VOLFIL=""
  Call PARAMUTIL("REPBANKDEF",NOMFIL,GUSER,"") From SUBAUS
  If NOMFIL<>"" & left$(NOMFIL,1)="["
   [M]VOLFIL = NOMFIL
  Else
   [M]VOLFIL = "["+GDIRBQE+"]"
  Endif
 Endif
Endif
Affzo [M:DIA]VOLFIL
Call AM_TYPFIL([M:DIA]TYPFIL) From SUBFRM
Return

##########################################################################
$CONTROLE
##########################################################################

Case GACTION
 When "FICMAG1" # Coming from GESFRM
  If BCRIT<>""
   If [M:DIA]FILREF6="" and [M:DIA]FILREF71="" and [M:DIA]FILREF8=""
    GMESSAGE = mess(132,121,1) : # Saisie d'un format de fichier obligatoire
    GERR = 1 : SAI = 1 : Return
   Endif
   # Vérif FILREF6
   If [M:DIA]FILREF6<>""
    Filter [TFB] Where COD=[M:DIA]FILREF6
    Read [TFB]TFB0 First
    Filter [TFB]
    If fstat
     GMESSAGE = mess(101,100,1) : # Fichier inexistant
     GERR = 1 : SAI = 1 : Return
    Endif
    Filter [TFB] Where COD=[M:DIA]FILREF6 and NATPAY=[F:TPY]NATPAY
    Read [TFB]TFB0 First
    Filter [TFB]
    If fstat
     GMESSAGE = mess(36,115,1)
     GERR = 1 : SAI = 1 : Return
    Endif
    # GCURLEG  is set when coming from FICMAG and not FICMAG1
    # so in this case fill in GCURLEG with the LEG of the CPY of the remittance
    Call LEC_CPY([F:FRM]CPY) From CPTLEC
    Call LEC_TPY_LEG([F:CPY]LEG,[F:FRM]PAYTYP) From CPTLEC
    TYPFIC = 1
    Read [TFB]TFB0(5) = [M:DIA]FILREF6;[F:FRM]BAN;1;0;[F:CPY]LEG
    If fstat
     Read [TFB]TFB0(5) = [M:DIA]FILREF6;[F:FRM]BAN;1;0;""
     If fstat
      Read [TFB]TFB0(5) = [M:DIA]FILREF6;"";1;0;[F:CPY]LEG
      If fstat
       Read [TFB]TFB0(5) = [M:DIA]FILREF6;"";1;0;""
       If fstat : Raz [F:TFB] : Endif
      Endif
     Endif
    Endif
   # Vérif FILREF7
   Elsif [M:DIA]FILREF71<>""
    Filter [EDP] Where MES=[M:DIA]FILREF71
    Read[EDP]EDP0 First
    If fstat
     GMESSAGE = mess(9,136,1) : # Paramétrage inexistant
     GERR = 1 : SAI = 1 : Return
    Endif
    Filter [EDP] Where MES=[M:DIA]FILREF71 & NATPAY=[F:TPY]NATPAY
    Read[EDP]EDP0 First
    If fstat
     GMESSAGE = mess(36,115,1) : # Struture de fichier incorrect
     GERR = 1 : SAI = 1 : Return
    Endif
    Filter [EDP]
    TYPFIC = 2
    Read [EDP]EDP0 = [M:DIA]FILREF71;[F:FRM]BAN;0;1
    If fstat
     Read [EDP]EDP0 = [M:DIA]FILREF71;"";0;1
     If fstat : Raz [F:EDP] : Endif
    Endif
   # Vérif FILREF8
   Elsif [M:DIA]FILREF8<>""
    Filter [TFB] Where COD=[M:DIA]FILREF8
    Read [TFB]TFB0 First
    Filter [TFB]
    If fstat
     GMESSAGE = mess(101,100,1) : # Fichier inexistant
     GERR = 1 : SAI = 1 : Return
    Endif
    Filter [TFB] Where COD=[M:DIA]FILREF8 and NATPAY=[F:TPY]NATPAY
    Read [TFB]TFB0 First
    Filter [TFB]
    If fstat
     GMESSAGE = mess(36,115,1) : # Struture de fichier incorrect
     GERR = 1 : SAI = 1 : Return
    Endif
    # GCURLEG  is set when coming from FICMAG and not FICMAG1
    # so in this case fill in GCURLEG with the LEG of the CPY of the remittance
    Call LEC_CPY([F:FRM]CPY) From CPTLEC
    Call LEC_TPY_LEG([F:CPY]LEG,[F:FRM]PAYTYP) From CPTLEC
    TYPFIC = 3
    Read [TFB]TFB0(5) = [M:DIA]FILREF8;[F:FRM]BAN;1;0;[F:CPY]LEG
    If fstat
     Read [TFB]TFB0(5) = [M:DIA]FILREF8;[F:FRM]BAN;1;0;""
     If fstat
      Read [TFB]TFB0(5) = [M:DIA]FILREF8;"";1;0;[F:CPY]LEG
      If fstat
       Read [TFB]TFB0(5) = [M:DIA]FILREF8;"";1;0;""
       If fstat : Raz [F:TFB] : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
  # Check TYPFIC = 3
  If TYPFIC=1 | TYPFIC=3 : # ETEBAC ou SEPA fill in in the Payment entry types
   L_NOM = [F:TFB]FILREF
   If L_NOM="" : L_NOM = left$([F:TFB]COD,2) : Endif
   L_NOM += format$("N0:5#",L_NUM)
  Elsif TYPFIC=2 : # EDI
   L_NOM = [F:EDP]FILREF
   If L_NOM="" : L_NOM = left$([F:EDP]MES,2) : Endif
   L_NOM += format$("N0:5#",L_NUM)
  Endif

  Raz [L]NOM, [L]EXT
  # Point d'entrée personnalisation nom du fichier
  GPOINT = "NOMFIC" : Gosub ENTREE From EXEFNC
  If [L]NOM<>"" : L_NOM=[L]NOM : Endif
  If [L]EXT<>"" : L_EXT=[L]EXT : Endif

  # if needed, append a slash character to the volume path
  If clalev([M:DIA])>0
   DIR_FICBAN=[M:DIA]FILDIRLOC
   VOLPATH = [M:DIA]VOLFIL
   If right$(VOLPATH,len(VOLPATH))<>"/" : VOLPATH += "/" : Endif
  Endif

  If L_NOM<>""
   If DIR_FICBAN<>"" and right$(DIR_FICBAN, len(DIR_FICBAN))<>"/"
    DIR_FICBAN += "/"
   Endif
   If [F:TFB]FILEXO<>""
    DIR_FICBAN += L_NOM+L_EXT+"."+[F:TFB]FILEXO
    VOLPATH += L_NOM+L_EXT+"."+[F:TFB]FILEXO
   Else
    DIR_FICBAN += L_NOM+"."+L_EXT
    VOLPATH += L_NOM+"."+L_EXT
   Endif
  Endif

  # Confirmation ?
  Read [PYH]PYH1(2) = 1;PARAM(1)
  If fstat
   FIN=1 : Return
  Elsif [F:PYH]STAFLG(5)=2
   GMESSAGE = ""
   If [F:PYH]TFBFIL<>""      : GMESSAGE -= [F:PYH]TFBFIL : Endif
   If [F:PYH]TFBDAT<>[0/0/0] : GMESSAGE -= format$("D:"+GFMDAT,[F:PYH]TFBDAT) : Endif
   If GMESSAGE<>"" : GMESSAGE = " :"+GMESSAGE : Endif
   OK=1 : TIT=mess(69,121,1)+GMESSAGE+"\"+mess(68,141,1)-"|"+VOLPATH+"|\"+mess(36,100,1)
   Call OUINON(TIT,OK) From GESECRAN
   If OK<>2 : FIN = 1 : Endif
  Else
   OK=2 : TIT=mess(68,141,1)-"|"+VOLPATH+"|\"+mess(36,100,1)
   Call OUINON(TIT,OK) From GESECRAN
   If OK<>2 : FIN = 1 : Endif
  Endif

 When "FICMAG"  # Coming from FICMAG
  If GSERVEUR : [M:DIA]TRCFLG=2 : Endif
  If GSERVEUR & dim(GCURLEG)>0 & [M:DIA]LEG<>"" : GCURLEG = [M:DIA]LEG : Endif # Issue X3-48503
  TMP=1 : TIT="V"
Endcase
Return

##########################################################################
$EXEC
##########################################################################
Local Integer STA
Local Char   MESSA(80)

Case GACTION
 When "FICMAG"
  Onerrgo ERREUR From CONTROLE
  If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
  If clalev([F:PYH])=0 : Local File PAYMENTH  [PYH] : Endif
  If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif
  If filinfo(filpath("FIL","MANDATE","fde",nomap),0)>0
   If clalev([F:MDT])=0 : Local File MANDATE   [MDT] : Endif
  Endif
  Onerrgo
  If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

  Local Integer OK, NBREM
  Local Char    CRITERE(250), CRITSPE(250)
  If !GSERVEUR & [M:DIA]TRCFLG=2
   Call TITAWI(BCRIT,CRITERE) From OBJDIV
   Call OUVRE_TRACE(CRITERE) From LECFIC
  Endif

  CRITERE = "FRMFLG=1"
  If [M:DIA]VCRFLG<>2
   CRITERE -= " & STAFLG(5)<>2"
  Endif
  If [M:DIA]ALLCPY<>2
   CRITERE -= '& CPY="'+[M:DIA]CPY+'"'
  Endif
  If [M:DIA]ALLFCY<>2
   CRITERE -= '& FRMFCY="'+[M:DIA]FCY+'"'
  Endif
  If [M:DIA]ALLTYP<>2
   CRITERE -= '& PAYTYP="'+[M:DIA]TYP+'"'
  Endif
  If [M:DIA]VCRSTR=[M:DIA]VCREND & [M:DIA]VCRSTR<>""
   CRITERE -= '& FRMNUM="'+[M:DIA]VCRSTR+'"'
  Else
   If [M:DIA]VCRSTR<>""
    CRITERE -= '& FRMNUM>="'+[M:DIA]VCRSTR+'"'
   Endif
   If [M:DIA]VCREND<>""
    CRITERE -= '& FRMNUM<="'+[M:DIA]VCREND+'"'
   Endif
  Endif

  # Entry point for specific filter for payments
  Raz CRITSPE
  GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
  If CRITSPE="" : CRITSPE="1=1" : Endif

  If [M:DIA]ALLTYP=2
   # Check EPACDTTRF
   Filter [TPY2] Where LEG="" | LEG= GCURLEG Order By Key LCLE=PAYTYP Asc ; LEG Desc
   For [TPY2]LCLE(1)
    If ([F:TPY2]STA6=2 or [F:TPY2]EPACDTTRF=2) & [F:TPY2]ENAFLG=2
     Call CONTEXE([F:TPY2]ACS) From CPTSUB
     If mkstat : mkstat=0 : OK=0 : GMESSAGE="" : Else OK=1 : Endif
    Else
     OK = 0
    Endif
    If OK
     If [F:TPY2]FILREF6<>""
      TYPFIC = 1
     Elsif [F:TPY2]FILREF71<>""
      TYPFIC = 2
     Elsif [F:TPY2]FILREF8<>""
      TYPFIC = 3
     Endif

     Link [PYH] With [CPY]CPY1~=GCURLEG;CPY
&    As [LNK]
&    Where PAYTYP=[F:TPY2]PAYTYP & evalue(CRITERE) & evalue(CRITSPE)
&    Order By Key CLE = FRMNUM;FRMLIN

     Gosub PARCOURS
    Endif
   Next
   Filter [TPY2]

  Else

   If [F:TPY]FILREF6<>""
    TYPFIC = 1
   Elsif [F:TPY]FILREF71<>""
    TYPFIC = 2
   Elsif [F:TPY]FILREF8<>""
    TYPFIC = 3
   Endif

   Link [PYH] With [CPY]CPY1~=GCURLEG;CPY
&  As [LNK]
&  Where evalue(CRITERE) & evalue(CRITSPE)
&  Order By Key CLE = FRMNUM;FRMLIN

   Gosub PARCOURS
  Endif
  If !GSERVEUR & [M:DIA]TRCFLG=2
   Call FERME_TRACE From LECFIC
   TRA=1
  Endif

 When "FICMAG1" # Coming from GESFRM
  Local Char TIT(20)
  TIT= mess(126,117,1)-PARAM(1)
  If !GSERVEUR
   Call OUVRE_TRACE(TIT) From LECFIC
  Endif

  If TYPFIC=1 | TYPFIC=3 : # Check TYPFIC = 3
   Call FICHIER(PARAM(1),[F:TFB]COD,STA,MESSA,TYPFIC)
  Else
   Call FICHIER(PARAM(1),[F:EDP]MES,STA,MESSA,TYPFIC)
  Endif
  If TYPFIC=1 | TYPFIC=3 : # Check TYPFIC = 3
   If !STA
    GERR=2
    If GACTION="FICMAG1" & clalev([M:DIA])>0 & [M:DIA]TYPFIL=1 : # Client
     GMESSAGE=mess(101,117,1)-mess(178,115,1)
    Else
     GMESSAGE=mess(101,117,1)-MESSA
    Endif
   Else
    GERR=1 : GMESSAGE=MESSA
   Endif
  Endif

  If !GSERVEUR
   If GERR = 1 and STA<>16
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Else
    Call ECR_TRACE(GMESSAGE,0) From GESECRAN
    Call FERME_TRACE From LECFIC
    TRA = 1
    FIN=1
    Raz GMESSAGE
   Endif
  Endif

 Endcase
Return

##########################################################################
$TERMINE
##########################################################################
Case GACTION
 When "FICMAG"
  If GSERVEUR : Return : Endif
  If !NBREM
   GERR=2
   If STA<>16
    GMESSAGE=mess(129,117,1)             : # Aucun bordereau traité
   Endif
  Elsif [M:DIA]TRCFLG<>2
   GERR=2 : GMESSAGE=num$(NBREM)-mess(130,117,1) : # NBREM bordereau(x) traité(s)
  Endif
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
 Endcase
Return

##########################################################################
$PARCOURS
##########################################################################
For [LNK]CLE(1)
 STA=0
 Call FICHIER([F:PYH]FRMNUM,"",STA,MESSA,TYPFIC)
 If STA=0 :  NBREM += 1 : Endif
 If [M:DIA]TRCFLG=2 & TYPFIC<>2
  If STA=0
   If clalev([M:DIA])>0 & [M:DIA]TYPFIL=1
    Call ECR_TRACE(mess(126,117,1)-[F:PYH]FRMNUM-":"-mess(178,115,1),0) From GESECRAN
   Else
    Call ECR_TRACE(mess(126,117,1)-[F:PYH]FRMNUM-":"-mess(101,117,1)-MESSA,0) From GESECRAN
   Endif
  Else
   If STA<>16
    Call ECR_TRACE(mess(100,117,1)-[F:PYH]FRMNUM-":"-MESSA,1) From GESECRAN
   Else
    Call ECR_TRACE(mess(100,117,1)-[F:PYH]FRMNUM-":"-MESSA,0) From GESECRAN
   Endif
  Endif
 Elsif [M:DIA]TRCFLG<>2 & TYPFIC<>2 & STA
  Call ECR_TRACE(mess(100,117,1)-[F:PYH]FRMNUM-":"-MESSA,1) From GESECRAN
 Endif
Next
Return

##########################################################################
## Generation of the file  ##
##########################################################################
Subprog FICHIER(NUMERO,CODE,STA,MESSA,TYPFIC)
Value    Char    NUMERO
Value    Char    CODE
Variable Integer STA
Variable Char    MESSA()
Variable Integer TYPFIC

Local Decimal BICCODSUM    : # Issue X3-40971
Local Integer TYP, NUM, STAT, IEURO, I
Local Integer SAVIUM
Local Char    BANQUE(GLONBAN), BANCUR(GLONBAN), DEVBAN(GLONCUR),VLEG(GLONADI),LEGCUR(GLONADI)
Local Char    FICHIER(250), NOM(20), EXT(3)
Local Char    SAVIFS(5), SAVIRS(5)
Local Char    RESULT(250), SYMBOLE(40)
Local Char    FLEURO(1)
Local Decimal AMTCUR, AMTBAN, AMTCPY, AMTVIR
Local Decimal TOTCUR, TOTBAN, TOTCPY, TOTVIR
Local Integer NUMREC, DECIM
Local Date    DATJ
Local Char    NOMTIRE(50)
Local Char    PLAN(GLONCOA)
Local Char    DEVLED(GLONCUR)

Local Date    LFECHANT #[Y0030]
Local Integer LINEASXFECHA #[Y0030]
Local Integer CUENTALINEASXFECHA #[Y0030]
Local Char LSQL(255) #[Y0030]
Local Decimal TOTFECHA #[Y0030]


If clalev([M:PAY3])=0 : Local Mask PAY3 [PAY3] : Endif
Local Integer XNBECH : XNBECH = dim([M:PAY3]DENCOD)
Close Local Mask [PAY3]
Local Decimal TOTBIDNUM1, TOTBIDNUM2

## Italian localisation : RIBA file
Local Integer NBLIG, NUMRIBA

## Variables used for variable format file generation
Local Char    FILCOU(GLONANM)  # name of the counter set in GESTCA #<YYFIN_95746>
Local Integer OKTCA
Local Char    MSGID(35)            # value of the counter
Local Integer NBPYH                # Number of payments included in the generated file
Local Integer NBLIG2

## Spanish localisation (fichier NORMA) and German
Local Char    TFAC(GLONVCR)(0..XNBECH-1), TTYP(GLONGTE)
Local Date    TDAT(0..XNBECH-1)          : # fecha factura proveedor
Local Char    TREF(20)(0..XNBECH-1)      : # número factura proveedor
Local Decimal TIMPORTE(0..XNBECH-1)      : # importe factura # CONFIRMING SPA
Local Char    TTIP(3)(0..XNBECH-1)       : # importe factura # CONFIRMING SPA
Local Integer TSNS(0..XNBECH-1)          : # importe factura # CONFIRMING SPA
Local Integer LINEAS                     : # CONFIRMING SPA
Local Integer TOTAL                      : # CONFIRMING SPA
Local Integer NBFAC, CONDOK

Local Char    DIR_FICBAN(GDIMFIC)
Local Char    DIR_FICBAN_OLD(GDIMFIC)
Local Char    VOLPATH(GDIMFIC)
Local Char    MACHIN(GDIMFIC)            : # Machine
Local Char    IRS(2)                     : # Separator
Local Char    OS(20)
Local Integer OK
Local Char    CODLAN(GLONLAN)

# Variables for client
Local Char FICDON(GDIMFIC),URL(GDIMFIC), CHEMIN(GDIMFIC), NOMFIC(GDIMFIC)
Local Integer STAT
#

Local Integer FLGLOA

Local File PAYMENTH [PYH], PAYMENTD [PYD], PAYFRM [FRM]

If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
If clalev([F:TFB])=0 : Local File TABFILBAN [TFB] : Endif
If clalev([F:BAN])=0 : Local File BANK      [BAN] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER  [BPR] : Endif
If clalev([F:BPC])=0 : Local File BPCUSTOMER[BPC] : Endif
If clalev([F:BPS])=0 : Local File BPSUPPLIER[BPS] : Endif
If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif
If filinfo(filpath("FIL","MANDATE","fde",nomap),0)>0
 If clalev([F:MDT])=0 : Local File MANDATE   [MDT] : Endif
Endif
If clalev([F:BPA])=0 : Local File BPADDRESS [BPA] : Endif
If clalev([F:TCU])=0 : Local File TABCUR    [TCU] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT  [GAC] : Endif
If clalev([F:TCH])=0 : Local File TABCHANGE [TCH] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV   [ADI] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY[TCY] : Endif
If clalev([F:SIH])=0 : Local File SINVOICE  [SIH] : Endif
If clalev([F:PIH])=0 : Local File PINVOICE  [PIH] : Endif
If clalev([F:EDP])=0 : Local File EDIPAR    [EDP] : Endif
If clalev([F:BID])=0 : Local File BID       [BID] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : Endif
If clalev([F:TAM])=0 : Local File TABPAM    [TAM] : Endif
If clalev([F:CNT])=0 : Local File CONTACT   [CNT] : Endif

If clalev([F:YBAN])=0 : Local File BANK      [YBAN] : Endif #[Y0030]

STA = 0
Read [PYH]PYH1(2) = 1;NUMERO
If fstat : STA = 1 : Goto FINFIC : Endif
If [F:PYH]TFBFIL<>""
 If instr(1,"0123456789",mid$([F:PYH]TFBFIL,2,1))
  NUM=val(mid$([F:PYH]TFBFIL,2,5))
 Else
  NUM=val(mid$([F:PYH]TFBFIL,3,5))
 Endif
Endif

If TYPFIC=1 | TYPFIC=3 : # Check TYPFIC = 3
 SYMBOLE = "FRM"+NUMERO+"\1"
 Lock =SYMBOLE
 If fstat=1 : STA = 6 : Goto FINFIC : Endif
Endif

Call LEC_CPY([F:PYH]CPY) From CPTLEC
Call SETMAINREF([F:PYH]CPY,GTYPGEN,GTYPANA) From CPTDIV
Call SETCUR(1,[F:PYH]CPY,DEVLED) From CPTDIV
Call LECPLAN([F:PYH]CPY,GTYPGEN,PLAN) From CPTDIV
Call LEC_TPY_LEG([F:CPY]LEG,[F:PYH]PAYTYP) From CPTLEC
VLEG = [F:CPY]LEG

GSOCIETE = [F:PYH]CPY
If (GACTION="FICMAG") | (GACTION="FICMAG1" & CODE="")
 # Check FILREF8
 If [F:TPY]FILREF6<>"" & [F:TPY]FILREF8="" & [F:TPY]FILREF71=""
  CODE = [F:TPY]FILREF6
  TYPFIC = 1
 Elsif [F:TPY]FILREF6="" & [F:TPY]FILREF8<>"" & [F:TPY]FILREF71=""
  CODE = [F:TPY]FILREF8
  TYPFIC = 3
 Elsif [F:TPY]FILREF6="" & [F:TPY]FILREF8="" & [F:TPY]FILREF71<>""
  CODE = [F:TPY]FILREF71
  TYPFIC = 2
 Elsif [F:TPY]FILREF6="" & [F:TPY]FILREF8="" & [F:TPY]FILREF71=""
  STA = 11 : Goto FINFIC
 Elsif ([F:TPY]FILREF6<>"" & [F:TPY]FILREF71<>"") | ([F:TPY]FILREF6<>"" & [F:TPY]FILREF8<>"") | ([F:TPY]FILREF8<>"" & [F:TPY]FILREF71<>"")
  STA = 12 : Goto FINFIC
 Endif
Endif
# Check EPACDTTRF
If CODE="" | ([F:TPY]STA6<>2 and [F:TPY]EPACDTTRF<>2): STA = 2 : Goto FINFIC : Endif

If clalev([M:DIA])>0
 If [M:DIA]VOLFIL<>"" and right$([M:DIA]VOLFIL, len([M:DIA]VOLFIL))<>"/" : [M:DIA]VOLFIL+="/" : Endif
 If [M:DIA]FILDIRLOC<>"" and find(right$([M:DIA]FILDIRLOC, len([M:DIA]FILDIRLOC)), "/", "\")=0
  Call GET_OS(adxmac(-1), OS) From ORDSYS
  If OS="unix"
   [M:DIA]FILDIRLOC += "/"
  Else
   [M:DIA]FILDIRLOC += "\"
  Endif
 Endif
 DIR_FICBAN = [M:DIA]FILDIRLOC
 VOLPATH = [M:DIA]VOLFIL
Else
 DIR_FICBAN = "["+GDIRBQE+"]/"
 VOLPATH = "["+GDIRBQE+"]/"
 Gosub ENUM_VOLFIL_TYPE From ASYRSTO
 If func ASYRSTO.CTL_VOLFIL(2,DIR_FICBAN,DIR_FICBAN,E_TYPE_FOLDER,GMESSAGE)>0
  STA = 4 : Goto FINFIC
 Endif
Endif

BANQUE = [F:PYH]BAN
Call LEC_BAN(BANQUE) From CPTLEC
DEVBAN = [F:BAN]CUR
Call LEC_TCY([F:BAN]CRY) From CPTLEC
CODLAN = [F:TCY]LAN

If [F:BAN]BIDNUM=""
 STA=13 : Goto FINFIC
Endif

If TYPFIC=1 | TYPFIC=3 : # Check TYPFIC = 3
 GLOCALDEV = DEVLED

 Read [TFB]TFB0(5) = CODE;BANQUE;1;0;VLEG
 If fstat
  Read [TFB]TFB0(5) = CODE;BANQUE;1;0;""
  If fstat
   Read [TFB]TFB0(5) = CODE;"";1;0;VLEG
   If fstat
    Read [TFB]TFB0(5) = CODE;"";1;0;""
    If fstat : Raz [F:TFB] : Endif
   Endif
  Endif
 Endif

 Local Char VARFILGEN(1)
 If [F:TFB]FMT=2
  Call PARAMUTIL("VARFILGEN", VARFILGEN, GUSER, "") From SUBAUS
 Endif

 If [F:TFB]CURMULT<>2 or [F:TPY]DACBID=1 : # Fichier banque mono-devise ou RIB inexistant
  For [PYH]PYH1 Where FRMFLG=1 & FRMNUM=NUMERO
   If [F:TFB]CURMULT<>[V]CST_AYES # 2
    If FLEURO=""
     GLOCALDEV = [F:PYH]CUR
     Case [F:PYH]CUR
      When GEURO   : IEURO=1 : FLEURO="E"
      When "FRF"   : IEURO=2 : FLEURO="F"
      When "ITL"   : IEURO=2 : FLEURO="I"
      When "ESP"   : IEURO=2 : FLEURO="S"
      When Default : IEURO=2 : FLEURO=" "
     Endcase
    Elsif (IEURO=1 & [F:PYH]CUR<>GEURO)
     STA=9 : Break
    Elsif (IEURO=2 & [F:PYH]CUR<>GLOCALDEV)
     STA=10 : Break
    Endif
     ###### X3-29247 MultiCur #######
    If [F:TFB]CURCTL = 2  # Autorised & set
      If !find([F:PYH]CUR,[F:TFB]CUR)
          STA=18
       Endif
    Endif
   Else #CURMULT =  [V]CST_AYES
    Case [F:TFB]CURCTL
      When 2 :# Autorised
        If !find([F:PYH]CUR,[F:TFB]CUR)
          STA=18
        Endif
      When 3 :#Prohibited
        If find([F:PYH]CUR,[F:TFB]CUR)
          STA=18
        Endif
    Endcase
   Endif
    ### END OF X3-29247 MultiCur ###
   If [F:TPY]DACBID=1 & [F:PYH]BID=""
    STA=8 : Break
   Endif
  Next: # [PYH]
  If STA : Goto FINFIC : Endif
 Endif
 Call LEC_TCU(DEVBAN) From CPTLEC
 DECIM = 10^[F:TCU]DECNBR
Endif

If TYPFIC=3 or TYPFIC=1
 If clalev([F:BPAD])=0 : Local File BPADDRESS [BPAD] : Endif
 Filter [F:BPAD] Where BPATYP=2 & BPANUM=[F:PYH]CPY & BPAADDFLG=G_OUI
 Read [F:BPAD] First
 Filter [BPAD]
Endif

EXT = [F:BAN]FILEXT
If EXT=""
 If len([F:BAN]BAN)>3
  STA=15 : Goto FINFIC
 Else
  EXT = [F:BAN]BAN
 Endif
Endif

If NUM=0
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK<1 : STA = 3 : Goto FINFIC : Endif
Endif

Case TYPFIC
 When 1, 3: # Check TYPFIC = 3
  NOM = [F:TFB]FILREF
  If NOM="" : NOM = left$([F:TFB]COD,2) : Endif
  NOM += format$("N0:5#",NUM)
 When 2
  Read [EDP]EDP0 = CODE;BANQUE;0;1
  If fstat
   Read [EDP]EDP0 = CODE;"";0;1
   If fstat : Raz [F:EDP] : Endif
  Endif
  NOM = [F:EDP]FILREF
  If NOM="" : NOM = left$([F:EDP]MES,2) : Endif
  NOM += format$("N0:5#",NUM)
Endcase

# Entry point to give a name to the file
GPOINT = "NOMFIC" : Gosub ENTREE From EXEFNC

DIR_FICBAN_OLD = DIR_FICBAN

If DIR_FICBAN<>"" and right$(DIR_FICBAN, len(DIR_FICBAN))<>"/"
 DIR_FICBAN += "/"
Endif
If [F:TFB]FILEXO<>""
 DIR_FICBAN += NOM+EXT+"."+[F:TFB]FILEXO
 VOLPATH = VOLPATH+NOM+EXT+"."+[F:TFB]FILEXO
Else
 DIR_FICBAN += NOM+"."+EXT
 VOLPATH = VOLPATH+NOM+"."+EXT
Endif
FICHIER = DIR_FICBAN

# Client
FICDON = FICHIER
If GACTION="FICMAG1" & clalev([M:DIA])>0 & [M:DIA]TYPFIL=1 : # Client
 Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
Endif

# Take back the execution date of the remittance
Read [FRM]FRM0 = 1;NUMERO
If fstat : STA = 1 : Goto FINFIC : Endif
Call LEC_FCY([F:FRM]FRMFCY) From CPTLEC

If TYPFIC=2
 Raz GMESSAGE
 Call FICHIER_EDI(CODE,1,NUMERO,FICDON,NOM,EXT) From FICMAGEDI
 If GOK<>1
  STA = -1
   If [F:PYH]TFBFIL<>"" & filinfo(FICHIER,0)>=0 &
& ( ([F:TFB]FILEXO<>"" & [F:PYH]TFBFIL<> NOM+EXT+"."+[F:TFB]FILEXO) | ([F:TFB]FILEXO="" & [F:PYH]TFBFIL<>NOM+"."+EXT) )
   Call EFFACE(FICHIER,I) From ORDSYS
  Endif
 Endif
 # Client
 If GACTION="FICMAG1" & clalev([M:DIA])>0 & [M:DIA]TYPFIL=1
  Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
  If STAT=1
   # Fichier non copié sur le poste client
   STA = -1 : Call ERREUR(mess(164,141,1)) From GESECRAN
  Elsif STAT>1
   # Fichier inexistant
   STA = -1  : Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  Endif
 Endif
 Gosub VIREFIC : End
Endif

Gosub VIREFIC

Openo FICDON,0 Using [FIC]
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = ""
adxium = GASCII
[L]DATJ = datesyst

# Header
NUMREC = 1
NBLIG=0 : NUMRIBA=0    # RIBA Italie
Read [BPA]BPA0 = 2;[F:CPY]CPY;[F:CPY]BPAADD
If fstat
 Read [BPA]BPA0(2) = 2;[F:CPY]CPY
 If fstat : Raz [F:BPA] : Endif
Endif
# Montant Total des réglements doit être donné en en-tête.
# Pour le format variable
If  TYPFIC=3 | TYPFIC=1
 Call LEC_TCU([F:PYH]CUR) From CPTLEC
 Call LEC_TAM(GCURLEG, [F:PYH]PAM) From CPTLEC
 DECIM = 10^[F:TCU]DECNBR
 For [PYH]PYH1 Where FRMNUM=NUMERO & FRMFLG=1
  NBPYH +=1
  AMTCUR = [F:PYH]AMTCUR
  [L]TOTCUR += AMTCUR
 Next
Endif

# X3-44228
If func AFNC.ACTIV("KSW")>0  : # Swiss activity code
 Local Date CHKDAT : CHKDAT = [0/0/0]
 If [F:TPY]SWIPAYTYP = 4 : # Swiss payment type ISO
  [L]CHKDAT = [F:FRM]EXEDAT
  If [L]CHKDAT = [0/0/0]
    [L]CHKDAT = [F:PYH]DUDDAT : # If [F:FRM]EXEDAT empty, DUDDAT of the first payment of the remittance is taken
  Endif
  If [L]CHKDAT = [0/0/0]
    STA = 20 :  Goto FINFIC
  Else
    # The execution date may be less than 10 days in the past or 60 days in the future!
    If not ( ([L]CHKDAT-date$)>= -10 and ([L]CHKDAT-date$)<= 60 )
      STA = 19 :  Goto FINFIC
    Endif
  Endif
 Endif
Endif

TYP = 1 : Gosub ENREG
# Error in SEPA sequence number
If STA = 14 : Goto FINFIC : Endif

# Detail
Raz TOTBAN, TOTCUR, TOTCPY
Raz TOTBIDNUM1, TOTBIDNUM2
Raz TOTAL, LINEAS

#For [PYH]PYH1 Where FRMNUM=NUMERO & FRMFLG=1
Filter [PYH] Where FRMNUM=NUMERO & FRMFLG=1 Order By DUDDAT
For [PYH]
#[Y0030]
 Read [F:YBAN]BAN0=[F:PYH]BAN #OMM
 If LFECHANT<>[PYH]DUDDAT
  CUENTALINEASXFECHA=1
  LSQL = "SELECT COUNT(*) FROM PAYMENTH WHERE FRMNUM_0='"+NUMERO+"' AND FRMFLG_0=1 AND DUDDAT_0='"+format$("YYYYMMDD",[F:PYH]DUDDAT)+"'"
  For (Integer NUM) From num$([V]GTYPDBA*2+1) Sql LSQL As [XXX]
    LINEASXFECHA=[F:XXX]NUM
  Next
  Raz TOTFECHA
  LSQL = "SELECT SUM(AMTCUR_0) FROM PAYMENTH WHERE FRMNUM_0='"+NUMERO+"' AND FRMFLG_0=1 AND DUDDAT_0='"+format$("YYYYMMDD",[F:PYH]DUDDAT)+"'"
  For (Decimal TOT) From num$([V]GTYPDBA*2+1) Sql LSQL As [XXX]
    TOTFECHA=[F:XXX]TOT
  Next
 Endif
#[Y0030]
 TOTAL+=1 #################################### CONFIRMING SPA
 Call LEC_BPR([F:PYH]BPR) From CPTLEC
 If [F:PYH]BPR<>""
  If [F:PYH]SNS=1   # Dépense/Fournisseur
   Call LEC_BPS([F:PYH]BPR) From CPTLEC
   Read [BPA]BPA0 = 1;[F:BPS]BPSNUM;[F:PYH]BPAINV
   If fstat
    Read [BPA]BPA0 = 1;[F:BPS]BPSNUM;[F:BPS]BPAADD
    If fstat
     Read [BPA]BPA0(2) = 1;[F:BPS]BPSNUM
     If fstat : Raz [F:BPA] : Endif
    Endif
   Endif
   NOMTIRE = [F:BPS]BPSNAM
   If [F:CNT]BPATYP<>1 or [F:CNT]BPANUM<>[F:BPS]BPSNUM or [F:CNT]CCNCRM<>[F:BPS]CNTNAM
    Read [CNT]CNT0=1;[F:BPS]BPSNUM;[F:BPS]CNTNAM
    If fstat : Raz [F:CNT] : Endif
   Endif
  Else              # Recette/Client
   Call LEC_BPC([F:PYH]BPR) From CPTLEC
   Read [BPA]BPA0 = 1;[F:BPC]BPCNUM;[F:PYH]BPAINV
   If fstat
    Read [BPA]BPA0 = 1;[F:BPC]BPCNUM;[F:BPC]BPAADD
    If fstat
     Read [BPA]BPA0(2) = 1;[F:BPC]BPCNUM
     If fstat : Raz [F:BPA] : Endif
    Endif
   Endif
   NOMTIRE = [F:BPC]BPCNAM
   If [F:CNT]BPATYP<>1 or [F:CNT]BPANUM<>[F:BPC]BPCNUM or [F:CNT]CCNCRM<>[F:BPC]CNTNAM
    Read [CNT]CNT0=1;[F:BPC]BPCNUM;[F:BPC]CNTNAM
    If fstat : Raz [F:CNT] : Endif
   Endif
  Endif
  If [F:BPA]BPANUM=""
   Call LEC_BPR([F:PYH]BPR) From CPTLEC
   Read [BPA]BPA0 = 1;[F:BPR]BPRNUM;[F:PYH]BPAINV
   If fstat
    Read [BPA]BPA0 = 1;[F:BPR]BPRNUM;[F:BPR]BPAADD
    If fstat
     Read [BPA]BPA0(2) = 1;[F:BPR]BPRNUM
     If fstat : Raz [F:BPA] : Endif
    Endif
   Endif
   NOMTIRE = [F:BPR]BPRNAM
  Endif
 Else
  Raz [F:CNT]
  Call LEC_GAC([F:PYH]ACC,PLAN) From CPTLEC
  Read [BPA]BPA0 = 5;[F:GAC]COA+[F:GAC]ACC;[F:PYH]BPAINV
  If fstat
   Read [BPA]BPA0 = 5;[F:GAC]COA+[F:GAC]ACC;[F:GAC]BPAADD
   If fstat
    Read [BPA]BPA0(2) = 5;[F:GAC]COA+[F:GAC]ACC
    If fstat : Raz [F:BPA] : Endif
   Endif
  Endif
  Call LECTEXTRA([L]NOMTIRE,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 Endif

 ## <Germany>
 If [F:PYH]BIDCRY="DE"
  TOTBIDNUM1 += val(mid$([F:PYH]BID,1,8))
  TOTBIDNUM2 += val(mid$([F:PYH]BID,9,10))
 Endif
 ## <End Germany>

 Call LEC_FCY([F:PYH]FCY) From CPTLEC
 Call LEC_TAM(GCURLEG, [F:PYH]PAM) From CPTLEC
 Call LEC_TCU([F:PYH]CUR) From CPTLEC
 DECIM = 10^[F:TCU]DECNBR
 AMTCUR = [F:PYH]AMTCUR
 AMTVIR = arr(DECIM*AMTCUR,1)
 If [F:PYH]AMTBAN<>0
  AMTBAN = [F:PYH]AMTBAN
 Else
  Call CONVERT([F:PYH]CUR,DEVBAN,DEVLED,[F:TPY]RATTYP
&   ,[L]DATJ,AMTCUR,AMTBAN,STAT) From TRTDEV
 Endif
 Call CONVERT([F:PYH]CUR,DEVLED,DEVLED,[F:TPY]RATTYP
&  ,[L]DATJ,AMTCUR,AMTCPY,STAT) From TRTDEV
 TOTCUR += AMTCUR
 TOTBAN += AMTBAN
 TOTCPY += AMTCPY
 TOTVIR += AMTVIR
 ## Localisation espagnole : memo des factures réglées
 ## <ALLEMAGNE> + localisation allemande où on a besoin de communiquer dans le fichier bancaire généré
 ## les échéances règlées (numéros factures chez le fournisseur contenues dans [F:PIH]BPRVCR et la variable
 ## TREF) et également le code de notre société chez le fournisseur (variable TCODSOC ou champ à rajouter
 ## dans BPSUPPLIER ??? A voir...)
 NBFAC=0 : Raz TFAC, TTYP, TDAT, TREF, TIMPORTE, TTIP, TSNS

 FLGLOA = 1
 GPOINT = "BEFLOAD" : Gosub ENTREE From EXEFNC
 If FLGLOA=1
  For [PYD]PYD0 Where NUM=[F:PYH]NUM
   LINEAS+=1 #################################### CONFIRMING SPA
   If [F:PYD]VCRNUM<>"" & !find([F:PYD]VCRNUM, TFAC(0..NBFAC-1))
    Look [SIH]SIH2 = [F:PYD]VCRTYP;[F:PYD]VCRNUM
    If fstat
     Look [PIH]PIH2 = [F:PYD]VCRTYP;[F:PYD]VCRNUM
     If fstat
      Look [HAE]HAE0 = [F:PYD]VCRTYP;[F:PYD]VCRNUM
     Endif
    Endif
    If !fstat
     TFAC(NBFAC) = [F:PYD]VCRNUM
      TTIP(NBFAC) = [F:PYD]VCRTYP ####################### CONFIRMING SPA
     ##########XXX:NORMA 68###################
     Gosub DATOSFACTURA
     ##########XXX:NORMA 68###################
     If NBFAC=0 : TTYP = [F:PYD]VCRTYP : Endif
     NBFAC+=1
     If NBFAC>XNBECH-1 : Break : Endif
    Endif
   Endif
  Next
 Endif
 # To access to the Invoice
 If TFAC(0)<>""
  Read [PIH]PIH2 = TTYP;TFAC(0)
  If fstat
   Raz [F:PIH]
   Read [SIH]SIH2 = TTYP;TFAC(0)
   If fstat : Raz [F:SIH] : Endif
  Endif
 Endif
 # Read PYD to take back the entry number
 Read [PYD]PYD0 = [F:PYH]NUM;1 : If fstat : Raz [F:PYD] : Endif
 Read [TCY]TCY0 = [F:CPY]CRY : If fstat : Raz [F:TCY] : Endif
 NUMRIBA += 1

 # To access to the Mandate associated to the payment.
 If filinfo(filpath("FIL","MANDATE","fde",nomap),0)>0
  Read [MDT]MDT0 = [F:PYH]CPY ; [F:PYH]UMRNUM
  If fstat : Raz [F:MDT] : Endif
 Endif

 TYP = 2   # Line

 If [F:PYH]BPR<>""
  Read [BID]BID0 = 1 ; [F:PYH]BPR ; [F:PYH]BID : If fstat : Raz [BID] : Endif
 Else
  Read [BID]BID0 = 5 ; [F:PYH]COA+[F:PYH]ACC ; [F:PYH]BID : If fstat : Raz [BID] : Endif
 Endif
 GPOINT = "AV_LIGNE" : Gosub ENTREE From EXEFNC

 Gosub ENREG

 CUENTALINEASXFECHA=CUENTALINEASXFECHA+1 #[Y0030]
 LFECHANT=[F:PYH]DUDDAT #[Y0030]
Next
Filter [PYH]
# Total
Call LEC_TCU(DEVBAN) From CPTLEC
DECIM = 10^[F:TCU]DECNBR
NUMREC += 1
TYP = 3 : Gosub ENREG

Openo Using [FIC]
If VARFILGEN="2" & STA=16
 Call EFFACE(FICDON, STAT) From ORDSYS
 Goto FINFIC
Endif
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
GPOINT = "FIN" : Gosub ENTREE From EXEFNC

Call DEBTRANS From GLOCK
Gosub TR2
If GOK<1 : STA = 5 : Goto FINFIC : Endif

# Masque DIA (Masque de génération en masse - Action FICMAG - ou Masque du choix du répertoire de saisie de remise - Action FICMAG1)
# Dans le cas de Saisie de Remise - Action FICMAG1 - l'écran du choix du répertoire ne s'ouvre pas
# lorsque la transaction de règlement a comme paramètrage "Famille fichier bancaire" à "Aucune"
If GACTION="FICMAG1" & clalev([M:DIA])>0 & [M:DIA]TYPFIL=1
 Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  STA=-1 : Call ERREUR(mess(164,141,1)) From GESECRAN
 Elsif STAT>1
  # Fichier inexistant
  STA=-1 : Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
 Endif
Endif
DIR_FICBAN=FICHIER

$FINFIC
Case STA
 When 0  : MESSA = "|"+VOLPATH+"|"
 When 1  : MESSA = mess(102,117,1)                   : # Remise inexistante
 When 2  : MESSA = mess(103,117,1)                   : # Pas de remise à faire
 When 3  : MESSA = mess(104,117,1)-"NUMFIL"          : # Erreur sur compteur
 When 4  : MESSA = "|"+DIR_FICBAN-"|:"-mess(9,141,1) : # Répertoire inexistant
 When 5  : MESSA = mess(35,110,1)                    : # Erreur transactionnelle
 When 6  : MESSA = mess(10,100,1)                    : # Modification en cours sur un autre poste
 When 8  : MESSA = mess(27,199,1)                    : # RIB inexistant
 When 9  : MESSA = mess(52,121,1)-GEURO              : # Remise non en devise"
 When 10 : MESSA = mess(52,121,1)-GLOCALDEV          : # Remise non en devise"
 When 11 : MESSA = mess(133,121,1)-"-"-mess(134,121,1)
 # Aucun format de fichier bancaire paramétré - Remise en banque manuelle
 When 12 : MESSA = mess(135,121,1)-"-"-mess(134,121,1)
 # 2 formats de fichiers paramétrés - Remise en banque manuelle
 When 13 : MESSA = [F:BAN]BAN-mess(154,121,1)
 # Coordonnées bancaires inexistantes, génération du fichier impossible
 When 14 : MESSA = GMESSAGE           : # Erreur sur compteur SEPA
 When 15 : MESSA = func AFNC.MES1(mess(262,117,1), [F:BAN]BAN)
 When 16 : MESSA = mess(324,117,1)
 When 18 : MESSA = mess(27,173,1)  : # X3-29247 CH FROM GESTFB - Devise Incompatible
 When 19 : MESSA = mess(25,3648,1) : # X3-44228
 When 20 : MESSA = mess(27,3648,1) : # X3-44228

Endcase
If SYMBOLE<>""
 Unlock =SYMBOLE
Endif
End

##########################################################################
$VIREFIC
##########################################################################
If GACTION="FICMAG1" & clalev([M:DIA])>0 & [M:DIA]TYPFIL=1 : Return : Endif
If [F:PYH]TFBFIL<>"" & (([F:TFB]FILEXO<>"" & [F:PYH]TFBFIL<>NOM+EXT+"."+[F:TFB]FILEXO) | ([F:TFB]FILEXO="" & [F:PYH]TFBFIL<>NOM+"."+EXT))
 Call GET_OS(adxmac(-1), OS) From ORDSYS
 If OS="unix"
  DIR_FICBAN_OLD += "/"+[F:PYH]TFBFIL
 Else
  DIR_FICBAN_OLD += "\"+[F:PYH]TFBFIL
 Endif
 If filinfo(DIR_FICBAN_OLD,0)>=0
  Call EFFACE(DIR_FICBAN_OLD,I) From ORDSYS
 Endif
Endif
Return

##########################################################################
Subprog CRE_IBAN(CRY,NUMBER,IBACOD)
Value    Char CRY()
Value    Char NUMBER()
Variable Char IBACOD()
Local Char CNUMBERI(34), CI(2), CNUMBERO(50)
Local Integer D, I
Local Decimal INUMBER
CNUMBERI = NUMBER+CRY+"00"
For I=1 To len(CNUMBERI)
 CI=mid$(CNUMBERI,I,1)
 If CI>"9"
  CI=num$(ascii(CI)-55)
 Endif
 CNUMBERO += CI
Next I
INUMBER = val(CNUMBERO)
D = 98-mod(INUMBER,97)
IBACOD = CRY+format$("##",D)+NUMBER
End


##########################################################################
$TR1
##########################################################################
GOK = 1
Trbegin [BAN]
 Lock NUMFIL
 If fstat
  GOK = -1 : GLOCK = "%NUMFIL" : Goto ROLL_TR1
 Endif
 [C]NUMFIL += 1
 If fstat=0 & [C]NUMFIL>=100000
  [C]NUMFIL = 1
 Endif
 If fstat=1
  GOK = -1 : GLOCK = "@NUMFIL" : Goto ROLL_TR1
 Elsif fstat
  GOK = 0 : Call RSTA("@NUMFIL","") From GLOCK : Goto AB_TR1
 Endif
 NUM = [C]NUMFIL
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

##########################################################################
$TR2
##########################################################################
GOK = 1
Trbegin [PYH],[FRM]

 For [PYH]PYH1 Where FRMFLG=1 & FRMNUM=[L]NUMERO With Lock
  If fstat=1
   GOK = -1 : GLOCK = "$PAYMENTH"-"1"-[L]NUMERO : Break
  Endif
  [F:PYH]STA=max([F:PYH]STA,6) : [F:PYH]STAFLG(5)=2
  If [F:TFB]FILEXO<>""
   [F:PYH]TFBFIL = NOM+EXT+"."+[F:TFB]FILEXO
  Else
   [F:PYH]TFBFIL = NOM+"."+EXT
  Endif
  [F:PYH]TFBDAT=[L]DATJ
  Rewrite [PYH]
  If fstat=1
   GOK = -1 : GLOCK = "$PAYMENTH"-"1"-[L]NUMERO : Break
  Elsif fstat
   GOK = 0 : Call RSTA("PYH","1"-[L]NUMERO) From GLOCK : Break
  Endif
 Next : # [PYH]
 If GOK<0    : Goto ROLL_TR2
 Elsif GOK=0 : Goto AB_TR2
 Endif

 Readlock [FRM]FRM0 =1;[L]NUMERO
 If fstat=1
  GOK=-1 : GLOCK="$PAYFRM"-"1"-[F:PYH]FRMNUM : Goto ROLL_TR2
 Endif
 [F:FRM]STA=max([F:FRM]STA,6)
 If [F:TFB]FILEXO<>""
  [F:FRM]TFBFIL = NOM+EXT+"."+[F:TFB]FILEXO
 Else
  [F:FRM]TFBFIL = NOM+"."+EXT
 Endif
 [F:FRM]TFBDAT=[L]DATJ
 Rewrite [FRM]
 If fstat
  GOK = 0 : Call FSTA("FRM") From GLOCK : Goto AB_TR2
 Endif

Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

##########################################################################
$ENREG
##########################################################################

Filter [TFB] Where COD=CODE & BAN=BANQUE & RECTYP=TYP & LEG=VLEG
If rowcount([TFB]) <= 0
 Filter [TFB] Where COD=CODE & BAN=BANQUE & RECTYP=TYP & LEG=""
 If rowcount([TFB]) <= 0
  Filter [TFB] Where COD=CODE & BAN="" & RECTYP=TYP & LEG=VLEG
  If rowcount([TFB]) <= 0
   Filter [TFB] Where COD=CODE & BAN="" & RECTYP=TYP & LEG=""
   If rowcount([TFB]) <= 0
    Raz [TFB]
   Else
    [L]BANCUR=""
    [L]LEGCUR=""
   Endif
  Else
   [L]BANCUR=""
   [L]LEGCUR=VLEG
  Endif
 Else
  [L]BANCUR=BANQUE
  [L]LEGCUR=""
 Endif
Else
[L]BANCUR=BANQUE
[L]LEGCUR=VLEG
Endif
Filter [TFB]

GPOINT= "OPENFILE"  : Gosub ENTREE From EXEFNC

# If the format of file is variable
If [F:TFB]FMT=2
 Gosub ENREGVAR
 Return
Endif

Local Integer S_ORDNUM, CARRET
S_ORDNUM=-1 : CARRET=G_NON

For [TFB]TFB0(4) Where COD=CODE & BAN=[L]BANCUR & RECTYP=TYP & LEG=[L]LEGCUR
 NBLIG+=1 : CONDOK=1
 If [F:TFB]FORCND<>""
   CONDOK = evalue([F:TFB]FORCND)
 Endif
 If CONDOK
  If TYP=2 : NUMREC+=1 : Endif
  CARRET=G_NON
  For [TFB]TFB0
   # Ajout retour chariot à la fin de la ligne
   If TYPFIC=3 and S_ORDNUM<>[F:TFB]ORDNUM
     If S_ORDNUM>=0
       CARRET=G_OUI
       RESULT = chr$(10)
       Wrseq RESULT Using [FIC]
     Endif
     S_ORDNUM=[F:TFB]ORDNUM
   Endif
   RESULT = ""
   If [F:TFB]FRM<>""
    Onerrgo ERREUR
    ER = 0
    Case [F:TFB]FLDTYP
     When 3,4,5,6,7 : # Dates pour l'avoir sous forme AAAAMMJJ
      RESULT = evalue([F:TFB]FRM)
      If RESULT="000000" : RESULT="00000000" : Endif
     When Default
      RESULT = num$(evalue([F:TFB]FRM))
    Endcase
    Onerrgo
   Endif
   LONG = [F:TFB]LNG
   Case [F:TFB]FLDTYP
    When 1 : # Chaîne cadrée à gauche
     ## La variable CODLAN est initialisée plus haut à la langue associée au code pays de la banque
     If CODLAN = "" : CODLAN = GLANGUE : Endif
     RESULT = func AFNC.TRANS(left$(RESULT+space$(LONG),LONG),CODLAN)
    When 2 : # Numérique cadré à gauche
     RESULT = right$(string$(LONG,"0")+RESULT,len(RESULT)+1)
    When 3 : # Date JJMMAA
     RESULT = mid$(RESULT,7,2)+mid$(RESULT,5,2)+mid$(RESULT,3,2)
    When 4 : # Date AAMMJJ
     RESULT = right$(RESULT,3)
    When 5 : # Année
     Case LONG
      When 1 : RESULT = mid$(RESULT,4,1)
      When 2 : RESULT = mid$(RESULT,3,2)
      When 4 : RESULT = mid$(RESULT,1,4)
     Endcase
    When 6 : # Mois
     RESULT = mid$(RESULT,5,2)
    When 7 : # Jour
     RESULT = mid$(RESULT,7,2)
    When 8 : # Séquence spéciale (binaire)
    When 9 : # Montant centimes
     RESULT = num$(arr(DECIM*val(RESULT),1))
     RESULT = right$(string$(LONG,"0")+RESULT,len(RESULT)+1)
   Endcase
   RESULT = left$(RESULT+space$(LONG),LONG)
   GPOINT= "UPDFORD"  : Gosub ENTREE From EXEFNC
   Wrseq RESULT Using [FIC]
  Next
 Endif   # CONDOK
Next
# Ajout retour chariot à la fin de la ligne
If TYPFIC=3
 RESULT = chr$(10)
 Wrseq RESULT Using [FIC]
Endif
Return

##########################################################################
## Variable format for the generation of the file
##########################################################################
$ENREGVAR
For [TFB]TFB0(4) Where COD=CODE & BAN=[L]BANCUR & RECTYP=TYP & LEG=[L]LEGCUR
 NBLIG+=1 : CONDOK=1
 If [F:TFB]FORCND<>""
  CONDOK = evalue([F:TFB]FORCND)
 Endif
 If CONDOK
  # Gestion du compteur nécessaire au paramétrage (to fill in MSGID)
  If TYP=1
   FILCOU = ""
   Call LECTCA(3,OKTCA) From SUBTCA
   If OKTCA
    If TYPFIC=3
     FILCOU = [F:TCA]CODNUM(12)
     If FILCOU = "" : FILCOU="SEPA" : Endif
     Call NUMERO(FILCOU, [F:PYH]FCY, date$, "", [L]MSGID, STAT) From SUBANM
    Else
     FILCOU = [F:TCA]CODNUM(18)
     If FILCOU = "" : FILCOU="VARFB" : Endif
     Call NUMERO(FILCOU, [F:PYH]FCY, date$, [F:TFB]FILREF, [L]MSGID, STAT) From SUBANM
    Endif
   Endif
   If STAT
   # Problème lors de la récupération du compteur
    Gosub MESSAGE From SUBANM
    GMESSAGE = mess(60,199,1)-"("+FILCOU+") : "+MESSA
    STA=14
    Break
   Endif
  Endif

  NBLIG2 = 0 # Line number in the TFB file
  For [TFB]TFB0
   RESULT = ""
   NBLIG2 +=1
   # Return the formula according to its type
   If [F:TFB]FRM<>""
    Onerrgo ERREUR
    ER = 0
    Case [F:TFB]FLDTYP
     When 3,4,5,6,7 : # Dates pour l'avoir sous forme AAAAMMJJ
      RESULT = evalue([F:TFB]FRM)
      If RESULT="000000" : RESULT="00000000" : Endif
     When Default
      RESULT = num$(evalue([F:TFB]FRM))
     Endcase
    Onerrgo
   Endif
   # Ajustement à la longueur variable
   LONG = [F:TFB]LNG
   Case [F:TFB]FLDTYP
    When 1 : # left-aligned string
     RESULT= func REPLCAR(RESULT)
     If find([F:TFB]NATPAY, 5, 6) : RESULT = func STRIPSLASHES(RESULT) : Endif
     RESULT = left$(RESULT,LONG)
    When 2 : # Numérique (rien à faire pour le cadrage)
    When 3 : # Date DDMMYY
     RESULT = mid$(RESULT,7,2)+mid$(RESULT,5,2)+mid$(RESULT,3,2)
    When 4 : # Date YYMMDD
     RESULT = right$(RESULT,3)
    When 5 : # year
     Case LONG
      When 1 : RESULT = mid$(RESULT,4,1)
      When 2 : RESULT = mid$(RESULT,3,2)
      When 4 : RESULT = mid$(RESULT,1,4)
     Endcase
    When 6 : # month
     RESULT = mid$(RESULT,5,2)
    When 7 : # day
     RESULT = mid$(RESULT,7,2)
    When 8 : # Séquence spéciale (binaire)
    When 9 : # Montant centimes
     RESULT = num$(arr(DECIM*val(RESULT),1))
   Endcase
   GPOINT= "UPDFORD"  : Gosub ENTREE From EXEFNC
   # If the result of the formula is empty and the field is mandatory in the corresponding TFB file, then warn
   # the user in the trace file.
   If ([F:TFB]CND="" & ([F:TFB]FRM="" or RESULT<>"")) or [F:TFB]CND<>"" & evalue([F:TFB]CND)
    If instr(1, [F:TFB]STRSEP, "$1$")
     # X3-29239
     # the opening tag contains $1$ => replace $1$ with the evaluated formula
     #Wrseq func AFNC.MES1([F:TFB]STRSEP, RESULT) + [F:TFB]ENDSEP + chr$(10) Using [FIC]
     #JOJAC - 2018-09-21 - X3-104634 - START
     If instr(1, [F:TFB]FRM, "SET_PARAM_VALUE") | instr(1, [F:TFB]FRM, "SET_CURAMT_VALUE")
     #If instr(1, [F:TFB]FRM, "SET_PARAM_VALUE")
     #JOJAC - 2018-09-21 - X3-104634 - END
       Local Char    S(1) : S=left$(RESULT,1)
       Local Integer S2, S3
       S2=instr(2,RESULT,S)
       S3=instr(S2+1,RESULT,S)
       RES1 = seg$(RESULT,2,S2-1)
       RES2 = seg$(RESULT,S2+1,S3-1)
       Wrseq func AFNC.MES1([F:TFB]STRSEP, RES1) + RES2 +[F:TFB]ENDSEP + chr$(10) Using [FIC]
     Else
      # the opening tag contains $1$ => replace $1$ with the evaluated formula
      Wrseq func AFNC.MES1([F:TFB]STRSEP, RESULT) + [F:TFB]ENDSEP + chr$(10) Using [FIC]
     Endif
    Else
     # append the evaluated formula to the opening tag
     Wrseq [F:TFB]STRSEP + RESULT + [F:TFB]ENDSEP + chr$(10) Using [FIC]
    Endif
   Elsif [F:TFB]FRM<>"" & RESULT="" & [F:TFB]OBY = 2
    If TYP=2  # Detail
     Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":",0) From GESECRAN
    Endif
    Call ECR_TRACE(mess(155,117,1)-[F:TFB]COD-mess(10,123,1)-mess(TYP,656,1)-mess(61,100,1)-num$(NBLIG2)-":"-[F:TFB]FRM,1) From GESECRAN
    Wrseq [F:TFB]STRSEP + RESULT + [F:TFB]ENDSEP + chr$(10) Using[FIC]
    If [F:TFB]FMT=2 & VARFILGEN="2"
     STA=16
    Endif
   Endif
  Next # For TFB0
 Endif # CONDOK
Next # For TFB4
Return

## For the debug
$ERREUR
Call ECR_TRACE([F:TFB]FRM-":"-errm-":"-errmes$(errn)-"("+mess(19,123,1)-errp-mess(17,104,1)-num$(errl)+")",1) From GESECRAN
ERR=1
Resume


##########################################################################
$SEL_TABLE
##########################################################################
Case COUZON
 When "VCRSTR","VCREND" : # Borne de bordereaux de remise
  OBJET="FRM"
  SUPP="1"
  If [M]VCRFLG<>2
   CRITERE="STA<6"
  Else
   CRITERE ="STA<=6"
  Endif
  If [M]FCY<>"" : CRITERE -= "& FRMFCY='"+[M]FCY+"'" : Endif
  If [M]CPY<>"" : CRITERE -= "& CPY='"+[M]CPY+"'"    : Endif
  If [M]TYP<>"" : CRITERE -= "& PAYTYP='"+[M]TYP+"'" : Endif

# X3-118926 2018-12-06 Bader begin don't show remittances linked to payment entry types without bank file generation
  Global Char GPAYTYPARR(GLONTPY)(500)
  Local Char ACTTYP(GLONTPY)
  Local Integer CNT
  Raz GPAYTYPARR, ACTTYP, CNT
  If clalev([F:FRM])=0 : Local File PAYFRM    [FRM] : Endif
  If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
  Link [FRM]  With [F:TPY]TPY0 ~= [F:FRM]PAYTYP,
&                  [F:CPY]CPY0 ~= [F:FRM]CPY
&             As [LNK]
&             Where ([F:TPY]LEG = [F:CPY]LEG or [F:TPY]LEG = "") and ([F:TPY]STA6=2 or [F:TPY]EPACDTTRF=2)
&                   and evalue(CRITERE)
&             Order By Key LNK0=[F:FRM]PAYTYP

  # Avoid duplicate entries in selection list
  For [LNK]
      If [F:FRM]PAYTYP <> ACTTYP and CNT < 499
          GPAYTYPARR(CNT) = [F:FRM]PAYTYP
          ACTTYP = [F:FRM]PAYTYP
          CNT += 1
      Endif
  Next
  CRITERE -= "& find(PAYTYP,GPAYTYPARR)"
# X3-118926 2018-12-06 Bader end
Endcase
Return

##########XXX:NORMA 68###################
$DATOSFACTURA
If clalev([F:PIHX])=0 : Local File PINVOICE  [PIHX] : Endif
Read [PIHX]PIH0 =TFAC(NBFAC)
If fstat=0
 TDAT(NBFAC)=[F:PIHX]BPRDAT
 TREF(NBFAC)=[F:PIHX]BPRVCR
 TSNS(NBFAC)=[F:PIHX]SNS
 TIMPORTE(NBFAC)=[F:PYD]AMTLIN ################################### CONFIRMING SPA
Else
 If clalev([F:HAEX])=0 : Local File GACCENTRY  [HAEX] : Endif
 Read [HAEX]HAE0 = [F:PYD]VCRTYP;[F:PYD]VCRNUM
 If fstat=0
  # to get the accounting date
  If  [F:HAEX]BPRDATVCR<>[00/00/0000]
   TDAT(NBFAC)=[F:HAEX]BPRDATVCR
  Else
   TDAT(NBFAC)=[F:HAEX]ACCDAT
  Endif
  TREF(NBFAC)=[F:HAEX]BPRVCR
  # Sign determination
  If [F:PYD]AMTLIN2<0
   TSNS(NBFAC)= -1
  Else
   TSNS(NBFAC)= 1
  Endif
  TIMPORTE(NBFAC)=[F:PYD]AMTLIN
 Endif
 # End of Sign determination
Endif
Return
##########XXX:NORMA 68###################

##########################################################################
## Screen FICMAG ##
##########################################################################

Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From CPTTRT
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
 If dim([M]LEG)>0 : Actzo LEG : Endif
 GSOCIETE=""
Else
 Actzo CPY,ALLFCY
 If dim([M]LEG)>0 : Effzo LEG : Diszo LEG : Endif
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
Call AS_CPY(VALEUR) From CPTTRT
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR) From CPTTRT
End

Subprog AM_CPY(VALEUR)
Variable Char     VALEUR
Call AM_CPY (VALEUR) From CPTTRT
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG (VALEUR) From CPTTRT
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
If dim([M]LEG)>0
 If (VALEUR<>[M]LEG)
  If [M]ALLCPY=1
   [M]LEG = [F:CPY]LEG
   Affzo LEG
  Endif
 Endif
Endif
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
Call AS_FCY(VALEUR) From CPTTRT
End

Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TYP : Grizo TYP
Else
 Actzo TYP
Endif
End

Subprog AS_TYP(VALEUR)
Variable Char     VALEUR
If [M]ALLTYP = 2 : mkstat = 1 : Endif
End

Subprog C_TYP(VALEUR)
Variable Char     VALEUR
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
Call LEC_TPY_LEG(GCURLEG,VALEUR) From CPTLEC
# Ajout vérif EPACDTTRF
If [F:TPY]STA6<>2 and [F:TPY]EPACDTTRF<>2
 # Type de règlement non paramétré pour cette fonction
 GMESSAGE=mess(29,117,1) : mkstat=2
Else
 Call CONTEXE([F:TPY]ACS) From CPTSUB
Endif
End

Subprog AS_VCREND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]VCRSTR : VALEUR=[M]VCRSTR : Endif
End

Subprog C_VCREND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]VCRSTR
 GMESSAGE = mess(44,199,1) :# La borne fin est inferieure a la borne debut
 mkstat = 2
Endif
End

