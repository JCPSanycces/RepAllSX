########################################
# Replace each character of MODEL with a space in the string STRCAR
Funprog REPLCAR(STRCAR)
Value Char STRCAR
Local Char MODEL(250), STRCAR1(250), RPL(250)
# Issue X3-52745 - 2017-08-24 by BEFOU : Adding  ON REPLCAR
MODEL = '!"#$%&*;<>=@[]\_^`{}|~§µ°£¤'
RPL   = '                            '
STRCAR1 = ctrans(STRCAR, MODEL, RPL)
STRCAR1 = ctrans(STRCAR1)
End STRCAR1

Funprog STRIPSLASHES(TXT)
Value Char TXT
# strip all slashes at the beginning of the string
While left$(TXT, 1)="/" : TXT = right$(TXT, 2) : Wend

# strip all slashes at the end of the string
While right$(TXT, len(TXT))="/" : TXT = left$(TXT, len(TXT)-1) : Wend

# replace double-slashes anywhere in the string with a space
Call DYNAMIC(TXT,"//", " ") From TEXTE
End TXT

