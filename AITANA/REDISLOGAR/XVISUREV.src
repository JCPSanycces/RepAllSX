#<AdxTL>@(#)9.0.0.0 $Revision$
#ACV#X00
#TIT#

$ACTION
Case ACTION
When "DEBUT" : Gosub DEBUT
Endcase
Return

################################################################################
################################################################################
################################################################################
################################################################################

$DEBUT
Local Integer FFLIN 
Local Integer FFNOREV
Local File SORDER   [SOHX]
&        , SORDERP  [SOPX]
&        , SORDERQ  [SOQX]
Local File VSORDER  [VOHX]
&        , VSORDERP [VOPX]
&        , VSORDERQ [VOQX]
Raz nolign, FFLIN
FFNOREV=9999
For [SOHX] Where [F:SOHX]SOHNUM=PARAM(1)
For [SOQX] Where [F:SOQX]SOHNUM=[F:SOHX]SOHNUM
For [SOPX] Where [F:SOPX]SOHNUM=[F:SOQX]SOHNUM
&              & [F:SOPX]SOPLIN=[F:SOQX]SOPLIN
&              & [F:SOPX]SOPSEQ=[F:SOQX]SOQSEQ
    nolign+=1
    FFLIN+=1
    [M:DIA]=[F:SOHX]
    [M:DIA]=[F:SOQX]
    [M:DIA]=[F:SOPX]

    [M:DIA]VACITM1(nolign-1)=[F:SOPX]VACITM(0)
    [M:DIA]VACITM2(nolign-1)=[F:SOPX]VACITM(1)
    [M:DIA]VACITM3(nolign-1)=[F:SOPX]VACITM(2)
    [M:DIA]DDEMDLVDAT(nolign-1)=[F:SOQX]DEMDLVDAT
    [M:DIA]DDAYLTI(nolign-1)=[F:SOQX]DAYLTI
    [M:DIA]DSHIDAT(nolign-1)=[F:SOQX]SHIDAT
    [M:DIA]DBPAADD(nolign-1)=[F:SOQX]BPAADD
    [M:DIA]DDLVPIO(nolign-1)=[F:SOQX]DLVPIO
    [M:DIA]DMDL(nolign-1)=[F:SOQX]MDL
    [M:DIA]DBPTNUM(nolign-1)=[F:SOQX]BPTNUM
    [M:DIA]DCCLREN(nolign-1)=[F:SOQX]CCLREN
    [M:DIA]DCCLDAT(nolign-1)=[F:SOQX]CCLDAT

    [M:DIA]DSTOFCY(nolign-1)=[F:SOQX]STOFCY
    [M:DIA]FSOQ(nolign-1)=1
    [M:DIA]FLIN(nolign-1)=FFLIN
    [M:DIA]FNOREV(nolign-1)=FFNOREV-[M:DIA]LINREVNUM(nolign-1)

    For [VOHX] Where [F:VOHX]SOHNUM=[F:SOHX]SOHNUM
    For [VOQX] Where [F:VOQX]SOHNUM=[F:VOHX]SOHNUM
&                  & [F:VOQX]LINREVNUM=[F:VOHX]REVNUM
&                  & [F:VOQX]SOPLIN=[F:SOQX]SOPLIN
&                  & [F:VOQX]SOQSEQ=[F:SOQX]SOQSEQ
    For [VOPX] Where [F:VOPX]SOHNUM=[F:VOQX]SOHNUM
&                  & [F:VOPX]LINREVNUM=[F:VOQX]LINREVNUM
&                  & [F:VOPX]SOPLIN=[F:VOQX]SOPLIN
&                  & [F:VOPX]SOPSEQ=[F:VOQX]SOQSEQ
        nolign+=1
        [M:DIA]=[F:VOHX]
        [M:DIA]=[F:VOQX]
        [M:DIA]=[F:VOPX]

        [M:DIA]VACITM1(nolign-1)=[F:VOPX]VACITM(0)
        [M:DIA]VACITM2(nolign-1)=[F:VOPX]VACITM(1)
        [M:DIA]VACITM3(nolign-1)=[F:VOPX]VACITM(2)
        [M:DIA]DDEMDLVDAT(nolign-1)=[F:VOQX]DEMDLVDAT
        [M:DIA]DDAYLTI(nolign-1)=[F:VOQX]DAYLTI
        [M:DIA]DSHIDAT(nolign-1)=[F:VOQX]SHIDAT
        [M:DIA]DBPAADD(nolign-1)=[F:VOQX]BPAADD
        [M:DIA]DDLVPIO(nolign-1)=[F:VOQX]DLVPIO
        [M:DIA]DMDL(nolign-1)=[F:VOQX]MDL
        [M:DIA]DBPTNUM(nolign-1)=[F:VOQX]BPTNUM
        [M:DIA]DCCLREN(nolign-1)=[F:VOQX]CCLREN
        [M:DIA]DCCLDAT(nolign-1)=[F:VOQX]CCLDAT

        [M:DIA]LINREVDAT(nolign-1)=[F:VOHX]CREDAT

        [M:DIA]DSTOFCY(nolign-1)=[F:VOQX]STOFCY
        [M:DIA]FSOQ(nolign-1)=0
        [M:DIA]FLIN(nolign-1)=FFLIN
        [M:DIA]FNOREV(nolign-1)=FFNOREV-[M:DIA]LINREVNUM(nolign-1)
    Next
    Next
    Next
Next
Next
Next
[M:DIA]NBLIG=nolign
Sorta [M:DIA]NBLIG [M:DIA]NBLIG Order By [M:DIA]FLIN(indice), [M:DIA]FNOREV(indice) Asc
Affzo [M:DIA]
Close Local File [SOHX],[SOPX],[SOQX] 
Close Local File [VOHX],[VOPX],[VOQX] 
Return

################################################################################
## Etiquette ajoutée par le superviseur (écran XVISUREV) 06/04/2007 14:25:43 (FMUYS)
################################################################################

Subprog AV_NOLIGNE(VALEUR)
Variable Decimal VALEUR
Call AFFCOL(nolign-1)
End

Subprog AFFCOL(P1)
Value Integer P1
pcolor=GCOUL(3)
If ![M:DIA]FSOQ(P1) Then pcolor=GCOUL(0) Endif
End

################################################################################
## Etiquette ajoutée par le superviseur (écran XVISUREV) 03/05/2007 14:29:38 (FMUYS)
################################################################################

Subprog GESDIFF(P1,P2)
Value Integer P1   #nolign-1
Value Char    P2() #nom de la zone
If (P1+1 < dim([M:DIA]FLIN))
&& ([M:DIA]FLIN(P1) = [M:DIA]FLIN(P1+1))
&& (evalue("[M:DIA]"+P2+"(P1)") <> evalue("[M:DIA]"+P2+"(P1+1)"))
    pcolor=GCOUL(1)
Else
    Call AFFCOL(P1)
Endif
End

