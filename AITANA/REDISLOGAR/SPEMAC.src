#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "CREATION"   : Gosub CREATION
  When "APRES_CRE"  : Gosub APRES_CRE
  When "APRES_MOD"  : Gosub APRES_MOD
  When "LIENS"      : Gosub LIENS
  When "MODIF"      : Gosub MODIF
  When "ANNULE"     : Gosub ANNULE
  When "DEFLIG"     : Gosub DEFLIG
  When "INICRE_LIG"       : Gosub INICRELIG
  When Default
Endcase
Return
######################################################################################
## YA041 - Historico estado parque cliente
######################################################################################
$OUVRE
# Le indicamos que valla primero al SUB
Gosub ACTION From SUBMAC

Gosub DECLARE From TABLEAUX

# Que no vuelva a ejecutar el la parte del SUB
GPE=1
Return
######################################################################################
## YA041 - Historico estado parque cliente
######################################################################################
$CREATION
# Le indicamos que valla primero al SUB
Gosub ACTION From SUBMAC

Gosub CREATION From TABLEAUX
If GOK<1 : Return : Endif

# Que no vuelva a ejecutar el la parte del SUB
GPE=1
Return
######################################################################################
## YA041 - Historico estado parque cliente
######################################################################################
$APRES_CRE
# Le indicamos que valla primero al SUB
Gosub ACTION From SUBMAC

# Regeneración d los indicadores UPDFLG y CREFLG
Gosub LIENS From TABLEAUX

# Que no vuelva a ejecutar el la parte del SUB
GPE=1
Return
######################################################################################
## YA041 - Historico estado parque cliente
######################################################################################
$APRES_MOD
# Le indicamos que valla primero al SUB
Gosub ACTION From SUBMAC

# Regeneración d los indicadores UPDFLG y CREFLG
Gosub LIENS From TABLEAUX

# Que no vuelva a ejecutar el la parte del SUB
GPE=1
Return
######################################################################################
## YA041 - Historico estado parque cliente
######################################################################################
$MODIF
# Le indicamos que valla primero al SUB
Gosub ACTION From SUBMAC

Gosub MODIF From TABLEAUX
If GOK<1 : Return : Endif

# Que no vuelva a ejecutar el la parte del SUB
GPE=1
Return
######################################################################################
## YA041 - Historico estado parque cliente
######################################################################################
$LIENS
# Le indicamos que valla primero al SUB
Gosub ACTION From SUBMAC

Gosub LIENS From TABLEAUX

# Que no vuelva a ejecutar el la parte del SUB
GPE=1
Return
######################################################################################
## YA041 - Historico estado parque cliente
######################################################################################
$ANNULE
# Le indicamos que valla primero al SUB
Gosub ACTION From SUBMAC

Gosub ANNULE From TABLEAUX
If GOK<1 : Return : Endif

# Que no vuelva a ejecutar el la parte del SUB
GPE=1
Return
######################################################################################
## YA041 - Historico estado parque cliente
######################################################################################
$DEFLIG
Default File [YHSM]
Default Mask [YMAC9]
#Default File [YHCC]
#Default Mask [YBPC7]
#
##----     Criterios de lectura
CRIT   = 'MACNUM="'+[M:MAC0]MACNUM+'"'
##----     Fichero de líneas
FICLIG = "YHISSTAMAC" : ABLIG  = "YHSM"
##----     línea
ZONLIG = "LINNUM"
Return
######################################################################################
## YA041 - Historico estado parque cliente
######################################################################################
$INICRELIG
# Le indicamos que valla primero al SUB
Gosub ACTION From SUBMAC
[F:YHSM]MACNUM = [M:MAC0]MACNUM

# Que no vuelva a ejecutar el la parte del SUB
GPE=1
Return

End
######################################################################################

