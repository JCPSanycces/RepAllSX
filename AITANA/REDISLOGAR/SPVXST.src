#<AdxTL>@(#)2.0.0.0 $Revision:   1.12  $ Gestion du masque SIT0
#ACV#X16
#TIT#Gestion des situations

GBIDC1=""
GBIDC2=""
Call OBJET("OPP",GBIDC1,GBIDC2) From GOBJET
End

#==========================================================================================
# Gestion de l'objet   : Gestion de l'objet XST (en-tête de situation)
#
# Auteur               : Laurent Bornes
# Date de création     :
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 17/01/2005    LBORN        Version 130 --> Version 140
#==========================================================================================

$ACTION

# Appel fonctions complémentaires GFI pour l'objet XST
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "OUVRE"    : Gosub OUVRE     From SPVOBJXST
  When "FERME"    : Gosub FERME     From SPVOBJXST
  When "SETBOUT"  : Gosub SETBOUT   From SPVOBJXST
  When "EXEBOUT"  : Gosub EXEBOUT   From SPVOBJXST
  When "VERF_ANU" : Gosub VERF_ANU  From SPVOBJXST
  When "FILTRE"   : Gosub FILTRE    From SPVOBJXST
  When "LIENS"    : Gosub LIENS     From SPVOBJXST
Endcase

Return


########################################
# XST0
########################################

#---------------------------------------
Subprog C_SITNUM(VALEUR)
Variable Char    VALEUR()
# Rien d'affiché, vérif si un enregistrement existe
If VALEUR<>""
  Look [XST]XST0=VALEUR
  If fstat GMESSAGE=mess(178,199,1) : mkstat=1 : End : Endif
Endif
End

#---------------------------------------
Subprog AV_OPPNUM(VALEUR) # Utiliser pour les actions PSG
Variable Char    VALEUR()
Call ITYPOBJ1([OPP]OPPTYP) From SPVOBJPSG
End

#---------------------------------------
Subprog AP_OPPNUM(VALEUR) # Utiliser pour les actions PSG
Variable Char    VALEUR()
Call ITYPOBJ2([OPP]OPPTYP) From SPVOBJPSG
End
