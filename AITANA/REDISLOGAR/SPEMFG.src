#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER = 'AIT07' : Infbox "1"-ACTION : Endif
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "FERME"     : Gosub FERME
 When "LIENS_LIG" : Gosub LIENS_LIG
 When "SETBOUT"   : Gosub SETBOUT
 When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
If clalev ([F:ZITU])  = 0   : Local File ITMBPC  [ZITU]   : Endif
# YRE11 - STR
If !clalev ([F:STO0]) Then  : Local File STOCK   [F:STO0] : Endif
If !clalev ([F:STA0]) Then  : Local File STOALL  [F:STA0] : Endif
# YRE11 - END
Return

##############################################################
$FERME
Close Local File [F:ZITU], [F:STO0], [F:STA0]
Return

##############################################################
$LIENS_LIG
  Gosub LIENS_LIG From SUBMFGA

  # YRE10 - muestra la información correcta en el campo 'Cod Artículo Cliente'
  If [M:MFG1]BPCTYPDEN(LIG) = 2
    Read [F:ZITU]ITU0 = [M:MFG1]ITMREF(LIG);[M:MFG1]BPCNUM(LIG)
    If !fstat
      [M:MFG1]YITMCLI(LIG) = [F:ZITU]ITMREFBPC
      Affzo [M:MFG1]YITMCLI(LIG)
    Endif
  Endif

  GPE=1
Return

##############################################################
$SETBOUT
# YRE11 - STR
  Gosub SET_CTDUBIPRODQTY
# YRE11 - END
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
# YRE11 - Añadir campo en componentes de OF
$SET_CTDUBIPRODQTY
Local Integer LCON0
Local Decimal LQTY

  For LCON0=0 To [M:MFG2]NBLIG-1
    Raz LQTY
    Filter [F:STA0] Where STOFCY = [M:MFG0]MFGFCY and ITMREF = [M:MFG2]ITMREF(LCON0) and VCRNUM = [M:MFG0]MFGNUM
    For [STA0]
      Filter [F:STO0] Where STOFCY = [F:STA0]STOFCY and STOCOU = [F:STA0]STOCOU and LOC = "MONTA"
      Read [F:STO0] First
      If !fstat Then
        LQTY += [F:STA0]QTYSTUACT
      Endif
      Filter [F:STO0]
    Next
    Filter [F:STA0]
    [M:MFG2]YUBIPRODQTY(LCON0) = LQTY
    Affzo [M:MFG2]YUBIPRODQTY(LCON0)
  Next LCON0

Kill LCON0

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################
Subprog AM_BPCNUM(VALEUR)
Variable Char    VALEUR()

If [M:MFG1]BPCTYPDEN(nolign-1) = 2
  Read [F:ZITU]ITU0 = [M:MFG1]ITMREF(nolign -1);VALEUR
  If !fstat
    [M:MFG1]YITMCLI(nolign-1)    = [F:ZITU]ITMREFBPC    # YRE10 - modif. JC 07/05/2020 - antes mostraba [F:ZITU]ITMDESBPC
    Affzo [M:MFG1]YITMCLI(nolign-1)
  Endif
Endif
End

##############################################################
Subprog AM_BPCTYPDEN(VALEUR)
Variable Integer VALEUR
Effzo [M:MFG1]YITMCLI(nolign-1)
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla MFG2) 11/05/2020 13:49:05 (AIT07)
######################################################################################
Subprog AM_YSNDQTY(VALEUR)
Variable Decimal VALEUR
End


######################################################################################

