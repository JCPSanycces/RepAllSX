#######################################################################################
#$BOUTON
## Siempre hace primero la parte del SPE, asi que le indicamos que valla al SUB
#Infbox('0')
#Gosub ACTION From TRTPREP
#
#Infbox('1')
#Case BOUT
# When "I" : Gosub ALL_INC
# When "J" : Gosub ALL_EXC
#Endcase
#
## GPE=1 es Para que no vuelva a ejecutar el la parte del SUB, ya que la hemos llamado antes
#GPE=1
#Return
######################################################################################
$ALL_INC

#Marcamos la lista original
For Z=0 To [M:PREP]KBLIG-1
   [M:PREP]YCOCHAGE(Z)=2
   Affzo [M:PREP]YCOCHAGE(Z)
Next Z

#Marcamos la lista filtrada
For Y=0 To [M:PREP]YBLIG-1
   [M:PREP]YYCOCHAGE(Y)=2
   Affzo [M:PREP]YYCOCHAGE(Y)
Next Y

Return
######################################################################################
$ALL_EXC

#Desmarcamos la lista original
For Z=0 To [M:PREP]KBLIG-1
   [M:PREP]YCOCHAGE(Z)=1
   Affzo [M:PREP]YCOCHAGE(Z)
Next Z

#Desmarcamos la lista filtrada
For Y=0 To [M:PREP]YBLIG-1
   [M:PREP]YYCOCHAGE(Y)=1
   Affzo [M:PREP]YYCOCHAGE(Y)
Next Y

Return
######################################################################################
Subprog AM_YCOCHAGE(VALEUR)
Variable Integer VALEUR

Variable Integer YNOLIGN

#Compruebo la lista original
For N=0 To [M:PREP]NBLIG-1
  If [M:PREP]ORINUM(N) =  [M:PREP]YORNUM(nolign -1)
    #Guardo el valor de nolign
    YNOLIGN = nolign
    #Le doy el valor en la tabla estandar
    nolign = N + 1

    #Llamo al subprorama del campo estandar
    Call AM_COCHAGE(VALEUR) From TRTPREP

    #Recupero el valor de nolign
    nolign = YNOLIGN

    Affzo [M:PREP]40
  Endif
Next

#Compruebo mi lista de líneas
For N=0 To [M:PREP]YBLIG-1
  If [M:PREP]YYORINUM(N) =  [M:PREP]YORNUM(nolign -1)
    #Guardo el valor de nolign
    YNOLIGN = nolign
    #Le doy el valor en la tabla estandar
    nolign = N + 1

    [M:PREP]YYCOCHAGE(N) = VALEUR

    #Recupero el valor de nolign
    nolign = YNOLIGN

    Affzo [M:PREP]50
  Endif
Next



End
######################################################################################
Subprog AM_YYCOCHAGE(VALEUR)
Variable Integer VALEUR

Variable Integer YYNOLIGN

For Y=0 To [M:PREP]NBLIG-1

  If [M:PREP]ORINUM(Y) =  [M:PREP]YYORINUM(nolign -1) & [M:PREP]ORILIN(Y) =  [M:PREP]YYORILIN(nolign -1)

    #Guardo el valor de nolign
    YYNOLIGN = nolign
    #Le doy el valor en la tabla estandar
    nolign = Y + 1

    #Llamo al subprorama del campo estandar
    Call AM_COCHAGE(VALEUR) From TRTPREP

    #Recupero el valor de nolign
    nolign = YYNOLIGN

    Affzo [M:PREP]40
  Endif
Next
End
######################################################################################
Subprog AM_YBPSSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   If [M:PREP]YBPSEND=""
    [M:PREP]YBPSEND=VALEUR
   Endif
   Actzo [M:PREP]YBPSSTR
#Else
#   Diszo [M:PREP]YBPSSTR
Endif
End

Subprog AP_YBPSEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   Actzo [M:PREP]YBPSEND
#Else
#   Diszo [M:PREP]YBPSEND
Endif
End
######################################################################################

######################################################################################
Subprog CL_YMOSTRAR(VALEUR)
Variable Char    VALEUR()

Local Integer NLL1
Local Integer NLL2

# Guardo el numero de línea que he seleccionado
NLL2 = nolign-1

# Vació la lista de lineas
Raz [M:PREP]YBLIG

#Recorro la lista original buscando las líneas del pedido seleccionado (Me crea una líneas de más)
For Y=0 To [M:PREP]NBLIG-1
  If [M:PREP]ORINUM(Y) = [M:PREP]YORNUM(NLL2)

    NLL1+=1

    Insa NLL1,1 [M:PREP]YBLIG
    [M:PREP]YBLIG +=1
    nolign = NLL1 + 1
    status = 0

    [M:PREP]YYCOCHAGE(YBLIG-1)   = [M:PREP]COCHAGE(Y)
    [M:PREP]YYPRHNUM(YBLIG-1)    = [M:PREP]PRHNUM(Y)
    [M:PREP]YYDLVFLG(YBLIG-1)    = [M:PREP]DLVFLG(Y)
    [M:PREP]YYORITYP(YBLIG-1)    = [M:PREP]ORITYP(Y)
    [M:PREP]YYORINUM(YBLIG-1)    = [M:PREP]ORINUM(Y)

    [M:PREP]YYORILIN(YBLIG-1)    = [M:PREP]ORILIN(Y)
    [M:PREP]YYSHIDAT(YBLIG-1)    = [M:PREP]SHIDAT(Y)
    [M:PREP]YYITMREF(YBLIG-1)    = [M:PREP]ITMREF(Y)
    [M:PREP]YYITMDES1(YBLIG-1)   = [M:PREP]ITMDES1(Y)
    [M:PREP]YYREOLOC(YBLIG-1)    = [M:PREP]REOLOC(Y)
    [M:PREP]YYQTYSTU(YBLIG-1)    = [M:PREP]QTYSTU(Y)
    [M:PREP]YYSTU(YBLIG-1)       = [M:PREP]STU(Y)
    [M:PREP]YYALLQTY(YBLIG-1)    = [M:PREP]ALLQTY(Y)
    [M:PREP]YYSHTQTY(YBLIG-1)    = [M:PREP]SHTQTY(Y)
    [M:PREP]YYALLTYP(YBLIG-1)    = [M:PREP]ALLTYP(Y)
    [M:PREP]YYQTYSTUMAX(YBLIG-1) = [M:PREP]QTYSTUMAX(Y)
    [M:PREP]YYBPCORD(YBLIG-1)    = [M:PREP]BPCORD(Y)
    [M:PREP]YYBPAADD(YBLIG-1)    = [M:PREP]BPAADD(Y)
    [M:PREP]YYLOT(YBLIG-1)       = [M:PREP]LOT(Y)
    [M:PREP]YYSLO(YBLIG-1)       = [M:PREP]SLO(Y)
    [M:PREP]YYSERNUM(YBLIG-1)    = [M:PREP]SERNUM(Y)
    [M:PREP]YYLOC(YBLIG-1)       = [M:PREP]LOC(Y)
    [M:PREP]YYSTA(YBLIG-1)       = [M:PREP]STA(Y)
    [M:PREP]YYPCU(YBLIG-1)       = [M:PREP]PCU(Y)
    [M:PREP]YYPCUSTUCOE(YBLIG-1) = [M:PREP]PCUSTUCOE(Y)
    [M:PREP]YYLOCDES(YBLIG-1)    = [M:PREP]LOCDES(Y)
    [M:PREP]YYPCK(YBLIG-1)       = [M:PREP]PCK(Y)
    [M:PREP]YYPCKCAP(YBLIG-1)    = [M:PREP]PCKCAP(Y)
    [M:PREP]YYLINTYP(YBLIG-1)    = [M:PREP]LINTYP(Y)
    [M:PREP]YYSDHTYP(YBLIG-1)    = [M:PREP]SDHTYP(Y)
    #[M:PREP]YYGROPRI(YBLIG-1)   = [M:PREP]YGROPRI(Y)
    [M:PREP]YYAMTALL(YBLIG-1)    = [M:PREP]YAMTALL(Y)  #JPL - Añado Importe de línea de la cantidad asignada
    [M:PREP]YYAMTLIN(YBLIG-1)    = [M:PREP]YAMTLIN(Y)  #JPL - Añado Importe de línea
    [M:PREP]YYAMTLINP(YBLIG-1)   = [M:PREP]YAMTLINP(Y) #JPL - Añado Importe de línea pte. entregar
    [M:PREP]YYSOQTEX(YBLIG-1)    = [M:PREP]YSOQTEX(Y)
    [M:PREP]YYSOHTEXDES(YBLIG-1) = [M:PREP]YSOHTEXDES(Y)
    [M:PREP]YYPOSCLI(YBLIG-1)    = [M:PREP]YPOSCLI(Y)

  Endif
Next
Affzo [M:PREP]50
End
