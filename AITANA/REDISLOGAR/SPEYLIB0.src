###############################################################################
#**
#* Obtener stock fisico ARTICULO/PLANTA
#* Usada en CONSULTA STOCK DETALLADO
#*
#* @param PITMREF
#* @param PSTOFCY
#*!
Funprog GETPHYSTO(PITMREF, PSTOFCY)
  Variable Char PITMREF, PSTOFCY
  Local Decimal LRES

  If !clalev([ZITV]) Then : Local File ITMMVT [ZITV] : Endif

  Read [ZITV]ITV0=PITMREF:PSTOFCY
  If !fstat Then
    LRES = [F:ZITV]PHYSTO
  Else
    LRES = 0
  Endif
  Close File [ZITV]

End LRES

