###############################################################################
#**
#* Obtener 'Descripción cliente' de artículo
#* Usada en PRODUCCIÓN > CONSUTLAS > ENCURSO > ENCURSO ARTÍCULO
#*
#* @param PITMREF
#* @param PVCRNUM
#*!
Funprog GET_ITMDESBPC(PITMREF, PBPCNUM)
Variable Char PITMREF, PBPCNUM

Local Char LRES

  If !clalev([F:ITU0]) Then : Local File ITMBPC [F:ITU0] : Endif

  Read [F:ITU0]ITU0=PITMREF;PBPCNUM
  If !fstat Then
    LRES = [F:ITU0]ITMDESBPC
  Else
    LRES = ""
  Endif
  Close File [F:ITU0]

End LRES

