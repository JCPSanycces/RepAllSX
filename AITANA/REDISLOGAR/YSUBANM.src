#####################################################################################
# CODACT: Y0000 - Genéricos
#####################################################################################

$ACTION
Case ACTION
  When "NUMERO"     : Gosub NUMERO
Endcase

Return

#####################################################################################

$NUMERO

Case COMPTEUR
  When "IT"
    If GFONCTION <> "GESITN"
      COMP = "AC"
    Else
      COMP = [F:ITN]YITNTYP
    Endif
    GPE = 0
  When "SS"
      COMP = [F:SRE]YTIPO
      GPE = 0
Endcase


Return

#####################################################################################

