#####################################################################################

$ACTION
  Case ACTION
    When Default
  Endcase

Return

#####################################################################################

Subprog AM_YFECHA(VALEUR)
Variable Date    VALEUR
[M:YPCUD]YFECHA (nolign-1) = VALEUR
Gosub CALC_PRIEUR
End

#####################################################################################

Subprog AM_YPRICU(VALEUR)
Variable Decimal VALEUR
[M:YPCUD]YPRICU (nolign-1) = VALEUR
Gosub CALC_PRIEUR
End


######################################################################################

$CALC_PRIEUR

# Traigo el tipo de cambio del mes
If !clalev([F:YTCH]) : Local File TABCHANGE [F:YTCH] : Endif

Filter [F:YTCH] Where CHGTYP = 2 and CURDEN = 'EUR' and CUR = 'CHF' and month(CHGSTRDAT) = month([M:YPCUD]YFECHA)
Read [F:YTCH]TCH0 Last
If !fstat
  [M:YPCUD]YCHGRAT (nolign-1)   = [F:YTCH]CHGRAT
  [M:YPCUD]YPRICUEUR (nolign-1) = [M:YPCUD]YPRICU (nolign-1) * [M:YPCUD]YCHGRAT (nolign-1)

  Affzo [M:YPCUD]YCHGRAT (nolign-1)
  Affzo [M:YPCUD]YPRICUEUR (nolign-1)
Endif
Filter [F:YTCH]

Return

######################################################################################

