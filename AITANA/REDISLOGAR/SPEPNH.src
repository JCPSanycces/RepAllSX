#####################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return
######################################################################################
## YA020 - Tipo de precio
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
Read [F:ZITM]ITM0 = VALEUR
If fstat = 0
  [M:PNH1]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
  Affzo [M:PNH1]YTIPPRI(nolign -1)
Endif

Case [M:PNH1]YTIPPRI(nolign -1)
  When 1 : [M:PNH1]YGROPRI(nolign -1) = [M:PNH1]GROPRI(nolign -1)
  When 2 : [M:PNH1]YGROPRI(nolign -1) = [M:PNH1]GROPRI(nolign -1) * 10
  When 3 : [M:PNH1]YGROPRI(nolign -1) = [M:PNH1]GROPRI(nolign -1) * 100
  When 4 : [M:PNH1]YGROPRI(nolign -1) = [M:PNH1]GROPRI(nolign -1) * 1000
Endcase
Affzo [M:PNH1]YGROPRI(nolign -1)

End
######################################################################################
## YA020 - Tipo de precio
######################################################################################
Subprog AM_YGROPRI(VALEUR)
Variable Decimal VALEUR

Local Decimal PRECIO

Case [M:PNH1]YTIPPRI(nolign -1)
  When 1 : PRECIO  = VALEUR
  When 2 : PRECIO  = VALEUR / 10
  When 3 : PRECIO  = VALEUR / 100
  When 4 : PRECIO  = VALEUR / 1000
Endcase

# Llamamos a las funciones del campo GROPRI, como si se hubiese modificdo en pantalla
Call AP_GROPRI(PRECIO) From SUBPNH
#Call PAMAPPFLG("PNH1",nolign-1,"GROPRI") From TRTACHAPP1
Call PAMDISCRG( PRECIO , "PNH1" , 0 , nolign-1 , [M:PNH1]NETCUR(nolign-1)) From TRTACHPRI1
#Call PAMVATFLG("PNH1",nolign-1,"GROPRI") From TRTACHFAC1
#Call AM_GROPRI(PRECIO) From SUBPNH

# Finalmente actualizamos el campo standard
[M:PNH1]GROPRI(nolign -1) = PRECIO
Affzo [M:PNH1]GROPRI(nolign -1)

End
######################################################################################
## YA020 - Tipo de precio
######################################################################################
Subprog AM_QTYUOM(VALEUR)
Variable Decimal    VALEUR()

If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
Read [F:ZITM]ITM0 = [M:PNH1]ITMREF(nolign -1)
If fstat = 0
  [M:PNH1]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
  Affzo [M:PNH1]YTIPPRI(nolign -1)
Endif

Case [M:PNH1]YTIPPRI(nolign -1)
  When 1 : [M:PNH1]YGROPRI(nolign -1) = [M:PNH1]GROPRI(nolign -1)
  When 2 : [M:PNH1]YGROPRI(nolign -1) = [M:PNH1]GROPRI(nolign -1) * 10
  When 3 : [M:PNH1]YGROPRI(nolign -1) = [M:PNH1]GROPRI(nolign -1) * 100
  When 4 : [M:PNH1]YGROPRI(nolign -1) = [M:PNH1]GROPRI(nolign -1) * 1000
Endcase
Affzo [M:PNH1]YGROPRI(nolign -1)

End


######################################################################################












######################################################################################
## Etiqueta añadida por el supervisor (pantalla PNH1) 08/07/2019 11:08:26 (LLL)
######################################################################################
Subprog C_YBPAENV(VALEUR)
Variable Char    VALEUR()
#<Y999> LUIS 08/07/2019 validar Codigo dirección de envio de la mercancia.
If VALEUR<>""
  Read [BPA] BPA0=1;[M:PNH1]BPSNUM;VALEUR
  If fstat Raz [F:BPA] : mkstat=1 : End : Endif
Endif
#</Y999>
End


