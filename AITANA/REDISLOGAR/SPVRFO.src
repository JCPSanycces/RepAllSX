#VALEUR = [M:RFO0]FORDES
#End

########################################
Subprog D_DATREF(VALEUR)
Variable Date    VALEUR
VALEUR=gdat$(1,1,year(date$)-1)
End

########################################
Subprog D_DATCAL(VALEUR)
Variable Date    VALEUR
VALEUR=date$
End

########################################
Subprog D_MONTANT(VALEUR)
Variable Decimal VALEUR
VALEUR=100
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran RFOTST) 04/02/2009 10:08:50 (LBORN)
######################################################################################
Subprog C_DATCAL(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M:DIA]DATREF
  mkstat=1
Endif
End


