#ACV#X13
#TIT#Interface Planner

# SOUCH # 02/10/2012


$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE      From SPVOBJXIP
  When "FILTRE"     : Gosub FILTRE     From SPVOBJXIP
  When "FILGAUCHE"  : Gosub FILGAUCHE  From SPVOBJXIP
  When "LIENS"      : Gosub LIENS      From SPVOBJXIP
  When "INICRE"     : Gosub INICRE     From SPVOBJXIP
  When "CREATION"   : Gosub CREATION   From SPVOBJXIP
  When "MODIF"      : Gosub MODIF      From SPVOBJXIP
  When "ANNULE"     : Gosub ANNULE     From SPVOBJXIP
  When "APRES_CRE"  : Gosub APRES_CRE  From SPVOBJXIP
  When "APRES_MOD"  : Gosub APRES_MOD  From SPVOBJXIP

  When "DEFLIG"     : Gosub DEFLIG     From SPVOBJXIP
  When "INICRE_LIG" : Gosub INICRE_LIG From SPVOBJXIP
  When "INIMOD_LIG" : Gosub INIMOD_LIG From SPVOBJXIP
  When "LIENS_LIG"  : Gosub LIENS_LIG  From SPVOBJXIP

  When "SETBOUT"    : Gosub SETBOUT    From SPVOBJXIP

Endcase
Return
