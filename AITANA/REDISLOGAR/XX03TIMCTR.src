$OUVRE
 If clalev([F:AUS])   =0    : Local File AUTILIS    [AUS]    : Endif  # Utilisateurs
 If clalev([F:XLR1])  =0    : Local File XLEAREQ    [XLR]    : Endif  # Demande d'absence
 If clalev([F:OPE])   =0    : Local File OPERATION  [OPE]    : Endif  # Opûôˋrations X3S
 If clalev([F:ITD])   =0    : Local File ITVREQD    [ITD]    : Endif  # Interventions
 If clalev([F:ITR])   =0    : Local File ITVREQ     [ITR]    : Endif  # Interventions
 If clalev([F:TUV])   =0    : Local File TABUNAVAIL [TUV]    : Endif  # Table des Pûôˋriodes d'indispo.
 If clalev([F:XX03TR])=0   : Local File XX03TIMCTR [F:XX03TR]  : Endif
 #If clalev([F:X03])   =0    : Local File XX03TIMCTR [X03] : Endif


 If clalev([F:AUS1])  =0    : Local File AUTILIS    [AUS1]   : Endif  # Utilisateurs
 If clalev([F:XCL])   =0    : Local File CALGAS     [XCL]    : Endif  # Calendriers X3S
 If clalev([F:XLR])   =0    : Local File XLEAREQ    [XLR]    : Endif  # Demande d'absence
 If clalev([F:ITD1])  =0    : Local File ITVREQD    [ITD1]   : Endif  # Interventions
Return
