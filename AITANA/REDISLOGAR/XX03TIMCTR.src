###############################################################################################################
# : impression :                          #
###############################################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
 Variable Integer NBPAR
 Variable Char    PARAMETRE()()

 Call EXEC(NBPAR,PARAMETRE)
 #[V]GOK=0

End
###############################################################################################################


###############################################################################################################
Subprog EXEC(NBPAR,PARAMETRE)
 Variable Integer NBPAR
 Variable Char PARAMETRE()()

 Call OUVRE_TRACE("XX03TIMCTR") From LECFIC
 Call ECR_TRACE("Ouvre",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
 Gosub OUVRE
 Call ECR_TRACE("Declare",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
 Gosub DECLARE
 Call ECR_TRACE("Prametre",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
 Gosub PARAMETRE
 Call ECR_TRACE("Periode",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
 Gosub PERIODE
 Call ECR_TRACE("Dûˋbut du parcours",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
 Gosub TRAITEMENT
#[V]GOK=0
End
 #Call LEC_TRACE() From LECFIC
###############################################################################################################


###############################################################################################################
$TRAITEMENT
Call ECR_TRACE("Traitement",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
 Trbegin[F:XX03TR]

 Link [F:ITD] With  [F:ITR]ITR0=[F:ITD]ITVNUM As [YITR]
&             Where [F:ITR]FLGITVVAL =2 & ([F:ITD]ASSLIB >= [L]USRITVDEB    & [F:ITD]ASSLIB<=USRITVFIN)
&             &     ([F:ITD]STRDAT   <=    [L]DATEFIN(0)    & [F:ITD]STRDAT >=[L]DATEDEB(2))
&             Order By Key CLE=[F:ITD]ASSLIB;[F:ITR]REQNUM;[F:ITD]ITVNUM;[F:ITD]ITVLIG;[F:ITD]STRDAT
#Dbgaff
 Raz [L]NBUSER2
 Filter [F:AUS]Where evalue([L]CRITERE) and  [F:AUS]ENAFLG=2
 [L]NBUSER2=rowcount([F:AUS])
 Call ECR_TRACE("Nombre d'untilisateur trouvûˋs " + num$(I)+ " [F:AUS]ENAFLG="+ num$([F:AUS]ENAFLG),0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
 Filter [F:AUS]

# Call ECR_TRACE("Avant le for",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement

 For [F:AUS]Where evalue([L]CRITERE) &  [F:AUS]ENAFLG=2
     [L]NBUSR+=1
     Call ECR_TRACE(num$([L]NBUSR)+ "-" +[F:AUS]USR + " -DEBUT",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement

     Raz [L]GRPCLASS
     Gosub GRPCLASS

     If [L]YCODOK=2 Then

             Call ECR_TRACE(" 1-Classification OK",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
             Call ECR_TRACE(" 2-Indisponibilitûˋ",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
        Gosub INDISPONIBILITE
             Call ECR_TRACE(" 2-Tot Per 0["+num$([L]NB_IND(0)) +"] Per 1["+ num$([L]NB_IND(1)) +"] Per 2["+num$([L]NB_IND(2)) +"]",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement

             Call ECR_TRACE(" 3-POT (Potentiel de temps travaillûˋ)",0) From GESECRAN # 0: Info, 1: Erreur,-1: Avertissement
        Gosub POT
              Call ECR_TRACE(" 3-Tot Per 0 ["+num$([L]TPPOT(0)) +"] Per 1 ["+ num$([L]TPPOT(1)) +"] Per 2["+num$([L]TPPOT(2)) +"]",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement

              Call ECR_TRACE(" 4-TPINTER (Temps dãintervention)",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
        Gosub TPINTER
              Call ECR_TRACE(" 4-Fac : Per 0 ["+num$([L]TPFAC(0)) +"] Per 1 ["+ num$([L]TPFAC(1)) +"] Per 2 ["+num$([L]TPFAC(2)) +"]"+
&                            " 4-NFac : Per 0 [" +num$([L]TPNFAC(0)) +"] Per 1 ["+ num$([L]TPNFAC(1)) +"] Per 2 ["+num$([L]TPNFAC(2)) +"]",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement

              Call ECR_TRACE(" 5-Heures de prûˋsence",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
        Gosub HEUR_PRESEN

              Call ECR_TRACE(" 6-TABS (Absences)",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
        Gosub TPABS
        Call ECR_TRACE(" 6-Total Abs P0-[" + num$([L]TPABS(0)) +"]; P1-[" + num$([L]TPABS(1))+"]; P2-["+ num$([L]TPABS(2))+"]",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement

         Gosub ECRITURE
     Else
        Call ECR_TRACE(" 1-Classification KO : Erreur.",1) From GESECRAN # 0: Info, 1: Erreur,1: Avertissement
     Endif
     Call ECR_TRACE([F:AUS]USR +" -FIN",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
     Call ECR_TRACE(" ",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
     Call ECR_TRACE(" ",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
 Next

 If [V]GOK=1 Then
    Commit
 Else
   Rollback
 Endif

 Raz I
 Filter [F:XX03TR] Where [F:XX03TR]NUMREQ=[L]NUMREQ
 I=rowcount([F:XX03TR])
 Filter [F:XX03TR]
 Call ECR_TRACE("Nombre de user Saisi :" + num$(I) +"/"+ num$([L]NBUSER2),0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
 Call FERME_TRACE() From LECFIC
 If I=0 Then
    GOK =0
    Infbox("Il n'y a rien û  imprimer. Pour plus d'inforamtion, consulter le ficheir trace.")
 Endif
Return
###############################################################################################################


###############################################################################################################
$INDISPONIBILITE
#Calcul des jour d'indisponibilitûˋ :
# Si l'utilisateur dispose d'un code d'indispolibiliter, on l'utilise pour effectue la recherche.
# Autrement on utilse le dernier code crûˋe.

 If [F:AUS]UVYCOD <>"" Then
    Read [F:TUV]UVY0=[F:AUS]UVYCOD
 Else
    Call ECR_TRACE(" 2- Pa Indisponibilitûˋ associûˋe û  utilisateur : lecture de la denriû´re ligne  de la table",-1) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
    Read [F:TUV] Last

 Endif

 Raz [L]D0_INDDEB, [L]D0_INDFIN, [L]D1_INDDEB,[L]D1_INDFIN
 Raz [L]D2_INDDEB, [L]D2_INDFIN, [L]NB_IND,I,[L]YI

 For [L]YI= 0 To dim([F:TUV]UVYSTRDAT)-1
     If ([F:TUV]UVYSTRDAT([L]YI))<>[0/0/0] Then
         For I=0 To 2
             # On ne rûˋcupûˋr que les jours des mois qui nous interesse.
             If [F:TUV]UVYSTRDAT([L]YI)>=[L]DATEDEB(I) & [F:TUV]UVYSTRDAT([L]YI)<=[L]DATEFIN(I) &
&               [F:TUV]UVYENDDAT([L]YI)>=[L]DATEDEB(I) & [F:TUV]UVYENDDAT([L]YI)<=[L]DATEFIN(I) Then
                 Assign ("D"+num$(I)+"_INDDEB"+"([L]NB_IND(I))") With [F:TUV]UVYSTRDAT([L]YI)
                 Assign ("D"+num$(I)+"_INDFIN"+"([L]NB_IND(I))") With [F:TUV]UVYENDDAT([L]YI)
                 [L]NB_IND(I)+=1
                 Call ECR_TRACE("    -Per "+num$(I)+"-["+format$("DD2",[F:TUV]UVYSTRDAT([L]YI))+"] ["+format$("DD2",[F:TUV]UVYENDDAT([L]YI)) +"]",0) From GESECRAN # 0: Info, 1: Erreur, -1:
# Avertissement
             Endif
         Next
     Endif
 Next
Return
###############################################################################################################


###############################################################################################################
$POT
 Local Integer OKPOT,NBJR,POS,YJ
 Raz [L]NBJR,I,J,[L]YI,[L]TPPOT, [L]OKPOT,YJ
 For I=0 To 2
     [L]NBJR =day(DATEFIN(I))

     For J=1 To [L]NBJR
         [L]DATETRT=gdat$(J,month([L]DATEFIN(I)),year([L]DATEFIN(I)))

         Case I
             When 0 : [L]YI=find([L]DATETRT,[L]D0_INDDEB(0..[L]NB_IND(0)))
             When 1 : [L]YI=find([L]DATETRT,[L]D1_INDDEB(0..[L]NB_IND(1)))
             When 2 : [L]YI=find([L]DATETRT,[L]D2_INDDEB(0..[L]NB_IND(2)))
         Endcase

         If [L]YI=0 Then
             YJ=dayn([L]DATETRT)-1
             If [F:AUS]UVYDAY(YJ)=2  Then
                [L]TPPOT(I) += [F:AUS]HOUWKDDAY(YJ)
                Call ECR_TRACE("    -Per "+num$(I)+"-["+ day$(dayn([L]DATETRT))+"--" +format$("DD2",[L]DATETRT)+"] "+ num$([F:AUS]HOUWKDDAY(YJ)) ,0) From GESECRAN # 0: Info, 1: Erreur, -1:
# Avertissement
             Endif
         Endif
     Next
 Next
 Raz I,YI,J,YJ
Return
###############################################################################################################


###############################################################################################################
$TPINTER
 Local Decimal TPNFAC(3), TPFAC(3)
 Raz [L]TPFAC,[L]TPNFAC
#       CATOPE =1 FACTURABLE
#       CATOPE =2 NONFACTURABLE
#       CATOPE =3 ABSENCE
#       CATOPE =4 FRAIS
#       CATOPE =5 PIûô´CE
#       CATOPE =6 AUTRE

 For I=0 To 2
     Filter  [YITR]Where [F:ITD]ASSLIB=[F:AUS]USR & [F:ITD]STRDAT>=DATEDEB(I) & [F:ITD]STRDAT<=DATEFIN(I)
     For [YITR]CLE
         Read [F:OPE]OPE0=[F:ITD]CODOPE
         If fstat =0 Then
             If [F:OPE]CATOPE=1 Then         #Facturable
                 [L]TPFAC(I) +=[F:ITD]ITVLEN
                 Call ECR_TRACE("    -Per "+ num$(I)+"-A-Fact-["+[F:ITR]REQNUM +"-"+[F:ITR]ITVNUM +"-" + num$([F:ITD]ITVLIG)+"-" +format$("DD2",[F:ITD]STRDAT)+"] "+ num$([F:ITD]ITVLEN),0) From
& GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
          Elsif [F:OPE]CATOPE=2 Then #Facturable
                 [L]TPNFAC(I) +=[F:ITD]ITVLEN
                 Call ECR_TRACE("    -Per "+ num$(I)+"-B-NonFact-["+[F:ITR]REQNUM +"-"+[F:ITR]ITVNUM +"-" + num$([F:ITD]ITVLIG)+"-" +format$("DD2",[F:ITD]STRDAT)+"] "+ num$([F:ITD]ITVLEN),0) From
& GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
             Endif
         Endif
     Next
 Next


Return
###############################################################################################################


###############################################################################################################
$TPABS
 Local Date    D_ABSDEB, D_ABSFIN,DATCAL
 Local Decimal H_ABSDEB,H_ABSFIN
 Local Decimal TPABS(3)
 Raz TPABS

 For I=0 To 2
     Filter [F:XLR] Where [F:XLR]ASSINT=[F:AUS]USR
&                   &     [F:XLR]BEGDAT<>[0/0/0] & [F:XLR]ENDDAT<>[0/0/0]
&                   & (
&                         ([F:XLR]BEGDAT>=DATEDEB(I) & [F:XLR]ENDDAT<=DATEFIN(I))
&                      |  ([F:XLR]BEGDAT>=DATEDEB(I) & [F:XLR]BEGDAT<=DATEFIN(I))
&                      |  ([F:XLR]ENDDAT>=DATEDEB(I) & [F:XLR]ENDDAT<=DATEFIN(I))
&                      |  ([F:XLR]BEGDAT<=DATEDEB(I) & [F:XLR]ENDDAT>=DATEFIN(I))
&                     )
# Abs dans la pûˋriode
# Abs dûˋbute dans la pûˋriode
# Abs fini dans la pûˋriode
# Priode comprie dans Abs

     Call ECR_TRACE("    -Per "+num$(I)+"-Absence du ["+format$("DD2",[L]DATEDEB(I)) +"] au [" +format$("DD2",[L]DATEFIN(I))+"]",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement

     For [F:XLR]XLR4
         If ([F:XLR]BEGDAT>=DATEDEB(I) & [F:XLR]ENDDAT<=DATEFIN(I)) Then                   # Abs dans la pûˋriode
            [L]D_ABSDEB=[F:XLR]BEGDAT
            [L]H_ABSDEB=val(left$([F:XLR]BEGHOU,2))+(val(right$([F:XLR]BEGHOU,3))/60)
            [L]D_ABSFIN=[F:XLR]ENDDAT
            [L]H_ABSFIN=val(left$([F:XLR]ENDHOU,2))+(val(right$([F:XLR]ENDHOU,3))/60)

         Elsif ([F:XLR]BEGDAT<=DATEDEB(I) & [F:XLR]ENDDAT>=DATEFIN(I)) Then                # Priode comprie dans Abs
            [L]D_ABSDEB=[L]DATEDEB(I)
            [L]H_ABSDEB=val(left$([L]YVALPAR(0),2))+(val(right$([L]YVALPAR(0),4))/60)
            [L]D_ABSFIN=DATEFIN(I)
            [L]H_ABSFIN=val(left$([L]YVALPAR(3),2))+(val(right$([L]YVALPAR(3),4))/60)

         Elsif ([F:XLR]BEGDAT>=DATEDEB(I) & [F:XLR]BEGDAT<=DATEFIN(I)) Then                # Abs dûˋbute dans la pûˋriode
            [L]D_ABSDEB=[F:XLR]BEGDAT
            [L]H_ABSDEB=val(left$([F:XLR]BEGHOU,2))+(val(right$([F:XLR]BEGHOU,3))/60)
            [L]D_ABSFIN=DATEFIN(I)
            [L]H_ABSFIN=val(left$([L]YVALPAR(3),2))+(val(right$([L]YVALPAR(3),4))/60)

         Elsif ([F:XLR]ENDDAT>=DATEDEB(I) & [F:XLR]ENDDAT<=DATEFIN(I)) Then                # Abs fini dans la pûˋriode
            [L]D_ABSDEB=[L]DATEDEB(I)
            [L]H_ABSDEB=val(left$([L]YVALPAR(0),2))+(val(right$([L]YVALPAR(0),4))/60)
            [L]D_ABSFIN=[F:XLR]ENDDAT
            [L]H_ABSFIN=val(left$([F:XLR]ENDHOU,2))+(val(right$([F:XLR]ENDHOU,3))/60)
         Endif

         If [L]D_ABSFIN<>[0/0/0] & [L]D_ABSDEB<>[0/0/0] Then
            [L]NBJR=[L]D_ABSFIN-[L]D_ABSDEB
          # Call ECR_TRACE("----Abs : du ["+format$("DD2",[L]D_ABSDEB) +"] au ["+format$("DD2",[L]D_ABSFIN) + "] soit : " +num$([L]NBJR+1)+" Jours",0) From GESECRAN # 0: Info, 1: Erreur, -1:
# Avertissement
          # Call ECR_TRACE("---Calcul des tps d'absence : du "+[L]D_ABSDEB +" au " + [L]D_ABSFIN ,0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
            Gosub TPABS_CALUL
         Endif
     Next
  Next

Return
###############################################################################################################


###############################################################################################################
$TPABS_CALUL
 Local Decimal H_TRAV,H_ABSTOT,H_ABSTOTP
 Local Integer NUMJR
 Raz [L]DATCAL,H_TRAV,H_ABSTOT,[L]H_ABSTOTP

#[L]NBJR
#[L]D_ABSFIN
#[L]D_ABSDEB
#[L]H_ABSFIN
#[L]H_ABSDEB
#H_MATDEB
#H_MATFIN
#H_APMDEB
#H_APMFIN
[L]DATCAL=[L]D_ABSDEB

 #Dbgaff
 While [L]DATCAL<=[L]D_ABSFIN
     # On verrifie que l'absence ne contient pas un jour d'indisponibilitûˋ.
     Case I
          When 0 : [L]YI=find([L]DATCAL,[L]D0_INDDEB(0..[L]NB_IND(0)))
          When 1 : [L]YI=find([L]DATCAL,[L]D1_INDDEB(0..[L]NB_IND(1)))
          When 2 : [L]YI=find([L]DATCAL,[L]D2_INDDEB(0..[L]NB_IND(2)))
     Endcase

     If [L]YI=0 Then
     [L]NUMJR=dayn([L]DATCAL)-1
         #On verrifier que le jour d'absence est jour de travail
         #On note aussi le temps de travail de la journûˋe.
         If [F:AUS]UVYDAY([L]NUMJR)=2  Then

             If [L]D_ABSDEB=D_ABSFIN then # Abs d'un jour
                 If [L]H_ABSFIN-[L]H_ABSDEB>=[F:AUS]HOUWKDDAY([L]NUMJR) Then #"Abs d'un jour complet"
                     [L]H_ABSTOT+=[F:AUS]HOUWKDDAY([L]NUMJR)
                 Elsif ([L]H_ABSFIN<=[L]H_MATFIN) or ([L]H_ABSDEB>=[L]H_APMDEB) Then
                     [L]H_ABSTOT+=[L]H_ABSFIN-[L]H_ABSDEB
                 Else
                     [L]H_ABSTOT+=[L]H_MATFIN-[L]H_ABSDEB
                     [L]H_ABSTOT+=[L]H_APMDEB-[L]H_ABSFIN
                 Endif
             #    Call ECR_TRACE("      -["+format$("DD2",[L]DATCAL)+"] Abs de "+num$([L]H_ABSDEB)+ " û  " +num$([L]H_ABSFIN)+ " soit " + num$([L]H_ABSTOT),0) From GESECRAN # 0: Info, 1: Erreur, -1:
# Avertissement

             Elsif [L]DATCAL=[L]D_ABSDEB & [L]D_ABSDEB<D_ABSFIN then  # Premier jour d'Abs
                 If [L]H_ABSDEB<=[L]H_MATFIN Then
                     [L]H_ABSTOTP=([L]H_MATFIN-[L]H_ABSDEB)+([L]H_APMFIN-H_APMDEB)
                     If [L]H_ABSTOTP>=[F:AUS]HOUWKDDAY([L]NUMJR) Then
                         [L]H_ABSTOT+=[F:AUS]HOUWKDDAY([L]NUMJR)
                     Else
                         [L]H_ABSTOT+=[L]H_ABSTOTP
                     Endif
                     Raz [L]H_ABSTOTP
                 Else
                     [L]H_ABSTOT+=[L]H_APMFIN-[L]H_ABSDEB
                 Endif
              #   Call ECR_TRACE("      -["+format$("DD2",[L]DATCAL)+"] Abs de "+num$([L]H_ABSDEB)+ " û  " +num$([L]H_APMFIN)+ " soit " + num$([L]H_ABSTOT),0) From GESECRAN # 0: Info, 1: Erreur, -1:
# Avertissement

             Elsif [L]DATCAL=D_ABSFIN & [L]D_ABSDEB<D_ABSFIN then  # Dernier jour d'Abs
                 If [L]H_ABSFIN>=H_APMDEB Then
                     [L]H_ABSTOTP=[L]H_ABSFIN-H_MATDEB
                     If [L]H_ABSTOTP>=[F:AUS]HOUWKDDAY([L]NUMJR) Then
                         [L]H_ABSTOT+=[F:AUS]HOUWKDDAY([L]NUMJR)
                     Else
                         [L]H_ABSTOT+=[L]H_ABSTOTP
                     Endif
                     Raz [L]H_ABSTOTP
                 Elsif [L]H_ABSFIN<[L]H_APMDEB Then
                     [L]H_ABSTOT+=[L]H_ABSFIN-[L]H_MATDEB
                 Else
                     [L]H_ABSTOT+=([L]H_MATFIN-[L]H_MATDEB)+([L]H_ABSFIN-[L]H_APMDEB)
                 Endif
                 Call ECR_TRACE("      -["+format$("DD2",[L]DATCAL)+"] Abs de "+num$([L]H_MATDEB)+ " û  " +num$([L]H_ABSFIN)+ " soit " + num$([L]H_ABSTOT),0) From GESECRAN # 0: Info, 1: Erreur, -1:
# Avertissement
             Else
                 [L]H_ABSTOT+=[F:AUS]HOUWKDDAY([L]NUMJR)
                 Call ECR_TRACE("      -["+format$("DD2",[L]DATCAL)+"] une journûˋe soit " + num$([L]H_ABSTOT),0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
             Endif

             If [L]H_ABSTOT<>0 Then
                 [L]TPABS(I)+=[L]H_ABSTOT
                 Call ECR_TRACE("      -["+format$("DD2",[L]DATCAL)+"] une journûˋe soit " + num$([L]H_ABSTOT),0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
                 Raz[L]H_ABSTOT
             Endif
         Endif
     Endif
     DATCAL+=1
 Wend
 #Call ECR_TRACE("----Total Abs ["+format$("DD2",[L]D_ABSDEB) +"] [" +format$("DD2",D_ABSFIN )+"] soit " + num$([L]TPABS(I)),0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement

Return
###############################################################################################################


###############################################################################################################
$HEUR_PRESEN
 Local Char YVALPAR(30)(6)
 Local Char YPARAM(30)(6)
 Local Decimal H_MATDEB,H_MATFIN
 Local Decimal H_APMDEB,H_APMFIN

 YPARAM(0)="XMORBEG"
 YPARAM(1)="XMOREND"
 YPARAM(2)="XAFTBEG"
 YPARAM(3)="XAFTEND"
 YPARAM(4)="XARRMIN"
 YPARAM(5)="XTIMDAY"
 Raz [L]YVALPAR
 #Call ECR_TRACE(" --1-Lecture au nivau le plus fin",-1) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
 For I=0 To 5
 #    Call PARAMUTIL([L]YPARAM(I),[L]YVALPAR(I),[F:AUS]USR,[F:AUS]FCYT) From SUBAUS
     If YVALPAR(I)<>"" Then
      #  Call ECR_TRACE(" --1-"+[L]YPARAM(I)+" /"+[L]YVALPAR(I),-1) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
     Endif
 Next

 If YVALPAR="" Then
 #    Call ECR_TRACE(" --2-Lecture au nivau plus haut ",-1) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
     For I=0 To 5
         Call PARAM([F:AUS]FCYT,[L]YPARAM(I),[L]YVALPAR(I)) From ADOVAL
         If YVALPAR(I)<>"" Then
         #   Call ECR_TRACE(" --2-"+[L]YPARAM(I)+" /"+[L]YVALPAR(I),-1) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
         Endif
     Next
 Endif

 H_MATDEB=val(left$([L]YVALPAR(0),2))+(val(right$([L]YVALPAR(0),4))/60)
 H_MATFIN=val(left$([L]YVALPAR(1),2))+(val(right$([L]YVALPAR(1),4))/60)
 H_APMDEB=val(left$([L]YVALPAR(2),2))+(val(right$([L]YVALPAR(2),4))/60)
 H_APMFIN=val(left$([L]YVALPAR(3),2))+(val(right$([L]YVALPAR(3),4))/60)
 Call ECR_TRACE("    -Matin de "+num$([L]H_MATDEB)+" û  "+num$([L]H_MATFIN) +" aprû´s-midi de "+num$([L]H_APMDEB)+ " û  "+num$([L]H_APMFIN),0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement


Return
###############################################################################################################


###############################################################################################################
$PERIODE
 Raz [L]DATEDEB,[L]DATEFIN,I,DATETRT
 [L]DATEREF=gdat$(01,month([L]DATEREF),year([L]DATEREF))
 For I=0 To 2
     DATEDEB(I)=addmonth([L]DATEREF,-I)
     DATEFIN(I)=eomonth([L]DATEDEB(I))
 Next
 Raz I,[L]DATETRT
Return
###############################################################################################################


###############################################################################################################
$ECRITURE
 [L]WNUMLIG = WNUMLIG + 1
 Call ECR_TRACE(" 7-Ecriture LgNum " + num$([L]WNUMLIG),0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement


 [F:XX03TR]NUMREQ       = [L]NUMREQ
 [F:XX03TR]USR          = GUSER
 [F:XX03TR]RPTCOD       = [L]ETAT
 [F:XX03TR]NUMLIG       = WNUMLIG

 [F:XX03TR]USRITV       = [F:AUS]USR
 [F:XX03TR]FCYT         = [F:AUS]FCYT
 [F:XX03TR]CATPRIINT    = [F:AUS]CATPRIINT
 [F:XX03TR]IUSHIE       = [F:AUS]IUSHIE
 [F:XX03TR]XGRPUTIL     = [L]GRPCLASS

 [F:XX03TR]MOIS1        = month$(DATEREF)
 [F:XX03TR]MOIS2        = month$(month(DATEREF)-1)
 [F:XX03TR]MOIS3        = month$(month(DATEREF)-2)

 [F:XX03TR]POT1         = [L]TPPOT(0)
 [F:XX03TR]POT2         = [L]TPPOT(1)
 [F:XX03TR]POT3         = [L]TPPOT(2)


 [F:XX03TR]ABS1         = [L]TPABS(0)
 [F:XX03TR]ABS2         = [L]TPABS(1)
 [F:XX03TR]ABS3         = [L]TPABS(2)

 [F:XX03TR]FACT1        = [L]TPFAC(0)
 [F:XX03TR]FACT2        = [L]TPFAC(1)
 [F:XX03TR]FACT3        = [L]TPFAC(2)

 [F:XX03TR]NFACT1       = [L]TPNFAC(0)
 [F:XX03TR]NFACT2       = [L]TPNFAC(1)
 [F:XX03TR]NFACT3       = [L]TPNFAC(2)

 [F:XX03TR]NSAISIE1     =[L]TPPOT(0)-([L]TPABS(0)+[L]TPFAC(0)+[L]TPNFAC(0))
 [F:XX03TR]NSAISIE2     =[L]TPPOT(1)-([L]TPABS(1)+[L]TPFAC(1)+[L]TPNFAC(1))
 [F:XX03TR]NSAISIE3     =[L]TPPOT(2)-([L]TPABS(1)+[L]TPFAC(2)+[L]TPNFAC(2))

 [F:XX03TR]DATEDEB(0)=[L]DATEDEB(0)
 [F:XX03TR]DATEDEB(1)=[L]DATEDEB(1)
 [F:XX03TR]DATEDEB(2)=[L]DATEDEB(2)

 [F:XX03TR]DATEFIN(0)=[L]DATEFIN(0)
 [F:XX03TR]DATEFIN(1)=[L]DATEFIN(1)
 [F:XX03TR]DATEFIN(2)=[L]DATEFIN(2)

 Write [F:XX03TR]
 If fstat
     GOK=0 : Call FSTA("XX03TR") From GLOCK
 Endif

Return
###############################################################################################################


###############################################################################################################
$DECLARE
 #--De Travail
 Local Char    CRITERE(255), CRITSUP(100), PARAM(30), VALEUR(30), ETAT(20),GRPCLASS(30)
 Local Integer NUMREQ, WNUMLIG, I, J,IMPR, TRAITAUTO
 Local Date    DATETRT


 #--Utilisateur
 Local Date    DATEREF : DATEREF = [16/02/2015]
 Local Char    GRPCLASSDEB(100),GRPCLASSFIN(100),USRITVDEB(50),USRITVFIN(50),CODECLASS(100)

 #--Groupes(GRPCLASS)
 Local Integer XI,ZI,YCODOK
 Local Char    YCODE(30)

 #--Indisponibilitûˋ(INDISPONIBILITE)
 Read [TUV]Last
 Local Date    D0_INDDEB(dim([F:TUV]UVYSTRDAT)),D0_INDFIN(dim([F:TUV]UVYSTRDAT))
 Local Date    D1_INDDEB(dim([F:TUV]UVYSTRDAT)),D1_INDFIN(dim([F:TUV]UVYSTRDAT))
 Local Date    D2_INDDEB(dim([F:TUV]UVYSTRDAT)),D2_INDFIN(dim([F:TUV]UVYSTRDAT))
 Local Integer NB_IND(3),YI, NBUSR,NBUSER2

 #--Pûˋriode
 Local Date DATEDEB(3),DATEFIN(3)

 #--Potentielle travail
  Local Decimal TPPOT(3)

Return
###############################################################################################################


###############################################################################################################
$GRPCLASS
     Local Integer XI,ZI,YCODOK
     Local Char    YCODE(30)
     Raz  XI,ZI,YCODOK,YCODE
     While ZI<len([F:AUS]XGRPUTIL)
           XI = instr(XI,[F:AUS]XGRPUTIL,";")
           If XI = 0
              Break
           Endif
           ZI = instr(XI+1,[F:AUS]XGRPUTIL,";")
           If ZI = 0
              ZI = len([F:AUS]XGRPUTIL)+1
           Endif
           # On parcourt les groupes rubriques associûˋs a l utilisateur
           [L]YCODE = seg$([F:AUS]XGRPUTIL,XI+1,ZI-1)
           XI = ZI
           ZI += 1

           If ([L]YCODE >=[L]GRPCLASSDEB & [L]YCODE <=[L]GRPCLASSFIN) or  [L]YCODOK=2  Then
              [L]YCODOK=2
              If ([L]YCODE >=[L]GRPCLASSDEB & [L]YCODE <=[L]GRPCLASSFIN) & len([L]GRPCLASS)=0 Then
                 [L]GRPCLASS=[L]YCODE
              Endif
           Else
              [L]YCODOK=1
           Endif

     Wend
 #Infbox([F:AUS]USR +" ["+[L]GRPCLASSDEB + "-" +[L]YCODE +"-" +[L]GRPCLASSFIN + "]"+"- ["+ num$([L]YCODOK) )
 Return
###############################################################################################################


###############################################################################################################
$PARAMETRE
 Local Char FCYTDEB,FCYTFIN,CATEGDEB, CATEGFIN, GRPCLASSDEB, GRPCLASSFIN
 Local Char USRITVDEB, USRITVFIN, SUPHIERARDEB, SUPHIERARFIN

 [L]TRAITAUTO = 0
 [L]CRITERE = "1=1"
 [L]CRITSUP = "1=1"

 For I=1 To NBPAR
     J=instr(1,[L]PARAMETRE(I),"=")
     If J
        [L]PARAM  = left$([L]PARAMETRE(I),J-1)
        [L]VALEUR = right$([L]PARAMETRE(I),J+1)
        Case [L]PARAM
            When "X3ETA"           : [L]ETAT         = [L]VALEUR
            When "__REQUETE"       : [L]NUMREQ       = val([L]VALEUR)
            When "numedt"          : [L]PARAMETRE(I) = "numedt="       +num$([L]NUMREQ)
            When "usr"             : [L]PARAMETRE(I) = "usr="          +GUSER
            When "etat"            : [L]PARAMETRE(I) = "etat="         +[L]ETAT
            When "sitedeb"         : [L]FCYTDEB      = [L]VALEUR
            When "sitefin"         : [L]FCYTFIN      = [L]VALEUR
            When "categdeb"        : [L]CATEGDEB     = [L]VALEUR
            When "categfin"        : [L]CATEGFIN     = [L]VALEUR
            When "grpclassdeb"     : [L]GRPCLASSDEB  = [L]VALEUR
            When "grpclassfin"     : [L]GRPCLASSFIN  = [L]VALEUR
            When "usritvdeb"       : [L]USRITVDEB    = [L]VALEUR       :[L]CRITERE -= "& USR>='" +[L]USRITVDEB+"'"
            When "usritvfin"       : [L]USRITVFIN    = [L]VALEUR       :[L]CRITERE -= "& USR<='" +[L]USRITVFIN+"'"
            When "suphierardeb"    : [L]SUPHIERARDEB = [L]VALEUR
            When "suphierarfin"    : [L]SUPHIERARFIN = [L]VALEUR
            When "dateref"         : [L]DATEREF      = [L]VALEUR
        Endcase
      Endif
 Next

 If [L]FCYTDEB      =" " Then : [L]FCYTDEB      ="" : Endif
 If [L]CATEGDEB     =" " Then : [L]CATEGDEB     ="" : Endif
 If [L]GRPCLASSDEB  =" " Then : [L]GRPCLASSDEB  ="" : Endif
 If [L]USRITVDEB    =" " Then : [L]USRITVDEB    ="" : Endif
 If [L]SUPHIERARDEB =" " Then : [L]SUPHIERARDEB ="" : Endif

 [L]CRITERE     -= "& FCYT>='"      +[L]FCYTDEB      +"'"
 [L]CRITERE     -= "& FCYT<='"      +[L]FCYTFIN      +"'"
 [L]CRITERE     -= "& CATPRIINT>='" +[L]CATEGDEB     +"'"
 [L]CRITERE     -= "& CATPRIINT<='" +[L]CATEGFIN     +"'"
 [L]CRITERE     -= "& USR>='"       +[L]USRITVDEB    +"'"
 [L]CRITERE     -= "& USR<='"       +[L]USRITVFIN    +"'"
 [L]CRITERE     -= "& IUSHIE>='"    +[L]SUPHIERARDEB +"'"
 [L]CRITERE     -= "& IUSHIE<='"    +[L]SUPHIERARFIN +"'"

  Call ECR_TRACE("Liste de param",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
  Call ECR_TRACE("   Borne de sites         : " + [L]FCYTDEB      +" û  "+ [L]FCYTFIN,0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
  Call ECR_TRACE("   Bornes des catûˋgories  : " + [L]CATEGDEB     +" û  "+ [L]CATEGFIN,0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
  Call ECR_TRACE("   Groupe classification  : " + [L]GRPCLASSDEB  +" û  "+ [L]GRPCLASSFIN,0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
  Call ECR_TRACE("   Borne Intervenants     : " + [L]USRITVDEB    +" û  "+ [L]USRITVFIN,0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
  Call ECR_TRACE("   Supûˋrieur hiûˋrarchique : " + [L]SUPHIERARDEB +" û  "+ [L]SUPHIERARFIN,0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
  Call ECR_TRACE("   Date de rûˋfûˋrence      : " + format$("DD2",[L]DATEREF),0)From GESECRAN
  Call ECR_TRACE("       Filtre             : Utilisateurs actifs uniqueent ",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement
  Call ECR_TRACE("    ",0) From GESECRAN # 0: Info, 1: Erreur, -1: Avertissement

Return
