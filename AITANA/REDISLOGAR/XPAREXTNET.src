$ACTION

Gosub ACTION From XPAREXTNET2

Return

######################################################################################
Subprog C_ITVTYPC(VALEUR)
Variable Char    VALEUR()
Local Integer I
[L]I=find(VALEUR,[M:XEN4]ITVTYPI(0..[M:XEN4]BASTAB2-1))
If [L]I>0
  [V]GMESSAGE=mess(24,123,1)-num$([L]I)
  [V]GERR=1
  mkstat=1
Endif
End


######################################################################################
Subprog C_ITVTYPI(VALEUR)
Variable Char    VALEUR()
Local Integer I
[L]I=find(VALEUR,[M:XEN4]ITVTYPC(0..[M:XEN4]BASTAB1-1))
If [L]I>0
  [V]GMESSAGE=mess(24,123,1)-num$([L]I)
  [V]GERR=1
  mkstat=1
Endif
End
