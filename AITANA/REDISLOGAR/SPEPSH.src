######################################################################################
$ACTION
Case ACTION
  When Default
Endcase
Return
######################################################################################
## YA020 - Tipo de precio
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
Read [F:ZITM]ITM0 = VALEUR
If fstat = 0
  [M:PSH1]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
  Affzo [M:PSH1]YTIPPRI(nolign -1)
Endif

Case [M:PSH1]YTIPPRI(nolign -1)
  When 1 : [M:PSH1]YGROPRI(nolign -1) = [M:PSH1]NETPRI(nolign -1)
  When 2 : [M:PSH1]YGROPRI(nolign -1) = [M:PSH1]NETPRI(nolign -1) * 10
  When 3 : [M:PSH1]YGROPRI(nolign -1) = [M:PSH1]NETPRI(nolign -1) * 100
  When 4 : [M:PSH1]YGROPRI(nolign -1) = [M:PSH1]NETPRI(nolign -1) * 1000
Endcase
Affzo [M:PSH1]YGROPRI(nolign -1)

End
######################################################################################
## YA020 - Tipo de precio
######################################################################################
Subprog AM_YGROPRI(VALEUR)
Variable Decimal VALEUR

Variable Decimal PRECIO

Case [M:PSH1]YTIPPRI(nolign -1)
  When 1 : PRECIO  = VALEUR
  When 2 : PRECIO  = VALEUR / 10
  When 3 : PRECIO  = VALEUR / 100
  When 4 : PRECIO  = VALEUR / 1000
Endcase

# Llamamos a las funciones del campo GROPRI, como si se hubiese modificdo en pantalla
#Call AP_NETPRI(PRECIO) From SUBPSH
#Call PAMAPPFLG("PSH1",nolign-1,"GROPRI") From TRTACHAPP1
#Call PAMDISCRG( PRECIO , "PSH1" , 0 , nolign-1 , [M:PSH1]NETCUR(nolign-1)) From TRTACHPRI1
#Call PAMVATFLG("PSH1",nolign-1,"GROPRI") From TRTACHFAC1
Call AM_NETPRI(PRECIO) From SUBPSH

# Finalmente actualizamos el campo standard
[M:PSH1]NETPRI(nolign -1) = PRECIO
Affzo [M:PSH1]NETPRI(nolign -1)

End
######################################################################################
## YA020 - Tipo de precio
######################################################################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()

If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
Read [F:ZITM]ITM0 = [M:PSH1]ITMREF(nolign -1)
If fstat = 0
  [M:PSH1]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
  Affzo [M:PSH1]YTIPPRI(nolign -1)
Endif

Case [M:PSH1]YTIPPRI(nolign -1)
  When 1 : [M:PSH1]YGROPRI(nolign -1) = [M:PSH1]NETPRI(nolign -1)
  When 2 : [M:PSH1]YGROPRI(nolign -1) = [M:PSH1]NETPRI(nolign -1) * 10
  When 3 : [M:PSH1]YGROPRI(nolign -1) = [M:PSH1]NETPRI(nolign -1) * 100
  When 4 : [M:PSH1]YGROPRI(nolign -1) = [M:PSH1]NETPRI(nolign -1) * 1000
Endcase
Affzo [M:PSH1]YGROPRI(nolign -1)

End


######################################################################################

