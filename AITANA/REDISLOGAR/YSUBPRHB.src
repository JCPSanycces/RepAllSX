#####################################################################################
# CodAct: YA032 - Textos de Cabecera Traspasables
#####################################################################################

$ACTION
Case ACTION
    When "BEFWRIPRH"    : Gosub BEFWRIPRH
    #When "CHG_ALLTYP"       : Gosub CHG_ALLTYP
    When "BEGWRIPRE"    : Gosub BEFWRIPRE
Endcase
Return

#####################################################################################

$BEFWRIPRH
# <YA032> - Textos de Cabecera Traspasables
If [F:PRH]YPRHTEX <> "" | [F:SOH]YSOHTEX <> ""
 [F:PRH]YPRHTEX = [F:SOH]YSOHTEX
Endif
[F:PRH]YBPCNAM = [F:SOH]BPCNAM

# </YA032>
Return

#####################################################################################
#Durante el arranque se decide volver a poner la asignación detallada en vales de preparación, y comento el desarrollo
#$CHG_ALLTYP
# Cambio el tipo de asignación del vale de preparación generado desde el botón del pedido de venta a global
# Asignarán desde la pistola

#WALLTYPFLG = 1

#Return


#####################################################################################

$BEFWRIPRE
#Llevo importes de línea del pedido al vale
[F:PRE]YNETPRI = [F:SOP]NETPRI
[F:PRE]YAMTNOTLIN = [F:SOP]NETPRI * [F:PRE]QTYSTU

Return











