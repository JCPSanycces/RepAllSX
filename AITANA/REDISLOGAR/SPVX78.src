$ACTION
Gosub ACTION From SPVOBJX78
Return

######################################################################################
Subprog C_PARAMVAR(VALEUR)
Variable Char    VALEUR()
If [M:XWO2]PARAMOBL(nolign-1) = 2 & VALEUR=""
  GMESSAGE = mess(10,123,1)
  mkstat = 2
Endif
End

######################################################################################
Subprog C_PARAMSER(VALEUR)
Variable Char    VALEUR()
If [M:XWO2]PARAMOBL(nolign-1) = 2 & VALEUR=""
  GMESSAGE = mess(10,123,1)
  mkstat = 2
Endif
End

######################################################################################
Subprog AM_PARAMTYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>1
  Raz [M:XWO2]PARAMSER(nolign-1)
  Affzo [M:XWO2]PARAMSER(nolign-1)
Endif
End

