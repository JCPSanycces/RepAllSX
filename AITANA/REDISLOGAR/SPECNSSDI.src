######################################################################################
## Etiqueta añadida por el supervisor (pantalla CONSSDI1) 18/02/2020 11:42:21 (AIT04)
######################################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
# Llamo fuente para que salte selector de artículo-cliente
If [M:SDI1]YCLIENTE <> ""
  Local Integer CUENTA
  Local Char LLIN (200) (250)
  Local Char DES (200) (250)
  Local Char COD (200) (250)

  If !clalev([PP1]) : Local File ITMBPC [PP1] : Endif
  Filter [PP1] Where [PP1]BPCNUM = [M:SDI1]YCLIENTE and instr(1,evalue("[F:PP1]ITMDESBPC"),toupper(VALEUR)) > 0 Order By [F:PP1]ITMDESBPC Asc
    For [PP1]
      LLIN(CUENTA) = vireblc(("C.X3: " + [F:PP1]ITMREF +  " ** C.Cliente: " + [F:PP1]ITMREFBPC + " ** D.cliente: " + [F:PP1]ITMDESBPC),2)
      COD(CUENTA) = [F:PP1]ITMREFBPC
      DES(CUENTA) = [F:PP1]ITMDESBPC
      CUENTA +=1
      If CUENTA = 250 : Break : Endif
    Next
  Filter [BPC]

  If CUENTA = 0
      Local Char ERROR (250)
      ERROR = "No hay ningún artículo con la descripción cliente '" + VALEUR + "'"
      Errbox ERROR
  Elsif CUENTA = 1
      VALEUR  = [F:PP1]ITMREF
  Else
      Local Char LART
      Local Integer LRES
      Selbox LLIN(0..CUENTA-1) Titled "Selección de artículos" Using LRES
      If LRES <> 0 Then
          Local Integer I,J
          For I=0 To 200
            If mid$(LLIN(LRES-1),I,2)='**'
              J=I
              Break
            Endif
          Next
          VALEUR = mid$(LLIN(LRES-1),7,J-8)
      Endif
  Endif

  Close Local File [PP1]
Endif

# Controlo la existencia del artículo-planta
If !clalev([PP2]) : Local File ITMFACILIT [PP2] : Endif
Read [PP2]ITF0 = VALEUR;[M:SDI1]FCY
If fstat <> 0
  Errbox "Artículo - planta no definido"
  mkstat = 2
Endif
Close Local File [PP2]
End


######################################################################################
Subprog IB_ITMREF
# Si he puesto cliente, habilito la opción de artículo-cliente
If [M:SDI1]YCLIENTE <> ""
  GBOUT6 = "Selección artículo - cliente"
Else
  GBOUT6 = ""
Endif
End


######################################################################################
Subprog B6_ITMREF(VALEUR)
Variable Char    VALEUR()
# Selección de todos los artículos-clientes

If !clalev([PP1]) : Local File ITMBPC [PP1] : Endif

Choose [PP1] Where [PP1]BPCNUM = [M:SDI1]YCLIENTE  Using
& [PP1]ITMREF Titled "Código REDISLOGAR",
& [PP1]ITMREFBPC Titled "Código CLIENTE",
& [PP1]ITMDESBPC Titled "Descripción CLIENTE",
& [PP1]BPCNUM Titled "Cliente"
& Sized (80,240)
& Titled "Selección de artículos - cliente"
If !fstat Then
    VALEUR = [PP1]ITMREF
Else
  Infbox "Ningún registro selecciónado"
Endif

Close Local File [PP1]
End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla CONSSDI1) 18/02/2020 12:22:24 (AIT04)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Read [ITM]ITM0 = VALEUR
If fstat = 0
  [M:SDI1]YITMDES = [ITM]ITMDES1
  Affzo [M:SDI1]YITMDES
Endif
End


