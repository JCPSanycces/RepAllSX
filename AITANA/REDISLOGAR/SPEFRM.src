$ACTION

Case ACTION
  When "FILTRE"  : Gosub FILTRE
Endcase

Return

#####################################################################################

$FILTRE

# Elimino el valor de GBIDC2, en ocasiones trae el valor "citas depuradas" y no se puede acceder a ninguna remesa
# Pendiente revisión

If GPILNAV > 1
  If GNAVIG(GPILNAV-1) = "GESFRM"
    FILTSUP="[F:FRM]FRMFLG=1"

    GPE = 1

  Endif
Endif

Return

