#-----------------------------------
Subprog AS_VALRUB(VALEUR)
Value Integer VALEUR

Local Integer RUBPDET
Raz [L]RUBPDET
For [F:SRP]SRP1 Where [F:SRP]PLANCOD=[M:SDL0]PLANCOD & [F:SRP]RUBTYP=1
  If [F:SRP]RUBSELTYP=2 : [L]RUBPDET=1 : Break : Endif
Next

If !clalev([F:AOB]) : Local File AOBJET : Endif

Read [F:SHP]SHP0=[M:SDL0]PLANCOD
If fstat : End : Endif
Read [F:SRP]SRP0=[M:SDL0]PLANCOD;VALEUR
If fstat : mkstat=1 : End : Endif
 
If VALEUR>[F:SHP]NBLIG
  mkstat=1
Elsif ([F:SRP]RUBSELTYP=1 & ![L]RUBPDET) | [M:SDL0]NUMSVP(nolign-1)<>0
  mkstat=2
Else
  Raz [V]GBOUT1
  Read [F:AOB]ABREV=[F:SRP]RUBOBJ
  If !fstat
    Call TEXTE([F:AOB]LIBEL,[V]GBOUT1) From OBJDIV
  Endif
Endif

End

#-----------------------------------
Subprog AV_VPCLE(VALEUR)
Variable Char    VALEUR()
VALEUR=[M:SDL0]VP1(nolign-1)+chr$(254)+[m:sdl0]vp2(nolign-1)+chr$(254)+[m:sdl0]vp3(nolign-1)
End

