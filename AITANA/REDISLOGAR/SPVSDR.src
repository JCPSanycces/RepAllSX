#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du masque SCHDETI0
#ACV#X13
#TIT#Gestion de l'objet SDR

#LBO 07/2002

GBIDC1=""
GBIDC2=""
Call OBJET("SDR",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet SDR
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "DEBUT_MOD"   : Gosub DEBUT_MOD   From SPVOBJSDR
  When "FILTRE"      : Gosub FILTRE      From SPVOBJSDR
  When "LIENS2"      : Gosub LIENS2      From SPVOBJSDR
  When "OUVRE"       : Gosub OUVRE       From SPVOBJSDR
  When "SETBOUT"     : Gosub SETBOUT     From SPVOBJSDR
  When "VERF_ANU"    : Gosub VERF_ANU    From SPVOBJSDR
  When "MODIF"       : Gosub MODIF       From SPVOBJSDR
  When "VERIF_MOD"   : Gosub VERIF_MOD   From SPVOBJSDR
  When "VERIF_CRE"   : Gosub VERIF_CRE   From SPVOBJSDR
  When "APRES_MOD"   : Gosub APRES_MOD   From SPVOBJSDR
  When "APRES_CRE"   : Gosub APRES_CRE   From SPVOBJSDR
  When "AB_MODIF"    : Gosub AB_MODIF    From SPVOBJSDR
  When "AB_CREATION" : Gosub AB_CREATION From SPVOBJSDR
Endcase

Return

#####################################################################################
# Ecran SCHDETL0 [SDL0]
#####################################################################################

#-----------------------------------
Subprog C_NBLIG

# Status 73 : Insertion
#        82 : Ajout
#        65 : Annulation

# Test annulation multiple refusée (contrôle car Pb options de la variable de bas de tableau)
If status=83 : mkstat=1 : End : Endif

Case status
  When 65,73,82
    mkstat=1
    For [F:SRP]SRP1 Where [F:SRP]PLANCOD=[M:SDL0]PLANCOD & [F:SRP]RUBTYP=1
      If [F:SRP]RUBSELTYP=2
        mkstat=0 : Break
      Endif
    Next
    If status=65 & !mkstat
      Read [F:AGD]AGD0(4)=[M:SDL0]PLANCOD;[M:SDL0]VP1(nolign-1);[M:SDL0]VP2(nolign-1);[M:SDL0]VP3(nolign-1)
      If !fstat
        [V]GMESSAGE="Ligne déjà plannifiée à partir du"-format$("D:DD[/]MM[/]YYYY",[F:AGD]BEGDAT)
        [V]GMESSAGE+="\Suppression impossible"
        mkstat=1
      Endif
    Endif
Endcase
End

#-----------------------------------
Subprog APRES_NBLIG

Local Integer I, NBP, NBS
Local Char ZVAL(50), ZVALD(50)

Raz [M:SDL0]VP1(nolign-1),[M:SDL0]VP2(nolign-1),[M:SDL0]VP3(nolign-1),[M:SDL0]VPCLE(nolign-1)
&  ,[M:SDL0]VS1(nolign-1),[M:SDL0]VS2(nolign-1),[M:SDL0]VS3(nolign-1),[M:SDL0]VS4(nolign-1),[M:SDL0]VS5(nolign-1)
&  ,[M:SDL0]VS6(nolign-1),[M:SDL0]VS7(nolign-1),[M:SDL0]VS8(nolign-1),[M:SDL0]VS9(nolign-1)
&  ,[M:SDL0]VD1(nolign-1),[M:SDL0]VD2(nolign-1),[M:SDL0]VD3(nolign-1)
&  ,[L]NBP, [L]NBS, [L]I

For [F:SRP]SRP0 Where [F:SRP]PLANCOD=[M:SDL0]PLANCOD
  [L]ZVAL=evalue("[M:SDL0]VALRUB"+num$([L]I+1)+"(nolign-1)")
  [L]ZVALD=evalue("[M:SDL0]DESRUB"+num$([L]I+1)+"(nolign-1)")
  If [F:SRP]RUBTYP=1
    [L]NBP+=1
    Assign "[M:SDL0]VP"+num$([L]NBP)+"(nolign-1)" With [L]ZVAL
    Assign "[M:SDL0]VD"+num$([L]NBP)+"(nolign-1)" With [L]ZVALD
    Assign "[M:SDL0]VLIGP"+num$([L]NBP)+"(nolign-1)" With [F:SRP]RUBLIG
    If [L]NBP>1
      [M:SDL0]VPCLE(nolign-1)+=chr$(254)+[L]ZVAL
    Else
      [M:SDL0]VPCLE(nolign-1)=[L]ZVAL
    Endif      
  Else
    [L]NBS+=1
    Assign "[M:SDL0]VS"+num$([L]NBS)+"(nolign-1)" With [L]ZVAL
  Endif
  [L]I+=1
Next
For [L]I=[L]NBP To 2
  [M:SDL0]VPCLE(nolign-1)+=chr$(254)
Next
End

