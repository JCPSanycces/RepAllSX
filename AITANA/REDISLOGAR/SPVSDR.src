#-----------------------------------
Subprog D_RUBLIG(ZNUM,VALEUR)
Value Integer ZNUM
Variable Decimal VALEUR

Read [F:SHP]SHP0=[M:SDL0]PLANCOD
If fstat | [L]ZNUM>[F:SHP]NBLIG : End : Endif
Read [F:SRP]SRP0=[M:SDL0]PLANCOD;[L]ZNUM
If !fstat
  VALEUR=[F:SRP]RUBLIG
Endif

End

#-----------------------------------
Subprog AS_CODCHO(VALEUR)
Variable Char    VALEUR()

If VALEUR=""
  Read [F:SRC]SRC2=[M:SDL0]PLANCOD;1
  If !fstat
    VALEUR=[F:SRC]CODCHO
  Endif
Endif
End

#-----------------------------------
Subprog AV_ENAFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=0
  VALEUR=2
Endif
End

