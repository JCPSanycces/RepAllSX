#-----------------------------------
Subprog C_VALRUB(ZNUM,VALEUR)
Value Char VALEUR
Value Integer ZNUM

Local Integer NBP, I, NUMP
Local Char ZCLE(200), ZVAL(100)

Read [F:SRP]SRP0=[M:SDL0]PLANCOD;[L]ZNUM
If !fstat & ([F:SRP]RUBTYP=1 | [F:SRP]RUBOBY=2) & VALEUR=""
  [V]GMESSAGE=mess(10,123,1)
  mkstat=1
Else
  Raz [L]ZCLE, [L]NBP, [L]NUMP, [L]I
  For [F:SRP]SRP0 Where [F:SRP]PLANCOD=[M:SDL0]PLANCOD
    If [F:SRP]RUBTYP=1
      [L]NBP+=1
      [L]NUMP=[L]I+1
      If [L]NUMP=[L]ZNUM
        [L]ZVAL=VALEUR
      Else
        [L]ZVAL=evalue("[M:SDL0]VALRUB"+num$([L]I+1)+"(nolign-1)")
      Endif
      If [L]NBP>1
        [L]ZCLE+=chr$(254)+[L]ZVAL
      Else
        [L]ZCLE+=[L]ZVAL
      Endif
    Endif      
    [L]I+=1
  Next
  If [L]NUMP=[L]ZNUM
    [M:SDL0]VPCLE(nolign-1)=[L]ZCLE
    For [L]I=[L]NBP To 2
      [M:SDL0]VPCLE(nolign-1)+=chr$(254)
    Next
    Call UNICITE([M:SDL0]VPCLE(NOLIGN-1),[M:SDL0]VPCLE) From OBJDIV
  Endif
Endif
End


