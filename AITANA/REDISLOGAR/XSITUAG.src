Subprog C_XEXTRCPDAT(VALEUR)
Variable Date    VALEUR

If VALEUR=[0/0/0]
  If [M:XS1]QTYPUR([M:XS0]XNUMLIG1-1)<>0 | [M:XS1]MNTPUR([M:XS0]XNUMLIG1-1)<>0
    [V]GMESSAGE=mess(10,123,1)
    mkstat=1
  Endif
Else
  Local Date ZDEB
  Read [F:FRL]FRL0=[M:XS1]FRMNUMLIG([M:XS0]XNUMLIG1-1)
  If !fstat
    [L]ZDEB=[F:FRL]CREDATFRM
  Endif
  Call CONT_EXTRCPDAT([M:XS1]STOFCY([M:XS0]XNUMLIG1-1),VALEUR,[L]ZDEB) From SPVOBJFRL
Endif

End

