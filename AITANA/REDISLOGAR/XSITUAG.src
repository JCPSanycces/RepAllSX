#==========================================================================================
Subprog C_XINVSIT2(VALEUR)
Variable Decimal VALEUR
Call VERIF_QTYGEN(3,VALEUR,[M:XS2]FRMNUMLIG([M:XS0]XNUMLIG2-1)) From SPVOBJSIL
# LBORN 27/10/2015 - Mantis 31142
# If !mkstat & VALEUR>[M:XS2]QTY([M:XS0]XNUMLIG2-1) & [M:XS2]INVMOD([M:XS0]XNUMLIG2-1)=6
If !mkstat & VALEUR>([M:XS2]QTY([M:XS0]XNUMLIG2-1)-[M:XS2]XQTEFACTOT) & [M:XS2]INVMOD([M:XS0]XNUMLIG2-1)=6
  [V]GMESSAGE=mess(357,[V]GXMSGPSA,1)-mess(6,1733,1)+"\"+mess(358,[V]GXMSGPSA,1)
  mkstat=1
Endif
End

#==========================================================================================
Subprog C_XINVSIT2M(VALEUR)
Variable Decimal VALEUR
Call VERIF_QTYGEN(3,VALEUR,[M:XS2]FRMNUMLIG([M:XS0]XNUMLIG2-1)) From SPVOBJSIL
# LBORN 27/10/2015 - Mantis 31142
# If !mkstat & VALEUR>[M:XS2]GROPRI([M:XS0]XNUMLIG2-1) & [M:XS2]INVMOD([M:XS0]XNUMLIG2-1)=6
If !mkstat & VALEUR>([M:XS2]GROPRI([M:XS0]XNUMLIG2-1)-[M:XS2]XQTEFACTOTM) & [M:XS2]INVMOD([M:XS0]XNUMLIG2-1)=6
  [V]GMESSAGE=mess(357,[V]GXMSGPSA,1)-mess(6,1733,1)+"\"+mess(45,[V]GXMSGOPP,1)
  mkstat=1
Endif
End

#==========================================================================================
$B_ZOOM

Read [F:FRL]FRL0=[M:XS1]FRMNUMLIG([M:XS0]XNUMLIG1-1)
If fstat : Raz [F:FRL] : Endif

If func SPVOBJPFM.SITINVQTY([F:FRL]TYPFRM)=1
  GBOUT5=mess(47,[V]GXMSGOPP,1) : # Zoom Réel.facturé
  GBOUT6=mess(48,[V]GXMSGOPP,1) : # Zoom Mnt Situations
  GBOUT7=mess(49,[V]GXMSGOPP,1) : # Explication des montants
Else
  GBOUT5=mess(42,[V]GXMSGOPP,1) : # Historique Qtés réel.facturées
  GBOUT6=mess(43,[V]GXMSGOPP,1) : # Historique Qtés Situations
  GBOUT7=mess(44,[V]GXMSGOPP,1) : # Explication des quantités
Endif
Return

#==========================================================================================
$BOUT_ZOOMACH

Raz [V]GBOUT5, [V]GBOUT6, [V]GBOUT7, [V]GBOUT8, [V]GBOUT9, [V]GBOUT10, [V]GBOUT11, [V]GBOUT12

If nolign<=0 : Return : Endif

[V]GBOUT5  =mess(82,[V]GXMSGOPP,1) : # Zoom Livré
[V]GBOUT6  =mess(83,[V]GXMSGOPP,1) : # Zoom Livré Sit. Prec.
[V]GBOUT7  =mess(84,[V]GXMSGOPP,1) : # Zoom Livré depuis S.Pre
[V]GBOUT8  =mess(85,[V]GXMSGOPP,1) : # Zoom Reçu
[V]GBOUT9  =mess(86,[V]GXMSGOPP,1) : # Zoom Reçu Sit. Prec
[V]GBOUT10 =mess(87,[V]GXMSGOPP,1) : # Zoom Reçu depuis Sit.Pr
[V]GBOUT11 =mess(88,[V]GXMSGOPP,1) : # Zoom Commandé
[V]GBOUT12 =mess(89,[V]GXMSGOPP,1) : # Zoom Sit.Préc

If [M:XS1]QTYLIVPREV(nolign-1) =0 : Raz [V]GBOUT6  : Endif
If [M:XS1]QTYLIVDEP(nolign-1)  =0 : Raz [V]GBOUT7  : Endif
If [M:XS1]QTYRECPREV(nolign-1) =0 : Raz [V]GBOUT9  : Endif
If [M:XS1]QTYRECDEP(nolign-1)  =0 : Raz [V]GBOUT10 : Endif

Return

#==========================================================================================
$BOUT_ZOOMREQ

Raz [V]GBOUT14, [V]GBOUT15, [V]GBOUT16, [V]GBOUT17, [V]GBOUT18, [V]GBOUT19

If nolign<=0 : Return : Endif

[V]GBOUT14 =mess(90,[V]GXMSGOPP,1) : # Info DI
[V]GBOUT15 =mess(91,[V]GXMSGOPP,1) : # Zoom Réalisé
[V]GBOUT16 =mess(92,[V]GXMSGOPP,1) : # Zoom Réalisé Sit. Préc.
[V]GBOUT17 =mess(93,[V]GXMSGOPP,1) : # Zoom Réalisé depuis Sit.Préc
[V]GBOUT18 =mess(94,[V]GXMSGOPP,1) : # Zoom Reste à faire
[V]GBOUT19 =mess(95,[V]GXMSGOPP,1) : # Zoom Sit. Préc.

[V]GBIDI1=1

If [M:XS1]REQTYP(nolign-1)=""
  Raz [V]GBOUT14
Elsif !find([V]GREP,"C","D")
  If !func XSITUAG2.AUTOR_MODIF
    [V]GBIDI1=0
  Endif
Endif

If [M:XS1]CPLPREV1(nolign-1)=0 : Raz [V]GBOUT16  : Endif
If [M:XS1]CPLPREV2(nolign-1)=0 : Raz [V]GBOUT17  : Endif

Return

#==========================================================================================
$BOUT_ZOOMOF

Raz [V]GBOUT5, [V]GBOUT6, [V]GBOUT7, [V]GBOUT8, [V]GBOUT9, [V]GBOUT10, [V]GBOUT11, [V]GBOUT12

If nolign<=0 : Return : Endif

[V]GBOUT5=mess(395,[V]GXMSGPSA,1)
[V]GBOUT6=mess(396,[V]GXMSGPSA,1)
[V]GBOUT7=mess(397,[V]GXMSGPSA,1)
[V]GBOUT8=mess(29,[V]GXMSGPSA(1),1)
[V]GBOUT9=mess(30,[V]GXMSGPSA(1),1)
[V]GBOUT10=mess(31,[V]GXMSGPSA(1),1)
[V]GBOUT11=mess(32,[V]GXMSGPSA(1),1)
[V]GBOUT12=mess(33,[V]GXMSGPSA(1),1)

If [M:XS4]QTYLIVPREV(nolign-1) =0 : Raz [V]GBOUT6  : Endif
If [M:XS4]QTYLIVDEP(nolign-1)  =0 : Raz [V]GBOUT7  : Endif
If [M:XS4]QTYREAPREV(nolign-1) =0 : Raz [V]GBOUT9  : Endif
If [M:XS4]QTYREADEP(nolign-1)  =0 : Raz [V]GBOUT10 : Endif

Return

