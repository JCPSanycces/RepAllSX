#==========================================================================================
Subprog AS_XCORPUR2M(VALEUR)
Variable Decimal VALEUR
If [M:XS1]XCORPUR2=0
  mkstat=1
Elsif VALEUR=0 & [M:XS1]XQTYUOM
  VALEUR=arr(abs([M:XS1]XMNTUOM/[M:XS1]XQTYUOM)*[M:XS1]XCORPUR2,[V]GARODEV)
Endif
End

#==========================================================================================
Subprog AS_XIBDTYP(VALEUR)
Variable Integer VALEUR
GMENLOC(5)=1
GMENLOC(6)=1
End

#==========================================================================================
Subprog AM_XIBDTYP(VALEUR)
Variable Integer VALEUR
[M:XS2]IBDTYP([M:XS0]XNUMLIG2-1)=VALEUR
Call ACTGRIZO_IBD(VALEUR) From XSITUAG2
End

#==========================================================================================
Subprog AS_XIBDAMT(VALEUR)
Variable Decimal VALEUR

If [M:XS2]XIBDTYP<>2
  mkstat=1
Else
  Local Decimal ZADED, ZDED, ZENC, ZSOLDE
  Call LEC_ACOMPTES([M:XS0]OPPNUM,[M:XS2]LINSITNUM([M:XS0]XNUMLIG2-1),[M:XS2]CURFRL([M:XS0]XNUMLIG2-1),ZADED,ZDED,ZENC,ZSOLDE) From XOBJOPPX11
  If [L]ZADED<>0
    Raz [V]GMESSAGE
    If [L]ZENC<>0 | VALEUR<>0
      [V]GMESSAGE=mess(2,21,1)-":"-num$([L]ZENC)-[M:XS2]CURFRL([M:XS0]XNUMLIG2-1)-"(+"+num$(VALEUR)-[M:XS2]CURFRL([M:XS0]XNUMLIG2-1)+") - "
    Endif
    [V]GMESSAGE+=mess(144,[V]GXMSGOPP,1)-":"-num$(max([L]ZSOLDE-VALEUR,0))-[M:XS2]CURFRL([M:XS0]XNUMLIG2-1)
    [V]GERR=4
  Endif
Endif

End

#==========================================================================================
Subprog AP_XIBDAMT(VALEUR)
Variable Decimal VALEUR
# Pour raffraichir info
[V]GMESSAGE=string$(70," ")
GERR=4
End

#==========================================================================================
Subprog AM_XIBDAMT(VALEUR)
Variable Decimal VALEUR
mkstat=0
If VALEUR<>0
  Local Decimal ZADED, ZDED, ZENC, ZSOLDE
  Call LEC_ACOMPTES([M:XS0]OPPNUM,[M:XS2]LINSITNUM([M:XS0]XNUMLIG2-1),[M:XS2]CURFRL([M:XS0]XNUMLIG2-1),ZADED,ZDED,ZENC,ZSOLDE) From XOBJOPPX11
  If ([L]ZSOLDE-VALEUR)<0
    [V]GMESSAGE=mess(145,[V]GXMSGOPP,1)-":"-num$([L]ZSOLDE)-[M:XS2]CURFRL([M:XS0]XNUMLIG2-1)
    [V]GERR=1
    mkstat=1
  Endif
Endif
If mkstat=0
  [M:XS2]IBDAMT([M:XS0]XNUMLIG2-1)=VALEUR
Endif
End

