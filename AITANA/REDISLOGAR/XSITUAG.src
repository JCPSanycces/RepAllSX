#==========================================================================================
Subprog C_XDATFOF(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
  If [M:XS4]QTYMFG([M:XS0]XNUMLIG4-1)<>0
    [V]GMESSAGE=mess(10,123,1)
    mkstat=1
  Endif
Else
  Local Date ZDEB
  Read [F:FRL]FRL0=[M:XS4]FRMNUMLIG([M:XS0]XNUMLIG4-1)
  If !fstat
    [L]ZDEB=[F:FRL]CREDATFRM
  Endif
  [L]ZDEB=max([L]ZDEB,datesyst)
  If VALEUR<[L]ZDEB
    [V]GMESSAGE = mess(305,[V]GXMSGPSA,1)-format$("D:DD[/]MM[/]YYYY",[L]ZDEB)
    mkstat=1
  Endif
Endif
End

#==========================================================================================
Subprog AM_XDATFOF(VALEUR)
Variable Date    VALEUR
[M:XS4]DATFOF([M:XS0]XNUMLIG4-1)=VALEUR
End

