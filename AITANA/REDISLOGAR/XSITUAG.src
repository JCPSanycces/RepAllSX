If [M:XS4]XCOROF2=0
  mkstat=1
Elsif VALEUR=0 & [M:XS4]XQTYOF
  VALEUR=arr(abs([M:XS4]XMNTOF/[M:XS4]XQTYOF)*[M:XS4]XCOROF2,[V]GARODEV)
Endif
End

#==========================================================================================
Subprog AV_NBLIGB

Read [F:XST]XST0=[M:XS0]SITNUM
If fstat : Raz [F:XST] : Endif

Local Integer I

For [L]I=0 To [M:XS2]NBLIGB-1
  If [M:XS0]SITNUM="" | [F:XST]VLYFLG=2 | [F:XST]CANFLG=2 | [M:XS2]INVMOD([M:XS0]XNUMLIG2-1)<>5 | [M:XS2]EXTDAT([L]I)>=[F:XST]CALDAT | [M:XS2]CPLFLG([L]I)=2
    Chgstl [M:XS2]NBLIGB([L]I) With ""
  Else
    Chgstl [M:XS2]NBLIGB([L]I) With "BACKYELLOW"
  Endif
Next

End

