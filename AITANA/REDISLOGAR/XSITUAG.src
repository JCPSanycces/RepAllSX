End

#==========================================================================================
Subprog C_OPPNUM(VALEUR)
Variable Char    VALEUR()

# LBORN 01/12/2010 - Action CONTOBJW ajouté pour court--circuiter les contrôles objet standard et permettre
#                    de sélectionner des affaires clôturées
#                    Utilisation du Call CONTROLE pour afficher le message d'erreur standard
Read [F:OPP]OPP0=VALEUR
If fstat
  Call CONTROLE("OPP","#",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : End : Endif
Endif

Read [F:XOP]XOP0=VALEUR
If fstat : End : Endif

Read [F:FCY]FCY0=[F:OPP]SALFCY
If fstat : Raz [F:FCY] : Endif

If [M:XS0]CPY<>"" & [F:FCY]LEGCPY<>[M:XS0]CPY
  [V]GMESSAGE=mess(99,[V]GXMSGOPP,1)
  [V]GERR=1
  mkstat=1
  End
Endif

If [M:XS0]SALFCY<>"" & [F:OPP]SALFCY<>[M:XS0]SALFCY
  [V]GMESSAGE=mess(100,[V]GXMSGOPP,1)
  [V]GERR=1
  mkstat=1
  End
Endif

If [M:XS0]OPPREP<>"" & [F:OPP]OPPREP<>[M:XS0]OPPREP
  [V]GMESSAGE=mess(114,[V]GXMSGOPP,1)
  [V]GERR=1
  mkstat=1
  End
Endif

If [M:XS0]GESINT<>"" & [F:XOP]GESINT<>[M:XS0]GESINT
  [V]GMESSAGE=mess(101,[V]GXMSGOPP,1)
  [V]GERR=1
  mkstat=1
  End
Endif

End

#==========================================================================================
Subprog AS_OPPNUM(VALEUR)
Variable Char    VALEUR()
Call CRITOPP([V]GBIDC1) From XSITUAG2
End

#==========================================================================================
Subprog B3_NBLIG

Local Integer J

Case maskcou

  When "XSITUAG1"
    For [L]J=nolign-1 To [M:XS1]NBLIG-1
      If [M:XS1]NIV([L]J)<=[M:XS1]NIV(nolign-1) & [L]J<>(nolign-1) : Break : Endif
      Case [M:XS1]TYPLIG([L]J)
        When 5
          Raz [M:XS1]QTYPUR([L]J),[M:XS1]GROPRIPUR([L]J)
        When 6
          Raz [M:XS1]RMNQTY([L]J),[M:XS1]RMNMNT([L]J)
      Endcase
    Next
    Call AFFTAB(1) From XSITUAG2
    Affzo [M:XS1]15-30

  When "XSITUAG2"
    For [L]J=nolign-1 To [M:XS2]NBLIG-1
      If [M:XS2]NIV([L]J)<=[M:XS2]NIV(nolign-1) & [L]J<>(nolign-1) : Break : Endif
      Case [M:XS2]TYPLIG([L]J)
        When 4
          If find([M:XS2]INVMOD([L]J),2,6)
            Raz [M:XS2]INVSIT2([L]J),[M:XS2]INVSIT2M([L]J)
          Endif
      Endcase
    Next
    Call AFFTAB(2) From XSITUAG2
    Affzo [M:XS2]15

  When "XSITUAG4"
    For [L]J=nolign-1 To [M:XS4]NBLIG-1
      If [M:XS4]NIV([L]J)<=[M:XS4]NIV(nolign-1) & [L]J<>(nolign-1) : Break : Endif
      Case [M:XS4]TYPLIG([L]J)
        When 8
          Raz [M:XS4]QTYMFG([L]J),[M:XS4]MNTMFG([L]J)
      Endcase
    Next
    Call AFFTAB(3) From XSITUAG2
    Affzo [M:XS4]15

Endcase

mkstat=4 : # Pour redéclencher l'action $APRES_MODIF

End

