Subprog AM_XRMNQTY(VALEUR)
Variable Decimal VALEUR

# LBORN 21/06/2011 - Raffraichissement du total en AM_
If [M:XS1]XRMNQTY<>0

  # LBORN 09/02/2016
  # [M:XS1]XRMNMNT=func XSITUAG2.ARRDEV([M:XS1]CURFRL3(max([M:XS0]XNUMLIG1,1)-1),[M:XS1]XRMNMNT/[M:XS1]XRMNQTY*VALEUR)
  If !clalev([F:TCU]) : Local File TABCUR : Endif
  If [F:TCU]CUR<>[M:XS1]CURFRL3(max([M:XS0]XNUMLIG1,1)-1)
    Read [F:TCU]TCU0=[M:XS1]CURFRL3(max([M:XS0]XNUMLIG1,1)-1)
    If fstat : Raz [F:TCU] : Endif
  Endif
  [M:XS1]XRMNMNT=arr([M:XS1]XRMNMNT/[M:XS1]XRMNQTY*VALEUR,[F:TCU]CURRND)

  [M:XS1]RMNMNT([M:XS0]XNUMLIG1-1)=[M:XS1]XRMNMNT
  Affzo [M:XS1]XRMNMNT
Endif

[M:XS1]RMNQTY([M:XS0]XNUMLIG1-1)=VALEUR

End

