  Read [F:FLF]FLF0=[M:XS2]FRMNUMLIG([M:XS0]XNUMLIG2-1);[M:XS2]NUMLIGSIT(nolign-1)
  If !fstat & [F:FLF]CPLFIXDAT<>[0/0/0]
    mkstat=2
