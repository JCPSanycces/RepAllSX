Local Char VALBOUT(250) , PARBOUT(250)(1..20)
PARBOUT(1) = "AFF1002SAL00001"
PARBOUT(1)="AFF1001LYO00001"
PARBOUT(1)="AFF1004LYO00003"
PARBOUT(1)="AFF1002SFR00001"
PARBOUT(1)="AFF1012LYO00001"
PARBOUT(1)="AFF1308PSF00003"
#Raz PARBOUT
GACTION = "XSITUATION"
Call SAISIE_CHAR(VALBOUT,PARBOUT,"XSITUAG","XSITUAG","YSITUAG") From GSAISIE
End

GBIDC1=""
GBIDC2=""
GFONC1="GESOPPGAS"
Call OBJET("OPP",GBIDC1,GBIDC2) From GOBJET
End


$ACTION

Gosub ACTION From XSITUAG2

Return

#==========================================================================================
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()

Gosub DEVERROU From XSITUAG2

Effzo [M:XS0]CALDAT

Filter [F:XST] Where [F:XST]OPPNUM=VALEUR & [F:XST]CANFLG<>2
Read [F:XST]XST1 Last
If fstat>2 : Raz [F:XST] : Endif
Filter [F:XST]

Gosub LECOPP
[M:XS0]OPPNUM=VALEUR
[M:XS0]SITNUM=[F:XST]SITNUM
[M:XS0]CALDAT=[F:XST]CALDAT
If [M:XS0]CALDAT=[0/0/0]
  [M:XS0]CALDAT=date$
Endif
[M:XS0]XNUMLIG1=1
[M:XS0]XNUMLIG2=1
[M:XS0]XNUMLIG3=1
[M:XS0]XNUMLIG4=1

Gosub TRISIT From XSITUAG2

Call RAFFRAICHI([M:XS0]OPPNUM,[M:XS0]SITNUM) From XSITUAG2

End


#==========================================================================================
$LECOPP
Read [F:OPP]OPP0=VALEUR
If !fstat
  Call GETDEV([F:OPP]SALFCY) From DEVSUB
  [M:XS0]CUR=[V]GLOCALDEV
Endif
Return

#==========================================================================================
Subprog AV_ICOOPP(VALEUR)
Variable Char    VALEUR()
If [M:XS0]OPPNUM=""
  VALEUR=""
Else
  VALEUR="65"
Endif
End

#==========================================================================================
Subprog IB_NBLIG

Local Integer J, ZTROUV

Raz [V]GBOUT3, [V]GBOUT4
& , [V]GBOUT5, [V]GBOUT6, [V]GBOUT7, [V]GBOUT8, [V]GBOUT9, [V]GBOUT10, [V]GBOUT11, [V]GBOUT12
& , [V]GBOUT13, [V]GBOUT14, [V]GBOUT15, [V]GBOUT16, [V]GBOUT17, [V]GBOUT18, [V]GBOUT19

If [M]FRMNUMLIG(nolign-1)<>""
  [V]GBOUT4=mess(20,[V]GXMSGOPP,1) : # Détail
Endif

Case maskcou

  When "XSITUAG1"

    If func XSITUAG2.AUTOR_MODIF
      Raz [L]ZTROUV
      For [L]J=nolign-1 To [M:XS1]NBLIG-1
        If [M:XS1]NIV([L]J)<=[M:XS1]NIV(nolign-1) & [L]J<>(nolign-1) : Break : Endif
        Case [M:XS1]TYPLIG([L]J)
          When 5
            If [M:XS1]QTYPUR([L]J)<>0 | [M:XS1]MNTPUR([L]J)<>0
              [L]ZTROUV=1 : Break
            Endif
          When 6
            If [M:XS1]RMNQTY([L]J)<>0 | [M:XS1]RMNMNT([L]J)<>0
              [L]ZTROUV=1 : Break
            Endif
        Endcase
      Next
      If [L]ZTROUV
        [V]GBOUT3=mess(102,[V]GXMSGOPP,1) : # RAZ à générer
      Endif
    Endif

    Case [M:XS1]TYPLIG(nolign-1)
      When 5
        # Achats
        [V]GBIDI2=[M:XS1]CHRACHAT(nolign-1)
        Gosub BOUT_ZOOMACH
      When 6
        # Prestations
        [V]GBIDI2=[M:XS1]CHRDS(nolign-1)
        Gosub BOUT_ZOOMREQ
    Endcase

  When "XSITUAG2"

    If func XSITUAG2.AUTOR_MODIF
      Raz [L]ZTROUV
      For [L]J=nolign-1 To [M:XS2]NBLIG-1
        If [M:XS2]NIV([L]J)<=[M:XS2]NIV(nolign-1) & [L]J<>(nolign-1) : Break : Endif
        Case [M:XS2]TYPLIG([L]J)
          When 4
            If ([M:XS2]INVSIT2([L]J)<>0 | [M:XS2]INVSIT2M([L]J)<>0) & find([M:XS2]INVMOD([L]J),2,6)
              [L]ZTROUV=1 : Break
            Endif
        Endcase
      Next
      GPOINT="IB_AVRAF" : Gosub ENTREE From EXEFNC
      If [L]ZTROUV
        [V]GBOUT3=mess(103,[V]GXMSGOPP,1) : # RAZ à facturer
      Endif
    Endif

    # Ventes
    If [M:XS2]TYPLIG(nolign-1)=4
      [V]GBOUT8=mess(96,[V]GXMSGOPP,1) : # Saisie texte
      Gosub B_ZOOM
    Endif

  When "XSITUAG4"

    If func XSITUAG2.AUTOR_MODIF
      Raz [L]ZTROUV
      For [L]J=nolign-1 To [M:XS4]NBLIG-1
        If [M:XS4]NIV([L]J)<=[M:XS4]NIV(nolign-1) & [L]J<>(nolign-1) : Break : Endif
        Case [M:XS4]TYPLIG([L]J)
          When 8
            If [M:XS4]QTYMFG([L]J)<>0 | [M:XS4]MNTMFG([L]J)<>0
              [L]ZTROUV=1 : Break
            Endif
        Endcase
      Next
      If [L]ZTROUV
        [V]GBOUT3=mess(6,[V]GXMSGOPR,1) : # RAZ à générer
      Endif
    Endif

    Case [M:XS4]TYPLIG(nolign-1)
      When 8
        # Production
        [V]GBIDI2=[M:XS4]NUMLIGOF(nolign-1)
        Gosub BOUT_ZOOMOF
    Endcase

Endcase

End

#==========================================================================================
Subprog AM_SITNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR="" & [M:XS0]SITNUM<>""
  VALEUR=[M:XS0]SITNUM
  [V]GMESSAGE=mess(10,123,1)
  [V]GERR=1
  mkstat=1
  Affzo [M:XS0]SITNUM
Else
  [M:XS0]SITNUM=VALEUR
  Call RAFFRAICHI([M:XS0]OPPNUM,[M:XS0]SITNUM) From XSITUAG2
Endif

End

#==========================================================================================
Subprog IB_NBSIT

Local Integer ZNOL, ZOK, J

[L]ZNOL=nolign

Raz [V]GBOUT5, [V]GBOUT6, [V]GBOUT7, [V]GBOUT8, [V]GBOUT9, [V]GBOUT10, [V]GBOUT11, [V]GBOUT12, [V]GBOUT13, [V]GBOUT14

# LBORN 28/08/2017 - Mantis 34473
Local Char SITSVG : [L]SITSVG=[M:XS0]SITNUM
[M:XS0]SITNUM=[M:XS3]SITNUM([L]ZNOL-1)

Read [F:OPP]OPP0=[M:XS0]OPPNUM
If fstat : Raz [F:OPP] : Endif
Read [F:XST]XST0=[M:XS0]SITNUM
If fstat : Raz [F:XST] : Endif

# Situation
If [M:XS3]SITNUM([L]ZNOL-1)<>""
  [V]GBOUT5=mess(78,[V]GXMSGOPP,1)
Else
  Raz [V]GBOUT5
Endif

###################################
# Annuler Fantôme
###################################

#LBORN 03/07/2012 - Algo modifié, sinon bug si affaire en lot
#Filter [F:XST] Where [F:XST]OPPNUM=[M:XS0]OPPNUM
#Read [F:XST]XST1 Last
#If !fstat & [F:XST]SITNUM=[M:XS3]SITNUM([L]ZNOL-1) & [F:XST]VLYFLG<>2 & [F:XST]CANFLG=2 & GREP="" & ![V]XVERROU
#  [V]GBOUT6=mess(98,[V]GXMSGOPP,1)
#Endif
#Filter [F:XST]

If ![V]XVERROU & GREP="" & func XSITUAG2.AUTOR_ANNUL_FANTOME([M:XS0]SITNUM)
  [V]GBOUT6=mess(98,[V]GXMSGOPP,1)
Endif

###################################
# Recalcul de la situation
###################################
If func XSITUAG2.AUTOR_MODIF & GREP="" & [M:XS3]SITNUM([L]ZNOL-1)<>""
  [V]GBOUT7=mess(338,[V]GXMSGPSA,1)
Endif

###################################
# Création des situations
###################################
If func XOBJOPPX11.AUTOR_CRESIT([M:XS0]OPPNUM,GREP) & ![V]XVERROU & [M:XS3]SITNUM([L]ZNOL-1)=""
  Read [F:PPT]PPT0=[F:OPP]OPPTYP
  If !fstat
    [L]ZOK=1
    If [F:PPT]SITOPP=2
      # Situation par affaire
      For [L]J=0 To [M:XS3]NBSIT-1
        If [M:XS3]SITNUM([L]J)<>""
          Read [F:XST]XST0=[M:XS3]SITNUM([L]J)
          If !fstat & [F:XST]VLYFLG<>2 & [F:XST]CANFLG<>2
            [L]ZOK=0 : Break : # Situation en cours
          Endif
        Endif
      Next
    Else
      # Situation par niveau
      # Structure à vérifier (à developper) pour voir s'il y a qq chose à créer
      # [L]ZOK=0
    Endif
    If [L]ZOK
      [V]GBOUT8=mess(113,[V]GXMSGOPP,1)
    Endif
  Endif
Endif

###################################
# Fantôme
###################################
If !func XSITUAG2.NOBOUT_SUP & GREP="" & [M:XS3]SITNUM([L]ZNOL-1)<>""
  GBOUT9=mess(115,[V]GXMSGOPP,1)
Endif

###################################
# Situation budgétaire
###################################
If func XSITUAG2.AUTOR_MODIF & [M:XS3]SITNUM([L]ZNOL-1)<>"" & [M:XS3]BUDFLG([L]ZNOL-1)<>2
  For [F:SL1]SL11 Where [F:SL1]SITNUM=[M:XS3]SITNUM([L]ZNOL-1)
    Read [F:FRL]FRL0=[F:SL1]FRMNUMLIG
    If !fstat & [F:FRL]BUDCOD<>""
      GBOUT10=mess(116,[V]GXMSGOPP,1)
      Break
    Endif
  Next
Endif

###################################
# Annuler Situation budgétaire
###################################
If func XSITUAG2.AUTOR_MODIF & [M:XS3]SITNUM([L]ZNOL-1)<>"" & [M:XS3]BUDFLG([L]ZNOL-1)=2
  GBOUT11=mess(117,[V]GXMSGOPP,1)
Endif

###################################
# Info situation
###################################
If [M:XS3]SITNUM([L]ZNOL-1)<>""
  GBOUT12=mess(118,[V]GXMSGOPP,1)
Endif

###################################
# Répartition budgétaire
###################################
If [M:XS3]BUDFLG([L]ZNOL-1)=2 & GREP=""
  For [F:SL1]SL11 Where [F:SL1]SITNUM=[M:XS3]SITNUM([L]ZNOL-1)
    Read [F:FRL]FRL0=[F:SL1]FRMNUMLIG
    If !fstat & [F:FRL]BUDCOD<>"" & [F:FRL]BUDBEG<>[0/0/0] & [F:FRL]BUDEND<>[0/0/0]
      GBOUT13=mess(122,[V]GXMSGOPP,1)
      Break
    Endif
  Next
Endif

###################################
# Traçabilité pièces
###################################
If [M:XS3]SITNUM([L]ZNOL-1)<>"" & GREP="" & [F:XST]CANFLG<>2 & func AFNC.ACTIV("TRA")
  GBOUT14=mess(19,723,1)
Endif

# LBORN 28/08/2017 - Mantis 34473
[M:XS0]SITNUM=[L]SITSVG

Read [F:XST]XST0=[M:XS0]SITNUM
If fstat : Raz [F:XST] : Endif

End

#==========================================================================================
Subprog AS_NBSIT

If nolign<>0 & status=71
  [M:XS0]XNUMLIG3=nolign
Endif

If [M:XS3]SITNUM(nolign-1)="" | find(GREP,"M","C") | status<>71 | [M:XS3]SITNUM(nolign-1)=[M:XS0]SITNUM : End : Endif

[M:XS0]SITNUM=[M:XS3]SITNUM(nolign-1)
Call RAFFRAICHI([M:XS0]OPPNUM,[M:XS0]SITNUM) From XSITUAG2

End


#==========================================================================================
Subprog B6_NBSIT
Call ANN_FANTOME([M:XS0]SITNUM,GOK) From XSITUAG2
If GOK=1
  Call RAFFRAICHI([M:XS0]OPPNUM,[M:XS0]SITNUM) From XSITUAG2
Endif
End

#==========================================================================================
Subprog B7_NBSIT
Call RECALSIT([M:XS0]OPPNUM,[M:XS0]SITNUM) From XSITUAG2
If [V]XBOUTOK
  Call RAFFRAICHI([M:XS0]OPPNUM,[M:XS0]SITNUM) From XSITUAG2
Endif
End

#==========================================================================================
Subprog B8_NBSIT

Case [M:XS3]TYPLIG(nolign-1)
  When 2
    Call CRESIT([M:XS0]OPPNUM,[M:XS3]NIV1(nolign-1),"") From XSITUAG2
  When 3
    Call CRESIT([M:XS0]OPPNUM,[M:XS3]NIV1(nolign-1),[M:XS3]NIV2(nolign-1)) From XSITUAG2
  When Default
    Call CRESIT([M:XS0]OPPNUM,"","") From XSITUAG2
Endcase

If [V]XBOUTOK
  Call RAFFRAICHI([M:XS0]OPPNUM,[M:XS0]SITNUM) From XSITUAG2
Endif
End

#==========================================================================================
Subprog C_SITNUM(VALEUR)
Variable Char    VALEUR()
Read [F:XST]XST0=VALEUR
If !fstat & [F:XST]OPPNUM<>[M:XS0]OPPNUM
  [V]GMESSAGE=mess(79,[V]GXMSGOPP,1)-[F:XST]OPPNUM
  [V]GERR=1
  mkstat=1
Endif
End

#==========================================================================================
Subprog C_CALDAT(VALEUR)
Variable Date    VALEUR

If GREP="C"
  Filter [F:XST] Where [F:XST]OPPNUM=[M:XS0]OPPNUM
  Read [F:XST]XST1 Last
  If !fstat & [F:XST]CALDAT>VALEUR
    [V]GMESSAGE=mess(329,[V]GXMSGPSA,1)-[F:XST]SITNUM-mess(330,[V]GXMSGPSA,1)-format$("D:DD[/]MM[/]YYYY",[F:XST]CALDAT)
    [V]GERR=1
    mkstat=1
  Endif
  Filter [F:XST]
Endif

End

#==========================================================================================
Subprog AM_CALDAT(VALEUR)
Variable Date    VALEUR

If GREP<>"C"

  # Dans un premier temps, on se contentera d'afficher la dernière situation
  # Pas encore de calcul en temps réel
  #  Filter [F:XST] Where [F:XST]OPPNUM=[M:XS0]OPPNUM & [F:XST]CALDAT=VALEUR
  #  Read [F:XST]XST1 Last
  #  If fstat>2 : Raz [F:XST] : Endif

  Filter [F:XST] Where [F:XST]OPPNUM=[M:XS0]OPPNUM & [F:XST]CALDAT<=VALEUR
  Read [F:XST]XST1 Last
  If fstat>2 : Raz [F:XST] : Else VALEUR=[F:XST]CALDAT : Endif

Else
  Filter [F:XST] Where [F:XST]OPPNUM=[M:XS0]OPPNUM
  Read [F:XST]XST1 Last
  If !fstat & [F:XST]CALDAT=VALEUR
    Raz [F:XST]
  Else
    Filter [F:XST] Where [F:XST]OPPNUM=[M:XS0]OPPNUM & [F:XST]CALDAT=VALEUR
    Read [F:XST]XST1 Last
    If fstat>2 : Raz [F:XST] : Endif
  Endif
Endif
Filter [F:XST]

If GREP="M"
  [V]GMESSAGE=mess(7,126,1)+"\"+mess(9,126,1)
  GSTATUS=1 : Call OUINON([V]GMESSAGE,GSTATUS) From GESECRAN
  If GSTATUS=2
    [M:XS0]SITNUM=[F:XST]SITNUM
    [M:XS0]CALDAT=VALEUR
    Call RAFFRAICHI([M:XS0]OPPNUM,[M:XS0]SITNUM) From XSITUAG2
  Else
    VALEUR=[M:XS0]CALDAT
    mkstat=2
    Raz [V]GMESSAGE
  Endif
Else
  [M:XS0]SITNUM=[F:XST]SITNUM
  [M:XS0]CALDAT=VALEUR
  Call RAFFRAICHI([M:XS0]OPPNUM,[M:XS0]SITNUM) From XSITUAG2
Endif

End

#==========================================================================================
Subprog CL_ICO1(VALEUR)
Variable Char    VALEUR()
Local Date ZDAT
[L]ZDAT=date$
Gosub CLIC_ICODAT
End

#==========================================================================================
Subprog CL_ICO2(VALEUR)
Variable Char    VALEUR()
Local Date ZDAT
[L]ZDAT=eomonth(addmonth(date$,-1))
Gosub CLIC_ICODAT
End

#==========================================================================================
$CLIC_ICODAT
If [L]ZDAT <>[M:XS0]CALDAT
  Local Date OLDDAT : [L]OLDDAT=[L]ZDAT
  Call C_CALDAT([L]ZDAT) From W1XSITUAG0
  If !mkstat
    Call AM_CALDAT([L]ZDAT) From W1XSITUAG0
    If !mkstat
      mkstat=4 : # Pour déclencher après-modif et setbout (raffraichissement auto des boutons)
    Else
      Raz [V]GMESSAGE, mkstat
    Endif
  Else
    Raz [V]GMESSAGE, mkstat
  Endif
Endif
Return

#==========================================================================================
Subprog AV_ICOOPP2(VALEUR)
Variable Char    VALEUR()
If GREP<>"" | [M:XS0]OPPNUM=""
  VALEUR=""
Else
  VALEUR="10"
Endif
End

#==========================================================================================
Subprog AV_ICOOPP3(VALEUR)
Variable Char    VALEUR()
If GREP<>"" | [M:XS0]OPPNUM=""
  VALEUR=""
Else
  VALEUR="11"
Endif
End

#==========================================================================================
Subprog CL_ICOOPP2(VALEUR)
Variable Char    VALEUR()

Local Char ZOPP, ZCRIT(240)

Filter [F:OPP] Where find([F:OPP]OPPSTEA2,'WIN','LOS','FOR')=0

Call CRITOPP([L]ZCRIT) From XSITUAG2

[L]ZOPP=[M:XS0]OPPNUM
While 1
  Read [F:OPP]OPP0<[L]ZOPP
  If fstat<=2 & [F:OPP]OPPNUM<>[L]ZOPP
    Read [F:XOP]XOP0=[F:OPP]OPPNUM
    If fstat : Raz [F:XOP] : Endif
    Read [F:FCY]FCY0=[F:OPP]SALFCY
    If fstat : Raz [F:FCY] : Endif
    If !evalue([L]ZCRIT)
      [L]ZOPP=[F:OPP]OPPNUM
    Else
      fstat=0
      Break
    Endif
  Else
    Break
  Endif
Wend

Gosub SUIVPREC

End

$SUIVPREC
If fstat>2 | [F:OPP]OPPNUM=[M:XS0]OPPNUM
  [V]GMESSAGE=mess(11,100,1)
  [V]GERR=2
Else
  Call AM_OPPNUM([F:OPP]OPPNUM)
  [M:XS0]OPPNUM=[F:OPP]OPPNUM
Endif
Filter [F:OPP]
Return

#==========================================================================================
Subprog CL_ICOOPP3(VALEUR)
Variable Char    VALEUR()

Local Char ZOPP, ZCRIT(240)

Filter [F:OPP] Where find([F:OPP]OPPSTEA2,'WIN','LOS','FOR')=0

Call CRITOPP([L]ZCRIT) From XSITUAG2

[L]ZOPP=[M:XS0]OPPNUM
While 1
  Read [F:OPP]OPP0>[L]ZOPP
  If fstat<=2 & [F:OPP]OPPNUM<>[L]ZOPP
    Read [F:XOP]XOP0=[F:OPP]OPPNUM
    If fstat : Raz [F:XOP] : Endif
    Read [F:FCY]FCY0=[F:OPP]SALFCY
    If fstat : Raz [F:FCY] : Endif
    If !evalue([L]ZCRIT)
      [L]ZOPP=[F:OPP]OPPNUM
    Else
      fstat=0
      Break
    Endif
  Else
    Break
  Endif
Wend

Gosub SUIVPREC

End

#==========================================================================================
Subprog AV_ICOOPP4(VALEUR)
Variable Char    VALEUR()
If [V]XVERROU
  VALEUR="280"
Else
  VALEUR=""
Endif
End

#==========================================================================================
Subprog AV_ICOSIT(VALEUR)
Variable Char    VALEUR()
If !func XSITUAG2.AUTOR_MODIF & [M:XS0]OPPNUM<>"" & [M:XS0]SITNUM<>""
  VALEUR="146"
Else
  VALEUR=""
Endif
End

#==========================================================================================
Subprog AS_NBLIG

If status<>71 | nolign=0 | [M:XS0]XNUMLIG1=0 | [M:XS0]XNUMLIG2=0 | [M:XS0]XNUMLIG4=0 : End : Endif

Local Integer ZI

Case maskcou

  When "XSITUAG1"

    # Charges
    If nolign<>[M:XS0]XNUMLIG1
      [M:XS0]XNUMLIG1=nolign
      If [M:XS2]FRMNUMLIG([M:XS0]XNUMLIG2-1)<>[M:XS1]FRMNUMLIG(nolign-1) | !find([M:XS1]TYPLIG(nolign-1),5,6)
        For [L]ZI=0 To [M:XS2]NBLIG-1
          If find([M:XS1]TYPLIG(nolign-1),5,6)
            If [M:XS2]CLE([L]ZI)=[M:XS1]PAR(nolign-1)
              [M:XS0]XNUMLIG2=[L]ZI+1 : Break
            Endif
          Else
            If [M:XS2]CLE([L]ZI)=[M:XS1]CLE(nolign-1)
              [M:XS0]XNUMLIG2=[L]ZI+1 : Break
            Endif
          Endif
        Next
      Endif

      If [V]GXOPTOPR
        If [M:XS4]FRMNUMLIG([M:XS0]XNUMLIG4-1)<>[M:XS1]FRMNUMLIG(nolign-1) | !find([M:XS1]TYPLIG(nolign-1),5,6)
          For [L]ZI=0 To [M:XS4]NBLIG-1
            If find([M:XS1]TYPLIG(nolign-1),5,6)
              If [M:XS4]CLE([L]ZI)=[M:XS1]PAR(nolign-1)
                [M:XS0]XNUMLIG4=[L]ZI+1 : Break
              Endif
            Else
              If [M:XS4]CLE([L]ZI)=[M:XS1]CLE(nolign-1)
                [M:XS0]XNUMLIG4=[L]ZI+1 : Break
              Endif
            Endif
          Next
        Endif
      Endif

      Call AFFTAB(1) From XSITUAG2
      Affzo [M:XS1]

      Default Mask [XS2]
      Call AFFTAB(2) From XSITUAG2
      Affzo [M:XS2]

      If [V]GXOPTOPR
        Default Mask [XS4]
        Call AFFTAB(3) From XSITUAG2
        Affzo [M:XS4]
      Endif

      Default Mask [XS1]

    Endif


  When "XSITUAG2"

    # Produits
    If nolign<>[M:XS0]XNUMLIG2
      [M:XS0]XNUMLIG2=nolign

      If [M:XS1]FRMNUMLIG([M:XS0]XNUMLIG1-1)<>[M:XS2]FRMNUMLIG(nolign-1) | [M:XS2]TYPLIG(nolign-1)<>4
        For [L]ZI=0 To [M:XS1]NBLIG-1
          If [M:XS1]CLE([L]ZI)=[M:XS2]CLE(nolign-1)
            [M:XS0]XNUMLIG1=[L]ZI+1 : Break
          Endif
        Next
      Endif

      If [V]GXOPTOPR
        If [M:XS4]FRMNUMLIG([M:XS0]XNUMLIG4-1)<>[M:XS2]FRMNUMLIG(nolign-1) | [M:XS2]TYPLIG(nolign-1)<>4
          For [L]ZI=0 To [M:XS4]NBLIG-1
            If [M:XS4]CLE([L]ZI)=[M:XS2]CLE(nolign-1)
              [M:XS0]XNUMLIG4=[L]ZI+1 : Break
            Endif
          Next
        Endif
      Endif
      Call AFFTAB(2) From XSITUAG2
      Affzo [M:XS2]


      Default Mask [XS1]
      Call AFFTAB(1) From XSITUAG2
      Affzo [M:XS1]

      If [V]GXOPTOPR
        Default Mask [XS4]
        Call AFFTAB(3) From XSITUAG2
        Affzo [M:XS4]
      Endif

      Default Mask [XS2]
    Endif

    # Pour raffraichir info
    [V]GMESSAGE=string$(70," ")
    GERR=4

  When "XSITUAG4"

    # Production
    If nolign<>[M:XS0]XNUMLIG4
      [M:XS0]XNUMLIG4=nolign

      If [M:XS1]FRMNUMLIG([M:XS0]XNUMLIG1-1)<>[M:XS4]FRMNUMLIG(nolign-1) | [M:XS4]TYPLIG(nolign-1)<>8
        For [L]ZI=0 To [M:XS1]NBLIG-1
          If [M:XS1]CLE([L]ZI)=[M:XS4]CLE(nolign-1)
            [M:XS0]XNUMLIG1=[L]ZI+1 : Break
          Endif
        Next
      Endif

      If [M:XS2]FRMNUMLIG([M:XS0]XNUMLIG2-1)<>[M:XS4]FRMNUMLIG(nolign-1) | [M:XS4]TYPLIG(nolign-1)<>8
        For [L]ZI=0 To [M:XS2]NBLIG-1
          If [M:XS2]CLE([L]ZI)=[M:XS4]CLE(nolign-1)
            [M:XS0]XNUMLIG2=[L]ZI+1 : Break
          Endif
        Next
      Endif

      Call AFFTAB(3) From XSITUAG2
      Affzo [M:XS4]

      Default Mask [XS1]
      Call AFFTAB(1) From XSITUAG2
      Affzo [M:XS1]

      Default Mask [XS2]
      Call AFFTAB(2) From XSITUAG2
      Affzo [M:XS2]

      Default Mask [XS4]

    Endif

Endcase

End

