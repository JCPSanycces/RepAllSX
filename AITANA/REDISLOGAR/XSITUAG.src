#==========================================================================================
Subprog AS_CPLFLG(VALEUR)
Variable Integer VALEUR
Local Integer ZTROUV, ZTROUV2
If [M:XS2]INVMOD([M:XS0]XNUMLIG2-1)<>4
  mkstat=2
Elsif VALEUR=2
  # LBORN 11/12/2013 - Mantis 18483
  # On ne modifie pas le flag "Réalisé" s'il n'y a que des chronos cloturés
  Raz [L]ZTROUV, [L]ZTROUV2
  For [F:VGA]VGA8 Hint Key VGA8 Where [F:VGA]FRMNUMLIG=[M:XS2]FRMNUMLIG([M:XS0]XNUMLIG2-1)
&                                    & find([F:VGA]LINFRMIND,0,[M:XS2]STEPS(nolign-1))<>0
&                                    & find([F:VGA]TYPDOC,"FC1","AC1")<>0
    If find([F:VGA]VGASTA,1,4)
      [L]ZTROUV=1 : Break
    Elsif [F:VGA]VGASTA=2
      [L]ZTROUV2=1
    Endif
  Next
  If ![L]ZTROUV & [L]ZTROUV2
    mkstat=2
  Endif
Endif
End

#==========================================================================================
Subprog AM_CPLFLG(VALEUR)
Variable Integer VALEUR
If [M:XS2]INVMOD([M:XS0]XNUMLIG2-1)=4 & VALEUR<>2
  # LBORN 11/12/2013 - Mantis 18483
  # Read [F:FLD]FLD0=[M:XS2]FRMNUMLIG([M:XS0]XNUMLIG2-1);[M:XS2]NUMLIGSIT(nolign-1)
  Read [F:FLD]FLD1=[M:XS2]FRMNUMLIG([M:XS0]XNUMLIG2-1);[M:XS2]STEPS(nolign-1)
  If !fstat & [F:FLD]CPLDAT<>[0/0/0]
    [V]GMESSAGE=mess(21,[V]GXMSGPSA(1),1)
    [V]GERR=3
  Endif
Endif
End

