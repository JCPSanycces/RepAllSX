Subprog CL_TRI(VALEUR)
Variable Char    VALEUR()
If [M:XS0]TRIDAT=2
  [M:XS0]TRIDAT=1
Else
  [M:XS0]TRIDAT=2
Endif
Gosub ICOTRI From XSITUAG2
VALEUR=[M:XS0]TRI
Call RAFFRAICHI([M:XS0]OPPNUM,[M:XS0]SITNUM) From XSITUAG2
End

