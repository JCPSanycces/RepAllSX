#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du masque SCHCOL1
#ACV#X11
#TIT#Gestion de l'objet COL

#LBO 07/2002

GBIDC1=""
GBIDC2=""
Call OBJET("COL",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet COL
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "OUVRE_BOITE" : Gosub OUVRE_BOITE From SPVOBJCOL
  When "FERME"       : Gosub FERME       From SPVOBJCOL
  When "MODIF"       : Gosub MODIF       From SPVOBJCOL
  When "VERIF_MOD"   : Gosub VERIF_MOD   From SPVOBJCOL
  When "APRES_MOD"   : Gosub APRES_MOD   From SPVOBJCOL
  When "AB_MODIF"    : Gosub AB_MODIF    From SPVOBJCOL
  When "SEL_TABLE"   : Gosub SEL_TABLE   From SPVOBJCOL
  When "RAZCRE"      : Gosub RAZCRE      From SPVOBJCOL
  When "RAZDUP"      : Gosub RAZDUP      From SPVOBJCOL
  When "LIENS"       : Gosub LIENS       From SPVOBJCOL
  When "FILGAUCHE"   : Gosub FILGAUCHE   From SPVOBJCOL
Endcase

Return


#####################################################################################
# Ecran SCHCOL1 [COL1]
#####################################################################################

#----------------------------
Subprog AV_CODCOLVP(VALEUR)
Variable Decimal VALEUR
Call CRYPTCOL2([M:COL1]RED,[M:COL1]GREEN,[M:COL1]BLUE,VALEUR) From XCRYPTVP
End

#----------------------------
Subprog C_RED(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 | VALEUR>255
  mkstat=1
Else
  Call GENCOLRTF(VALEUR,[M:COL1]GREEN,[M:COL1]BLUE) From SPVOBJCOL
Endif
End

#----------------------------
Subprog C_GREEN(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 | VALEUR>255
  mkstat=1
Else
  Call GENCOLRTF([M:COL1]RED,VALEUR,[M:COL1]BLUE) From SPVOBJCOL
Endif
End

#----------------------------
Subprog C_BLUE(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 | VALEUR>255
  mkstat=1
Else
  Call GENCOLRTF([M:COL1]RED,[M:COL1]GREEN,VALEUR) From SPVOBJCOL
Endif
End
