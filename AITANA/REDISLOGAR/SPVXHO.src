#ACV#X16
#TIT#Gestion de l'objet XHO (Codes hierarchie)


#==========================================================================================
# Gestion de l'objet   : Gestion de l'objet XHO (Codes hierarchie)
#                        
# Auteur               : Laurent Bornes
# Date de création     : 09/11/2009      
#==========================================================================================
# Modifications significatives : 
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------


GBIDC1=""
GBIDC2=""
Call OBJET("XHO",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

##################################################################
$ACTION
Case ACTION
  When "MODIF"     : Gosub MODIF     From SPVOBJXHO
  When "SEL_TABLE" : Gosub SEL_TABLE From SPVOBJXHO
  When "FIN_TABLE" : Gosub FIN_TABLE From SPVOBJXHO
Endcase

Return

######################################################################################
Subprog C_DEPNIV(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Local Integer ZRANG
[L]ZRANG=find(VALEUR,[M:XHO0]HIECOD(0..[M:XHO0]NBLIG-1))
If [L]ZRANG<=0
  mkstat=1
Endif
End

######################################################################################
Subprog AS_DEPNIV(VALEUR)
Variable Char    VALEUR()
If [M:XHO0]NIV2(nolign-1)<>2
  mkstat=1
Endif
End
