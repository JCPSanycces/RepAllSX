#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du masque SCHGAS0
#ACV#X13
#TIT#Gestion de l'action SCHLOTREP

#LBO 01/2003

Local Char PARAM(30)(1..16),VALEUR(10) 

PARAM(1)=""
PARAM(2)=""
PARAM(3)=""
PARAM(4)="" 
Call TRAITE_CHAR(VALEUR,PARAM,"SCHSAILOT","XAGELOT2","",1) From GTRAITE
End


#-------------------------------------------------------------------------------
# Ecran SCHLOTREP [DIA]
#-------------------------------------------------------------------------------
#-------------------------
Subprog AP_CHREP(VALEUR)
Variable Integer VALEUR
Call ACTGRIZO(VALEUR)
End

Subprog ACTGRIZO(ZVAL)
Value Integer ZVAL
If [L]ZVAL<2
  Effzo [M:DIA]ENDDAT
  Grizo [M:DIA]ENDDAT
  Actzo [M:DIA]NFOIS
  If [M:DIA]NFOIS=0 : [M:DIA]NFOIS=1 : Endif
Else
  Effzo [M:DIA]NFOIS
  Grizo [M:DIA]NFOIS
  Actzo [M:DIA]ENDDAT
Endif
End

#-------------------------
Subprog AV_CHREP(VALEUR)
Variable Integer VALEUR
Call ACTGRIZO(VALEUR)
End
