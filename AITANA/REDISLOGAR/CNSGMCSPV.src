#<AdxTL>@(#)1.0.0.0 $Revision$
#ACV#X11
#TIT#COnsultation du Parc matériel

#==========================================================================================
# Gestion de la consultation : GMC -- Parc matériel
#
# Auteur                     :
# Date de création           :
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 28/02/2003    OTHYR        Modélisation Web + ajout PE
#==========================================================================================

Local Char PARAM(30)(3)

Call GCONSULT("GMC","",PARAM)From GCONSULT
End


###################################################################
$ACTION

Case ACTION
    When "AUTORIS"    : Gosub AUTORIS
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "SETBOUT"    : Gosub SETBOUT
    When "FIN_CRIT"   : Gosub FIN_CRIT
    When Default
Endcase
Return

#-----------------------------------------------------------------#
#    Gestion des étiquettes liées a ACTION                        #
#-----------------------------------------------------------------#
###################################################################
$AUTORIS
Return

###################################################################
$SETBOUT
Return

###################################################################
$OUVRE

Local Char   CRIT1(250), CRIT2(250), CRIT3(250), CRITSPE(250), CRITMAC(250)
Local   Decimal  WMNTORG(0..5), WMNTDES(0..5)
Local   Integer  SPSTAT

Gosub DEFCRIT

Return

###################################################################
$DEFCRIT

For I = 1 To dim(PARAM)
    Case I
        When 1 :    : # Parametre Tiers
            If PARAM(I) <> "" Then
                Call LECTURE("BPR",PARAM(I),"") From CONTOBJ
                If !fstat Then
                    [M:GMC1]BPCNUM = PARAM(I)
                Endif
            Endif
        When 2 :    : # Parametre article
            If PARAM(I) <> "" Then
                 Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
                 If !fstat Then
                    [M:GMC1]ITMREF = PARAM(I)
                 Endif
            Endif
        When 3 :    : # Parametre n° serie
            If PARAM(I) <> "" Then
                [M:GMC1]SERNUM = PARAM(I)
            Endif
    Endcase
Next I

If !find([M:CGMC]TRI,1,2,3)  : [M:CGMC]TRI = 1   : Endif

# -- copie de l'écran critères (CGMC) vers le masque 1 (GMC1)
Gosub CRITENT From =PROGCNS

Return

###################################################################
$LECTURE

If [M:GMC1]BPCNUM = "" & [M:GMC1]ITMREF = "" & [M:GMC1]STATITM = "" & [M:GMC1]MACTYP = "" Then
    NBLU = 0
    Return
Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

Call TEMPON("R") From GESECRAN

#-- Positionnement des Filtres
Gosub LOAD_FILTER
# Appel au filtre spécifique client
ACTION = "FILTRE"
Gosub ACTION From XOBJCNS
ACTION = "LECTURE"

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE = 1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CGMC]TRI
        When 1     : # tri par statut
            Link [MAC] With [XMA]XMA0=[MAC]MACNUM
&           As [LNK]
&           Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITMAC) & evalue([L]CRITSPE)
&           Order By Key CLE=[F:XMA]STATITM;[F:XMA]MACNUM
        When 2     : # tri par Tiers
            Link [MAC] With [XMA]XMA0=[MAC]MACNUM
&           As [LNK]
&           Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITMAC) & evalue([L]CRITSPE)
&           Order By Key CLE=[F:MAC]BPCNUM;[F:XMA]MACNUM
        When 3     : # tri par Article
            Link [MAC] With [XMA]XMA0=[MAC]MACNUM
&           As [LNK]
&           Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITMAC) & evalue([L]CRITSPE)
&           Order By Key CLE=[F:MAC]MACNUM
    Endcase
Else
    RETOUR = 1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CGMC]TRI
        When 1     : # tri par statut
            Link [MAC] With [XMA]XMA0=[MAC]MACNUM
&           As [LNK]
&           Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITMAC) & evalue([L]CRITSPE)
&           Order By Key CLE=[F:XMA]STATITM Desc;[F:XMA]MACNUM Desc
        When 2     : # tri par Tiers
            Link [MAC] With [XMA]XMA0=[MAC]MACNUM
&           As [LNK]
&           Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITMAC) & evalue([L]CRITSPE)
&           Order By Key CLE=[F:MAC]BPCNUM Desc;[F:XMA]MACNUM Desc
        When 3     : # tri par Article
            Link [MAC] With [XMA]XMA0=[MAC]MACNUM
&           As [LNK]
&           Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITMAC) & evalue([L]CRITSPE)
&           Order By Key CLE=[F:MAC]MACNUM Desc
    Endcase
Endif

#-- raz du masque
If CHGPAG <> 2 & CHGPAG <> -2 Then
    Raz [M:GMC2]
Endif

#-- lecture
$BOUCLE
For [LNK]
    If NBLU = 1
        If CHGPAG = 2 | CHGPAG = -2 : Raz [M:GMC2] : Endif
        NBLU = 2
    Endif
    If CHGPAG > 0 Then
        If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
        NOL += 1
        If NOL=0
            DEBSTAT = [F:XMA]STATITM
            DEBBPR  = [F:MAC]BPCNUM
            DEBITM  = [F:MAC]MACPDTCOD
        Endif
        FINSTAT = [F:XMA]STATITM
        FINBPR  = [F:MAC]BPCNUM
        FINITM  = [F:MAC]MACPDTCOD
    Else
        If NOL <= 0 : RETOUR=2 : Break : Endif
        NOL -= 1
        If NOL = MAXLIG-1 Then
            FINSTAT = [F:XMA]STATITM
            FINBPR  = [F:MAC]BPCNUM
            FINITM  = [F:MAC]MACPDTCOD
        Endif
        DEBSTAT = [F:XMA]STATITM
        DEBBPR  = [F:MAC]BPCNUM
        DEBITM  = [F:MAC]MACPDTCOD
    Endif

    nolign = NOL+1

    [M:GMC2] = [F:MAC]
    [M:GMC2] = [F:XMA]

$SUIV
Next

Call TEMPOFF From GESECRAN

Return

###################################################################
$LOAD_FILTER

[L]CRITMAC = "1"
[L]CRIT1   = "1"
[L]CRIT2   = "1"
[L]CRIT3   = "1"
[L]CRITSPE = "1"            :# Critère spécifique client

If [M:GMC1]BPCNUM <> "" Then
    [L]CRITMAC += "&[F:MAC]BPCNUM=[M:GMC1]BPCNUM"
Endif
If [M:GMC1]ITMREF <> "" Then
    [L]CRITMAC += "&[F:MAC]MACPDTCOD=[M:GMC1]ITMREF"
Endif
If [M:GMC1]SERNUM <> "" Then
    [L]CRITMAC += "&[F:MAC]MACSERNUM=[M:GMC1]SERNUM"
Endif

If [M:GMC1]STATITM <> "" Then
    [L]CRIT1 += "&[F:XMA]STATITM=[M:GMC1]STATITM"
Endif
If [M:GMC1]MACTYP <> "" Then
    [L]CRIT1 += "&[F:XMA]MACTYP=[M:GMC1]MACTYP"
Endif

If [M:CGMC]PISBEG <> [0/0/0] Then
    [L]CRIT2 += "&[F:XMA]PISDAT>=[M:CGMC]PISBEG"
Endif
If [M:CGMC]PISEND <> [0/0/0] Then
    [L]CRIT2 += "&[F:XMA]PISDAT<=[M:CGMC]PISEND"
Endif
If [M:CGMC]BEGGUARBEG <> [0/0/0] Then
    [L]CRIT2 += " & [F:XMA]BEGDATGAR>=[M:CGMC]BEGGUARBEG"
Endif
If [M:CGMC]BEGGUAREND <> [0/0/0] Then
    [L]CRIT2 += " & [F:XMA]BEGDATGAR<=[M:CGMC]BEGGUAREND"
Endif
If [M:CGMC]ENDGUARBEG <> [0/0/0] Then
    [L]CRIT2 += " & [F:XMA]ENDDATGAR>=[M:CGMC]ENDGUARBEG"
Endif
If [M:CGMC]ENDGUAREND <> [0/0/0] Then
    [L]CRIT2 += " & [F:XMA]ENDDATGAR<=[M:CGMC]ENDGUAREND"
Endif
If [M:CGMC]MAINTBEG <> [0/0/0] Then
    [L]CRIT2 += " & [F:XMA]MAINTDAT>=[M:CGMC]MAINTBEG"
Endif
If [M:CGMC]MAINTEND <> [0/0/0] Then
    [L]CRIT2 += " & [F:XMA]MAINTDAT<=[M:CGMC]MAINTEND"
Endif

Case CHGPAG
    When 2 : # suite
        Case [M:CGMC]TRI
            When 1 : # tri par statut
                [L]CRIT3 += "&[F:XMA]STATITM>FINSTAT"
            When 2 : # tri par tiers
                [L]CRITMAC += "&[F:MAC]BPCNUM>FINBPR"
            When 3 : #tri par article
                [L]CRITMAC += "&[F:MAC]MACPDTCOD>FINITM"
        Endcase
    When -2 : # retour
        Case [M:CGMC]TRI
            When 1 : # tri par statut
                [L]CRIT3 += "&[F:XMA]STATITM<DEBSTAT"
            When 2 : # tri par tiers
                [L]CRITMAC += "&[F:MAC]BPCNUM<DEBBPR"
            When 3 : #tri par article
                [L]CRITMAC += "&[F:MAC]MACPDTCOD<DEBITM"
        Endcase
Endcase

Return

###################################################################
$FIN_CRIT
Return


#-----------------------------------------------------------------#
#    Gestion des étiquettes liées aux masques GMC1, GMC2 et CGMC  #
#-----------------------------------------------------------------#
###################################################################
Subprog IB_NBLIG

Raz GBOUT1, GBOUT5

If [M:GMC2]MACPDTCOD(nolign-1) <> "" & [M:GMC2]MACSERNUM(nolign-1) <> "" Then
    GBOUT1 = mess(116,[V]GXMSGPSA,1)
Endif

# LBORN 30/07/2013 - Mantis 20505
If [V]GXOPTSAV & [M:GMC2]MACNUM(nolign-1)<>""
  [V]GBOUT5=func SPVOBJXON.DESOBJ("REQ")
  Global Integer GXLIGMAC
  [V]GXLIGMAC=nolign
Endif

End

###################################################################
Subprog AV_PISEND(VALEUR)
Variable Date    VALEUR
VALEUR = [M]PISBEG
End

###################################################################
Subprog AV_BEGGUAREND(VALEUR)
Variable Date    VALEUR
VALEUR = [M]BEGGUARBEG
End

###################################################################
Subprog AV_ENDGUAREND(VALEUR)
Variable Date    VALEUR
VALEUR = [M]ENDGUAREND
End

###################################################################
Subprog AV_MAINTEND(VALEUR)
Variable Date    VALEUR
VALEUR = [M]MAINTBEG
End
