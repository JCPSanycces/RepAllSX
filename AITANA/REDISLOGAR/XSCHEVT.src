#<AdxTL>@(#)3.0.0.0 $Revision:   1.20  $ Gestion du masque SCHEVTJOU
#ACV#X13
#TIT#Gestion écran de l'action XSCHSAIEVT

#LBO 10/2003

GBIDC1="" : GBIDC2="" : Call OBJET("AGE",[V]GBIDC1,[V]GBIDC2) From GOBJET : End

Local Char PARAM(30)(1..20)
Local Decimal VALEUR

GACTION = "SCHSAIEVT"

PARAM(1)="2"          : # Type durée : 1->Jour, 2->1/2 Jour, 3->Horaire
PARAM(2)="20031017"   : # Date début
PARAM(3)="0900"       : # Heure début
PARAM(4)="20031021"   : # Date fin
PARAM(5)="1500"       : # Heure fin
PARAM(6)="2"          : # Durée travaillé : 1->Non, 2->Oui
PARAM(7)=""           : # Durée en jour
PARAM(8)=""           : # Durée en heure décimale
PARAM(9)=""           : # Durée en minutes
PARAM(10)="LBO6"      : # Code planning
PARAM(11)="1"         : # Modif autorisée : 1->Non, 2->Oui
PARAM(12)="1"         : # Origine : 0->Après contrôle Date fin, 1->Click droit sur une ligne
PARAM(13)="00000000"  : # Date début avant modif d'une ligne
PARAM(14)="00000000"  : # Date fin avant modif d'une ligne
PARAM(15)="2"         : # Ligne déjà modifiée avant l'appel de l'action
PARAM(16)="20031017"  : # Date du jour où est déclenché l'action
PARAM(17)="1"         : # Numéro de ligne

Call TRAITE_NUM(VALEUR,PARAM,"SCHEVTJOU","XSCHSAIEVT","",1) From GTRAITE
Errbox PARAM
End



#-----------------------------------------------------------------------
# Ecrans SCHEVTJOU et SCHEVTDJ
#-----------------------------------------------------------------------


#---------------------------------
Subprog AV_DAYDEB(VALEUR)
Variable Char    VALEUR()
VALEUR=day$([M:DIA]DATDEB)-num$(day([M:DIA]DATDEB))-month$([M:DIA]DATDEB)-num$(year([M:DIA]DATDEB))
End

#---------------------------------
Subprog AV_DAYFIN(VALEUR)
Variable Char    VALEUR()
VALEUR=day$([M:DIA]DATFIN)-num$(day([M:DIA]DATFIN))-month$([M:DIA]DATFIN)-num$(year([M:DIA]DATFIN))
End

#---------------------------------
Subprog AV_DJDEB(VALEUR)
Variable Integer VALEUR
Affzo [M:DIA]DAYDEB
End

#---------------------------------
Subprog AV_DJFIN(VALEUR)
Variable Integer VALEUR
Affzo [M:DIA]DAYFIN
End

#---------------------------------
Subprog AS_DJDEB(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1
End

#---------------------------------
Subprog AS_DJFIN(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=1
If [M:DIA]DATDEB=[M:DIA]DATFIN & [M:DIA]DJDEB=2
  GMENLOC(2)=1
  If VALEUR<>3
    VALEUR=3
    Call AM_DJFIN(VALEUR)
    If mkstat : mkstat=0 : Else mkstat=2 : Endif
  Endif
Endif
End


#---------------------------------
Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR>[M:DIA]DATDAY & [M:DIA]DATDAY<>[0/0/0]
  [V]GERR=1
  [V]GMESSAGE="La date ne doit pas être supérieure au"-format$("D:DD[/]MM[/]YYYY",[M:DIA]DATDAY)
  mkstat=1
Elsif [M:DIA]WKD=2
  Call DISPO_DAT(VALEUR,[M:DIA]PLANCOD,[M:DIA]CODCHO,mkstat) From XSCHSAIEVT
  If mkstat
    [V]GERR=1
  Endif
Endif
End

#---------------------------------
Subprog AM_DATDEB(VALEUR)
Variable Date    VALEUR
Call AM_DATDEB(VALEUR) From XSCHSAIEVT
End

#---------------------------------
Subprog AM_DJDEB(VALEUR)
Variable Integer VALEUR
Call AM_DJDEB(VALEUR) From XSCHSAIEVT
End

#---------------------------------
Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:DIA]DATDAY & [M:DIA]DATDAY<>[0/0/0]
  [V]GERR=1
  [V]GMESSAGE="La date ne doit pas être inférieure au"-format$("D:DD[/]MM[/]YYYY",[M:DIA]DATDAY)
  mkstat=1
Elsif VALEUR=[M:DIA]DATDEB & [M:DIA]DATDAY<>VALEUR & [M:DIA]DATDAY<>[0/0/0]
  [V]GMESSAGE="Evènement à saisir au"-format$("DD:DD[/]MM[/]YYYY",VALEUR)
  GERR=1
  mkstat=1
Elsif VALEUR-[M:DIA]DATDEB>400
  [V]GMESSAGE="Ecart trop important entre la date de début et la date de fin"
  GERR=1
  mkstat=1
Elsif [M:DIA]WKD=2
  Call DISPO_DAT(VALEUR,[M:DIA]PLANCOD,[M:DIA]CODCHO,mkstat) From XSCHSAIEVT
  If mkstat
    [V]GERR=1
  Endif
Endif
End

#---------------------------------
Subprog AM_DATFIN(VALEUR)
Variable Date    VALEUR
Call AM_DATFIN(VALEUR) From XSCHSAIEVT
End

#---------------------------------
Subprog AM_DJFIN(VALEUR)
Variable Integer VALEUR
Call AM_DJFIN(VALEUR) From XSCHSAIEVT
End

#---------------------------------
Subprog C_DJFIN(VALEUR)
Variable Integer VALEUR
If VALEUR<=[M:DIA]DJDEB & [M:DIA]DATDEB=[M:DIA]DATFIN
  mkstat=1
Endif
End

#---------------------------------
Subprog C_DURDAY(VALEUR)
Variable Decimal VALEUR
Local Date ZDAUX
Local Integer ZOK
[L]ZDAUX=[M:DIA]DATFIN
Call CAL_DATFIN([M:DIA]PLANCOD,[M:DIA]CODCHO,[M:DIA]DATDEB,VALEUR,[M:DIA]WKD,[M:DIA]UVYCOD,[L]ZDAUX) From XSCHSAIEVT
If [M:DIA]DATDAY<>[0/0/0]
  Call VERF_FINDAY([M:DIA]DATDEB,[L]ZDAUX,[M:DIA]DATDAY,[L]ZOK) From XSCHSAIEVT
  If ![L]ZOK
    If [L]ZDAUX<[M:DIA]DATDAY
      [V]GERR=1
      [V]GMESSAGE="La date de fin calculée ne peut pas être inférieure au"-format$("D:DD[/]MM[/]YYYY",[M:DIA]DATDAY)
      mkstat=1
    Else
      mkstat=1
    Endif
  Endif
Endif
End

#---------------------------------
Subprog C_DURDJ(VALEUR)
Variable Decimal VALEUR
Local Date ZDAUX
Local Integer ZFLGAUX
Local Integer ZOK
[L]ZDAUX=[M:DIA]DATFIN
Call CAL_DATFINDJ([M:DIA]PLANCOD,[M:DIA]CODCHO,[M:DIA]DATDEB,[M:DIA]DJDEB,VALEUR,[M:DIA]WKD,[M:DIA]UVYCOD,[L]ZDAUX,[L]ZFLGAUX) From XSCHSAIEVT
If [M:DIA]DATDAY<>[0/0/0]
  Call VERF_FINDAY([M:DIA]DATDEB,[L]ZDAUX,[M:DIA]DATDAY,[L]ZOK) From XSCHSAIEVT
  If ![L]ZOK
    If [L]ZDAUX<[M:DIA]DATDAY
      [V]GERR=1
      [V]GMESSAGE="La date de fin calculée ne peut pas être inférieure au"-format$("D:DD[/]MM[/]YYYY",[M:DIA]DATDAY)
      mkstat=1
    Else
      mkstat=1
    Endif
  Endif
Endif
End


#---------------------------------
Subprog AM_DURDAY(VALEUR)
Variable Decimal VALEUR
Call CAL_DATFIN([M:DIA]PLANCOD,[M:DIA]CODCHO,[M:DIA]DATDEB,VALEUR,[M:DIA]WKD,[M:DIA]UVYCOD,[M:DIA]DATFIN) From XSCHSAIEVT
Affzo [M:DIA]DATFIN,DAYFIN
Call CAL_DURHOUMIN(VALEUR,[M:DIA]DURHOU,[M:DIA]DURMIN) From XSCHSAIEVT
[V]XMODIFAGE=1
End

#---------------------------------
Subprog AM_WKD(VALEUR)
Variable Integer VALEUR
Call AM_WKD(VALEUR) From XSCHSAIEVT
End

#---------------------------------
Subprog AM_DURDJ(VALEUR)
Variable Decimal VALEUR
Call CAL_DATFINDJ([M:DIA]PLANCOD,[M:DIA]CODCHO,[M:DIA]DATDEB,[M:DIA]DJDEB,VALEUR,[M:DIA]WKD,[M:DIA]UVYCOD,[M:DIA]DATFIN,[M:DIA]DJFIN) From XSCHSAIEVT
Affzo [M:DIA]DATFIN,DAYFIN,DJFIN
Call CAL_DURHOUMIN(VALEUR,[M:DIA]DURHOU,[M:DIA]DURMIN) From XSCHSAIEVT
[V]XMODIFAGE=1
End

#---------------------------------
Subprog AV_HOUDEB(VALEUR)
Variable Char    VALEUR()
Affzo [M:DIA]DAYDEB
End

#---------------------------------
Subprog AV_HOUFIN(VALEUR)
Variable Char    VALEUR()
Affzo [M:DIA]DAYFIN
End

#---------------------------------
Subprog C_HOUDEB(VALEUR)
Variable Char    VALEUR()
Gosub LEC_CODCHO From XSCHSAIEVT
If instr(1,VALEUR,".") | VALEUR=""
  mkstat=1
Elsif [F:SRC]DAYTRA(dayn([M:DIA]DATDEB)-1)=2 & [M:DIA]WKD=2
  Call CTRL_HD([M:DIA]DATDEB,VALEUR,[M:DIA]PLANCOD,[M:DIA]CODCHO,mkstat) From XSCHSAIEVT
  If mkstat
    [V]GMESSAGE="Heure non travaillée"
    GERR=1
  Endif
Endif
End

#---------------------------------
Subprog C_HOUFIN(VALEUR)
Variable Char    VALEUR()
Gosub LEC_CODCHO From XSCHSAIEVT
If instr(1,VALEUR,".") | (val(VALEUR)<=val([M:DIA]HOUDEB) & [M:DIA]DATDEB=[M:DIA]DATFIN) | VALEUR=""
  mkstat=1
Elsif [F:SRC]DAYTRA(dayn([M:DIA]DATFIN)-1)=2 & [M:DIA]WKD=2
  Call CTRL_HF([M:DIA]DATFIN,VALEUR,[M:DIA]PLANCOD,[M:DIA]CODCHO,mkstat) From XSCHSAIEVT
  If mkstat
    [V]GMESSAGE="Heure non travaillée"
    GERR=1
  Endif
Endif
End


#---------------------------------
Subprog AM_HOUDEB(VALEUR)
Variable Char    VALEUR()
Call AM_HOUDEB([M:DIA]DATDEB,VALEUR) From XSCHSAIEVT
End

#---------------------------------
Subprog AM_HOUFIN(VALEUR)
Variable Char    VALEUR()
Call AM_HOUFIN([M:DIA]DATFIN,VALEUR) From XSCHSAIEVT
End

#---------------------------------
Subprog C_DURHOU(VALEUR)
Variable Decimal VALEUR
Local Date ZDAUX
Local Char ZHAUX(4)
Local Integer ZOK
[L]ZDAUX=[M:DIA]DATFIN
[L]ZHAUX=[M:DIA]HOUFIN        
Call CAL_DATFINH([M:DIA]PLANCOD,[M:DIA]CODCHO,[M:DIA]DATDEB,[M:DIA]HOUDEB,(VALEUR*61)-1,[M:DIA]WKD,[M:DIA]UVYCOD,[L]ZDAUX,[L]ZHAUX) From XSCHSAIEVT
If [M:DIA]DATDAY<>[0/0/0]
  Call VERF_FINDAY([M:DIA]DATDEB,[L]ZDAUX,[M:DIA]DATDAY,[L]ZOK) From XSCHSAIEVT
  If ![L]ZOK
    If [L]ZDAUX<[M:DIA]DATDAY
      [V]GERR=1
      [V]GMESSAGE="La date de fin calculée ne peut pas être inférieure au"-format$("D:DD[/]MM[/]YYYY",[M:DIA]DATDAY)
      mkstat=1
    Else
      mkstat=1
    Endif
  Endif
Endif
End

#---------------------------------
Subprog AM_DURHOU(VALEUR)
Variable Decimal VALEUR
Call CAL_DATFINH([M:DIA]PLANCOD,[M:DIA]CODCHO,[M:DIA]DATDEB,[M:DIA]HOUDEB,VALEUR*60+[M:DIA]DURMIN,[M:DIA]WKD,[M:DIA]UVYCOD,[M:DIA]DATFIN,[M:DIA]HOUFIN) From XSCHSAIEVT
Affzo [M:DIA]DATFIN,DAYFIN,HOUFIN
[V]XMODIFAGE=1
End

#---------------------------------
Subprog C_DURMIN(VALEUR)
Variable Decimal VALEUR
Local Date ZDAUX
Local Char ZHAUX(4)
Local Integer ZOK
If [M:DIA]DURHOU=0 & VALEUR=0
  [V]GMESSAGE="Durée obligatoire"
  GERR=1
  mkstat=1
Else
  [L]ZDAUX=[M:DIA]DATFIN
  [L]ZHAUX=[M:DIA]HOUFIN        
  Call CAL_DATFINH([M:DIA]PLANCOD,[M:DIA]CODCHO,[M:DIA]DATDEB,[M:DIA]HOUDEB,[M:DIA]DURHOU*60+VALEUR,[M:DIA]WKD,[M:DIA]UVYCOD,[L]ZDAUX,[L]ZHAUX) From XSCHSAIEVT
  If [M:DIA]DATDAY<>[0/0/0]
    Call VERF_FINDAY([M:DIA]DATDEB,[L]ZDAUX,[M:DIA]DATDAY,[L]ZOK) From XSCHSAIEVT
    If ![L]ZOK
      If [L]ZDAUX<[M:DIA]DATDAY
        [V]GERR=1
        [V]GMESSAGE="La date de fin calculée ne peut pas être inférieure au"-format$("D:DD[/]MM[/]YYYY",[M:DIA]DATDAY)
        mkstat=1
      Else
        mkstat=1
      Endif
    Endif
  Endif
Endif
End

#---------------------------------
Subprog AM_DURMIN(VALEUR)
Variable Decimal VALEUR
Call CAL_DATFINH([M:DIA]PLANCOD,[M:DIA]CODCHO,[M:DIA]DATDEB,[M:DIA]HOUDEB,[M:DIA]DURHOU*60+VALEUR,[M:DIA]WKD,[M:DIA]UVYCOD,[M:DIA]DATFIN,[M:DIA]HOUFIN) From XSCHSAIEVT
Affzo [M:DIA]DATFIN,DAYFIN,HOUFIN
[V]XMODIFAGE=1
End

