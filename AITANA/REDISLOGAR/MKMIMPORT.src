#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPORTATION("MKM") From GIMPOBJ
End

###################################################################################
$ACTION
Case ACTION
    When "EXPORT"    :  Gosub EXPORT
    When "IMP_ZONE"  :  Gosub IMP_ZONE
    When "IMP_FERME" :  Gosub IMP_FERME
Endcase
Return

###################################################################################
$EXPORT
If clalev ([F:MTK]) = 0 : Local File MFGHEADTRK  [MTK] : Endif
Read [F:MTK]MTK0 = [F:MKM]MFGTRKNUM
# 57336 Modification du nombre de paramètres de SETDATE
If !fstat : Call SETDATE([F:MTK]MFGTRKDAT,GIMP(1),[F:AOE]OPTDAT) From SUBEXPOBJ : Endif
#If !fstat : GIMP(1)= [F:MTK]MFGTRKDAT : Endif
Return

###################################################################################
$IMP_FERME
# GH 04/10/2013 bug 87599 gestion du lock symbole sur OF
Call DELOCK("MFG") From GLOCK
Return

###################################################################################
$IMP_ZONE
Case IMPFIC
  When "MKM"
      #----- Pas de contrôle si les comptes et sections sont importés avec "CAL" -----#
      If find("CPTANALIN",[M:AOE1]FLGFIL(0..[M:AOE1]NBRFLG))
        OK=0 : mkstat=1 : # Zones non concernées par PRECEIPTD
      Endif
      #-----
  When "CAL"
    #----- La zone présente dans le modèle a déjà été chargée par IMPORT_ACCCCE du $SAIMSK
    If find("[F:CAL]"+IMPZON+"(0)",[M:AOE2]ZONMSK1)
      If GSTK_TRACE=2
        GSTK_ACT="IMP_ZONE("+IMPZON+")" : GSTK_PGM="MKMIMPORT"
        Gosub TRACE_DETAILLEE From STKIMP
      Endif
      IMPMOD=1
    Endif
    OK=0
    #-----
     When "STJ"
           GSTK_ACTION="IMP_ZONE" : Gosub ACTION From STKIMP
Endcase
Return

###########################################################
# Ouvertures                                              #
# GIMP :                                                  #
#     GIMP(1) : Date du suivi                             #
#     GIMP(2) : Transaction suivi des matières à utiliser #
#     GIMP(3) : Indicateur de solde                       #
###########################################################
$OUVRE
Local   Char    WMESSAGE(250)
Global  Char    GMMLNUM(GLONTRS)
Global  Integer G_DATOK, G_TRSOK, G_CLEFLGOK
Global  Integer G_LIN, G_WNBMAT
Global  Integer G_WMATCLENBR
Global  Date    G_DATE
# Issue 86522 - 2013-03-06 by CCC : sauvegarde du site précédent
Global  Char    G_FCY(GLONFCY)
Global  Char    G_MFGNUM(GLONVCR),G_WMFGNUM(GLONVCR),G_MFGTRKNUM(GLONVCR)

Global   Char    GSTK_ACTION (20)                              : # Nom action de STKIMP
Global   Char    GSTK_BASTAB (20) : GSTK_BASTAB="[M:MBM]NBLIG": # Nom variable bas tableau
Global   Libelle GSTK_TRSTYP      : GSTK_TRSTYP=6              : # Type mouvement (M.704)
Global   Libelle GSTK_VCRTYP      : GSTK_VCRTYP=12              : # Type piÃ¨ce (M.701)

#---- GH 03/10/2013 bug 92531
#Global   Libelle GSTK_TRACE       : GSTK_TRACE =2              : # Trace dÃ©taillÃ©e si =2
Global   Libelle GSTK_TRACE       : GSTK_TRACE =1              : # Trace dÃ©taillÃ©e si =2
If GSTOTRACE>2 : GSTK_TRACE=2 : Endif
#-----

Local Integer DEBENR_SVG, LCOMMIT
Local Integer WMKMFLG : WMKMFLG=1
Local Integer WADXSEK, NBENR_SVG
#
#Pour savoir si la date de suivi et la transaction à utiliser sont paramétrées
Call TST_CHAMP("MKM","*1",G_DATOK)    From SUBIMPOBJ    : # date du suivi
Call TST_CHAMP("MKM","*2",G_TRSOK)    From SUBIMPOBJ    : # Transaction de suivi des temps
Call TST_CHAMP("MKM","*3",G_CLEFLGOK) From SUBIMPOBJ    : # Indicateur de solde
#
If clalev([M:MBM])=0  : Local Mask MTKBENCHM [MBM]  : Endif       # masque buffer suivi matière
If clalev([M:MTMK])=0 : Local Mask MTMK      [MTMK] : Endif       # masque buffer suivi matière
If clalev([F:FCY])<=0 : Local File FACILITY  [FCY]  : Endif
If clalev([M:ORDK])=0 : Local Mask ORDK      [ORDK] : Endif       # pour générer encours
If clalev([M:STW])=0  : Local Mask STOWORK   [STW]  : Endif  # masque STOCK
If !clalev([M:SVW])  : Local Mask STOVALWORK [SVW]  : Endif

If clalev([M:SOW])=0  : Local Mask STOSORW   [SOW]  : Endif  # masque de travail sorties
If clalev([M:ALP])=0  : Local Mask ALLPAR    [ALP]  : Endif  # masque de travail sorties
If clalev([M:MTMK])=0 : Local Mask MTMK      [MTMK] : Endif       # masque buffer suivi matière
If clalev([F:BOH])<=0 : Local File BOM        [BOH] : Endif
If clalev([F:BOD])<=0 : Local File BOMD       [BOD] : Endif
If clalev([F:BOD1])<=0: Local File BOMD      [BOD1] : Endif
If clalev([F:ITM])<=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF])<=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITG])<=0 : Local File ITMCATEG   [ITG] : Endif
If clalev([F:ITV])<=0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:MFG])<=0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:MFI])<=0 : Local File MFGITM     [MFI] : Endif
If clalev([F:MFM])<=0 : Local File MFGMAT     [MFM] : Endif
If clalev([F:MFM1])<=0: Local File MFGMAT    [MFM1] : Endif
If clalev([F:MFO])<=0 : Local File MFGOPE     [MFO] : Endif
If clalev([F:MTK])<=0 : Local File MFGHEADTRK [MTK] : Endif
If clalev([F:MKI])<=0 : Local File MFGITMTRK  [MKI] : Endif
If clalev([F:MKM])<=0 : Local File MFGMATTRK  [MKM] : Endif
If clalev([F:TCA])<=0 : Local File TABCOUAFF  [TCA] : Endif
If clalev([F:TBO])<=0 : Local File TABBOMALT  [TBO] : Endif
If clalev([F:STA])<=0 : Local File STOALL     [STA] : Endif
If clalev([F:STO])<=0 : Local File STOCK      [STO] : Endif
If clalev([F:STC])<=0 : Local File STOLOC     [STC] : Endif
If clalev([F:STJ])<=0 : Local File STOJOU     [STJ] : Endif
If clalev([F:STL])<=0 : Local File STOLOT     [STL] : Endif
If clalev([F:ORD])<=0 : Local File ORDERS     [ORD] : Endif
If clalev([F:MWS])<=0 : Local File WORKSTATIO [MWS] : Endif
If clalev([F:BTS])<=0 : Local File BENCHTRS   [BTS] : Endif
If clalev([F:DTR])<=0 : Local File DIETRS     [DTR] : Endif
If clalev([F:ADP])<=0 : Local File ADOPAR     [ADP] : Endif
If clalev([F:ADW])<=0 : Local File ADOVAL     [ADW] : Endif
If clalev([F:CAL])<=0 : Local File CPTANALIN  [CAL] : Endif
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif

# Issue 75838 - 2011-09-05 by CCC
Raz [M:SOW], [M:STW]

# Issue 86725 GA 07/2014 see CHARG_PARAM
#Récupération du compteur
#Local Integer WOK, WERR
#Call LECTCA(8,WOK) From SUBTCA
#If WOK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
#GCODNUM    = [F:TCA]CODNUM(2)   # compteur suivi
#GMANCOU    = [F:TCA]MANCOU(2)
#GOPS       = [F:TCA]CODNUM(4)   # compteur encours opérations
Raz G_LIN, G_DATE, G_FCY
Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub CHARG_PARAM
Gosub STK_INILOC From STKLOC

Gosub FLD_MODELE From TRTX3IMP

GSTK_ACTION="OUVRE" : Gosub ACTION From STKIMP

Return

####################################################
$CHARG_PARAM
#Local Char     MKMPARAM(10)
#Global Char    GMKMTRSNUM(GLONTRS)
#Global Libelle GMTKALLMGT

Gosub CHARG_PARAM From FUNBENCHM

# Issue 81181 - 2012-03-29 by CCC : Récupération de la transaction par défaut
If G_TRSOK            : Read [F:BTS]BTS0 = 61;GIMP(2)
                        If fstat
                           Read [F:BTS]BTS0 = 61;GMKMTRSNUM
                           If fstat
                               OK = 0 : GOK = 0
                           Else
                               GMMLNUM=GMKMTRSNUM
                           Endif
                        Else
                               GMMLNUM=GIMP(2)
                        Endif
Else
                        Read [F:BTS]BTS0 = 61;GMKMTRSNUM
                        If fstat
                            OK = 0 : GOK = 0
                        Else
                            GMMLNUM=GMKMTRSNUM
                        Endif
Endif
If GOK = 0
        WMESSAGE = mess(6,199,1)+"BTSNUM" - [M:MTMK]ITMREF
        Call ECR_TRACE(WMESSAGE,1) From GESECRAN
Endif
Call GETCPY(GFCY,"BTS",61,GMMLNUM) From TRTX3CPT


## Transaction suivi matières import
#Call PARAM(GFCY,"MKMTRSNUM",MKMPARAM) From ADOVAL
#GMKMTRSNUM = MKMPARAM
## Allocation à l'OF obligatoire
#Call PARAM(GFCY,"MTKALLMGT",MKMPARAM) From ADOVAL
#GMTKALLMGT = val(MKMPARAM)

# Issue 86725 GA 07/2014 idem 72699/SUBMTKA Change counter when change current site
Local Integer WOK, WERR
Call LECTCA(8,WOK) From SUBTCA
If WOK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
GCODNUM    = [F:TCA]CODNUM(2)   # compteur suivi
GMANCOU    = [F:TCA]MANCOU(2)
GOPS       = [F:TCA]CODNUM(4)   # compteur encours opérations

Return

######################################################
# Réinitialisation après création (début de lecture)
$RAZCRE
Raz [M:MTMK]
GREP="C"
Return

######################################################
$SAIMSK
Local Integer I,J

If IMPFIC<>"MKM" : WMKMFLG=0 :Endif # Permet de savoir si on importe autre chose que seulement le suivi

Case IMPFIC
  When "MKM"
      Raz [M:MBM]
      nolign = 1
      indice = 0
      Raz GSTK_NBLIG
      # Issue 85182 - 2012-10-25 by CCC
      Raz [F:CAL]
      [M:MBM] = [F:MKM]
      [M:MBM]FCY = [F:MKM]MFGFCY
      # Issue 81181 - 2012-03-29 by CCC : Récupération de la transaction par défaut
      If [M:MBM]FCY <> GFCY
           GFCY = [M:MBM]FCY
           Gosub CHARG_PARAM
      Endif
      # Issue 87780 - 2013-03-07 by CCC
      If G_CLEFLGOK : [M:MBM]CLEFLG = val(GIMP(3))
      Else          : [M:MBM]CLEFLG = 3
      Endif
      If [M:MBM]CLEFLG(nolign-1) = 0 : [M:MBM]CLEFLG = 3 : Endif

      [M:MBM]NBLIG += 1
      If G_DATOK
          Call SETDATE([M:MBM]IPTDAT,GIMP(1),[M:AOE1]OPTDAT,WERR) From SUBIMPOBJ
          If WERR : WMESSAGE = mess(6,199,1)+"IPTDAT" - [M:MBM]ITMREF
               Call ECR_TRACE(WMESSAGE,1) From GESECRAN
               OK = 0
               GOK = 0
          Endif
      Else
          [M:MBM]IPTDAT = date$
      Endif
      If [F:ITM]ITMREF<>[M:MBM]ITMREF([M:MBM]NBLIG-1)
         Read [ITM] ITM0=[M:MBM]ITMREF([M:MBM]NBLIG-1)
         If fstat  Raz [F:ITM] : Endif
      Endif
      If [F:ITF]ITMREF<>[M:MBM]ITMREF([M:MBM]NBLIG-1) | [F:ITF]STOFCY<>[M:MBM]FCY
         Read [ITF] ITF0=[M:MBM]ITMREF([M:MBM]NBLIG-1);[M:MBM]FCY
         If fstat  Raz [F:ITF] : Endif
      Endif

  When "CAL"
   # Issue 94225 GA 11/2013
    Default Mask [MBM]
    indice=nolign-1 : mkstat=0

    For I=1 To GNBDIE # before: max(GNBDIE,GOPTCANA)
#----------------- Contrôle des sections analytiques -----------------#
        Call CTRL_CCE([F:CAL]CCE(I-1),I,"",GFINRSP,[M:MBM]IPTDAT) From TRTX3CPT
        If mkstat
            Call ECR_TRACE(GMESSAGE,1) From GESECRAN
            Raz GMESSAGE
            Raz OK, GOK
            Break
        Endif
        J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
        If J
            Assign "[M:MBM]CCE"+num$(J) With [F:CAL]CCE(I-1)
        Endif
    Next I

   When "STJ"
        Default File [STJ]

        GSTK_ACTION="SAIMSK" : Gosub ACTION From STKIMP
        If mkstat : GREP="" : REP="" : mkstat=0 : GOK=0 : Endif
Endcase
If GOK<1
  GOK=1
  LCOMMIT=1
  Gosub FIN_DOC
  LCOMMIT=0
  GOK=0
Endif
Return

######################################################
# Contrôles et mises à jour
$VALID
Local Char LSEC(GLONCCE)

If GOK<=0
    Call ECR_TRACE("Pas normal !!! $valid et gok"+num$(GOK),1) From GESECRAN
    Goto FIN_VALID
Endif

If GREP=""
    Raz GSTK_NBLIG
    OK=0
    Goto FIN_VALID
Endif

If [M:MBM]USEQTY = 0
    WMESSAGE = mess(28,190,1) - [M:MBM]MFGNUM(0)-[M:MBM]ITMREF(0)
    Call ECR_TRACE(WMESSAGE,1) From GESECRAN
    OK = 0
    GOK = 0
    LCOMMIT=1
    # Issue 78484 & 78521 - 2011-12-12 by CCC : il faut continuer pour fermer la transaction
    Goto FIN_VALID
Endif
# Chargement [MTMK]
Raz [M:MTMK]
[M:MTMK]             = [M:MBM]
[M:MTMK]MFGFCY       = [M:MBM]FCY
# 03.07 demande 40392
[M:MTMK]WNBMAT       = G_WNBMAT

# Issue 83567 GA 07/2012
Call GETSOC([M:MTMK]MFGFCY) From DEVSUB
Call GETCPY([M:MTMK]MFGFCY,"",0,"") From TRTX3CPT

Raz [M:MTMK]MFGTRKNUM
#If G_DATOK
#    Call SETDATE([M:MTMK]IPTDAT,GIMP(1),[M:AOE1]OPTDAT,WERR) From SUBIMPOBJ
#    If WERR : WMESSAGE = mess(6,199,1)+"IPTDAT" - [M:MTMK]ITMREF
#             Call ECR_TRACE(WMESSAGE,1) From GESECRAN
#             OK = 0
#             GOK = 0
#            # Issue 78484 & 78521 - 2011-12-12 by CCC : il faut continuer pour fermer la transaction
#            Goto FIN_VALID
#    Endif
#                       [M:MTMK]IPTDAT = GIMP(1)
#Else                  : [M:MTMK]IPTDAT = date$
#Endif

# Issue 81181 - 2012-03-29 by CCC : Déjà fait dans SAIMSK
#If G_TRSOK            : Read [F:BTS]BTS0 = 61;GIMP(2)
#                        If fstat
#                           Read [F:BTS]BTS0 = 61;GMKMTRSNUM
#                           If fstat : OK = 0 : GOK = 0 : Endif
#                        Endif
#Else
#                        Read [F:BTS]BTS0 = 61;GMKMTRSNUM
#                        If fstat : OK = 0 : GOK = 0 : Endif
#Endif
#If GOK = 0
#        WMESSAGE = mess(6,199,1)+"BTSNUM" - [M:MTMK]ITMREF
#        Call ECR_TRACE(WMESSAGE,1) From GESECRAN
#        # Issue 78484 & 78521 - 2011-12-12 by CCC : il faut continuer pour fermer la transaction
#        LCOMMIT=1
#        Goto FIN_VALID
#Endif
[M:MTMK]STOCODMAN    = [F:BTS]STOCODMAN
[M:MTMK]ENTCOD       = [F:BTS]ENTCODS
[M:MTMK]TRSFAM       = [F:BTS]TRSFAMS
[M:MTMK]TRSCODS      = [F:BTS]TRSCODS

If [M:MTMK]MFGNUM <> ""
   [M:MTMK]TYPTRT = 4 # sr deviendra peut-être  12 si matière inexistante sur l'OF
# Issue 87780 - 2013-03-07 by CCC : GIMP contient déjà la valeur suivante
#   If G_CLEFLGOK : [M:MTMK]CLEFLG = val(GIMP(3))
#   Else          : [M:MTMK]CLEFLG = 3
#   Endif
#   If [M:MTMK]CLEFLG = 0 : [M:MTMK]CLEFLG = 3 : Endif
Elsif [M:MTMK]BOMNUM <> "" & [M:MTMK]BOMALT <> 0
      [M:MTMK]TYPTRT = 8 # sr deviendra peut-être 13 si matière inexistante sur la nomenclature
Else
  # Aucun suivi effectué
   WMESSAGE = mess(28,190,1)-[M:MTMK]BOMNUM-num$([M:MTMK]BOMALT)
   Call ECR_TRACE(WMESSAGE,1) From GESECRAN
   GOK=0
   LCOMMIT=1
   Goto FIN_VALID
Endif
#
Read [F:ITM]ITM0 = [M:MTMK]ITMREF
If fstat : Raz [F:ITM] : Endif

# Issue 83567 GA 07/2012
For I=1 To GNBDIE
    J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
    If J
        Assign "[M:MTMK]CCE"+num$(J) With [F:CAL]CCE(I-1)
    Endif
Next

# Issue 83567 GA 07/2012
For I=1 To GNBDIE
    If evalue("[M:MTMK]CCE"+num$(I))=""
        Raz LSEC
        Call INIT_CCE(LSEC,I,"MKMB","",0) From TRTX3CPT
        Assign "[M:MTMK]CCE"+num$(I) With LSEC
    Endif
Next I
#

Call ECR_TRACE ("VALID_1",0) From GESECRAN

Gosub CONTROLE_IMP

Call ECR_TRACE ("VALID_2",0) From GESECRAN

If !OK
    Call ECR_TRACE(WMESSAGE,1) From GESECRAN
    GOK = 0
    LCOMMIT=1
Else  # CCC (2009-11-13) Bug 57648 : En cas d'erreur on continue pour fermer la transaction mais on ne crée pas la ligne de suivi
    [M:MTMK]STU = [F:ITM]STU

    # Issue 78118 - 2012-01-05 by CCC
    Raz WMESSAGE
    Call ECR_TRACE ("VALID_2_1",0) From GESECRAN
    Gosub CRE_SUIVI
    Call ECR_TRACE ("VALID_2_2",0) From GESECRAN
    If GOK < 1
        If WMESSAGE<>""
            Call ECR_TRACE(WMESSAGE,1) From GESECRAN
        Endif
         WMESSAGE = mess(254,193,1)
         Call ECR_TRACE(WMESSAGE,1) From GESECRAN
         WMESSAGE = mess(255,193,1)
         Call ECR_TRACE(WMESSAGE,1) From GESECRAN
         Gosub COP_SVG
    Endif
    # 100766 - 2014-11-13 by mm
    # component untracked because no stock available; we must generate an error file
    If [M:MTMK]USEQTY = 0
      GOK = 0
      LCOMMIT=1
      GERR = 0
    Endif
Endif

Call ECR_TRACE ("VALID_3",0) From GESECRAN

$FIN_VALID
If LCOMMIT & GOK=0
    GOK=1
    Gosub FIN_DOC
    GOK=0
Else
    Gosub FIN_DOC
Endif

LCOMMIT=0
Return


$FIN_DOC
If IMPFIN | GOK<=0 | LCOMMIT
   If G_WMFGNUM <> "" : Gosub MAJ_ENTOF  : Endif
   If G_WNBMAT <> 0
      Gosub CRE_ENTETE
      If GOK < 1
         WMESSAGE = mess(254,193,1)
         Call ECR_TRACE(WMESSAGE,1) From GESECRAN
         WMESSAGE = mess(255,193,1)
         Call ECR_TRACE(WMESSAGE,1) From GESECRAN
         Gosub COP_SVG
      Endif
   Else
      If adxlog <> 0 : Rollback : Endif
   Endif
   OK  = 0
   TRA = 0
   #GOK=1
Endif
Return

######################################################
# Contrôles
$CONTROLE_IMP
Local Date    WDAT
Local Char    WFCY(GLONFCY)
Local Char    WITM(GLONITM)
Local Char    WLOC(GLONLOC) : # FQ 43237
Local Char    WLOT(GLONLOT) : # FQ 43237
Local Integer WALT, WALTTYP, WBOD_OK, I , J
Local Integer TABTBO(3)
Local Integer WCUNFLG
Local Decimal WDIS, WALLQTY, WALLQTYSHT
Local Integer WRET

Call LECSRU([M:MTMK]MFGFCY,[F:ITM]TCLCOD,6,[M:MTMK]TRSCODS,"",WRET) From STKLIB

# Issue 81181 - 2012-03-29 by CCC : Déjà fait dans SAIMSK
#Call GETCPY([M:MTMK]MFGFCY,"BTS",61,GMKMTRSNUM) From TRTX3CPT    # alimentation de GSOCIETE et GTYPGEN

#Contrôle OF
If [M:MTMK]TYPTRT = 4
    # GH 04/10/2013 bug 87599 gestion du lock symbole sur OF
    Lock ="MFG"+[M:MTMK]MFGNUM
    If fstat
       # Ordre de fabrication : Modification en cours sur un autre poste
       WMESSAGE = mess(156,197,1)-[M:MTMK]MFGNUM-":"-mess(10,100,1) : OK=0 : Return
    Endif

    Read [F:MFM]MFM0 = [M:MTMK]MFGNUM;[M:MTMK]MFGLIN;[M:MTMK]BOMSEQ;[M:MTMK]ITMREF
    # sr 09.02 1.4.0 pouvoir importer des suivis sur matières non prévues
    If fstat
       [M:MTMK]TYPTRT = 12
      # GA 43237 pb dans CRE_MKM si [F:MFM] n'a pas été maj => ajout d'une affectation de [F:MFM]
       Raz [F:MFM] : [F:MFM]=[M:MTMK]
      # Issue 110979/1 - 2016-03-24 by ALSHE : Warning message when released product is versioned
      If [F:MFI]MFGNUM<>[M:MTMK]MFGNUM
        Read [F:MFI]MFI0(1) = [M:MTMK]MFGNUM
        [G:MFI]currlen=0
      Endif
      If [F:MFI]ECCVALMAJ <> ""
        WMESSAGE = mess(347,193,1)-[M:MTMK]MFGNUM-num$([M:MTMK]MFGLIN)-num$([M:MTMK]BOMSEQ)-[M:MTMK]ITMREF
        Call ECR_TRACE(WMESSAGE,-1) From GESECRAN
      Else
        WMESSAGE = mess(85,195,1)-[M:MTMK]MFGNUM-num$([M:MTMK]MFGLIN)-num$([M:MTMK]BOMSEQ)-[M:MTMK]ITMREF
        Call ECR_TRACE(WMESSAGE,0) From GESECRAN
      Endif
    Else
        Read [CAL] CAL0="MFM";0;[F:MFM]MFGNUM;[F:MFM]MFGLIN;[F:MFM]BOMSEQ;[F:MFM]ITMREF;1
        If !fstat
            For I=1 To max(GNBDIE,GOPTCANA)
                J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
                If J & evalue("[M:MTMK]CCE"+num$(J))=""
                  Assign "[M:MTMK]CCE"+num$(J) With [F:CAL]CCE(I-1)
                Endif
            Next I
        Endif
    Endif
    If [M:MTMK]MFGFCY = "" : [M:MTMK]MFGFCY = [F:MFM]MFGFCY : Endif
    Read [MFG]MFG0 = [M:MTMK]MFGNUM
    If fstat
       WMESSAGE = mess(151,193,1) - [M:MTMK]MFGNUM
       OK = 0
       Return
    Endif
    #L'OF doit être complet
    If [F:MFG]TYPMOD = 1    : WMESSAGE = mess(51,190,1)- [M:MTMK]MFGNUM : OK = 0 : Return : Endif
    #L'OF doit être ferme
    If [F:MFG]MFGSTA <> 1   : WMESSAGE = mess(19,190,1)- [M:MTMK]MFGNUM : OK = 0 : Return : Endif
    #Selon paramètre général l'OF doit être alloué complètement
    If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
         WMESSAGE = mess(18,190,1) - [M:MTMK]MFGNUM
         OK = 0
         Return
    Endif
    #Selon paramètre général, l'OF doit être édité
    If  [F:MFG]MFGTRKFLG < 3 &  GDOSFAB = 2
        WMESSAGE = mess(20,190,1) - [M:MTMK]MFGNUM
        OK = 0
        Return
    Endif

    # boucle d'analyse des matières bloquantes si rupture
    # 10.02 Performances
    For [MFM1]MFM0 Where MFGNUM = [F:MFG]MFGNUM
        If [F:MFM1]SHTQTY <> 0
           Read [ITF]ITF0=[F:MFM1]ITMREF;[F:MFM1]MFGFCY
           If !fstat & [F:ITF]MFGSHTCOD = 1
              WMESSAGE = mess(105,193,1)- [M:MTMK]MFGNUM +" ("+[F:MFM1]ITMREF+")"
              OK = 0
              Break
           Endif
        Endif
    Next
    If OK = 0 : Return : Endif
Elsif [M:MTMK]TYPTRT = 8
    #Contrôle nomenclature
    WITM=[M:MTMK]BOMNUM
    WDAT=[M:MTMK]IPTDAT
    WFCY=[M:MTMK]MFGFCY
    WALT=[M:MTMK]BOMALT
    WALTTYP=2
    #    Lecture BOM
    Read [TBO]TBO0=WALTTYP;WALT
    If fstat : WMESSAGE = mess(154,193,1) - [M:MTMK]BOMNUM+"/"+num$([M:MTMK]BOMALT): OK = 0 : Return : Endif
    Read [BOH]BOH0=WITM;WALT;WALTTYP
    If fstat
        WMESSAGE = mess(95,193,1) - [M:MTMK]BOMNUM+"/"+num$([M:MTMK]BOMALT)
        OK = 0
        Return
    Endif
    Call CONTMFGNOM(WFCY,WALT,WDAT,1) From MFGLIB
    If WALT=0 : OK = 0 : Return : Endif
    Raz WBOD_OK
    Read [F:BOD]BOD0 = WITM;WALT;[M:MTMK]BOMSEQ;[M:MTMK]ITMREF;WALTTYP
    If fstat
       #Lecture invalide, traversée éventulelle des fantômes
       # 10.02 Performances
       For [BOD]BOD0 Where ITMREF = WITM & BOMALT = WALT & BOMALTTYP = WALTTYP
           Read [F:ITM]ITM0 = [F:BOD]CPNITMREF
           If [F:ITM]PHAFLG = 2
              Read [F:BOD1]BOD0 = [F:ITM]ITMREF;WALT;[M:MTMK]BOMSEQ;[M:MTMK]ITMREF;WALTTYP
              If ! fstat : WBOD_OK = 1 : Break : Endif
           Endif
       Next
    Else
       If !find([F:BOD]CPNTYP,5,6) :  WBOD_OK = 1 : Endif
    Endif
  # sr 09.02 1.4.0 pouvoir importer des suivis sur matières non prévues
    If !WBOD_OK : [M:MTMK]TYPTRT = 13 :  Endif
Endif

# controle site
Call LECTURE("FCY",[M:MTMK]MFGFCY,"") From CONTOBJ
If fstat | [F:FCY]MFGFLG <> 2
    WMESSAGE = mess(1,193,1)  - [M:MTMK]MFGFCY
    OK = 0
    Return
Endif
If [M:MTMK]MFGFCY <> GFCY
   GFCY = [M:MTMK]MFGFCY
   Gosub CHARG_PARAM
Endif
#Controle de la date
GMESSAGE = ""
# <GON> Quito controles para la importación
If 1 = 2

Call STKCTRIPT([M:MTMK]IPTDAT, [M:MTMK]MFGFCY, "1") From STKLIB
If GMESSAGE <> "": WMESSAGE = GMESSAGE : GMESSAGE="" : OK = 0 : Return : Endif
# controle article
If [F:ITM]ITMREF <> [M:MTMK]ITMREF
   Read [ITM]ITM0 = [M:MTMK]ITMREF
   If fstat
      WMESSAGE = mess(134,100,1) - [M:MTMK]ITMREF
      OK = 0
      Return
   Endif
Endif

# controle article-site
If [F:ITF]ITMREF <> [M:MTMK]ITMREF | [F:ITF]STOFCY <> [M:MTMK]MFGFCY
    Read [ITF]ITF0 = [M:MTMK]ITMREF;[M:MTMK]MFGFCY
    If fstat
        WMESSAGE = mess(2,196,1)+" : "+[M:MTMK]ITMREF - [M:MTMK]MFGFCY
        OK = 0
        Return
    Endif
Endif
Endif
#Contrôle inventaire
If [F:ITF]CUNFLG = 2
    Raz WCUNFLG
    If [M:MTMK]TYPTRT = 4 & [F:MFM]ALLSTA > 3
        Gosub REC_LOC From SUBMTKB
    Else
        # sr 06.02 Si emplacement importé on doit controler sur celui ci
        If [M:MTMK]LOCPREF <> ""
            Filter [F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF &
&                                LOC = [M:MTMK]LOCPREF & CUNLOKFLG = 1
&                      Order By Key STO3

        Else
            Filter [F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF & CUNLOKFLG = 1
&                      Order By Key STO3
        Endif
        Read [F:STO]STO3 First
        If fstat WCUNFLG = 2 : Endif
        Filter [F:STO]
    Endif
    If WCUNFLG = 2 : WMESSAGE = mess(185,199,1)+" : " +[M:MTMK]ITMREF-[M:MTMK]MFGFCY
       OK = 0
       Return
    Endif
Endif

# sr 06.02 recalcul de la qté en unité active si besoin
If [F:ITF]STOMGTCOD = 3 & [F:BTS]TYPQTY = 2 & [M:MTMK]LOTPREF <> ""
    Read [F:STL]STL0(2) = [F:ITM]ITMREF;[M:MTMK]LOTPREF
    If !fstat & [F:STL]POT <> 0
        [M:MTMK]USEQTY = ([M:MTMK]USEQTY * [F:STL]POT) / 100
    Endif
Endif

#sr 06.02 Si stock négatif interdit et LOT/empl/statut importés
#controle qu'on a du stock
# FQ 43237 GA 10/2007 Si stock négatif interdit: toujours vérifier si stock dispo
#If [F:ITM]NEGSTO = 1 & [M:MTMK]LOTPREF <> "" & [M:MTMK]LOCPREF <> ""

# <GON> Quito los controles de Stock para la importación
##If [F:ITM]NEGSTO <> 2
If [F:ITM]NEGSTO <> 2 and 1= 2

  # FQ 43237 GA 10/2007 les codes LOCPREF ou LOTPREF peuvent être renseignés
  #                     dans la ligne importée ou sur [F:MFM]
    If [M:MTMK]LOTPREF <> ""  WLOT = [M:MTMK]LOTPREF
    Elsif [F:MFM]LOT   <> ""  WLOT = [F:MFM]LOT : [M:MTMK]LOTPREF=[F:MFM]LOT
    Else  WLOT = "*"
    Endif
    If [M:MTMK]LOCPREF <> ""  WLOC = [M:MTMK]LOCPREF
    Elsif [F:MFM]LOC   <> ""  WLOC = [F:MFM]LOC : [M:MTMK]LOCPREF=[F:MFM]LOC
    Else  WLOC = "*"
    Endif

    If [M:MTMK]LOTPREF <> ""  :      # Le lot importé existe-t-il ?
      # Issue 78698 - 2011-12-21 by CCC
      #Read [F:STL]STL0(2) = [F:ITM]ITMREF;[M:MTMK]LOTPREF
      Filter [STL] Where ITMREF=[F:ITM]ITMREF
&                      & pat(LOT,[M:MTMK]LOTPREF)<>0
      Look [STL] First
      Filter [STL]
      If fstat : WMESSAGE = mess(123,199,1) - [M:MTMK]ITMREF - "/" - [M:MTMK]LOTPREF
               OK = 0
               Return
      Endif
    Endif
    If [M:MTMK]LOCPREF <> "" :      # L'emplacement importé existe-t-il ?
      # Issue 78698 - 2011-12-21 by CCC
      #Read [F:STC]STC0 = [M:MTMK]MFGFCY;[M:MTMK]LOCPREF
      Filter [STC] Where [STC]STOFCY=[M:MTMK]MFGFCY
&                      & pat(LOC,[M:MTMK]LOCPREF)<>0
      Look [STC] First
      Filter [STC]
      If fstat : WMESSAGE = mess(18,196,1) - [M:MTMK]ITMREF - "/" - [M:MTMK]LOCPREF
               OK = 0
               Return
      Endif
    Endif
    Call LECITV2([M:MTMK]MFGFCY,[F:ITM]ITMREF,WRET) From MFGLIB
    # FQ 43237 GA 10/2007 attention si emplacement et/ou lot précisé
    If WLOC = "*" & WLOT = "*"
       Call STODISTOT("",0,[F:SRU]AUZSTA,"",WDIS) From STKLIB
    Else
       #--- TS 106217
       #Call STODISPO("",[M:MTMK]MFGFCY,[M:MTMK]ITMREF,WLOT,WLOC,4,[F:SRU]AUZSTA,"","","",WDIS) From STKLIB
       Call STODISPO("",[M:MTMK]MFGFCY,[M:MTMK]ITMREF,WLOT,WLOC,4,[F:SRU]AUZSTA,"","","","",WDIS) From STKLIB
       #---
    Endif
    #FQ 51487 GA 01/2009 en import de suivi d'une matière d'OF TYPTRT=4: tenir compte des allocs
    If find([M:MTMK]TYPTRT,1,2,3,4) & find([F:MFM]ALLSTA,4,5)
        Call CTLALL([F:MFM]MFGFCY,10,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,6,[M:MTMK]TRSCODS,
&            "",1,WALLQTY,WALLQTYSHT,WRET) From STKALL
        WDIS += WALLQTY
    #FQ 51487 GA 01/2009 en import de suivi d'une matière d'OF TYPTRT=4: tenir compte des allocs
    Elsif find([M:MTMK]TYPTRT,1,2,3,4) & find([F:MFM]ALLSTA,2,3)
        WDIS += [F:MFM]ALLQTY
    Endif
    If WDIS < [M:MTMK]USEQTY
        OK = 0
        WMESSAGE = mess(86,193,1) - [M:MTMK]ITMREF - "/"  - [M:MTMK]LOTPREF - "/" - [M:MTMK]LOCPREF
        Return
    Endif
Endif

Return

######################################################
$CRE_SUIVI
Local Integer STAT, WOK
Call ECR_TRACE ("CRE_SUIVI_1",0) From GESECRAN
If G_LIN = 0
   G_DATE = [M:MTMK]IPTDAT
   G_FCY = [M:MTMK]MFGFCY
 # Issue 103194 GA 10/2014 idem MKIIMPORT, raz FQ 42737
 # If [M:MTMK]TYPTRT = 4        : G_WMFGNUM = [M:MTMK]MFGNUM : Endif
   If find([M:MTMK]TYPTRT,4,12) : G_MFGNUM  = [M:MTMK]MFGNUM
                                  G_WMFGNUM = [M:MTMK]MFGNUM : Endif
Call ECR_TRACE ("CRE_SUIVI_1_1",0) From GESECRAN
   Gosub DECL_SVG
   GOK = 1
   Call DEBTRANS From GLOCK
   Trbegin [MKM]
   Call NUMERO(GCODNUM,[M:MTMK]MFGFCY,G_DATE,"",G_MFGTRKNUM,STAT) From SUBANM
   If STAT
     WMESSAGE = mess(60,199,1)-GCODNUM-num$([L]STAT)
     GOK = 0
     Gosub TR_ROLL
     Return
   Endif
Else

Call ECR_TRACE ("CRE_SUIVI_2",0) From GESECRAN

   If [M:MTMK]IPTDAT <> G_DATE | [M:MTMK]MFGFCY <> GFCY
      If G_WMFGNUM <> ""
         Gosub MAJ_ENTOF
         Raz   G_WMFGNUM
      Endif
      Call ECR_TRACE ("CRE_SUIVI_2_1",0) From GESECRAN
      Gosub CRE_ENTETE
      Call ECR_TRACE ("CRE_SUIVI_2_2",0) From GESECRAN
      If GOK < 1 : Return : Endif
      GOK = 1
      Call DEBTRANS From GLOCK
      Trbegin [MKM]
      G_DATE = [M:MTMK]IPTDAT
      G_FCY = [M:MTMK]MFGFCY
    # Issue 103194 GA 10/2014 idem MKIIMPORT, raz FQ 42737
    # FQ 42737 dans les 2 cas on passe dans MAJ_ENTOF, utiliser la meme variable
    # If find([M:MTMK]TYPTRT,4,12) : G_MFGNUM  = [M:MTMK]MFGNUM : Endif
    # If [M:MTMK]TYPTRT = 4        : G_WMFGNUM = [M:MTMK]MFGNUM : Endif
      If find([M:MTMK]TYPTRT,4,12) : G_MFGNUM  = [M:MTMK]MFGNUM
                                     G_WMFGNUM = [M:MTMK]MFGNUM : Endif
      Call NUMERO(GCODNUM,[M:MTMK]MFGFCY,G_DATE,"",G_MFGTRKNUM,STAT) From SUBANM
      If STAT
         WMESSAGE = mess(60,199,1)-GCODNUM-num$([L]STAT)
         GOK = 0
         Gosub TR_ROLL
         Return
      Endif
   Else
    # Issue 103194 GA 10/2014 idem MKIIMPORT, lines uncommented
      If [M:MTMK]MFGNUM <> G_WMFGNUM       # FQ 42737
         Raz G_MFGNUM
      Endif
      If [M:MTMK]MFGNUM <> G_WMFGNUM & G_WMFGNUM <> ""
         Gosub MAJ_ENTOF
         Raz G_WMFGNUM
         If find([M:MTMK]TYPTRT,4,12) : G_WMFGNUM = [M:MTMK]MFGNUM : Endif
      Endif
   Endif
Endif
[M:MTMK]MATTRKLIN    = G_LIN + 1
[M:MTMK]MFGTRKNUM    = G_MFGTRKNUM
[M:MTMK]FICFLG       = 0
[M:MTMK]WLINUM    = 1
# sr 07.02
[M:MTMK]WMATCLENBR    = G_WMATCLENBR

Call ECR_TRACE ("CRE_SUIVI_3",0) From GESECRAN

#Appel du moteur de création du suivi des matières
#On a en ligne soit la ligne matière soit la ligne nomenclature
# sr 04.02  demande 13797 Si on nous a importé emplacement et statut , il faut les garder !!!
Case [M:MTMK]TYPTRT
    When 4,12 :  If [M:MTMK]TYPTRT    = 4
                    If [M:MTMK]LOCPREF = "" : [M:MTMK]LOCPREF   = [F:MFM]LOC : Endif
                 Endif
                 If [M:MTMK]STAPREF   = "" : [M:MTMK]STAPREF   = [F:MFM]STA  : Endif

# <GON>
                 Call ECR_TRACE ("CRE_SUIVI_4",0) From GESECRAN

                 Call CRE_MKM("",0) From MTKAUTLIB
                 If GOK < 1 : Gosub TR_ROLL : Return
                 Else Gosub TRACE_SVG
                 Endif
                 G_LIN                = [M:MTMK]MATTRKLIN
                 G_WMATCLENBR         = [M:MTMK]WMATCLENBR
                   G_WNBMAT             = [M:MTMK]WNBMAT                # 08.06 demande 37221
    When 8,13 :
#                 If [M:MTMK]STAPREF   = "" : [M:MTMK]STAPREF = "A"           : Endif
# <GON>
                 Call ECR_TRACE ("CRE_SUIVI_5",0) From GESECRAN

                 Call CRE_MKM([M:MTMK]BOMNUM,0) From MTKAUTLIB
                 If GOK < 1 : Gosub TR_ROLL : Return
                 Else Gosub TRACE_SVG
                 Endif
                 G_LIN                = [M:MTMK]MATTRKLIN
                 G_WMATCLENBR         = [M:MTMK]WMATCLENBR
                   G_WNBMAT             = [M:MTMK]WNBMAT                # 08.06 demande 37221
    When Default :
Endcase
#
Return

$TR_ROLL
#Rollback
#Raz G_MFGNUM, G_WMFGNUM, G_MFGTRKNUM, G_WNBMAT, G_LIN
Return

#######################################
$MAJ_ENTOF
#Maj entête d'OF
Readlock [F:MFG]MFG0 = G_WMFGNUM
If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-num$(G_WMFGNUM) : Return
Elsif fstat GOK=0  : Call RSTA("MFG",num$(G_WMFGNUM)) From GLOCK
      Return
Endif
# FQ 42737 GA 09/2007 comptage seult si "Conso Matière d'OF"
If [M:MTMK]TYPTRT   = 4 : [F:MFG]MATCLENBR += G_WMATCLENBR : Endif
If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&  [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&  [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
   [F:MFG]MFGTRKFLG = 5
   # CCC (10/01/08) DM 44021
#   [F:MFG]TRKLAST   = G_DATE
Else
   [F:MFG]MFGTRKFLG = 4
   # CCC (10/01/08) DM 44021
#   Raz [F:MFG]TRKLAST
Endif

# CCC (10/01/08) DM 44021
If [F:MFG]TRKLAST<G_DATE
   [F:MFG]TRKLAST   = G_DATE
Endif
If [F:MFG]TRKLASTC<date$
   [F:MFG]TRKLASTC  = date$
Endif
If [F:MFG]TRKFIRST>G_DATE | [F:MFG]TRKFIRST = "00/00/00"
    [F:MFG]TRKFIRST = G_DATE
Endif
If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
    [F:MFG]TRKFIRSTC = date$
Endif
[F:MFG]UPDDAT    = date$  : # FQ 42680
[F:MFG]UPDUSR    = GUSER  : # FQ 42680
Rewrite [F:MFG]
If fstat
   GOK = 0 : Call FSTA("MFG") From GLOCK : Return
Endif
#----- MISE à jour statistiques entête d'OF -----#
Call VALSTA("MFG",1) From SUBPS2
If GOK < 1 : Return : Endif
Raz G_WMATCLENBR
Return

#######################################
$CRE_ENTETE
If GOK = 1
    Raz [F:MTK]
    # Issue 103194 GA 10/2014 Raz FQ42737
    If G_MFGNUM <> ""
       Read [F:MFG] = G_MFGNUM
       If !fstat : [F:MTK] = [F:MFG] : Endif
    Endif
    [F:MTK]MFGFCY    = G_FCY      # Issue 90461 GA 07/201 avant GFCY
    [F:MTK]TRSCODS   = [M:MTMK]TRSCODS
    [F:MTK]MFGTRKNUM = G_MFGTRKNUM
    [F:MTK]MFGTRKDAT = G_DATE
    [F:MTK]OPETRKFLG = 1
    [F:MTK]ITMTRKFLG = 1
    [F:MTK]MATTRKFLG = 2
    [F:MTK]NBRMAT    = G_WNBMAT
    [F:MTK]CREDAT    = date$
    [F:MTK]CREUSR    = GUSER
    [F:MTK]EXPNUM    = [C]EXPORT
    Raz [F:MTK]UPDUSR
    Raz [F:MTK]UPDDAT
    Write [F:MTK]
    If fstat : GOK = 0 : Call FSTA("MTK") From GLOCK : Endif
Endif
If GOK < 1 : Rollback
    # Enregistrement dans SAS si nécessaire
    If WMKMFLG & [L]AOWSTA=2
        DEBENR_TMP = DEBENR
        WDEBENR_TMP = WDEBENR
        DEBENR = DEBENR_SVG
        WADXSEK = adxseek("IMP")
        OLDIRS = adxirs
        OLDIFS = adxifs
        OLDIUM = adxium
        adxirs = IMPIRS
        adxifs = IMPIFS
        adxium = IMPIUM
        GOK=1
        GNUMAOW=NBENR_SVG+1
        For I=1 To NBENR-NBENR_SVG-2
            Gosub IMPORT_SAS From =NOMTRT
            GNUMAOW+=1

            Seek First + DEBENR Using [IMP]
            Call RD_SEQ(VALIMP,BLBIMP,CLBIMP,IMPFIC,SEPNUMS,IMPFINS,WDEBENR) From SUBIMPOBJ
            DEBENR=adxseek("IMP")
        Next
        IMPSTA=0
        NUMFLD=0
        LIG=0
        Raz [F:AOV], [F:AOW]
        DEBENR = DEBENR_TMP
        WDEBENR = WDEBENR_TMP
        Seek First + WADXSEK Using [IMP]
        GOK=0
        adxirs = OLDIRS
        adxifs = OLDIFS
        adxium = OLDIUM
    Endif
Else       : Commit
             Gosub CLEAR_SVG
             DEBENR_SVG=DEBENR
             WMSGSUI = mess(79,190,1)-[F:MTK]MFGTRKNUM
             TRA = 1
             Call ECR_TRACE(WMSGSUI,0) From GESECRAN
             Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

NBENR_SVG = G_WNBMAT

Raz G_MFGNUM, G_WMFGNUM, G_MFGTRKNUM, G_WNBMAT, G_LIN
# Issue 97137 - 2014-02-21 by CCC
Call RAZSTOSORW From STKSOR
Return


#####################################################
# Déclaration du fichier sauvegarde
$DECL_SVG
MKMSVG = filpath("tmp",tolower(GFCY)+"_"+tolower(ctrans(adxusr,"./*\@","_")),"mkmsvg")
adxifs = ";"
adxirs = chr$(10)
Gosub CLEAR_SVG
Return

#####################################################
# sauvegarde de l'enregistrement en cours de traitement
$TRACE_SVG
Local Char    OLDIRS(5), OLDIFS(5)
Local Integer OLDIUM, FINENR, NBCAR , NBCAR2
OLDIRS = adxirs
OLDIFS = adxifs
OLDIUM = adxium
adxirs = IMPIRS
adxifs = IMPIFS
adxium = IMPIUM
FINENR = adxseek("IMP")
NBCAR  = WDEBENR-DEBENR
Seek First + DEBENR Using [IMP]
Openo MKMSVG , -1 Using [SVG]
While NBCAR>0
 NBCAR2 = min(NBCAR,32000)
 Local Schar CAR(1)(1..NBCAR2)
 Getseq NBCAR2 , CAR Using [IMP]
 Putseq NBCAR2 , CAR Using [SVG]
 NBCAR -= NBCAR2
Wend
Openo Using [SVG]
Seek First + FINENR Using [IMP]
adxirs = OLDIRS
adxifs = OLDIFS
adxium = OLDIUM
Return

#####################################################
# Copie du fichier des sauvegardes dans le fichier erreur du superviseur
$COP_SVG
Local Char    OLDIRS(5), OLDIFS(5)
Local Integer OLDIUM, FINENR, NBCAR , NBCAR2
OLDIRS = adxirs
OLDIFS = adxifs
OLDIUM = adxium
adxirs = IMPIRS
adxifs = IMPIFS
adxium = IMPIUM
Openi MKMSVG Using [SVG]
Seek Last Using [SVG]
NBCAR  = adxseek("SVG")
Seek First Using [SVG]
Openo FICERR , -1 Using [ERR]
While NBCAR>0
 NBCAR2 = min(NBCAR,32000)
 Local Schar CAR(1)(1..NBCAR2)
 Getseq NBCAR2 , CAR Using [SVG]
 Putseq NBCAR2 , CAR Using [ERR]
 NBCAR -= NBCAR2
Wend
Openo Using [ERR]
Openi Using [SVG]
Gosub CLEAR_SVG
adxirs = OLDIRS
adxifs = OLDIFS
adxium = OLDIUM
Return

#####################################################
# réinitialisation du fichier des sauvegardes
$CLEAR_SVG
Openo MKMSVG , 0 Using [SVG]
Openo MKMSVG Using [SVG]
Return

