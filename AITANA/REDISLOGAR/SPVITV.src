########################################
Subprog AVANT_NBLIG
#affectation des variables globales pour parametrage objet
[V]GCODPARCTL="ITVD"        :# Code paramétrage à utiliser (sera paramétrable ultérieurement dans les transactions)
[V]GXCODOBJ   ="ITD"         :# Code objet à contrôler
End

########################################
Subprog APRES_NBLIG

# Réaffectation pour controle objet sur ligne
[V]GCODPARCTL="ITV"        :# Code paramétrage à utiliser (sera paramétrable ultérieurement dans les transactions)
[V]GXCODOBJ   =[V]GABREV    :# Code objet à contrôler

[M:ITV2]FLGTPS(nolign-1)=0

# Lancement du questionnaire
If [M:ITV2]CREFLG(nolign-1)=0 | GREP="D"
    Gosub LEC_LIENSD_SUP From SPVOBJITV:# Mise en phase de liens supplémentaires
    GMODQSN="C"
Elsif [M:ITV2]CREFLG(nolign-1)=nolign & [M:ITV2]UPDFLG(nolign-1)=1
    Gosub LEC_LIENSD_SUP From SPVOBJITV :# Mise en phase de liens supplémentaires
    GMODQSN="M"
Endif

Call DUREEINT() From SPVOBJITV2

# SOUCH # 27/10/2009 # Compatibilité WEBSERVICES
#------------------------------------------------
If dim(GWEBSERV)=1 & GWEBSERV=1
    #-- CLAVA 23/09/11 inters automatiques
    If dim([V]XGAUTINT) > 0 & [M:ITV2]TYPORI(nolign-1) = 2 Then
        Local File FORNEE [XFNE]
        Read [F:XFNE]FNE1 = [M:ITV2]NUMORI(nolign-1) ; [M:ITV2]CODOPE(nolign-1) ; val([M:ITV2]LIGORI(nolign-1))
        If !fstat Then
            Case [M:ITV2]OPETYP(nolign-1)
                When 1 : [M:ITV2]ASSPRD(nolign-1) = [F:XFNE]ASSPRD
                When 2 : [M:ITV2]ASSITV(nolign-1) = [F:XFNE]ASSINT
                When 3 : [M:ITV2]RSCCOD(nolign-1) = [F:XFNE]RESCOD
            Endcase
            [M:ITV2]STRDAT(nolign-1) = [F:XFNE]BEGDAT
            [M:ITV2]STRHOU(nolign-1) = [F:XFNE]BEGHOU
            [M:ITV2]ENDDAT(nolign-1) = [F:XFNE]ENDDAT
            [M:ITV2]ENDHOU(nolign-1) = [F:XFNE]ENDHOU
        Endif
        Close Local File [XFNE]
    Endif
    #--

    # LBORN 29/10/2012
    If [M:ITV2]OPETYP(nolign-1)=2 & [M:ITV2]ASSLIB(nolign-1)<>[M:ITV2]ASSITV(nolign-1) & [M:ITV2]ASSLIB(nolign-1)<>""
      [M:ITV2]ASSITV(nolign-1)=[M:ITV2]ASSLIB(nolign-1)
    Endif

    [M:ITV2]STRDAT(nolign-1)=[M:ITV1]ITVDAT

    # LBORN 12/11/2014
    If [M:ITV2]RECMOD(nolign-1)=3
      Local Integer UVYDAY(7)
      Local Char    UVYCOD
      Local Decimal HOUWKD(7), DUREE
      Local Date    DATDISPO, DATEFIN
      [L]DUREE=(int(val([M]ENDHOU(nolign-1))/100)*60+mod(val([M]ENDHOU(nolign-1)),100))-(int(val([M]STRHOU(nolign-1))/100)*60+mod(val([M]STRHOU(nolign-1)),100) )
      [M:ITV2]HMLEN(nolign-1)=" " + string$(3-len(num$(int([L]DUREE/60))),"0")
&                  + num$(int([L]DUREE/60))+string$(2-len(num$(mod([L]DUREE,60))),"0")
&                  + num$(mod([L]DUREE,60))
      [L]DATDISPO=[M]ENDDAT(nolign-1)
      Call RECUP_DISPO([M:ITV0]REQNUM,[M:ITV2]FCY(nolign-1),[M:ITV2]CODOPE(nolign-1),[M:ITV1]ITVTYP,[M:ITV2]ASSITV(nolign-1),[L]UVYDAY,[L]UVYCOD,[L]HOUWKD) From SPVOBJITV3
      Call DAY_FIN_DUREE([L]DATDISPO,[M:ITV2]NBDAY(nolign-1),[L]UVYDAY,[L]UVYCOD,[L]HOUWKD,[M:ITV2]HMLEN(nolign-1),[L]DATEFIN) From SPVOBJITV3
    Else
      Call AM_HMLEN([M:ITV2]HMLEN(nolign-1)) From XSAIITVD
    Endif

    Call CAL_QTY([M:ITV2]UOM(nolign-1),[M:ITV2]QTY(nolign-1),[M:ITV2]RECMOD(nolign-1),[M:ITV2]ITVLEN(nolign-1),[M:ITV2]STRHOU(nolign-1)
&               ,[M:ITV2]STRDAT(nolign-1),[M:ITV2]ENDHOU(nolign-1),[M:ITV2]ENDDAT(nolign-1),[M:ITV2]NBDAY(nolign-1),[M:ITV2]HMLEN(nolign-1)
&               ,[M:ITV2]ASSLIB(nolign-1)) From SPVOBJITV2
    ##################

    Call CHGT_LIG_PREST([M:ITV2]RECMOD(nolign-1),[M:ITV2]OPETYP(nolign-1),[M:ITV2]ASSITV(nolign-1)
&    ,[M:ITV2]STRDAT(nolign-1),[M:ITV2]STRHOU(nolign-1),[M:ITV2]ENDDAT(nolign-1)
&    ,[M:ITV2]ENDHOU(nolign-1),[M:ITV2]HMLEN(nolign-1),[M:ITV2]DES(nolign-1),[M:ITV2]BPSNUM(nolign-1))From SPVOBJITV2


Endif
#------------------------------------------------

End


