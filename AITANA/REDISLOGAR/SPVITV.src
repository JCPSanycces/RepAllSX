########################################
Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
#FM le 31.03.06
If VALEUR<>"" Then
  Local File STOLOC [XTC]
  Read [XTC]STC0=[M]FCY(nolign-1);VALEUR
  If fstat Then GERR=1 : mkstat=2 Endif
  Close Local File [XTC]
# LBORN 16/09/2015 - Mantis 29923
Elsif func SPVOBJITV3.MANDATORY_LOC([M:ITV1]ITVTYP,[M:ITV2]CODOPE(nolign-1),[M:ITV2]ASSPRD(nolign-1),[M:ITV2]FCY(nolign-1))
  GERR=3 : [V]GMESSAGE=mess(125,184,1)
Endif

End

################################################################################
## Etiquette ajoutée par le superviseur (écran ITV2) 31/10/2008 12:31:55 (LBORN)
################################################################################

########################################
Subprog AV_CURINV(VALEUR)
Variable Char    VALEUR()

If [M:ITV2]CURTYP(nolign-1)=0
  [M:ITV2]CURTYP(nolign-1)=[F:REQ]CURTYP
  If !GIMPORT
    Affzo [M:ITV2]CURTYP(nolign-1)
  Endif
Endif

If VALEUR=""
  VALEUR=[F:REQ]CURINV
Endif

If [M:ITV2]RATINV(nolign-1)=0
  If VALEUR=[V]GLOCALDEV
    [M:ITV2]RATINV(nolign-1)=1
  Else
    Call COURSITE(VALEUR,[F:REQ]FCY,[M:ITV2]CURTYP(nolign-1),[M:ITV1]ITVDAT,[M:ITV2]RATINV(nolign-1),GSTATUS) From TRTDEV
  Endif
  If !GIMPORT
    Affzo [M:ITV2]RATINV(nolign-1)
  Endif
Endif
End

########################################
Subprog AS_CURPUR(VALEUR)
Variable Char    VALEUR()

If VALEUR=""
  If [M:ITV2]BPSNUM(nolign-1)<>""
    If !clalev([F:BPR]) : Local File BPARTNER : Endif
    Read [F:BPR]BPR0=[M:ITV2]BPSNUM(nolign-1)
    If !fstat & [F:BPR]CUR<>""
      VALEUR=[F:BPR]CUR
    Elsif [M:ITV2]CURINV(nolign-1)<>""
      VALEUR=[M:ITV2]CURINV(nolign-1)
    Else
      VALEUR=[F:REQ]CURINV
    Endif
  Else
    VALEUR=[F:REQ]CURINV
  Endif
Endif

Gosub VALFLGMOD
End

########################################
Subprog AM_CURPUR(VALEUR)
Variable Char    VALEUR()
If [M:ITV2]CURTYPPUR(nolign-1)=0
  [M:ITV2]CURTYPPUR(nolign-1)=[F:REQ]CURTYP
  If !GIMPORT
    Affzo [M:ITV2]CURTYPPUR(nolign-1)
  Endif
Endif
If VALEUR=[V]GLOCALDEV
  [M:ITV2]RATPUR(nolign-1)=1
Else
  Call COURSITE(VALEUR,[F:REQ]FCY,[M:ITV2]CURTYPPUR(nolign-1),[M:ITV1]ITVDAT,[M:ITV2]RATPUR(nolign-1),GSTATUS) From TRTDEV
Endif
If !GIMPORT
  Affzo [M:ITV2]RATPUR(nolign-1)
Endif
End

########################################
Subprog AV_CURTYPPUR(VALEUR)
Variable Integer VALEUR
If VALEUR=0
  VALEUR=[F:REQ]CURTYP
Endif
If [M:ITV2]RATPUR(nolign-1)=0
  If [M:ITV2]CURPUR(nolign-1)=[V]GLOCALDEV
    [M:ITV2]RATPUR(nolign-1)=1
  Else
    Call COURSITE([M:ITV2]CURPUR(nolign-1),[F:REQ]FCY,[M:ITV2]CURTYPPUR(nolign-1),[M:ITV1]ITVDAT,[M:ITV2]RATPUR(nolign-1),GSTATUS) From TRTDEV
  Endif
Endif
End

