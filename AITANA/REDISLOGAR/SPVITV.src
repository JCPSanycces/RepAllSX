################################################################################
$D_CCEX

#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
Gosub DEC_VARAXE
If AXE>GNBDIE Then Return Endif
If GIMPORT & evalue("[F:ITD]CCE"+num$(AXE))<>"" Then Return Endif

#Call INISEC(VALEUR,"ITVLIG"+num$([M]OPETYP(nolign-1)),GDIE(AXE)) From SUBCDE
Call INIT_CCE(VALEUR,AXE,"XITVLIG"+num$([M]OPETYP(nolign-1)),"",0) From TRTX3CPT

# LBORN 07/10/2015
indice=[L]SVGNOL-1

Return

$DEC_VARAXE
# LBORN 30/07/2013 - Mantis 20393 (le numéro d'axe a été ajouté dans chaque Subprog, sinon pb Webservice avec zoncou)
# Local Integer AXE
# AXE=val(ctrans(zoncou,"CCE",""))

# LBORN 07/10/2015
Local Integer SVGNOL
[L]SVGNOL=nolign

Return

################################################################################
$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Gosub DEC_VARAXE
If GIMPORT & evalue("[F:ITD]CCE"+num$(AXE))<>"" Then Return Endif

Call SAIS_CCE(VALEUR,AXE,"","")From TRTX3CPT

# LBORN 07/10/2015
indice=[L]SVGNOL-1

Return

################################################################################
$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Gosub DEC_VARAXE
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:ITV1]ITVDAT)From TRTX3CPT

# LBORN 07/10/2015
indice=[L]SVGNOL-1

Return

