########################################
Subprog C_QTY(VALEUR)
Variable Decimal VALEUR

Local Integer RETOUR, NOL

[L]NOL=nolign-1

Call C_QTY_OTI(VALEUR,[M:ITV1]ITVTYP,[M:ITV2]CODOPE(nolign-1),[L]RETOUR)From SPVOBJITV3
If [L]RETOUR : mkstat=2 : End : Endif

# LBORN 06/02/2013 - Mantis 7485
# LBORN 16/12/2016 - Mantis 33785 (ajout test GIMPORT)
If !GIMPORT
  Call C_QTY_OTM([M:ITV2]FCY(NOL),[M:ITV2]UOM(NOL),VALEUR,[M:ITV1]ITVTYP,[M:ITV2]CODOPE(NOL),[M:ITV2]ASSPRD(NOL),2,[L]NOL+1,[V]GERR) From SPVOBJITV3
  If [V]GERR | mkstat : End : Endif
Endif

End

