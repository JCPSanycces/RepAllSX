######################################################################################
Subprog AV_ICOREQ(VALEUR)
Variable Char    VALEUR()
If [M:ITV0]REQNUM=""
  VALEUR=""
Else
  VALEUR="65"
Endif
End


######################################################################################
Subprog AM_RAFITV(VALEUR)
Variable Char    VALEUR()

Local Decimal ZNBJ

VALEUR=num$(val(VALEUR))
VALEUR=space$(6-len(VALEUR))+VALEUR

[L]ZNBJ=int(val(VALEUR)/100)+ar2(mod(val(VALEUR),100)/60)

Raz GBIDC1
Call PARAM("","XTIMDAY",GBIDC1) From ADOVAL
If val(GBIDC1)
  [M:ITV2]DAYRAFITV=ar2([L]ZNBJ/val(GBIDC1))
Else
  [M:ITV2]DAYRAFITV=ar2([L]ZNBJ/24)
Endif
If !GIMPORT
  Affzo [M:ITV2]DAYRAFITV
Endif

End


######################################################################################
Subprog AM_DAYRAFITV(VALEUR)
Variable Decimal VALEUR

Local Decimal ZNBH

Raz GBIDC1
Call PARAM("","XTIMDAY",GBIDC1) From ADOVAL
If val(GBIDC1)
  [L]ZNBH=VALEUR*val(GBIDC1)
Else
  [L]ZNBH=VALEUR*24
Endif

[M:ITV2]RAFITV=num$(int([L]ZNBH))+format$("N0:2#",([L]ZNBH-int([L]ZNBH))*60)
[M:ITV2]RAFITV=space$(6-len([M:ITV2]RAFITV))+[M:ITV2]RAFITV

If !GIMPORT
  Affzo [M:ITV2]RAFITV
Endif

End

######################################################################################
Subprog AM_FLGREGUL(VALEUR)
Variable Integer VALEUR
Read [F:REQ]REQ0=[M:ITV0]REQNUM
If [F:REQ]FLGREGUL=2
  If VALEUR=2
    [V]GMESSAGE=mess(54,[V]GXMSGPSA(1),1)
  Else
    [V]GMESSAGE=mess(55,[V]GXMSGPSA(1),1)
  Endif
  [V]GERR=3
Endif
End

######################################################################################
Subprog AV_MACNUM(VALEUR)
Variable Char    VALEUR()

Actzo [M:ITV2]MACNUM

If !func AFNC.ACTIV("HDK") | [M:ITV2]ASSPRD(nolign-1)="" | [M:ITV2]SERNUM(nolign-1)="" : End : Endif

If !clalev([F:MAC]) : Local File MACHINES : Endif

Raz VALEUR

Read [F:MAC]MAC5=[M:ITV2]ASSPRD(nolign-1);[M:ITV2]SERNUM(nolign-1)
If !fstat
  VALEUR=[F:MAC]MACNUM
Endif

End

#####################################################################################
Subprog AS_MACNUM(VALEUR)
Variable Char    VALEUR()

[V]GBIDC1="1"

If [M:ITV1]BPRITV<>""
  [V]GBIDC1-="& [F:MAC]MACCUTBPC='"+[M:ITV1]BPRITV+"'"
Endif
If [M:ITV2]ASSPRD(nolign-1)<>""
  [V]GBIDC1-="& [F:MAC]MACPDTCOD='"+[M:ITV2]ASSPRD(nolign-1)+"'"
Endif
If [M:ITV2]SERNUM(nolign-1)<>""
  [V]GBIDC1-="& [F:MAC]MACSERNUM='"+[M:ITV2]SERNUM(nolign-1)+"'"
Endif

Gosub VALFLGMOD

End

######################################################################################
Subprog AM_MACNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR="" : End : Endif

If !clalev([F:MAC]) : Local File MACHINES : Endif

Read [F:MAC]MAC0=VALEUR
If !fstat
  [M:ITV2]ASSPRD(nolign-1) =[F:MAC]MACPDTCOD
  [M:ITV2]SERNUM(nolign-1) =[F:MAC]MACSERNUM
Endif

Affzo [M:ITV2]ASSPRD(nolign-1),SERNUM(nolign-1)

End

######################################################################################
Subprog C_DES(VALEUR)
Variable Char    VALEUR()

If VALEUR<>"" : End : Endif

If [M:ITV2]LIGORI(nolign-1)<>""
  If !clalev([F:ILD]) : Local File ITVLOTD : Endif
  Read [F:ILD]ILD0=[M:ITV3]ORINUM;val([M:ITV2]LIGORI(nolign-1))
  If !fstat & [F:ILD]ITLSUM<>""
    End
  Endif
Endif

If !func SPVOBJITL.VALID_FRAIS([M]FCY(nolign-1), [M]CODOPE(nolign-1), [M:ITV1]ITVTYP, [M]ASSLIB(nolign-1), [M]ITVDAT, VALEUR)
  mkstat=1 : End
Endif

End

######################################################################################
Subprog AV_STRDAT(VALEUR)
Variable Date    VALEUR

# LBORN 03/12/20112
If VALEUR=[0/0/0] & [M:ITV2]OPETYP(nolign-1)=2 & [M:ITV2]RECMOD(nolign-1)=4 & [M:ITV1]ITVDAT<>[0/0/0]
  VALEUR=[M:ITV1]ITVDAT
Endif

# LBORN 12/11/2014
If !GWEBSERV : mkstat=2 : Endif

End

######################################################################################
Subprog AV_ENDDAT(VALEUR)
Variable Date    VALEUR

# LBORN 03/12/20112
If VALEUR=[0/0/0] & [M:ITV2]OPETYP(nolign-1)=2 & [M:ITV2]RECMOD(nolign-1)=4 & [M:ITV1]ITVDAT<>[0/0/0]
  VALEUR=[M:ITV1]ITVDAT
Endif

# LBORN 12/11/2014
If !GWEBSERV : mkstat=2 : Endif

End

######################################################################################
Subprog AV_FCY(VALEUR)
Variable Char    VALEUR()

Call D_FCYENT(VALEUR) From SPVOBJITV

End

######################################################################################
# LBORN 17/09/2015 - Mantis 29922
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()

If !clalev([F:ITM]) : Local File ITMMASTER : Endif
If !clalev([F:STS]) : Local File STOSER    : Endif

Read [F:ITM]ITM0=[M:ITV2]ASSPRD(nolign-1)
If !fstat & [F:ITM]SERMGTCOD>1
  # LBORN 20/06/2016 - Mantis 32592
  # If func SPVOBJITV3.SS1_ONLY([M:ITV1]ITVTYP,[M:ITV2]CODOPE(nolign-1))
  If func SPVOBJITV3.STK_ONLY([M:ITV1]ITVTYP,[M:ITV2]CODOPE(nolign-1),"SS1")
    Read [F:STS]STS0=[M:ITV2]ASSPRD(nolign-1);VALEUR
    If fstat
      [V]GMESSAGE=mess(43,196,1)
      [V]GERR=3
    Elsif [F:STS]ISSDAT<>[0/0/0]
      [V]GMESSAGE=VALEUR-":"-mess(15,[V]GXMSGACT,1)-[M:ITV2]ASSPRD(nolign-1)
      [V]GERR=3
    Endif

  # LBORN 20/06/2016 - Mantis 32592
  Elsif func SPVOBJITV3.STK_ONLY([M:ITV1]ITVTYP,[M:ITV2]CODOPE(nolign-1),"ES1") & [F:ITM]SERMGTCOD=3
    Read [F:STS]STS0=[M:ITV2]ASSPRD(nolign-1);VALEUR
    If !fstat & [F:STS]ISSDAT=[0/0/0]
      [V]GMESSAGE=mess(93,184,1)
      [V]GERR=3
    Endif
  Endif

Endif

End

