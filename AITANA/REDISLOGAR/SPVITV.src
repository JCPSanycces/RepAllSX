################################################################################
## Etiquette ajoutée par le superviseur (écran ITV2) 16/03/2006 (FMUYS)
################################################################################

########################################
Subprog AV_DES(VALEUR)
Variable Char    VALEUR()

Case [M:ITV2]OPETYP(nolign-1)
    When 1 :

#FM le 16.03.06 / Déporté en Init
###        If [M:ITV2]FLGTPS(nolign-1)=3 :# Si modification
###            Call CHGT_LIG_PRO([M:ITV2]ASSLIB(nolign-1),VALEUR)From SPVOBJITV2
###            [M:ITV2]ITMDES=VALEUR
###        Endif

        [M:ITV2]ASSPRD(nolign-1)=[M:ITV2]ASSLIB(nolign-1)
        [M:ITV2]ASSITV(nolign-1)=""
        [M:ITV2]RSCCOD(nolign-1)=""
    When 2 :
        [M:ITV2]ASSITV(nolign-1)=[M:ITV2]ASSLIB(nolign-1)
        [M:ITV2]RSCCOD(nolign-1)=""
    When Default :
        [M:ITV2]ASSITV(nolign-1)=""
        [M:ITV2]RSCCOD(nolign-1)=[M:ITV2]ASSLIB(nolign-1)
Endcase
If find([M:ITV2]FLGTPS(nolign-1),2,3) : # signifie qu'une modif a été faite
    Call CHGT_LIG_PREST([M:ITV2]RECMOD(nolign-1),[M:ITV2]OPETYP(nolign-1),[M:ITV2]ASSITV(nolign-1)
&    ,[M:ITV2]STRDAT(nolign-1),[M:ITV2]STRHOU(nolign-1),[M:ITV2]ENDDAT(nolign-1)
&    ,[M:ITV2]ENDHOU(nolign-1),[M:ITV2]HMLEN(nolign-1),VALEUR,[M:ITV2]BPSNUM(nolign-1))From SPVOBJITV2
    If !GIMPORT
        Affzo [M]NBDAY(nolign-1),ITVLEN(nolign-1),BPSNUM(nolign-1)
    Endif
Endif
End

########################################
Subprog AM_ASSLIB(VALEUR)
Variable Char    VALEUR()
#FM le 16.03.06
If !clalev([OTI]) Then Local File OPETIT  Endif
If !clalev([AUS]) Then Local File AUTILIS Endif
#--
Case [M:ITV2]OPETYP(nolign-1)
When 1 : Effzo [M:ITV2]DES(nolign-1)
         Effzo [M:ITV2]BPSNUM(nolign-1)

         # LBORN 25/10/2016 - Mantis 29720
         Read [F:OTI]OTI0=[M]CODOPE(nolign-1);[M:ITV1]ITVTYP
         If !fstat
           If !clalev([ITM]) Then Local File ITMMASTER : Endif
           Read [F:ITM]ITM0=VALEUR
           If !fstat
             Case [F:OTI]ORGUOM
               When 2 : # Ventes
                 [M]UOM(nolign-1)=[F:ITM]SAU
               When 3 : # Achats
                 [M]UOM(nolign-1)=[F:ITM]PUU
               When 4 : # Stock
                 [M]UOM(nolign-1)=[F:ITM]STU
             Endcase
             If !GIMPORT & [M]UOM(nolign-1)<>"" : Affzo [M]UOM(nolign-1) : Endif
           Endif
         Endif

When 2 : #FM le 09.03.10
         #Vérifier si site est paramétré /intervenant
         #Si oui, réini du site
         #M2897

         # ATTENTION si modif, VERIFIER trt SPVOBJITV2 (Chgt_lig) + SPVITL (AM_ASSLIB)

         Call LECTURE("OTI",[M:ITV1]ITVTYP,[M]CODOPE(nolign-1))From CONTOBJ
         # Init du Site
         Case [F:OTI]ORIFCYOTI
         When 6 : # Site intervenant
                  Call LECTURE("AUS",VALEUR,"")From CONTOBJ
                  [M]FCY(nolign-1)=[F:AUS]FCYT
                  ###
                  #verif si site pas depot , on va chercher le site depot
                  Call LECTURE("FCY",[M]FCY(nolign-1),"")From CONTOBJ
                  If [F:FCY]WRHFLG<>2 & !fstat
                      If [F:OTI]ROLEFCY=0
                          [F:OTI]ROLEFCY=1
                      Endif
                      If find([F:OTI]ROLEFCY,[F:FCY]ROLEFCY)
                          [M]FCY(nolign-1)=[F:FCY]STOFCY(find([F:OTI]ROLEFCY,[F:FCY]ROLEFCY)-1)
                      Endif
                  Endif
                  If !GIMPORT Then Affzo [M]FCY(nolign-1) Endif
          Endcase
Endcase
End

########################################
Subprog D_DES(VALEUR)
Variable Char    VALEUR()
#FM le 16.03.06
Case [M:ITV2]OPETYP(nolign-1)
When 1 : Call CHGT_LIG_PRO([M:ITV2]ASSLIB(nolign-1),VALEUR)From SPVOBJITV2
         [M:ITV2]ITMDES(nolign-1)=VALEUR
Endcase
End


