########################################
Subprog AS_BPSNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR<>"" : End : Endif

If !clalev([F:FNE]) : Local File FORNEE  : Endif
If !clalev([F:POQ]) : Local File PORDERQ : Endif

For [F:FNE]FNE1  Where [F:FNE]REQNUM=[M:ITV0]REQNUM
&                     & [F:FNE]CODOPE=[M:ITV2]CODOPE(nolign-1)
&                     & [F:FNE]ITMSCO=[M:ITV2]ASSPRD(nolign-1)

  Filter [F:POQ] Where [F:POQ]REQNUM=[F:FNE]REQNUM
&                    & [F:POQ]ITMREF=[F:FNE]ITMSCO

  Read [F:POQ] First
  If !fstat
    VALEUR=[F:POQ]BPSNUM
  Endif

  Filter [F:POQ]

  If VALEUR<>"" : Break : Endif

Next

Gosub VALFLGMOD

End

