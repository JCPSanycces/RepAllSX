$INIT_PARAM

#initialisation des paramètres pour recherche des prix
Local Decimal PRIX
Local Char PARAMC(30)(10),DEVISE
Local Date PARAMD(10)
Local Integer CURTYP

If [L]NBREM <> 0 Then
    Local Decimal REMISE([L]NBREM)
Else
    Local Decimal REMISE
Endif

[L]PARAMC(0)=[M:ITV0]REQNUM
[L]PARAMC(1)=[M:ITV2]ASSLIB(nolign-1)
[L]PARAMC(2)=[M:ITV2]ASSPRD(nolign-1)
[L]PARAMC(3)=[M:ITV2]UOM(nolign-1)
[L]PARAMC(4)=[M:ITV2]CODOPE(nolign-1)
[L]PARAMC(5)=[M:ITV1]ITVTYP
[L]PARAMC(6)=[M:ITV2]BPSNUM(nolign-1)
#FM le 14.03.06
[L]PARAMC(7)=num$([M:ITV2]QTY(nolign-1))
[L]PARAMC(8)=num$([M:ITV2]FCY(nolign-1))
#\FM

# LBORN 04/02/2015 - Mantis 27890
[L]PARAMC(9)=[M:ITV1]BPAITV

[L]PARAMD(0)=[M:ITV1]ITVDAT
[L]PARAMD(1)=[M:ITV2]STRDAT(nolign-1)

Raz [L]PRIX,[L]REMISE
Return


