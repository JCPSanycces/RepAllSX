########################################
Subprog B10_NBLIG
#FM le 09.02.06 / Visu mvt stock
Local Shortint XOK : XOK=0
Local Integer  XGT : XGT=0

If GTEST=0 Then XGT=1 : GTEST=1 Endif
Call VRFSTOITD([M:ITV0]ITVNUM,XOK,GMESSAGE) From XVRFSTOITD2
If XGT Then GTEST=0 Endif

End

########################################
$MAJ_GBOUT10

#FM le 09.02.06
Raz GBOUT10
If [M:ITV0]ITVNUM<>"" & [M:ITV1]FLGITVVAL<2 Then
  Local Integer XOK
  For II=0 To [M:ITV2]NBLIG
    Call CTLMVT([M:ITV2]CODOPE(II),[M:ITV1]ITVTYP,XOK)
    If XOK Then GBOUT10=mess(10,1823,1) : Break Endif
  Next
Endif
Return

########################################
Subprog CTLMVT(P1,P2,P3)
Value    Char    P1() #Code opé
Value    Char    P2() #Type inter
Variable Integer P3   #Retour

#FM le 09.02.06
Local File OPETIT    [OTI9]
Local File OPETITMVT [OTM9]
Local File PARVGA1   [PV19]
P3=0
Read [OTI9]OTI0=P1;P2
If !fstat Then
  For [OTM9]OTM1 Where [OTM9]OPECOD=[F:OTI9]OPECOD
&                        & [OTM9]INTTYP=[F:OTI9]INTTYP
&                        & [OTM9]EVENT =1
&                        & [OTM9]ENAFLG=2
    Read [PV19]PV10=[F:OTM9]CODVAL
    If !fstat Then
      Case [F:PV19]TYPDOC
      When "ES1" : P3=1 : Break
      When "SS1" : P3=2 : Break
      When "TS1" : P3=3 : Break
      Endcase
    Endif
  Next
Endif
Close Local File [OTI9],[OTM9],[PV19]
End

