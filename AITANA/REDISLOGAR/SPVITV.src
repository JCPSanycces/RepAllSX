#<AdxTL>@(#)4.0.0.0 $Revision$
#ACV#X12
#TIT#Gestion action sur champ Objet ITV

GBIDC1=""
GBIDC2=""
Call OBJET("ITV",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

################################################################################
################################################################################
################################################################################
################################################################################

#===============================================================================
# Gestion de l'objet   : ITV
#
# Auteur               :
# Date de création     :
#===============================================================================
# Modifications significatives
#-------------------------------------------------------------------------------
# Date        Auteur   Description
#===============================================================================
# 12/10/2004  OTHYR    Gestion de l'impression de liste
#-------------------------------------------------------------------------------
# 17/09/2003  CPERR    Ajout d'un bouton (B3) sur ASSLIB si celui-ci est un produit
#                      pour la recherche des articles gérés en parc client.
#-------------------------------------------------------------------------------
# 12/09/2003  OTHYR    Ajout des actions objet ABANDON et RAZCRE pour gestion des textes
#-------------------------------------------------------------------------------
# 30/05/2003  OTHYR    Sélection dans table sur champ numéro de série
#===============================================================================

$ACTION

# Appel fonctions complémentaires GFI pour l'objet ITV
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Gosub ACTION From SPVOBJITV

Return


################################################################################
################################################################################
################################################################################
################################################################################

########################################
Subprog AS_ITVNUM(VALEUR)
Variable Char    VALEUR()
If find(GREP,"C","D") & !GIMPORT
  mkstat=2
Endif
End

########################################
Subprog C_ITVNUM(VALEUR)
Variable Char    VALEUR()

#----- Vérif si un enregistrement existe -----#
If VALEUR<>"" & !GIMPORT
   Look [ITR]ITR0=VALEUR
   If fstat GMESSAGE=mess(178,199,1) : mkstat=1 : End : Endif
Endif
End

########################################
#*FMSubprog AV_REQNUM(VALEUR)
#*FMVariable Char     VALEUR
#*FMIf !GIMPORT & GXTUNNEL Then
#*FM  Diszo [M:ITV0]REQNUM
#*FMElse
#*FM  Actzo [M:ITV0]REQNUM
#*FMEndif
#*FMEnd

########################################
Subprog AS_REQNUM(VALEUR)
Variable Char    VALEUR()

Raz mkstat
If VALEUR="" Then End Endif
If (!find([V]GREP,"C","D") | [V]GXTUNNEL) & !GIMPORT & !GWEBSERV Then mkstat=2 Endif
End

########################################
Subprog AM_REQNUM(VALEUR)
Variable Char    VALEUR()
# FMUYS le 13/11/03
Gosub AM_REQNUMBER

# LBORN 02/08/2013 - Mantis 20293
If GWEBSERV & VALEUR<>""
  Read [REQ]REQ0=VALEUR
  If !fstat
    GFCY=[F:REQ]FCY
    Gosub CHARG_PARAM From SPVOBJREQ : Raz GERR : Raz GMESSAGE
  Endif
Endif

End

########################################
Subprog C_REQNUM(VALEUR)
Variable Char    VALEUR()
If GREP="C" & !func SPVOBJITV.AUTOR_CREITV(VALEUR)
  mkstat=1
  GERR=1
Endif
End

#=======================================
$AM_REQNUMBER
# Initialisation des infos DS
If VALEUR<>"" Then
  Call INITMSK_DS(VALEUR)From SPVOBJITV
  Effzo [M:ITV1]BPRITV, BPAITV, CNTNAM, TELCNT, FAXCNT, WEBCNT
Endif
Return

########################################
Subprog AV_TELCNT(VALEUR)
Variable Char    VALEUR()
If ![V]GIMPORT
  If [M:ITV1]CNTNAM=""
    Call COORD_BPA(1,[M:ITV1]BPRITV,[M:ITV1]BPAITV,VALEUR,[M:ITV1]FAXCNT,[M:ITV1]WEBCNT) From SPVOBJREQ
  Else
    Call COORD_CNT(1,[M:ITV1]BPRITV,[M:ITV1]CNTNAM,VALEUR,[M:ITV1]FAXCNT,[M:ITV1]WEBCNT,GBIDC1) From SPVOBJREQ
  Endif
Endif
End

########################################
Subprog AM_ITVTYP(VALEUR)
Variable Char    VALEUR()
[M:ITV1]ACS=[F:X7Y]ACS
End

########################################
Subprog AS_ITVTYP(VALEUR)
Variable Char    VALEUR()
If !find(GREP, "C", "D") & !GIMPORT
  mkstat=2
Endif
End

########################################
Subprog D_ITVDAT(VALEUR)
Variable Date    VALEUR

If VALEUR=[0/0/0] Then
   VALEUR=date$
Endif
End

########################################
Subprog D_ITVTIM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   VALEUR=left$(time$,2)+mid$(time$,4,2)
Endif
End


########################################
Subprog AS_BPRITV(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
  mkstat=2 : # permet de conserver le lien
Endif

End

##################################
Subprog C_ITVTYP(VALEUR)
Variable Char     VALEUR

Call CONITV(VALEUR,[M:ITV0]REQNUM) From SPVOBJX7Y
If [F:X7Y]ACS<>"" & !mkstat
    Call CTLACS([F:X7Y]ACS,"E")From CONTX3
Endif
End

########################################
Subprog C_UOM(VALEUR)
Variable Char    VALEUR()
Local Integer OK

Call CTRL_UOM_ITM([M]ASSPRD(nolign-1),VALEUR,[L]OK) From SPVOBJOTI
If ![L]OK : mkstat=2 : GERR=2 : Endif
End

########################################
Subprog D_CHRLIG(VALEUR)
Variable Char    VALEUR()
If vireblc(VALEUR,4)="" & [M:ITV2]CODOPE(nolign-1)<>""
    VALEUR=num$(uniqid([ITD]))
Endif
End

########################################
Subprog AV_CODOPE(VALEUR)
Variable Char    VALEUR()

#initialise codopes en fonction du rang paramatré ou du declencheur
If VALEUR=""
    Call INI_CODOPE(VALEUR,[M]ITVTYP,[M]REQNUM) From SPVOBJITV2
Endif

Call FMTOPE(VALEUR,[M]FMTASS(nolign-1)) From SPVOBJITV2
End


########################################
Subprog IB_ASSLIB
Raz GBOUT3
Case [M:ITV2]OPETYP(nolign-1)
When 1 : GBOUT3=mess(323,[V]GXMSGPSA,1) # Recherche parc matériel
When 2 :
When 3 :
Endcase
End

########################################
Subprog AS_ASSLIB(VALEUR)
Variable Char    VALEUR()

Local Integer XFLGMOD
Case [M:ITV2]OPETYP(nolign-1)
When 1 : Call VAL_FLGMOD([M:ITV2]CODOPE(nolign-1),[M:ITV1]ITVTYP,"ASSPRD",[L]XFLGMOD)From SPVOBJOTI
         If [L]XFLGMOD<>2 Then mkstat=2 Endif
When 2 : Call VAL_FLGMOD([M:ITV2]CODOPE(nolign-1),[M:ITV1]ITVTYP,"ASSITV",[L]XFLGMOD)From SPVOBJOTI
         If [L]XFLGMOD<>2 Then mkstat=2 Endif
When 3 : Call VAL_FLGMOD([M:ITV2]CODOPE(nolign-1),[M:ITV1]ITVTYP,"RSCCOD",[L]XFLGMOD)From SPVOBJOTI
         If [L]XFLGMOD<>2 Then mkstat=2 Endif
Endcase
End

########################################
Subprog AP_ASSLIB(VALEUR)
Variable Char     VALEUR
#Permet le declenchement de la saise des temps
[M:ITV2]FLGTPS(nolign-1)=1
If [M:ITV2]OPETYP(nolign-1)=1 Then [M:ITV2]FLGTPS(nolign-1)=3 Endif
End

########################################
Subprog AS_DES(VALEUR)
Variable Char    VALEUR()

# LBORN 15/06/2011 - Sinon, la zone n'est pas importée en validation de CRA
If GIMPORT : End : Endif

If [M:ITV2]RECMOD(nolign-1)<>4
   mkstat=2
Else
   Gosub VALFLGMOD
Endif
End

########################################
Subprog AS_UOM(VALEUR)
Variable Char    VALEUR()

Gosub VALFLGMOD
End

########################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()

Gosub VALFLGMOD
End

########################################
Subprog AS_MOTINV(VALEUR)
Variable Integer VALEUR

Gosub VALFLGMOD
End

########################################
Subprog AS_QTY(VALEUR)
Variable Decimal VALEUR

# SOUCH # 20/10/2009 # Compatibilité WEBSERVICES
#------------------------------------------------
If dim(GWEBSERV)=1 & GWEBSERV=1
  Call AV_QTY(VALEUR)
Endif
#-------------------------------------------------

Gosub VALFLGMOD
End

########################################
Subprog AV_QTY(VALEUR)
Variable Decimal VALEUR

If [M:ITV2]FLGTPS(nolign-1)=2
    Call CAL_QTY([M:ITV2]UOM(nolign-1),VALEUR,[M:ITV2]RECMOD(nolign-1),[M:ITV2]ITVLEN(nolign-1),[M:ITV2]STRHOU(nolign-1)
&               ,[M:ITV2]STRDAT(nolign-1),[M:ITV2]ENDHOU(nolign-1),[M:ITV2]ENDDAT(nolign-1),[M:ITV2]NBDAY(nolign-1),[M:ITV2]HMLEN(nolign-1)
&               ,[M:ITV2]ASSLIB(nolign-1)) From SPVOBJITV2
    If ![V]GIMPORT
        Affzo [M:ITV2]ITVLEN(nolign-1)
    Endif
Endif
End


########################################
Subprog D_USRITV(VALEUR)
Variable Char    VALEUR()

If VALEUR=""
    Call LECTURE("REQ",[M:ITV0]REQNUM,"")From CONTOBJ
    If [F:REQ]RESINT<>""
        VALEUR=[F:REQ]RESINT
    Endif
Endif

End

########################################
Subprog C_NBLIG

# LBORN 15/10/2012
If [M]CLOPER(nolign-1)=2
  If status=65
    [V]GMESSAGE=mess(101,[V]GXMSGACT,1)+"\"+mess(54,123,1)
    mkstat=1
  Elsif status=75
    [V]GMESSAGE=mess(101,[V]GXMSGACT,1)+"\"+mess(9,123,1)
    mkstat=1
  Elsif status = 68 | status= 83
    For NOL=nolign-1 To nolign1-1
      If [M]CLOPER(NOL)=2
        [V]GMESSAGE=mess(101,[V]GXMSGACT,1)+"\"+mess(54,123,1)
        mkstat=1
        Break
      Endif
    Next
  Endif
Endif

End

########################################
Subprog AM_CODOPE(VALEUR)
Variable Char    VALEUR()

Local Integer FLGMOD,OK
#Permet de recupérer la nouvelle désignation
If ![V]GIMPORT
    Effzo [M:ITV2]DES(nolign-1)
Endif

Call FMTOPE(VALEUR,[M]FMTASS(nolign-1)) From SPVOBJITV2
Call CHGT_LIG([M:ITV1]ITVTYP,VALEUR,[M:ITV0]REQNUM,[M:ITV2]FCY(nolign-1),[M:ITV2]ASSLIB(nolign-1)
& ,[M:ITV2]ASSPRD(nolign-1),[M:ITV2]ASSITV(nolign-1),[M:ITV2]RSCCOD(nolign-1),[M:ITV2]ITMDES(nolign-1)
& ,[M:ITV2]UOM(nolign-1),[M:ITV2]QTY(nolign-1),[M:ITV2]QUESTION(nolign-1),[M:ITV2]MOTINV(nolign-1)
& ,[M:ITV2]NBPT(nolign-1),[M:ITV2]NBLOD(nolign-1),[M:ITV2]BPSNUM(nolign-1)) From SPVOBJITV2
If ![V]GIMPORT

    # LBORN 25/10/2016 - Mantis 29720
    # Affzo [M:ITV2]FCY(nolign-1),ITMDES(nolign-1),UOM(nolign-1),QTY(nolign-1)
    Affzo [M:ITV2]FCY(nolign-1),ITMDES(nolign-1),QTY(nolign-1)
    If [M:ITV2]UOM(nolign-1)<>""
      Affzo [M:ITV2]UOM(nolign-1)
    Endif

    Affzo [M:ITV2]QUESTION(nolign-1),MOTINV(nolign-1),NBPT(nolign-1)
    Affzo [M:ITV2]NBLOD(nolign-1),BPSNUM(nolign-1)
Endif

If [M:ITV2]OPETYP(nolign-1)<>1
    [M:ITV2]FLGTPS(nolign-1)=1
Else
    [M:ITV2]FLGTPS(nolign-1)=3 : # produit
Endif
End

########################################
Subprog D_UNTPRI(VALEUR)
Variable Decimal VALEUR

Local Integer NBREM,I,NOL
Local Char ACTION
[L]NOL=nolign-1

#Recuper le nb remise pour le gas
If !clalev([F:ACV]) : Local File ACTIV : Endif
Call LECTURE("ACV","SPR","") From CONTOBJ
If [F:ACV]FLACT = 2 Then
  [L]NBREM = [F:ACV]DIME
Endif

Gosub INIT_PARAM
[L]DEVISE=[M:ITV2]CURINV(nolign-1)
[L]CURTYP=[M:ITV2]CURTYP(nolign-1)
Call RECH_PRIX([L]PARAMC,[L]PARAMD,[L]PRIX,[L]REMISE,[L]DEVISE,[L]CURTYP,1)From SPVOBJITV2

# Actions spécifiques : renseigner las variables PRIX et REMISE() en se servant de la devise de calcul DEVISE
GPOINT="D_UNTPRI" : Gosub ENTREE From EXEFNC

VALEUR=[L]PRIX
#On reparti les remises
For I=1 To [L]NBREM
    Assign "[M:ITV2]DISCRGVAL"+num$(I)+"([L]NOL)" With [L]REMISE(I-1)
    If ![V]GIMPORT
    #Cause web
        Affzo ="[M:ITV2]DISCRGVAL"+num$(I)+"([L]NOL)"
    Endif
Next
End

########################################
Subprog D_PRIPUR(VALEUR)
Variable Decimal VALEUR

# LBORN 30/10/2012
Local Char ZCODEXP
[L]ZCODEXP=func SPVOBJITL.CODEXP_FRAIS([M]CODOPE(nolign-1), [M:ITV1]ITVTYP)
If [L]ZCODEXP<>""
  Call INIT_FRAIS([M]FCY(nolign-1), [L]ZCODEXP, [M]ASSLIB(nolign-1), [M]CURPUR(nolign-1), [M]QTY(nolign-1), VALEUR) From SPVOBJITL
  If VALEUR<>0 : End : Endif
Endif

Local Integer NBREM,I,NOL
Local Char ACTION
[L]NOL=nolign-1

#Recuper le nb remise pour le gas
If !clalev([F:ACV]) : Local File ACTIV : Endif
Call LECTURE("ACV","PPR","") From CONTOBJ
If [F:ACV]FLACT = 2 Then
  [L]NBREM = [F:ACV]DIME
Endif

Gosub INIT_PARAM
[L]DEVISE=[M:ITV2]CURPUR(nolign-1)
[L]CURTYP=[M:ITV2]CURTYPPUR(nolign-1)
Call RECH_PRIX([L]PARAMC,[L]PARAMD,[L]PRIX,[L]REMISE,[L]DEVISE,[L]CURTYP,2)From SPVOBJITV2

# Actions spécifiques : renseigner las variables PRIX et REMISE() en se servant de la devise de calcul DEVISE
GPOINT="D_PRIPUR" : Gosub ENTREE From EXEFNC

VALEUR=[L]PRIX
#On reparti les remises
For I=1 To [L]NBREM
    Assign "[M:ITV2]DISPUR"+num$(I)+"([L]NOL)" With [L]REMISE(I-1)
    If ![V]GIMPORT
    #Cause web
        Affzo ="[M:ITV2]DISPUR"+num$(I)+"([L]NOL)"
    Endif
Next
End

