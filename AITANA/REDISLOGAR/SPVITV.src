######################################################################################
Subprog AS_NBLIG

# LBORN 10/11/2015 - Mantis 30645
If GIMPORT : End : Endif

# LBORN 25/06/2013 - Mantis 19607
Raz [V]GBIDC1

If [M:ITV2]NUMORI(nolign-1)<>""
  Case [M:ITV2]TYPORI(nolign-1)
    When 3 : [V]GBIDC1="SOH"
    When 4 : [V]GBIDC1="ITL"
  Endcase
Endif

End

########################################
Subprog IB_NBLIG
Local Char XABREV,XIND
Local Char XCLEIDX1, XCLEIDX2
Local Integer XNBCLE # nombre de composant de cle

# LBORN 18/06/2012
If [M:ITV2]CODOPE(nolign-1)=""
  Raz GBOUT6
Endif

If nolign>dim([M:ITV2]ASSLIB) | nolign < 1
  GBOUT3=""
  GBOUT4=""
  End
Endif
If ([M:ITV2]ASSITV(nolign-1)<>"" & [M:ITV2]ASSITV(nolign-1)=[M:ITV2]ASSLIB(nolign-1))
&  |([M:ITV2]RSCCOD(nolign-1)<>"" & [M:ITV2]RSCCOD(nolign-1)=[M:ITV2]ASSLIB(nolign-1))
  GBOUT3=mess(16,[V]GXMSGPSA,1)
  [M:ITV2]FLGTPS(nolign-1)=1
Else
  GBOUT3=""
Endif

If [M:ITV2]QUESTION(nolign-1)<>"" & [M:ITV2]IDQSNLIG(nolign-1)=""
    #Consultation du resultat du questionnaire en ligne
    Gosub LEC_LIENSD_SUP From SPVOBJITV :# Mise en phase de liens supplémentaires

    If !clalev([F:QSN]) : Local File QSNPSA : Endif
    If !clalev([F:XGOB]) : Local File GASOBJ [XGOB] : Endif

    Read [QSN]QSN0(1)=[M:ITV2]QUESTION(nolign-1)
    If !fstat
        Read [XGOB]GOB0=[F:QSN]CODLIK
        If !fstat
            Call ATB_INFO([XGOB]FILCOD,[L]XABREV,[L]XIND,[L]XCLEIDX1,[L]XCLEIDX2,[L]XNBCLE) From XTRTDIV
            If [L]XCLEIDX2<>""
                [F:ITD]ITVLIG=[M:ITV2]ITVLIG(nolign-1)
                GLNKQSND=[F:QSN]CODLIK+num$(evalue([L]XABREV+[L]XCLEIDX1))+num$(evalue([L]XABREV+[L]XCLEIDX2))
            Else
                GLNKQSND=[F:QSN]CODLIK+num$(evalue([L]XABREV+[L]XCLEIDX1))
            Endif
        Endif
    Endif
Else
    [V]GBOUT4=""
Endif

#FM le 09.02.06
Gosub MAJ_GBOUT10

# LBORN 10/12/2010
If [M:ITV2]CMMNUM(nolign-1)<>""
  If !clalev([F:CMM]) : Local File GCOMMIT : Endif
  Read [F:CMM]CMM0=[M:ITV2]CMMNUM(nolign-1)
  If !fstat
    [V]GBOUT5=mess(160,198,1)
  Endif
Else
  Raz [V]GBOUT5
Endif

# LBORN 25/06/2013 - Mantis 19607
If [M:ITV2]VALNUM(nolign-1)<>""
  # LBORN 05/09/2014
  # [V]GBOUT7=mess(22,477,1)-[M:ITV2]VALNUM(nolign-1)
  [V]GBOUT7=mess(52,477,1)-[M:ITV2]VALNUM(nolign-1)
Else
  Raz [V]GBOUT7
Endif

# LBORN 25/06/2013 - Mantis 19607
Raz [V]GBOUT8, [V]GBIDC1
If [M:ITV2]NUMORI(nolign-1)<>""
  Case [M:ITV2]TYPORI(nolign-1)
    When 3 : [V]GBOUT8=mess([M:ITV2]TYPORI(nolign-1),1850,1)-[M:ITV2]NUMORI(nolign-1)
    When 4 : [V]GBOUT8=mess([M:ITV2]TYPORI(nolign-1),1850,1)-[M:ITV2]NUMORI(nolign-1)
  Endcase
Endif

End

