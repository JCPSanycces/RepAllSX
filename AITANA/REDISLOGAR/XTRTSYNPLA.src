######################################################################################
Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 : Raz [M:DIA]FCYBEG,FCYEND : Affzo [M:DIA]FCYBEG,FCYEND : Endif
End

