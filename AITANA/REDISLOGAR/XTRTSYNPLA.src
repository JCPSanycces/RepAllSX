######################################################################################
Subprog AV_ALLOPP(VALEUR)
Variable Integer VALEUR
If [V]GXOPTOPP=0 # Si module affaire actif
  Grizo [M:DIA]ALLOPP,OPPBEG,OPPEND
  Grizo [M:DIA]ALLTASK,TASKOPPBEG,TASKOPPEND
Endif
If GFONC1 = "GESOPP"
  Grizo [M:DIA]1-99
Endif
End

