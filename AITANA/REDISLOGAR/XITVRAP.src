#<AdxTL>@(#)9.0.0.0 $Revision$
#ACV#X12
#TIT#Trt init XITVRAP

Subprog IMPRIME(NBPAR,PARAMETRE) : Value Integer NBPAR : Variable Char PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End

Subprog EXEC(NBPAR,PARAMETRE) : Value Integer NBPAR : Variable Char PARAMETRE()()
Local File AREPORTM [ARM]

Local Integer I, J, OK, COMPTEUR,XNUMLIG
Local Char PARAM(30), VALEUR(30)
Local Char XBPRDEB,XPBRFIN,XREQDEB,XREQFIN,XITVDEB,XITVFIN
Local Date XDATDEB,XDATFIN

For I=1 To NBPAR
   J=instr(1,[L]PARAMETRE(I),"=")
   If J<>0 Then
      [L]PARAM  = left$([L]PARAMETRE(I),J-1)
      [L]VALEUR = right$([L]PARAMETRE(I),J+1)
      Case [L]PARAM
         When "bprdeb" : XBPRDEB=[L]VALEUR
         When "bprfin" : XBPRFIN=[L]VALEUR
         When "reqdeb" : XREQDEB=[L]VALEUR
         When "reqfin" : XREQFIN=[L]VALEUR
         When "itvdeb" : XITVDEB=[L]VALEUR
         When "itvfin" : XITVFIN=[L]VALEUR
          When "datedeb" : XDATDEB=gdat$(val(mid$(VALEUR,7,2)),val(mid$(VALEUR,5,2)),val(left$(VALEUR,4)))
          When "datefin" : XDATFIN=gdat$(val(mid$(VALEUR,7,2)),val(mid$(VALEUR,5,2)),val(left$(VALEUR,4)))
         When "compteur" : 
            [L]COMPTEUR=uniqid([F:ARM])
            PARAMETRE(I)="compteur="+num$([L]COMPTEUR)
      Endcase
   Endif
Next

Call DEBTRANS From GLOCK
GOK=1
Trbegin [ARM]

Local File REQUEST [REQ],ITVREQ [ITV]

XNUMLIG=1
For [ITV]ITR0 
&  Where ITVNUM>=XITVDEB and ITVNUM<=XITVFIN
&      & REQNUM>=XREQDEB and REQNUM<=XREQFIN
&      & ITVDAT>=XDATDEB and ITVDAT<=XDATFIN
   Read [REQ]REQ0=[ITV]REQNUM
   If fstat=0 and [REQ]BPCNUM>=XBPRDEB and [REQ]BPCNUM<=XBPRFIN Then
      Readlock [ITV] Curr
      If fstat=0 Then
         [F:ITV]FLGITVPRN=2
         Rewrite [F:ITV]
         If fstat=0 THEN
            [F:ARM]USR     = GUSER
            [F:ARM]RPTCOD  = [F:ARP]RPTCOD
            [F:ARM]NUMREQ  = [L]COMPTEUR
            [F:ARM]NUMLIG  = XNUMLIG : XNUMLIG+=1
            [F:ARM]CLEA1   = [F:ITV]ITVNUM
            [F:ARM]CREDAT  = date$
            Write [F:ARM]   
            If fstat<>0 Then
               Call FSTA("ARM") From GLOCK
               GOK=0
               Break
            Endif
         Else Call FSTA("ITV") From GLOCK : Endif     
      Else Infbox "Intervention"-[ITV]ITVNUM-"en cours d'utilisation" : Endif
   Endif
Next

If GOK=1 Then Commit Else Rollback : Endif
End
