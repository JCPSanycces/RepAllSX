#TIT#Gestion de l'objet Opé / Type d'inter

#===============================================================================
# Gestion de l'objet   : Gestion de l'objet Opé / Type d'inter
#
# Auteur               :
# Date de création     :
#===============================================================================
# Modifications significatives :
#-------------------------------------------------------------------------------
# Date          Auteur       Description
#-------------------------------------------------------------------------------
# 08/08/2002    OTHYR        Modélisation Web
#-------------------------------------------------------------------------------
# 30/10/2002    OTHYR        Modélisation Web / Sélection dans table
#-------------------------------------------------------------------------------
# 25/11/2004    LBORN        Maj init actions sur champs / Paramétrage code validation
#===============================================================================

Call OBJET("OTI", GBIDC1, GBIDC2) From GOBJET
End

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$ACTION

# Spé du client(GFI infogen + dév client) - Appel auto Trt YSPEOTI
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "FILTRE"     : Gosub FILTRE        From SPVOBJOTI
  When "LIENS"      : Gosub LIENS         From SPVOBJOTI
  When "SETBOUT"    : Gosub SETBOUT       From SPVOBJOTI
  When "RAZDUP"     : Gosub RAZDUP        From SPVOBJOTI
  When "RAZCRE"     : Gosub RAZCRE        From SPVOBJOTI
  When "CREATION"   : Gosub CREATION      From SPVOBJOTI
  When "MODIF"      : Gosub MODIF         From SPVOBJOTI
  When "ANNULE"     : Gosub ANNULE        From SPVOBJOTI
  When "SEL_TABLE"  : Gosub SEL_TABLE     From SPVOBJOTI
  When "SEL_LISTE"  : Gosub SEL_LISTE     From SPVOBJOTI
  When "OUVRE"      : Gosub OUVRE         From SPVOBJOTI
Endcase

Return

################################################################################
################################################################################
################################################################################
################################################################################

#===============================================================================
# Ecran OPETIT0
#===============================================================================

########################################
Subprog D_OPECOD(VALEUR)
Variable Char     VALEUR
If !GIMPORT & dim([M:OPE0]OPECOD)>=0 Then
  VALEUR=[M:OPE0]OPECOD
Endif
End


#===============================================================================
# Ecran OPETIT1
#===============================================================================

########################################
Subprog AP_QTYNEG(VALEUR)
Variable Integer  VALEUR

If (VALEUR = 1) & ([M:OTI1]QTYPOS = 1) Then
    [M:OTI1]QTYPOS = 2
Endif
End

########################################
Subprog AP_QTYPOS(VALEUR)
Variable Integer  VALEUR

If (VALEUR = 1) & ([M:OTI1]QTYNEG = 1) Then
    VALEUR = 2
Endif
End

#==============================================#
# Contrôle sur les valeurs / défaut            #
#                                              #
# si OPETYP = Prestation | Ressource           #
# alors ttes les valeurs / défaut obligatoires #
#==============================================#
########################################
Subprog C_ITEM(VALEUR)
Variable Char    VALEUR()

If find([F:OPE]OPETYP,2,3) and (VALEUR = "") Then
    [V]GMESSAGE = mess(17,[V]GXMSGPSA,1)
    mkstat = 2
Endif
End

########################################
Subprog AS_TCLCOD(VALEUR)
Variable Char    VALEUR()

If find([F:OPE]OPETYP,2,3) Then
    VALEUR = ""
    mkstat = 2
Endif
End

########################################
Subprog AS_ORGINT(VALEUR)
Variable Integer VALEUR

If find([F:OPE]OPETYP,1,3) Then
    VALEUR = 1
    mkstat = 2
Endif
End

########################################
Subprog AS_CATPRIINT(VALEUR)
Variable Char    VALEUR()

If find([F:OPE]OPETYP,1,3) Then
    VALEUR = ""
    mkstat = 2
Endif
End

########################################
Subprog AS_IUSCOD(VALEUR)
Variable Char    VALEUR()

If find([F:OPE]OPETYP,1,3) Then
    VALEUR = ""
    mkstat = 2
Endif
End

########################################
Subprog C_IUSCOD(VALEUR)
Variable Char    VALEUR()

If [F:OPE]OPETYP = 2 & [M:OTI1]ORGINT = 5 & VALEUR = "" Then
    [V]GMESSAGE = mess(17,[V]GXMSGPSA,1)
    mkstat = 2
Endif
End

########################################
Subprog AS_CAT(VALEUR)
Variable Char    VALEUR()

If find([F:OPE]OPETYP,1,2) Then
    VALEUR = ""
    mkstat = 2
Endif
End

########################################
Subprog AS_RSCDEF(VALEUR)
Variable Char    VALEUR()

If find([F:OPE]OPETYP,1,2) Then
    VALEUR = ""
    mkstat = 2
Endif
End

########################################
Subprog C_FCYDEF(VALEUR)
Variable Char    VALEUR()

If [M:OTI1]ORIFCYOTI = 5 & VALEUR = "" Then
    [V]GMESSAGE = mess(17,[V]GXMSGPSA,1)
    mkstat = 2
Endif
End

########################################
Subprog C_UOM(VALEUR)
Variable Char    VALEUR()
Local Char TEXTE(250)
Local Integer OK

If find([F:OPE]OPETYP,2) Then
    Call CONTROLE("TUN","B",VALEUR,"",mkstat) From CONTOBJ
    If mkstat Then
        [L]TEXTE = [V]GMESSAGE
        Call CONTROLE("TUN","C",VALEUR,"",mkstat) From CONTOBJ

        # LBORN 14/05/2014 - Mantis 24758
        # [V]GMESSAGE -= "ou"-[L]TEXTE
        [V]GMESSAGE-=mess(58,147,1)-[L]TEXTE
    Endif
Else
    Call CONTROLE("TUN","",VALEUR,"",mkstat) From CONTOBJ
Endif

#Verification que l'unité est rataché à l'article
If !mkstat & [M]ITEM<>"" Then
    Call CTRL_UOM_ITM([M]ITEM,VALEUR,[L]OK) From SPVOBJOTI
    If ![L]OK Then
        mkstat=2
    Endif
Endif

# LBORN 14/05/2014 - Mantis 24758
If [F:OPE]FLGTES=2 & mkstat
  mkstat=0
  [V]GERR=3
Endif

End

########################################
Subprog C_QTY(VALEUR)
Variable Decimal VALEUR

If VALEUR = 0 & [M:OTI1]QTYNUL <> 2 Then
    mkstat = 2
Endif
End


################################################################################
################################################################################
################################################################################
################################################################################

#===============================================================================
# Ecran OPETIT5
#===============================================================================

########################################
Subprog AS_ORIPXV(VALEUR)
Variable Integer VALEUR

If nolign>1 Then GMENLOC(1)=1 Endif
End

########################################
Subprog AS_ORIPXA(VALEUR)
Variable Integer VALEUR

GMENLOC(5)=1 #FM le 13.03.06 (Pour rester en phase avec le ML 1775)
If nolign>1 Then GMENLOC(1)=1 Endif
End

########################################
Subprog C_ORIPXV(VALEUR)
Variable Integer VALEUR

Call UNICITE(VALEUR,[M:OTI5]ORIPXV)From OBJDIV
End

########################################
Subprog C_ORIPXA(VALEUR)
Variable Integer VALEUR

Call UNICITE(VALEUR,[M:OTI5]ORIPXA)From OBJDIV
End

########################################
Subprog AM_ORIPXV(VALEUR)
Variable Integer VALEUR

Local Integer I
If nolign=1 & VALEUR=1
    For I=1 To dim([M]ORIPXV)-1
        [M:OTI5]ORIPXV(I)=0
    Next I
    [M:OTI5]NBPXV=1
    Affzo [M:OTI5]NBPXV
Endif
End

########################################
Subprog AM_ORIPXA(VALEUR)
Variable Integer VALEUR

Local Integer I
If nolign=1 & VALEUR=1
    For I=1 To dim([M]ORIPXA)-1
        [M:OTI5]ORIPXA(I)=0
    Next I
    [M:OTI5]NBPXA=1
    Affzo [M:OTI5]NBPXA
Endif
End

########################################
Subprog C_NBPXV

If nolign>1 & [M]ORIPXV(0)=1 & status<>21 & status<>92
    mkstat=2
Endif
End

########################################
Subprog C_NBPXA

If nolign>1 & [M]ORIPXA(0)=1 & status<>21 & status<>92
    mkstat=2
Endif
End

########################################
Subprog D_TRTSPE(VALEUR)
Variable Char    VALEUR()

VALEUR = "Y"+[M]OPECOD+[M]INTTYP
End



################################################################################
################################################################################
################################################################################
################################################################################

#===============================================================================
# Ecran OPETIT9
#===============================================================================

########################################
$SETNOL
Local Integer NOL : NOL=nolign-1
Return

########################################
Subprog AM_CODVAL(VALEUR)
Variable Char     VALEUR

Read [F:PV1]PV10=VALEUR
If !fstat Then
  Gosub SETNOL
  [M:OTI9]EXPR(NOL)=[F:PV1]TRIGEXP
  [M:OTI9]VGASTA(NOL)=max([F:PV1]VALVGASTA,1)
  [M:OTI9]UPDFLG(NOL)=max([F:PV1]VALFLGUPD,1)
  [M:OTI9]RGPCOD(NOL)=[F:PV1]RGPCOD
  [M:OTI9]PARAM1(NOL)=[F:PV1]PARAM1
  [M:OTI9]PARAM2(NOL)=[F:PV1]PARAM2

  If [M:OTI9]ORGFCY(NOL)=3 Then [M:OTI9]FCY(NOL)=[F:PV1]VALFCY Endif
  If [M:OTI9]ORGFCYSOC(NOL)=3 Then [M:OTI9]FCYSOC(NOL)=[F:PV1]VALFCYSOC Endif

  If !GIMPORT Then
    Affzo [M:OTI9]EXPR(NOL)
&                ,VGASTA(NOL)
&                ,UPDFLG(NOL)
&                ,RGPCOD(NOL)
&                ,PARAM1(NOL)
&                ,PARAM2(NOL)
&                ,FCY(NOL)
&                ,FCYSOC(NOL)
  Endif
Endif
End

########################################
Subprog AM_ORGRGPCOD(VALEUR)
Variable Integer  VALEUR

#Si origine=Code opé
If VALEUR=2 Then
  Read [F:PV1]PV10=[M:OTI9]CODVAL(nolign-1)
  If !fstat Then [M:OTI9]RGPCOD(nolign-1)=[F:PV1]RGPCOD Endif
Endif
End

########################################
Subprog AS_RGPCOD(VALEUR)
Variable Char     VALEUR

#Si origine<>Code opé
If [M:OTI9]ORGRGPCOD(nolign-1)<>2 Then mkstat=1 Endif
End

########################################
Subprog AM_ORGFCYSOC(VALEUR)
Variable Integer  VALEUR

If VALEUR=3 Then
  Read [F:PV1]PV10=[M:OTI9]CODVAL(nolign-1)
  If !fstat Then [M:OTI9]FCYSOC(nolign-1)=[F:PV1]VALFCYSOC Endif
Endif
End

########################################
Subprog AM_ORGFCY(VALEUR)
Variable Integer  VALEUR

If VALEUR=3 Then
  Read [F:PV1]PV10=[M:OTI9]CODVAL(nolign-1)
  If !fstat Then [M:OTI9]FCY(nolign-1)=[F:PV1]VALFCY Endif
Endif
End

########################################
Subprog AS_FCYSOC(VALEUR)
Variable Char     VALEUR

If [M:OTI9]ORGFCYSOC(nolign-1)<>3 Then mkstat=1 Endif
End

########################################
Subprog AS_FCY(VALEUR)
Variable Char     VALEUR

If [M:OTI9]ORGFCY(nolign-1)<>3 Then mkstat=1 Endif
End

########################################
Subprog AS_UPDFLG(VALEUR)
Variable Integer  VALEUR

If find([M:OTI9]VGASTA(nolign-1),2,3) Then
  VALEUR=1 : mkstat=2
Elsif [M:OTI9]VGASTA(nolign-1)=4 Then
  VALEUR=2 : mkstat=2
Endif
End

########################################
Subprog AS_VGADIF(VALEUR)
Variable Integer  VALEUR

Call LECTURE("PV1",[M:OTI9]CODVAL(nolign-1),"")From CONTOBJ

#LBORN 16/08/2010
#If !find([F:PV1]TYPDOC, "OBJ", "ES1", "SS1", "TS1") Then
If find([F:PV1]TYPDOC, "LP1","LV1","RC1","RE1","RP1","RV1","RX1")
  VALEUR = 2 : mkstat = 2
Elsif VALEUR = 0 Then
  VALEUR = 2
Endif
End

########################################
Subprog C_PARAM1(VALEUR)
Variable Char     VALEUR
Call CONPARAM(VALEUR, [M]CODVAL(nolign-1))From SPVOBJOTI
End

########################################
Subprog C_PARAM2(VALEUR)
Variable Char     VALEUR
Call CONPARAM2(VALEUR, [M]CODVAL(nolign-1))From SPVOBJOTI
End

########################################
Subprog AS_ORGRGPCOD(VALEUR)
Variable Integer  VALEUR
If !GIMPORT & !GSERVEUR Then
  If !GXOPTCON Then
    GMENLOC(3)=1 #Contrat (Gestion)
    GMENLOC(4)=1 #Contrat (Facturation)
    GMENLOC(5)=1 #Contrat (DS)
  Endif
Endif
End

########################################
Subprog AP_ORGRGPCOD(VALEUR)
Variable Integer  VALEUR
If !GIMPORT & !GSERVEUR Then Raz GMENLOC Endif
End

########################################
Subprog AS_ORGFCY(VALEUR)
Variable Integer  VALEUR
If !GIMPORT & !GSERVEUR Then
  If !GXOPTCON Then GMENLOC(7)=1 Endif #Contrat
Endif
End

########################################
Subprog AP_ORGFCY(VALEUR)
Variable Integer  VALEUR
If !GIMPORT & !GSERVEUR Then Raz GMENLOC Endif
End

########################################
Subprog AS_ORGFCYSOC(VALEUR)
Variable Integer  VALEUR
If !GIMPORT & !GSERVEUR Then
  If !GXOPTCON Then GMENLOC(7)=1 Endif #Contrat
Endif
End

########################################
Subprog AP_ORGFCYSOC(VALEUR)
Variable Integer  VALEUR
If !GIMPORT & !GSERVEUR Then Raz GMENLOC Endif
End

########################################
Subprog AS_NOTFRL(VALEUR)
Variable Integer VALEUR

If ![V]GXOPTOPP
  mkstat=1
Else
  Read [PV1]PV10=[M]CODVAL(nolign-1)
  If !fstat & [F:PV1]TYPDOC="RE1"
    VALEUR=1
    mkstat=2
  Endif
Endif

End

######################################################################################
Subprog AV_NOTFRL(VALEUR)
Variable Integer VALEUR
If ![V]GXOPTOPP
  mkstat=1
Elsif VALEUR=0
  VALEUR=1
Endif
End


######################################################################################
Subprog AS_BCHFLG(VALEUR)
Variable Integer VALEUR

Read [PV1]PV10=[M]CODVAL(nolign-1)
If !fstat & !find([F:PV1]TYPDOC,"FC1","AC1")
  VALEUR=1
  mkstat=2
Endif

End


######################################################################################
Subprog AV_BCHFLG(VALEUR)
Variable Integer VALEUR

If VALEUR=0
  VALEUR=1
Endif

End

######################################################################################
Subprog AV_ORGUOM(VALEUR)
Variable Integer VALEUR

If VALEUR=0
  VALEUR=1
Endif

End

