#<AdxTL>@(#)7.0.0.0 $Revision$
#ACV#X11
#TIT#Gestion de l'objet PTV

[V]GBIDC1=""
[V]GBIDC2=""
Call OBJET("OPP", GBIDC1, GBIDC2) From GOBJET
End

$ACTION
Case ACTION
    When "OUVRE"      : Gosub OUVRE     From SPVOBJPTV
    When "FILTRE"     : Gosub FILTRE    From SPVOBJPTV
    When "SETBOUT"    : Gosub SETBOUT   From SPVOBJPTV
    When "FERME"      : Gosub FERME     From SPVOBJPTV
Endcase
Return


########################################
Subprog AS_OPPNUM(VALEUR)
Variable Char    VALEUR()
If [V]GXTUNNEL
   VALEUR=[F:OPP]OPPNUM
   If GXOPTOPP
     If !clalev([F:XOP]) : Local File OPPORX3S : Endif
     Read [F:XOP]XOP0=[F:OPP]OPPNUM
     If !fstat
       [M:PTV0]BPCINV=[F:XOP]BPCINV
     Endif
   Endif
   [M:PTV0]OPPNUM=VALEUR
   [M:PTV0]CURINV=[F:OPP]CUR
   [M:PTV0]LAN   =[V]GLANGUE
   If !GIMPORT
      Affzo OPPNUM
      mkstat=2
   Endif
Endif
End

########################################
Subprog IB_ITMREF
Raz GBOUT1, GBOUT2, GBOUT3

# Déf. bouton article
GBOUT1=mess(22,198,1)
# Déf. bouton article-client
GBOUT2=mess(87,198,1)
# Déf. bouton Tarif
GBOUT3=mess(42,198,1)
End


########################################
Subprog C_ITMREF(VALEUR)
Variable Char     VALEUR

Local Integer NOL
NOL=nolign-1

# --> Lecture objet ITM
Call LECTURE("ITM", VALEUR, "") From CONTOBJ
If fstat <> 0 GMESSAGE = mess(8,192,1) : mkstat=2 : End : Endif

# --> Contrôle du statut de l'article
If [F:ITM]ITMSTA > 1
   GMESSAGE = mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")"
   If [F:ITM]ITMSTA = 6
      GERR=1 : mkstat=2
   Else
      GERR=3
   Endif
Endif

End



########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer NLIG    : NLIG = nolign-1

#---- Init des zones liées à l'article
Gosub INIT_ITM
Return

########################################
$INIT_ITM

#---- Désignation
[M:PTV0]ITMDES1(NLIG)    = [F:ITS]ITMDES1

Call LEC_TEXTRA("ITMMASTER","DES1AXX",[M:PTV0]LAN,VALEUR,"",[M:PTV0]ITMDES(NLIG))
&               From XTRTATEXTRA

If [M:PTV0]ITMDES(NLIG) = "" Then
   [M:PTV0]ITMDES(NLIG) = [M:PTV0]ITMDES1(NLIG)
Endif

If !GIMPORT
  Affzo [M:PTV0]ITMDES(NLIG)
Endif

#---- Unité (Vente)
[M:PTV0]SAU(NLIG)   = [F:ITM]SAU
End

########################################
Subprog AM_ENAFLG(VALEUR)
Variable Integer VALEUR

[M:PTV0]MODUSR(nolign-1)=[V]GUSER
[M:PTV0]MODDAT(nolign-1)=date$
End

########################################
Subprog IB_IUSRES
GBOUT3=mess(135,[V]GXMSGPSA,1)
End


########################################
Subprog C_IUSRES(VALEUR)
Variable Char    VALEUR()
Local Shortint OK

If VALEUR<>""
    Call CONTROLE("IUS","",VALEUR,"",[L]OK)From CONTOBJ
    If [L]OK
        Call CONTROLE("RSE","",VALEUR,"",[L]OK)From CONTOBJ
        mkstat=[L]OK
    Endif
Endif
# --> Teste si recouvrement de date pour un même article

Local Integer I, J
J = nolign-1

For I=0 To dim([M:PTV0]DATBEG)-1

    If (I<>J) & ([M:PTV0]ITMREF(I)=[M:PTV0]ITMREF(J)) & [M:PTV0]IUSRES(I)=VALEUR & [M:PTV0]SAU(I)=[M:PTV0]SAU(J)

        If (([M:PTV0]DATBEG(J) <= [M:PTV0]DATBEG(I)) and ([M:PTV0]DATEND(J) >= [M:PTV0]DATBEG(I)))
&       or (([M:PTV0]DATBEG(J) >= [M:PTV0]DATBEG(I)) and ([M:PTV0]DATEND(J) <= [M:PTV0]DATEND(I)))
&       or (([M:PTV0]DATEND(J) >= [M:PTV0]DATEND(I)) and ([M:PTV0]DATBEG(J) <= [M:PTV0]DATEND(I))):

            [V]GMESSAGE = mess(36,[V]GXMSGPSA,1)-[M:PTV0]ITMREF(J)
            mkstat=2
            Break
        Endif
    Endif
Next
End

########################################
Subprog AS_REVCOE(VALEUR)
Variable Decimal VALEUR
If [M]REVFOR(nolign-1)=""
    mkstat=1
Endif
End

########################################
Subprog AS_REVBAS(VALEUR)
Variable Date    VALEUR
If [M]REVFOR(nolign-1)=""
    mkstat=1
Endif
End

