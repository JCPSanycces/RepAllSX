######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If !clalev([ZVITBPC]) : Local File YVITMBPC [ZVITBPC] : Endif

Read [ZVITBPC]YIB0 = VALEUR;[M:SDI1]YCLIENTE
If !fstat
  [M:SDI1]YITMDES = [ZVITBPC]ITMDESBPC
Endif
Affzo [M:SDI1]YITMDES
End

