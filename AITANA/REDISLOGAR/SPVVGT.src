#<AdxTL>@(#)4.0.0.0 $Revision$
#ACV#X11
#TIT#Gestion de la table VALGASTMP

GBIDC1=""
GBIDC2=""
Call OBJET("VGT",[V]GBIDC1,[V]GBIDC2) From GOBJET
End


$ACTION

# Appel fonctions complémentaires GFI pour l'objet VGT
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "OUVRE"  : Gosub OUVRE  From SPVOBJVGT
  When "FILTRE" : Gosub FILTRE From SPVOBJVGT
  When "LIENS"  : Gosub LIENS  From SPVOBJVGT
Endcase
    
Return

