#ACV#X11
#TIT#Gestion de l'objet RGT

GBIDC1=""
GBIDC2=""
Call OBJET("RGT",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$ACTION
Case ACTION
 When "SETBOUT" :  Gosub SETBOUT  From SPVOBJRGT
 When default
Endcase
Return

################################################################################
################################################################################
################################################################################
################################################################################

########################################
Subprog C_RGPCODV(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" Then
   Call CONTROLE("RGT","$",VALEUR,"",mkstat)From CONTOBJ
Endif
End

########################################
Subprog C_EXPPCEDAT(VALEUR) # CGUES 27/01/2002
Variable Char    VALEUR()
If VALEUR="" Then
    GERR=3 : GMESSAGE=mess(228,[V]GXMSGPSA,1)
Endif
End



