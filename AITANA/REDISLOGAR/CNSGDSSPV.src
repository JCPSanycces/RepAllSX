#<AdxTL>@(#)11.0.0.0 $Revision$
#ACV#X12
#TIT#Consultation de DS par rapport au contrat

#==========================================================================================
# Gestion de la consultation : GDS -- Consultation DS par rapport au contrat
#                        
# Auteur                     : 
# Date de création           :       
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 28/02/2003    OTHYR        Modélisation Web + ajout PE
#==========================================================================================

Local Char PARAM(30)(2)

Call GCONSULT("GDS","",PARAM)From GCONSULT
End


###################################################################
$ACTION

Case ACTION
    When "AUTORIS"    : Gosub AUTORIS
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "SETBOUT"    : Gosub SETBOUT
    When "FIN_CRIT"   : Gosub FIN_CRIT
    When default
Endcase
Return


#-----------------------------------------------------------------#
#    Gestion des étiquettes liées a ACTION                        #
#-----------------------------------------------------------------#
###################################################################
$AUTORIS
Return

###################################################################
$SETBOUT
Return

###################################################################
$OUVRE

Local Char     CRIT1(250), CRIT2(250), CRIT3(250), CRITSPE(250)
Local Decimal  WMNTORG(0..5), WMNTDES(0..5)
Local Integer  SPSTAT

Gosub DEFCRIT

Return

###################################################################
$DEFCRIT

#If [M:GDS1]FCYREQ <> "" & (([M:GDS1]FCYREQ = GFCYDEF & GUSRACC(1) = 0) | ([M:GDS1]FCYREQ <> GFCYDEF & GUSRACC(2) = 0)) Then
If [M:GDS1]FCYREQ <> "" & ([M:GDS1]FCYREQ = GFCYDEF | [M:GDS1]FCYREQ <> GFCYDEF) Then
    [M:GDS1]FCYREQ = ""
Endif

For I = 1 To dim(PARAM)
    Case I  
        When 1 :    : # Parametre Site
            If PARAM(I) <> "" Then
                If [F:FCY]FCY <> PARAM(I) Then   
                    Read [F:FCY]FCY0 = PARAM(I)
                    If fstat  Raz [F:FCY] : Endif
                Endif
#               If !fstat & ((PARAM(I) = GFCYDEF & GUSRACC(1) <> 0) | (PARAM(I) <> GFCYDEF & GUSRACC(2) <> 0)) Then
                If !fstat & (PARAM(I) = GFCYDEF | PARAM(I) <> GFCYDEF) Then
                    [M:GDS1]FCYREQ = PARAM(I) 
                    Call GETDEV([M:GDS1]FCYREQ) From DEVSUB
                    [M:CGDS]CPY    = GSOCIETE
                Endif
            Endif
        When 2 :    : # Parametre Avenant 
            If PARAM(I) <> "" Then
                Call LECTURE("XON",PARAM(I),"")From CONTOBJ
                If !fstat
                    [M:GDS1]CONREV = PARAM(I)
                Endif   
            Endif
    Endcase
Next I   

If !find([M:GDS1]FLGPRN,1,2) : [M:GDS1]FLGPRN = 2 : Endif
If !find([M:GDS1]FLGCLO,1,2) : [M:GDS1]FLGCLO = 2 : Endif
If !find([M:GDS1]FLGCAN,1,2) : [M:GDS1]FLGCAN = 2 : Endif
If !find([M:GDS1]ORICON,1,2) : [M:GDS1]ORICON = 2 : Endif
If !find([M:GDS1]ORIDIR,1,2) : [M:GDS1]ORIDIR = 2 : Endif
If !find([M:CGDS]TRI,1,2)    : [M:CGDS]TRI    = 1 : Endif

# -- copie de l'écran critères (CGDS) vers le masque 1 (GDS1)
Gosub CRITENT From =PROGCNS

# Pour ne pas lancer automatiquement la consultation si les critères obligatoires ne sont pas renseignés
# Cela évite d'avoir le message d'erreur (NBLU = 0)
If [M:GDS1]CONREV = "" & [M:GDS1]DATBEG = [0/0/0] & [M:GDS1]DATEND = [0/0/0] Then
    CHARGMT = 1
Endif

Return

############################################################
$LECTURE

If [M:GDS1]CONREV = "" & [M:GDS1]DATBEG = [0/0/0] & [M:GDS1]DATEND = [0/0/0] Then
    GERR = 1
    GMESSAGE = mess(13,[V]GXMSGACT,1)
    NBLU = 0 
    Return
Endif

Gosub CHANGE_MSK From GCONSULT 
If CHGPAG < 0 Then 
    NOL = MAXLIG 
Endif

Call TEMPON("R") From GESECRAN

#-- Positionnement des Filtres
Gosub LOAD_FILTER
# Appel au filtre spécifique client
ACTION = "FILTRE"
Gosub ACTION From XOBJCNS
ACTION = "LECTURE"

#***********************************#
# RAPPEL : valeur CHGPAG :          #
#    1 : Recherche                  #
#    2 : Suite                      #
#    3 : F5 (Rafraichissement)      #
#   -1  : Dernier                   #
#   -2  : Retour (Page précédente)  #
#***********************************#
#-- Application des Filtres
If CHGPAG > 0 Then
    SUITE = 1
    If CHGPAG = 1 Then
        RETOUR = 1
    Elsif CHGPAG = 2 Then
        RETOUR = 2
    Endif
    Case [M:CGDS]TRI
        When 1 : # tri par numéro
            Filter [REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE) 
&                        Order By Key REQ0
        When 2 : # tri par date
            Filter [REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE) 
&                        Order By Key CLE = [F:REQ]CREADAT
    Endcase
Else
    RETOUR = 1
    If CHGPAG = -1 Then
        SUITE = 1
    Else
        SUITE = 2
    Endif
    Case [M:CGDS]TRI
        When 1 : # tri par numéro
            Filter [REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE) 
&                        Order By Key REQ0 Desc
        When 2 : # tri par date
            Filter [REQ] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE) 
&                        Order By Key CLE = [F:REQ]CREADAT Desc
    Endcase
Endif
# RAZ du masque
If CHGPAG <> 2 & CHGPAG <> -2 Then
    Raz [M:GDS2]
Endif

#-- lecture 
$BOUCLE
For [REQ]
    # Filtre sur la société
    If [M:CGDS]CPY <> "" & ([M:CGDS]CPY <> [F:REQ]CMP) Goto SUIV : Endif

    If NBLU = 1 Then
        If CHGPAG=2 | CHGPAG=-2 : Raz [M:GDS2] : Endif
        NBLU = 2
    Endif
    If CHGPAG > 0 Then
        If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
        NOL += 1 
        If NOL = 0 Then
            DEBNUM = [F:REQ]REQNUM 
            DEBDAT = [F:REQ]CREADAT
        Endif
        FINNUM = [F:REQ]REQNUM
        FINDAT = [F:REQ]CREADAT
    Else
        If NOL <= 0 : RETOUR=2 : Break : Endif
        NOL    -= 1 
        If NOL = MAXLIG-1 Then
            FINNUM = [F:REQ]REQNUM 
            FINDAT = [F:REQ]CREADAT
        Endif
        DEBNUM = [F:REQ]REQNUM
        DEBDAT = [F:REQ]CREADAT
    Endif

    nolign = NOL+1
    
    [M:GDS2] = [F:REQ]

    [M:GDS2]FCYREQ(nolign-1)        = [F:REQ]FCY
    [M:GDS2]ITMMASTER(nolign-1)     = [F:REQ]ARTICLE 

  $SUIV  
Next

Filter [REQ]

Call TEMPOFF From GESECRAN

Return


###################################################################
$LOAD_FILTER
[L]CRIT1   = "1"            :# Critère sur origine contrat, site, société, contrat, type DS
[L]CRIT2   = "1"            :# Critère sur flag Annulé, Cloturé, Imprimé et Origine directe/contrat
[L]CRIT3   = "1"            :# Critère sur bornes de date et tri
[L]CRITSPE = "1"            :# Critère spécifique client

# 1er critère
# Origine d'un contrat
[L]CRIT1 += "& [F:REQ]CONREV<>''"
If [M:GDS1]FCYREQ <> ""
    [L]CRIT1 += "&[F:REQ]FCY=[M:GDS1]FCYREQ"
Endif
If [M:GDS1]CONREV <> ""
    [L]CRIT1 += "&[F:REQ]CONREV=[M:GDS1]CONREV"
Endif
If [M:CGDS]REQTYP <> ""
    [L]CRIT1 += "&[F:REQ]REQTYP=[M:CGDS]REQTYP"
Endif
If [M:CGDS]CPY <> ""
    [L]CRIT1 += "&[F:REQ]CMP=[M:CGDS]CPY"
Endif

# 2ème critère
# Prise en compte des Ds
# --> Si 1 (Non) On exclut les DS imprimées
If [M:GDS1]FLGPRN = 1
    [L]CRIT2 += "&[F:REQ]FLGREQPRN<>2"
Endif
# --> Si 1 (Non) On exclut les DS Cloturées
If [M:GDS1]FLGCLO = 1
    [L]CRIT2 += "&[F:REQ]FLGREQCLO<>2"
Endif
# --> Si 1 (Non) On exclut les DS Annulées
If [M:GDS1]FLGCAN = 1
    [L]CRIT2 += "&[F:REQ]FLGREQCAN<>2"
Endif
# Prise en compte des DS d'origine contrat ou directe
# --> Si 1 (Non) On exclut les Ds d'origine contrat
If [M:GDS1]ORICON = 1
    [L]CRIT2 += "&[F:REQ]ORIREQ<>2"
Endif
# --> Si 1 (Non) On exclut les DS directe
If [M:GDS1]ORIDIR = 1
    [L]CRIT2 += "&[F:REQ]ORIREQ<>1"
Endif

# 3ème critère
If [M:GDS1]DATBEG <> [0/0/0]
    [L]CRIT3 += "& [F:REQ]CREADAT>=[M:GDS1]DATBEG"
Endif
If [M:GDS1]DATEND <> [0/0/0]
    [L]CRIT3 += "& [F:REQ]CREADAT<=[M:GDS1]DATEND"
Endif


Case CHGPAG
    When 3 : # rafraichissement
        Case [M:CGDS]TRI
            When 1 : # tri par numéro
                [L]CRIT3 += "&[F:REQ]REQNUM>=DEBNUM"
            When 2 : # tri par date
                [L]CRIT3 += "&[F:REQ]CREADAT>=DEBDAT"
        Endcase
    When 2 : # suite
        Case [M:CGDS]TRI
            When 1 : # tri par numéro
                [L]CRIT3 += "&[F:REQ]REQNUM>FINNUM"
            When 2 : # tri par date
                [L]CRIT3 += "&[F:REQ]CREADAT>FINDAT"
        Endcase
    When -2 : # retour
        Case [M:CGDS]TRI
            When 1 : # tri par numéro
                [L]CRIT3 += "&[F:REQ]REQNUM<DEBNUM"
            When 2 : # tri par date
                [L]CRIT3 += "&[F:REQ]CREADAT<DEBDAT"
        Endcase
Endcase

Return

###################################################################
$FIN_CRIT
Return


#-----------------------------------------------------------------#
#    Gestion des étiquettes liées aux masques GDS1, GDS2 et CGDS  #
#-----------------------------------------------------------------#
###################################################################
Subprog C_FCYREQ(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" Then
    # -- Controle autorisation sur le site
#   If (GUSRACC(1) = 0 & GFCYDEF = VALEUR) or (GUSRACC(2) = 0 & GFCYDEF <> VALEUR)
    
        GMESSAGE = VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        mkstat   = 2 
        End
    

    #-----------------------------------#
    # Alimentation site fin.(GFINRSP)   #
    #              soc. (GSOCIETE)      #
    #              dev.soc. (GLOCALDEV) #
    #-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE 
    Affzo [M]CPY, ZCPY
Elsif [M]CPY = "" Then
    GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    mkstat   = 2
Else
#    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif

End

###################################################################
Subprog IB_NBLIG

Raz GBOUT1

If [M:GDS2]REQNUM(nolign-1) <> "" Then
    GBOUT1 = mess(41,[V]GXMSGPSA,1) 
Endif

End

###################################################################
Subprog AM_DATBEG(VALEUR)
Variable Date    VALEUR

If VALEUR <> [0/0/0] Then 
    [M]DATEND = VALEUR 
Endif

End

###################################################################
Subprog AM_FCYREQ(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" Then
    Call GETDEV(VALEUR) From DEVSUB
    [M:CGDS]CPY = GSOCIETE 
Endif

End

