#ACV#X13
#TIT#Gestion de l'action SCHVRFAGE

#LBO 12/2003

Local Char PARAM(30)(1..16),VALEUR(10) 

PARAM(1)=""
PARAM(2)=""
PARAM(3)=""
PARAM(4)=""
Call TRAITE_CHAR(VALEUR,PARAM,"","XVERIFAGE2","SCHVRFAGE",3) From GTRAITE
End

#-----------------------------------------------------------------------
# Ecran SCHVRFAGE [DIA]
#-----------------------------------------------------------------------

#--------------------------------
Subprog AM_TSSPLA(VALEUR)
Variable Integer VALEUR
Call ACTGRIZO(VALEUR) From XVERIFAGE2
End

#--------------------------------
Subprog AV_ACTGRIZO(VALEUR)
Variable Decimal VALEUR
Call ACTGRIZO([M:DIA]TSSPLA) From XVERIFAGE2
End
