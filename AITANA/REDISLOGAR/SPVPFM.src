########################################
Subprog AV_STAFRM(VALEUR)
Variable Integer VALEUR
Local Integer ZI
For [L]ZI=1 To [M:PFM1]NBLIG+1
  If [L]ZI<>[M:PFM1]XNUMLIG
    Chgstl [M:PFM1]NBLIG([L]ZI-1) With ""
  Else
    Chgstl [M:PFM1]NBLIG([L]ZI-1) With "AMKCUR"
  Endif
Next
End


########################################
Subprog AS_NBLIG

If status<>71 & find(GREP,"C","D") : End : Endif

Local Integer ZLIG, ZI

[L]ZLIG=nolign-1

If [L]ZLIG<=[M:PFM1]NBLIG-1
  Effzo [M:PFM1] 20-40
  Gosub AFFECT_PFM From SPVOBJPFM
  Affzo [M:PFM1]20-40
Endif

nolign=[L]ZLIG+1

Affzo [M:PFM1]STAFRM
End

