Subprog AS_XRAZBUD(VALEUR)
Variable Integer VALEUR
If [M:PFM1]XFLGGENSIT<>2
  VALEUR=1
  [M:PFM1]RAZBUD([M:PFM1]XNUMLIG-1)=VALEUR
  mkstat=2
Endif
End

######################################################################################
Subprog AV_VGADIFPC1(VALEUR)
Variable Integer VALEUR
If VALEUR=0
  If [M:PFM5]VALPC1OPP(nolign-1)=""
    VALEUR=1
  Else
    VALEUR=2
  Endif
Endif
End

######################################################################################
Subprog AS_VGADIFPC1(VALEUR)
Variable Integer VALEUR
If [M:PFM5]VALPC1OPP(nolign-1)=""
