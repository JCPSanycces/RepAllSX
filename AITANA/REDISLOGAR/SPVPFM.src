#<AdxTL>@(#)1.0.0.0 $Revision$
#ACV#X16
#TIT#Gestion de l'objet de Paramétrage par type de bordereau

#==========================================================================================
# Gestion de l'objet   : Gestion de l'objet Paramètres type de bordereau
#
# Auteur               :
# Date de création     :
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 21/12/2004    CPERR        Gestion des textes traduisibles
#==========================================================================================

GBIDC1=""
GBIDC2=""
GFONC1="GESPFM"
Call OBJET("PFM",GBIDC1,"GBIDC2")From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet PFM
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "INICRE"    : Gosub INICRE     From SPVOBJPFM
  When "INIMOD"    : Gosub INIMOD     From SPVOBJPFM
  When "CHANGE"    : Gosub CHANGE     From SPVOBJPFM
  When "ANNULE"    : Gosub ANNULE     From SPVOBJPFM
  When "LIENS"     : Gosub LIENS      From SPVOBJPFM
  When "RAZCRE"    : Gosub RAZCRE     From SPVOBJPFM
  When "CREATION"  : Gosub CREATION   From SPVOBJPFM
  When "MODIF"     : Gosub MODIF      From SPVOBJPFM
  When "SEL_TABLE" : Gosub SEL_TABLE  From SPVOBJPFM
  When "OUVRE"     : Gosub OUVRE      From SPVOBJPFM
  When "FERME"     : Gosub FERME      From SPVOBJPFM
Endcase
Return


#----------------------------------------------------------------
#
# Ecran PFM1
#
#----------------------------------------------------------------
########################################
Subprog AM_XFLGGENSIT(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 Then
    [M:PFM1]SELSTAPUR([M:PFM1]XNUMLIG-1) = 2
    [M:PFM1]XSELSTAPUR = 2
    [M:PFM1]SELSTAREQ([M:PFM1]XNUMLIG-1) = 2
    [M:PFM1]XSELSTAREQ = 2
    [M:PFM1]SELSTASIH([M:PFM1]XNUMLIG-1) = 2
    [M:PFM1]XSELSTASIH = 2
    If dim([M:PFM1]SELSTAOF)>0
      [M:PFM1]SELSTAOF([M:PFM1]XNUMLIG-1) = 2
      [M:PFM1]XSELSTAOF = 2
    Endif
    If !GIMPORT Then
        Affzo [M:PFM1]XSELSTAPUR
        Affzo [M:PFM1]XSELSTAREQ
        Affzo [M:PFM1]XSELSTASIH
        If dim([M:PFM1]XSELSTAOF)>0
          Affzo [M:PFM1]XSELSTAOF
        Endif
    Endif
Else
    [M:PFM1]XRAZBUD=1
    [M:PFM1]RAZBUD([M:PFM1]XNUMLIG-1)=1
    Affzo [M:PFM1]XRAZBUD
Endif
[M:PFM1]FLGGENSIT([M:PFM1]XNUMLIG-1)=VALEUR
End

########################################
Subprog D_TYPDEF(VALEUR)
Variable Integer VALEUR
If !find([V]GREP,"C","D") : End : Endif
Look [F:PFM]PFM0 First
If fstat Then
  VALEUR = 2
Endif
End

