#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du masque SCH2
#ACV#X13
#TIT#Gestion de l'objet SDC

#LBO 07/2002

GBIDC1=""
GBIDC2=""
Call OBJET("SDC",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet SDC
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "DEBUT_MOD" : Gosub DEBUT_MOD From SPVOBJSDC
  When "FILTRE"    : Gosub FILTRE    From SPVOBJSDC
  When "SETBOUT"   : Gosub SETBOUT   From SPVOBJSDC
  When "VERF_ANU"  : Gosub VERF_ANU  From SPVOBJSDC
  When "INICRE"    : Gosub INICRE    From SPVOBJSDC
  When "LIENS"     : Gosub LIENS     From SPVOBJSDC
Endcase

Return


#####################################################################################
# Ecran SCHDETC0 [SDC0]
#####################################################################################

#-----------------------------------
Subprog AS_OPETRAM(VALEUR)
Variable Decimal VALEUR
If [M:SDC0]SYNFLG(nolign-1)<2
  mkstat=1+([M:SDC0]NUMSVP(nolign-1)<>0)
Elsif VALEUR=0
  If indice
    VALEUR=[M:SDC0]OPETRAM(indice-1)
  Else
    VALEUR=1
  Endif
Endif
End

#-----------------------------------
Subprog C_OPETRAM(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 | VALEUR>7
  mkstat=1
Endif
End

#-----------------------------------
Subprog C_NBLIG

# Status 73 : Insertion
#        82 : Ajout
#        65 : Annulation

# Test annulation multiple refusée (contrôle car Pb options de la variable de bas de tableau)
If status=83 : mkstat=1 : End : Endif

If !clalev([F:SHP]) : Local File SCHPARGAS : Endif
Read [F:SHP]SHP0=[M:SDC0]PLANCOD
If fstat : End : Endif

If (find(status,65,68,73,82,83) & [F:SHP]OPESELTYP=1) | (find(status,65,68,83) & [M:SDC0]NUMSVP(nolign-1)=1)
  mkstat=1 : End
Endif

If status=65 & !mkstat
  Read [F:AGD]AGD6(2)=[F:SHP]PLANCOD;[M:SDC0]OPELIB(nolign-1)
  If !fstat
    [V]GMESSAGE="Couleur déjà utilisée dans l'agenda"-[F:SHP]PLANCOD
    [V]GMESSAGE+="\Suppression impossible"
    mkstat=1
  Endif
Endif

End


#-----------------------------------
Subprog AS_OPELIB(VALEUR)
Variable Char    VALEUR()
If !clalev([F:SHP]) : Local File SCHPARGAS : Endif
Read [F:SHP]SHP0=[M:SDC0]PLANCOD
If fstat : End : Endif
If [F:SHP]OPESELTYP=1 | [M:SDC0]NUMSVP(nolign-1)=1 : mkstat=2 : End : Endif
If !mkstat & VALEUR=""
  Read [F:OPE]OPE0=[M:SDC0]OPECOD(nolign-1)
  If !fstat
    Default [F]
    Default File [F:OPE] 
    Onerrgo PB_EVAL
    VALEUR=evalue([F:SHP]OPEVALEXP)
    Onerrgo
    Default [M]
  Endif
Endif
End

$PB_EVAL
Resume

#-----------------------------------
Subprog C_OPELIB(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:SDC0]OPELIB) From OBJDIV
End


#-----------------------------------
Subprog AS_OPECOD(VALEUR)
Variable Char    VALEUR()
If !clalev([F:SHP]) : Local File SCHPARGAS : Endif
Read [F:SHP]SHP0=[M:SDC0]PLANCOD
If fstat : End : Endif
If [F:SHP]OPESELTYP=1 | [M:SDC0]NUMSVP(nolign-1)=1 : mkstat=2 : End : Endif
End

#-----------------------------------
Subprog C_OPECOD(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:SDC0]OPECOD) From OBJDIV
If !mkstat
  [M:SDC0]OPEDES(nolign-1)=[F:OPE]OPEDES
Endif
End

#-----------------------------------
Subprog AS_CODCOL(VALEUR)
Variable Char    VALEUR()
If [M:SDC0]SYNFLG(nolign-1)<2
  mkstat=1+([M:SDC0]NUMSVP(nolign-1)<>0)
Endif
End

#-----------------------------------
Subprog C_CODCOL(VALEUR)
Variable Char    VALEUR()
Call CRYPTCOL(VALEUR,[M:SDC0]CODCOLVP(nolign-1)) From XCRYPTVP
End

#-----------------------------------
Subprog AS_SYNFLG(VALEUR)
Variable Integer VALEUR
If !clalev([F:SHP]) : Local File SCHPARGAS : Endif
Read [F:SHP]SHP0=[M:SDC0]PLANCOD
If fstat | [F:SHP]SYNFLG<>2
  VALEUR=1
  mkstat=2
Elsif VALEUR=0
  VALEUR=2
Endif
End

