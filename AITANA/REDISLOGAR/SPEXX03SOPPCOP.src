#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara XX03SOPPCOP0 (Especifico)

$ACTION

Return

#------------------------------------------------------------------------------#

Subprog AM_YFATHERPJT(VALEUR)
Variable Char    VALEUR()
  If VALEUR=""
    [M:XX03SC0]YREVNUM = "00"
    [M:XX03SC0]YSUBPJTNUM = "000"
    Affzo [M:XX03SC0]YREVNUM, YSUBPJTNUM
  Endif
End

#------------------------------------------------------------------------------#

Subprog AS_YREVNUM(VALEUR)
Variable Char    VALEUR()
  If [M:XX03SC0]YFATHERPJT=""
    VALEUR = "00" : mkstat = 2
  Endif
End

#------------------------------------------------------------------------------#

Subprog C_YREVNUM(VALEUR)
Variable Char    VALEUR()
Local Integer AUXINT

  If VALEUR<>""
    AUXINT = val(VALEUR)
    VALEUR = format$("N0:2#", AUXINT)
  Endif
End

#------------------------------------------------------------------------------#

Subprog AS_YSUBPJTNUM(VALEUR)
Variable Char    VALEUR()
  If [M:XX03SC0]YFATHERPJT=""
    VALEUR = "000" : mkstat = 2
  Endif
End

#------------------------------------------------------------------------------#

Subprog C_YSUBPJTNUM(VALEUR)
Variable Char    VALEUR()
Local Integer AUXINT

  If VALEUR<>""
    AUXINT = val(VALEUR)
    VALEUR = format$("N0:3#", AUXINT)
  Endif
End

