#<AdxTL>@(#)0.0.0.0 $Revision$ Devoluciones cliente

$ACTION
Case ACTION
  When "APRES_CRE" : Gosub APRES_CRE
 When Default
Endcase
Return


#####################################################################################
# CodAct: YA041 - Cambio automatico estado parque cliente JEL
#####################################################################################
$APRES_CRE
#Indicamos que primero vaya a sub
Gosub ACTION From SUBSRH
  Local Char RETTYP : Raz RETTYP
  Local Integer ERRORNUMSER
  #abrimos las tablas
#  If !clalev ([ZSRH]) : Local File SRETURN [ZSRH] : Endif
#  If !clalev ([ZSRD]) : Local File SRETURND [ZSRD] : Endif
  [L]RETTYP = [F:SRH]SRHTYP
  If [F:SRH]SRHTYP = "REP" | [F:SRH]SRHTYP = "FAB"
    Filter [F:SRD] Where [F:SRD]SRHNUM = [F:SRH]SRHNUM
    For [SRD]
      Filter [F:STJ] Where [F:STJ]VCRNUM = [SRH]SRHNUM & [F:STJ]VCRLIN = [SRD]SRDLIN
&                        & [F:STJ]TRSTYP = 12 & [F:STJ]UPDCOD = 2
      For [STJ]
        If !clalev ([ZITM]) : Local File ITMMASTER [ZITM] : Endif
        Read [F:ZITM]ITM0 = [F:STJ]ITMREF
        If fstat = 0
          If [F:ZITM]CREMAC = 2
            If [STJ]SERNUM <>''
              If !clalev ([ZMAC]) : Local File MACHINES [ZMAC] : Endif
              Read [ZMAC]MAC5 = [STJ]ITMREF;[STJ]SERNUM
              If fstat = 0
			  #cambiamos el campo estado de la pantalla MAC1
                If !clalev ([ZXMA]) : Local File MACHINEFL [ZXMA] : Endif
                Trbegin [ZXMA]
                Readlock [ZXMA]XMA0 = [ZMAC]MACNUM
                If fstat=0
#                  If RETTYP = "FAB"
#                    [F:ZXMA]STATITM = "DFA"
#                  Elsif RETTYP = "REP"
#                    [F:ZXMA]STATITM = "REP"
#                  Endif

                   If !clalev ([ZTRD]) : Local File TABSRHTYP [ZTRD] : Endif
                   Read [ZTRD]TRE0 = RETTYP;''
                   If fstat = 0
                    [F:ZXMA]STATITM = [F:ZTRD]YSTATITM
                   Endif
                  Rewrite [ZXMA]
                  Commit
				#encontramos MAC, rellenamos la tabla YHISSTAMAC
				If !clalev ([YHSM]) : Local File YHISSTAMAC [YHSM] : Endif
                #añadimos los datos a la tabla
                  Read [YHSM]YHSM0(1)= [ZMAC]MACNUM
                  Read [YHSM] Last
                  [YHSM]LINNUM +=1000
                  [YHSM]BPRNUM = "Redislogar"
                  [YHSM]YCAMSTADAT = date$
                  [YHSM]MACNUM = [ZMAC]MACNUM
				  [YHSM]STATITM = [ZXMA]STATITM
                #grabamos la tabla
                  Trbegin [YHSM]
                  Write [YHSM]
                  If fstat
                    Rollback
                  Else
                    Commit
                  Endif

              Endif
                  Unlock [ZXMA]
                Else
                  Rollback
                Endif

            Else
              #error, damos mensaje diciendo que el articulo no tiene numero de serie
              ERRORNUMSER = 1
            Endif
          Endif
        Endif
      Next
      Filter[STJ]
    Next
    Filter [SRD]
    If ERRORNUMSER = 1
      #mostramnos el mensaje
      GERR = 2
      GMESSAGE = "Algún articulo no tiene numero de serie y no se pudo añadir histórico de parque" : Return
    Endif
  Endif
GPE=1
Return
######################################################################################
## YA034 - Tipo precio en Ventas
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
  Read [F:ZITM]ITM0 = VALEUR
  If fstat = 0
    [M:SRH1]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
    Affzo [M:SRH1]YTIPPRI(nolign -1)
  Endif

   Case [M:SRH1]YTIPPRI(nolign -1)
    When 1 : [M:SRH1]YGROPRI(nolign -1) = [M:SRH1]NETPRI(nolign -1)
    When 2 : [M:SRH1]YGROPRI(nolign -1) = [M:SRH1]NETPRI(nolign -1) * 10
    When 3 : [M:SRH1]YGROPRI(nolign -1) = [M:SRH1]NETPRI(nolign -1) * 100
    When 4 : [M:SRH1]YGROPRI(nolign -1) = [M:SRH1]NETPRI(nolign -1) * 1000
  Endcase
  Affzo [M:SRH1]YGROPRI(nolign -1)

End
######################################################################################




######################################################################################
## Etiqueta añadida por el supervisor (pantalla SRH1) 05/06/2019 16:46:43 (ADMIN)
######################################################################################
Subprog AM_YGROPRI(VALEUR)
Variable Decimal VALEUR
Variable Decimal PRECIO,GBIDD1

Local Char VAT (5)(0..2)
Local Char LVACBPR(5)

If !clalev([F:YBPC]) : Local File BPCUSTOMER [YBPC] : Endif
If !clalev([F:YITM]) : Local File ITMMASTER [YITM] : Endif
If !clalev([F:YTVC]) : Local File TABVAC [YTVC] : Endif

Local Decimal  GROPRI, MAJREM(0..8), NETPRI
  Case [M:SRH1]YTIPPRI(nolign -1)
    When 1 : PRECIO  = VALEUR
    When 2 : PRECIO  = VALEUR / 10
    When 3 : PRECIO  = VALEUR / 100
    When 4 : PRECIO  = VALEUR / 1000
  Endcase

  # Actualizamos el campo standard
  [M:SRH1]NETPRI(nolign -1) = PRECIO
  [M:SRH1]NETPRINOT(nolign -1) = PRECIO
  GROPRI=PRECIO
  Read [F:YBPC]BPC0=[M:SRH0]BPCORD
  If !fstat
    LVACBPR=[F:YBPC]VACBPR
    PRITYP=[F:YBPC]PRITYP
  Endif
  Read [F:YITM]ITM0=[M:SRH1]ITMREF
  If !fstat
    Read [F:YTVC]TVC1=LVACBPR;[F:YITM]VACITM
    If !fstat
      VAT(0)=[F:YTVC]VAT
    Endif
  Endif

Call CLCTAXEPRIV(PRECIO,VAT,PRITYP,GSOCIETE,[M:SRH0]ENTRTNDAT ,[M:SRH1]QTY,LVACBPR,PRECIO,PRECIO,
&                          GBIDD1) From TRTX3
  [M:SRH1]NETPRIATI(nolign -1) = GBIDD1
  Affzo [M:SRH1]NETPRI(nolign -1)
  Affzo [M:SRH1]NETPRINOT(nolign -1)
  Affzo [M:SRH1]NETPRIATI(nolign -1)

End


######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SRH1) 06/06/2019 18:27:28 (LIVDV)
######################################################################################
Subprog AM_NETPRI(VALEUR)
Variable Decimal VALEUR
End


