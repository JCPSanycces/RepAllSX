#<AdxTL>@(#)2.0.0.0 $Revision$
#ACV#X12
#TIT#ClûÇture en lot des DI

#===============================================================================
# Gestion de l'objet   : ClûÇture en lot des DI
#
# Auteur               : CGUES
# Date de crûˋation     : 26/02/01
#===============================================================================
# Modifications significatives
#-------------------------------------------------------------------------------
# Date          Auteur       Description
#-------------------------------------------------------------------------------
# 21/02/2002    OTHYR        Plus de bornes sur site (case a cocher pour tout site ou un seul)
#                            DS 35180 + 35027
# ------------------------------------------------------------------------------
# 30/08/2002    FMUYS        Modûˋlisation Web
#===============================================================================

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$ACTION
#--- Actions liûˋes au scûˋnario GTRAITE
Case ACTION
    When "INIT"       : Gosub INIT
    When "AVANT_PAR"  : Gosub AVANT_PAR
    When "CONTROLE"   : Gosub CONTROLE
    When "EXEC"       : Gosub EXEC
    When "TERMINE"    : Gosub TERMINE
    When "OK"         : Gosub A_OK
    When "END"        : Gosub A_END
    When "DEBUT"      : Gosub A_DEBUT
    When Default
Endcase
Return

################################################################################
$INIT
If [V]GSERVEUR
    Onerrgo ERR_BATCH
Endif
Gosub OUVRE
Return

################################################################################
$OUVRE
Local Integer OK
Local Char TIT(100)
Local Char CRITERE1(200)
Local Char CRITERE2(200)
Local Char CRITERE3(250)
Local Char SPECRITERE(200) :#Reservûˋ client
Local Char ACTION
Local Integer AUZFCY

Local Integer ESS
Local Integer FLG_TSSITE

If !clalev([F:REQ]) : Local File REQUEST [REQ] : Endif

Local Mask CLOREQ [DIA]

TIT=mess(8,[V]GXMSGPSA,1)
Return

################################################################################
$AVANT_PAR
Return

################################################################################
$CONTROLE
If [V]GOK<1
    FIN = 1
Else
    TMP = 1
    If [M:DIA]TSSITE <> 2 & [M:DIA]FCYBEG = "" Then
        GERR = 1
        GMESSAGE = mess(165,[V]GXMSGPSA,1)
    Endif
Endif
Return

################################################################################
$EXEC
Gosub OUV_TRACE
Gosub VERROU
If [L]OK = 1 Then
    Return
Endif

Gosub CLOLOTREQ

Gosub DEVERROU
Return

################################################################################
$TERMINE
If ![V]GSERVEUR
    Call FERME_TRACE From LECFIC
    TRA=1
Endif
Return

################################################################################
$A_OK
FIN=1
[V]GOK=1
Return

################################################################################
$A_END
FIN=1
[V]GOK=0
Return

################################################################################
$A_DEBUT
Affzo [M:DIA]
Return

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$ERR_BATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
GERR=1
End

################################################################################
$CLOLOTREQ

Gosub FILTRE

Call TEMPON(mess(204,[V]GXMSGPSA,1)) From GESECRAN

Close Local Mask [DIA]

Filter [REQ] Where [F:REQ]FLGREQCLO <> 2 & [F:REQ]FLGREQCAN <> 2
&            &      evalue([L]CRITERE1) & evalue([L]CRITERE2) & evalue([L]CRITERE3) & evalue([L]SPECRITERE)

For [REQ]REQ7
    If FLG_TSSITE = 2 Then
        Call CTL_AUZFCY([F:REQ]FCY,"GESREQ","V",[L]AUZFCY) From XTRTFCY
        If [L]AUZFCY = 0 Then
            Goto SUIV_REQ
        Endif
    Endif
    [L]OK=1
    #Verif si cloture possible
    Call VERIF_CLOTURE([F:REQ]REQNUM,[L]OK) From SPVOBJREQ
    GPOINT="F_VERIF_CLO" : Gosub ENTREE From EXEFNC
    If [L]OK=1
        [V]GOK = 1
        [L]OK  = 3

        Call CLOREQ(2,[F:REQ]REQNUM,[L]OK) From SPVOBJREQ3 #FMUYS le 30/08/02

        If [V]GOK = 1 Then
            Call ECR_TRACE(mess(202,[V]GXMSGPSA,1)-[F:REQ]REQNUM,0) From GESECRAN
        Else
            Call ECR_TRACE(mess(203,[V]GXMSGPSA,1)-[F:REQ]REQNUM,1) From GESECRAN
        Endif
    Elsif [L]OK=0
            Call ECR_TRACE([F:REQ]REQNUM-[V]GMESSAGE,1) From GESECRAN
    Elsif [L]OK=-1
            Call ECR_TRACE([F:REQ]REQNUM-[V]GMESSAGE,-1) From GESECRAN
    Endif

$SUIV_REQ
Next

Filter [REQ]

# LBORN 17/08/2010 - Gûˋnûˋration des documents en direct / GIDENT
Call GENDOC_DIR From XVALGAS2

Call TEMPOFF From GESECRAN
Call LEC_TRACE From LECFIC

Close Local File [REQ]

Return

################################################################################
$FILTRE

[L]CRITERE1="1"
[L]CRITERE2="1"
[L]CRITERE3="1"
[L]SPECRITERE="1"


If [M:DIA]TSSITE=2 Then
    FLG_TSSITE=2
Else
    FLG_TSSITE=1
    If [M:DIA]FCYBEG<>""
        [L]CRITERE1-="& [F:REQ]FCY='"+[M:DIA]FCYBEG+"'"
    Endif
Endif


If [M:DIA]QUEUEDEB<>""
    [L]CRITERE1-="& [F:REQ]QUEUE>='"+[M:DIA]QUEUEDEB+"'"
Endif
If [M:DIA]QUEUEFIN<>""
    [L]CRITERE1-="& [F:REQ]QUEUE<='"+[M:DIA]QUEUEFIN+"'"
Endif

If [M:DIA]CREADATDEB<>[0/0/0]
    [L]CRITERE1-="& [F:REQ]CREADAT>=["+right$([M:DIA]CREADATDEB,7)+"/"+mid$([M:DIA]CREADATDEB,5,2)+"/"+left$([M:DIA]CREADATDEB,4)+"]"
Endif
If [M:DIA]CREADATFIN<>[0/0/0]
    [L]CRITERE1-="& [F:REQ]CREADAT<=["+right$([M:DIA]CREADATFIN,7)+"/"+mid$([M:DIA]CREADATFIN,5,2)+"/"+left$([M:DIA]CREADATFIN,4)+"]"
Endif

If [M:DIA]BPCINVBEG<>""
    [L]CRITERE1-="& [F:REQ]BPCINV>='"+[M:DIA]BPCINVBEG+"'"
Endif
If [M:DIA]BPCINVEND<>""
    [L]CRITERE1-="& [F:REQ]BPCINV<='"+[M:DIA]BPCINVEND+"'"
Endif

If [M:DIA]REQNUMBEG<>""
    [L]CRITERE1-="& [F:REQ]REQNUM>='"+[M:DIA]REQNUMBEG+"'"
Endif
If [M:DIA]REQNUMEND<>""
    [L]CRITERE1-="& [F:REQ]REQNUM<='"+[M:DIA]REQNUMEND+"'"
Endif

If [M:DIA]REQTYPDEB<>""
    [L]CRITERE2-="& [F:REQ]REQTYP>='"+[M:DIA]REQTYPDEB+"'"
Endif
If [M:DIA]REQTYPFIN<>""
    [L]CRITERE2-="& [F:REQ]REQTYP<='"+[M:DIA]REQTYPFIN+"'"
Endif

If [M:DIA]OPPNUMBEG<>""
    [L]CRITERE2-="& [F:REQ]OPPNUM>='"+[M:DIA]OPPNUMBEG+"'"
Endif
If [M:DIA]OPPNUMEND<>""
    [L]CRITERE2-="& [F:REQ]OPPNUM<='"+[M:DIA]OPPNUMEND+"'"
Endif

# LBORN 22/02/2011
# Test si module X15 actif
If [V]GXOPTCON
  If [M:DIA]CONNUMBEG<>""
    [L]CRITERE2-="& [F:REQ]CONREV>='"+[M:DIA]CONNUMBEG+"'"
  Endif
  If [M:DIA]CONNUMEND<>""
    [L]CRITERE2-="& [F:REQ]CONREV<='"+[M:DIA]CONNUMEND+"'"
  Endif
Endif

If [M:DIA]LOTPJTBEG<>""
    [L]CRITERE3-="& [F:REQ]LOTPJT>='"+[M:DIA]LOTPJTBEG+"'"
Endif
If [M:DIA]LOTPJTEND<>""
    [L]CRITERE3-="& [F:REQ]LOTPJT<='"+[M:DIA]LOTPJTEND+"'"
Endif

#ajout des critere du cllient
GPOINT="F_VALLOT" : Gosub ENTREE From EXEFNC

Return

################################################################################
$VERROU

# Positionnement d'un verrou sur l'entûˆte commande

SYMBOLE = "XTRTVALREQ/"+[M:DIA]FCYBEG
#+"/"+[M:DIA]FCYEND
Lock = SYMBOLE With lockwait = 0
OK=2
If fstat
    Call ECR_TRACE(mess(30,100,1),1) From GESECRAN
    OK=1
Endif
Return

################################################################################
$DEVERROU

# Suppression du verrou

Unlock=SYMBOLE
Return

################################################################################
$OUV_TRACE

#-------------------------------------------------------------------------------
# Ouverture du fichier Trace
#-------------------------------------------------------------------------------
If !GSERVEUR
   Call OUVRE_TRACE(TIT) From LECFIC
Endif

# Ecriture des critû´res de lancements
Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call PRTSCR("CLOREQ","DIA","",0,1) From ATRTX3
Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Return


################################################################################
################################################################################
################################################################################
################################################################################

########################################
Subprog AV_TSSITE(VALEUR)
Variable Integer  VALEUR

Call AP_TSSITE(VALEUR)
End

########################################
Subprog AP_TSSITE(VALEUR)
Variable Integer  VALEUR

If VALEUR=2 Then
    Effzo [M]FCYBEG
    Diszo [M]FCYBEG
Else
    Actzo [M]FCYBEG
Endif
End

########################################
Subprog D_FCYBEG(VALEUR)
Variable Char     VALEUR
If [M]TSSITE<>2 Then
  VALEUR=GUSRFCY
Endif
End

########################################
Subprog C_FCYBEG(VALEUR)
Variable Char     VALEUR
If [M]TSSITE<>2 & VALEUR="" Then
    mkstat=2
Endif
End

########################################
Subprog AV_CREADATFIN(VALEUR)
Variable Date     VALEUR

VALEUR=[M]CREADATDEB
End
