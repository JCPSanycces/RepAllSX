####################################################################################
# Program Name: ZUPDTEMPLATE
# Description : YA007 - Create Template File
# Author      : GT NDEV
# Date        : Jul 4th, 2018
####################################################################################

Local Char ZSOHNUM(20) : ZSOHNUM = "SONAO0110032"
Local Integer ZSOPLIN
Local Integer ZQTY
Local Char ZPOHNUM(20) : ZPOHNUM = "POHNUM1"
Local Integer ZPOPLIN : ZPOPLIN = 2000
Local Char ZPATH(250) : ZPATH = ""
Local Integer ZMAXSOPLIN : ZMAXSOPLIN = 1000
Local Decimal ZQTYCOUNT : ZQTYCOUNT = 9
Call ZCREATETEMPLATE(ZSOHNUM,ZSOPLIN,ZQTY,ZPOHNUM,ZPOPLIN,ZPATH,ZMAXSOPLIN,ZQTYCOUNT)
End

#####################################################################################################
Subprog ZCREATETEMPLATE(ZSOHNUM,ZSOPLIN,ZQTY,ZPOHNUM,ZPOPLIN,ZPATH,ZLINCLOSED,ZQTYCOUNT,ZCREHEADER)
Value Char ZSOHNUM
Value Integer ZSOPLIN
Value Decimal ZQTY
Value Char ZPOHNUM
Value Integer ZPOPLIN
Variable Char ZPATH
Variable Integer ZLINCLOSED
Variable Decimal ZQTYCOUNT
Variable Integer ZCREHEADER

If !clalev([F:ZSQ1]) : Local File SORDERQ [F:ZSQ1] : Endif
# <GON:JUL19>
If !clalev([F:YSOP]) : Local File SORDERP [F:YSOP] : Endif
# </GON>
Local Char PATH1(250)
Local Char PATH2(250)
Local Integer I
Local Char URL
Local Char HEADER(255) : HEADER = ""
Local Char DETAIL(255)
Local Integer ZSOQOPENEDHERE : ZSOQOPENEDHERE = 0
Local Char ZPRD : ZPRD = ""
Local Integer ZFLG1 : ZFLG1 = 0

If ZPATH = ""
 #ZCREHEADER = 1
 Call SET_FICNAM(PATH1,PATH2,URL) From ORDSYS
 ZFLG1 = 1
Else
 #ZCREHEADER = 0
 ZFLG1 = 0
 PATH2 = ZPATH
Endif

Openo PATH2 Using [FACS]
adxifs = "" : adxirs = chr$(13) + chr$(10)

If ZCREHEADER = 1
 ZPATH = PATH2
 HEADER  += "E"
 HEADER += ";" + ZSOHNUM
 Wrseq HEADER  Using [FACS]
 Raz HEADER
Endif

For [F:ZSQ1] Where [F:ZSQ1]SOHNUM = ZSOHNUM and [F:ZSQ1]SOPLIN = ZSOPLIN
  Read [F:YSOP]SOP0 = [F:ZSQ1]SOHNUM; [F:ZSQ1]SOPLIN; [F:ZSQ1]SOQSEQ
  If !fstat
   ZPRD = [F:ZSQ1]ITMREF
   If ([F:ZSQ1]DLVQTY + [F:ZSQ1]ODLQTY) <> 0 and ZLINCLOSED =0
    DETAIL = ""
    DETAIL += "L"
    DETAIL += ";" + ZPRD
    DETAIL += ";" + num$([F:ZSQ1]QTY)
    DETAIL += ";" + num$([F:YSOP]YGROPRI)
    DETAIL += ";" + num$(ZSOPLIN)
    DETAIL += ";"
    DETAIL += ";0"
    DETAIL += ";3"
    Wrseq DETAIL Using [FACS]
    Raz DETAIL
    ZARLNLIST(ZARLNLISTCNT) = ZSOHNUM+ "|"+num$(ZSOPLIN) : ZARLNLISTCNT = ZARLNLISTCNT + 1
    ZFLG1 = 0
    ZLINCLOSED = 1
   Endif
  Endif
Next

DETAIL = ""
DETAIL += "L"
DETAIL += ";" + ZPRD
DETAIL += ";" + num$(ZQTY)
DETAIL += ";" + num$([F:YSOP]YGROPRI)
Call ZGETNXTSOLIN(ZSOHNUM,ZSOPLIN)
DETAIL += ";" + num$(ZSOPLIN)
DETAIL += ";" + ZPOHNUM #+ "|X"
DETAIL += ";" + num$(ZPOPLIN)
DETAIL += ";1"
ZQTYCOUNT+=ZQTY
Wrseq DETAIL Using [FACS]
Raz DETAIL

Openo Using [FACS]
Close File [F:ZSQ1]
End

#####################################################################################################
Subprog ZGETNXTSOLIN(ZSOHNUM,ZSOPLIN)
Value Char ZSOHNUM
Variable Integer ZSOPLIN

Local Integer ZSOLINITER : ZSOLINITER = 1000
Local Char REQUETE(250)
Local Char ZSNM(250)

ZSNM = ZSOHNUM+ "|"+num$(ZSOPLIN)

If find("",ZARLNLIST) = 1
 ZARLNLIST(ZARLNLISTCNT) = ZSNM : ZARLNLISTCNT = ZARLNLISTCNT + 1
Else
 If find(ZSNM,ZARLNLIST)>0
  ZSOPLIN = 0
  While ZSOPLIN = 0
   REQUETE = " select MAX(SOPLIN_0) + " + num$(ZSOLINITER) + " from "
&   + nomap + ".SORDERQ where SOHNUM_0 = '" + ZSOHNUM + "' "
   For (Integer ZNEWLIN) From "5" Sql REQUETE As [ZNEWLIN]
    ZSOPLIN = ZNEWLIN
   Next
   ZSNM = ZSOHNUM+ "|"+num$(ZSOPLIN)
   If find(ZSNM,ZARLNLIST) > 0 : ZSOPLIN = 0 : ZSOLINITER = ZSOLINITER +1000 : Endif
  Wend
#  If (ZSAMELNFLG = 0): ZARLNLIST(ZARLNLISTCNT) = ZSOPLIN : ZARLNLISTCNT = ZARLNLISTCNT + 1: Endif
 Endif
 ZARLNLIST(ZARLNLISTCNT) = ZSNM : ZARLNLISTCNT = ZARLNLISTCNT + 1
Endif
End
#####################################################################################################

