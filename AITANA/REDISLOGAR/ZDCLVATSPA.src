#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
# especifico que se ejecuta antes de la resincronización

Case ACTION
 When "BEFWRIDVSsss" : Gosub UPDATE_DATOS_FACTURA : # Actualiza los datos de factura

 When Default
Endcase
Return
#################################################################################################


$UPDATE_DATOS_FACTURA
    If [F:DVS]TAXTYP = 'R' Then
      If dim([F:SIH]BPRVCR)>0  and [F:SIH]BPRVCR <> [F:DVS]BPRVCR  Then
         [F:DVS]BPRVCR =[F:SIH]BPRVCR
      Endif
      # Solicitado por Guillermo EY 13/06/2019.
      If [F:SIH]SIVTYP = 'ADI' or [F:SIH]SIVTYP = 'ABP' Then
        [F:DVS]INVNUM = [F:SIH]BPRVCR
        [F:DVS]INVNUMDAT = [F:SIH]BPRDAT
      Endif
   Elsif [F:DVS]TAXTYP = 'S' Then
     If dim([F:PIH]BPRVCR) > 0  and [F:PIH]BPRVCR <> [F:DVS]BPRVCR Then
      [F:DVS]BPRVCR =[F:PIH]BPRVCR
      # [F:X025SI]BPRVCR = [F:SIH]BPRVCR
    Endif
  Endif




Return

