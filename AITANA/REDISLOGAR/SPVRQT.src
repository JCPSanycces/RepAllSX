#<AdxTL>@(#)3.0.0.0 $Revision:   1.20  $ Gestion du masque MCT0
#ACV#X12
#TIT#Gestion du paramétrage des transaction de saisie des DS

##############################################
$ACTION

# Appel fonctions complémentaires GFI pour l'objet RQT
Gosub ACTION From XOBJSPE
If GPE=1 : GPE = 0 : Return : Endif

Case ACTION
  When "OUVRE"      : Gosub OUVRE       From SPVOBJRQT   
  When "RAZCRE"     : Gosub RAZCRE      From SPVOBJRQT
  When "INICRE"     : Gosub INICRE      From SPVOBJRQT
                      Gosub INI_CRE_MOD From XTRPSA
  When "INIMOD"     : Gosub INIMOD      From SPVOBJRQT      
                      Gosub INI_CRE_MOD From XTRPSA
  When "CREATION"   : Gosub CREATION    From SPVOBJRQT
  When "MODIF"      : Gosub MODIF       From SPVOBJRQT
  When "ANNULE"     : Gosub ANNULE      From SPVOBJRQT 
                      Gosub ANNULE      From XTRPSA  
  When "LIENS"      : Gosub LIENS       From SPVOBJRQT 
  When "SETBOUT"    : Gosub SETBOUT     From XTRPSA   
  When "EXEBOUT"    : Gosub EXEBOUT     From XTRPSA
  When "FILTRE"     : Gosub FILTRE      From SPVOBJRQT 
  When "CHANGE"     : Gosub CHANGE      From XTRPSA
  When "AJOUT_ZONE" : Gosub AJOUT_ZONE  From SPVOBJRQT   

  When Default
Endcase

Return

