## Etiquette ajoutée par le superviseur (écran RQT7) 03/05/2006 11:25:19 (FMUYS)
################################################################################

########################################
Subprog IB_NBRQT7E
Gosub IB_NBRQT7
End

########################################
Subprog B3_NBRQT7E
Local Char    XNIV : XNIV="E"
Local Integer XVAL : XVAL=2
Gosub BX_NBRQT7
End

########################################
Subprog B4_NBRQT7E
Local Char    XNIV : XNIV="E"
Local Integer XVAL : XVAL=1
Gosub BX_NBRQT7
End

########################################
Subprog IB_NBRQT7L
Gosub IB_NBRQT7
End

########################################
Subprog B3_NBRQT7L
Local Char    XNIV : XNIV="L"
Local Integer XVAL : XVAL=2
Gosub BX_NBRQT7
End

########################################
Subprog B4_NBRQT7L
Local Char    XNIV : XNIV="L"
Local Integer XVAL : XVAL=1
Gosub BX_NBRQT7
End

$IB_NBRQT7
GBOUT3=mess(2,1,1)
GBOUT4=mess(1,1,1)
Return

$BX_NBRQT7
Local Integer II, JJ
JJ=evalue("[M]NBRQT7"+XNIV)-1
For II=nolign-1 To JJ : Assign "[M]R"+XNIV+"ZONAFF(II)" With XVAL : Next
If !GIMPORT Then Affzo [M:RQT7] Endif
mkstat=4
Return

######################################################################################
Subprog AV_RMACNUM(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=1 : Endif
End
