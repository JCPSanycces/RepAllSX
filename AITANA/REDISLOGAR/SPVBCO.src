#<AdxTL>@(#)5.0.0.0 $Revision:   1.12  $ Gestion du masque BCO2
#ACV#X11
#TIT#Gestion des Codes de base

GBIDC1=""
GBIDC2=""

Call OBJET("BCO",GBIDC1,GBIDC2) From GOBJET
End

$ACTION

Gosub ACTION From SPVOBJBCO

Return

########################################
# Ecran BCO1
########################################

Subprog AS_NBHOUR(VALEUR)
Variable Decimal VALEUR
If [M:BCO1]MAXEXT=1 | [M:BCO1]NBDAY<>0: mkstat=1: Endif
End


########################################
Subprog C_MAINCAT(VALEUR)
Variable Char    VALEUR()

Call UNICITE(VALEUR,[M:BCO1]MAINCAT)From OBJDIV
End

########################################
# Ecran BCO2
########################################
Subprog C_CODOPE(VALEUR)
Variable Char    VALEUR()

Local Integer I,POS
[L]POS=nolign-1

For I=0 To [M:BCO2]NBLIG-1
    If [M:BCO2]CODOPE(I)=VALEUR & [L]POS<>I
        If ([M:BCO2]DATBEGOPC([L]POS)<=[M:BCO2]DATBEGOPC(I) & [M:BCO2]DATENDOPC([L]POS)>=[M:BCO2]DATBEGOPC(I))
&    | ([M:BCO2]DATBEGOPC([L]POS)>=[M:BCO2]DATBEGOPC(I) & [M:BCO2]DATENDOPC([L]POS)<=[M:BCO2]DATENDOPC(I))
&    | ([M:BCO2]DATBEGOPC([L]POS)<=[M:BCO2]DATENDOPC(I) & [M:BCO2]DATENDOPC([L]POS)>=[M:BCO2]DATENDOPC(I))

            mkstat=2
            Break 1
        Endif
    Endif
Next I

End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()

Local Integer I,POS
[L]POS=nolign-1

For I=0 To [M:BCO2]NBLIGITM-1
    If [M:BCO2]ITMREF(I)=VALEUR & [L]POS<>I
        If ([M:BCO2]DATBEGITM([L]POS)<=[M:BCO2]DATBEGITM(I) & [M:BCO2]DATENDITM([L]POS)>=[M:BCO2]DATBEGITM(I))
&    | ([M:BCO2]DATBEGITM([L]POS)>=[M:BCO2]DATBEGITM(I) & [M:BCO2]DATENDITM([L]POS)<=[M:BCO2]DATENDITM(I))
&    | ([M:BCO2]DATBEGITM([L]POS)<=[M:BCO2]DATENDITM(I) & [M:BCO2]DATENDITM([L]POS)>=[M:BCO2]DATENDITM(I))

            mkstat=2
            Break 1
        Endif
    Endif
Next I

End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Char DES, UNITE

Call INIT_ITM(VALEUR, DES, UNITE,"a") From X11TRTDIV
[M:BCO2]UOM(nolign-1) = UNITE
If !GIMPORT 
    Affzo [M:BCO2]UOM(nolign-1)
Endif
End
########################################
# Ecran BCO3
########################################
Subprog C_CODOPEA(VALEUR)
Variable Char    VALEUR()

Local Integer I,POS
[L]POS=nolign-1

For I=0 To [M:BCO3]NBLIGA-1
    If [M:BCO3]CODOPEA(I)=VALEUR & [L]POS<>I
        If ([M:BCO3]DATBEGOPCA([L]POS)<=[M:BCO3]DATBEGOPCA(I) & [M:BCO3]DATENDOPCA([L]POS)>=[M:BCO3]DATBEGOPCA(I))
&    | ([M:BCO3]DATBEGOPCA([L]POS)>=[M:BCO3]DATBEGOPCA(I) & [M:BCO3]DATENDOPCA([L]POS)<=[M:BCO3]DATENDOPCA(I))
&    | ([M:BCO3]DATBEGOPCA([L]POS)<=[M:BCO3]DATENDOPCA(I) & [M:BCO3]DATENDOPCA([L]POS)>=[M:BCO3]DATENDOPCA(I))

            mkstat=2
            Break 1
        Endif
    Endif
Next I

End

########################################
Subprog C_ITMREFA(VALEUR)
Variable Char    VALEUR()

Local Integer I,POS
[L]POS=nolign-1

For I=0 To [M:BCO3]NBLIGITMA-1
    If [M:BCO3]ITMREFA(I)=VALEUR & [L]POS<>I
        If ([M:BCO3]DATBEGITMA([L]POS)<=[M:BCO3]DATBEGITMA(I) & [M:BCO3]DATENDITMA([L]POS)>=[M:BCO3]DATBEGITMA(I))
&    | ([M:BCO3]DATBEGITMA([L]POS)>=[M:BCO3]DATBEGITMA(I) & [M:BCO3]DATENDITMA([L]POS)<=[M:BCO3]DATENDITMA(I))
&    | ([M:BCO3]DATBEGITMA([L]POS)<=[M:BCO3]DATENDITMA(I) & [M:BCO3]DATENDITMA([L]POS)>=[M:BCO3]DATENDITMA(I))

            mkstat=2
            Break 1
        Endif
    Endif
Next I
End

########################################
Subprog AM_ITMREFA(VALEUR)
Variable Char    VALEUR()

Local Char DES, UNITE

Call INIT_ITM(VALEUR, DES, UNITE,"a") From X11TRTDIV
[M:BCO3]UOMA(nolign-1) = UNITE
If !GIMPORT 
    Affzo [M:BCO2]UOM(nolign-1)
Endif
End

######################################################################################
Subprog IB_NBITM
If nolign<=[M:BCO4]NBITM | [M:BCO4]ITMREF(nolign-1)<>""
  Raz [V]GBOUT5
Else
  [V]GBOUT5=mess(1,[V]GXMSGSAV,1)
Endif

If [M:BCO4]ITMREF(nolign-1)=""
  Raz [V]GBOUT6,[V]GBOUT7
Else
  [V]GBOUT6=mess(5,[V]GXMSGSAV,1)-mess(1,1944,1)
  [V]GBOUT7=mess(5,[V]GXMSGSAV,1)-mess(2,1944,1)
Endif

End

######################################################################################
Subprog B6_NBITM
Local Integer I
For [L]I=0 To max(nolign,[M:BCO4]NBITM)-1
  If [M:BCO4]INCLUD([L]I)<>1
    [M:BCO4]INCLUD([L]I)=1
    Affzo [M:BCO4]INCLUD([L]I)
    mkstat=4
  Endif
Next
End

######################################################################################
Subprog B7_NBITM
Local Integer I
For [L]I=0 To max(nolign,[M:BCO4]NBITM)-1
  If [M:BCO4]INCLUD([L]I)<>2
    [M:BCO4]INCLUD([L]I)=2
    Affzo [M:BCO4]INCLUD([L]I)
    mkstat=4
  Endif
Next
End
