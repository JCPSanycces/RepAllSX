Local Char PARAM(30)(2)

Call GCONSULT("VGS","",PARAM)From GCONSULT
End


###################################################################
$ACTION

Gosub ACTION From XCNSVGSSPV

Return


#----------------------------------------------------------------------#
# Gestion du programme d'éclatement par TRT_Divers (Action TRTVGSDET)  #
#----------------------------------------------------------------------#
###################################################################
Subprog DETAIL(LIGNE,RGP,FLGVISA)
Value Integer LIGNE
Value Char RGP
Value Integer FLGVISA

Local Integer I,LIGDEB
[L]LIGDEB = [L]LIGNE-1

If [M:VGS1]FLGRGP([L]LIGNE-1) <> 2 Then
    For I=0 To [M:XVGS]NBLIG-1
        If [M:XVGS]RGPVISA(I) = [L]RGP Then
            Insa [L]LIGNE [M:VGS1]NBLIG

            [M:VGS1]FLGRGP([L]LIGNE)    = 2
            [M:VGS1]OPPNUM([L]LIGNE)    = [M:XVGS]OPPNUM(I)
            [M:VGS1]UOM([L]LIGNE)       = [M:XVGS]UOM(I)
            [M:VGS1]IUSCOD([L]LIGNE)    = [M:XVGS]IUSCOD(I)
            [M:VGS1]CODOPE([L]LIGNE)    = [M:XVGS]CODOPE(I)
            [M:VGS1]REQNUM([L]LIGNE)    = [M:XVGS]REQNUM(I)
            [M:VGS1]REQSUM([L]LIGNE)    = [M:XVGS]REQSUM(I)
            [M:VGS1]ITVTYP([L]LIGNE)    = [M:XVGS]ITVTYP(I)
            [M:VGS1]CONREV([L]LIGNE)    = [M:XVGS]CONREV(I)
            [M:VGS1]FLGVISA([L]LIGNE)   = [L]FLGVISA
            [M:VGS1]RGPVISA([L]LIGNE)   = [M:XVGS]RGPVISA(I)
            [M:VGS1]QTY([L]LIGNE)       = [M:XVGS]QTY(I)
            [M:VGS1]DUREE([L]LIGNE)     = [M:XVGS]DUREE(I)
            [M:VGS1]ITLNUM([L]LIGNE)    = [M:XVGS]ITLNUM(I)
            [M:VGS1]LIGITL([L]LIGNE)    = [M:XVGS]LIGITL(I)
            [M:VGS1]DATITV([L]LIGNE)    = [M:XVGS]DATITV(I)
            [M:VGS1]DES([L]LIGNE)       = [M:XVGS]DES(I)
            [M:VGS1]CUR([L]LIGNE)       = [M:XVGS]CUR(I)
            [M:VGS1]UNTPRI([L]LIGNE)    = [M:XVGS]UNTPRI(I)
            [M:VGS1]CURPUR([L]LIGNE)    = [M:XVGS]CURPUR(I)
            [M:VGS1]PRIPUR([L]LIGNE)    = [M:XVGS]PRIPUR(I)
            [M:VGS1]UNTPRITOT([L]LIGNE) = [M:XVGS]UNTPRITOT(I)
            [M:VGS1]PRIPURTOT([L]LIGNE) = [M:XVGS]PRIPURTOT(I)
            [M:VGS1]TPSAVA([L]LIGNE)    = [M:VGS1]TPSAVA([L]LIGDEB)
            [M:VGS1]CODWRK([L]LIGNE)    = [M:XVGS]CODWRK(I)
            [M:VGS1]WCHRONO([L]LIGNE)   = [M:XVGS]WCHRONO(I)

            # LBORN 16/01/2014
            [M:VGS1]TPSSAI([L]LIGNE)    = [M:XVGS]TPSSAI(I)
            [M:VGS1]TPSVER([L]LIGNE)    = [M:XVGS]TPSVER(I)
            [M:VGS1]TPSHIE([L]LIGNE)    = [M:XVGS]TPSHIE(I)
            [M:VGS1]TPSPJT([L]LIGNE)    = [M:XVGS]TPSPJT(I)
            [M:VGS1]TPSVAL([L]LIGNE)    = [M:XVGS]TPSVAL(I)

            GPOINT="LECTURE4" : Gosub ENTREE From EXEFNC
            [L]LIGNE += 1
            [M:VGS1]NBLIG += 1

        Endif
    Next I

    Dela [L]LIGDEB [M:VGS1]NBLIG
    [M:VGS1]NBLIG -= 1
Endif

# LBORN 13/11/2013 - Mantis 22238
Call AS_NBLIG From W1CONSVGS1

Affzo [M:VGS1]

End


#----------------------------------------------------------------------#
# Gestion du programme de validation par TRT_Divers (Action TRTVGSVAL) #
#----------------------------------------------------------------------#
###################################################################
Subprog VALVGS

Local Char NUMCRA, XSYMBITL, XTIT, XTRACE
Local Integer LIGCRA, RANG, RANG1

If !clalev([F:XITL]) : Local File ITVLOTD [XITL] : Endif

If [M:VGS1]NBLIG = 0 Then
    End
Endif

# Ouverture trace
If [M:VGS0]TRTVISA = 1 Then
    [L]XTIT = mess(1,1773,1)        :# Donner Visa
Else
    [L]XTIT = mess(2,1773,1)        :# Oter   Visa
Endif

If !GSERVEUR Then
    Call OUVRE_TRACE([L]XTIT) From LECFIC
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE([L]XTIT,0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
Endif

Call TEMPON("E") From GESECRAN

# Il faut distinguer le cas regroupé et non regroupé
For I = 0  To [M:VGS1]NBLIG-1

    # Si on est en train de "Viser", alors mettre dans table les valeurs des flags de l'écran
    # Par contre, si on est en train de "Déviser", alors mettre l'inverse :
    # Donner Visa <--> Si je flague oui, alors je donne un avis "favorable"
    # Oter Visa   <--> Si je flague oui, alors je veux déflaguer l'avis favorable que j'avais donné
    # Donc, il n'y a seulement qu'à la valeur Oui du flag que l'on s'interesse

    If [M:VGS1]FLGVISA(I)=2 | ([M:VGS1]TPSAVA(I)=2 & [M:VGS1]FLGVISA(I)<>3) Then : # Flag saisissable Oui / Non <--> A été "visé"
        # Detaillé
        If [M:VGS1]FLGRGP(I) = 2 Then             :# Flag Détail
            [L]NUMCRA = [M:VGS1]ITLNUM(I)
            [L]LIGCRA = [M:VGS1]LIGITL(I)
            Gosub RW_ITL
        Else
            [L]RANG  = 0
            [L]RANG1 = 0

            Raz [L]NUMCRA,[L]LIGCRA

            Repeat
                [L]RANG   = find([M:VGS1]RGPVISA(I),[M:XVGS]RGPVISA([L]RANG1..[M:XVGS]NBLIG-1))
                [L]RANG1 += [L]RANG

                If [L]RANG Then
                    [L]NUMCRA = [M:XVGS]ITLNUM([L]RANG1-1)
                    [L]LIGCRA = [M:XVGS]LIGITL([L]RANG1-1)
                    Gosub RW_ITL
                Endif
            Until ![L]RANG

        Endif


    Endif
Next

# LBORN 20/11/2013 - Mantis 22238
Gosub VALID_CRA
Gosub SIGN_CRA

Call TEMPOFF From GESECRAN

Raz   [M:VGS1]
Affzo [M:VGS1]

# Fermeture trace
If !GSERVEUR Then
    Call FERME_TRACE From LECFIC
    TRA = 1
Endif

# Lecture du fichier trace
Openo XTRACE
Call LEC_TRACE From LECFIC

End

###################################################################
$SIGN_CRA

If [M:VGS0]TRTVISA<>1 : Return : Endif

Local Char XREACOD, XACTSIG
Local Integer XREANUM, ZR

For I=0 To [M:VGS1]NBLIG-1
  If [M:VGS1]FLGVISA(I)>1
    If [M:VGS1]FLGRGP(I)=2 : # Flag Détail

      [L]XACTSIG=func DEF_OPERATION([M:VGS1]FLGVISA(I))

      If [M:VGS1]WREACOD(I)<>""
        [L]XREACOD=[M:VGS1]WREACOD(I)
      Else
        Raz [L]XREACOD
      Endif

      If [M:VGS1]WREANUM(I)<>0
        [L]XREANUM=[M:VGS1]WREANUM(I)
      Else
        Raz [L]XREANUM
        Read [F:AWF]AWF0=[M:VGS1]CODWRK(I)
        If !fstat
          [L]ZR=find([L]XREACOD,[F:AWF]OPESIG(0..[F:AWF]NBRSIG-1))
          If [L]ZR>0
            [L]XREANUM=[F:AWF]REANUM([L]ZR-1)
          Endif
        Endif
      Endif

      Call SIGNATURE([M:VGS1]ITLNUM(I),[M:VGS1]LIGITL(I),[M:VGS1]FLGVISA(I),[M:VGS1]WCHRONO(I)
&                   ,[L]XACTSIG,[L]XREANUM,[L]XREACOD) From XCNSVGSSPV

    Else
      Raz [L]RANG1
      Repeat
        [L]RANG   = find([M:VGS1]RGPVISA(I),[M:XVGS]RGPVISA([L]RANG1..[M:XVGS]NBLIG-1))
        [L]RANG1 += [L]RANG
        If [L]RANG

          [L]XACTSIG=func DEF_OPERATION([M:XVGS]FLGVISA([L]RANG1-1))

          If [M:XVGS]WREACOD([L]RANG1-1)<>""
            [L]XREACOD=[M:XVGS]WREACOD([L]RANG1-1)
          Else
            Raz [L]XREACOD
          Endif

          If [M:XVGS]WREANUM([L]RANG1-1)<>0
            [L]XREANUM=[M:XVGS]WREANUM([L]RANG1-1)
          Else
            Raz [L]XREANUM
            Read [F:AWF]AWF0=[M:XVGS]CODWRK([L]RANG1-1)
            If !fstat
              [L]ZR=find([L]XREACOD,[F:AWF]OPESIG(0..[F:AWF]NBRSIG-1))
              If [L]ZR>0
                [L]XREANUM=[F:AWF]REANUM([L]ZR-1)
              Endif
            Endif
          Endif

          Call SIGNATURE([M:XVGS]ITLNUM([L]RANG1-1),[M:XVGS]LIGITL([L]RANG1-1),[M:XVGS]FLGVISA([L]RANG1-1)
&                       ,[M:XVGS]WCHRONO([L]RANG1-1),[L]XACTSIG,[L]XREANUM,[L]XREACOD) From XCNSVGSSPV

        Endif
      Until ![L]RANG
    Endif
  Endif
Next

Return

###################################################################
$VALID_CRA

If [M:VGS0]TRTVISA<>1 : Return : Endif

Global Decimal XITLLIG(0..)
Global Integer XITLLNB, XNBCLE, XNBLCRA
Global Char    XLISTCLE(50)(0..), XLISTCRA(50)(0..)

Local Char XCLE(50)

Raz [V]XLISTCLE, [V]XNBCLE, [V]XLISTCRA, [V]XNBLCRA

For I=0 To [M:VGS1]NBLIG-1
  If [M:VGS1]TPSAVA(I)=2
    If [M:VGS1]FLGRGP(I)=2 : # Flag Détail
      [L]XCLE=[M:VGS1]ITLNUM(I)+"~"+num$([M:VGS1]LIGITL(I))
      If !find([L]XCLE,[V]XLISTCLE(0..[V]XNBCLE-1))
        [V]XLISTCLE([V]XNBCLE)=[L]XCLE
        [V]XNBCLE+=1
        If !find([M:VGS1]ITLNUM(I),[V]XLISTCRA(0..[V]XNBLCRA-1))
          [V]XLISTCRA([V]XNBLCRA)=[M:VGS1]ITLNUM(I)
          [V]XNBLCRA+=1
        Endif
      Endif
    Else
      Raz [L]RANG1
      Repeat
        [L]RANG   = find([M:VGS1]RGPVISA(I),[M:XVGS]RGPVISA([L]RANG1..[M:XVGS]NBLIG-1))
        [L]RANG1 += [L]RANG
        If [L]RANG
          [L]XCLE=[M:XVGS]ITLNUM([L]RANG1-1)+"~"+num$([M:XVGS]LIGITL([L]RANG1-1))
          If !find([L]XCLE,[V]XLISTCLE(0..[V]XNBCLE-1))
            [V]XLISTCLE([V]XNBCLE)=[L]XCLE
            [V]XNBCLE+=1
            If !find([M:XVGS]ITLNUM([L]RANG1-1),[V]XLISTCRA(0..[V]XNBLCRA-1))
              [V]XLISTCRA([V]XNBLCRA)=[M:XVGS]ITLNUM([L]RANG1-1)
              [V]XNBLCRA+=1
            Endif
          Endif
        Endif
      Until ![L]RANG
    Endif
  Endif
Next

Sorta [V]XNBCLE [V]XLISTCLE

If [V]XNBCLE
  Call B_VALID
Endif

Kill [V]XITLLIG,[V]XITLLNB,[V]XNBCLE,[V]XLISTCLE,[V]XLISTCRA,[V]XNBLCRA

Return

###################################################################
Subprog B_VALID
Local Char VALBOUT(250) , PARBOUT(250)(1..20), SVGACT
[L]SVGACT=GACTION
Raz PARBOUT
PARBOUT(1)= [M:VGS0]FCYDEF
PARBOUT(4)= "3"
GACTION = "TRTLOTCRA"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","XVALLOTCRA","XVALLOTCRA",4,"XYXVALLOTCRA") From GTRAITE
GACTION=[L]SVGACT
End

###################################################################
$RW_ITL

[L]XSYMBITL = "ITL"+[L]NUMCRA

Lock = [L]XSYMBITL With lockwait = 0
If fstat Then
    # Modification en cours sur un autre poste
    Call ECR_TRACE(mess(30,100,1)-"du C.R.A"-[L]NUMCRA,1) From GESECRAN
Else
    Call DEBTRANS From GLOCK

    Trbegin [XITL]
    [V]GOK = 1

    Readlock [F:XITL]ILD0 = [L]NUMCRA;[L]LIGCRA
    If fstat = 1 Then
        [V]GOK = -1 : GLOCK = "ITVLOTD"-[L]NUMCRA-num$([L]LIGCRA)
        Goto ROL_TR1
    Elsif fstat Then
        [V]GOK = 0
        Call RSTA("XITL",[L]NUMCRA-num$([L]LIGCRA)) From GLOCK
        Goto AB_TR1
    Endif

    If [M:VGS1]TPSAVA(I)=2 & [M:VGS0]TRTVISA=1
      [F:XITL]FLGHIE=2
      [F:XITL]FLGPJT=2
    Elsif [M:VGS0]FLGHIE = 2 Then                        :# Visa hiérarchique
        If [M:VGS0]TRTVISA = 1 Then
            [F:XITL]FLGHIE = 2
        Else
            [F:XITL]FLGHIE = 1
        Endif
    Elsif [M:VGS0]FLGPJT = 2 Then                     :# Visa projet
        If [M:VGS0]TRTVISA = 1 Then
            [F:XITL]FLGPJT = 2
        Else
            [F:XITL]FLGPJT = 1
        Endif
    Endif

    If [M:VGS1]FLGRGP(I) = 2 Then
        [F:XITL]QTY = [M:VGS1]QTY(I)
    Endif

    Rewrite [XITL]

    If fstat Then
       [V]GOK = 0
       Call FSTA("XITL") From GLOCK
    Endif

    If GOK
        GPOINT="VALVGS" : Gosub ENTREE From EXEFNC
    Endif

    If [V]GOK Then
        Call ECR_TRACE(mess(212,[V]GXMSGPSA,1)-[L]NUMCRA-","-mess(160,195,1)-num$([L]LIGCRA),0) From GESECRAN   : # MAJ du Visa
        Commit
    Else
        Call ECR_TRACE(mess(213,[V]GXMSGPSA,1)-[L]NUMCRA-","-mess(160,195,1)-num$([L]LIGCRA),1) From GESECRAN  : # Pb MAJ
        Gosub AB_TR1
    Endif

    Unlock =[L]XSYMBITL
Endif

Return

###################################################################
$AB_TR1
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

###################################################################
$ROL_TR1
Rollback
Call ROLL From GLOCK
If GROLL Then
    Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else
    Goto RW_ITL
Endif
Return


#----------------------------------------------------------------------#
#     Gestion des étiquettes liées aux masques VGS0, VGS1 et CVGS      #
#----------------------------------------------------------------------#
###################################################################
Subprog AM_FLGHIE(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M]FLGPJT=1
Else
  [M]FLGPJT=2
Endif
Affzo [M]FLGPJT
End

###################################################################
Subprog AM_FLGPJT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M]FLGHIE=1
Else
  [M]FLGHIE=2
Endif
Affzo [M]FLGHIE
End

###################################################################
Subprog IB_NBLIG

Raz [V]GBOUT5, [V]GBOUT6, [V]GBOUT7, [V]GBOUT8, [V]GBOUT9

If [M:VGS1]ITLNUM(nolign-1)<>""
  [V]GBOUT5=func XCNSVGSSPV.DESOBJ("ITL")
Endif

If [M:VGS1]REQNUM(nolign-1)<>""
  [V]GBOUT6=func XCNSVGSSPV.DESOBJ("REQ")
Endif

If [M:VGS1]CONREV(nolign-1)<>""
  [V]GBOUT7=func XCNSVGSSPV.DESOBJ("XON")
Endif

If [M:VGS1]OPPNUM(nolign-1)<>""
  [V]GBOUT8=func XCNSVGSSPV.DESOBJ("OPP")
Endif

If [M:VGS1]FLGRGP(nolign-1)<>2
  [V]GBOUT9=mess(11,198,1)
Endif

End

######################################################################################
Subprog B6_TPSAVA(VALEUR)
Variable Integer VALEUR
Local Integer I
For [L]I=0 To [M:VGS1]NBLIG-1
  If [L]I<>nolign-1
    [M:VGS1]TPSAVA([L]I)=1
  Else
    VALEUR=1
  Endif
Next
Affzo [M:VGS1]TPSAVA
End

######################################################################################
Subprog B7_TPSAVA(VALEUR)
Variable Integer VALEUR
Local Integer I
For [L]I=0 To [M:VGS1]NBLIG-1
  If [L]I<>nolign-1
    [M:VGS1]TPSAVA([L]I)=2
  Else
    VALEUR=2
  Endif
Next
Affzo [M:VGS1]TPSAVA
End

######################################################################################
Subprog B6_FLGVISA(VALEUR)
Variable Integer VALEUR
Local Integer I
For [L]I=0 To [M:VGS1]NBLIG-1
  If [L]I<>nolign-1
    [M:VGS1]FLGVISA([L]I)=1
  Else
    VALEUR=1
  Endif
Next
Affzo [M:VGS1]FLGVISA
End

######################################################################################
Subprog B7_FLGVISA(VALEUR)
Variable Integer VALEUR
Local Integer I
For [L]I=0 To [M:VGS1]NBLIG-1
  If [L]I<>nolign-1
    [M:VGS1]FLGVISA([L]I)=2
  Else
    VALEUR=2
  Endif
Next
Affzo [M:VGS1]FLGVISA
End

######################################################################################
Funprog DEF_OPERATION(FLGVISA)
Value Integer FLGVISA

If FLGVISA=2
  End "VAL"
Elsif FLGVISA=3
  End "REJ"
Else
  End ""
Endif

######################################################################################
Subprog AM_FLGVISA(VALEUR)
Variable Integer VALEUR

If [M:VGS1]FLGRGP(nolign-1)<>2 & VALEUR=3
  [V]GMESSAGE=mess(116,[V]GXMSGPSA(1),1)
  [V]GERR=1
  mkstat=1
  End
Endif

Local Integer XOK, NOL, REANUM, ZR
Local Char REACOD

[L]NOL=nolign

Raz [M:VGS1]WREANUM([L]NOL-1), [M:VGS1]WREACOD([L]NOL-1)

If VALEUR=3
  Read [F:AWF]AWF0=[M]CODWRK(nolign-1)
  If !fstat
    [L]ZR=find(func DEF_OPERATION(VALEUR),[F:AWF]OPESIG(0..[F:AWF]NBRSIG-1))
    If [L]ZR>0
      If [F:AWF]REANUM([L]ZR-1)<>0
        [L]REANUM=[F:AWF]REANUM([L]ZR-1)
        Call SAICAR([L]REACOD,mess(155,75,1),mess(155,75,1),"ADI",[L]REANUM,0,"",[L]XOK) From GESECRAN
        If [L]REACOD<>""
          [M]WREANUM([L]NOL-1)=[L]REANUM
          [M]WREACOD([L]NOL-1)=[L]REACOD
        Endif
      Endif
    Endif
  Endif
Else

Endif

End

######################################################################################
Subprog AS_FLGVISA(VALEUR)
Variable Integer VALEUR
If [M:VGS0]TRTVISA=2
  GMENLOC(3)=1
Endif
End

######################################################################################
Subprog AV_WTHE(VALEUR)
Variable Decimal VALEUR

Call CAL_WTHE(VALEUR) From XCNSVGSSPV

End
