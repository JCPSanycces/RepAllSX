#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du masque SCHGAS0
#ACV#X13
#TIT#Gestion de l'action TRTSCHAJW

#LBO 01/2003

Local Char PARAM(30)(1..16),VALEUR(10) 

PARAM(1)="LBO5"
PARAM(2)="CIMENT"
PARAM(3)="DECO"
PARAM(4)="" 
Call TRAITE_CHAR(VALEUR,PARAM,"","XSCHAJWEE2","SCHAJWEE",4) From GTRAITE    :# Appel avec ouverture de la fenetre
End


#-----------------------------------------------------------------------
# Ecran SCHAJWEE
#-----------------------------------------------------------------------
Subprog D_ENDDAT(VALEUR)
Variable Date VALEUR

VALEUR=gdat$(1,1,year(date$)+1)-1

Read [F:SHP]SHP0=[M:DIA]PLANCOD
If !fstat & [F:SHP]PLANENDDAT<VALEUR & [F:SHP]PLANENDDAT>=date$
  VALEUR=[F:SHP]PLANENDDAT
Endif
End



Subprog C_ENDDAT(VALEUR)
Variable Date VALEUR
Read [F:SHP]SHP0=[M:DIA]PLANCOD
If !fstat & [F:SHP]PLANENDDAT<VALEUR & [F:SHP]PLANENDDAT<>[0/0/0]
  [V]GMESSAGE="Planning actif jusqu'au"-format$("D:DD[/]MM[/]YYYY",[F:SHP]PLANENDDAT)
  mkstat=1
Endif
End

