#Gbn-Déb-Report V7 DKS
#########################################################################
# $S_GRPFCY : Selection Site
#########################################################################
$S_GRPFCY
#   zone courante AZC : Site
#   PARAM(1) = FILTRE  : Critères pour le filtre
#------------------------------------------------------------------------
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Local Char CODFIC(GLONDES)    : CODFIC = "FACILITY"
Link [FGR] With [FCY]FCY0=[F:FGR]FCY As [KFGR]
Default File [KFGR]
If PARAM(1)="" PARAM(1)="1=1" : Endif
ORDRE="FCY"
CRITERE(1)=PARAM(1)
TIT(0) = mess(12,123,1)
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "[F:FCY]FCY"    : Call TEXTFIC(CODFIC,"FCY",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:FCY]FCYNAM" : Call TEXTFIC(CODFIC,"FCYNAM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:FCY]FCYSHO" : Call TEXTFIC(CODFIC,"FCYSHO",1,TIT(NBCOL)) From OBJDIV

Return
#########################################################################
# $S_GRPLEG : Selection groupe site/soc en fonction d'une législation
#########################################################################
$S_GRPLEG
#   zone courante AZC   : Grp. site/soc
#   PARAM(1) = LEG      : Législation
#   PARAM(2) = CODMSK   : Abréviation masque - Pour déterminer les options de sélection
#   PARAM(3) = CHAMPCOD : Nom du champ 			 - Pour déterminer les options de sélection
#------------------------------------------------------------------------

If clalev([F:AGF])=0  : Local File AGRPFCY    [AGF]  : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX]  : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON    [AMZZ] : Endif :#--CPO 71937 Pour déterminer les options de sélection

Local Char CODFIC(GLONDES)    : CODFIC = "AGRPFCY"

Local Char    LEG(GLONADI)

Local Integer CAT
Local Integer WNOL
Local Integer ERR

#--CPO 71937 Pour déterminer les options de sélection
#Local Integer WPSPP
#Local Integer WPSUB, WPSPE, WPSTD, WPSPV
#Local Char    WPROGOBJ(GDIMFIC) , WPROGSUB(GDIMFIC) , WPROGSPE(GDIMFIC) , WPROGSPV(GDIMFIC)
If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif
Local Char CODMSK(GLONAMK)
Local Char CHAMPCOD (GLONAVA)
CODMSK  =PARAM(2)
CHAMPCOD=PARAM(3)

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
Endif
#--/CPO

#--------------------------------------------------------------------------------------------------
# Identifying the parameters
#--------------------------------------------------------------------------------------------------
LEG  = PARAM(1)

If [L]LEG=""
 [L]LEG = GCURLEG
Endif
#--------------------------------------------------------------------------------------------------
## Position and dimension of the window
#--------------------------------------------------------------------------------------------------

If [L]LEG<>""
  Gosub OUVRE_LISTE From WOAGF
  For I=1 To NBSEL
   If SELEXP(I)<>""
    COL(I) = SELEXP(I)
   Else
    COL(I) = SELZON(I)
   Endif
   TIT(I)  = SELLIB(I)
   If left$(SELFMT(I),2)="LA"
    COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
   Endif
  Next I
  NBCOL   = NBSEL
  SIZCOL  = 240
  SIZLIG  = 100
  TIT(0)  = mess(12,123,1)
  Call TITOBJ("AGF","",TIT(1)) From CONTOBJ
  TIT(0) -= TIT(1)
  START   = "[F:AGF]GRP"
  ORDRE   = "[F:AGF]GRP"
  OBJET   = ""

  #--------------------------------------------------------------------------------------------------
  ## Standard selection criteria
  #--------------------------------------------------------------------------------------------------

  CRITERE(1) = '1=1'

  ICRITERE = 3
  Call FILROLE(OBJET,FILROLE) From SUBARL
  If FILROLE<>"" & FILROLE<>"1=1"
   For I=0 To dim(FILROLE)-1
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
   Next I
  Endif

  #--------------------------------------------------------------------------------------------------
  #--Views calls
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGGRPSEL"
    Local File =SZVIEW [LGCS]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, on se déroute sur le select standard
    OBJET = "AGF"
    Return
  Endif

  Link [AGF] With [F:AXX]AXX0    = "AGRPFCY";"DESAXX";GLANGUE;[F:AGF]GRP;"",
&                 [F:LGCS]LGCS0 ~= [F:AGF]GRP;[L]LEG
& As [LAGF]

  Default File [LAGF]
Else
  #--Si pas de législation, on passe par la sélection de l'objet
  OBJET = "AGF" : Return
Endif

# Options de sélection
If OPTIONS<>""
#  Call SETPROG("AGF",WPROGOBJ,WPROGSUB,WPROGSPE,WPROGSPV,WPSTD,WPSUB,WPSPE,WPSPV) From CONTOBJ
#  If WPSTD
#    Gosub OPTIONS From =WPROGOBJ
		Gosub OPTIONS From WOAGF
    ICRITERE=2
    For I=1 To NBCOND
     If instr(1,OPTIONS,OPT(I))
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+CONDIT(I)+")","&") From GOBJSUB
     Endif
    Next I
#  Endif
Endif

DEFPAG = 1

Return

$ERRVUE
#ERR = errn
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif

Resume
#Gbn-Fin

#########################################################################

$TEXTE
Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

#<YA000/>
$YTEXTE
Call TEXTFIC(YCODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return
#</YA000>

#########################################################################

# ------------------------------------------------------------------------#
# Ajout des filtres divers utilisés dans les sélections std de l'objet    #
# ------------------------------------------------------------------------#
$FILDIV
# Filtre sur sites autorisés
 If GUSRFCY(1)<>"\" & dim(ZSITE)>0 & ZSITE<>"" & GNBAUZ<>GNBSITE
  Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'([F:'+ABFIC+']'+ZSITE+'=""',"&") From GOBJSUB
  Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'find([F:'+ABFIC+']'+ZSITE+',GUSRFCY(1..GNBAUZ))<>0)',"|")
& From GOBJSUB
 Endif

# Filtre sur droit d'accès
 If GUSRACS<>2 & dim(ZACC)>0 & ZACC<>""
  Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'([F:'+ABFIC+']'+ZACC+'="" or [F:ACC]CONSUL=2)',"&") From GOBJSUB
 Endif

# Filtre sur les rôles
 ABROL = WABROL
 Gosub FILROLE From GOBJACT
 If FILROLE<>"" & FILROLE<>"1=1"
  For I=0 To dim(FILROLE)-1
   Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
  Next I
 Endif
Return

#########################################################################
#    CHOIX DANS LES LISTES                                              #
#########################################################################
$SEL_LISTE
Case LISTE
    When "SELSAU"   : Gosub S_SAU
Endcase
Return

#########################################################################
$S_SAU

Local Char    ART(GLONITM)    :    ART= PARAM(1)
Local Char    CLI(GLONBPR)    :    CLI= PARAM(2)
Local Char    UNIVEN(GLONDES)

Local    Integer I,J,NO
#Local    Char    UV(GLONUOM)(9)
#Local    Char    DUV(30)(9)
#Local    Char    LUV(48)(9)

Gosub CHARGSAU From TRTVENCTL

If J >= 0
   For I=0 To J-1
        NBTEX +=1
        TEX(NBTEX) = vireblc(left$([L]LUV(I),GLONUOM),1)
        TEXTE(NBTEX) = TEX(NBTEX)+vireblc(mid$([L]LUV(I),GLONUOM+2,20),1)
   Next I
Endif

TIT = mess(6,191,1)

Return
#########################################################################




