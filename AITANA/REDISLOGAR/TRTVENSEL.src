#########################################################################
# $S_ITV : Selection Article-Vente
#########################################################################
$S_ITV
If clalev([F:ITS])=0 : Local File ITMSALES  : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   : Endif
Local Char CODFIC(GLONDES)    : CODFIC = "ITMSALES"

Link [ITS] With [ITM]ITM0=[ITS]ITMREF As [KITS]
Default File [KITS]

ORDRE   = 'ITMREF'
START   = 'ITMREF'

CRITERE='[F:ITM]ITMSTA=1 & [F:ITM]ITMREF>="'+VALEUR+'"'
OBJET="ITS"

#Local Char WABROL : WABROL="ITS" : Gosub FILDIV
#TIT(0) = mess(12,123,1)
#NBCOL = 0
#NBCOL +=1 : COL(NBCOL) = "ITMREF"  : Gosub TEXTE
#NBCOL +=1 : COL(NBCOL) = "ITMDES1" : Gosub TEXTE
#NBCOL +=1 : COL(NBCOL) = "mess([F:ITS]ITMTYP,436,1)" : Call TEXTFIC(CODFIC, "ITMTYP", 1, TIT(NBCOL)) From OBJDIV
#NBCOL +=1 : COL(NBCOL) = "arr([F:ITS]BASPRI,0.0001)" : Call TEXTFIC(CODFIC, "BASPRI", 1, TIT(NBCOL)) From OBJDIV
#NBCOL +=1 : COL(NBCOL) = "GSYSCUR" : Call TEXTE(323,TIT(NBCOL)) From OBJDIV

Return

# GRNA 79855
#########################################################################
# $S_ITV1 : Selection Article-Vente
#########################################################################
$S_ITV1
Local Char CODFIC(GLONDES)
Local Char UPVAL(type(VALEUR)-10)
Local Integer NBREC
Local Clbfile SQL_REQ(1)  # FGR 18/11/2014 : X3SUIVI103817 taille de (1) est plus raisonnable

  #111075.sn
  #Remove parameter AUTOSELITS
  #If func AFNC.PARAMUTIL("AUTOSELITS", GUSER, "") <> "2" Then
  #  OK = 0
  #  Return
  #Endif
  #111075.en
  #
  If clalev([F:ITS])=0 : Local File ITMSALES  : Endif
  If clalev([F:ITM])=0 : Local File ITMMASTER : Endif
  If clalev([F:ATZ])=0 : Local File ATABZON   : Endif
  #
  #CODFIC = "AUTOSELITS" #111075.n Remove parameter AUTOSELITS
  UPVAL = toupper(VALEUR)
  #
  Link [ITS] With [ITM]ITM0=[ITS]ITMREF As [KITS]
  Default File [F:KITS]
  Read [F:KITS]ITS0=UPVAL
  If !fstat Then
    OK = 0
    Return
  Endif
  #
  ORDRE = 'ITMREF'
  START = 'ITMREF'
  OBJET = 'ITS'
  #
  CRITERE  = '((left$([F:ITM]ITMREF,' + num$(len(UPVAL)) + ')="' + UPVAL + '")'
  CRITERE -= '| (pat(toupper([F:ITM]ITMDES1),"*' + UPVAL + '*"))'
  CRITERE -= '| (toupper([F:ITM]EANCOD)="' + UPVAL + '"))'
  CRITERE -= '& [F:ITM]ITMSTA=1'                                               # FGR 18/11/2014 : X3SUIVI103817
  #
  SQL_REQ  =      "select count(*) From ITMMASTER ITM, ITMSALES ITS"
  Append SQL_REQ, " Where ITM.ITMREF_0=ITS.ITMREF_0"
  Append SQL_REQ, " and ITM.ITMSTA_0=1"                                        # FGR 18/11/2014 : X3SUIVI103817
  Append SQL_REQ, " and (" + func CUSSEA.FUZZIFY("ITM.ITMREF_0", VALEUR, 2)
  Append SQL_REQ, " or" - func CUSSEA.FUZZIFY("upper(ITM.ITMDES1_0)", VALEUR, 3)
  Append SQL_REQ, " or" - func CUSSEA.FUZZIFY("ITM.EANCOD_0", VALEUR, 0) + ")"

  # Issue 108259
  # Point d'entree modification filtre selection article
  GPOINT="SELITV1CRIT" : Gosub ENTREE From EXEFNC
  # End issue 108259

  For (Integer RES) From num$(GTYPDBA*2+1) Sql SQL_REQ As [CONT]
    NBREC = RES
  Next
  If NBREC < 2 Then
    # Either 0 or 1 matches
    If NBREC = 1 Then
      # If only 1 match, autoselect it
      Filter [F:KITS] Where evalue(CRITERE)
      Read [F:KITS] First
      VALEUR = [F:KITS]ITMREF
      Filter [F:KITS]
    Endif
    OK = 0
    Return
  Endif
Return

#########################################################################
# $S_BPD : Selection Client livré
#########################################################################
$S_BPD

OBJET   = "BPD"
OPTIONS = PARAM(1)
If len(OPTIONS)<>0 : OPTIONS+= "&" : Endif : OPTIONS += "ENAFLG=2"
SUPP    = PARAM(2)
GBPCNUM = PARAM(2)

Return

#########################################################################
# $S_ITU : Selection Article-Client
#########################################################################
$S_ITU
Local Char ART(GLONITM)        : ART=VALEUR
Local Char CLI(GLONBPR)        : CLI=PARAM(1)
Local Integer SELTYP  : SELTYP = val(PARAM(2))

Gosub SEL_ITU
Return

$SEL_ITU
If clalev([F:ITU])=0 : Local File ITMBPC    : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   : Endif
Local Char CODFIC(GLONDES)    : CODFIC = "ITMBPC"
Local Char YCODFIC(GLONDES)   : YCODFIC = "ITMMASTER"  #YA000

Link [ITU] With [ITM]ITM0=[ITU]ITMREF As [KITU]
Default File [KITU]

ORDRE   = 'ITMREFBPC'
If SELTYP=1
    START   = 'ITMREF'
Else
    START   = 'ITMREFBPC'
Endif
TIT(0) = mess(12,123,1)

NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "ITMREFBPC" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "ITMDESBPC" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "BPCNUM"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "ITMREF"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "ITMDES1"   : Gosub YTEXTE     #YA000
If ART = ""
    CRITERE = '[F:ITU]BPCNUM="'+CLI+'" & [F:ITM]ITMSTA=1'
Else
    CRITERE = '[F:ITU]BPCNUM="'+CLI+'" & [F:ITU]ITMREFBPC>="'+ART+'" & [F:ITM]ITMSTA=1'
Endif
DEFPAG=1
Return

#########################################################################
# $S_SALFCY : Selection Site vente
#########################################################################
$S_SALFCY
If clalev([F:ATZ])=0 : Local File ATABZON : Endif
Local Char CODFIC(GLONDES)    : CODFIC = "FACILITY"
Default File [FCY]

CRITERE = 'SALFLG=2'
If GSOCIETE<>"" CRITERE += ' & LEGCPY=GSOCIETE' Endif
START   = 'FCY'
TIT(0) = mess(12,123,1)
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "LEGCPY" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "FCY"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "FCYNAM" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "FCYSHO" : Gosub TEXTE
DEFPAG=1
Return

#########################################################################
$S_SIVTYP
If clalev([F:ATZ])=0 : Local File ATABZON : Endif
Local Char CODFIC(GLONDES)    : CODFIC = "TABSIVTYP"
Default File [TSV]
OBJET="TSV"

#  GFACTYP : 1=facture, 2=avoir, 3=proforma, 4=facture & proforma, 5=tous(import)
CRITERE = "(GFACTYP=1&INVTYP=1) |(GFACTYP=2&INVTYP=2) |(GFACTYP=3&INVTYP=5) | (GFACTYP=4 & find(INVTYP,1,5))"

#TIT(0) = mess(12,123,1)
#NBCOL = 0
#NBCOL += 1 : COL(NBCOL) = "SIVTYP" : Gosub TEXTE
#NBCOL += 1 : COL(NBCOL) = "TSVDES" : Gosub TEXTE
#NBCOL += 1 : COL(NBCOL) = "INVTYP" : Gosub TEXTE
Return

#########################################################################
$S_STOFCY
If clalev([F:ATZ])=0 : Local File ATABZON : Endif
Local Char CODFIC(GLONDES)    : CODFIC = "FACILITY"

Default File [FCY]

CRITERE = 'WRHFLG=2'
If GSOCIETE<>"" CRITERE += ' & LEGCPY=GSOCIETE' Endif
START   = 'FCY'
TIT(0) = mess(12,123,1)
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "LEGCPY" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "FCY"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "FCYNAM" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "FCYSHO" : Gosub TEXTE
DEFPAG=1
Return


###################################################################################################
# $S_TSVTYP : Selection Types de facture client (Appelé par Action SEL_TABLE & Table SELTSV)
#  appelé entre autres par écran:BCH1/Zone:SIVTYP           Type Act:Sélection
###################################################################################################
$S_TSV
#   zone courante AZC  : Type de facture
#   PARAM(1) = FILTRE  : Critères pour le filtre
#   PARAM(2) = OPTIONA : Options de l'objet TSV
#------------------------------------------------------------------------
If PARAM(1)="" PARAM(1)="1=1" : Endif
CRITERE(1)=PARAM(1)
OPTIONS=PARAM(2)
OBJET="TSV"
Return

