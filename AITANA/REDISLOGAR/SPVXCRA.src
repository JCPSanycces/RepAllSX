#ACV#X12
#TIT#

$ACTION
Return

########################################
Subprog C_DATBEG(VALEUR)
Variable Date VALEUR

If VALEUR<[M:ITL0]DATBEG | VALEUR>[M:ITL0]DATEND
    mkstat=2
Endif
End

########################################
Subprog C_DATEND(VALEUR)
Variable Date VALEUR

If VALEUR>[M:ITL0]DATEND
    mkstat=2
Endif
End

