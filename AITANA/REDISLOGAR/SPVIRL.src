#<AdxTL>@(#)5.0.0.0 $Revision$
#ACV#X11
#TIT#Gestion de l'indice de révision

GBIDC1=""
GBIDC2=""
Call OBJET("IRL",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

###############################################
$ACTION

# Appel fonctions complémentaires GFI pour l'objet IRL
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
 When "OUVRE"   :  Gosub OUVRE     From SPVOBJIRL
 When "SETBOUT" :  Gosub SETBOUT   From SPVOBJIRL
Endcase

Return

###############################################
Subprog D_INDDESSHO(VALEUR)
Variable Char     VALEUR
VALEUR=[M]INDDES
End
