#ACV#X16
#TIT#Gestion spécifique de l'écran DUDX

#===============================================================================
# Gestion de l'objet   : Gestion spécifique de l'écran DUDX
# Auteur               : Laurent Bornes
# Date de création     : 20/04/2011
#===============================================================================
# Modifications significatives
#-------------------------------------------------------------------------------
# Date          Auteur       Description
#-------------------------------------------------------------------------------
#
# Utilisation d'un Trt vertical nécessaire pour désactiver le std et éviter
# d'utiliser de codes activité SPE sur le Std
#
#===============================================================================

Local Char VALBOUT(250) , PARBOUT(250)(1..20)
PARBOUT(1) = "13"
PARBOUT(2) = "AFF1011PSF00008"
#PARBOUT(2) = "AFF1012LYO00001"
PARBOUT(3) = num$(1)
PARBOUT(4) = ""
FLGEXE = 1
GACTION = "TRTMODACO"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","TRTTPT","DDUDX",3,"XYTRTTPT") From GTRAITE
End

#===============================================================================
Subprog AS_NBLIG

If ![V]GXOPTOPP | GMODULE<>13
  Call AS_NBLIG From SUBDUDX
  End
Endif

GMODIF = 2
If [M]PAMTYP(nolign-1) <> 0 
  If [M]SENINS(nolign-1) = 2 GMODIF = 1 : End  : Endif
  If [M]PAYCUR(nolign-1)<>0 | [M]TMPCUR(nolign-1)<>0  GMODIF=1 : End : Endif            
  If [M]PAMTYP(nolign-1) = 1 : GMODIF = 1 : Endif
Endif
[M]DCUR(nolign-1)= [M]CUR

Gosub INFOENC From XTRTMODACO

End

#===============================================================================
Subprog C_NBLIG

If ![V]GXOPTOPP | GMODULE<>13
  Call C_NBLIG From SUBDUDX
  End
Endif

If find(status,73,82) & [M]NBLIG>3  
# Si insertion de ligne on ne peut pas mettre plus de 4 acomptes / retenue de garantie
#  LBORN 10/02/2011 - Désactivé pour autoriser +4 lignes
#  GMESSAGE=mess(143,[V]GXMSGOPP,1) : mkstat=2 : End 
Endif

# On ne peut pas supprimer l'acompte s'il y a un règlement (41822)
If find(status,65,68,83) & ([M]PAYCUR(nolign-1)<>0 | [M]TMPCUR(nolign-1)<>0) 
  GMESSAGE=mess(50,117,1) : mkstat=2 : End 
Endif

If find(status,65,68,73,75,82,83) 
# Si le détail est facturé ou partiellement facturé on ne peut plus faire de modif,suppression,insertion
# LBORN 10/02/2011 - Désactivé pour autoriser de saisir ou modifier les acomptes après règlement, mais
#                    on interdit de modifier les lignes déjà déduites
#  GMESSAGE=mess(138,[V]GXMSGOPP,1)
#  GERR=3
  If [M]PAYCUR(nolign-1)<>0 | [M]TMPCUR(nolign-1)<>0 | [M]DINAMT(nolign-1)<>0
    mkstat=2
  Endif
Endif

End

#===============================================================================
Subprog C_AMTCUR(VALEUR)
Variable Decimal VALEUR

If ![V]GXOPTOPP | GMODULE<>13
  Call C_AMTCUR(VALEUR) From SUBDUDX
  End
Endif

Local Decimal WMONTANT, WMONTORD
Local Integer OK

If VALEUR < [M]DINAMT(nolign-1)
   GMESSAGE= (mess(110,196,1)- num$([M]DINAMT(nolign-1))) 
   mkstat = 1 
   End 
Endif

WMONTANT = sum([M]AMTCUR(0..NBLIG-1))-[M]AMTCUR(nolign-1)+VALEUR 

If !GTPTTVA WMONTORD=[M]TTVORD Else WMONTORD=[M]TOTORD Endif
If WMONTANT > WMONTORD 
   OK=1
   Call AVERTIR(mess(71,196,1)-"="-num$(WMONTANT)+"\"+mess(137,[V]GXMSGOPP,1)-"="
&              -num$(WMONTORD)+"\"+mess(205,100,1),OK) From GESECRAN 
   If OK<>2 mkstat=1 : End : Endif 
Endif
If varinit([M]IBDAMT,nolign-1)<>0 & [M]AMTCUR(nolign-1)<>VALEUR
  [M]IBDAMT(nolign-1)=VALEUR : Affzo IBDAMT(nolign-1)
Endif

End

