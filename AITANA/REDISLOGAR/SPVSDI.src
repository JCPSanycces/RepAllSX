#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion du masque SCHDETI0
#ACV#X13
#TIT#Gestion de l'objet SDI

#LBO 07/2002

GBIDC1=""
GBIDC2=""
Call OBJET("SDI",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet SDI
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "DEBUT_MOD" : Gosub DEBUT_MOD From SPVOBJSDI
  When "FILTRE"    : Gosub FILTRE  From SPVOBJSDI
  When "SETBOUT"   : Gosub SETBOUT From SPVOBJSDI
  When "VERF_ANU"  : Gosub VERF_ANU From SPVOBJSDI
Endcase

Return


#####################################################################################
# Ecran SCHDETI0 [SDI0]
#####################################################################################

#-----------------------------------
Subprog C_NBLIG

# Status 73 : Insertion
#        82 : Ajout
#        65 : Annulation

# Test annulation multiple refusée (contrôle car Pb options de la variable de bas de tableau)
If status=83 : mkstat=1 : End : Endif

Local Integer I

Case status
  When 73,82
    mkstat=1
    For [F:XIP]XIP0 Where [F:XIP]PLANCOD=[M:SDI0]PLANCOD
      If [F:XIP]ICOSELTYP=2
        mkstat=0 : Break
      Endif
    Next
  When 65
    mkstat=1
    Read [F:XIP]XIP2=[M:SDI0]PLANCOD;[M:SDI0]ICOOBJ(nolign-1)
    If !fstat & [F:XIP]ICOSELTYP=2
      mkstat=0
    Endif
    If status=65 & !mkstat
      Read [F:AGD]AGD5(2)=[M:SDI0]PLANCOD;[M:SDI0]ICOLIB(nolign-1)
      If !fstat
        [V]GMESSAGE="Icône déjà utilisé dans l'agenda"
        [V]GMESSAGE+="\Suppression impossible"
        mkstat=1
      Endif
    Endif
Endcase
End

#-----------------------------------
Subprog APRES_NBLIG
# Pas d'init en annulation
If status<>65
  Call CRYPTICO([M:SDI0]ICOLIB(nolign-1),[M:SDI0]CODICO(nolign-1),[M:SDI0]ICOTYP(nolign-1),[M:SDI0]ICODUR(nolign-1),[M:SDI0]ICOMIN(nolign-1)
&           ,[M:SDI0]ICOWKD(nolign-1),[M:SDI0]CODICOVP1(nolign-1),[M:SDI0]CODICOVP2(nolign-1)) From XCRYPTVP
Endif
End


#-----------------------------------
Subprog C_ICOLIB(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:SDI0]ICOLIB) From OBJDIV
End

#-----------------------------------
Subprog AS_ICOMIN(VALEUR)
Variable Decimal VALEUR
If [M:SDI0]ICOTYP(nolign-1)<>3
  mkstat=1
Endif
End

#-----------------------------------
Subprog C_ICOMIN(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 | VALEUR>59
  mkstat=1
Endif
End


#-----------------------------------
Subprog AS_ICOLIB(VALEUR)
Variable Char    VALEUR()

Read [F:XIP]XIP2=[M:SDI0]PLANCOD;[M:SDI0]ICOOBJ(nolign-1)
If !fstat & [F:XIP]ICOSELTYP=1
  mkstat=2
Endif

End


#-----------------------------------
Subprog AS_DESVAL(VALEUR)
Variable Char    VALEUR()

Read [F:XIP]XIP2=[M:SDI0]PLANCOD;[M:SDI0]ICOOBJ(nolign-1)
If !fstat & [F:XIP]ICOSELTYP=1 & [F:XIP]ICOEXPDES<>""
  mkstat=2
Endif

End


#-----------------------------------
Subprog D_ICOTYP(VALEUR)
Variable Integer VALEUR

Gosub INIT_I
If [L]I<>0
  VALEUR=[F:XIP]ICOTYP
Endif
End
  
$INIT_I
Local Integer I
[L]I=0
Read [F:XIP]XIP2=[M:SDI0]PLANCOD;[M:SDI0]ICOOBJ(nolign-1)
If !fstat
  [L]I=1
Else
  Read [F:XIP]XIP3(2)=[M:SDI0]PLANCOD;2
  If !fstat
    [L]I=1
  Endif
Endif
Return


#-----------------------------------
Subprog D_ICODUR(VALEUR)
Variable Decimal VALEUR
Gosub INIT_I
If [L]I<>0
  VALEUR=[F:XIP]ICODUR
Endif
End

#-----------------------------------
Subprog D_ICOMIN(VALEUR)
Variable Decimal VALEUR
Gosub INIT_I
If [L]I<>0
  VALEUR=[F:XIP]ICOMIN
Endif
End

#-----------------------------------
Subprog D_ICOWKD(VALEUR)
Variable Integer VALEUR
Gosub INIT_I
If [L]I<>0
  VALEUR=[F:XIP]ICOWKD
Endif
End

