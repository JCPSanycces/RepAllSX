#<AdxTL>@(#)10.0.0.0 $Revision$
#ACV#X12
#TIT#Actions sur champ spécifiques

#===================================================================================================
# Gestion de l'objet   : Gestion des actions PSG
#
# Auteur               :
# Date de création     :
#===================================================================================================
# Modification significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#
# L'étiquette PSGACTION doit être présente dans ce traitement.
# La variable PSGACTION contient le code étiquette utilisé dans les colonnes suivantes
#
# -------------
# "Déclencheur"
# -------------
# Variable OK à initialisé à 1 pour déclencher le paramètrage de la ligne, sinon par défaut le paramètrage
# de la ligne n'est pas déclenché si une étiquette est définie (OK=0).
#
# -------------------
# "Valeur par défaut"
# -------------------
# Variable VALEUR à utiliser pour initialiser la zone.
# (exemple VALEUR=[25/05/2003] pour une zone de type "Date", VALEUR="art1" pour une zone de type "Alpha", sinon VALEUR=6.55957
# pour une zone de type "numérique" ou "libellé")
# Utilisez de préférence la syntaxe suivante pour le code étiquette : $D_<Zone>
#
# ---------------------
# "Condition de saisie"
# ---------------------
# Variable OK à initialiser à 1 pour rendre la zone saisissable, sinon par défaut la zone ne sera pas saisissable
# si une étiquette est définie (OK=0)
# Utilisez de préférence la syntaxe suivante pour le code étiquette : $AS_<Zone>
#
# ---------------------
# "Contrôle de saisie"
# ---------------------
# Variable OK à initialiser à 1 pour ne pas bloquer la zone, sinon par défaut (OK=0) la zone sera bloquée
# si une étiquette est définie.
# Utilisez de préférence la syntaxe suivante pour le code étiquette : $C_<Zone>
#
# ---------------------
# "Message Erreur"
# ---------------------
# Variable [V]GMESSAGE à utiliser pour renvoyer un message d'erreur si le contrôle PSG n'est pas respecté


$PSGACTION
Case PSGACTION
 When "C_PRIPUR" : Gosub C_PRIPUR
 When "C_PRIPUR2": Gosub C_PRIPUR2
 When "I_PRIPUR" : Gosub I_PRIPUR
 When "D_FCY"    : Gosub D_FCY
 When "I_LOC"    : Gosub I_LOC
Endcase
Return

$C_PRIPUR
    OK=1
    [M:ITV2]UNTPRI(nolign-1)=[M:ITV2]PRIPUR(nolign-1)
    Affzo [M:ITV2]UNTPRI(nolign-1)
Return

$C_PRIPUR2
    OK=1
    [M:ITV2]PRIPUR(nolign-1)=[M:ITV2]UNTPRI(nolign-1)
    Affzo [M:ITV2]PRIPUR(nolign-1)
Return

$I_PRIPUR
    [M:ITV2]UNTPRI(nolign-1)=[M:ITV2]PRIPUR(nolign-1)
    Affzo [M:ITV2]UNTPRI(nolign-1)
Return

$D_FCY
    If !clalev([F:YAUS]) Then Local File AUTILIS [YAUS] Endif
    If [F:YAUS]USR<>GUSER
        Read [F:YAUS]CODUSR=GUSER
    Endif
    VALEUR=[F:YAUS]FCYT
    If VALEUR=""
        Read [F:YAUS]CODUSR=[F:REQ]RESINT
        VALEUR=[F:YAUS]FCYT
    Endif
Return

$I_LOC
    If !clalev([F:YBPD]) Then Local File BPDLVCUST [YBPD] Endif
    Read [F:YBPD]BPD0=[F:REQ]BPCNUM;[M:ITV1]BPAITV
    If [F:YBPD]STOFCY=[F:REQ]FCY Then
        VALEUR=[F:YBPD]BPCLOC
    Endif
Return

