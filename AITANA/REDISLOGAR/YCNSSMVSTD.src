#<AdxTL>@(#)0.0.0.0 $Revision$
#Local Char PARAM(20)(1..8)
#PARAM(1) = "0"
#PARAM(2) = "GAL"
#PARAM(3) = "A-HN140"
#PARAM(4) = ""
#PARAM(5) = ""
#PARAM(6) = "0"
#PARAM(7) = ""
#PARAM(8) = ""
#Raz GPILOBJ, GNBMASKOUV : Call GCONSULT("SMV","",PARAM) From GCONSULT
#End
############################################################
$ACTION
Case ACTION

  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE

  When Default
Endcase
Return
  #When "FERME"      : Gosub FERME
#  When "SETBOUT"    : Gosub SETBOUT
#  When "EXEBOUT"    : Gosub EXEBOUT
#  When "FIN_CRIT"   : Gosub FIN_CRIT
#  When "AP_MAGNETO" : Gosub AP_MAGNETO
############################################################
$OUVRE

Raz GSOC_ACTIVE                                               # Ana

If clalev([F:STJ]) = 0 : Local File STOJOU     [STJ] : Endif
If clalev([F:SJV]) = 0 : Local File STOJOUVAL  [SJV] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY]) = 0 : Local File COMPANY    [CPY] : Endif
If clalev([F:TCU]) = 0 : Local File TABCUR     [TCU] : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR     [TFO] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If GMODU(2)=2 : # Si module compta actif                       # Ana
  If !clalev([F:GCM])    Local File GACM       [GCM] : Endif   # Ana
Endif                                                          # Ana

# Chargement des globales référenciels, comptes et sections de la société
GFCY=GFCYDEF(7)                                                # Ana
Call GETCPY(GFCY,"",0,"") From TRTX3CPT                        # Ana
GORITITCOL=1                                                   # Ana

Global Char   WFIL1(250),WFIL2(250), WFILS(250), WFILF(250), WFILX(250), WSTR(250), WFILSPE(250)    # hcb 78584
Local Integer WNOLIGN, WFSTAT, WREAD, WSKIP, WLIG, WCLA, WSEL, WPAGE
Local Decimal WACT, WSTO, WWSTO
Local Char    WSAP
Local Char    WCOL(13) : WCOL = "1111110001110"
Local Integer WBUT
Local Integer I, J
Local Integer WOK
Local Char    WPAR
Local Integer WLTI, WAGR
Local  Integer WGCONSULT : WGCONSULT = GCONSULT         # hcb 30488

WNOLIGN = nolign
Gosub LOAD_SCREEN

NAVIG="CONSSMV"
SUITE  = 1
RETOUR = 1

Local Integer FLG
FLG = 0
Local Integer WSTOCOUSEL
WSTOCOUSEL = 0

Return
############################################################
$LOAD_SCREEN

#[M:SMV1]SRTCOD
Local Integer WSRTCOD
WSRTCOD = 7



#[M:SMV1]INQLTI = WLTI
#[M:SMV1]STDFLG = 2
#[M:SMV1]MISFLG = 1
Local Integer INQLTI, STDFLG, MISFLG, CHGFLG, AGGFLG, REGFLG

WSTDFLG = 2
WMISFLG = 1
WCHGFLG = 1
WAGGFLG = 1
WREGFLG = 1

Local Char WSELFOR : Raz WSELFOR
Local Integer WINQLTI
WINQLTI = 8

Local Integer WUPDFLG
WUPDFLG = 1


Return
############################################################
$LECTURE
Gosub AFF_TITCOL

If [M:SPR1]ITMREF = ""
  NBLU = 0
  Return
Endif

# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
WBUT   = 0

Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [STJ]
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [STJ]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        If dim([M:YSMV2]BEFSTO) > 0
          If WSEL = 0 & WBUT = 0
              WSTO -= [F:STJ]QTYSTU
          Endif
        Endif
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Raz [M:YSMV2]
    WLIG = 0
    For [STJ]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [STJ]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        If dim([M:YSMV2]BEFSTO) > 0
          If WSEL = 0 & WBUT = 0
              WSTO -= [F:STJ]QTYSTU
          Endif
        Endif
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [STJ]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        If dim([M:YSMV2]BEFSTO) > 0
          If WSEL = 0 & WBUT = 0
              WSTO -= [F:STJ]QTYSTU
          Endif
        Endif
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
# Pas dépositionné
###Filter [STJ]

#[M:YSMV2]NBLIG = 2
Affzo [M:YSMV2]

Return
############################################################
$AFF_TITCOL                             : # ana
If  dim([M:YSMV2]CCE1)>0                                      # hcb 112700
  Local Char BASPAG(10)
  Call ISSCREENOK (nomap,"YCONSSMV2") From INTRUTILB
  BASPAG="NBLIG" : Gosub TIT_COL From W1YCONSSMV2
  # Pour forcer l'utilisation des formats évalués si tableau vide
  If [M:YSMV2]NBLIG=0
    [M:YSMV2]NBLIG=1 : Affzo [YSMV2]5 : Effzo [YSMV2]5
  Endif
Endif
Raz GSOC_UPDFLG
Return
############################################################
$TRT_FILTER
If CHGPAG = 1
  WFLG =0
Endif

If WFLG = 0
   Filter [STJ]                     # hcb 27082
  WFLG = 1
  Raz [M:YSMV2]
  Gosub LOAD_FILTER

  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
# Chargement stock initial
  WSTO = 0
  If WSEL = 0
      Filter [STO] Where evalue(WFILX)
&                  Order By Key STO3
      For [STO]
        WSTO += [F:STO]QTYSTU
      Next
      Filter [STO]
  Endif
  WWSTO = WSTO
  Case WSRTCOD
    When 1 :
      Onerrgo ERR_FORM1
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By Key STJ0
      Onerrgo
    When 3 :
      Onerrgo ERR_FORM3
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By ITMREF; LOT; STOFCY; IPTDAT; MVTSEQ Desc; UPDCOD
      Onerrgo
    When 4 :
      Onerrgo ERR_FORM4
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By ITMREF; LOC; STOFCY; IPTDAT; MVTSEQ Desc; UPDCOD
      Onerrgo
    When 5 :
      Onerrgo ERR_FORM5
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                 Order By ITMREF; STA; STOFCY; IPTDAT; MVTSEQ Desc; UPDCOD
      Onerrgo
    When 6 :
      Onerrgo ERR_FORM6
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By ITMREF; PCU; PCUSTUCOE; STOFCY; IPTDAT; MVTSEQ Desc; UPDCOD
      Onerrgo
    When 9 :
      Onerrgo ERR_FORM9
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By IPTDAT Asc; CREMVTDAT Asc; CREMVTTIM Asc; MVTSEQ Desc; MVTIND Desc : # Bug 88530
#&                  Order By ITMREF; IPTDAT; STOFCY; MVTSEQ Desc; UPDCOD                       : # Bug 88530
      Onerrgo
    When 10 :
      Onerrgo ERR_FORM10
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By ITMREF; CREDAT Desc; CRETIM Desc; IPTDAT Desc; MVTSEQ
      Onerrgo
    When 11 :
      Onerrgo ERR_FORM11
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By ITMREF; CREDAT; CRETIM; IPTDAT; MVTSEQ Desc
      Onerrgo
    When Default :
      Onerrgo ERR_FORM
      Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By IPTDAT Desc; CREMVTDAT Desc; CREMVTTIM Desc; MVTSEQ Asc; MVTIND Asc : # Bug 88530
#&                  Order By ITMREF; IPTDAT Desc; STOFCY; MVTSEQ; UPDCOD                        : # Bug 88530
      Onerrgo
  Endcase
  Raz [F:STJ]
  fstat = 0
Else
  WSTO = WWSTO
Endif
Return
############################################################
$LOA_LIGNE
#MAE, bg 85422

If [F:ITM]SERMGTCOD > 1
  Gosub AGREG
Endif
If WAGR=1 : Return : Endif

[M:YSMV2]  = [F:STJ]
For I=1 To GNBDIE
   Assign "[M:YSMV2]CCE"+num$(I)+"(nolign-1)" With [F:STJ]CCE(I-1)
Next I

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:STJ]STOFCY | [F:ITF]ITMREF <> [F:STJ]ITMREF
   Read [ITF]ITF0 = [F:STJ]ITMREF;[F:STJ]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

If dim([M:YSMV2]POT) > 0 & [F:ITF]STOMGTCOD <> 3
  [M:YSMV2]POT(nolign-1) = 0
Endif
If dim([M:YSMV2]ACT) > 0 & [F:ITF]STOMGTCOD <> 4
  [M:YSMV2]ACT(nolign-1) = 0
Endif
If [F:STJ]VCRTYP = 0
  [M:YSMV2]VCRTYPTXT(nolign-1) = ""
Else
  [M:YSMV2]VCRTYPTXT(nolign-1) =  mess([F:STJ]VCRTYP,701,1)
Endif
If [F:STJ]VCRTYPORI = 0
  [M:YSMV2]VCRTYPORIT(nolign-1) = ""
Else
  [M:YSMV2]VCRTYPORIT(nolign-1) =  mess([F:STJ]VCRTYPORI,701,1)
Endif
If [F:FCY]FCY<>[F:STJ]STOFCY
    Read [F:FCY]FCY0=[F:STJ]STOFCY
Endif
If [F:CPY]CPY<>[F:FCY]LEGCPY
    Read [F:CPY]CPY0=[F:FCY]LEGCPY
Endif
[M:YSMV2]ACCCUR(nolign-1)=[F:CPY]ACCCUR

If dim([M:YSMV2]BEFSTO) > 0
  [M:YSMV2]AFTSTO(nolign-1) = 0
  [M:YSMV2]BEFSTO(nolign-1) = 0
  If WSEL = 0 & WBUT = 0 & [M:YSMV2]TRSTYP(nolign-1)<>23

      [M:YSMV2]AFTSTO(nolign-1) = WSTO
      WSTO -= [F:STJ]QTYSTU
      [M:YSMV2]BEFSTO(nolign-1) = WSTO

  Endif
Endif
#--- calcul du no série de finv dans le cas des mvt de sorties
If dim([M:YSMV2]SERNUM(nolign-1))>0 & [M:YSMV2]SERNUM(nolign-1) <> ""
   If abs([M:YSMV2]QTYSTU(nolign-1)) = 1
        [M:YSMV2]SERFIN(nolign-1) = [M:YSMV2]SERNUM(nolign-1)
   Else Call PLUS_NB([M:YSMV2]SERNUM(nolign-1),abs([M:YSMV2]QTYSTU(nolign-1)),[M:YSMV2]SERFIN(nolign-1),WOK) From STKLIB
   Endif
Endif
If [M:YSMV2]NBLIG < 1000
  [M:YSMV2]NBLIG +=1
Endif
Return
############################################################
$LOAD_FILTER
Raz WFILX, WFIL1
WFILX = "1=1"
WFIL1 = "1=1"

If WSRTCOD = 0
  WSRTCOD = 7
Endif
If find(WSRTCOD,7,9,10,11)
  WSEL = 0
Else
  WSEL = 1
Endif
WSTRDAT = date$-WINQLTI
# Filtre site
If [M:SPR1]FCY <> ""                             # graph
  WFIL1 += "&[F:STJ]STOFCY=[M:SPR1]FCY"            # graph
  WFILX += "&[F:STO]STOFCY=[M:SPR1]FCY"            # graph
  If WUPDFLG <> 2                         # graph
    WFIL1 += "&[F:STJ]UPDCOD=2"
  Else
    WSEL   = 1
    WFIL1 += "&[F:STJ]UPDCOD=1"
  Endif
  If WREGFLG <> 2                    # hcb 040105  24390    # graph
    WFIL1 += "&[F:STJ]REGFLG<>2"            # hcb 040105  24390
  Endif                                     # hcb 040105  24390
Else
  #    Autorisation site
  # 99078 : Ctrl Autorisation site ssi aucun site saisi (si site saisi, le ctrl a été fait à la saisie)
  If GUSRFCY(1)<>"\" & [M:SPR1]FCY = "" & GNBAUZ<>GNBSITE
    WFIL1 += "& find([F:STJ]STOFCY,GUSRFCY(1..GNBAUZ))"
    WFILX += "& find([F:STO]STOFCY,GUSRFCY(1..GNBAUZ))"
  Endif
  If WUPDFLG <> 2                         # graph
    WFIL1 += "&[F:STJ]UPDCOD=2"
  Else
    WSEL  = 1
    WFIL1 += "&[F:STJ]UPDCOD=1"
  Endif
  If WREGFLG <> 2                    # hcb 040105  24390    # graph
    WFIL1 += "&[F:STJ]REGFLG<>2"            # hcb 040105  24390
  Endif                                     # hcb 040105  24390
Endif

# Sélection numéro article
WFIL1 += "&[F:STJ]ITMREF=[M:SPR1]ITMREF"    # graph
If WFILX=""
  WFILX  = "[F:STO]ITMREF=[M:SPR1]ITMREF"   # graph
Else
  WFILX += "&[F:STO]ITMREF=[M:SPR1]ITMREF"  # graph
Endif
# Pas de selection date et tous mouvements si filtre chrono stock
If WSTOCOUSEL <> 0                   # graph
  WFILX += "&[F:STO]STOCOU=WSTOCOUSEL"  # graph
Endif
# Filtre date
If WINQLTI <> 0                     # graph
  WFIL1 += "&[F:STJ]IPTDAT>=WSTRDAT"
Endif

# Pour filtre les enregistrements bidon d'inventaire
WFIL2 = "[F:STJ]TRSTYP<>0"

# Filtre types de mvts
If !(WMISFLG=2 & WSTDFLG=2 & WCHGFLG=2) & !(WMISFLG=1 & WSTDFLG=1 & WCHGFLG=1)   # graph
  If WSTDFLG = 2                                         # graph
    If WMISFLG = 2      WFIL2 += "&[F:STJ]TRSTYP<>23"    # graph
    Else If WCHGFLG = 2 WFIL2 += "&!find([F:STJ]TRSTYP,7,8,9,21,25)"  # graph
         Else             WFIL2 += "&!find([F:STJ]TRSTYP,7,8,9,21,23,25)"
         Endif
    Endif
  Else
    If WMISFLG = 2                                      # graph
       If WCHGFLG = 2   WFIL2 += "&find([F:STJ]TRSTYP,7,8,9,21,23,25)"  # graph
       Else               WFIL2 += "&find([F:STJ]TRSTYP,7,8,9,21,25)"
       Endif
    Else
       If WCHGFLG = 2   WFIL2 += "&[F:STJ]TRSTYP=23"      # graph
       Endif
    Endif
  Endif
Endif

# Filtre formule
WFILF = "1=1"
Return
############################################################
############################################################
$ERR_FORM1
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)
&            Order By Key STJ0
Resume

$ERR_FORM3
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)
&            Order By ITMREF; LOT; STOFCY; IPTDAT; MVTSEQ; UPDCOD
Resume

$ERR_FORM4
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)
&            Order By ITMREF; LOC; STOFCY; IPTDAT; MVTSEQ; UPDCOD
Resume

$ERR_FORM5
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)
&            Order By ITMREF; STA; STOFCY; IPTDAT; MVTSEQ; UPDCOD
Resume

$ERR_FORM6
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)
&            Order By ITMREF; PCU; PCUSTUCOE; STOFCY; IPTDAT; MVTSEQ; UPDCOD
Resume

$ERR_FORM9
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)
&            Order By IPTDAT Asc; CREMVTDAT Asc; CREMVTTIM Asc; MVTSEQ Desc; MVTIND Desc : # Bug 88530
#&            Order By ITMREF; IPTDAT; STOFCY; MVTSEQ; UPDCOD                            : # Bug 88530
Resume

$ERR_FORM10
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)
&            Order By ITMREF; CREDAT Desc; CRETIM Desc; IPTDAT Desc; MVTSEQ
Resume

$ERR_FORM11
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)
&            Order By ITMREF; CREDAT; CRETIM; IPTDAT; MVTSEQ
Resume

$ERR_FORM
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFILS)
&            Order By IPTDAT Desc; CREMVTDAT Desc; CREMVTTIM Desc; MVTSEQ Asc; MVTIND Asc : # Bug 88530
#&            Order By ITMREF; IPTDAT Desc; STOFCY; MVTSEQ; UPDCOD                        : # Bug 88530
Resume

############################################################
############################################################
$AGREG
Raz WAGR
############################################################
Subprog AV_QTYPCU(VALEUR)
Variable Decimal VALEUR
If nolign > 0
  If VALEUR < 0
    pcolor = GCOUL(1)
  Else
    pcolor = GCOUL(0)
  Endif
Endif
End
############################################################
Subprog AV_QTYSTU(VALEUR)
Variable Decimal VALEUR
If nolign > 0
  If VALEUR < 0
    pcolor = GCOUL(1)
  Else
    pcolor = GCOUL(0)
  Endif
Endif
End
######################################################################################
Subprog IB_NBLIG
End

