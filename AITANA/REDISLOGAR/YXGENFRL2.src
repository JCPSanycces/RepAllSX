#<AdxTL>@(#)0.0.0.0 $Revision$ 

$ACTION
  Case ACTION
    When "CREA_FRL" : Gosub CREA_FRL
  Endcase
Return

#####################################################################################

$CREA_FRL
  If [F:XHO]YBPSNUM="" : Return : Endif

  If clalev([F:YPFM])=0 : Local File PARFRMTYP [YPFM] : Endif
  Read [F:YPFM]PFM0=[F:XHO]TYPFRM
  If fstat : Raz [F:YPFM] : Endif
  If [F:YPFM]YGENPURLINE<>2 : Return : Endif

  Local Integer YAINT
  If clalev([F:YBPR])=0 : Local File BPARTNER [YBPR] : Endif
  If clalev([F:YFRL])=0 : Local File FORMSL   [YFRL] : Endif
  If clalev([F:FRA])=0  : Local File FORMSLA   [FRA] : Endif

  Read [F:YFRL]FRL0=[F:FRL]FRMNUMLIG
  If fstat : Return : Endif

  Read [F:YBPR]BPR0=[F:XHO]YBPSNUM
  If fstat : Raz [F:YBPR] : Endif

  Read [F:FRA]FRA0=[F:FRL]FRMNUMLIG;1000
  If fstat
    Raz [F:FRA]
    [F:FRA]FRMNUMLIG  = [F:FRL]FRMNUMLIG
    [F:FRA]NUMLIGFRL2 = 1000
    [F:FRA]BPSNUM     = [F:XHO]YBPSNUM
    [F:FRA]ITMREFPUR  = [F:FRL]ITMREF
    [F:FRA]ITMDESPUR  = [F:FRL]ITMDES
    # [F:FRA]STOFCY     = [F:FRL]SALFCY
	[F:FRA]STOFCY     = "ES1AG" # JPL
    [F:FRA]UOM        = [F:FRL]SAU
    [F:FRA]QTYUOM     = [F:FRL]QTY
    [F:FRA]EXTRCPDAT  = [F:XHO]YEXTRCPDAT
    [F:FRA]PURCUR     = [F:YBPR]CUR
    [F:FRA]CURTYP     = 1
    Gosub TRT_PRICE

    For YAINT=0 To max(dim([F:FRA]DIE), dim([F:FRL]DIE))-1
      [F:FRA]DIE(YAINT) = [F:FRL]DIE(YAINT)
    Next
    [F:FRA]CCE1  = [F:FRL]CCE(0)
    [F:FRA]CCE2  = [F:FRL]CCE(1)
    [F:FRA]CCE3  = [F:FRL]CCE(2)
    [F:FRA]CCE4  = [F:FRL]CCE(3)
    [F:FRA]CCE5  = [F:FRL]CCE(4)
    [F:FRA]CCE6  = [F:FRL]CCE(5)
    [F:FRA]CCE7  = [F:FRL]CCE(6)
    [F:FRA]CCE8  = [F:FRL]CCE(7)
    [F:FRA]CCE9  = [F:FRL]CCE(8)
    [F:FRA]CCE10 = [F:FRL]CCE(9)
    [F:FRA]CCE11 = [F:FRL]CCE(10)
    [F:FRA]CCE12 = [F:FRL]CCE(11)
    [F:FRA]CCE13 = [F:FRL]CCE(12)
    [F:FRA]CCE14 = [F:FRL]CCE(13)
    [F:FRA]CCE15 = [F:FRL]CCE(14)
    [F:FRA]CCE16 = [F:FRL]CCE(15)
    [F:FRA]CCE17 = [F:FRL]CCE(16)
    [F:FRA]CCE18 = [F:FRL]CCE(17)
    [F:FRA]CCE19 = [F:FRL]CCE(18)
    [F:FRA]CCE20 = [F:FRL]CCE(19)
    [F:FRA]CHRACHAT = 0
    [F:FRA]BUDCOEPUR = ""

    Write [F:FRA]
    If fstat
      GOK = 0
      GMESSAGE = mess(5,6100,1)
    Else
      [F:YFRL]COSPRI = [F:FRA]COSPRIPUR
      [F:YFRL]GROPRI = [F:FRA]COSPRIPUR

      Rewrite [F:YFRL]
      If fstat
        GOK = 0
        GMESSAGE = mess(6,6100,1)
      Endif
    Endif
  Endif

Return

#####################################################################################

$TRT_PRICE
  Local Integer X, WSTAT, WZNBREM
  Local Decimal AUXDEC, WZREM(9)

  [F:FRA]COEPUR = [F:XHO]YCOEPUR
  If [F:FRA]COEPUR=0 : [F:FRA]COEPUR = 1 : Endif

  Raz [L]WZREM,[L]WZNBREM
  If [F:XHO]YGROPRI<>0
    [F:FRA]GROPRIPUR = [F:XHO]YGROPRI
    If dim([F:FRA]DISPUR)>0
      [F:FRA]DISPUR = [F:XHO]YDISPUR
      [L]WZREM(0) = [F:XHO]YDISPUR
      [L]WZNBREM += 1
    Endif

    For [L]X=2 To 9
      If evalue("dim([F:FRA]DISPUR" + num$([L]X) + ")>0") and
&       evalue("dim([F:XHO]YDISPUR" + num$([L]X) + ")>0")
        Assign "[F:FRA]DISPUR" + num$([L]X) With evalue("[F:XHO]YDISPUR" + num$([L]X))
        [L]WZREM([L]WZNBREM) = evalue("[F:XHO]YDISPUR" + num$([L]X))
        [L]WZNBREM+=1
      Endif
    Next
  Else
    [F:FRA]GROPRIPUR = [F:XHO]PRIX
  Endif

  # Precio neto en divisa de compra
  [L]AUXDEC = [F:FRA]GROPRIPUR
  Call CALNET(2, "", [F:FRA]GROPRIPUR, [L]WZREM, [F:FRA]QTYUOM, [L]AUXDEC, [F:FRA]PURCUR) From TRTPRICE
  [F:FRA]GROPRINET = [L]AUXDEC * [F:FRA]QTYUOM
  # Precio neto en divisa local
  [L]AUXDEC = [F:FRA]GROPRINET
  If [L]AUXDEC<>0 & [F:FRA]PURCUR<>[F:FRL]CURFRL
    Call CONVERT([F:FRA]PURCUR, [F:FRL]CURFRL, [F:FRL]CURFRL, [F:FRA]CURTYP,
&                 datesyst, [L]AUXDEC, [L]AUXDEC, [L]WSTAT) From TRTDEV
  Endif
  [L]AUXDEC = arr([L]AUXDEC, [V]GARODEV)
  [F:FRA]NETAMTPUR = [L]AUXDEC
  If [F:FRA]QTYUOM<>0
    [F:FRA]COSPRIPUR = ([L]AUXDEC * [F:FRA]COEPUR)/[F:FRA]QTYUOM
  Endif
  [F:FRA]COSPRIPUR = arr([F:FRA]COSPRIPUR, [V]GARODEV)
Return




