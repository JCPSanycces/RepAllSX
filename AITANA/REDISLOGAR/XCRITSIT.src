Local Char PARAM(30)(1..16),VALEUR(10) 

Raz [L]PARAM, [L]VALEUR

GACTION="TRTGENESIT"

[L]PARAM(1)=""
[L]PARAM(2)="" 
[L]PARAM(3)="" 
[L]PARAM(4)="" 
Call TRAITE_CHAR(VALEUR,PARAM,"","XSITUATION","GENESIT",4) From GTRAITE
End


#----------------------------------------------------------------------------------------------------
# Ecran GENESIT
#----------------------------------------------------------------------------------------------------

########################
Subprog D_CALDAT(VALEUR)
Variable Date VALEUR
VALEUR=datesyst
End

########################
Subprog AP_ALLPJT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    Effzo [M]OPPINF,OPPSUP
    Grizo [M]OPPINF,OPPSUP
Elsif [M]ACTGRIZO=0
    Actzo [M]OPPINF,OPPSUP
Endif
End

########################
Subprog AP_ALLTYPPJT(VALEUR)
Variable Integer VALEUR

If VALEUR=2
    Effzo [M]TYPPJTINF,TYPPJTSUP
    Grizo [M]TYPPJTINF,TYPPJTSUP
Elsif [M]ACTGRIZO=0
    Actzo [M]TYPPJTINF,TYPPJTSUP
Endif
End

########################
Subprog AP_ALLFCY(VALEUR)
Variable Integer VALEUR

If VALEUR=2
    Effzo [M]FCYINF,FCYSUP
    Grizo [M]FCYINF,FCYSUP
Elsif [M]ACTGRIZO=0
    Actzo [M]FCYINF,FCYSUP
Endif
End

########################
Subprog AP_ALLBPC(VALEUR)
Variable Integer VALEUR

If VALEUR=2
    Effzo [M]BPCINF,BPCSUP
    Grizo [M]BPCINF,BPCSUP
Elsif [M]ACTGRIZO=0
    Actzo [M]BPCINF,BPCSUP
Endif
End

########################
Subprog AP_ALLGESINTO(VALEUR)
Variable Integer  VALEUR
If VALEUR=2
    Effzo [M]GESINTINFO,GESINTSUPO
    Grizo [M]GESINTINFO,GESINTSUPO
Elsif [M]ACTGRIZO=0
    Actzo [M]GESINTINFO,GESINTSUPO
Endif
End

########################
Subprog AP_CALSITFLG(VALEUR)
Variable Integer VALEUR

If VALEUR=1
    Effzo [M]SITINF,SITSUP
    Grizo [M]SITINF,SITSUP
Elsif [M]ACTGRIZO=0
    Actzo [M]SITINF,SITSUP
Endif
End

########################
Subprog AP_RECSITFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=1
    Effzo [M]SITVLYINF,SITVLYSUP
    Grizo [M]SITVLYINF,SITVLYSUP
Elsif [M]ACTGRIZO=0
    Actzo [M]SITVLYINF,SITVLYSUP
Endif
End


########################
Subprog AV_INITZON(VALEUR)
Gosub INIZON
End

$INIZON
Call AP_ALLPJT([M]ALLPJT)
Call AP_ALLTYPPJT([M]ALLTYPPJT)
Call AP_ALLFCY([M]ALLFCY)
Call AP_ALLBPC([M]ALLBPC)
Call AP_ALLGESINTO([M]ALLGESINTO)
Call AP_CALSITFLG([M]CALSITFLG)
Call AP_RECSITFLG([M]RECSITFLG)
Call AP_GENSITFLG([M]GENSITFLG)
Return

########################
Subprog AM_SITINF(VALEUR)
Variable Char    VALEUR()
If [M]GENSITFLG=2 & VALEUR<>""
  [M]BUDFLG=0
  [M]GENSITFLG=1
  Affzo [M]GENSITFLG,BUDFLG
Endif
End

########################
Subprog AM_SITVLYINF(VALEUR)
Variable Char    VALEUR()
If [M]GENSITFLG=2 & VALEUR<>""
  [M]BUDFLG=0
  [M]GENSITFLG=1
  Affzo [M]GENSITFLG,BUDFLG
Endif
End


########################
Subprog AM_SITSUP(VALEUR)
Variable Char    VALEUR()
If [M]GENSITFLG=2 & VALEUR<>""
  [M]BUDFLG=0
  [M]GENSITFLG=1
  Affzo [M]GENSITFLG,BUDFLG
Endif
End

########################
Subprog AM_SITVLYSUP(VALEUR)
Variable Char    VALEUR()
If [M]GENSITFLG=2 & VALEUR<>""
  [M]BUDFLG=0
  [M]GENSITFLG=1
  Affzo [M]GENSITFLG,BUDFLG
Endif
End

#==========================================================================================
Subprog CL_ICO1(VALEUR)
Variable Char    VALEUR()
[M:DIA]CALDAT=date$
Affzo [M:DIA]CALDAT
End

#==========================================================================================
Subprog CL_ICO2(VALEUR)
Variable Char    VALEUR()
[M:DIA]CALDAT=eomonth(addmonth(date$,-1))
Affzo [M:DIA]CALDAT
End

#==========================================================================================
Subprog AP_GENSITFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=1
  [M]BUDFLG=0
  Grizo [M]BUDFLG
  Affzo [M]BUDFLG
Elsif [M]ACTGRIZO=0
  If [M]BUDFLG=0
    [M]BUDFLG=1
  Endif
  Actzo [M]BUDFLG
Endif
End
End

########################
Subprog AV_ACTGRIZO(VALEUR)
Variable Decimal  VALEUR

#1 Situation, 2 Affaire
#If PARAM(1)="" & PARAM(2)="" & PARAM(3)=""
#  [M:DIA]ACTGRIZO=0
#If PARAM(1)<>""
#  [M:DIA]ACTGRIZO=1
#Elsif PARAM(2)<>""
#  [M:DIA]ACTGRIZO=2
#Elsif PARAM(3)<>""
#  [M:DIA]ACTGRIZO=3
#Endif

Case VALEUR
  When 0
    Actzo 20
  When 1
    Grizo [M]
    Actzo [M]CALDAT,ICO1,ICO2,TRAFICFLG
  When 2,3
    Grizo [M]
    Actzo [M]CALDAT,ICO1,ICO2,BUDFLG,TRAFICFLG
Endcase
End

