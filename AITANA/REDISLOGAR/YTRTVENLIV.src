#####################################################################################
# CodAct: YA039 - Campos específicos (precio en albaran)
#####################################################################################

$ACTION

Case ACTION
  When "ALISOHSDH"  : Gosub LOAD_LINES
  When "ALICDESDD"  : Gosub LOAD_LINES

Endcase

Return

$LOAD_LINES
  [M:SDH0]YDLVPRI = [F:BPC]YDLVPRI
######YA032 - Tratamiento de la cabecera traspasable ########
Case GFONC1
  When 'GESPRH'
    #Pasamos los datos entre pantallas
    If [M:SDH0]YSDHTEX<>"" | [F:PRH]YPRHTEX <> ""
     [M:SDH0]YSDHTEX = [F:PRH]YPRHTEX
     [F:SDH]YSDHTEX = [M:SDH0]YSDHTEX
    Endif
    If func AFNC.PARAM("ZAPPSDH",[M:SDH0]STOFCY) = "1"
     [M:SDH1]ZAPPFLG = 4
     Affzo [M:SDH1]ZAPPFLG
    Endif
  When 'GESSOH'
    #Pasamos los datos entre pantallas
    If [M:SDH0]YSDHTEX<>"" | [F:SOH]YSOHTEX <> ""
     [M:SDH0]YSDHTEX = [F:SOH]YSOHTEX
     [F:SDH]YSDHTEX = [M:SDH0]YSDHTEX
    Endif
    If func AFNC.PARAM("ZAPPSDH",[M:SDH0]STOFCY) = "1"
     [M:SDH1]ZAPPFLG = 4
     Affzo [M:SDH1]ZAPPFLG
    Endif
Endcase
############################################################
Return




