#<AdxTL>@(#)1.0.0.0 $Revision$
#ACV#X11
#TIT#Gestion des résultats questionnaires

#==========================================================================================
# Gestion de l'objet   : Gestion de l'objet résultat questionnaire
#                        
# Auteur               : CGUES
# Date de création     : 11/2000 
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 22/07/2002    CDOUE        Modélisation Web        
#==========================================================================================

GBIDC1=""
GBIDC2=""
GFONC1="GESCON"
Call OBJET("XON",GBIDC1,GBIDC2) From GOBJET
End




$ACTION
#===== Actions scénario objet
Case ACTION
    When "AVANT_OUVRE" : Gosub AVANT_OUVRE  From SPVOBJRES
    When "SETBOUT"     : Gosub SETBOUT      From SPVOBJRES
    When "LIENS2"      : Gosub LIENS2       From SPVOBJRES
    When Default
Endcase

Return


#=========================================================================================================================
# SECTION CONTENANT LES SOUS-PROGRAMMES DE CONTROLE SUR CHAMPS
#=========================================================================================================================

########################################
Subprog AS_CODQUS(VALEUR)
Variable Char    VALEUR()
mkstat=2
End



###########################################################################################
# A conserver pour compatibilité avec les objets non modélisés Web
###########################################################################################

Subprog VISUQSN(CODLIK,CLE1,CLE2)
Value Char CODLIK,CLE1,CLE2

Local Integer SVGCONSULT
Local Char VALEUR(20),CPN1(45)

Local File RESQSN [XRES]

[L]SVGCONSULT=[V]GCONSULT


[L]CPN1=[L]CODLIK+[L]CLE1+[L]CLE2

Read [XRES]RES0(1)=[L]CPN1
If !fstat
    [V]GCONSULT=2
    Call OBJET("RES",[L]CPN1,"") From GOBJET
    
    [V]GCONSULT=[L]SVGCONSULT
Else
    Call MESSAGE(mess(14,[V]GXMSGPSA,1))From GESECRAN
Endif
Close File [XRES]
End
