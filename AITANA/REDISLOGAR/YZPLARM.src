#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Infbox(ACTION)
#Case ACTION
#  When "CONTPRT" : Gosub CONTPRT
#  When "EXEC"    : Gosub EXEC
#Endcase
Return
#===============================================================
$ALIM_ETAT
#RM * 75916
Local Char NUMCOPIAS
Call PARAML([M:RPT]VALEUR12,"NUMCOPIAS",NUMCOPIAS) From ADOVAL

#-----
If [L]WADXLOG=0
  GOK=1
  Trbegin [ARM]
Endif
#----- Création des enregistrements dans la table AREPORTM -----#
Raz [F:ARM]
[F:ARM]NUMREQ = REQUETE
[F:ARM]USR    = GUSER
[F:ARM]RPTCOD = ETAT
[F:ARM]NUMLIG = LIGNE
[F:ARM]SEQREQ = SEQUENCE
[F:ARM]CLEA1  = [F:SDH]SDHNUM
[F:ARM]CREDAT = date$
#-----
For I=1 To max(NUMCOPIAS,1)
  [F:ARM]NUMLIG+=1
#  Gosub ALIMETAT_PE From ETAT  --->SALTO A GPOINT="ALIMETAT"

  Write [ARM]
  If fstat  GOK=0 : Call FSTA("ARM") From GLOCK : Break : Endif
Next I


#-----
If [L]WADXLOG=0
  Commit
Endif
Return
#-----
$AB_ALIM_ETAT
If [L]WADXLOG=0
  Rollback
Endif
Return

