Subprog C_YCNFRCPDAT(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "YCNFRCPDAT" : GZNUM = 104042 : Endif
Gosub _AFF
End

