#<AdxTL>@(#)0.0.0.0 $Revision$
# Supervisor
# Gesti¾n de la mßscara YPOC1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [18/12/2019]
A_HEURE = "11:54:26"
A_USER  = "AIT07"
A_STAMP = "20191218115426"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask YPOC1 [YPOC1]
Gosub HORODAT
Local Inpbox "YPOC1" From GFONCTION At A_STAMP With A_WINDPREV Mask [YPOC1] As [SIM_]
Grizo [YPOC1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [YPOC1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=20
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1YPOC1
Onevent CONTROL Call C_NBLIG From W1YPOC1
Onevent AFTER_LINE Call APRES_NBLIG From W1YPOC1
Return

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action SPE
Call AS_NBLIG From SPEYPOC
Gosub _AFF
End

Subprog C_NBLIG
Local Decimal BASPAG
## Action DIVLINCONT
Call INSERE("YPOCLIN") From TABLEAUX
If mkstat : GERR = 1 : GZONE = "NBLIG" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog APRES_NBLIG
Local Decimal BASPAG
## Action DIVLINNUM
Call LINNUM("YPOCLIN") From TABLEAUX
If mkstat : End : Endif
Gosub _AFF
End

$ON_YPOCNUM
Return

$ON_YPOHNUM
Onevent CONTROL Call C_YPOHNUM(zc) From W1YPOC1
Onevent BEFORE_INPUT Call AS_YPOHNUM(zc) From W1YPOC1
Return

Subprog AS_YPOHNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(33920,GBOUT1) From OBJDIV
Call TEXTE(41059,GBOUTS) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_YPOHNUM(zc) From W1YPOC1
Onkey   2 Titled GBOUTS Call S_YPOHNUM(zc) From W1YPOC1
Gosub _AFF
End

Subprog C_YPOHNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "YPOHNUM" : GZNUM = 104157 : Endif
If !GWEBSERV
 If !mkstat
  ## Action CONTVCR
  Call CONTVCR(VALEUR) From TRTDIV
  If mkstat : GERR = 1 : GZONE = "YPOHNUM" : GZNUM = 104157 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_YPOHNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action VCRSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "VCRSEL"
 PARMSK(1) = "POH"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"VCRSEL","TRTDIV","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_YPOHNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action VCRTUN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "VCRTUN"
 Call OBJET_CHAR(VALEUR,"POH","") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_YPOPLIN
Onevent CONTROL Call C_YPOPLIN(zc) From W1YPOC1
Onevent AFTER_CHANGE Gosub AMM_YPOPLIN From W1YPOC1
Return

Subprog C_YPOPLIN(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "YPOPLIN" : GZNUM = 104158 : Endif
If !mkstat
 ## Action SPE
 Call C_YPOPLIN(VALEUR) From SPEYPOC
 If mkstat : GERR = 1 : GZONE = "YPOPLIN" : GZNUM = 104158 : Endif
Endif
Gosub _AFF
End

$AMM_YPOPLIN
Call AM_YPOPLIN(zc)
If !mkstat & GOBJET
 zoncou = "YPOPLIN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_YPOPLIN(VALEUR)
Variable Decimal VALEUR
## Action SPE
Call AM_YPOPLIN(VALEUR) From SPEYPOC
If mkstat : GERR = 1 : GZONE = "YPOPLIN" : GZNUM = 104158 : Endif
Gosub _AFF
End

$ON_YITMREF
Return

$ON_ZYITMREF
Onevent BEFORE_AREA Gosub AV_ZYITMREF From W1YPOC1
Return

$AV_ZYITMREF
Call LECTEXTRA(zc,"ITMMASTER","DES1AXX",num$([M]YITMREF(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_YQTY
Onevent BEFORE_AREA Gosub AV_YQTY From W1YPOC1
Onevent CONTROL Call C_YQTY(zc) From W1YPOC1
Onevent AFTER_CHANGE Gosub AMM_YQTY From W1YPOC1
Return

$AV_YQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find("",GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]YQTY(indice) With "Nz:"+GUNTFMT
Gosub _AFF
Return

Subprog C_YQTY(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "YQTY" : GZNUM = 23231 : Endif
If !mkstat
 ## Action SPE
 Call C_YQTY(VALEUR) From SPEYPOC
 If mkstat : GERR = 1 : GZONE = "YQTY" : GZNUM = 23231 : Endif
Endif
Gosub _AFF
End

$AMM_YQTY
Call AM_YQTY(zc)
If !mkstat & GOBJET
 zoncou = "YQTY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_YQTY(VALEUR)
Variable Decimal VALEUR
## Action SPE
Call AM_YQTY(VALEUR) From SPEYPOC
If mkstat : GERR = 1 : GZONE = "YQTY" : GZNUM = 23231 : Endif
Gosub _AFF
End

$ON_YTIPPRI
