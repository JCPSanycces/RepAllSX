####################################################################################
#YSBUPIH  : Gestion de los puntos de entrada de SUBPIH                  26/06/2019
#Marca: <YA020>
#Programador: ALIVE
####################################################################################
$ACTION
  Case ACTION
    When "ORIPRIFAC" : Gosub ORIPRIFAC
  Endcase
Return
####################################################################################
$ORIPRIFAC
  # Variable modificable en el punto de entrada :                          #
   #    ORIPRIRCP : Indicador del precio de origen                         #
   #                1 = a partir del precio del pedido (valor por defecto) #
   #                2 = a partir del precio de la recepción                #
   #-----------------------------------------------------------------------#
   ORIPRIRCP = 2
Return

