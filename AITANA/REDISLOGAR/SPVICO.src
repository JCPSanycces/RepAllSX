#<AdxTL>@(#)1.0.0.0 $Revision:   1.20  $ Gestion du masque SCHICO1
#ACV#X13
#TIT#Gestion de l'objet ICO

#LBO 07/2002

GBIDC1=""
GBIDC2=""
Call OBJET("ICO",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet ICO
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "MODIF"     : Gosub MODIF      From SPVOBJICO
  When "APRES_MOD" : Gosub APRES_MOD  From SPVOBJICO
  When "AB_MODIF"  : Gosub AB_MODIF   From SPVOBJICO
  When "LIENS"     : Gosub LIENS      From SPVOBJICO
  When "INIMOD"    : Gosub INIMOD     From SPVOBJICO
  When "INICRE"    : Gosub INICRE     From SPVOBJICO
  When "VERIF_CRE" : Gosub VERIF_CRE  From SPVOBJICO
  When "VERIF_MOD" : Gosub VERIF_MOD  From SPVOBJICO
Endcase

Return

#####################################################################################
# Ecran SCHICO1 [ICO1]
#####################################################################################

#-----------------------------------
Subprog AM_CALTXT(VALEUR)
Variable Integer VALEUR
Call ACTGRIZO(VALEUR,[M:ICO1]DESTXT,[M:ICO1]COLTXT,[M:ICO1]COLFND) From SPVOBJICO
End

#-----------------------------------
Subprog AS_COLTXT(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  VALEUR="0"
Endif
End

#-----------------------------------
Subprog AM_COLTXT(VALEUR)
Variable Char    VALEUR()
Call ACTGRIZO([M:ICO1]CALTXT,[M:ICO1]DESTXT,VALEUR,[M:ICO1]COLFND) From SPVOBJICO
End

#-----------------------------------
Subprog AS_COLFND(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  VALEUR="F"
Endif
End

#-----------------------------------
Subprog AM_COLFND(VALEUR)
Variable Char    VALEUR()
Call ACTGRIZO([M:ICO1]CALTXT,[M:ICO1]DESTXT,[M:ICO1]COLTXT,VALEUR) From SPVOBJICO
End

#-----------------------------------
Subprog C_COLFND(VALEUR)
Variable Char VALEUR
If VALEUR<>"" & VALEUR=[M:ICO1]COLTXT | ((VALEUR<"A" | VALEUR>"F") & (VALEUR<"0" | VALEUR>"9"))
  mkstat=1
Endif
End

#-----------------------------------
Subprog AM_DESTXT(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char ZCAR
For [L]I=1 To len(VALEUR)
  [L]ZCAR=mid$(VALEUR,[L]I,1)
  If ([L]ZCAR<"A" | [L]ZCAR>"Z") & ([L]ZCAR<"0" | [L]ZCAR>"9")
    [V]GMESSAGE="Texte incorrect"
    mkstat=1
    Break
  Endif
Next
If !mkstat
  Call ACTGRIZO([M:ICO1]CALTXT,VALEUR,[M:ICO1]COLTXT,[M:ICO1]COLFND) From SPVOBJICO
Endif
End

#-----------------------------------
Subprog C_COLTXT(VALEUR)
Variable Char    VALEUR()
If (VALEUR<"A" | VALEUR>"F") & (VALEUR<"0" | VALEUR>"9")
  mkstat=1
Endif
End

