#<AdxTL>@(#)11.0.0.0 $Revision:   1.20  $ Gestion du masque SCHSYNC
#ACV#X13
#TIT#Gestion de l'action SCHSYNC

#LBO 04/2003

Local Char PARAM(30)(1..16),VALEUR(10) 

PARAM(1)=""
PARAM(2)=""
PARAM(3)=""
PARAM(4)=""
Call TRAITE_CHAR(VALEUR,PARAM,"","XSYNCHRO2","SCHSYNC",3) From GTRAITE
End


#-----------------------------------------------------------------------
# Ecran SCHSYNC [DIA]
#-----------------------------------------------------------------------

#--------------------------------
Subprog AM_PLANCOD(VALEUR)
Variable Char    VALEUR()
Effzo [M:DIA]SYNVP,SYNORA
Call ACTGRIZO(VALEUR) From XSYNCHRO2
End

#--------------------------------
Subprog C_SYNORA(VALEUR)
Variable Integer VALEUR
If VALEUR=1
  Grizo [M:DIA]SYNFCT
Else
  Actzo [M:DIA]SYNFCT
Endif
End

#--------------------------------
Subprog AV_ACTGRIZO(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
  Grizo [M:DIA]PLANCOD
ELSe
  Actzo [M:DIA]PLANCOD
Endif
Call ACTGRIZO([M:DIA]PLANCOD) From XSYNCHRO2
End

#--------------------------------
Subprog C_SYNVP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
  Grizo [M:DIA]SYNVPFL1,SYNVPFL2,SYNVPFL3,SYNVPFL4
Else
  Actzo [M:DIA]SYNVPFL1,SYNVPFL2,SYNVPFL3,SYNVPFL4
Endif
End

