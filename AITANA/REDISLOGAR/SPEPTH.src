######################################################################################

Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()

[M:PTH0]BPSINV = VALEUR

End


######################################################################################


$APRES_CRE
Return
  If [F:PTH]STOFCY = 'ES1SAT'
  #recorrer las lineas
    Filter [F:PTD] Where [F:PTD]PTHNUM = [F:PTD]PTHNUM
    For [PTD]
    #mirar movimientos de stock
      Filter [F:STJ] Where [F:STJ]VCRNUM = [PTH]PTHNUM & [F:STJ]VCRLIN = [PTD]PTDLIN
&                        & [F:STJ]TRSTYP = 3 & [F:STJ]UPDCOD = 2
      For [STJ]
      #si el articulo esta marcado como parque
      #0259970012
        If !clalev ([ZITM]) : Local File ITMMASTER [ZITM] : Endif
        Read [F:ZITM]ITM0 = [F:STJ]ITMREF
        If fstat = 0
          If [F:ZITM]CREMAC = 2
            #Si tiene numero de serie
            If [STJ]SERNUM <>''
			 #cambiamos el campo estado de la pantalla MAC1
			 If !clalev ([ZMAC]) : Local File MACHINES [ZMAC] : Endif
             Read [ZMAC]MAC5 = [STJ]ITMREF;[STJ]SERNUM
             If fstat = 0
		        If !clalev ([ZXMA]) : Local File MACHINEFL [ZXMA] : Endif
                Trbegin [ZXMA]
                Readlock [ZXMA]XMA0 = [ZMAC]MACNUM
                If fstat=0
                  [F:ZXMA]STATITM = 'DFA'
                  Rewrite [ZXMA]
                  Commit
                   #encontramos MAC, rellenamos la tabla YHISSTAMAC
                     If !clalev ([YHSM]) : Local File YHISSTAMAC [YHSM] : Endif
                     #añadimos los datos a la tabla
                     Read [YHSM]YHSM0(1)= [ZMAC]MACNUM
                     Read [YHSM] Last
                     [YHSM]LINNUM +=1000
                     [YHSM]BPRNUM = "Redislogar"
                     [YHSM]YCAMSTADAT = date$
                     [YHSM]MACNUM = [ZMAC]MACNUM
				     [YHSM]STATITM = [ZXMA]STATITM
                     #grabamos la tabla
                     Trbegin [YHSM]
                     Write [YHSM]
                     If fstat
                       Rollback
                     Else
                       Commit
                     Endif
                Endif
                  Unlock [ZXMA]
              Else
                Rollback
              Endif

            Else
              #error, damos mensaje diciendo que el articulo no tiene numero de serie
              ERRORNUMSER = 1
            Endif
          Endif
        Endif
      Next
      Filter [STJ]
    Next
    Filter [PTD]
    If ERRORNUMSER = 1
      #mostramnos el mensaje
      GERR = 2
      GMESSAGE = "Algún articulo no tiene numero de serie y no se pudo añadir histórico de parque" : Return
    Endif
  Endif
Return
