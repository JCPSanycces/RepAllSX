$ACTION
Case ACTION
 When "APRES_CRE"  :  Gosub APRES_CRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "PICKE"  :  Gosub PICKE
 When "FIN_ACTION" : Gosub FIN_ACTION
 When Default
Endcase
Return
######################################################################################
## ## YA020 - Tipo de precio
######################################################################################
Subprog AM_YGROPRI(VALEUR)
Variable Decimal VALEUR

Variable Decimal PRECIO

  Case [M:PTH1]YTIPPRI(nolign -1)
    When 1 : PRECIO  = VALEUR
    When 2 : PRECIO  = VALEUR / 10
    When 3 : PRECIO  = VALEUR / 100
    When 4 : PRECIO  = VALEUR / 1000
  Endcase

  # Llamamos a las funciones del campo GROPRI, como si se hubiese modificdo en pantalla
  Call AP_GROPRI(PRECIO) From SUBPTH
  #Call PAMAPPFLG("PTH1",nolign-1,"GROPRI") From TRTACHAPP1
  Call PAMDISCRG( PRECIO , "PTH1" , 0 , nolign-1 , [M:PTH1]NETCUR(nolign-1)) From TRTACHPRI1
  Call PAMVATFLG("PTH1",nolign-1,"GROPRI") From TRTACHFAC1
  #Call AM_GROPRI(PRECIO) From SUBPOH

  # Finalmente actualizamos el campo standard
  [M:PTH1]GROPRI(nolign -1) = PRECIO
  Affzo [M:PTH1]GROPRI(nolign -1)

End
######################################################################################
## YA020 - Tipo de precio
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()


If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
Read [F:ZITM]ITM0 = VALEUR
If fstat = 0
  [M:PTH1]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
  Affzo [M:PTH1]YTIPPRI(nolign -1)
Endif

Case [M:PTH1]YTIPPRI(nolign -1)
  When 1 : [M:PTH1]YGROPRI(nolign -1) = [M:PTH1]GROPRI(nolign -1)
  When 2 : [M:PTH1]YGROPRI(nolign -1) = [M:PTH1]GROPRI(nolign -1) * 10
  When 3 : [M:PTH1]YGROPRI(nolign -1) = [M:PTH1]GROPRI(nolign -1) * 100
  When 4 : [M:PTH1]YGROPRI(nolign -1) = [M:PTH1]GROPRI(nolign -1) * 1000
Endcase
Affzo [M:PTH1]YGROPRI(nolign -1)

End
######################################################################################

######################################################################################
## YA020 - Tipo de precio
######################################################################################
Subprog AM_QTYUOM(VALEUR)
Variable Decimal VALEUR

If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
Read [F:ZITM]ITM0 = [M:PTH1]ITMREF(nolign -1)
If fstat = 0
  [M:PTH1]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
  Affzo [M:PTH1]YTIPPRI(nolign -1)
Endif

Case [M:PTH1]YTIPPRI(nolign -1)
  When 1 : [M:PTH1]YGROPRI(nolign -1) = [M:PTH1]GROPRI(nolign -1)
  When 2 : [M:PTH1]YGROPRI(nolign -1) = [M:PTH1]GROPRI(nolign -1) * 10
  When 3 : [M:PTH1]YGROPRI(nolign -1) = [M:PTH1]GROPRI(nolign -1) * 100
  When 4 : [M:PTH1]YGROPRI(nolign -1) = [M:PTH1]GROPRI(nolign -1) * 1000
Endcase
Affzo [M:PTH1]YGROPRI(nolign -1)

End
