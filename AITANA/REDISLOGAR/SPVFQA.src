#<AdxTL>@(#)12.0.0.0 $Revision:   1.11  $ Gestion du masque FREQASS1
#ACV#X11
#TIT#Fréquence

GBIDC1=""
GBIDC2=""
Call OBJET("FQA",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SETBOUT"  :  Gosub SETBOUT    From SPVOBJFQA
 When "VERIF_CRE":  Gosub VERIF_CRE  From SPVOBJFQA
 When "VERIF_MOD":  Gosub VERIF_MOD  From SPVOBJFQA
 When "INICRE"   :  Gosub INICRE     From SPVOBJFQA
 When "INIMOD"   :  Gosub INIMOD     From SPVOBJFQA
 When "CHANGE"   :  Gosub CHANGE     From SPVOBJFQA 
Endcase
Return


#=====================================================================================
# Actions liées aux champs
#=====================================================================================

########################################
Subprog C_PERIOD(VALEUR)
Variable Integer VALEUR

If VALEUR=3 & !mod([M:FQA1]NBPER,2)
    [V]GMESSAGE="NB pair interdit pour les quinzaines\Utiliser plutôt les mois"
    mkstat=2 
Endif
End


########################################
Subprog C_DAYMON(VALEUR)
Variable Decimal  VALEUR
Local Integer I,NUMERO

[L]NUMERO=indice

If VALEUR>31 
    mkstat=2
Else
    For I=0 To [L]NUMERO
        If VALEUR=[M:FQA1]DAYMON(I) & I<>[L]NUMERO
            mkstat=2
            Break
        Endif
    Next I
Endif
End
########################################
Subprog AS_DAYMON(VALEUR)
Variable Decimal VALEUR

Case indice
    When 0
        If [M:FQA1]PERIOD=1 | [M:FQA1]PERIOD=2 | ([M:FQA1]PERIOD=4 & [M:FQA1]FREQ>4)
            mkstat=1
        Endif
    When 2
        If [M:FQA1]DAYMON(indice-1)=0 | ([M:FQA1]PERIOD=4 & [M:FQA1]FREQ=indice) | [M:FQA1]PERIOD=3
            mkstat=1
        Endif
    When Default    
        If [M:FQA1]DAYMON(indice-1)=0 | ([M:FQA1]PERIOD=4 & [M:FQA1]FREQ=indice)
            mkstat=1
        Endif
Endcase

End

