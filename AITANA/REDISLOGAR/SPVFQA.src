########################################
Subprog AS_WEESTR(VALEUR)
Variable Decimal VALEUR

If indice & [M:FQA2]WEESTR(indice-1)=0
    mkstat=1
Endif
End

########################################
Subprog C_WEESTR(VALEUR)
Variable Decimal VALEUR

If VALEUR>53
    mkstat=2
Endif
End

########################################
Subprog AS_WEEEND(VALEUR)
Variable Decimal VALEUR

If [M:FQA2]WEESTR(indice)=0
    mkstat=1
Endif
End

########################################
Subprog C_WEEEND(VALEUR)
Variable Decimal VALEUR

If VALEUR>53 | (VALEUR<[M:FQA2]WEESTR(indice))
    mkstat=2
Endif
End

########################################
Subprog AS_DAYSTR(VALEUR)
Variable Date    VALEUR

If indice & [M:FQA2]DAYSTR(indice-1)=[0/0/0]
    mkstat=1
Endif
    
End

########################################
Subprog C_DAYEND(VALEUR)
Variable Date    VALEUR

If [M:FQA2]DAYSTR(indice)<>[0/0/0] & VALEUR=[0/0/0]
    mkstat=2
Endif
End

########################################
Subprog AS_DATSTR(VALEUR)
Variable Date    VALEUR

If indice & [M:FQA2]DATSTR(indice-1)=[0/0/0]
    mkstat=1
Endif
End

########################################
Subprog D_LIBFQASHO(VALEUR)
Variable Char     VALEUR
VALEUR=[M:FQA0]LIBFQA
End

########################################
Subprog C_DAYPLN(VALEUR)
Variable Integer VALEUR

If VALEUR=2 & [M]DAYFBD(indice)=2: 
  [V]GMESSAGE = day$(indice+1)-mess(90,[V]GXMSGPSA,1)
  mkstat=2
Endif
End

########################################
Subprog AS_DAYPLN(VALEUR)
Variable Integer VALEUR
If [M:FQA1]DAYWISH=2: mkstat=1: Endif
End



