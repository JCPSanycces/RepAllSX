########################################
Subprog AM_MVT(VALEUR)
Variable Integer VALEUR

If !clalev([AST]): Local File APLSTD [AST]: Endif

Read [AST]CLE = 1743;VALEUR;[V]GLANDEF
If !fstat Then
    [M]MVTDES = [AST]LANMES
Endif

End

########################################
Subprog C_CODVAL(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR, [M:XPM1]CODVAL)From OBJDIV
End
