######################################################################################
Subprog AV_AVDEFFLG(VALEUR)
Variable Integer VALEUR
VALEUR=2
If [M:OPT5]AETFLG=2 | [M:OPT5]AETFIXFLG=2 : End : Endif
VALEUR=1
If !clalev([F:AMZ]) : Local File AMSKZON : Endif
For [F:AMZ]CODE Where [F:AMZ]CODMSK="OPT5" & [F:AMZ]CODTYP="MM" & [F:AMZ]NOLIB=35 & [F:AMZ]SAIAFF=1
  If evalue("[M:OPT5]"+[F:AMZ]CODZON)<>3
    VALEUR=2 : Break
  Endif
Next
End

######################################################################################
Subprog AM_AFLGTES(VALEUR)
Variable Integer VALEUR
[M:OPT4]ATYPTES=VALEUR
End

######################################################################################
Subprog AV_AFLGTES(VALEUR)
Variable Integer VALEUR
If VALEUR=0
  VALEUR=1
  [M:OPT4]ATYPTES=VALEUR
Endif
End


