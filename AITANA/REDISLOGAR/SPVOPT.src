#<AdxTL>@(#)12.0.0.0 $Revision:   1.20  $ Gestion du masque MCT0
#ACV#X16
#TIT#Gestion du paramétrage des transaction de saisie des affaires

Call OBJET ("OPT",GBIDC1,GBIDC2) From GOBJET
End


$ACTION

# Appel fonctions complémentaires GFI pour l'objet OPT
Gosub ACTION From XOBJSPE
If GPE=1 : GPE = 0 : Return : Endif

Case ACTION
  When "OUVRE"      : Gosub OUVRE      From SPVOBJOPT
  When "RAZCRE"     : Gosub RAZCRE     From SPVOBJOPT
  When "INICRE"     : Gosub INICRE     From SPVOBJOPT
                      Gosub INI_CRE_MOD From XTRPSA
  When "INIMOD"     : Gosub INIMOD     From SPVOBJOPT
                      Gosub INI_CRE_MOD From XTRPSA
  When "CREATION"   : Gosub CREATION   From SPVOBJOPT
  When "MODIF"      : Gosub MODIF      From SPVOBJOPT
  When "ANNULE"     : Gosub ANNULE     From SPVOBJOPT
                      Gosub ANNULE     From XTRPSA
  When "CHANGE"     : Gosub CHANGE     From XTRPSA
  When "LIENS"      : Gosub LIENS      From SPVOBJOPT
  When "SETBOUT"    : Gosub SETBOUT    From XTRPSA
  When "EXEBOUT"    : Gosub EXEBOUT    From XTRPSA
  When "FILTRE"     : Gosub FILTRE     From SPVOBJOPT
  When "AJOUT_ZONE" : Gosub AJOUT_ZONE From SPVOBJOPT
Endcase

Return

################################################################
$AMZONPSA
    Case left$(ECRAN,4)
        When  "XOP7"
            Case ZONE

            When "APBYPRJAAM","AOPPAAM","ADAM" # Pourcentage
                If AZCI=3 # Devise
                    VALINT=3
                Else
                    VALINT=2
                Endif

         Endcase
    Endcase
Return

######################################################################################
Subprog AM_FLGTAB1(VALEUR)
Variable Integer VALEUR
Effzo [M:OPT3]AXNIV11,AXNIV21,AXNIV31,AXITMDES1,AXSAU1,AXQTY1,AXPRIX1,AXMOD1,AXTYPFRM1,AXFRMNUMLIG1,AXLIGS1
Call AFF_FLGTAB1(VALEUR)
Affzo [M:OPT3]AXNIV11,AXNIV21,AXNIV31,AXITMDES1,AXSAU1,AXQTY1,AXPRIX1,AXMOD1,AXTYPFRM1,AXFRMNUMLIG1,AXLIGS1
End

Subprog AFF_FLGTAB1(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M:OPT3]AXNBS1=1
  Actzo [M:OPT3]AXNIV11,AXNIV21,AXNIV31,AXITMDES1,AXSAU1,AXQTY1,AXPRIX1,AXMOD1,AXTYPFRM1,AXFRMNUMLIG1,AXLIGS1
Else
  [M:OPT3]AXNBS1=3
  [M:OPT3]AXNIV11=3
  [M:OPT3]AXNIV21=3
  [M:OPT3]AXNIV31=3
  [M:OPT3]AXITMDES1=3
  [M:OPT3]AXSAU1=3
  [M:OPT3]AXQTY1=3
  [M:OPT3]AXPRIX1=3
  [M:OPT3]AXMOD1=3
  [M:OPT3]AXTYPFRM1=3
  [M:OPT3]AXFRMNUMLIG1=3
  [M:OPT3]AXLIGS1=3
  Grizo [M:OPT3]AXNIV11,AXNIV21,AXNIV31,AXITMDES1,AXSAU1,AXQTY1,AXPRIX1,AXMOD1,AXTYPFRM1,AXFRMNUMLIG1,AXLIGS1
Endif
End

######################################################################################
Subprog AM_FLGTAB2(VALEUR)
Variable Integer VALEUR
Effzo [M:OPT3]AXNIV12,AXNIV22,AXNIV32,AXITMDES2,AXSAU2,AXQTY2,AXPRIX2,AXMOD2,AXTYPFRM2,AXFRMNUMLIG2,AXLIGS2
Call AFF_FLGTAB2(VALEUR)
Affzo [M:OPT3]AXNIV12,AXNIV22,AXNIV32,AXITMDES2,AXSAU2,AXQTY2,AXPRIX2,AXMOD2,AXTYPFRM2,AXFRMNUMLIG2,AXLIGS2
End

Subprog AFF_FLGTAB2(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M:OPT3]AXNBS2=1
  Actzo [M:OPT3]AXNIV12,AXNIV22,AXNIV32,AXITMDES2,AXSAU2,AXQTY2,AXPRIX2,AXMOD2,AXTYPFRM2,AXFRMNUMLIG2,AXLIGS2
Else
  [M:OPT3]AXNBS2=3
  [M:OPT3]AXNIV12=3
  [M:OPT3]AXNIV22=3
  [M:OPT3]AXNIV32=3
  [M:OPT3]AXITMDES2=3
  [M:OPT3]AXSAU2=3
  [M:OPT3]AXQTY2=3
  [M:OPT3]AXPRIX2=3
  [M:OPT3]AXMOD2=3
  [M:OPT3]AXTYPFRM2=3
  [M:OPT3]AXFRMNUMLIG2=3
  [M:OPT3]AXLIGS2=3
  Grizo [M:OPT3]AXNIV12,AXNIV22,AXNIV32,AXITMDES2,AXSAU2,AXQTY2,AXPRIX2,AXMOD2,AXTYPFRM2,AXFRMNUMLIG2,AXLIGS2
Endif
End

######################################################################################
Subprog AM_FLGMRG1(VALEUR)
Variable Integer VALEUR
Effzo [M:OPT3]ANETAMT1,ABUYCOS1,AREQSTO1,APFMB1,APFMN1
If [V]GXOPTOPR : Effzo [M:OPT3]AMFGCOS1 : Endif
Call AFF_FLGMRG1(VALEUR)
Affzo [M:OPT3]ANETAMT1,ABUYCOS1,AREQSTO1,APFMB1,APFMN1
If [V]GXOPTOPR : Affzo [M:OPT3]AMFGCOS1 : Endif
End

Subprog AFF_FLGMRG1(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Actzo [M:OPT3]ANETAMT1,ABUYCOS1,AREQSTO1,APFMB1,APFMN1
  If [V]GXOPTOPR : Actzo [M:OPT3]AMFGCOS1 : Endif
  [M:OPT3]ALOCALDEV1=2
  [M:OPT3]AXBID1=2
  [M:OPT3]AXICOM1=1
Else
  [M:OPT3]ALOCALDEV1=3
  [M:OPT3]AXBID1=3
  [M:OPT3]AXICOM1=3
  [M:OPT3]ANETAMT1=3
  [M:OPT3]ABUYCOS1=3
  [M:OPT3]AREQSTO1=3
  If [V]GXOPTOPR
    [M:OPT3]AMFGCOS1=3
  Endif
  [M:OPT3]APFMB1=3
  [M:OPT3]APFMN1=3
  Grizo [M:OPT3]ANETAMT1,ABUYCOS1,AREQSTO1,APFMB1,APFMN1
  If [V]GXOPTOPR : Grizo [M:OPT3]AMFGCOS1 : Endif

Endif
End

######################################################################################
Subprog AM_FLGMRG2(VALEUR)
Variable Integer VALEUR
Effzo [M:OPT3]ANETAMT2,ABUYCOS2,AREQSTO2,APFMB2,APFMN2
If [V]GXOPTOPR : Effzo [M:OPT3]AMFGCOS2 : Endif
Call AFF_FLGMRG2(VALEUR)
Affzo [M:OPT3]ANETAMT2,ABUYCOS2,AREQSTO2,APFMB2,APFMN2
If [V]GXOPTOPR : Affzo [M:OPT3]AMFGCOS2 : Endif
End

Subprog AFF_FLGMRG2(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Actzo [M:OPT3]ANETAMT2,ABUYCOS2,AREQSTO2,APFMB2,APFMN2
  If [V]GXOPTOPR : Actzo [M:OPT3]AMFGCOS2 : Endif
  [M:OPT3]ALOCALDEV2=2
  [M:OPT3]AXBID2=2
  [M:OPT3]AXICOM2=1
Else
  [M:OPT3]ALOCALDEV2=3
  [M:OPT3]AXBID2=3
  [M:OPT3]AXICOM2=3
  [M:OPT3]ANETAMT2=3
  [M:OPT3]ABUYCOS2=3
  [M:OPT3]AREQSTO2=3
  If [V]GXOPTOPR
    [M:OPT3]AMFGCOS2=3
  Endif
  [M:OPT3]APFMB2=3
  [M:OPT3]APFMN2=3
  Grizo [M:OPT3]ANETAMT2,ABUYCOS2,AREQSTO2,APFMB2,APFMN2
  If [V]GXOPTOPR : Grizo [M:OPT3]AMFGCOS2 : Endif
Endif
End

######################################################################################
Subprog AM_FLGGRP1(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M:OPT3]FLGTAB1=2
  [M:OPT3]FLGMRG1=2
Else
  [M:OPT3]FLGTAB1=1
  [M:OPT3]FLGMRG1=1
Endif
Call AFF_FLGGRP(VALEUR,[M:OPT3]FLGGRP1)
Affzo [M:OPT3]FLGTAB1,FLGMRG1
Call AM_FLGTAB1([M:OPT3]FLGTAB1)
Call AM_FLGMRG1([M:OPT3]FLGMRG1)
End

######################################################################################
Subprog AM_FLGGRP2(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  [M:OPT3]FLGTAB2=2
  [M:OPT3]FLGMRG2=2
Else
  [M:OPT3]FLGTAB2=1
  [M:OPT3]FLGMRG2=1
Endif
Call AFF_FLGGRP([M:OPT3]FLGGRP1,VALEUR)
Affzo [M:OPT3]FLGTAB2,FLGMRG2
Call AM_FLGTAB2([M:OPT3]FLGTAB2)
Call AM_FLGMRG2([M:OPT3]FLGMRG2)
End

Subprog AFF_FLGGRP(FLGRP1,FLGRP2)
Value Integer FLGRP1, FLGRP2
If [L]FLGRP1=2
  Actzo [M:OPT3]FLGTAB1,FLGMRG1
Else
  Grizo [M:OPT3]FLGTAB1,FLGMRG1
Endif
If [L]FLGRP2=2
  Actzo [M:OPT3]FLGTAB2,FLGMRG2
Else
  Grizo [M:OPT3]FLGTAB2,FLGMRG2
Endif
End

######################################################################################
Subprog AM_ACALFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Actzo [M:OPT4]25
  Effzo [M:OPT4]25
  [M:OPT4]ACALFLG=2
Else
  [M:OPT4]AUVYDAY=3
  [M:OPT4]AHHMMWKDDAY=3
  [M:OPT4]AUVYCOD=3
  Grizo [M:OPT4]25
  Actzo [M:OPT4]ACALFLG
Endif
Affzo [M:OPT4]25
End

