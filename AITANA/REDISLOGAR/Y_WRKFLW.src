#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
#* YA044 - Control Modificaciones de Pedidos de venta con OF asociada
#* Evalua para un pedido si tiene en sus lineas una OF asociada y si hay
#* cambio de cantidad
#*
#* @param PS_SOH (Value) (Char) Código del pedido a consultar
#* @param PS_SOPLIN (Value) (Integer) Código de la linea de pedido a
#*                                    consultar
#* @param PS_QTY (Value) (Integer) Cantidad del pedido a consultar
#* @return Devuelve un valor numérico mayor que Cero si resulta ser
#*         algunos de los casos
#*!
##########################################################################
Funprog SOH_OF_ASOC_QTY(PS_SOH,PS_SOPLIN,PS_QTY)
  Value Char PS_SOH
  Value Integer PS_SOPLIN
  Value Integer PS_QTY

  Local Char RESULT : Raz RESULT

  Local File SORDERQ
  Local File MFGITM

  #Recorrer la mascara
  For I = 0 To NBLIG
    #Buscar la linea que corresponde con los parametros pasados
    If [M:SOH4]SOPLIN(I) = PS_SOPLIN Then
      If PS_QTY < [M:SOH4]QTY(I) Then  #Comprobar si la cantidad ha aumentado
        RESULT = "2"
      Elsif PS_QTY > [M:SOH4]QTY(I) Then  #Comprobar si la cantidad ha disminuido
        Read [SOQ]SOQ0 = PS_SOH;PS_SOPLIN;PS_SOPLIN  #Busqueda en SOQ para conseguir unos campos
        If fstat = 0 Then
          Read [MFI]MFI0 = [SOQ]FMINUM;[SOQ]FMILIN  #Filtrado para buscar la cantidad en la OF
          If [F:MFI]UOMEXTQTY <= [M:SOH4]QTY(I) Then  #Comparación de la cantidad de OF con la linea
            RESULT = "1"
          Endif
        Endif
      Endif
      I=NBLIG #Salida
    Endif
  Next I

End [L]RESULT

##########################################################################
## YA044 - Función para el texto mostrado para los correos que se envien
##########################################################################

Funprog MSG_SOH_OF_ASOC_QTY(PS_SOH,PS_SOPLIN,PS_QTY)
  Value Char PS_SOH
  Value Integer PS_SOPLIN
  Value Integer PS_QTY

  Local Char MSG(255) : Raz MSG

  If !clalev([F:SOQ])  : Local File SORDERQ [SOQ]  : Endif
  If !clalev([F:ZMFI]) : Local File MFGITM  [ZMFI] : Endif

  #Recorre la pantalla
  For I = 0 To NBLIG
    #Se comprueba que tenga OF asociada
    If [M:SOH4]YMFGNUM(I) <> ""
      #Se verifica que sea la misma linea de pedido
      If [M:SOH4]SOPLIN(I) = PS_SOPLIN Then
        #-- Búsqueda de la línea de OF segun el Pedido para conseguir la ctdad lanzamiento
        Filter [F:ZMFI] Where [F:ZMFI]ITMREF = [M:SOH4]ITMREF(I) and [F:ZMFI]VCRNUMORI = [M:SOH0]SOHNUM  and
&                             [F:ZMFI]VCRLINORI = [M:SOH4]SOPLIN(I) and [F:ZMFI]MFGNUM = [M:SOH4]YMFGNUM(I)
        Read [ZMFI]First
        #Se coteja que la cantidad de pantalla es mayor que la del pedido
        If [M:SOH4]QTY(I) > PS_QTY Then
          MSG = "La Posición"-num$(I+1)-"del Pedido '"+PS_SOH+"' que tiene asignada la OF '"+[F:SOQ]FMINUM+
&               "' con"-num$([F:ZMFI]UOMEXTQTY)-"unidades ha sido aumentada de"-num$([F:SOQ]QTY)-"unidades"-
&               "a"-num$([M:SOH4]QTY(I))-"unidades."
          Break
        Else
          MSG = "La Posición"-num$(I+1)-"del Pedido '"+PS_SOH+"' que tiene asignada la OF '"+[F:SOQ]FMINUM+
&               "' con"-num$([F:ZMFI]UOMEXTQTY)-"unidades ha sido disminuida de"-num$([F:SOQ]QTY)-"unidades"-
&               "a"-num$([M:SOH4]QTY(I))-"unidades."
          Break
        Endif
      Endif
    Endif
  Next I

End [L]MSG

##########################################################################
#* YA044 - Control Modificaciones de Pedidos de venta con OF asociada
#* Evalua para un pedido si tiene en sus lineas una OF asociada y si hay
#* cambio de fecha de
#*
#* @param PS_SOH (Value) (Char) Código del pedido a consultar
#* @param PS_SOPLIN (Value) (Integer) Código de la linea de pedido a
#*                                    consultar
#* @param PS_DDEMDLVDAT (Value) (Date) Fecha Entrega Solicitada del
#*                                     pedido a consultar
#* @return Devuelve un valor numérico mayor que Cero si resulta ser
#*         algunos de los casos
#*!
##########################################################################
Funprog SOH_OF_ASOC_FEC(PS_SOH,PS_SOPLIN,PS_DDEMDLVDAT)
  Value Char PS_SOH
  Value Integer PS_SOPLIN
  Value Date PS_DDEMDLVDAT

  Local Char RESULT : Raz RESULT
  Local Char VARGLB : VARGLB = "YMDFPVOFF"

  If !clalev([F:SOQ]) : Local File SORDERQ [SOQ]  : Endif
  If !clalev([F:ABG]) : Local File AGLOBVAR [AGB] : Endif

  #Recorrer la mascara
  For I = 0 To NBLIG
    #Buscar la linea que corresponde con los parametros pasados
    If [M:SOH4]SOPLIN(I) = PS_SOPLIN Then
      If PS_DDEMDLVDAT < [M:SOH4]DDEMDLVDAT(I) Then  #Comprobar si la fecha se ha atrasado
        RESULT = "2"
      Elsif PS_DDEMDLVDAT > [M:SOH4]DDEMDLVDAT(I) Then  #Comprobar si la fecha se ha adelantado XX días
        Read [F:AGB]AGB0 = VARGLB
        If fstat = 0 Then
          If (num$(PS_DDEMDLVDAT - [M:SOH4]DDEMDLVDAT(I))) <= [F:AGB]FORINI Then
            RESULT = "1"
          Endif
        Endif
      Endif
      I=NBLIG #Salida
    Endif
  Next I

End [L]RESULT

##########################################################################
## YA044 - Función para el texto mostrado para los correos que se envien
##########################################################################

Funprog MSG_SOH_OF_ASOC_FEC(PS_SOH,PS_SOPLIN,PS_DDEMDLVDAT)
  Value Char PS_SOH
  Value Integer PS_SOPLIN
  Value Date PS_DDEMDLVDAT

  Local Char MSG(255) : Raz MSG

  If !clalev([F:SOQ])  : Local File SORDERQ [SOQ]  : Endif
  If !clalev([F:ZMFI]) : Local File MFGITM  [ZMFI] : Endif

  #Recorre la pantalla
  For I = 0 To NBLIG
    #Se comprueba que tenga OF asociada
    If [M:SOH4]YMFGNUM(I) <> ""
      #Se verifica que sea la misma linea de pedido
      If [M:SOH4]SOPLIN(I) = PS_SOPLIN Then
        #-- Búsqueda de la línea de OF segun el Pedido para conseguir la ctdad lanzamiento
        Filter [F:ZMFI] Where [F:ZMFI]ITMREF = [M:SOH4]ITMREF(I) and [F:ZMFI]VCRNUMORI = [M:SOH0]SOHNUM  and
&                             [F:ZMFI]VCRLINORI = [M:SOH4]SOPLIN(I) and [F:ZMFI]MFGNUM = [M:SOH4]YMFGNUM(I)
        Read [ZMFI]First
        #Se coteja que la cantidad de pantalla es mayor que la del pedido
        If [M:SOH4]DDEMDLVDAT(I) > PS_DDEMDLVDAT Then
          MSG = "La Posición"-num$(I+1)-"del Pedido '"+PS_SOH+"' que tiene asignada la OF '"+[F:SOQ]FMINUM+
&               "' con"-num$([F:ZMFI]UOMEXTQTY)-"unidades ha sido atrasada del"-format$("D:DD[/]MM[/]YYYY",PS_DDEMDLVDAT)-
&               "al"-format$("D:DD[/]MM[/]YYYY",[M:SOH4]DDEMDLVDAT(I))-"."
          Break
        Else
          MSG = "La Posición"-num$(I+1)-"del Pedido '"+PS_SOH+"' que tiene asignada la OF '"+[F:SOQ]FMINUM+
&               "' con"-num$([F:ZMFI]UOMEXTQTY)-"unidades ha sido adelantada del"-format$("D:DD[/]MM[/]YYYY",PS_DDEMDLVDAT)-
&               "al"-format$("D:DD[/]MM[/]YYYY",[M:SOH4]DDEMDLVDAT(I))-"."
          Break
        Endif
      Endif
    Endif
  Next I

End [L]MSG

