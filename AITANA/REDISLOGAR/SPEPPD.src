######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return
######################################################################################
## YA020 - Tipo de precio
######################################################################################
Subprog AM_YGROPRI(VALEUR)
Variable Decimal VALEUR

Variable Decimal PRECIO

Case [M:PPD2]YTIPPRI(nolign -1)
  When 1 : PRECIO  = VALEUR
  When 2 : PRECIO  = VALEUR / 10
  When 3 : PRECIO  = VALEUR / 100
  When 4 : PRECIO  = VALEUR / 1000
Endcase

# actualizamos el campo standard
[M:PPD2]PRI(nolign -1) = PRECIO
Affzo [M:PPD2]PRI(nolign -1)

End
######################################################################################
## YA020 - Tipo de precio
######################################################################################
Subprog AV_YGROPRI(VALEUR)
Variable Decimal VALEUR

If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
Read [F:ZITM]ITM0 = [M:PPD1]ITMREF
If fstat = 0
  [M:PPD2]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
  Affzo [M:PPD2]YTIPPRI(nolign -1)
Endif

End


######################################################################################

