#<AdxTL>@(#)2.0.0.0 $Revision:   1.20  $ Gestion du masque TRFGEN
#ACV#X11
#TIT#Génération transfert paramètrage PSA

#LBO 08/2003

Local Char PARAM(30)(1..16),VALEUR(10) 

PARAM(1)="TEST"

Call TRAITE_CHAR(VALEUR,PARAM,"TRFGEN","XTRFGEN","TRFGENCRIT",4) From GTRAITE
End

########################################
Subprog AV_DOSDES(VALEUR)
Variable Char    VALEUR()
If [M:DIA]DOSSIER=""
  VALEUR=""
Else
  If !clalev([F:ADS]) : Local File ADOSSIER : Endif
  Read [F:ADS]DOSSIER=[M:DIA]DOSSIER
  If !fstat
    VALEUR=[F:ADS]NOMDOS
  Else
    VALEUR=""
  Endif
Endif
End
