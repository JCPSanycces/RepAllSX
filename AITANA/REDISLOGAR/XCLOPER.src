#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

Local Char PARAM(30)(1..16),VALEUR(10) 

Raz [L]PARAM, [L]VALEUR

GACTION="TRTVALSIT"

[L]PARAM(1)=""
[L]PARAM(2)="" 
[L]PARAM(3)="" 
[L]PARAM(4)="" 
Call TRAITE_CHAR(VALEUR,PARAM,"","XCLOPER","XCLOPER",4,"") From GTRAITE
End

$ACTION
Gosub ACTION From XCLOPER2
Return

#----------------------------------------------------------------------------------------------------
# Ecran XCLOPER
#----------------------------------------------------------------------------------------------------

######################################################################################
Subprog AP_ALLUSR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    Effzo [M]USRINF
    Grizo [M]USRINF
Else
    Actzo [M]USRINF
Endif
End


######################################################################################
Subprog AV_INITZON(VALEUR)
Gosub INIZON
End

$INIZON
Call AP_ALLUSR([M]ALLUSR)
Call AP_ALLFCYT([M]ALLFCYT)
Return

######################################################################################
Subprog AP_ALLFCYT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    Effzo [M]FCYT
    Grizo [M]FCYT
Else
    Actzo [M]FCYT
Endif
End
