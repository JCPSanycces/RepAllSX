#ACV#X13
#TIT#Gestion de l'objet XLR (Demande d'absence)

#==========================================================================================
# Gestion de l'objet   : Gestion de l'objet XLR (Demande d'absence)
# Auteur               : Laurent Bornes
# Date de création     : 20/09/2013
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

GBIDC1=""
GBIDC2=""
GFONC1="GESXLR"
GFLAG=""
Call OBJET("XLR",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

#==========================================================================================
$ACTION
#If GIMPORT : Call ECR_TRACE(ACTION,0) From GESECRAN : Endif

Gosub ACTION From SPVOBJXLR

Return

#==========================================================================================
Subprog AS_REQNUM(VALEUR)
Variable Char    VALEUR()
[V]GBIDC3="[F:REQ]FLGREQCLO<>2 & [F:REQ]FLGREQCAN<>2 & [F:PRT]LEAFLG=2"
If [M:XLR1]NBLIG>0 & !GIMPORT
  mkstat=2
Endif
End

#==========================================================================================
Subprog C_NBLIG

Local Integer NOL

If find(status,68,83)
  Local Integer NOL
  For [L]NOL=nolign-1 To nolign1-1
    If [M:XLR1]STA([L]NOL)>1
      [V]GMESSAGE=mess(241,[V]GXMSGPSA,1)-mess([M:XLR1]STA([L]NOL),1949,1)+"\"+mess(54,123,1)
      mkstat=1
      Break
    Endif
  Next
Elsif [M:XLR1]STA(nolign-1)>1
  If find(status,75,82)
    [V]GMESSAGE+=mess(241,[V]GXMSGPSA,1)-mess([M:XLR1]STA(nolign-1),1949,1)+"\"+mess(9,123,1)
    mkstat=1
  Elsif status=65
    [V]GMESSAGE+=mess(241,[V]GXMSGPSA,1)-mess([M:XLR1]STA(nolign-1),1949,1)+"\"+mess(54,123,1)
    mkstat=1
  Endif
Endif
End

#==========================================================================================
Subprog AS_BEGHOU(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  VALEUR=[V]XMORBEG
Endif
End

#==========================================================================================
Subprog AS_ENDHOU(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & ([V]XAFTEND>=[M:XLR1]BEGHOU(nolign-1) | [M:XLR1]ENDDAT(nolign-1)>[M:XLR1]BEGDAT(nolign-1))
  VALEUR=[V]XAFTEND
Endif
End

#==========================================================================================
Subprog C_ENDHOU(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M:XLR1]BEGHOU(nolign-1) & [M:XLR1]BEGDAT(nolign-1)=[M:XLR1]ENDDAT(nolign-1)
  mkstat=1
Endif
End

#==========================================================================================
Subprog AV_REQTYP(VALEUR)
Variable Char    VALEUR()
Read [F:REQ]REQ0=[M:XLR1]REQNUM
If !fstat
  VALEUR=[F:REQ]REQTYP
Else
  Raz VALEUR
Endif
End

#==========================================================================================
Subprog AS_ASSINT(VALEUR)
Variable Char    VALEUR()
If [M:XLR1]NBLIG>0
  mkstat=2
Endif
End

#==========================================================================================
Subprog AV_ICOREQ(VALEUR)
Variable Char    VALEUR()
Read [F:FNE]FNE0=[M:XLR1]REQNUM
If !fstat
  VALEUR="21"
Else
  VALEUR=""
Endif
End
