#ACV#X13
#TIT#Gestion de l'action SCHVALID

#LBO 04/2003

Local Char PARAM(30)(1..16),VALEUR(10) 

PARAM(1)=""
PARAM(2)=""
PARAM(3)=""
PARAM(4)=""
Call TRAITE_CHAR(VALEUR,PARAM,"","XSCHVALID2","SCHVALID",3) From GTRAITE
End


#-----------------------------------------------------------------------
# Ecran SCHVALID [DIA]
#-----------------------------------------------------------------------

#--------------------------------
Subprog AM_TSSPLA(VALEUR)
Variable Integer VALEUR
Call ACTGRIZO(VALEUR) From XSCHVALID2
End

#--------------------------------
Subprog AV_ACTGRIZO(VALEUR)
Variable Decimal VALEUR
Call ACTGRIZO([M:DIA]TSSPLA) From XSCHVALID2
End
