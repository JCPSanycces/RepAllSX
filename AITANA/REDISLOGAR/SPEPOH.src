#<AdxTL>@(#)0.0.0.0 $Revision$ Pedidos
######################################################################################
$ACTION

##b/- GT NDEV 06JUL2018 Customization for ACTIVITY Code YA007
If func AFNC.ACTIV("YA007"): Gosub ACTION From ZSPEPOH : Endif
##e/- GT NDEV 06JUL2018 Customization for ACTIVITY Code YA007
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "SETBOUT" : Gosub SETBOUT
  When "LIENS"  : Gosub LIENS
  When "RAZDUP"  : Gosub RAZDUP
  When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
#Y0000 VISUALIZAR LOS 5 REGISTROS DE FECHAS RECLAMACIÓN
$LIENS
 [M:YPOH1]NBLIG1=5
Return
#FIN Y000

##############################################################
$RAZDUP
  GPE = 1
  Gosub RAZDUP From SUBPOHA
  Local Integer I
  For I = 0 To  [M:POH2]NBLIG-1
    Case [M:POH2]YTIPPRI(I)
      When 0 : [M:POH2]YGROPRI(I) = [M:POH2]GROPRI(I)
      When 1 : [M:POH2]YGROPRI(I) = [M:POH2]GROPRI(I)
      When 2 : [M:POH2]YGROPRI(I) = [M:POH2]GROPRI(I) * 10
      When 3 : [M:POH2]YGROPRI(I) = [M:POH2]GROPRI(I) * 100
      When 4 : [M:POH2]YGROPRI(I) = [M:POH2]GROPRI(I) * 1000
    Endcase
    Affzo [M:POH2]YGROPRI(I)
  Next
Return

##############################################################
######################################################################################
## YA025 - Mofificar la fecha de recepción a todas las líneas marcadas del pedido de compra
######################################################################################
$SETBOUT
# Le indicamos que valla primero al SUB
Gosub ACTION From SUBPOH

# Comprobamos que el no estemos creando o duplicando un pedido, o que no esté saldado
If find(GREP,"C","D") | [M:POH1]CLEFLG>1
  # Deshabilitamos el botón "Modif. fecha recepción
  Call VIREBOUT(CHAINE,"Y") From GOBJET
Endif

# Que no vuelva a ejecutar el la parte del SUB
GPE=1
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
######################################################################################
$REC_YGROPRI
Case [M:POH2]YTIPPRI(nolign -1)
    When 0 : [M:POH2]YGROPRI(nolign -1) = [M:POH2]GROPRI(nolign -1)
    When 1 : [M:POH2]YGROPRI(nolign -1) = [M:POH2]GROPRI(nolign -1)
    When 2 : [M:POH2]YGROPRI(nolign -1) = [M:POH2]GROPRI(nolign -1) * 10
    When 3 : [M:POH2]YGROPRI(nolign -1) = [M:POH2]GROPRI(nolign -1) * 100
    When 4 : [M:POH2]YGROPRI(nolign -1) = [M:POH2]GROPRI(nolign -1) * 1000
  Endcase
  Affzo [M:POH2]YGROPRI(nolign -1)
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

  ## YA024 - Pasa el valor de la fecha de recepción al campo de fecha solicitada de recepción
  [M:POH2]YSOLRCPDAT(nolign -1) = [M:POH2]EXTRCPDAT(nolign -1)
  Affzo [M:POH2]YSOLRCPDAT(nolign -1)

  ## YA020 - Tipo de precio
  If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
  Read [F:ZITM]ITM0 = VALEUR
  If fstat = 0
    [M:POH2]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
    Affzo [M:POH2]YTIPPRI(nolign -1)
  Endif

  Case [M:POH2]YTIPPRI(nolign -1)
    When 1 : [M:POH2]YGROPRI(nolign -1) = [M:POH2]GROPRI(nolign -1)
    When 2 : [M:POH2]YGROPRI(nolign -1) = [M:POH2]GROPRI(nolign -1) * 10
    When 3 : [M:POH2]YGROPRI(nolign -1) = [M:POH2]GROPRI(nolign -1) * 100
    When 4 : [M:POH2]YGROPRI(nolign -1) = [M:POH2]GROPRI(nolign -1) * 1000
  Endcase
  Affzo [M:POH2]YGROPRI(nolign -1)

End
######################################################################################
# YA024
# si se modifica la fecha de recepción solicitada al crear el pedido, se pasa a la f. recepción.
Subprog AM_YSOLRCPDAT(VALEUR)
Variable Date    VALEUR

  If GREP="C" | GREP="D"
  [M:POH2]EXTRCPDAT(nolign -1) = VALEUR
  Affzo [M:POH2]EXTRCPDAT(nolign -1)
  Endif

End
######################################################################################
# YA020 - Tipo de precio
######################################################################################
Subprog AM_YGROPRI(VALEUR)
Variable Decimal VALEUR
Local Decimal PRECIO

  Case [M:POH2]YTIPPRI(nolign -1)
    When 1 : PRECIO  = VALEUR
    When 2 : PRECIO  = VALEUR / 10
    When 3 : PRECIO  = VALEUR / 100
    When 4 : PRECIO  = VALEUR / 1000
  Endcase

  # Llamamos a las funciones del campo GROPRI, como si se hubiese modificdo en pantalla
  Call AP_GROPRI(PRECIO) From SUBPOH
  Call PAMAPPFLG("POH2",nolign-1,"GROPRI") From TRTACHAPP1
  Call PAMDISCRG( PRECIO , "POH2" , 0 , nolign-1 , [M:POH1]CUR) From TRTACHPRI1
  Call PAMVATFLG("POH2",nolign-1,"GROPRI") From TRTACHFAC1
  Call AM_GROPRI(PRECIO) From SUBPOH
  # Finalmente actualizamos el campo standard
  [M:POH2]GROPRI(nolign -1) = PRECIO
  Affzo [M:POH2]GROPRI(nolign -1)

End

