GBIDC1=""
GBIDC2=""
GFONC1="GESFNE"
GFLAG="#"
Call OBJET("FNE",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

Gosub ACTION From XGENPOH2

Return

######################################################################################
Subprog AV_DES(VALEUR)
Variable Char    VALEUR()
If !clalev([F:ITM]) : Local File ITMMASTER : Endif
Read [F:ITM]ITM0=[M:XGPO]ITMREF
If !fstat
  VALEUR=[F:ITM]ITMDES1
Else
  VALEUR=""
Endif
End
