#<AdxTL>@(#)4.0.0.0 $Revision:   1.0  $ Gestion du masque CCN5
#ACV#X11
#TIT#Recherche d'un tiers


Local Char PARAM(50)(1..20) , SAVACT(10), VALEUR
SAVACT = GACTION : GACTION = "RECHBPR"
GFONCTION="GESREQ"
Call TRAITE_CHAR(VALEUR,PARAM,"RECHBPR","XRECHBPR2","",1) From GTRAITE
GACTION = SAVACT
Infbox "Code tiers"-VALEUR
End

#=======================================================================================================================
#    ACTIONS SUR CHAMPS
#=======================================================================================================================

Subprog AM_BPRNAM(VALEUR)
Variable Char    VALEUR()
[M:RBPR]BPRNAM = VALEUR
Gosub LOOKUPCPY From XRECHBPR2
End

########################################
Subprog AM_BPRZIP(VALEUR)
Variable Char    VALEUR()
[M:RBPR]BPRZIP = VALEUR
Gosub LOOKUPCPY From XRECHBPR2
End

########################################
Subprog AM_BPRCTY(VALEUR)
Variable Char    VALEUR()
[M:RBPR]BPRCTY = VALEUR
Gosub LOOKUPCPY From XRECHBPR2
End

########################################
Subprog AS_NBREC
If nolign - 1 > 0
    GCCN5NOL = nolign - 1
Endif
End

########################################
Subprog C_NBREC
If nolign - 1 > 0
    GCCN5NOL = nolign - 1
Endif
End
