#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Mask Management YMARG (Specific)
##########################################################################################################
# File Name : SPEYMR
# Developer : GT_RM
# Date : 2 Aug.,2018
# Description : File contains updating YCOEPUR field with new margin based on given conditions.
###########################################################################################################
## Section automatically added (screen ZMARG) 01/02/2017 11:53:52 (ADMIN)
######################################################################################
$ACTION
Case ACTION
  When "DEBUT" : Gosub DEBUT
  When "FIN" : Gosub FIN
  When "AVANT_OK" : Gosub AVANT_YOK
  When "OK" : Gosub YOK
  When default
Endcase
Return
######################################################################################
$AVANT_YOK
  If [M:YMR0]YBPSNUM = '' and [M:YMR0]YALLLIN = 1 and [M:YMR0]YNOBPSLIN = 1
    GMESSAGE = mess(1,6003,1)
    GERR = 1 
    FIN = 0
  Endif

Return
######################################################################################
Subprog AP_YBPSNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ''
  Diszo [M:YMR0]YALLLIN
  Diszo [M:YMR0]YNOBPSLIN 
Else
  Actzo [M:YMR0]YALLLIN 
  Actzo [M:YMR0]YNOBPSLIN
Endif
End
######################################################################################
Subprog AP_YALLLIN(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Diszo [M:YMR0]YBPSNUM
  Diszo [M:YMR0]YNOBPSLIN 
Else
  Actzo [M:YMR0]YBPSNUM 
  Actzo [M:YMR0]YNOBPSLIN
Endif
End
######################################################################################
Subprog AP_YNOBPSLIN(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  Diszo [M:YMR0]YBPSNUM
  Diszo [M:YMR0]YALLLIN
Else
  Actzo [M:YMR0]YBPSNUM 
  Actzo [M:YMR0]YALLLIN
Endif
End
######################################################################################
$YOK
If !clalev([YXHO]) : Local File XOPPHIE[YXHO] : Endif
If [M:YMR0]YBPSNUM <> ''
   Update [F:YXHO] where OPPNUM = [M:OPP0]OPPNUM and YBPSNUM = [M:YMR0]YBPSNUM and FRMNUMLIG = "" with YCOEPUR = [M:YMR0]YNEWMAR
Elsif [M:YMR0]YALLLIN = 2
     Update [F:YXHO] where OPPNUM = [M:OPP0]OPPNUM and FRMNUMLIG = "" with YCOEPUR = [M:YMR0]YNEWMAR
Elsif [M:YMR0]YNOBPSLIN = 2
     Update [F:YXHO] where OPPNUM = [M:OPP0]OPPNUM and YBPSNUM = '' and FRMNUMLIG = "" with YCOEPUR = [M:YMR0]YNEWMAR
Endif

Close File[F:YXHO]
Return
######################################################################################
$FIN
If !clalev([YXHO]) : Local File XOPPHIE[YXHO] : Endif
Local Integer I : I=0
For[F:YXHO] where OPPNUM = [M:OPP0]OPPNUM 
   [M:XOP1]YCOEPUR(I) = [F:YXHO]YCOEPUR
   I=I+1
Next
Affzo[M:XOP1]
Close File[F:YXHO]
Return
######################################################################################

$DEBUT
[M:YMR0]YBPSNUM = ''
[M:YMR0]YNEWMAR = 0
[M:YMR0]YALLLIN = 1
[M:YMR0]YNOBPSLIN = 1
Affzo [M:YMR0]
Return






