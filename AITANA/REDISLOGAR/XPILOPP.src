F#ACV#X16
#TIT#Consultation suivi d'affaire
#==========================================================================================
# Gestion de l'objet   : Consultation suivi d'affaire
#                        
# Auteur               : Laurent Bornes
# Date de création     : 22/03/2010      
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

GBIDC1=""
GBIDC2=""
GFONC1="GESOPP"
Call OBJET("OPP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case GBOITE
  When "XPILOPP"
    Case ACTION
      When "DEBUT"   : Gosub DEBUT      From XPILOPP2
      When "BOUTON"  : Gosub BOUTON     From XPILOPP2
      When "FINSAI"  : Gosub FINSAI     From XPILOPP2
      When "FIR"     : Gosub FIR        From XPILOPP2
      When "PRE"     : Gosub PRE        From XPILOPP2
      When "SUI"     : Gosub SUI        From XPILOPP2
      When "LAS"     : Gosub LAS        From XPILOPP2
      When "SETBOUT" : Gosub SETBOUT    From XPILOPP2
    Endcase
  When "XCRITPILOP"
    Case ACTION
      When "DEBUT"   : Gosub CRIT_DEBUT From XPILOPP2
      When "OK"      : Gosub CRIT_OK    From XPILOPP2
      When "END"     : Gosub CRIT_END   From XPILOPP2
    Endcase
Endcase
Return


######################################################################################
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()
Read [F:OPP]OPP0=VALEUR
If !fstat
  Call GETDEV([F:OPP]SALFCY) From DEVSUB
  [M:XP0]CUR=[V]GLOCALDEV
  Affzo [M:XP0]CUR
Endif
Call RAFFRAICHI(VALEUR) From XPILOPP2
End

######################################################################################
Subprog AV_ICOOPP(VALEUR)
Variable Char    VALEUR()
If [M:XP0]OPPNUM=""
  VALEUR=""
Else
  VALEUR="65"
Endif
End

######################################################################################
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()
[M:XP0]CUR=VALEUR
Call RAFFRAICHI([M:XP0]OPPNUM) From XPILOPP2
End

######################################################################################
Subprog C_CRTS2(VALEUR)
Variable Decimal VALEUR
If VALEUR<=[M:XCP]CRTS1
  mkstat=1
Endif
End

######################################################################################
Subprog IB_NBLIG

Raz [V]GBOUT5, [V]GBOUT6, [V]GBOUT7, [V]GBOUT8, [V]GBOUT9, [V]GBOUT10, [V]GBOUT11, [V]GBOUT12, [V]GBOUT13, [V]GBOUT14, [V]GBOUT15

If [M:XP1]FRMNUMLIG(nolign-1)<>""
  GBOUT5=mess(20,[V]GXMSGOPP,1) : # Détail
Endif

Case [M:XP1]TYPLIG(nolign-1)
  When 1 : # Affaire
  When 2 : # Hierarchie 1
  When 3 : # Hierarchie 2
  When 4 : # Ventes
           If [M:XP1]MNT12(nolign-1)<>0
             [V]GBOUT6  =mess(58,[V]GXMSGOPP,1) : # "Zoom CA Réalisé"
           Endif
  When 5 : # Achat
           If [M:XP1]MNT5(nolign-1)<>0
             [V]GBOUT7  =mess(59,[V]GXMSGOPP,1) : # "Zoom Coût Lancé"
           Endif
           If [M:XP1]MNT6(nolign-1)<>0
             [V]GBOUT8  =mess(60,[V]GXMSGOPP,1) : # "Zoom Coût Réalisé"
           Endif
           If [M:XP1]MNTCOR(nolign-1)<>0
             [V]GBOUT12 =mess(61,[V]GXMSGOPP,1) : # "Zoom Corrigé"
           Endif
  When 6 : # Prestations
           If [M:XP1]MNT5(nolign-1)<>0
             [V]GBOUT9  =mess(59,[V]GXMSGOPP,1) : # "Zoom Coût Lancé"
           Endif
           If [M:XP1]MNT6(nolign-1)<>0
             [V]GBOUT10 =mess(60,[V]GXMSGOPP,1) : # "Zoom Coût Réalisé"
           Endif
           If [M:XP1]MNTCOR(nolign-1)<>0
             [V]GBOUT11 =mess(61,[V]GXMSGOPP,1) : # "Zoom Corrigé"
           Endif
  When 7 : # Production
           If [M:XP1]MNT5(nolign-1)<>0
             [V]GBOUT13  =mess(59,[V]GXMSGOPP,1) : # "Zoom Coût Lancé"
           Endif
           If [M:XP1]MNT6(nolign-1)<>0
             [V]GBOUT14  =mess(60,[V]GXMSGOPP,1) : # "Zoom Coût Réalisé"
           Endif
           If [M:XP1]MNTCOR(nolign-1)<>0
             [V]GBOUT15 =mess(61,[V]GXMSGOPP,1) : # "Zoom Corrigé"
           Endif
Endcase
  
End

######################################################################################
Subprog AM_DAT(VALEUR)
Variable Date    VALEUR
[M:XP0]DAT=VALEUR
Call RAFFRAICHI([M:XP0]OPPNUM) From XPILOPP2
End
