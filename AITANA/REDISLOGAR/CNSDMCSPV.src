#<AdxTL>@(#)3.0.0.0 $Revision$
#ACV#X11
#TIT#Consultation du Parc matériel

#==========================================================================================
# Gestion de la consultation : DMC -- Consultation du Parc Matériel
#
# Auteur                     :
# Date de création           :
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
# 20/12/2002    OTHYR        Ajout des critères sur le code Affaire et Type d'inter (+ ajout des PE)
# 28/02/2003    OTHYR        Modélisation Web
#------------------------------------------------------------------------------------------
#==========================================================================================

Local Char PARAM(30)(3)

Call GCONSULT("DMC","",PARAM)From GCONSULT
End


############################################################
$ACTION

Case ACTION
    When "AUTORIS"    : Gosub AUTORIS
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "SETBOUT"    : Gosub SETBOUT
    When "FIN_CRIT"   : Gosub FIN_CRIT
    When Default
Endcase

Return

#-----------------------------------------------------------------#
#    Gestion des étiquettes liées a ACTION                        #
#-----------------------------------------------------------------#
###################################################################
$AUTORIS
Return

###################################################################
$SETBOUT
Return

###################################################################
$OUVRE

Local Char WFIL(250),WFIL1(250),WFIL2(250),WFIL3(250),WFIL4(250),WFIL5(250),WFIL6(250)
Local Char CRITMAC(250), CRIT1(250), CRIT2(250), CRIT3(250), CRIT4(250), CRIT5(250), CRITSPE(250), CRITSPE2(250)
Local Char DEBITR,FINITR
Local Decimal  WMNTORG(0..5), WMNTDES(0..5)
Local Integer  SPSTAT
Local Integer  FLITMREQ,FLITMITD

Gosub DEFCRIT

Return

###################################################################
$DEFCRIT

For I = 1 To dim(PARAM)
    Case I
        When 1 :    : # Paramètre Tiers
            If PARAM(I) <> "" Then
                Call LECTURE("BPR",PARAM(I),"") From CONTOBJ
                If !fstat Then
                    [M:DMC1]BPCNUM = PARAM(I)
                Endif
            Endif
        When 2 :    : # Paramètre article
            If PARAM(I) <> "" Then
                Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
                If !fstat Then
                    [M:DMC1]ITMREF = PARAM(I)
                Endif
            Endif
        When 3 :    : # Paramètre n° serie
            If PARAM(I) <> "" Then
                [M:DMC1]SERNUM = PARAM(I)
            Endif
    Endcase
Next I

If !find([M:DMC1]FLGPRN,1,2) : [M:DMC1]FLGPRN = 2 : Endif
If !find([M:DMC1]FLGCLO,1,2) : [M:DMC1]FLGCLO = 2 : Endif
If !find([M:DMC1]FLGCAN,1,2) : [M:DMC1]FLGCAN = 2 : Endif
If !find([M:CDMC]TRI,1,2,3)  : [M:CDMC]TRI    = 1 : Endif

# -- copie de l'écran critères (CDMC) vers le masque 1 (DMC1)
Gosub CRITENT From =PROGCNS

Return

###################################################################
$LECTURE

If [M:DMC1]BPCNUM = "" & [M:DMC1]ITMREF = "" & [M:DMC1]STATITM = "" & [M:DMC1]MACTYP = "" & [M:DMC1]OPPNUM = ""
&                      & [M:DMC1]ITVTYP = "" Then
    NBLU = 0
    GERR = 1
    Raz GMESSAGE
####FM    GMESSAGE = mess(217,[V]GXMSGPSA,1)                :# Il faut saisir au moins un critère
    Raz [M:DMC2]
    Affzo [M:DMC2]
    Return
Endif

Call TEMPON("R") From GESECRAN

Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 Then
    NOL = MAXLIG
Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
# Appel au filtre spécifique client
ACTION = "FILTRE"
Gosub ACTION From XOBJCNS
ACTION = "LECTURE"

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0 Then
    SUITE = 1
    If CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CDMC]TRI
      When 1 : # tri par Code ope
        # LBORN 09/12/2015 - Mantis 31292
        # Link [REQ] With [ITR]ITR1(1) = REQNUM,
        # &               [ITD]ITD0(1) = [ITR]ITVNUM
        Link [ITD] With [ITR]ITR0    = [ITD]ITVNUM,
&                       [REQ]REQ0    = [ITR]REQNUM
&                  As [LNK]
&                  Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRITSPE) & evalue([L]CRIT4)
&                      & evalue([L]CRIT5) & evalue([L]CRITSPE2)
&                  Order By Key CLE =[F:ITD]CODOPE;[F:ITD]ITVNUM

      When 2 : # tri par date
         # LBORN 09/12/2015 - Mantis 31292
        # Link [REQ] With [ITR]ITR1(1) = REQNUM,
        # &               [ITD]ITD0(1) = [ITR]ITVNUM
        Link [ITD] With [ITR]ITR0    = [ITD]ITVNUM,
&                       [REQ]REQ0    = [ITR]REQNUM
&                  As [LNK]
&                  Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRITSPE) & evalue([L]CRIT4)
&                      & evalue([L]CRIT5) & evalue([L]CRITSPE2)
&                  Order By Key CLE =[F:ITR]ITVDAT Desc;[F:ITD]ITVNUM Desc
    Endcase
Else
    RETOUR = 1
    If CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CDMC]TRI
      When 1 : # tri par Code ope
        # LBORN 09/12/2015 - Mantis 31292
        # Link [REQ] With [ITR]ITR1(1) = REQNUM,
        # &               [ITD]ITD0(1) = [ITR]ITVNUM
        Link [ITD] With [ITR]ITR0    = [ITD]ITVNUM,
&                       [REQ]REQ0    = [ITR]REQNUM
&                  As [LNK]
&                  Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRITSPE) & evalue([L]CRIT4)
&                      & evalue([L]CRIT5) & evalue([L]CRITSPE2)
&                  Order By Key CLE=[F:ITD]CODOPE Desc ;[F:ITD]ITVNUM Desc
      When 2 : # tri par date
        # LBORN 09/12/2015 - Mantis 31292
        # Link [REQ] With [ITR]ITR1(1) = REQNUM,
        # &               [ITD]ITD0(1) = [ITR]ITVNUM
        Link [ITD] With [ITR]ITR0    = [ITD]ITVNUM,
&                       [REQ]REQ0    = [ITR]REQNUM
&                  As [LNK]
&                  Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRITSPE) & evalue([L]CRIT4)
&                      & evalue([L]CRIT5) & evalue([L]CRITSPE2)
&                  Order By Key CLE =[F:ITR]ITVDAT;[F:ITD]ITVNUM
    Endcase
Endif

#-- raz du masque
If CHGPAG <> 2 & CHGPAG <> -2 Then
    Raz [M:DMC2]
Endif

#-- lecture
$BOUCLE

For [LNK]CLE

    Raz [L]FLITMREQ, [L]FLITMITD

    Filter [F:XMA] Where evalue([L]CRIT1) & evalue([L]CRIT3)
    Filter [F:MAC] Where evalue([L]CRITMAC)

    Read [F:MAC]MAC5=[F:ITD]ASSPRD;[F:ITD]SERNUM
    If !fstat
      Read [F:XMA]XMA0=[F:MAC]MACNUM
      If !fstat
        [L]FLITMITD=1
      Endif
    Endif

    If ![L]FLITMITD
      Read [F:MAC]MAC5=[F:REQ]ARTICLE;[F:REQ]SERNUM
      If !fstat
        Read [F:XMA]XMA0=[F:MAC]MACNUM
        If !fstat
          [L]FLITMREQ=1
        Endif
      Endif
    Endif

    Filter [F:XMA]
    Filter [F:MAC]

    If ![L]FLITMREQ & ![L]FLITMITD
        Goto SUIV
    Endif

    If NBLU = 1 Then
        If CHGPAG=2 | CHGPAG=-2 : Raz [M:DMC2] : Endif
        NBLU = 2
    Endif

    If CHGPAG > 0 Then
        If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
        NOL    += 1
        If NOL = 0 Then
           DEBDAT    = [F:ITR]ITVDAT
           DEBOPE    = [F:ITD]CODOPE
           [L]DEBITR = [F:ITD]ITVNUM
        Endif

        FINDAT    = [F:ITR]ITVDAT
        FINOPE    = [F:ITD]CODOPE
        [L]FINITR = [F:ITD]ITVNUM
    Else
        If NOL <= 0 : RETOUR=2 : Break : Endif
        NOL    -= 1
        If NOL = MAXLIG-1 Then
           FINDAT    = [F:ITR]ITVDAT
           FINOPE    = [F:ITD]CODOPE
           [L]FINITR = [F:ITD]ITVNUM
        Endif

        DEBDAT    = [F:ITR]ITVDAT
        DEBOPE    = [F:ITD]CODOPE
        [L]DEBITR = [F:ITD]ITVNUM
    Endif

    nolign   = NOL+1

    [M:DMC2] = [F:ITD]
    [M:DMC2] = [F:REQ]

    [M:DMC2]FCYREQ(nolign-1) = [F:REQ]FCY

    If ![L]FLITMITD
        [M:DMC2]ITMMASTER(nolign-1) = [F:REQ]ARTICLE
        [M:DMC2]SERNUM(nolign-1)    = [F:REQ]SERNUM
    Else
        [M:DMC2]ITMMASTER(nolign-1) = [F:ITD]ASSPRD
        [M:DMC2]SERNUM(nolign-1)    = [F:ITD]SERNUM
    Endif

    [M:DMC2]ITVLEN(nolign-1) = [F:ITR]TIMLEN
    [M:DMC2]ITVDAT(nolign-1) = [F:ITR]ITVDAT
    [M:DMC2]CPRPRI(nolign-1) = func ARRDEV([F:ITD]CURINV,[F:ITD]CPRPRI)

    $SUIV
Next

Call TEMPOFF From GESECRAN

Return


###################################################################
$LOAD_FILTER

# CRIT1, CRIT2 et CRIT3 pour restrictions sur XMA (chaines trop courtes si pas ces 3 var)
# CRIT4 et CRIT5 pour restrictions sur REQ et ITR
[L]CRITMAC  = "1"
[L]CRIT1    = "1"
[L]CRIT2    = "1"
[L]CRIT3    = "1"
[L]CRIT4    = "1" : # Réservé request/itvreq
[L]CRIT5    = "1" : # Réservé request/itvreq
[L]CRITSPE  = "1" : # Réservé CLIENT
[L]CRITSPE2 = "1" : # Réservé CLIENT request/itvreq

If [M:DMC1]BPCNUM <> "" Then
    [L]CRITMAC += "&[F:MAC]BPCNUM = [M:DMC1]BPCNUM"
Endif

If [M:DMC1]STATITM <> "" Then
    [L]CRIT1 += "&[F:XMA]STATITM = [M:DMC1]STATITM"
Endif

If [M:DMC1]ITMREF <> "" Then
    [L]CRITMAC += "&[F:MAC]MACPDTCOD = [M:DMC1]ITMREF"
    [L]CRIT4 += "&([F:REQ]ARTICLE = [M:DMC1]ITMREF | [F:ITD]ASSPRD = [M:DMC1]ITMREF)"
Endif

If [M:DMC1]SERNUM <> "" Then
    [L]CRITMAC += "&[F:MAC]MACSERNUM = [M:DMC1]SERNUM"
    [L]CRIT4 += "&([F:REQ]SERNUM = [M:DMC1]SERNUM | [F:ITD]SERNUM = [M:DMC1]SERNUM)"
Endif

If [M:DMC1]MACTYP <> "" Then
    [L]CRIT1 += "&[F:XMA]MACTYP = [M:DMC1]MACTYP"
Endif

If [M:DMC1]OPPNUM <> "" Then
    [L]CRIT5 += "&[F:REQ]OPPNUM = [M:DMC1]OPPNUM"
Endif

If [M:DMC1]ITVTYP <> "" Then
    [L]CRIT5 += "&[F:ITR]ITVTYP = [M:DMC1]ITVTYP"
Endif

If [M:CDMC]PISBEG <> [0/0/0] Then
    [L]CRIT2 += "&[F:XMA]PISDAT >= [M:CDMC]PISBEG"
Endif

If [M:CDMC]PISEND <> [0/0/0] Then
    [L]CRIT2 += "&[F:XMA]PISDAT <= [M:CDMC]PISEND"
Endif

If [M:CDMC]BEGGUARBEG <> [0/0/0] Then
    [L]CRIT2 += "&[F:XMA]BEGDATGAR >= [M:CDMC]BEGGUARBEG"
Endif

If [M:CDMC]BEGGUAREND <> [0/0/0] Then
    [L]CRIT2 += "&[F:XMA]BEGDATGAR <= [M:CDMC]BEGGUAREND"
Endif

If [M:CDMC]ENDGUARBEG <> [0/0/0] Then
    [L]CRIT3 += "&[F:XMA]ENDDATGAR >= [M:CDMC]ENDGUARBEG"
Endif

If [M:CDMC]ENDGUAREND <> [0/0/0] Then
    [L]CRIT3 += "&[F:XMA]ENDDATGAR <= [M:CDMC]ENDGUAREND"
Endif

If [M:CDMC]MAINTBEG <> [0/0/0] Then
    [L]CRIT3 += "&[F:XMA]MAINTDAT >= [M:CDMC]MAINTBEG"
Endif

If [M:CDMC]MAINTEND <> [0/0/0] Then
    [L]CRIT3 += "&[F:XMA]MAINTDAT <= [M:CDMC]MAINTEND"
Endif

If [M:DMC1]FLGPRN = 1 Then
    [L]CRIT4 += "&[F:REQ]FLGREQPRN <> 2"
Endif

If [M:DMC1]FLGCLO = 1 Then
    [L]CRIT4 += "&[F:REQ]FLGREQCLO <> 2"
Endif

If [M:DMC1]FLGCAN = 1 Then
    [L]CRIT4 += "&[F:REQ]FLGREQCAN <> 2"
Endif


Case CHGPAG
    When 3 : # rafraichissement
        Case [M:CDMC]TRI
            When 1 : # tri par article
#                [L]CRIT5 += "& [F:REQ]ARTICLE >= DEBITM"
            When 2 : # tri par date
#                [L]CRIT5 += "& [F:REQ]CREADAT >= DEBDAT"
        Endcase
    When 2 : # suite
        Case [M:CDMC]TRI
            When 1 : # tri par codeope
                [L]CRIT5 += "&(([F:ITD]CODOPE=FINOPE & [F:ITR]ITVNUM>=[L]FINITR) | [F:ITD]CODOPE>FINOPE)"
            When 2 : # tri par date
                [L]CRIT5 += "&(([F:ITR]ITVDAT=FINDAT & [F:ITR]ITVNUM<=[L]FINITR) | [F:ITR]ITVDAT<FINDAT)"
        Endcase
    When -2 : # retour
        Case [M:CDMC]TRI
            When 1 : # tri par codeope
                [L]CRIT5 += "&(([F:ITD]CODOPE=DEBOPE & [F:ITR]ITVNUM<=[L]DEBITR) | [F:ITD]CODOPE<DEBOPE)"
            When 2 : # tri par date
                [L]CRIT5 += "&(([F:ITR]ITVDAT=DEBDAT & [F:ITR]ITVNUM>=[L]DEBITR) | [F:ITR]ITVDAT>DEBDAT)"
        Endcase
Endcase

Return

###################################################################
$FIN_CRIT
Return

#-----------------------------------------------------------------#
#    Gestion des étiquettes liées aux masques DMC1, DMC2 et CDMC  #
#-----------------------------------------------------------------#
###################################################################
Subprog IB_NBLIG

Raz GBOUT1, GBOUT2

If [M:DMC2]REQNUM(nolign-1) <> "" Then
    GBOUT1 = mess(41,[V]GXMSGPSA,1)
Endif
If [M:DMC2]ITVNUM(nolign-1) <> "" Then
    GBOUT2 = mess(3,[V]GXMSGPSA,1)
Endif

End

###################################################################
Subprog AV_PISEND(VALEUR)
Variable Date    VALEUR
VALEUR = [M]PISBEG
End

###################################################################
Subprog AV_BEGGUAREND(VALEUR)
Variable Date    VALEUR
VALEUR = [M]BEGGUARBEG
End

###################################################################
Subprog AV_ENDGUAREND(VALEUR)
Variable Date    VALEUR
VALEUR = [M]ENDGUAREND
End

###################################################################
Subprog AV_MAINTEND(VALEUR)
Variable Date    VALEUR
VALEUR = [M]MAINTBEG
End


#==========================================================================================
Funprog ARRDEV(CUR,XMNT)
Value Char CUR
Value Decimal XMNT

If [L]XMNT=0 : End 0 : Endif

# Arrondi / Devise d'en-tête
If [F:TCU]CUR<>[V]GSYSCUR
  Read [F:TCU]TCU0=[V]GSYSCUR
  If fstat : Raz [F:TCU] : Endif
Endif

If [L]CUR<>[V]GSYSCUR

  # Pour raffraichir GLOCALDEV
  Call GETDEV([F:REQ]FCY) From DEVSUB

  Local Decimal AUX
  Local Integer XSTAT
  [L]AUX=[L]XMNT
  Call CONVERT([L]CUR,[V]GSYSCUR,[V]GLOCALDEV,1,date$,[L]AUX,[L]AUX,[L]XSTAT) From TRTDEV
  If [L]XSTAT
    # Pour afficher **** dans le tab
    End 99999999999999999999999
  Else
    End arr([L]AUX,[F:TCU]CURRND)
  Endif
Else
  End arr([L]XMNT,[F:TCU]CURRND)
Endif

