#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER = 'AIT50' : Infbox ACTION : Endif
Case ACTION
  When "FILTRE" : Gosub FILTRE
  When "AV_AFFICHE" : Gosub AV_AFFICHE
  When Default
Endcase
Return

######################################################################################
$FILTRE
If [M:CSP1]YCONFDATDEB <> [0/0/0]
  Call ADD_FILTER("&[F:SOQ]YCONFIRMADAT>="+"["+num$([M:CSP1]YCONFDATDEB)+"]", WFIL, WFIL1, WFIL2) From CNSCSPSTD
Endif
If [M:CSP1]YCONFDATFIN <> [0/0/0]
  Call ADD_FILTER("&[F:SOQ]YCONFIRMADAT<="+"["+num$([M:CSP1]YCONFDATFIN)+"]", WFIL, WFIL1, WFIL2) From CNSCSPSTD
Endif

Return

######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If !clalev([ZVITBPC]) : Local File YVITMBPC [ZVITBPC] : Endif

Read [ZVITBPC]YIB0 = VALEUR;[M:CSP1]BPCORD
If !fstat
  [M:CSP1]YITMDES = [ZVITBPC]ITMDESBPC
Endif
Affzo [M:CSP1]YITMDES
End


######################################################################################
$AV_AFFICHE
Local Integer LCON
If !clalev([ZSOQ]) : Local File SORDERQ [ZSOQ] : Endif
If !clalev([ZSOH]) : Local File SORDER  [ZSOH] : Endif
For LCON=0 To NBLIG-1
  Read [ZSOQ]SOQ0 =  [M:CSP2]SOHNUM(LCON);[M:CSP2]SOPLIN(LCON);[M:CSP2]SOQSEQ(LCON)
  If !fstat
   # If LCON <= 3 : Infbox num$([F:ZSOQ]YCONFIRMADAT) : Endif
    [M:CSP2]YCONFIRMADAT(LCON) = [F:ZSOQ]YCONFIRMADAT
    [M:CSP2]YITMREFBPC(LCON)   = [F:ZSOQ]YITMCLI
    Read [ZSOH]SOH0 = [M:CSP2]SOHNUM(LCON)
    If !fstat
      [M:CSP2]YCUSORDREF(LCON) = [F:ZSOH]CUSORDREF
    Endif
    [M:CSP2]DDEMDLVDAT(LCON)   = [F:ZSOQ]DEMDLVDAT
    Affzo [M:CSP2]YCONFIRMADAT(LCON)
    Affzo [M:CSP2]YITMREFBPC(LCON)
    Affzo [M:CSP2]YCUSORDREF(LCON)
  Endif
Next

Return

