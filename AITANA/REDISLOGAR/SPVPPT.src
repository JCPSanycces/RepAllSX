Subprog AS_ORIPXV(VALEUR)
Variable Integer VALEUR
If VALEUR=0 & nolign>1
  If [M:PPT7]ORIPXV(nolign-2)<len(mess(0,1948,1))
    VALEUR=[M:PPT7]ORIPXV(nolign-2)+1
  Endif
Endif
End

