######################################################################################
Subprog AVANT_XNBST1
If find(status,6,7,20,27,28,65,68,83) | status>=1792 | [M]XLIGS(nolign-1)<>0 : End : Endif
[M]XLIGS(nolign-1)=max([M]XLIGS)+1000
End

######################################################################################
Subprog D_XNIV1(VALEUR)
Variable Char    VALEUR()
If nolign>1 & [M]XNIV1(nolign-2)<>"" : VALEUR=[M]XNIV1(nolign-2) : Endif
End

######################################################################################
Subprog AS_XNIV1(VALEUR)
Variable Char    VALEUR()
If nolign>1 & [M]XNIV1(nolign-2)=[M]XNIV1(nolign)
  VALEUR=[M]XNIV1(nolign-2)
  mkstat=2
Endif
End

######################################################################################
Subprog C_XNIV1(VALEUR)
Variable Char    VALEUR()
If [M]XNIV1(nolign)=VALEUR | (nolign>1 & [M]XNIV1(nolign-2)=VALEUR) : End : Endif
Local Integer I, XNB
If dim([M]XNBST1)>0
  [L]XNB=[M]XNBST1
Else
  [L]XNB=[M]XNBST2
Endif
For [L]I=0 To [L]XNB-1
  If [L]I<>nolign-1 & VALEUR=[M]XNIV1([L]I)
    GERR=1
    GMESSAGE=mess(16,[V]GXMSGOPP,1)
    mkstat=1
    Break
  Endif
Next
End

######################################################################################
Subprog D_XNIV2(VALEUR)
Variable Char    VALEUR()
If nolign>1 & [M]XNIV2(nolign-2)<>"" & [M]XNIV1(nolign-1)<>"" : VALEUR=[M]XNIV2(nolign-2) : Endif
End

######################################################################################
Subprog AS_XNIV2(VALEUR)
Variable Char    VALEUR()
If nolign>1 & [M]XNIV1(nolign-2)=[M]XNIV1(nolign) & [M]XNIV2(nolign-2)=[M]XNIV2(nolign)
  VALEUR=[M]XNIV2(nolign-2)
  mkstat=2
Elsif [M]XNIV1(nolign-1)=""
  mkstat=1
Endif
End

######################################################################################
Subprog C_XNIV2(VALEUR)
Variable Char    VALEUR()
If ([M]XNIV1(nolign)=[M]XNIV1(nolign-1) & [M]XNIV2(nolign)=VALEUR) | (nolign>1 & [M]XNIV1(nolign-2)=[M]XNIV1(nolign-1) & [M]XNIV2(nolign-2)=VALEUR) : End : Endif

Local Integer I, XNB
If dim([M]XNBST1)>0
  [L]XNB=[M]XNBST1
Else
  [L]XNB=[M]XNBST2
Endif

For [L]I=0 To [L]XNB-1
  If [L]I<>nolign-1 & [M]XNIV1(nolign-1)=[M]XNIV1([L]I) & VALEUR=[M]XNIV2([L]I)
    GERR=1
    GMESSAGE=mess(16,[V]GXMSGOPP,1)
    mkstat=1
    Break
  Endif
Next

End

######################################################################################
Subprog C_XNIV3(VALEUR)
Variable Char    VALEUR()
Local Integer I, XNB
If dim([M]XNBST1)>0
  [L]XNB=[M]XNBST1
Else
  [L]XNB=[M]XNBST2
Endif
For [L]I=0 To [L]XNB
  If [L]I<>nolign-1 & [M]XNIV1(nolign-1)=[M]XNIV1([L]I) & [M]XNIV2(nolign-1)=[M]XNIV2([L]I) & VALEUR=[M]XNIV3([L]I) & VALEUR<>""
    GERR=3
    GMESSAGE=mess(29,100,1)-num$([L]I+1)
    Break
  Endif
Next
End

######################################################################################
Subprog AM_XNIV3(VALEUR)
Variable Char    VALEUR()

Call CTRLSTA_ITMFRL(VALEUR) From SPVOBJFRL
If mkstat : End : Endif

Effzo [M]XITMDES(nolign-1)
End

######################################################################################
Subprog AS_XITMDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  If !clalev([F:ITM]) : Local File ITMMASTER : Endif
  Read [ITM]ITM0=[M]XNIV3(nolign-1)
  If !fstat
    VALEUR=[F:ITM]ITMDES1
  Endif
Endif
End

######################################################################################
Subprog C_XITMDES(VALEUR)
Variable Char    VALEUR()
If nolign>1
  Local Integer I, XNB
  If dim([M]XNBST1)>0
    [L]XNB=[M]XNBST1
  Else
    [L]XNB=[M]XNBST2
  Endif

  For [L]I=0 To [L]XNB
    If [L]I<>nolign-1 & [M]XNIV1(nolign-1)=[M]XNIV1([L]I) & [M]XNIV2(nolign-1)=[M]XNIV2([L]I) & [M]XNIV3(nolign-1)=[M]XNIV3([L]I) & VALEUR=[M]XITMDES([L]I)
      GERR=3
      GMESSAGE=mess(29,100,1)-num$([L]I+1)
      Break
    Endif
  Next
Endif
End

######################################################################################
Subprog AS_XSAU(VALEUR)
Variable Char    VALEUR()
If [M]XNIV3(nolign-1)=""
  mkstat=1 : End
Endif
If VALEUR=""
  If !clalev([F:ITM]) : Local File ITMMASTER : Endif
  Read [ITM]ITM0=[M]XNIV3(nolign-1)
  If !fstat
    VALEUR=[F:ITM]SAU
  Endif
Endif
End

######################################################################################
Subprog AS_XPRIX(VALEUR)
Variable Decimal VALEUR
If [M]XNIV3(nolign-1)=""
  mkstat=1 : End
Endif
End

######################################################################################
Subprog AS_XTYPFRM(VALEUR)
Variable Char    VALEUR()
Call DEF_TYPFRM(VALEUR,[M:PPT0]PJTTYP,[M]XMOD(nolign-1)) From XACTOPPX11
End

######################################################################################
Subprog AM_XLIGS(VALEUR)
Variable Decimal VALEUR
If !find(VALEUR,[M:PPT4]XLIGS(0..[M:PPT4]XNBST1-1))
  GMESSAGE=mess(25,[V]GXMSGOPP,1)
  GERR=1
  mkstat=1
Else
  Local Integer I
  For [L]I=0 To [M]XNBST2-1
    If [L]I<>nolign-1 & VALEUR=[M]XLIGS([L]I)
      GERR=1
      GMESSAGE=mess(26,[V]GXMSGOPP,1)-num$([L]I+1)
      mkstat=1
      Break
    Endif
  Next
  If !mkstat
    [M]XLIGS(nolign-1)=VALEUR
    [M]XNIV3(nolign-1)=[M:PPT4]XNIV3(find(VALEUR,[M:PPT4]XLIGS(0..[M:PPT4]XNBST1-1))-1)
    [M]XITMDES(nolign-1)=[M:PPT4]XITMDES(find(VALEUR,[M:PPT4]XLIGS(0..[M:PPT4]XNBST1-1))-1)
    Affzo [M]XNIV1(nolign-1),XNIV2(nolign-1),XNIV3(nolign-1),XITMDES(nolign-1),XSAU(nolign-1),XQTY(nolign-1),XPRIX(nolign-1),XMOD(nolign-1)
  Endif
Endif
End

######################################################################################
Subprog C_XNBST1
If status=65
  Local Integer ZI
  [L]ZI=find([M:PPT4]XLIGS(nolign-1),[M:PPT5]XLIGS(0..[M:PPT5]XNBST2-1))
  If [L]ZI>0
    Dela [L]ZI-1 [M:PPT5]XNBST2 : [M:PPT5]XNBST2-=1
    Affzo [M:PPT5]
  Endif
Endif
End

