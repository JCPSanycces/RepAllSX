######################################################################################
Subprog AM_SITOPP(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
  Actzo [M:PPT6]SITRGPS,SITRGPN
#  Chgfmt [M:PPT6]SITRGPS With "LA1917:20X"
#  Chgfmt [M:PPT6]SITRGPN With "LA1918:20X"
Else
  Effzo [M:PPT6]SITRGPS,SITRGPN
  Grizo [M:PPT6]SITRGPS,SITRGPN
#  Chgfmt [M:PPT6]SITRGPS With "-LA1917:20X"
#  Chgfmt [M:PPT6]SITRGPN With "-LA1918:20X"
Endif
Affzo [M:PPT6]SITRGPS,SITRGPN
End

######################################################################################
Subprog AV_SITRGPS(VALEUR)
Variable Integer VALEUR
If [M:PPT6]SITOPP=2
  VALEUR=0
Elsif VALEUR=0
  VALEUR=1
Endif
End

