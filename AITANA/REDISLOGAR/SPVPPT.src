GBIDC1=""
GBIDC2=""
GFONC1="GESPPT"
Call OBJET("PPT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet PPT
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "SEL_TABLE" : Gosub SEL_TABLE From SPVOBJPPT
  When "INICRE"    : Gosub INICRE    From SPVOBJPPT
  When "INIMOD"    : Gosub INIMOD    From SPVOBJPPT
  When "CHANGE"    : Gosub CHANGE    From SPVOBJPPT
  When "ANNULE"    : Gosub ANNULE    From SPVOBJPPT
  When "MODIF"     : Gosub MODIF     From SPVOBJPPT
  When "CREATION"  : Gosub CREATION  From SPVOBJPPT
  When "LIENS"     : Gosub LIENS     From SPVOBJPPT
Endcase

Return

#########################################################################
# Paramètrage des types de DS
#########################################################################
#########################################################################
Subprog AV_CTRLREQTYP(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 0,1 : Grizo [M:PPT1]15
               Effzo [M:PPT1]15
    When 2   : Actzo [M:PPT1]15
Endcase

If !GIMPORT Then
    Affzo [M:PPT1]15
Endif

End

#########################################################################
Subprog AP_CTRLREQTYP(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 0,1 : Grizo [M:PPT1]15
               Effzo [M:PPT1]15
    When 2   : Actzo [M:PPT1]15
Endcase

If !GIMPORT Then
    Affzo [M:PPT1]15
Endif

End

#########################################################################
Subprog C_REQTYP(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR, [M:PPT1]REQTYP) From OBJDIV
End

#########################################################################
Subprog C_DEFREQTYP(VALEUR)
Variable Char    VALEUR()
Local Integer INDEX
Call TROUVE([M:PPT1]CTRLREQTYP, VALEUR, [M:PPT1]REQTYP, INDEX) From SPVOBJXRT
End


