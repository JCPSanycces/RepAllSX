########################################
Subprog AV_CTRLETP(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=1 : Endif
Gosub ACT_GRIZO
End

$ACT_GRIZO
If find(VALEUR,0,1) | [M:PPT3]GESFRM<2
  Grizo [M:PPT3]55
  Effzo [M:PPT3]55
Else
  Actzo [M:PPT3]55
Endif

If !GIMPORT Then
    Affzo [M:PPT3]55
Endif
Return

########################################
Subprog AP_CTRLETP(VALEUR)
Variable Integer VALEUR
Gosub ACT_GRIZO
End

