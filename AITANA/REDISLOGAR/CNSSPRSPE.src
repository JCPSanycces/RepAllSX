#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# <YA053> Cambios Consulta Stock Proyectado
######################################################################################

$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"     : Gosub LECTURE
Endcase
Return
#######################################################################################
$OUVRE
Gosub OUVRE From CNSSPRSTD

Gosub OUVRE From YCNSSMVSTD

GPE=1
Return
#######################################################################################
$LECTURE
Gosub LECTURE From CNSSPRSTD

# Alimento el Stock Disponible
Local Decimal WSTODISP
##If !clalev([F:ITV]) : Local File ITMMVT [F:ITV]    : Endif
If !clalev([F:ITG]) : Local File ITMCATEG [F:ITG]  : Endif
If !clalev([F:ITM]) : Local File ITMMASTER [F:ITM] : Endif

Local Decimal WDISPO
Local Integer WEST

Read [ITG]ITG1=[F:ITM]TCLCOD;[F:ITV]STOFCY
If fstat
   Read [ITG]ITG1=[F:ITM]TCLCOD;""
   If fstat Raz [F:ITG] Endif
Endif
WEST=0
WDISPO=0
If [F:ITG]GLOAAAFLG = 2   WEST += 1  Endif
If [F:ITG]GLOQQQFLG = 2   WEST += 2  Endif
If [F:ITG]GLORRRFLG = 2   WEST += 4  Endif
#--- TS 106217

Call STODISPO("",[F:ITF]STOFCY,[F:ITF]ITMREF,"*","*",1,WEST,"","","","",WDISPO) From STKLIB

[M:SPR2]YSTODISP = WDISPO
Affzo [M:SPR2]YSTODISP

# Añado un valor a la rejilla
[M:SPR2]INTFLD ([M:SPR2]NBLIG0) =  mess (1, 6007, 1)
[M:SPR2]VALFLD ([M:SPR2]NBLIG0) = WDISPO
[M:SPR2]NBLIG0 += 1

Affzo [M:SPR2]NBLIG0

Gosub LECTURE From YCNSSMVSTD

GPE=1
Return
#######################################################################################

