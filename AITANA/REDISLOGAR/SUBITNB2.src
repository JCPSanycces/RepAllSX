#<AdxTL>@(#)0.0.0.0 $Revision$ 
## YA040 - Tarifas reparación
##########################################################################################################
#  Sous programmes pour la gestion des interventions                     Module CRM       aout           #
##########################################################################################################
# LOADHDTCRE : Charge le tableau des consommations lors de la création d'une nouvelle intervention.
# ADDHDTLINE : Boucle intérieure de LOADHDTCRE
# LOADHDT : Chargement du tableau des consommations.
# SAVEHDT : Enregistrement des consommations (Avec sa propre transaction)
# SAVEHDTCRE : Enregistrement des consommations au cours d'une création
# RUNTARIF : Calcul le montant consommé pour chaque ligne d'un même code article du tableau des consommations
# MNGHORO : Gestion des menus Horodatage
# BEGINHORO : Gestion du lancement d'un Horodatage
# QUITHORO : Gestion de l'abandon d'un Horodatage
# SAVEHORO : Enregistrement d'un nouvel horodatage
# SETDEFPLN : Propose une planification par défaut en fonction des consommations planifiées
# DONHDKTASK : Transforme en tant que effectuées toutes les consommations
# SETDONITNFLG : Détecte s'il y a des consommations non effectuées pour l'intervention.  Classe M
# SETDONHDK4 : Détecte s'il y a des consommations non effectuées pour l'intervention.  Classe F
# SETDONALLFLG : Détecte s'il y a des consommations non effectuées pour l'ensemble de la demande de service
# ALI_STW : Chargement du masque de paramétrage pour composants stock
# CHARGE_STOSOR : Alimentation du masque de sortie de stock
# APRES_STOSOR : Mise à jour complémentaires après enregistrement
# CHARGE_STOSOM : Alimentation du masque de sortie de stock
# APRES_STOSOM : Alimentation du masque de sortie de stock
# ALI_ALP : Chargement du masque de paramétrage pour composants stock             #
##########################################################################################################
##########################################################################################################
$READ_CODACT_SPX
Local Integer ITER

  For ITER = 0 To dim(IDISCRGFLG)-1
    Read [ACV]CODACT="SP"+num$(ITER+1)
    If [F:ACV]FLACT = 2 Then
      IDISCRGFLG(ITER) = 1
      Case ITER+1
        When 1 : Raz [M:ITN8]DISCRGVAL1 : Raz [M:ITN8]DISCRGREN1
        When 2 : Raz [M:ITN8]DISCRGVAL2 : Raz [M:ITN8]DISCRGREN2
        When 3 : Raz [M:ITN8]DISCRGVAL3 : Raz [M:ITN8]DISCRGREN3
        When 4 : Raz [M:ITN8]DISCRGVAL4 : Raz [M:ITN8]DISCRGREN4
        When 5 : Raz [M:ITN8]DISCRGVAL5 : Raz [M:ITN8]DISCRGREN5
        When 6 : Raz [M:ITN8]DISCRGVAL6 : Raz [M:ITN8]DISCRGREN6
        When 7 : Raz [M:ITN8]DISCRGVAL7 : Raz [M:ITN8]DISCRGREN7
        When 8 : Raz [M:ITN8]DISCRGVAL8 : Raz [M:ITN8]DISCRGREN8
        When 9 : Raz [M:ITN8]DISCRGVAL9 : Raz [M:ITN8]DISCRGREN9  # FGR 13/01/2009 : X3SUIVI60986
      Endcase
    Endif
  Next ITER
Return

##########################################################################################################
$RAZ_ITN8_LOADHDT
Local Integer ITER

  Raz [M:ITN8]NBLIG
  Raz [M:ITN8]HDTMACSRE
  Raz [M:ITN8]HDTCPN
  Raz [M:ITN8]HDTTYP
  Raz [M:ITN8]HDTITM
  Raz [M:ITN8]ITMREF
  Raz [M:ITN8]HDTQTY
  Raz [M:ITN8]HDTUOM
  Raz [M:ITN8]HDTSTOFCY
  Raz [M:ITN8]HDTAVA
  Raz [M:ITN8]HDTAVAUOM
  Raz [M:ITN8]HDTDONDAT
  Raz [M:ITN8]HDTDONHOU
  Raz [M:ITN8]BHDTDONHOU
  Raz [M:ITN8]HDTSTOISS
  Raz [M:ITN8]HDTINV
  Raz [M:ITN8]HDTAMT
  Raz [M:ITN8]HDTAMTINV
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    Raz [M:ITN8]PITHDT
    Raz [M:ITN8]INVPITFLG
  Endif
  Raz [M:ITN8]HDTCUR
  Raz [M:ITN8]SPGTIMHOU
  Raz [M:ITN8]SPGTIMMNT
  Raz [M:ITN8]HDTNUM
  Raz [M:ITN8]HDTTEX
  Raz [M:ITN8]HDTSALTEX
  Raz [M:ITN8]MANAMTFLG
  Raz [M:ITN8]HDTMACSET
  Raz [M:ITN8]VAT1
  Raz [M:ITN8]VAT2
  Raz [M:ITN8]VAT3
  Raz [M:ITN8]CLCAMT1
  Raz [M:ITN8]CLCAMT2
  Raz [M:ITN8]PRIREN
  Raz [M:ITN8]SAUSTUCOD
  Raz [M:ITN8]SAUSTUCOE
  Raz [M:ITN8]HDTSTU
  Raz [M:ITN8]HDTSTUQTY
  Raz [M:ITN8]DACCOE
  Raz [M:ITN8]LBEFMT
  Raz [M:ITN8]HDTISSQTY
  Raz [M:ITN8]HDTISSISS
  Raz [M:ITN8]WSTOSEQ
  Raz [M:ITN8]STOMGTCOD
  Raz [M:ITN8]STA
  Raz [M:ITN8]MVTDES
  Raz [M:ITN8]CREFLG
  Raz [M:ITN8]UPDFLG
  #
  Gosub READ_CODACT_SPX
  For ITER = 0 To dim(ICCEFLG)-1
    ICCEFLG(0) = 1
    Case ITER
      When 1  : Raz [M:ITN8]CCE1
      When 2  : Raz [M:ITN8]CCE2
      When 3  : Raz [M:ITN8]CCE3
      When 4  : Raz [M:ITN8]CCE4
      When 5  : Raz [M:ITN8]CCE5
      When 6  : Raz [M:ITN8]CCE6
      When 7  : Raz [M:ITN8]CCE7
      When 8  : Raz [M:ITN8]CCE8
      When 9  : Raz [M:ITN8]CCE9
      When 10 : Raz [M:ITN8]CCE10
      When 11 : Raz [M:ITN8]CCE11
      When 12 : Raz [M:ITN8]CCE12
      When 13 : Raz [M:ITN8]CCE13
      When 14 : Raz [M:ITN8]CCE14
      When 15 : Raz [M:ITN8]CCE15
      When 16 : Raz [M:ITN8]CCE16
      When 17 : Raz [M:ITN8]CCE17
      When 18 : Raz [M:ITN8]CCE18
      When 19 : Raz [M:ITN8]CCE19
      When 20 : Raz [M:ITN8]CCE20
    Endcase
  Next ITER
Return

##########################################################################################################
# Charge le tableau des consommations lors de la création d'une nouvelle intervention.
##########################################################################################################
Subprog LOADHDTCRE(SZCONTEXT, SZSRENUM, SZGRU, ISRE7NBLIG)
Value Char SZCONTEXT
Value Char SZSRENUM
Value Char SZGRU
Value Integer ISRE7NBLIG

Local Integer ISTOERR
Local Integer ILINDEB
Local Integer ICCEFLG(max(GNBDIE,GOPTCANA))  # FGR 06/02/2009 avant (9)
Local Integer IDISCRGFLG(9)

  #Sortie de stock
  Call RAZSTOSORW From STKSOR
  Raz [M:ITN8]CREFLG
  Raz [M:ITN8]UPDFLG
  Raz [M:ITN8]SAVSTOISS    # FGR 05/08/2010 : X3SUIVI66063
  Raz GITN8HDTISSISS
  Raz GITN8DIRTYISSISS
  ILINDEB = 0
  ISTOERR = 0
  Raz IDISCRGFLG
  Raz ICCEFLG
  Gosub RAZ_ITN8_LOADHDT
  nolign = 0
  If ISRE7NBLIG Then
    Filter [SRM] Where [F:SRM]SRENUM = SZSRENUM and [F:SRM]ITNGRU = SZGRU
    For [SRM]
      If ILINDEB >= dim([M:ITN8]HDTMACSRE) Then
        Break
      Endif
      Gosub ADDHDTLINE
    Next
    Filter [SRM]
  Else
    Gosub ADDHDTLINE
  Endif
  [M:ITN8]NBLIG = ILINDEB
  Call LOADTIMHDT From SUBITNB1
  Affzo [M:ITN8]1-99
End

##########################################################################################################
# Boucle intérieure de LOADHDTCRE
################################################################
$ADDHDTLINE
Local Integer ITER

  If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif
  If ISRE7NBLIG Then
    Filter [HDT] Where [F:HDT]HDTMACSRE = [F:SRM]MACNUM and [F:HDT]SRENUM = SZSRENUM and [F:HDT]TPL <> 2 and [F:HDT]ITNNUM = "" and [F:HDT]HDTDONDAT = [00/00/00]
&             Order By [F:HDT]HDTNUM Asc
  Else
    If SZCONTEXT = "HDN" Then
      Filter [HDT] Where [F:HDT]HDTNUM = [M:SRE0]CURHDTNUMX and [F:HDT]TPL <> 2 and [F:HDT]ITNNUM = "" and [F:HDT]HDTDONDAT = [00/00/00]
    Else
      Filter [HDT] Where [F:HDT]SRENUM = SZSRENUM and [F:HDT]TPL <> 2 and [F:HDT]ITNNUM = "" and [F:HDT]HDTDONDAT = [00/00/00]
&               Order By [F:HDT]HDTNUM Asc
    Endif
  Endif
  For [HDT] Hint Key HDT1
    If ILINDEB >= dim([M:ITN8]HDTMACSRE) Then
      Break
    Endif
    Gosub CHARGE_ITN8
    If GERR = 1 Then
      Break
    Endif
    ILINDEB += 1
  Next
  Filter [HDT]
Return

##########################################################################################################
$CHARGE_ITN8
  #Transclass
  nolign += 1
  [M:ITN8] = [F:HDT]
  [M:ITN8]HDTMACSRE(ILINDEB) = [F:HDT]HDTMACSRE
  [M:ITN8]HDTCPN(ILINDEB) = [F:HDT]HDTCPN
  [M:ITN8]HDTTYP(ILINDEB) = [F:HDT]HDTTYP
  [M:ITN8]HDTITM(ILINDEB) = [F:HDT]HDTITM
  [M:ITN8]ITMREF(ILINDEB) = [F:HDT]HDTITM
  [M:ITN8]HDTQTY(ILINDEB) = [F:HDT]HDTQTY
  [M:ITN8]HDTUOM(ILINDEB) = [F:HDT]HDTUOM
  [M:ITN8]HDTSTOFCY(ILINDEB) = [F:HDT]HDTSTOFCY
  [M:ITN8]HDTAVA(ILINDEB) = [F:HDT]HDTAVA
  [M:ITN8]HDTAVAUOM(ILINDEB) = [F:HDT]HDTAVAUOM
  [M:ITN8]HDTDONDAT(ILINDEB) = [F:HDT]HDTDONDAT
  [M:ITN8]HDTDONHOU(ILINDEB) = [F:HDT]HDTDONHOU
  Call SECTOHOU([F:HDT]HDTDONHOU, [M:ITN8]BHDTDONHOU(ILINDEB)) From CRMUTIL140
  [M:ITN8]HDTTEX(ILINDEB) = [F:HDT]HDTTEX
  [M:ITN8]HDTSALTEX(ILINDEB) = [F:HDT]HDTSALTEX
  [M:ITN8]HDTSTOISS(ILINDEB) = [F:HDT]HDTSTOISS
  [M:ITN8]SAVSTOISS(ILINDEB) = [M:ITN8]HDTSTOISS(ILINDEB)    # FGR 05/08/2010 : X3SUIVI66063
  [M:ITN8]HDTINV(ILINDEB) = [F:HDT]HDTINV
  [M:ITN8]HDTAMT(ILINDEB) = [F:HDT]HDTAMT
  [M:ITN8]HDTAMTINV(ILINDEB) = [F:HDT]HDTAMTINV
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    [M:ITN8]INVPITFLG(ILINDEB) = [F:HDT]INVPITFLG
  Endif
  [M:ITN8]HDTCUR(ILINDEB) = [F:HDT]HDTCUR
  [M:ITN8]SPGTIMHOU(ILINDEB) = [F:HDT]SPGTIMHOU
  [M:ITN8]SPGTIMMNT(ILINDEB) = [F:HDT]SPGTIMMNT
  [M:ITN8]HDTNUM(ILINDEB) = [F:HDT]HDTNUM
  [M:ITN8]MANAMTFLG(ILINDEB) = [F:HDT]MANAMTFLG
  [M:ITN8]HDTMACSET(ILINDEB) = [F:HDT]HDTMACSET
  [M:ITN8]VAT1(ILINDEB) = [F:HDT]VAT(0)
  [M:ITN8]VAT2(ILINDEB) = [F:HDT]VAT(1)
  [M:ITN8]VAT3(ILINDEB) = [F:HDT]VAT(2)
  [M:ITN8]CLCAMT1(ILINDEB) = [F:HDT]CLCAMT1
  [M:ITN8]CLCAMT2(ILINDEB) = [F:HDT]CLCAMT2
  [M:ITN8]PRIREN(ILINDEB) = [F:HDT]PRIREN
  [M:ITN8]SAUSTUCOE(ILINDEB) = [F:HDT]SAUSTUCOE
  [M:ITN8]HDTSTUQTY(ILINDEB) = [F:HDT]HDTSTUQTY
  [M:ITN8]HDTISSQTY(ILINDEB) = [F:HDT]HDTISSQTY
  # FGR 12/10/2010 : X3SUIVI66063 (début) : je corrige HDTISSISS qui a une mauvaise valeur ici
  If [M:ITN8]HDTSTOISS(ILINDEB) <> 2 and [F:HDT]HDTISSISS <> 0 Then
    [M:ITN8]HDTISSISS(ILINDEB) = 0
  Else
    [M:ITN8]HDTISSISS(ILINDEB) = [F:HDT]HDTISSISS
  Endif
  # FGR 12/10/2010 : X3SUIVI66063 (fin)
  If [M:ITN8]HDTNUM(ILINDEB) <> "" Then
    If [M:ITN8]HDTTYP(ILINDEB) = 2 Then
      If [M:ITN8]HDTDONDAT(ILINDEB) <> [00/00/00] Then
        If [M:ITN8]HDTSTOISS(ILINDEB) = 2 Then
          If [M:ITN8]HDTISSQTY(ILINDEB) > 0 Then
            [M:ITN8]CREFLG(ILINDEB) = 1
          Endif
        Endif
      Endif
    Endif
  Endif
  For ITER = 0 To dim(IDISCRGFLG)-1
    If IDISCRGFLG(ITER) Then
      Assign ("[M:ITN8]DISCRGVAL" + num$(ITER+1) + "(ILINDEB)") With evalue("[F:HDT]DISCRGVAL" + num$(ITER+1))
      Assign ("[M:ITN8]DISCRGREN" + num$(ITER+1) + "(ILINDEB)") With evalue("[F:HDT]DISCRGREN" + num$(ITER+1))
    Endif
  Next ITER
  #----- Chargement comptes et sections analytiques -----#
  Call CHARG_ACCCCE(ILINDEB,"","","[M:ITN8]CCE", "HDT",0,[F:HDT]HDTNUM,0,0,"") From TRTX3CPT
  #
  #Chargement des points débités
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    Read [PCT]PCT0=[M:ITN0]SRVDEMNUM;0;0;"";"";"";[M:ITN8]HDTNUM(ILINDEB);""
    If !fstat Then
      [M:ITN8]PITHDT(ILINDEB) = [F:PCT]PIT
    Endif
  Endif
  #Gestion de stock de l'article consommé
  If [M:ITN8]HDTITM(ILINDEB) <> "" Then
    Read [ITM]ITM0=[M:ITN8]HDTITM(ILINDEB)
    If fstat Then
      Raz [F:ITM]
    Endif
  Endif
  [M:ITN8]STOMGTCOD(ILINDEB) = [F:ITM]STOMGTCOD
  #lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
  If [F:ITM]STOMGTCOD > 1 Then
    If [F:ITF]STOFCY <> [M:ITN8]HDTSTOFCY(ILINDEB) or [F:ITF]ITMREF <> [M:ITN8]HDTITM(ILINDEB) Then
      Read [ITF]ITF0=[M:ITN8]HDTITM(ILINDEB);[M:ITN8]HDTSTOFCY(ILINDEB)
      If fstat  Then
        Raz [F:ITF]
      Endif
    Endif
    [M:ITN8]STOMGTCOD(ILINDEB) = [F:ITF]STOMGTCOD
  Endif
  #Sortie de stock
  ISTOERR = 0
  If [M:ITN8]HDTNUM(ILINDEB) = "" Then
    Call RECSTOSOR (3, "ITN8", ILINDEB, [M:ITN8]HDTSTOFCY(ILINDEB), [M:ITN8]HDTITM(ILINDEB), 33, [M:ITN8]HDTNUM(nolign-1), 0, "", ISTOERR) From STKECR
  Else
    Call RECSTOSOR (1, "ITN8", ILINDEB, [M:ITN8]HDTSTOFCY(ILINDEB), [M:ITN8]HDTITM(ILINDEB), 33, [M:ITN8]HDTNUM(nolign-1), 0, "", ISTOERR) From STKECR
  Endif
  # FGR 31/05/2013 : X3SUIVI90082 (début) : Vu avec TS pas la peine de tester le code retour
  #If ISTOERR Then
  #  #Erreur lors de la lecture des informations relatives à la gestion des stocks.
  #  GMESSAGE = mess(521,182,1)
  #  GERR = 1
  #  Return
  #Endif
  # FGR 31/05/2013 : X3SUIVI90082 (fin)
Return

##########################################################################################################
# Chargement du tableau des consommations.
#################################################################################################
Subprog LOADHDT(SZITNNUM)
Value Char SZITNNUM

Local Integer ITER
Local Integer ISTOERR
Local Integer ILINDEB
Local Integer ICCEFLG(9)
Local Integer IDISCRGFLG(9)

  If !clalev([F:ITF]) : Local File ITMFACILIT [ITF]  Endif
  #Sortie de stock
  Call RAZSTOSORW From STKSOR
  Raz [M:ITN8]CREFLG
  Raz [M:ITN8]UPDFLG
  Raz [M:ITN8]SAVSTOISS    # FGR 05/08/2010 : X3SUIVI66063
  Raz GITN8HDTISSISS
  Raz GITN8DIRTYISSISS
  ILINDEB = 0
  ISTOERR = 0
  Raz IDISCRGFLG
  Raz ICCEFLG
  Gosub RAZ_ITN8_LOADHDT
  Filter [HDT] Where [F:HDT]ITNNUM = SZITNNUM and [F:HDT]TPL <> 2 Order By [F:HDT]HDTDONDAT Asc; [F:HDT]HDTDONHOU Asc; [F:HDT]HDTNUM Asc
  nolign = 0
  For [HDT] Hint Key HDT2
    If ILINDEB >= dim([M:ITN8]HDTMACSRE) Then
      Break
    Endif
    Gosub CHARGE_ITN8
    If GERR = 1 Then
      Break
    Endif
    ILINDEB += 1
  Next
  Filter [HDT]
  [M:ITN8]NBLIG = ILINDEB
  Call LOADTIMHDT From SUBITNB1
  Affzo [M:ITN8]1-99
End

##########################################################################################################
# Enregistrement des consommations
#####################################################################
Subprog SAVEHDT(SZSRENUM, SZITNNUM)
Value Char SZSRENUM
Value Char SZITNNUM

Local Char SZTXCCODE
Local Integer ITER
Local Integer IERR
Local Decimal IBID1
Local Decimal IBID2
Local Integer IBID3
Local Integer IBID4
Local Integer J
Local Integer IBDEBTRANSFLG

  IBID1 = 0
  IBID2 = 0
  IBID3 = 0
  IBID4 = 0
  ITER = 0
  IERR = 0
  J = 0
  SZTXCCODE = ""
  If !clalev ([F:CAL]) : Local File CPTANALIN [CAL] : Endif
  Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
  If fstat Then
    #Les informations de la demande de service n'ont pas pu être obtenues. L'enregistrement des consommations a échoué.
    GMESSAGE = mess(523,182,1)
    GERR = 1
    End
  Endif
  If adxlog = 1 Then
    #On a une transaction en cours
    IBDEBTRANSFLG = 1
  Else
    #On n'a pas de transaction en cours
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [HDT]
  Endif
  For [HDT] Where [F:HDT]ITNNUM = SZITNNUM
    Call ENREG_ACCCCE(0, "", "", "", "HDT", 0, [F:HDT]HDTNUM, 0, 0, "", "A") From TRTX3CPT
    If GOK < 1 Then
      #Erreur lors de la suppression des axes analytiques associés aux consommations de l'intervention.
      GMESSAGE = mess(430,177,1)
      GERR = 1
      GOK = 0
      Break
    Endif
  Next
  If GERR > 0 Then
    If IBDEBTRANSFLG = 0 Then
      Rollback
      #End  # FGR 02/01/2012 : X3SUIVI78440 : Ca pas bon dans tous les cas ici !
    Endif
    End     # FGR 02/01/2012 : X3SUIVI78440 : C'est mieux ici !
  Endif
  #On efface tout
  Delete [HDT] Where [F:HDT]ITNNUM = SZITNNUM
  If fstat Then
    #Erreur lors de l'enregistrement des travaux.
    GMESSAGE = mess(186,182,1)
    GERR = 1
    GOK = 0
    Call FSTA("HDT") From GLOCK
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GERR > 0 Then
      Rollback
    #Else                               # FGR 02/01/2012 : X3SUIVI78440 : ou tout est bon, ou rien
    #  Commit                           # FGR 02/01/2012 : X3SUIVI78440 : ou tout est bon, ou rien
    Endif
  Endif
  If GERR > 0 Then
    GOK = 0
    End
  Endif
  #If IBDEBTRANSFLG = 0 Then            # FGR 02/01/2012 : X3SUIVI78440 : ou tout est bon, ou rien
  #  Call DEBTRANS From GLOCK           # FGR 02/01/2012 : X3SUIVI78440 : ou tout est bon, ou rien
  #  Trbegin [HDT]                      # FGR 02/01/2012 : X3SUIVI78440 : ou tout est bon, ou rien
  #Endif                                # FGR 02/01/2012 : X3SUIVI78440 : ou tout est bon, ou rien
  #On récrée
  nolign =  0
  For ITER = 0 To [M:ITN8]NBLIG-1
    If [M:ITN8]HDTITM(ITER) <> "" Then
      nolign += 1
      SZTXCCODE = [M:ITN8]HDTSALTEX(ITER)
      #Enregistrement du Clob Consommation
      If [M:ITN8]HDTNUM(ITER) = "" Then
        If [M:ITN8]HDTNUMSEQ(ITER) = "" Then
          #Erreur lors de l'enregistrement des textes saisis sur les consommations.
          GMESSAGE = mess(906,182,1) - "(a)"
          GERR = 1
          GOK = 0
          Break
        Else
          Read [HD7]HD70=[M:ITN8]HDTNUMSEQ(ITER);"HDTSEQ";adxuid(1)
        Endif
      Else
        Read [HD7]HD70=[M:ITN8]HDTNUM(ITER);"HDT";adxuid(1)
      Endif
      If !fstat Then
        If [M:ITN8]HDTSALTEX(ITER) = "" Then
          SZTXCCODE = ""
          Call CPTTXCKEY(SZTXCCODE, IERR) From SUBSREB3
          If IERR Then
            #Erreur lors de l'enregistrement des textes saisis sur les consommations.
            GMESSAGE = mess(906,182,1) - "(b)"
            GERR = 1
            GOK = 0
            Break
          Endif
        Else
          SZTXCCODE = [M:ITN8]HDTSALTEX(ITER)
          Delete [TXC] Where [F:TXC]CODE = [M:ITN8]HDTSALTEX(ITER)
          If fstat Then
            #Erreur lors de l'enregistrement des textes saisis sur les consommations.
            GMESSAGE = mess(906,182,1) - "(c)"
            GERR = 1
            Call FSTA("TXC") From GLOCK
            GOK = 0
            Break
          Endif
        Endif
        #Ecriture du texte dans TEXCLOB
        Raz [F:TXC]
        [F:TXC]CODE = SZTXCCODE
        [F:TXC]TEXTE = [F:HD7]CLOB
        [F:TXC]CREUSR = GUSER
        [F:TXC]CREDAT = date$
        Write [TXC]
        If fstat Then
          #Erreur lors de l'enregistrement des textes saisis sur les consommations.
          GMESSAGE = mess(906,182,1) - "(d)"
          GERR = 1
          Call FSTA("TXC") From GLOCK
          GOK = 0
          Break
        Endif
      Endif
      #Enregistrement de la clé
      Raz [F:HDT]  # Issue X3-52139 - 2017-08-25 by FGR
      If [M:ITN8]HDTNUM(ITER) = "" Then
        #------------------------------------------------------------#
        # --> Calcul du code compteur                                #
        #------------------------------------------------------------#
        Call CPTHDTKEY([M:ITN0]SALFCY, [F:HDT]HDTNUM, IERR) From SUBSREB1
        If IERR Then
          #Erreur lors de l'enregistrement des travaux.
          GMESSAGE = mess(186,182,1)
          GERR = 1
          GOK = 0
          Break
        Endif
        [M:ITN8]HDTNUM(ITER) = [F:HDT]HDTNUM
      Else
        [F:HDT]HDTNUM = [M:ITN8]HDTNUM(ITER)
      Endif
      #Transclass
      [F:HDT] = [M:ITN8]
      # FGR 03/01/2013 : X3SUIVI86797 (début)
      [F:HDT]VAT(0) = [M:ITN8]VAT1(ITER)
      [F:HDT]VAT(1) = [M:ITN8]VAT2(ITER)
      [F:HDT]VAT(2) = [M:ITN8]VAT3(ITER)
      # FGR 03/01/2013 : X3SUIVI86797 (fin)
      [F:HDT]SRENUM = SZSRENUM
      [F:HDT]HDTSALTEX = SZTXCCODE
      [F:HDT]ITNNUM = SZITNNUM
      [F:HDT]TPL = 1
      If [M:ITN1]SCO = 2 Then
        [F:HDT]HDTAUSTYP = 2
      Else
        [F:HDT]HDTAUSTYP = 1
      Endif
      [F:HDT]HDTAUS = [M:ITN1]ITNASS
      [F:HDT]HDTPLNDAT = [M:ITN1]DATX
      If GITN8DIRTYISSISS(ITER) > 0 Then
        [F:HDT]HDTISSISS = GITN8HDTISSISS(ITER)
        [M:ITN8]HDTISSISS(ITER) = GITN8HDTISSISS(ITER)
      Endif
      # -----------------------------------
      # FGR 13/08/2014 : X3SUIVI91771 (début) : S'il la sortie de stock n'est pas faite, il n'y a pas de qté sortie.
      If [M:ITN8]HDTSTOISS(ITER) <> 2 and [M:ITN8]HDTISSISS(ITER) <> 0 Then
        [M:ITN8]HDTISSISS(ITER) = 0
        [F:HDT]HDTISSISS = 0
      Endif
      # FGR 13/08/2014 : X3SUIVI91771 (fin)
      # -----------------------------------
      Write [HDT]
      If fstat Then
        #Erreur lors de l'enregistrement des consommations.
        GMESSAGE = mess(186,182,1)
        GERR = 1
        Call FSTA("HDT") From GLOCK
        GOK = 0
        Break
      Endif
      #
      Call ENREG_ACCCCE(nolign-1, "", "", "[M:ITN8]CCE", "HDT", 0, [F:HDT]HDTNUM, 0, 0, "", "C") From TRTX3CPT
      If GOK < 1 Then
        #Erreur lors de l'enregistrement des axes analytiques des consommations
        GMESSAGE = mess(428,177,1)
        GERR = 1
        GOK = 0
        Break
      Endif
      #Sortie de stock
      If [M:ITN8]HDTTYP(ITER) = 2 Then
        If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
          If [M:ITN8]HDTSTOISS(ITER) = 2 Then
            If [M:ITN8]HDTISSQTY(ITER) > 0 Then
              If [M:ITN8]WSTOSEQ(ITER) > 0 Then
                Gosub ALI_STW
                Call ALISTOWORK(3, [M:ITN8]WSTOSEQ(ITER), IBID1, IBID2, IBID3, IBID4, IERR) From STKINT
                If IERR Then
                  #Erreur lors du traitement des sorties de stock.
                  GMESSAGE = mess(522,182,1)
                  GERR = 1
                  GOK = 0
                  Break
                Endif
                Call MAJ_STOCK From STKMAJ
                If GOK < 1 Then
                  #Erreur lors du traitement des sorties de stock.
                  GMESSAGE = mess(522,182,1)
                  GERR = 1
                  GOK = 0
                  Break
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
      If GERR Then
        Break
      Endif
    Endif
  Next
  If IBDEBTRANSFLG = 0 Then
    If GERR > 0 Then
      Rollback
    #Else                               # FGR 02/01/2012 : X3SUIVI78440 : ou tout est bon, ou rien
    #  Commit                           # FGR 02/01/2012 : X3SUIVI78440 : ou tout est bon, ou rien
    Endif
  Endif
  If GERR Then
    End
  Endif
  Gosub DELHD7CLOB From SUBSREB1
  If IBDEBTRANSFLG = 0 Then
    If GERR > 0 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
# Enregistrement des consommations au cours d'une création
#####################################################################
Subprog SAVEHDTCRE(SZSRENUM, SZITNNUM)
Value Char SZSRENUM
Value Char SZITNNUM

Local Char SZTXCCODE
Local Integer ITER
Local Integer IERR
Local Decimal IBID1
Local Decimal IBID2
Local Integer IBID3
Local Integer IBID4
Local Integer J
Local Integer IBDEBTRANSFLG

  IBID1 = 0
  IBID2 = 0
  IBID3 = 0
  IBID4 = 0
  ITER = 0
  IERR = 0
  J = 0
  SZTXCCODE = ""
  If adxlog = 1 Then
    #On a une transaction en cours
    IBDEBTRANSFLG = 1
  Else
    #On n'a pas de transaction en cours
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [HDT]
  Endif
  If !clalev([F:CAL]) : Local File CPTANALIN [CAL] : Endif
  nolign =  0
  For ITER = 0 To [M:ITN8]NBLIG-1
    If [M:ITN8]HDTITM(ITER) <> "" Then
      nolign += 1
      SZTXCCODE = [M:ITN8]HDTSALTEX(ITER)
      #Enregistrement du Clob Consommation
      If [M:ITN8]HDTNUM(ITER) = "" Then
        If [M:ITN8]HDTNUMSEQ(ITER) = "" Then
          #Erreur lors de l'enregistrement des textes saisis sur les consommations.
          GMESSAGE = mess(906,182,1) - "(e)"
          GERR = 1
          GOK = 0
          Break
        Else
          Read [HD7]HD70=[M:ITN8]HDTNUMSEQ(ITER);"HDTSEQ";adxuid(1)
        Endif
      Else
        Read [HD7]HD70=[M:ITN8]HDTNUM(ITER);"HDT";adxuid(1)
      Endif
      If !fstat Then
        If [M:ITN8]HDTSALTEX(ITER) = "" Then
          SZTXCCODE = ""
          Call CPTTXCKEY(SZTXCCODE, IERR) From SUBSREB3
          If IERR Then
            #Erreur lors de l'enregistrement des textes saisis sur les consommations.
            GMESSAGE = mess(906,182,1) - "(f)"
            GERR = 1
            GOK = 0
            Break
          Endif
        Else
          SZTXCCODE = [M:ITN8]HDTSALTEX(ITER)
          Delete [TXC] Where [F:TXC]CODE = [M:ITN8]HDTSALTEX(ITER)
          If fstat Then
            #Erreur lors de l'enregistrement des textes saisis sur les consommations.
            GMESSAGE = mess(906,182,1) - "(g)"
            GERR = 1
            GOK = 0
            Call FSTA("TXC") From GLOCK
            Break
          Endif
        Endif
        #Ecriture du texte dans TEXCLOB
        Raz [F:TXC]
        [F:TXC]CODE = SZTXCCODE
        [F:TXC]TEXTE = [F:HD7]CLOB
        [F:TXC]CREUSR = GUSER
        [F:TXC]CREDAT = date$
        Write [TXC]
        If fstat Then
          #Erreur lors de l'enregistrement des textes saisis sur les consommations.
          GMESSAGE = mess(906,182,1) - "(h)"
          GERR = 1
          GOK = 0
          Break
        Endif
      Endif
      If [M:ITN8]HDTNUM(ITER) = "" Then
        #Création
        Raz [F:HDT]
        #------------------------------------------------------------#
        # --> Calcul du code compteur                                #
        #------------------------------------------------------------#
        Call CPTHDTKEY([M:ITN0]SALFCY, [F:HDT]HDTNUM, IERR) From SUBSREB1
        If IERR Then
          #Erreur lors de l'enregistrement des travaux.
          GMESSAGE = mess(186,182,1)
          GERR = 1
          GOK = 0
          Break
        Endif
        [M:ITN8]HDTNUM(ITER) = [F:HDT]HDTNUM
        #Transclass
        [F:HDT] = [M:ITN8]
        # FGR 03/01/2013 : X3SUIVI86797 (début)
        [F:HDT]VAT(0) = [M:ITN8]VAT1(ITER)
        [F:HDT]VAT(1) = [M:ITN8]VAT2(ITER)
        [F:HDT]VAT(2) = [M:ITN8]VAT3(ITER)
        # FGR 03/01/2013 : X3SUIVI86797 (fin)
        [F:HDT]SRENUM = SZSRENUM
        [F:HDT]HDTSALTEX = SZTXCCODE
        [F:HDT]ITNNUM = SZITNNUM
        [F:HDT]TPL = 1
        If [M:ITN1]SCO = 2 Then
          [F:HDT]HDTAUSTYP = 2
        Else
          [F:HDT]HDTAUSTYP = 1
        Endif
        [F:HDT]HDTAUS = [M:ITN1]ITNASS
        [F:HDT]HDTPLNDAT = [M:ITN1]DATX
        If GITN8DIRTYISSISS(ITER) > 0 Then
          [F:HDT]HDTISSISS = GITN8HDTISSISS(ITER)
          [M:ITN8]HDTISSISS(ITER) = GITN8HDTISSISS(ITER)
        Endif
        Write [HDT]
        If fstat Then
          #Erreur lors de l'enregistrement des consommations.
          GMESSAGE = mess(186,182,1)
          GERR = 1
          GOK = 0
          Break
        Endif
        #
        Call ENREG_ACCCCE(nolign-1, "", "", "[M:ITN8]CCE", "HDT", 0, [F:HDT]HDTNUM, 0, 0, "", "C") From TRTX3CPT
        If GOK < 1 Then
          #Erreur lors de l'enregistrement des axes analytiques des consommations
          GMESSAGE = mess(428,177,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Else
        #Modification
        Readlock [HDT]HDT0=[M:ITN8]HDTNUM(ITER)
        If fstat Then
          #Erreur lors de l'enregistrement des consommations.
          GMESSAGE = mess(186,182,1)
          GERR = 1
          GOK = 0
          Unlock [HDT]
          Break
        Endif
        [F:HDT] = [M:ITN8]
        # FGR 03/01/2013 : X3SUIVI86797 (début)
        [F:HDT]VAT(0) = [M:ITN8]VAT1(ITER)
        [F:HDT]VAT(1) = [M:ITN8]VAT2(ITER)
        [F:HDT]VAT(2) = [M:ITN8]VAT3(ITER)
        # FGR 03/01/2013 : X3SUIVI86797 (fin)
        [F:HDT]SRENUM = SZSRENUM
        [F:HDT]ITNNUM = SZITNNUM
        [F:HDT]TPL = 1
        If [M:ITN1]SCO = 2 Then
          [F:HDT]HDTAUSTYP = 2
        Else
          [F:HDT]HDTAUSTYP = 1
        Endif
        [F:HDT]HDTAUS = [M:ITN1]ITNASS
        [F:HDT]HDTPLNDAT = [M:ITN1]DATX
        If GITN8DIRTYISSISS(ITER) > 0 Then
          [F:HDT]HDTISSISS = GITN8HDTISSISS(ITER)
          [M:ITN8]HDTISSISS(ITER) = GITN8HDTISSISS(ITER)
        Endif
        Rewrite [HDT]
        If fstat Then
          #Erreur lors de l'enregistrement des consommations.
          GMESSAGE = mess(186,182,1)
          GERR = 1
          GOK = 0
          Unlock [HDT]
          Break
        Endif
        #
        #Modification
        Call ENREG_ACCCCE(nolign-1, "", "", "[M:ITN8]CCE", "HDT", 0, [F:HDT]HDTNUM, 0, 0, "", "M") From TRTX3CPT
        If GOK < 1 Then
          #Erreur lors de l'enregistrement des axes analytiques des consommations
          GMESSAGE = mess(428,177,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Endif
      #Sortie de stock
      If [M:ITN8]HDTTYP(ITER) = 2 Then
        If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
          If [M:ITN8]HDTSTOISS(ITER) = 2 Then
            If [M:ITN8]HDTISSQTY(ITER) > 0 Then
              If [M:ITN8]WSTOSEQ(ITER) > 0 Then
                Gosub ALI_STW
                Call ALISTOWORK(3, [M:ITN8]WSTOSEQ(ITER), IBID1, IBID2, IBID3, IBID4, IERR) From STKINT
                If IERR Then
                  #Erreur lors du traitement des sorties de stock.
                  GMESSAGE = mess(522,182,1)
                  GERR = 1
                  GOK = 0
                  Break
                Endif
                Call MAJ_STOCK From STKMAJ
                If GOK < 1 Then
                  #Erreur lors du traitement des sorties de stock.
                  GMESSAGE = mess(522,182,1)
                  GERR = 1
                  GOK = 0
                  Break
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
      If GERR Then
        Break
      Endif
    Endif
  Next
  If IBDEBTRANSFLG = 0 Then
    If GERR > 0 Then
      Rollback
    #Else                               # FGR 02/01/2012 : X3SUIVI78440 : ou tout est bon, ou rien
    #  Commit                           # FGR 02/01/2012 : X3SUIVI78440 : ou tout est bon, ou rien
    Endif
  Endif
  If GERR Then
    End
  Endif
  Gosub DELHD7CLOB From SUBSREB1
  If IBDEBTRANSFLG = 0 Then
    If GERR > 0 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

##########################################################################################################
# Calcul le montant consommé pour chaque ligne d'un même code article du tableau des consommations
################################################################
Subprog RUNTARIF(SZITM, DCBQTY, SZUOM, INOL)
Value Char SZITM
Value Decimal DCBQTY
Value Char SZUOM
Value Integer INOL

Local Integer ITER
Local Decimal GROPRI
Local Decimal NETPRI
Local Decimal MAJREM(0..8)
Local Integer ITERNET
Local Char SZVACBPR
Local Decimal DCBCUMQTY
Local Decimal DCBCLCQTY
Local Decimal ICOEFPARAM
Local Integer IERRINF
Local Decimal IPITHDT     # FGR 02/02/2010 : X3SUIVI62146 : Pas Integer
Local Decimal IINVPITFLG  # FGR 02/02/2010 : X3SUIVI62146 : Pour le moment tout doit être decimal

# YA040
Local Decimal WPRECIO
#FIN YA040

  IERRINF = 0
  If SZITM = "" Then
    [M:ITN8]HDTAMT(INOL) = 0
    End
  Endif
  Read [ITS]ITS0=SZITM
  If fstat Then
    [M:ITN8]HDTAMT(INOL) = 0
    End
  Endif
  Read [ITM]ITM0=SZITM
  If fstat Then
    [M:ITN8]HDTAMT(INOL) = 0
    End
  Endif
  #Contrôle de l'association de l'intervention à une demande de service.
  If [M:ITN0]SRVDEMNUM = "" Then
    [M:ITN8]HDTAMT(INOL) = 0
    End
  Endif
  Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
  If fstat Then
    [M:ITN8]HDTAMT(INOL) = 0
    End
  Endif
  #On obtient un régime de taxe
  If [F:SRE]SREVACBPR = "" Then
    Read [BPC]BPC0=[F:SRE]SREBPC
    If fstat Then
      SZVACBPR = ""
    Else
      SZVACBPR = [F:BPC]VACBPR
    Endif
  Else
    SZVACBPR = [F:SRE]SREVACBPR
  Endif
  If SZVACBPR = "" Then
    [M:ITN8]HDTAMT(INOL) = [F:ITS]BASPRI * DCBQTY
    Raz [M:ITN8]VAT1
    Raz [M:ITN8]VAT2
    Raz [M:ITN8]VAT3
    Raz [M:ITN8]CLCAMT1
    Raz [M:ITN8]CLCAMT2
    Raz [M:ITN8]PRIREN
    Raz [M:ITN8]SAUSTUCOE
    Raz [M:ITN8]HDTSTUQTY
    #
    Gosub READ_CODACT_SPX
  Else
    Local Mask SPSW [SPSW]
    [M:SPSW]BPCREF = [F:SRE]SREBPC
    [M:SPSW]DATREF = date$
    [M:SPSW]USRREF = GUSER
    [M:SPSW]CUR = [F:SRE]SRECUR
    [M:SPSW]PRITYP = [F:SRE]SREPRITYP
    [M:SPSW]VACBPR = [F:SRE]SREVACBPR
    [M:SPSW]CHGTYP = [F:SRE]SRECHGTYP
    [M:SPSW]SAU = [F:ITM]STU
    [M:SPSW]CONTEXT = "ITN"
    Call RECHVATCOD(1,1,[M:SPSW]BPCREF,[F:ITM]ITMREF,"CRM5",INOL,[M:SPSW]VAT) From TRTX3
    #Calcul des taxes complémentaire pour la seule ligne courante.
    Call ALICLCAMT([F:ITM]ITMREF, DCBQTY, INOL, "CRM5", [M:ITN8]CLCAMT1(INOL), [M:ITN8]CLCAMT2(INOL)) From TRTX3
    #Calcul de la quantité courante en unité de stock
    Call SREC_COE(SZITM, [M:ITN0]BPC, [F:ITM]STU, SZUOM, ICOEFPARAM) From TRTVENQTE
    [M:ITN8]SAUSTUCOE(INOL) = ICOEFPARAM
    DCBCUMQTY = DCBQTY * [M:ITN8]SAUSTUCOE(INOL)
    DCBCLCQTY = DCBQTY * [M:ITN8]SAUSTUCOE(INOL)
    [M:ITN8]HDTSTUQTY(INOL) = DCBCUMQTY
    #Sortie de stock
    If [M:ITN8]HDTTYP(INOL) = 2 Then                           # FGR 02/01/2012 : X3SUIVI78440 pas nolign-1
      If [M:ITN8]HDTDONDAT(INOL) <> [00/00/00] Then            # FGR 02/01/2012 : X3SUIVI78440 pas nolign-1
        If [M:ITN8]HDTSTOISS(INOL) = 2 Then                    # FGR 02/01/2012 : X3SUIVI78440 pas nolign-1
          [M:ITN8]HDTISSQTY(INOL) = [M:ITN8]HDTSTUQTY(INOL)    # FGR 02/01/2012 : X3SUIVI78440 pas nolign-1
        Endif
      Endif
    Endif
    #Calcul de la quantité cumulée en unité de stock
    For ITER = 0 To [M:ITN8]NBLIG-1
      If ITER <> INOL Then
        If SZITM = [M:ITN8]HDTITM(ITER) Then
          DCBCUMQTY += [M:ITN8]HDTSTUQTY(ITER)
        Endif
      Endif
    Next
    #Recherche du tarif
    Call ALICLCAMT([F:ITM]ITMREF, DCBCUMQTY, -1, "CRM6", [M:SPSW]CLCAMT1, [M:SPSW]CLCAMT2) From TRTX3
    #PROVISOIRE
    Gosub CRM_OPEN_BPR_VENTE From CRMMULTISOC
    Gosub CRM_OPEN_BPC_VENTE From CRMMULTISOC
    Call RECH_TARIF(1, [F:ITM]ITMREF, 0, DCBCUMQTY, "CRM", GROPRI) From TRTVENTAR
    Gosub CRM_CLOSE_BPR_VENTE From CRMMULTISOC
    Gosub CRM_CLOSE_BPC_VENTE From CRMMULTISOC
    #
    Raz MAJREM
    NETPRI = 0
    For ITERNET = 1 To dim(MAJREM)
      If evalue("dim([M:SPSW]DISCRGVAL" + num$(ITERNET) + ")") > 0 Then
        MAJREM(ITERNET-1) = evalue("[M:SPSW]DISCRGVAL" + num$(ITERNET))
      Endif
    Next

# YA040
    Raz WPRECIO
    Call BUSCAR_PRECIO([M:ITN8]HDTMACSRE(INOL), [M:ITN8]HDTITM(INOL), [M:ITN8]HDTQTY(INOL), WPRECIO) From SPESRE
    If WPRECIO <> 0 Then
      GROPRI = WPRECIO
    Endif
# FIN YA040

    #Calcul du prix net unitaire
    Call CALNET (1, "", GROPRI, MAJREM, DCBCUMQTY, NETPRI, [M:SPSW]CUR) From TRTPRICE
    #Calcul du prix net de la ligne courante
    [M:ITN8]HDTAMT(INOL) = NETPRI * [M:ITN8]HDTSTUQTY(INOL)
    [M:ITN8]HDTAMTINV(INOL) = arr(NETPRI * [M:ITN8]HDTSTUQTY(INOL),10^-2)
    #Calcul du prix net des autres lignes du même article
    For ITER = 0 To [M:ITN8]NBLIG-1
      If ITER <> INOL Then
        If SZITM = [M:ITN8]HDTITM(ITER) Then
          If [M:ITN8]HDTINV(ITER) = G_OUI Then  # FGR 03/01/2012 : X3SUIVI76710 : on applique le tarif que sur les lignes déjà facturables
            [M:ITN8]HDTAMT(ITER) = NETPRI * [M:ITN8]HDTSTUQTY(ITER)
            If [M:ITN8]MANAMTFLG(ITER) <> 2 Then
              [M:ITN8]HDTAMTINV(ITER) = arr(NETPRI * [M:ITN8]HDTSTUQTY(ITER),10^-2)
              If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
                # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
                Call AMOUNT(0, "ITN8", ITER, [M:ITN8]HDTAMT(ITER), [M:ITN8]HDTINV(ITER), [M:ITN8]HDTAMTINV(ITER), [M:ITN8]PITHDT(ITER), [M:ITN8]INVPITFLG(ITER), IERRINF) From TRTAMOUNT
              Else
                IPITHDT = 0
                IINVPITFLG = 0
                Call AMOUNT(0, "ITN8", ITER, [M:ITN8]HDTAMT(ITER), [M:ITN8]HDTINV(ITER), [M:ITN8]HDTAMTINV(ITER), IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
              Endif
              If IERRINF Then
                GMESSAGE = mess(IERRINF,182,1)
                GERR = 1
                Break
              Endif
            Endif
          Endif
        Endif
      Endif
    Next
    If GERR Then
      End
    Endif
    #Transfert des informations du masque vers l'écran (Ligne courante)
    [M:ITN8]VAT1(INOL) = [M:SPSW]VAT(0)
    [M:ITN8]VAT2(INOL) = [M:SPSW]VAT(1)
    [M:ITN8]VAT3(INOL) = [M:SPSW]VAT(2)
    [M:ITN8]PRIREN(INOL) = [M:SPSW]PRIREN
    #
    For ITERNET = 1 To 9
      If evalue("dim([M:ITN8]DISCRGVAL" + num$(ITERNET) + ")") > 0 Then
        If evalue("dim([M:SPSW]DISCRGVAL" + num$(ITERNET) + ")") > 0 Then
          Assign ("[M:ITN8]DISCRGVAL" + num$(ITERNET) + "(INOL)") With evalue("[M:SPSW]DISCRGVAL" + num$(ITERNET))
          Assign ("[M:ITN8]DISCRGREN" + num$(ITERNET) + "(INOL)") With evalue("[M:SPSW]DISCRGREN" + num$(ITERNET))
        Endif
      Endif
    Next ITERNET
    #Transfert des informations du masque vers l'écran (Lignes du même article)
    For ITER = 0 To [M:ITN8]NBLIG-1
      If ITER <> INOL Then
        If SZITM = [M:ITN8]HDTITM(ITER) Then
          If [M:ITN8]MANAMTFLG(ITER) <> 2 Then
            [M:ITN8]PRIREN(ITER) = [M:SPSW]PRIREN
            For ITERNET = 1 To 9
              If evalue("dim([M:ITN8]DISCRGVAL" + num$(ITERNET) + ")") > 0 Then
                If evalue("dim([M:SPSW]DISCRGVAL" + num$(ITERNET) + ")") > 0 Then
                  Assign ("[M:ITN8]DISCRGVAL" + num$(ITERNET) + "(ITER)") With evalue("[M:SPSW]DISCRGVAL" + num$(ITERNET))
                  Assign ("[M:ITN8]DISCRGREN" + num$(ITERNET) + "(ITER)") With evalue("[M:SPSW]DISCRGREN" + num$(ITERNET))
                Endif
              Endif
            Next
          Endif
        Endif
      Endif
    Next
    Close Local Mask [SPSW]
  Endif
End

##########################################################################################################
# Gestion des menus Horodatage
#####################################################################
Subprog MNGHORO(SZITNNUM, SZHDTNUM, INOL, IAFFFLG)
Value Char SZITNNUM
Value Char SZHDTNUM
Value Integer INOL
Value Integer IAFFFLG

  If GIITN8TIMFLG Then
    Call QUITHORO(SZITNNUM, SZHDTNUM, IAFFFLG)
  Else
    Call BEGINHORO(INOL)
  Endif
End

##########################################################################################################
# Gestion du lancement d'un Horodatage
#####################################################################
Subprog BEGINHORO(INOL)
Value Integer INOL

Local Char RETOUR
Local Integer IHANGUP1
Local Integer IHANGUP2

  RETOUR = ""
  IHANGUP1 = 86400
  IHANGUP2 = 100
  If !GIITN8TIMFLG Then
    [M:ITN8]BLKTIT = mess(184,182,1) #Horodatage en cours
    GIITN8TIMFLG = 1
    GIITN8TIMNOL = INOL
    GIITN8TIMHDTNUM = [M:ITN8]HDTNUM(INOL)
    GIITN8STRDAYCTL = nday(date$)
    GIITN8STRSODCTL = time
  Endif
  Callui RETOUR="" With "UIAction="+chr$(1)+"Sethangup"
&                    , "UITimehangup1="+chr$(1)+num$(IHANGUP1)
&                    , "UITimehangup2="+chr$(1)+num$(IHANGUP2)
  Affzo [M:ITN8]BLKTIT
End

##########################################################################################################
# Gestion de l'abandon d'un Horodatage
#####################################################################
Subprog QUITHORO(SZITNNUM, SZHDTNUM, IAFFFLG)
Value Char SZITNNUM
Value Char SZHDTNUM
Value Integer IAFFFLG

Local Integer ITOTMNT
Local Integer INBSOD
Local Integer ITIMSPGHOU
Local Integer ITIMSPGMNT
Local Char SZMESS(250)
Local Integer IMESSOK

  ITOTMNT = 0
  INBSOD = 0
  ITIMSPGHOU = 0
  ITIMSPGMNT = 0
  IMESSOK = 0
  If GIITN8TIMFLG Then
    GIITN8TIMFLG = 0
    [M:ITN8]BLKTIT = ""
    #Détermine si l'horodatage est inférieur à la minute
    If GIITN8STRDAYCTL = nday(date$) Then
      ITOTMNT = time - GIITN8STRSODCTL
      If ITOTMNT < 60 Then
        If IAFFFLG Then
          #Aucun nouvel horodatage n'a été enregistré pour cette demande. Sa durée est en effet inférieure à la minute.
          GMESSAGE = mess(190,182,1)
          GERR = 3
        Endif
        If IAFFFLG Then
          Affzo [M:ITN8]BLKTIT
        Endif
        End
      Endif
    Endif
    #Détermine si l'horodatage s'est déroulé sur plusieurs jours.
    If GIITN8STRDAYCTL <> nday(date$) Then
      If IAFFFLG Then
        #Aucun nouvel horodatage n'a été enregistré pour cette demande. Sa durée s'échelonne en effet sur plusieurs jours.
        GMESSAGE = mess(221,182,1)
        GERR = 3
      Endif
      If IAFFFLG Then
        Affzo [M:ITN8]BLKTIT
      Endif
      End
    Endif
    #Tout est bon. On peut donc calculer les jours, heures et minutes
    INBSOD = time - GIITN8STRSODCTL
    #Calcul du nombre d'heures
    ITIMSPGHOU = int(INBSOD / 3600)
    #Calcul du nombre de minutes
    ITIMSPGMNT = int((mod(INBSOD, 3600)) / 60)
    #Avant d'enregistrer l'horodatage, on demande si celui-ci achève la ligne de prestation à réaliser
    #La prestation à réaliser est-elle totalement achevée au terme de cet horodatage ?
    If IAFFFLG Then
      SZMESS = mess(249,182,1)
      Call OUINON(SZMESS, IMESSOK) From GESECRAN
    Else
      IMESSOK = 1
    Endif
    Call SAVEHORO(SZHDTNUM, IAFFFLG, 1, IMESSOK, ITIMSPGHOU, ITIMSPGMNT)
    If IAFFFLG Then
      If IMESSOK = 2 Then
        Call LOADHDT(SZITNNUM)
      Else
        Affzo [M:ITN8]SPGTIMHOU(GIITN8TIMNOL)
        Affzo [M:ITN8]SPGTIMMNT(GIITN8TIMNOL)
      Endif
    Endif
  Endif
  If IAFFFLG Then
    Affzo [M:ITN8]BLKTIT
  Endif
  GIITN8TIMITNNUM = ""
  GIITN8TIMHDTNUM = ""
End

##########################################################################################################
# Enregistrement d'un nouvel horodatage
###########################################################
Subprog SAVEHORO(SZHDTNUM, IAFFFLG, IDURFLG, IANSWER, ISPGHOU, ISPGMNT)
Value Char SZHDTNUM
Value Integer IAFFFLG
Value Integer IDURFLG
Value Integer IANSWER
Value Integer ISPGHOU
Value Integer ISPGMNT

Local Integer IOLDSPGHOU
Local Integer IOLDSPGMNT
Local Integer INEWSPGHOU
Local Integer INEWSPGMNT

  Call DEBTRANS From GLOCK
  Trbegin [HDT]
  Readlock [HDT]HDT0=SZHDTNUM
  If fstat Then
    #Erreur lors de l'enregistrement de l'horodatage relatif à la consommation sélectionnée.
    GMESSAGE = mess(250,182,1)
    GERR = 1
    Rollback
    Unlock [HDT]
    End
  Endif
  IOLDSPGHOU = [F:HDT]SPGTIMHOU
  IOLDSPGMNT = [F:HDT]SPGTIMMNT
  INEWSPGHOU = [F:HDT]SPGTIMHOU + ISPGHOU
  INEWSPGMNT = [F:HDT]SPGTIMMNT + ISPGMNT
  If IANSWER = 2 Then
    #La consommation est effectuée.
    [F:HDT]HDTDONDAT = date$
    [F:HDT]HDTDONHOU = time
    [F:HDT]SPGTIMHOU += ISPGHOU
    [F:HDT]SPGTIMMNT += ISPGMNT
    If IAFFFLG Then
      [M:ITN8]HDTDONDAT(GIITN8TIMNOL) = date$
      [M:ITN8]HDTDONHOU(GIITN8TIMNOL) = time
      Call SECTOHOU([M:ITN8]HDTDONHOU(GIITN8TIMNOL), [M:ITN8]BHDTDONHOU(GIITN8TIMNOL)) From CRMUTIL140
      [M:ITN8]SPGTIMHOU(GIITN8TIMNOL) += ISPGHOU
      [M:ITN8]SPGTIMMNT(GIITN8TIMNOL) += ISPGMNT
    Endif
  Else
    #Seule une horodatage intermédiaire doit être enregistrée
    [F:HDT]SPGTIMHOU += ISPGHOU
    [F:HDT]SPGTIMMNT += ISPGMNT
    If IAFFFLG Then
      [M:ITN8]SPGTIMHOU(GIITN8TIMNOL) += ISPGHOU
      [M:ITN8]SPGTIMMNT(GIITN8TIMNOL) += ISPGMNT
    Endif
  Endif
  Rewrite [HDT]
  If fstat Then
    #Erreur lors de l'enregistrement de l'horodatage relatif à la consommation sélectionnée.
    GMESSAGE = mess(250,182,1)
    GERR = 1
    Rollback
    Unlock [HDT]
    End
  Endif
End

##########################################################################################################
# Propose une planification par défaut en fonction des consommations planifiées
##########################################################################
Subprog SETDEFPLN(DDATE, SZHOU, IHOU, IMNT)
Value Date DDATE
Value Char SZHOU
Value Integer IHOU
Value Integer IMNT

Local Integer INOTDURPLN
Local Integer INBDAYITN
Local Integer INBHOUITN
Local Integer INBMNTITN
Local Integer INBSECITN
Local Integer INBSEC
Local Char SZCHARHOU
Local Char SZCHARMNT
Local Char SZCHARHOU2
Local Char SZCHARMNT2
Local Integer ITER
Local Date DZNEWDATE # FGR 25/09/2007 : X3Suivi 34492
Local Date DZDATEEND # FGR 25/09/2007 : X3Suivi 34492
Local Integer IOK    # FGR 25/09/2007 : X3Suivi 34492
Local Integer ITYPE  # FGR 05/09/2008 : X3SUIVI33081

  ITER = 0
  INBDAYITN = 0
  INBHOUITN = 0
  INBMNTITN = 0
  INBSECITN = 0
  INOTDURPLN = 0
  INBSEC = 0
  SZCHARHOU = ""
  SZCHARMNT = ""
  SZCHARHOU2 = ""
  SZCHARMNT2 = ""
  DZNEWDATE = [0/0/0]  # FGR 25/09/2007 : X3Suivi 34492
  [M:ITN1]DURX = mess(1,976,1)
  If IHOU = 0 Then
    If IMNT = 0
      INOTDURPLN = 1
    Endif
  Endif
  [M:ITN1]HOU = SZHOU
  # FGR 25/09/2007 : X3SUIVI34492
  #[M:ITN1]DAT = DDATE
  #[M:ITN1]DATX = DDATE
  #[M:ITN1]DATEND = DDATE
  #While dayn([M:ITN1]DAT) > 5
  #    [M:ITN1]DAT = [M:ITN1]DAT + 1
  #    [M:ITN1]DATX = [M:ITN1]DATX + 1
  #    [M:ITN1]DATEND = [M:ITN1]DATEND + 1
  #Wend
  Call GETNEXTWDAY("", [M:ITN1]ITNASS, DDATE-1, DZNEWDATE, IOK) From CRM_UTIL
  # FGR 24/01/2008 X3SUIVI45356
  #If DDATE <> DZNEWDATE Then
  If DDATE <> DZNEWDATE and DZNEWDATE <> [0/0/0] Then
    # Si la prochaine date calculee est differente de celle saisie, c'est que
    # l'intervenant ne travaille pas ce jour là. Donc on force la date à une date compatible avec ses jours travaillés
    [M:ITN1]DAT = DZNEWDATE
    [M:ITN1]DATX = DZNEWDATE
    [M:ITN1]DATEND = DZNEWDATE
  Else
    # Sinon, la date est valide, on la prend
    [M:ITN1]DAT = DDATE
    [M:ITN1]DATX = DDATE
    [M:ITN1]DATEND = DDATE
  Endif
  [M:ITN1]WEE = week([M:ITN1]DATX)
  If INOTDURPLN Then
    #Ajoute une heure pour la date de fin
    If val(left$([M:ITN1]HOU, 2)) + 1 < 10
      SZCHARHOU2 = "0" + num$(val(left$([M:ITN1]HOU, 2)) + 1)
    Else
      SZCHARHOU2 = num$(val(left$([M:ITN1]HOU, 2)) + 1)
    Endif
    If val(mid$([M:ITN1]HOU, 3, 2)) < 10 Then
      SZCHARMNT2 = "0" + mid$([M:ITN1]HOU, 4, 2)
    Else
      SZCHARMNT2 = mid$([M:ITN1]HOU, 3, 2)
    Endif
    [M:ITN1]HOUEND = SZCHARHOU2 + SZCHARMNT2
    [M:ITN1]DUR = "00100"  # FGR 24/07/2014 : X3SUIVI101618 plus "0100"
  Else
    #On calcul le nombre de jours.
    Call DAYTOSEC(0, IHOU, IMNT, 0, 8, INBSEC) From CRMUTIL140
    Call SECTODAY(INBSEC, 8, INBDAYITN, INBHOUITN, INBMNTITN, INBSECITN) From CRMUTIL140
    If INBDAYITN Then
      DZDATEEND = [M:ITN1]DATEND  # FGR 25/09/2007 : X3SUIVI34492
      For ITER = 0 To INBDAYITN-1
        # FGR 25/09/2007 : X3SUIVI34492 : il y aura le même problème ici
        #[M:ITN1]DATEND = [M:ITN1]DATEND + 1
        #While dayn([M:ITN1]DATEND) > 5
        #    [M:ITN1]DATEND = [M:ITN1]DATEND + 1
        #Wend
        DZDATEEND += 1
        # On regarde si c'est un jour travaillé pour l'utilisateur
        Call GETNEXTWDAY("", [M:ITN1]ITNASS, DZDATEEND-1, DZNEWDATE, IOK) From CRM_UTIL
        If DZDATEEND <> DZNEWDATE Then
          # Si la prochaine date calculee est differente de la date de fin, c'est que
          # l'intervenant ne travaille pas ce jour là. Donc on force la date à une date
          # compatible avec ses jours travaillés
          # Remarque : ça n'influe pas sur la duree de l'intervention. Elle fera INBDAYITN jours, mais pas consécutifs
          DZDATEEND = DZNEWDATE
        Endif
      Next
      [M:ITN1]DATEND = DZDATEEND # FGR 25/09/2007 : X3Suivi 34492
    Endif
    If INBHOUITN > 4 Then
      INBHOUITN += 1
    Endif
    INBHOUITN += val(left$(SZHOU, 2))
    If INBHOUITN > 18 Then
      [M:ITN1]DATEND = [M:ITN1]DATEND + 1
      INBHOUITN = 9 + (18 - val(left$(SZHOU, 2)))
    Endif
    If INBHOUITN < 10 Then
      SZCHARHOU = "0" + num$(int(INBHOUITN))
    Else
      SZCHARHOU = num$(int(INBHOUITN))
    Endif
    If INBMNTITN < 10 Then
      SZCHARMNT = "0" + num$(int(INBMNTITN))
    Else
      SZCHARMNT = num$(int(INBMNTITN))
    Endif
    [M:ITN1]HOUEND = SZCHARHOU + SZCHARMNT
    # FGR 05/09/2008 : X3SUIVI33081 : calcul de la durée en fonction du schéma hebdomadaire
    If [M:ITN1]SCO = 1 Then
      ITYPE = 1
    Else
      ITYPE = 0
    Endif
    # FGR 23/07/2014 : X3SUIVI101618 durée maxi passée à 999h00 heures au lieu de 99h00 (9900)
    Call GET_DUREE_DT_HO(ITYPE, [M:ITN1]REP, [M:ITN0]SALFCY, "99900", [M:ITN1]DAT, [M:ITN1]HOU, [M:ITN1]DATEND, [M:ITN1]HOUEND, [M:ITN1]DUR) From CRM_UTIL
  Endif
End

##########################################################################################################
# Transforme en tant que effectuées toutes les consommations
###########################################################################
$DONHDKTASK
Local Integer ITER
Local Integer ISPGTIMHOU
Local Integer ISPGTIMMNT

  For ITER = 0 To [M:ITN8]NBLIG-1
    If [M:ITN8]HDTDONDAT(ITER) = [00/00/00] Then
      #Transforme la consommation comme effectuée
      [M:ITN8]HDTDONDAT(ITER) = date$
      [M:ITN8]HDTDONHOU(ITER) = time
      Call SECTOHOU([M:ITN8]HDTDONHOU(ITER), [M:ITN8]BHDTDONHOU(ITER)) From CRMUTIL140
      If [M:ITN8]HDTTYP(ITER) = 3 Then
        Call DEFSPGTIM([M:ITN0]BPC, [M:ITN8]HDTQTY(ITER), [M:ITN8]HDTUOM(ITER), [M:ITN8]HDTITM(ITER), ISPGTIMHOU, ISPGTIMMNT) From SUBITNB1
        [M:ITN8]SPGTIMHOU(ITER) = ISPGTIMHOU
        [M:ITN8]SPGTIMMNT(ITER) = ISPGTIMMNT
      Endif
    Endif
  Next
  Call LOADTIMHDT From SUBITNB1
  Affzo [M:ITN8]1-99
Return

##########################################################################################################
# Détecte s'il y a des consommations non effectuées pour l'intervention.  Classe M
#####################################################################
Subprog SETDONITNFLG (IERRINF,ICHAPTER,IBRETOUR)
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer ITERHDT
Local Integer IDONEFLG
Local Integer IREP
Local Integer ISPGTIMHOU
Local Integer ISPGTIMMNT
Local Integer IHDTDONHOU

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  IDONEFLG = 0
  IREP = 0
  IDONDATLG = 0
  ISPGTIMHOU = 0
  ISPGTIMMNT = 0
  #Contrôle dans l'écran des consommations
  For ITERHDT = 0 To [M:ITN8]NBLIG-1
    If [M:ITN8]HDTINV(ITERHDT) = 2 Then
      If [M:ITN8]HDTDONDAT(ITERHDT) = [00/00/00] Then
        IDONEFLG = 1
        Break
      Endif
    Endif
  Next
  #Si oui, on demande si on doit les passer en effectué.
  If IDONEFLG <> 0 Then
    IREP = 0
    #Souhaitez-vous transformer les consommations non effectuées de cette intervention en effectuées.
    Call OUINON(mess(325,182,1), IREP) From GESECRAN
    If IREP = 2 Then
      For ITERHDT = 0 To [M:ITN8]NBLIG-1
        If [M:ITN8]HDTDONDAT(ITERHDT) = [00/00/00] Then
          [M:ITN8]HDTDONDAT(ITERHDT) = date$
          [M:ITN8]BHDTDONHOU(ITERHDT) = left$(time$, 2) + mid$(time$, 4, 2)
          IHDTDONHOU = 0
          Call HOUTOSEC(val(left$(time$, 2)), val(mid$(time$, 4, 2)), IHDTDONHOU) From CRMUTIL140
          [M:ITN8]HDTDONHOU(ITERHDT) = IHDTDONHOU
          If [M:ITN8]HDTTYP(ITERHDT) = 3 Then
            If [M:ITN8]SPGTIMHOU(ITERHDT) = 0 Then
              If [M:ITN8]SPGTIMMNT(ITERHDT) = 0 Then
                ISPGTIMHOU = 0
                ISPGTIMMNT = 0
                Call DEFSPGTIM([M:ITN0]BPC, [M:ITN8]HDTQTY(ITERHDT), [M:ITN8]HDTUOM(ITERHDT), [M:ITN8]HDTITM(ITERHDT), ISPGTIMHOU, ISPGTIMMNT) From SUBITNB1
                [M:ITN8]SPGTIMHOU(ITERHDT) = ISPGTIMHOU
                [M:ITN8]SPGTIMMNT(ITERHDT) = ISPGTIMMNT
              Endif
            Endif
          Endif
        Endif
      Next
      Call LOADTIMHDT From SUBITNB1
      Call CPTSPGTIM From SUBITNB1
      Affzo [M:ITN4]1-99
      Affzo [M:ITN8]1-99
    Endif
  Endif
End

##########################################################################################################
# Détecte s'il y a des consommations non effectuées pour l'intervention.  Classe F
#####################################################################
Subprog SETDONHDK4(SZITNNUM, SZBPC, IERR)
Value Char SZITNNUM
Value Char SZBPC
Variable Integer IERR

Local Integer ITERHDT
Local Integer IDONEFLG
Local Integer IREP
Local Integer ISPGTIMHOU
Local Integer ISPGTIMMNT
Local Integer IHDTDONHOU

  ITERHDT = 0
  IDONEFLG = 0
  IREP = 0
  IDONDATLG = 0
  ISPGTIMHOU = 0
  ISPGTIMMNT = 0
  #Contrôle  des consommations
  Filter [HDT] Where [F:HDT]ITNNUM = SZITNNUM and [F:HDT]TPL <> 2 and [F:HDT]HDTDONDAT = [00/00/00]
  For [HDT]
    IDONEFLG = 1
    Break
  Next
  Filter [HDT]
  #Si oui, on demande si on doit les passer en effectué.
  If IDONEFLG Then
    IREP = 0
    #Souhaitez-vous transformer les consommations non effectuées de cette intervention en effectuées.
    Call OUINON(mess(325,182,1), IREP) From GESECRAN
    If IREP = 2 Then
      Trbegin [HDT]
      Filter [HDT] Where [F:HDT]ITNNUM = SZITNNUM and [F:HDT]TPL <> 2 and [F:HDT]HDTDONDAT = [00/00/00]
      For [HDT]
        [F:HDT]HDTDONDAT = date$
        IHDTDONHOU = 0
        Call HOUTOSEC(val(left$(time$, 2)), val(mid$(time$, 4, 2)), IHDTDONHOU) From CRMUTIL140
        [F:HDT]HDTDONHOU = IHDTDONHOU
        If [F:HDT]HDTTYP = 3 Then
          If [F:HDT]SPGTIMHOU = 0 Then
            If [F:HDT]SPGTIMMNT = 0 Then
              ISPGTIMHOU = 0
              ISPGTIMMNT = 0
              Call DEFSPGTIM(SZBPC, [F:HDT]HDTQTY, [F:HDT]HDTUOM, [F:HDT]HDTITM, ISPGTIMHOU, ISPGTIMMNT) From SUBITNB1
              [F:HDT]SPGTIMHOU = ISPGTIMHOU
              [F:HDT]SPGTIMMNT = ISPGTIMMNT
            Endif
          Endif
        Endif
        Rewrite [HDT]
        If fstat Then
          #Erreur lors de la transformation des consommations de l'intervention.
          IERR = 330
          Break
        Endif
      Next
      Filter [HDT]
      If IERR Then
        Rollback
        End
      Else
        Commit
      Endif
      Call ITNSPGTIM(SZITNNUM, ISPGTIMHOU, ISPGTIMMNT) From SUBITNB1
      [M:HDK4]HTOTTIMSPG = ISPGTIMHOU
      [M:HDK4]MTOTTIMSPG = ISPGTIMMNT
      [M:HDK4]MANTIMFLG = 0
    Endif
  Endif
End

##########################################################################################################
# Détecte s'il y a des consommations non effectuées pour l'ensemble de la demande de service
#####################################################################
Subprog SETDONALLFLG(SZSRENUM, SZITNNUM, SZCLASSMF, IDONDATFLG)
Value Char SZSRENUM
Value Char SZITNNUM
Value Char SZCLASSMF
Variable Integer IDONDATFLG

Local Integer ITERHDT
Local Integer IDONEFLG
Local Integer IREP

  IDONEFLG = 0
  IREP = 0
  IDONDATLG = 0
  Case SZCLASSMF
    When "F"
      IDONEFLG = 0
      Filter [HDT] Where [F:HDT]SRENUM = SZSRENUM and [F:HDT]TPL <> 2 and [F:HDT]HDTINV = 2 and [F:HDT]HDTDONDAT = [00/00/00]
      For [HDT]HDT1
        IDONEFLG = 1
        Break
      Next
      Filter [HDT]
    When "M"
      IDONEFLG = 0
      Filter [HDT] Where [F:HDT]SRENUM = SZSRENUM  and [F:HDT]TPL <> 2 and [F:HDT]ITNNUM <> SZITNNUM and [F:HDT]HDTINV = 2 and [F:HDT]HDTDONDAT = [00/00/00]
      For [HDT]HDT1
        IDONEFLG = 1
        Break
      Next
      Filter [HDT]
      #Contrôle dans l'écran des consommations
      If !IDONEFLG Then
        For ITERHDT = 0 To [M:ITN8]NBLIG-1
          If [M:ITN8]HDTINV(ITERHDT) = 2 Then
            If [M:ITN8]HDTDONDAT(ITERHDT) = [00/00/00] Then
              IDONEFLG = 1
              Break
            Endif
          Endif
        Next
      Endif
  Endcase
  #Si oui, on demande si on doit les passer en effectué.
  If IDONEFLG Then
    IREP = 0
    #Souhaitez-vous transformer toutes les consommations à facturer et non effectuées en effectuées.
    #Celles-ci seront alors facturables.
    Call OUINON(mess(324,182,1), IREP) From GESECRAN
    If IREP = 2 Then
      IDONDATFLG = 1
    Else
      IDONDATFLG = 0
    Endif
  Else
    IDONDATFLG = 0
  Endif
End

##########################################################################################################
# Chargement du masque de paramétrage pour composants stock             #
#########################################################################
$ALI_STW
  Raz [M:STW]
  [M:STW]STOFCY     = [M:ITN8]HDTSTOFCY(ITER)
  [M:STW]TRSTYP     = 24
  [M:STW]VCRTYP     = 33
  [M:STW]VCRNUM     = [M:ITN8]HDTNUM(ITER)
  [M:STW]VCRLIN     = 0
  [M:STW]ITMREF     = [M:ITN8]HDTITM(ITER)
  [M:STW]MVTDES     = [M:ITN8]MVTDES(ITER)
  [M:STW]BPRNUM     = [M:ITN0]BPC
  [M:STW]BPAADD     = [F:SRE]SREBPAADD
  [M:STW]PJT        = [F:SRE]SREPJT
  [M:STW]TRSCOD     = [M:ITN0]TRSCOD
  [M:STW]TRSFAM     = [M:ITN0]TRSFAM
  [M:STW]ENTCOD     = [M:ITN0]ENTCOD
  [M:STW]IPTDAT     = [M:ITN8]HDTDONDAT(ITER)
  [M:STW]CCECOD     = "STKHDT"
  [M:STW]BPRNUM     = [M:ITN0]BPC
  [M:STW]CUR        = [M:ITN8]HDTCUR(ITER)
  [M:STW]VCRTYPORI    = 33
  [M:STW]VCRNUMORI    = [M:ITN0]SRVDEMNUM
Return

##########################################################################################################
# Alimentation du masque de sortie de stock
#######################################################################
$CHARGE_STOSOR
  #-----------------------------------------------------------------------#
  # Chargement des paramètres dans masque STOSOR pour saisie des sorties  #
  # Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSORA       #
  #-----------------------------------------------------------------------#
  [M:SOR]WSTOSEQ   = [M:ITN8]WSTOSEQ(LNOL)
  [M:SOR]TRSTYP    = 24
  [M:SOR]TRSCOD    = [M:ITN0]TRSCOD
  [M:SOR]TRFFCY    = ""
  [M:SOR]VCRNUM    = [M:ITN8]HDTNUM(LNOL)
  # FGR 04/05/2015 : X3SUIVI105605 (début)
  If dim([M:ITN8]ECCVALMAJ) >= 0 Then
    [M:SOR]WECCVALMAJ = [M:ITN8]ECCVALMAJ(LNOL)
  Endif
  # FGR 04/05/2015 : X3SUIVI105605 (fin)
  [M:SOR]VCRLIN    = 0
  [M:SOR]MVTDES    = [M:ITN8]MVTDES(LNOL)
  [M:SOR]STU       = [M:ITN8]HDTSTU(LNOL)
  [M:SOR]PCU       = [M:ITN8]HDTUOM(LNOL)
  [M:SOR]PCUSTUCOE = [M:ITN8]SAUSTUCOE(LNOL)
  [M:SOR]SORQTY    = [M:ITN8]HDTISSQTY(LNOL)
  [M:SOR]SORQTYACT = [M:ITN8]HDTISSQTY(LNOL)
  [M:SOR]RETDAT    = [M:ITN8]HDTDONDAT(LNOL)
  [M:SOR]DLVDAT    = [M:ITN8]HDTDONDAT(LNOL)
  [M:SOR]PECINTLOC = 2
  [M:SOR]PECPLFLOC = 2
  [M:SOR]PECSCOLOC = 1
  [M:SOR]PECQLYCTL = 1
  [M:SOR]STOLOC    = ""
  [M:SOR]XLOT      = ""
  [M:SOR]XLOC      = ""
  [M:SOR]XSTA      = ""
  [M:SOR]BPRNUM = [M:ITN0]BPC
  [M:SOR]CUR = [M:ITN8]HDTCUR(LNOL)
  [M:SOR]GLOALLQTY = 0
  If dim([M:ITN8]WRH)>0 [M:SOR]XWRH=[M:ITN8]WRH(LNOL) Endif
Return

##########################################################################################################
# Mise à jour complémentaires après enregistrement
#######################################################################
$APRES_STOSOR
  If WGENR > 0 Then
    GITN8HDTISSISS(LNOL) = [M:SOR]PECQTY
    GITN8DIRTYISSISS(LNOL) = 1
  Endif
Return

##########################################################################################################
# Alimentation du masque de sortie de stock
#######################################################################
$CHARGE_STOSOM
  #-----------------------------------------------------------------------#
  # Chargement des paramètres dans masque STOSOR pour saisie des sorties  #
  # Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOSORA       #
  #-----------------------------------------------------------------------#
  [M:SOM]TRSTYP    = 24
  [M:SOM]TRSCOD    = [M:ITN0]TRSCOD
  [M:SOM]TRFFCY    = ""
  [M:SOM]VCRNUM    = [M:ITN8]HDTNUM(LNOL)
  # FGR 04/05/2015 : X3SUIVI105605 (début)
  If dim([M:ITN8]ECCVALMAJ) >= 0 Then
    [M:SOM]WECCVALMAJ = [M:ITN8]ECCVALMAJ(LNOL)
  Endif
  # FGR 04/05/2015 : X3SUIVI105605 (fin)
  [M:SOM]VCRLIN    = 0
  [M:SOM]STU       = [M:ITN8]HDTSTU(LNOL)
  [M:SOM]PCU       = [M:ITN8]HDTUOM(LNOL)
  [M:SOM]PCUSTUCOE = [M:ITN8]SAUSTUCOE(LNOL)
  [M:SOM]SORQTY    = [M:ITN8]HDTISSQTY(LNOL)
  [M:SOM]SORQTYACT = [M:ITN8]HDTISSQTY(LNOL)
  [M:SOM]DLVDAT    = [M:ITN8]HDTDONDAT(LNOL)
  [M:SOM]PECINTLOC = 2
  [M:SOM]PECPLFLOC = 2
  [M:SOM]PECSCOLOC = 1
  [M:SOM]PECQLYCTL = 1
  [M:SOM]STOLOC    = ""
  [M:SOM]XLOT      = ""
  [M:SOM]XLOC      = ""
  [M:SOM]XSTA      = ""
  If dim([M:ITN8]WRH)>0 [M:SOR]XWRH=[M:ITN8]WRH(LNOL) Endif
Return

##########################################################################################################
# Alimentation du masque de sortie de stock
#######################################################################
$APRES_STOSOM
Local Integer IAVERR
Local Integer SAVNOLIGN
Local Integer IHDTDONHOU

  # FGR 03/01/2011 : X3SUIVI78440
  IAVERR = 2
  If WGENR > 0 Then
    GITN8HDTISSISS(LNOL) = [M:SOM]PECQTY
    GITN8DIRTYISSISS(LNOL) = 1
    #
    [M:ITN8]HDTISSISS(LNOL) = [M:SOM]PECQTY
    If [M:ITN8]HDTISSISS(LNOL) = 0 Then
      [M:ITN8]HDTSTOISS(LNOL) = 1
      [M:ITN8]HDTISSQTY(LNOL) = 0
    Else
      If [M:ITN8]HDTSTUQTY(LNOL) <> [M:SOM]SORQTYACT Then
        # Mise en adéquation la quantité a sortir avec la quantité sortie
        [M:ITN8]HDTISSISS(LNOL) = [M:ITN8]HDTISSISS(LNOL)
        [M:ITN8]HDTQTY(LNOL) = [M:ITN8]HDTISSISS(LNOL) / [M:ITN8]SAUSTUCOE(LNOL)
        [M:ITN8]HDTSTUQTY(LNOL) = [M:ITN8]HDTISSISS(LNOL)
        SAVNOLIGN = nolign
        nolign = LNOL + 1
        Call AM_HDTQTY([M:ITN8]HDTQTY(LNOL)) From SUBITN
        nolign = SAVNOLIGN
      Endif
    Endif
    [M:ITN8]HDTDONDAT(LNOL) = date$
    #
    Call HOUTOSEC(val(left$(time$,2)), val(mid$(time$,4,2)), IHDTDONHOU) From CRMUTIL140
    [M:ITN8]HDTDONHOU(LNOL) = IHDTDONHOU
    Call SECTOHOU([M:ITN8]HDTDONHOU(LNOL), [M:ITN8]BHDTDONHOU(LNOL)) From CRMUTIL140
    #
    Affzo [M:ITN8]1-99
    Call SAVEHDT([M:ITN0]SRVDEMNUM, [M:ITN0]NUM)
    Call LOADTIMHDT From SUBITNB1
  Endif
Return

#######################################################################
$OLDAPRES_STOSOM
Local Integer IAVERR

  IAVERR = 2
  If WGENR > 0 Then
    # FGR 14/10/2010 : X3SUIVI68217 (début)
    #Avertissement. La nouvelle quantité de stock à sortir n'est plus le reflet de la consommation associée.
    #If [M:ITN8]HDTSTUQTY(LNOL) <> [M:SOM]SORQTYACT Then
    #  Call AVERTIR(mess(153,177,1), IAVERR) From GESECRAN
    #Endif
    # FGR 14/10/2010 : X3SUIVI68217 (fin)
    GITN8HDTISSISS(LNOL) = [M:SOM]PECQTY
    GITN8DIRTYISSISS(LNOL) = 1
    Readlock [HDT]HDT0=[M:ITN8]HDTNUM(LNOL)
    If fstat Then
      GOK =  0
      Call RSTA ("HDT",[M:ITN8]HDTNUM(LNOL)) From GLOCK
      Return
    Else
      [F:HDT]HDTISSISS = [M:SOM]PECQTY
      # FGR 14/10/2010 : X3SUIVI68217 (début)
      If [F:HDT]HDTISSISS = 0 Then
        [F:HDT]HDTSTOISS = 1
        [F:HDT]HDTISSQTY = 0
      Else
        If [M:ITN8]HDTSTUQTY(LNOL) <> [M:SOM]SORQTYACT Then
          # Mise en adéquation la quantité a sortir avec la quantité sortie
          [F:HDT]HDTISSISS = [F:HDT]HDTISSISS
          [F:HDT]HDTQTY = [F:HDT]HDTISSISS / [F:HDT]SAUSTUCOE
          [F:HDT]HDTSTUQTY = [F:HDT]HDTISSISS
        Endif
      Endif
      [F:HDT]HDTDONDAT = date$
      Call HOUTOSEC(val(left$(time$,2)), val(mid$(time$,4,2)), [F:HDT]HDTDONHOU) From CRMUTIL140
      # FGR 14/10/2010 : X3SUIVI68217 (fin)
      Rewrite [HDT]
      If fstat Then
        GOK =  0
        Call RSTA("HDT",[M:ITN8]HDTNUM(LNOL)) From GLOCK
        Return
      Else
        # FGR 14/10/2010 : X3SUIVI68217 (début)
        [M:ITN8]HDTSTOISS(LNOL) = [F:HDT]HDTSTOISS
        [M:ITN8]HDTISSISS(LNOL) = [F:HDT]HDTISSISS
        [M:ITN8]HDTISSQTY(LNOL) = [F:HDT]HDTISSQTY
        [M:ITN8]HDTQTY(LNOL)    = [F:HDT]HDTQTY
        [M:ITN8]HDTSTUQTY(LNOL) = [F:HDT]HDTSTUQTY
        [M:ITN8]HDTDONDAT(LNOL) = [F:HDT]HDTDONDAT
        Call SECTOHOU([F:HDT]HDTDONHOU, [M:ITN8]BHDTDONHOU(LNOL)) From CRMUTIL140
        # FGR 14/10/2010 : X3SUIVI68217 (début)
        Affzo [M:ITN8]1-99
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Chargement du masque de paramétrage pour composants stock             #
#########################################################################
$ALI_ALP
  [M:ALP]TRSTYP     = 24
  [M:ALP]TRSCOD     = [M:ITN0]TRSCOD
  [M:ALP]VCRTYP     = 33
  [M:ALP]STOFCY     = [M:ITN8]HDTSTOFCY(NOL)
  [M:ALP]ITMREF     = [M:ITN8]HDTITM(NOL)
  # --------------------------------------
  # FGR 21/04/2015 : X3SUIVI105605 (début)
  If dim([M:ITN8]ECCVALMAJ) >= 0 Then
    [M:ALP]ECCVALMAJ    = [M:ITN8]ECCVALMAJ(NOL)
  Endif
  # FGR 21/04/2015 : X3SUIVI105605 (fin)
  # --------------------------------------
  [M:ALP]PCU        = [M:ITN8]HDTUOM(NOL)
  [M:ALP]PCUSTUCOE  = [M:ITN8]SAUSTUCOE(NOL)
  [M:ALP]QTY        = [M:ITN8]HDTISSQTY(NOL)
  [M:ALP]TYPQTY     = 1
  [M:ALP]BESDAT     = [M:ITN8]HDTDONDAT
  [M:ALP]DLVDAT     = [M:ITN8]HDTDONDAT
  Raz [M:ALP]ALLDAT
  Raz [M:ALP]STOLOC
  [M:ALP]PECINTLOC  = 2
  [M:ALP]PECSCOLOC  = 1
  [M:ALP]PECPLFLOC  = 1
  [M:ALP]PECCUNLOK  = 1
  [M:ALP]PECQLYCTL  = 1
  Raz [M:ALP]FILSTO
  [M:ALP]LOT        = ""
  [M:ALP]LOC        = ""
  [M:ALP]STA        = ""
  [M:ALP]VCRNUM     = [M:ITN8]HDTNUM(NOL)
  [M:ALP]VCRLIN     = 0
  Raz [M:ALP]VCRSEQ
  If dim([M:ITN8]WRH)>0 [M:ALP]WRH=[M:ITN8]WRH(NOL) Endif
Return




