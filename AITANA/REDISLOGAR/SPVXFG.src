#<AdxTL>@(#)7.0.0.0 $Revision:   1.18  $ Gestion du masque XFICGFO
#ACV#X11
#TIT#Gestion dimensionnement des tabes GAS

Call OBJET("GFO",GBIDC1,GBIDC2)From GOBJET
End

$ACTION
Case ACTION
 When Default
Endcase
Return

########################################
Subprog C_NOMFIC(VALEUR)
Variable Char    VALEUR()

If VALEUR<>"*"
    Call CONTROLE("GFO","$",VALEUR,"",mkstat)From CONTOBJ
Endif

End

########################################
Subprog S_NOMFIC(VALEUR)
Variable Char    VALEUR()

If !clalev([ATB]) : Local File ATABLE : Endif 

Filter [ATB] Where CODACT="X11"
Call SELECT("ATB","",VALEUR,"")From SELOBJ
Filter [ATB]
End


