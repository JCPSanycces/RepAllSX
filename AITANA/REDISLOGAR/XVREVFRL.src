#<AdxTL>@(#)3.0.0.0 $Revision$
#ACV#X16
#TIT#Gestion des avenants du détail de l'affaire

#==========================================================================================
# Gestion de l'objet   : Gestion des avenants du détail de l'affaire
# Auteur               : Laurent Bornes
# Date de création     : 18/05/2011
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

GBIDC1="AFF0911BEA/028"
GBIDC2=""
GFONC1="GESFRL"
GFLAG="#"
Call OBJET("FRL",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

Case ACTION
  When "OUVRE" : Gosub OUVRE
  When "DEBUT" : Gosub DEBUT
Endcase

Return

#==========================================================================================
$OUVRE

If !clalev([F:OPP]) : Local File OPPOR     : Endif

If !clalev([F:FRL]) : Local File FORMSL    : Endif
If !clalev([F:FRA]) : Local File FORMSLA   : Endif
If !clalev([F:FRR]) : Local File FORMSLR   : Endif
If !clalev([F:FLD]) : Local File FORMSLD   : Endif
If !clalev([F:FLF]) : Local File FORMSLF   : Endif

If !clalev([F:XVF]) : Local File XVFORMSL  : Endif
If !clalev([F:XVA]) : Local File XVFORMSLA : Endif
If !clalev([F:XVD]) : Local File XVFORMSLD : Endif
If !clalev([F:XVI]) : Local File XVFORMSLF : Endif
If !clalev([F:XVR]) : Local File XVFORMSLR : Endif

If !clalev([F:AMZ]) : Local File AMSKZON   : Endif

If [V]GXOPTOPR
  If !clalev([F:XVP]) : Local File XVFORMSLP : Endif
  If !clalev([F:FLP]) : Local File FORMSLP   : Endif
Endif

Local Integer I

Return

#==========================================================================================
$DEBUT

Raz [M:DIA]

Call TEMPON("L") From GESECRAN

Read [F:FRL]FRL0=PARAM(1)
If fstat : Raz [F:FRL] : Endif
Read [F:OPP]OPP0=[F:FRL]OPPNUM
If fstat : Raz [F:OPP] : Endif

Case GACTION
  When "XVREVFRL" : Gosub VENTES
  When "XVREVFRA" : Gosub ACHATS
  When "XVREVETP" : Gosub ETAPES
  When "XVREVFRP" : Gosub PROD
  When "XVREVFRR" : Gosub PREST
Endcase

Affzo [M:DIA]

Call TEMPOFF From GESECRAN

Return

#==========================================================================================
$VENTES

Filter [F:XVF] Where [F:XVF]FRMNUMLIG=PARAM(1) Order By Key XVF0 Desc

nolign=1
[M:DIA]=[F:FRL]
For [L]I=1 To GOPTCANA
  If evalue("dim([M:DIA]CCE"+num$([L]I)+")")>0
    Assign "[M:DIA]CCE"+num$([L]I)+"("+num$(nolign-1)+")" With [F:FRL]CCE([L]I-1)
  Endif
Next

For [F:XVF]XVF0
  nolign+=1
  [M:DIA]=[F:XVF]
  For [L]I=1 To GOPTCANA
    If evalue("dim([M:DIA]CCE"+num$([L]I)+")")>0
      Assign "[M:DIA]CCE"+num$([L]I)+"("+num$(nolign-1)+")" With [F:XVF]CCE([L]I-1)
    Endif
  Next
Next

[M:DIA]NBLIG     =nolign
[M:DIA]OPPNUM    =[F:OPP]OPPNUM
[M:DIA]FRMNUMLIG =[F:FRL]FRMNUMLIG

Filter [F:XVF]

Return

#==========================================================================================
$ACHATS

If val(PARAM(2))<>0
  Filter [F:XVA] Where [F:XVA]FRMNUMLIG=PARAM(1) & [F:XVA]NUMLIGFRL2=val(PARAM(2))
Else
  Filter [F:XVA] Where [F:XVA]FRMNUMLIG=PARAM(1)
Endif

Raz nolign
For [F:XVA]XVA0(2)

  Read [F:FRA]FRA0=[F:XVA]FRMNUMLIG;[F:XVA]NUMLIGFRL2
  If !fstat
    nolign+=1
    [M:DIA]=[F:FRA]
    [M:DIA]REVNUM(nolign-1)  =[F:FRL]REVNUM
    [M:DIA]ZORILIG(nolign-1) =[F:XVA]NUMLIGFRL2
    [M:DIA]UPDDAT(nolign-1)  =[F:FRL]UPDDAT
  Endif

  For [F:XVA]XVA0
    nolign+=1
    [M:DIA]=[F:XVA]
    [M:DIA]ZORILIG(nolign-1) =[F:XVA]NUMLIGFRL2
    [M:DIA]UPDDAT(nolign-1)  =[F:XVA]UPDDAT
  Next

Next

[M:DIA]NBLIG     =nolign
[M:DIA]OPPNUM    =[F:OPP]OPPNUM
[M:DIA]FRMNUMLIG =[F:FRL]FRMNUMLIG
[M:DIA]ORILIG    =val(PARAM(2))

Filter [F:XVA]

Return

#==========================================================================================
$PREST

If val(PARAM(2))<>0
  Filter [F:XVR] Where [F:XVR]FRMNUMLIG=PARAM(1) & [F:XVR]NUMLIGFRL3=val(PARAM(2))
Else
  Filter [F:XVR] Where [F:XVR]FRMNUMLIG=PARAM(1)
Endif

Raz nolign

For [F:XVR]XVR0(2)

  Read [F:FRR]FRR0=[F:XVR]FRMNUMLIG;[F:XVR]NUMLIGFRL3
  If !fstat
    nolign+=1
    [M:DIA]=[F:FRR]
    [M:DIA]REVNUM(nolign-1)  =[F:FRL]REVNUM
    [M:DIA]ZORILIG(nolign-1) =[F:XVR]NUMLIGFRL3
    [M:DIA]UPDDAT(nolign-1)  =[F:FRL]UPDDAT
  Endif

  For [F:XVR]XVR0
    nolign+=1
    [M:DIA]=[F:XVR]
    [M:DIA]ZORILIG(nolign-1) =[F:XVR]NUMLIGFRL3
    [M:DIA]UPDDAT(nolign-1)  =[F:XVR]UPDDAT
  Next

Next

[M:DIA]NBLIG     =nolign
[M:DIA]OPPNUM    =[F:OPP]OPPNUM
[M:DIA]FRMNUMLIG =[F:FRL]FRMNUMLIG
[M:DIA]ORILIG    =val(PARAM(2))

Filter [F:XVR]

Return

#==========================================================================================
$PROD

If val(PARAM(2))<>0
  Filter [F:XVP] Where [F:XVP]FRMNUMLIG=PARAM(1) & [F:XVP]NUMLIGOF=val(PARAM(2))
Else
  Filter [F:XVP] Where [F:XVP]FRMNUMLIG=PARAM(1)
Endif

Raz nolign

For [F:XVP]XVP0(2)

  Read [F:FRP]FRP0=[F:XVP]FRMNUMLIG;[F:XVP]NUMLIGOF
  If !fstat
    nolign+=1
    [M:DIA]=[F:FRP]
    [M:DIA]REVNUM(nolign-1)  =[F:FRL]REVNUM
    [M:DIA]ZORILIG(nolign-1) =[F:XVP]NUMLIGOF
    [M:DIA]UPDDAT(nolign-1)  =[F:FRL]UPDDAT
  Endif

  For [F:XVP]XVP0
    nolign+=1
    [M:DIA]=[F:XVP]
    [M:DIA]ZORILIG(nolign-1) =[F:XVP]NUMLIGOF
    [M:DIA]UPDDAT(nolign-1)  =[F:XVP]UPDDAT
  Next

Next

[M:DIA]NBLIG     =nolign
[M:DIA]OPPNUM    =[F:OPP]OPPNUM
[M:DIA]FRMNUMLIG =[F:FRL]FRMNUMLIG
[M:DIA]ORILIG    =val(PARAM(2))

Filter [F:XVP]

Return

#==========================================================================================
$ETAPES

If val(PARAM(2))<>0
  If [F:FRL]INVMOD=4
    Read [F:FLD]FLD0=[F:FRL]FRMNUMLIG;val(PARAM(2))
    If !fstat
      Filter [F:XVD] Where [F:XVD]FRMNUMLIG=PARAM(1) & [F:XVD]STEPS=[F:FLD]STEPS
    Endif
    Filter [F:XVI] Where 1=0
  Elsif [F:FRL]INVMOD=5
    Filter [F:XVI] Where [F:XVI]FRMNUMLIG=PARAM(1) & [F:XVI]NUMLIGF=val(PARAM(2))
    Filter [F:XVD] Where 1=0
  Endif
Else
  Filter [F:XVF] Where [F:XVF]FRMNUMLIG=PARAM(1) Order By Key XVF0 Desc
  Filter [F:XVI] Where [F:XVI]FRMNUMLIG=PARAM(1)
  Filter [F:XVD] Where [F:XVD]FRMNUMLIG=PARAM(1)
Endif

Raz nolign

#############################
# Etapes
#############################
For [F:XVD]XVD1(2)

  Read [F:FLD]FLD1=[F:XVD]FRMNUMLIG;[F:XVD]STEPS
  If !fstat
    nolign+=1
    [M:DIA]=[F:FLD]
    [M:DIA]REVNUM(nolign-1)  =[F:FRL]REVNUM
    [M:DIA]ZORILIG(nolign-1) =[F:XVD]NUMLIGD
    [M:DIA]UPDDAT(nolign-1)  =[F:FRL]UPDDAT
    [M:DIA]INVMOD(nolign-1)  =[F:FRL]INVMOD
    [M:DIA]CURFRL(nolign-1)  =[F:FRL]CURFRL
  Endif

  For [F:XVD]XVD1
    Read [F:XVF]XVF0=[F:XVD]FRMNUMLIG;[F:XVD]REVNUM
    If !fstat
      nolign+=1
      [M:DIA]=[F:XVD]
      [M:DIA]ZORILIG(nolign-1) =[F:XVD]NUMLIGD
      [M:DIA]UPDDAT(nolign-1)  =[F:XVD]UPDDAT
      [M:DIA]INVMOD(nolign-1)  =[F:XVF]INVMOD
      [M:DIA]CURFRL(nolign-1)  =[F:XVF]CURFRL
    Endif
  Next

Next

#############################
# Dates fixes
#############################
For [F:XVI]XVI0(2)

  Read [F:FLF]FLF0=[F:XVI]FRMNUMLIG;[F:XVI]NUMLIGF
  If !fstat
    nolign+=1
    [M:DIA]=[F:FLF]
    [M:DIA]EXTDAT(nolign-1)    =[F:FLF]FIXDAT
    [M:DIA]PRCINV(nolign-1)    =[F:FLF]PRCFIXINV
    [M:DIA]AMTCUR(nolign-1)    =[F:FLF]AMTFIXCUR
    [M:DIA]ITMETPDES(nolign-1) =[F:FLF]ITMFIXDES
    [M:DIA]PTEETP(nolign-1)    =[F:FLF]PTEETP
    [M:DIA]REVNUM(nolign-1)    =[F:FRL]REVNUM
    [M:DIA]ZORILIG(nolign-1)   =[F:XVI]NUMLIGF
    [M:DIA]UPDDAT(nolign-1)    =[F:FRL]UPDDAT
    [M:DIA]INVMOD(nolign-1)    =[F:FRL]INVMOD
    [M:DIA]CURFRL(nolign-1)    =[F:FRL]CURFRL
    [M:DIA]STEPS(nolign-1)     =0
  Endif

  For [F:XVI]XVI0
    Read [F:XVF]XVF0=[F:XVI]FRMNUMLIG;[F:XVI]REVNUM
    If !fstat
      nolign+=1
      [M:DIA]=[F:XVI]
      [M:DIA]EXTDAT(nolign-1)    =[F:XVI]FIXDAT
      [M:DIA]PRCINV(nolign-1)    =[F:XVI]PRCFIXINV
      [M:DIA]AMTCUR(nolign-1)    =[F:XVI]AMTFIXCUR
      [M:DIA]ITMETPDES(nolign-1) =[F:XVI]ITMFIXDES
      [M:DIA]PTEETP(nolign-1)    =[F:XVI]PTEETP
      [M:DIA]ZORILIG(nolign-1)   =[F:XVI]NUMLIGF
      [M:DIA]UPDDAT(nolign-1)    =[F:XVI]UPDDAT
      [M:DIA]INVMOD(nolign-1)    =[F:XVF]INVMOD
      [M:DIA]CURFRL(nolign-1)    =[F:XVF]CURFRL
      [M:DIA]STEPS(nolign-1)     =0
    Endif
  Next

Next

[M:DIA]NBLIG     =nolign
[M:DIA]OPPNUM    =[F:OPP]OPPNUM
[M:DIA]FRMNUMLIG =[F:FRL]FRMNUMLIG
[M:DIA]ORILIG    =val(PARAM(2))

Filter [F:XVF]
Filter [F:XVI]
Filter [F:XVD]

Return

#==========================================================================================
Subprog AV_NBLIG

Local Integer I, TEST
Local Char ZMSK

Case GACTION
  When "XVREVFRL" : [L]ZMSK="XVREVFRL"
  When "XVREVFRA" : [L]ZMSK="XVREVFRA"
  When "XVREVETP" : [L]ZMSK="XVREVETP"
  When "XVREVFRP" : [L]ZMSK="XVREVFRP"
  When "XVREVFRR" : [L]ZMSK="XVREVFRR"
Endcase

For [L]I=1 To [M:DIA]NBLIG-1
  If [M:DIA]ZORILIG([L]I-1)=[M:DIA]ZORILIG([L]I)
    For [F:AMZ]CODE Where [F:AMZ]CODMSK=[L]ZMSK & [F:AMZ]NUMBLOC=2 & find([F:AMZ]CODZON,"NBLIG","REVLIG","REVNUM","UPDDAT")=0
      If evalue("dim([M:DIA]"+[F:AMZ]CODZON+")")>0
        If evalue("[M:DIA]"+[F:AMZ]CODZON+"("+num$([L]I-1)+")")<>evalue("[M:DIA]"+[F:AMZ]CODZON+"("+num$([L]I)+")")
          Chgstl ="[M:DIA]"+[F:AMZ]CODZON+"("+num$([L]I-1)+")" With "AERROR"
        Else
          Chgstl ="[M:DIA]"+[F:AMZ]CODZON+"("+num$([L]I-1)+")" With ""
        Endif
      Endif
    Next
  Endif
Next

End

