################################################################################
################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()()
Local    Char    XTRT

If dim([v]GXUNIQID)<0 Then

    [L]XTRT = "XFACGAS"
Else
# var [v]GXUNIQID déclarée dans Trt XVALGAS2
# impression après 'Génération de docs'...

    [L]XTRT = "XFACGAS2"
Endif

#===============================================================================
Call EXEC(NBPAR,PARAMETRE) From =[L]XTRT
Kill [l]XTRT
End


################################################################################
################################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Variable Integer NBPAR 
Variable Char    PARAMETRE()()
Local Integer IMPR, I, COMPTEUR

Gosub OUVRE 
If GERREUR : GERREUR=0 : End : Endif 
Gosub DECLARE 

# -- récup. entete de colonne pour les frais et remises
Call COLREM("C",1,"")     From TRTPRICE
 
[L]CRITERE = "1=1"
[L]CRITSUP = "1=1"
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
   When "__DESTINATION"   : [L]DEST   = val([L]VALEUR)
   When "sitedeb"         : [L]CRITERE -= "& SALFCY>='"+[L]VALEUR+"'"
   When "sitefin"         : [L]CRITERE -= "& SALFCY<='"+[L]VALEUR+"'" 
   When "clientdeb"       : [L]CRITERE -= "& BPCINV>='"+[L]VALEUR+"'" 
   When "clientfin"       : [L]CRITERE -= "& BPCINV<='"+[L]VALEUR+"'"
   When "facturedeb"      : [L]CRITERE -= "& NUM>='"+[L]VALEUR+"'" 
   When "facturefin"      : [L]CRITERE -= "& NUM<='"+[L]VALEUR+"'"
   When "typedeb"         : [L]CRITERE -= "& INVTYP>="+num$([L]VALEUR)
   When "typefin"         : [L]CRITERE -= "& INVTYP<="+num$([L]VALEUR)
   When "codimp"          : If [L]VALEUR = "1" 
                                [L]CRITERE -= "& INVSTA="+num$([L]VALEUR)
                                [L]IMPR = 1
                            Else
                                [L]CRITERE -= "& INVSTA>="+num$([L]VALEUR)
                                [L]IMPR = 2
                            Endif






   When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
   When "euro"            : [L]PARAMETRE(I) = "euro="+GEURO
   When "gcolrem0"        : [L]PARAMETRE(I) = "gcolrem0="+GCOLREM(0) 
   When "gcolrem1"        : [L]PARAMETRE(I) = "gcolrem1="+GCOLREM(1) 
   When "gcolrem2"        : [L]PARAMETRE(I) = "gcolrem2="+GCOLREM(2) 
   When "gfmtrem0"        : [L]PARAMETRE(I) = "gfmtrem0="+GFMTREM(0) 
   When "gfmtrem1"        : [L]PARAMETRE(I) = "gfmtrem1="+GFMTREM(1) 
   When "gfmtrem2"        : [L]PARAMETRE(I) = "gfmtrem2="+GFMTREM(2) 
   When "compteur"  :
     [L]COMPTEUR=uniqid([F:XET])
     PARAMETRE(I)="compteur="+num$([L]COMPTEUR)   
 Endcase
 Endif
Next

Filter [F:SIV] Where evalue([L]CRITERE) 
Gosub TRT_SIV
  
End

###################################################################
###################################################################

$TRT_SIV
Local Integer XLIG : XLIG=0

Raz WNUMLIG 
Default File [SIV]

For [F:SIV]SIV0 
    Call DEBTRANS From GLOCK 
    If [L]IMPR = 1 
        Gosub TR1
    Else
        Gosub TR2
    Endif
Next 
Return

##########################################################################

$TR1
Trbegin [SIH] , [ARM] , [SIV], [XET]

# Mise à jour table entête facture(SINVOICE et SINVOICEV)  si demande d'impression
If [L]IMPR = 1
 Readlock [F:SIV]SIV0 Curr   
 If fstat = 1 : GOK = -1 : GLOCK = "$SINVOICEV" : Goto ROLL_TR1
 Elsif fstat  : GOK = 0 : Call RSTA("SIV","*") From GLOCK : Goto AB_TR1
 Endif
 [F:SIV]INVSTA = 2
 Rewrite [F:SIV]   
 If fstat=1 
  GOK=-1 : GLOCK="$SINVOICEV"-[F:SIV]NUM
  Goto ROLL_TR1 
 Elsif fstat 
  GOK=0 : Call RSTA("SINVOICEV",[F:SIV]NUM) From GLOCK : Goto AB_TR1 
 Endif  

Readlock [F:SIH]SIH0 = [F:SIV]NUM   
 If fstat = 1 : GOK = -1 : GLOCK = "$SINVOICE" : Goto ROLL_TR1
 Elsif fstat  : GOK = 0 : Call RSTA("SIH","*") From GLOCK : Goto AB_TR1
 Endif
 [F:SIH]STA = 2
 Rewrite [F:SIH]   
 If fstat=1 
  GOK=-1 : GLOCK="$SINVOICE"-[F:SIH]NUM
  Goto ROLL_TR1 
 Elsif fstat 
  GOK=0 : Call RSTA("SINVOICE",[F:SIH]NUM) From GLOCK : Goto AB_TR1 
 Endif  
Endif
 
#Initialisation à 1 le nombre d'exemplaire si = 0
If [F:SIV]COPNBR = 0 
   WCOPNBR = 1
Endif
# 1 seul exemplaire en messagerie
If [L]DEST = 2 Then WCOPNBR = 1
Else WCOPNBR = [F:SIV]COPNBR
Endif

# Yannick (08/01/2002) : Calcul du Cours
XCOURS=0
LA_DEVISE=[SIH]CUR : LE_TYPCUR=[SIH]CURTYP : LA_DATE=[SIH]ACCDAT : Gosub LECTURE From XSIHCOURS

#####################################################################################
#Ftazi le 02/03/2009 : Correction trt calcul du cours
#Read[F:YSTP]TSV0=[F:SIH]SIVTYP
 #   If !fstat
  #      Read [F:YGTP]GTE0=[F:YSTP]GTE
   #     If !fstat Then
    #        XCOURS =[F:YGTP]TYPRAT
     #   Endif
#    Endif
####################################################################################

#Création de l'enregistrement dans la table AREPORTM
For I = 1 To WCOPNBR
    Raz [F:ARM]
    WNUMLIG      += 1
    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = [F:ARP]RPTCOD
    [F:ARM]NUMREQ  = [L]NUMREQ
    [F:ARM]NUMLIG  = WNUMLIG
    [F:ARM]CLEA1   = [F:SIV]NUM
    [F:ARM]CLEN1   = XCOURS
    [F:ARM]CLEN2   = I
    [F:ARM]CREDAT  = date$
    Write [F:ARM]   
    If fstat : Break : Goto ROLL_TR1 : Endif 
Next I

LE_NUM=[SIH]NUM : Gosub MAJ_XET

Commit 
Return 
 
$ROLL_TR1
Rollback : Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR1 : Endif 
 
$AB_TR1 
Rollback 
Return 

###########################
$TR2

Trbegin [ARM]
#Initialisation à 1 le nombre d'exemplaire si = 0
If [F:SIV]COPNBR = 0
   WCOPNBR = 1
Endif
#1 seul exemplaire en pré-visu et messagerie
If [L]DEST = 2 Then WCOPNBR = 1
Else WCOPNBR = [F:SIV]COPNBR
Endif

# Yannick (08/01/2002) : Calcul du Cours
Read [F:SIH]SIH0 = [F:SIV]NUM   
XCOURS=0
LA_DEVISE=[SIH]CUR : LE_TYPCUR=[SIH]CURTYP : LA_DATE=[SIH]ACCDAT : Gosub LECTURE From XSIHCOURS
#######################################################
#Ftazi le 02/03/2008 
#Read[F:YSTP]TSV0=[F:SIH]SIVTYP
 #   If !fstat
  #      Read [F:YGTP]GTE0=[F:YSTP]GTE
   #     If !fstat Then
    #        XCOURS =[F:YGTP]TYPRAT
     #   Endif
#    Endif

#####################################################

#Création de l'enregistrement dans la table AREPORTM
For I = 1 To WCOPNBR
    Raz [F:ARM]
    WNUMLIG      += 1
    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = [F:ARP]RPTCOD
    [F:ARM]NUMREQ  = [L]NUMREQ
    [F:ARM]NUMLIG  = WNUMLIG
    [F:ARM]CLEA1   = [F:SIV]NUM
    [F:ARM]CLEN1   = XCOURS
    [F:ARM]CLEN2   = I
    [F:ARM]CREDAT  = date$
    Write [F:ARM]   
    If fstat : Break : Goto ROLL_TR2 : Endif
Next I  

LE_NUM=[SIV]NUM : Gosub MAJ_XET

Commit 
Return 
 
$ROLL_TR2
Rollback : Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR2 : Endif 
 
$AB_TR2 
Rollback 
Return 

########################################################################### 
 
$OUVRE 
Local File SINVOICEV [SIV],   SINVOICE [SIH], SINVOICED [SID], AREPORTM [ARM]
Local File TABCUR [TCU], TABCHANGE [TCH]
Local File XETATTMP [XET], VALGAS [VGA]
#Local File TABSIVTYP[YSTP],GTYPACCENT[YGTP]
Return 
 
$DECLARE 
Local Char    CRITERE(255), CRITSUP(100), PARAM(30) , VALEUR(30) , ETAT(15) 
Local Integer WNUMLIG, WCOPNBR , DEST , NUMREQ
Return 
 
# Yannick (09/01/2002) : Mise à jour de XET pour la partie situation
$MAJ_XET
For [SID]SID0 Where NUM=LE_NUM and VALNUM<>""
   Read [VGA]VGA1=[SID]VALNUM
   If fstat=0 and find([VGA]ORIVAL,7,23)<>0 Then
#      Call CALCUL_SIT([VGA]SITNUM,COMPTEUR, XLIG, LE_NUM) From XSITGAS
       Call CALCUL_SITLIG([VGA]LINSITNUM,0, COMPTEUR, XLIG, LE_NUM) From XSITGAS
   Endif
Next
Return


