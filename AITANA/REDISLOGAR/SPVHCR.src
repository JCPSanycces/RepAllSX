#<AdxTL>@(#)10.0.0.0 $Revision$
#ACV#X12
#TIT#Gestion historique cout intervenants
#Othyr 08/2002 : ajout des actions PSG


Call OBJET("HCR",GBIDC1,GBIDC2)From GOBJET
End


#######################################################
$ACTION
Case ACTION
    When "OUVRE"   : Gosub OUVRE   From SPVOBJHCR
    When "FERME"   : Gosub FERME   From SPVOBJHCR
Endcase
Return


#######################################################
Subprog C_UOM(VALEUR)
Variable Char VALEUR

Local Integer I,POS
Local Char SITE

[L]SITE = [M:HCR0]FCY(nolign-1)
[L]POS  = nolign-1

For I = 0 To [M:HCR0]NBLIG-1
    If [M:HCR0]FCY(I) = [L]SITE & [L]POS<>I & VALEUR = [M]UOM(I) Then
        If ([M:HCR0]DATBEG([L]POS)<=[M:HCR0]DATBEG(I) & [M:HCR0]DATEND([L]POS)>=[M:HCR0]DATBEG(I))
&    | ([M:HCR0]DATBEG([L]POS)>=[M:HCR0]DATBEG(I) & [M:HCR0]DATEND([L]POS)<=[M:HCR0]DATEND(I))
&    | ([M:HCR0]DATBEG([L]POS)<=[M:HCR0]DATEND(I) & [M:HCR0]DATEND([L]POS)>=[M:HCR0]DATEND(I)) Then
            [V]GMESSAGE = mess(155,[V]GXMSGPSA,1)-num$(I+1)
            mkstat = 2
            Break 1
        Endif
    Endif
Next I

End

######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

If [M:HCR0]CUR(nolign-1)="" | VALEUR<>[M:HCR0]FCY(nolign-1)
  If VALEUR<>""
    Call GETDEV(VALEUR) From DEVSUB
    [M:HCR0]CUR(nolign-1) = [V]GLOCALDEV

    If ![V]GIMPORT Then
      Affzo [M]CUR 
    Endif
  Else
    [M:HCR0]CUR(nolign-1)=GSYSCUR
  Endif
Endif

End

