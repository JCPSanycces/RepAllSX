#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

Local Char PARAM(250)(1..20), VALEUR(30) 

Raz [L]PARAM, [L]VALEUR

GACTION="XCALSITFIN"

[L]PARAM(1)="AFF0911LEV00001"
[L]PARAM(2)="" 
[L]PARAM(3)="" 
[L]PARAM(4)="" 
Call TRAITE_CHAR(VALEUR,PARAM,"","XCALSITFIN","XCALSITFIN",4,"YCALSITFIN") From GTRAITE
End

$ACTION
Gosub ACTION From XCALSITFIN2
Return

#----------------------------------------------------------------------------------------------------
# Ecran XCALSITFIN
#----------------------------------------------------------------------------------------------------

########################
Subprog AP_ALLPJT(VALEUR)
Variable Integer VALEUR

If VALEUR=2
  Effzo [M]OPPINF,OPPSUP
  Grizo [M]OPPINF,OPPSUP
Elsif [M]OPPINF=""
  Actzo [M]OPPINF,OPPSUP
Else
  Grizo [M]OPPINF,OPPSUP
Endif
End

########################
Subprog AP_ALLTYPPJT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo [M]TYPPJTINF,TYPPJTSUP
  Grizo [M]TYPPJTINF,TYPPJTSUP
Else
  Actzo [M]TYPPJTINF,TYPPJTSUP
Endif
End

########################
Subprog AP_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo [M]FCYINF,FCYSUP
  Grizo [M]FCYINF,FCYSUP
Else
  Actzo [M]FCYINF,FCYSUP
Endif
End

########################
Subprog AP_ALLBPC(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo [M]BPCINF,BPCSUP
  Grizo [M]BPCINF,BPCSUP
Else
  Actzo [M]BPCINF,BPCSUP
Endif
End

########################
Subprog AP_ALLGESINTO(VALEUR)
Variable Integer  VALEUR
If VALEUR=2
  Effzo [M]GESINTINFO,GESINTSUPO
  Grizo [M]GESINTINFO,GESINTSUPO
Else
  Actzo [M]GESINTINFO,GESINTSUPO
Endif
End

#==========================================================================================
Subprog AV_INITZON(VALEUR)
Gosub INIZON
End

#==========================================================================================
$INIZON
Call AP_ALLPJT([M]ALLPJT)
Call AP_ALLTYPPJT([M]ALLTYPPJT)
Call AP_ALLFCY([M]ALLFCY)
Call AP_ALLBPC([M]ALLBPC)
Call AP_ALLGESINTO([M]ALLGESINTO)
Call AP_CALSITFLG([M]CALSITFLG)
Return

#==========================================================================================
Subprog CL_ICO1(VALEUR)
Variable Char    VALEUR()
[M:DIA]DATSITD=gdat$(1,month(date$),year(date$))
[M:DIA]DATSITF=eomonth(date$)
Affzo [M:DIA]DATSITD,DATSITF
End

#==========================================================================================
Subprog CL_ICO2(VALEUR)
Variable Char    VALEUR()
[M:DIA]DATSITD=gdat$(1,month(date$)-1,year(date$))
[M:DIA]DATSITF=eomonth([M:DIA]DATSITD)
Affzo [M:DIA]DATSITD,DATSITF
End

#==========================================================================================
Subprog CL_ICO3(VALEUR)
Variable Char    VALEUR()
[M:DIA]EXTDAT=date$
Affzo [M:DIA]EXTDAT
End

#==========================================================================================
Subprog CL_ICO4(VALEUR)
Variable Char    VALEUR()
[M:DIA]EXTDAT=eomonth(addmonth(date$,-1))
Affzo [M:DIA]EXTDAT
End

#==========================================================================================
Subprog CL_ICO5(VALEUR)
Variable Char    VALEUR()
[M:DIA]PCEDAT=date$
Affzo [M:DIA]PCEDAT
End

#==========================================================================================
Subprog CL_ICO6(VALEUR)
Variable Char    VALEUR()
[M:DIA]PCEDAT=eomonth(addmonth(date$,-1))
Affzo [M:DIA]PCEDAT
End

#==========================================================================================
Subprog AP_CALSITFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=1
  Effzo [M]SITINF,SITSUP
  Grizo [M]SITINF,SITSUP
Elsif [M]SITINF=""
  Actzo [M]SITINF,SITSUP
Else
  Grizo [M]SITINF,SITSUP
Endif
End

#==========================================================================================
Subprog AM_SITINF(VALEUR)
Variable Char    VALEUR()
If [M]GENSITFLG=2 & VALEUR<>""
  [M]GENSITFLG=1
  Affzo [M]GENSITFLG
Endif
End

#==========================================================================================
Subprog AM_SITSUP(VALEUR)
Variable Char    VALEUR()
If [M]GENSITFLG=2 & VALEUR<>""
  [M]GENSITFLG=1
  Affzo [M]GENSITFLG
Endif
End

