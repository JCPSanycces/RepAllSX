#ACV#X16
#TIT#Réalisé contrat
#==========================================================================================
# Gestion de l'objet   : Réalisé contrat
#                        
# Auteur               : Laurent Bornes
# Date de création     : 17/03/2010      
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

GBIDC1=""
GBIDC2=""
GFONC1="GESXON"
Call OBJET("XON",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
  When "DEBUT"  : Gosub DEBUT  From XREACON2
  When "BOUTON" : Gosub BOUTON From XREACON2
Endcase

Return

######################################################################################
Subprog C_PERFIN(VALEUR)
Variable Date    VALEUR
If [M:XRC]PERDEB<>[0/0/0] & VALEUR<>[0/0/0] & VALEUR<[M:XRC]PERDEB
  [V]GMESSAGE=mess(90,121,1)
  [V]GERR=1
  mkstat=1
Else
  Call RAFFRAICHI([M:XRC]PERDEB,VALEUR,[M:XRC]ECH) From XREACON2
Endif
End

######################################################################################
Subprog CL_ICO1(VALEUR)
Variable Char    VALEUR()
[M:XRC]ECH=max([M:XRC]ECH-1,1)
Call RAFFRAICHI([M:XRC]PERDEB,[M:XRC]PERFIN,[M:XRC]ECH) From XREACON2
End

######################################################################################
Subprog CL_ICO2(VALEUR)
Variable Char    VALEUR()
[M:XRC]ECH=min([M:XRC]ECH+1,len(mess(0,1912,1)))
Call RAFFRAICHI([M:XRC]PERDEB,[M:XRC]PERFIN,[M:XRC]ECH) From XREACON2
End

######################################################################################
Subprog AM_ECH(VALEUR)
Variable Integer VALEUR
Call RAFFRAICHI([M:XRC]PERDEB,[M:XRC]PERFIN,VALEUR) From XREACON2
End

######################################################################################
Subprog AV_ICO1(VALEUR)
Variable Char    VALEUR()
If [M:XRC]ECH=1
  VALEUR=""
Else
  VALEUR="153"
Endif
End

######################################################################################
Subprog AV_ICO2(VALEUR)
Variable Char    VALEUR()
If [M:XRC]ECH=len(mess(0,1912,1))
  VALEUR=""
Else
  VALEUR="154"
Endif
End
