Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
If !clalev([ZVITBPC]) : Local File YVITMBPC [ZVITBPC] : Endif

Read [ZVITBPC]YIB0 = VALEUR;[M:SDE1]YCLIENTE
If !fstat
  [M:SDE1]YITMDES = [ZVITBPC]ITMDESBPC
Endif
Affzo [M:SDE1]YITMDES
End


