Local Char PARAM(30)(1..16),VALEUR(10)
PARAM(1)=""
Call TRAITE_CHAR(VALEUR,PARAM,"FFREQTEST","XFREQ","FTESTFREQ",4) From GTRAITE
End


########################################
Subprog C_DOSSIER(VALEUR)
Variable Char    VALEUR()
If VALEUR=[S]nomap | VALEUR="IGSDEV" | left$(VALEUR,6)="GFIDEV"
  mkstat=1
Elsif GBOITE="TRFBTRFCRI" & VALEUR=""
  [V]GMESSAGE=mess(10,123,1)
  mkstat=1
Endif
End

