#<AdxTL>@(#)1.0.0.0 $Revision:   1.12  $ Gestion du masque RHC1
#ACV#X12
#TIT#Gestion objet coût ressource

GBIDC1=""
GBIDC2=""
Call OBJET("RHC",GBIDC1, GBIDC2) From GOBJET
End

$ACTION
Case ACTION
   When "OUVRE": Gosub OUVRE From SPVOBJRHC
Endcase
Return



########################################
Subprog D_CATCUR(VALEUR)
Variable Char    VALEUR()
VALEUR=[V]GCUR
End

########################################
Subprog C_UOM(VALEUR)
Variable Char    VALEUR()

Local Integer NOL,I

[L]NOL=nolign-1

For I=0 To [M]NBLIG-1
    If I<>[L]NOL & [M]UOM(I)=VALEUR & [M]CATRES(I)=[M]CATRES([L]NOL)
        [V]GMESSAGE=mess(155,[V]GXMSGPSA,1)-num$(I+1)
        mkstat=2
        Break 1
    Endif
Next
End

