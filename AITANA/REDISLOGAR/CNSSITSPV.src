#<AdxTL>@(#)5.0.0.0 $Revision$
#ACV#X16
#TIT#Consultation situations

#==========================================================================================
# Gestion de la consultation : SIT -- Situation
#                        
# Auteur                     : 
# Date de création           :       
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 25/02/2003    OTHYR        Modélisation Web + ajout PE consultation       
# 18/01/2005    LBORN        Passage version 140       
#==========================================================================================

Local Char PARAM(30)(2)

Call GCONSULT("XST","",PARAM)From GCONSULT
End

######################################################################
$ACTION

Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "FIN_CRIT"   : Gosub FIN_CRIT
    When default
Endcase

Return


#-----------------------------------------------------------------#
#    Gestion des étiquettes liées a ACTION                        #
#-----------------------------------------------------------------#

###################################################################
$OUVRE
Local Char CRIT1(250), CRIT2(250), CRIT3(250), CRITSPE(250), CRITOPP(250)
Local Char DEBNUM,FINNUM

Gosub DEFCRIT

Return

###################################################################
$DEFCRIT

If !find([M:CST0]VLYFLG,1,2)    : [M:CST0]VLYFLG   = 2   : Endif
If !find([M:CST0]VLYFLGN,1,2)   : [M:CST0]VLYFLGN  = 2   : Endif
If !find([M:CST0]CANFLG,1,2)    : [M:CST0]CANFLG   = 2   : Endif
If !find([M:CST0]CANFLGN,1,2)   : [M:CST0]CANFLGN  = 2   : Endif

# Copie de l'écran critère (CCST) vers la masque 0 d'entete (CST0)
Gosub CRITENT From =PROGCNS

Return

###################################################################
$LECTURE

Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 Then
    NOL = MAXLIG
Endif    

Call TEMPON("R") From GESECRAN

# Positionnement des filtres
Gosub LOAD_FILTER
# Appel au filtre spécifique client
ACTION = "FILTRE"
Gosub ACTION From XOBJCNS
ACTION = "LECTURE"

#***********************************#
# RAPPEL : valeur CHGPAG :          #
#    1 : Recherche                  #
#    2 : Suite                      #
#    3 : F5 (Rafraichissement)      #
#   -1  : Dernier                   #
#   -2  : Retour (Page précédente)  #
#***********************************#
# Application des filtres
If CHGPAG > 0 Then
    SUITE = 1
    If CHGPAG = 1 Then
        RETOUR = 1
    Elsif CHGPAG = 2 Then
        RETOUR = 2
    Endif
    Filter [XST] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                Order By Key XST0
Else
    RETOUR = 1
    If CHGPAG = -1 Then
        SUITE = 1
    Else
        SUITE = 2
    Endif
    Filter [XST] Where evalue([L]CRIT1) & evalue([L]CRIT2) & evalue([L]CRIT3) & evalue([L]CRITSPE)
&                Order By Key XST0 Desc
Endif

# RAZ du masque
If CHGPAG <> 2 & CHGPAG <> -2 Then
    Raz [M:CST1]
Endif

# Lecture
For [XST]
  Read [F:OPP]OPP0=[F:XST]OPPNUM
  If !fstat & evalue([L]CRITOPP)
    If NBLU = 1 Then
        If CHGPAG = 2 | CHGPAG = -2 Then
            Raz [M:CST1]
        Endif
        NBLU = 2
    Endif
    If CHGPAG > 0 Then
        If NOL >= MAXLIG-1 Then
            SUITE = 2
            Break
        Endif
        NOL += 1
        If NOL = 0 Then
            DEBNUM = [F:XST]SITNUM
        Endif
        FINNUM = [F:XST]SITNUM
    Else
        If NOL <= 0 Then
            RETOUR = 2
            Break
        Endif
        NOL -= 1
        If NOL = MAXLIG-1 Then
            FINNUM = [F:XST]SITNUM
        Endif 
        DEBNUM = [F:XST]SITNUM
    Endif

    nolign = NOL+1

    [M:CST1] = [F:XST]
    [M:CST1]OPPTYP(nolign-1)=[F:OPP]OPPTYP
  Endif
Next

Filter [XST]

Call TEMPOFF From GESECRAN

Return

###################################################################
$LOAD_FILTER
[L]CRITOPP = "1"        :# Critere sur affaire
[L]CRIT1   = "1"        :# Critere sur tiers, affaire
[L]CRIT2   = "1"        :# Critere sur bornes de date
[L]CRIT3   = "1"        :# Critere sur flag de provenance : contrat et/ou affaire, ET validé/annulé
[L]CRITSPE = "1"        :# Critère spécifique client

# 1er critere
If [M:CST0]COPPTYP <> "" Then
    [L]CRITOPP += "& [F:OPP]OPPTYP=[M:CST0]COPPTYP"
Endif

# 2eme critere
If [M:CST0]OPPNUM <> "" Then
    [L]CRIT1 += "&[F:XST]OPPNUM=[M:CST0]OPPNUM"
Endif
If [M:CST0]BPCNUM <> "" Then
    [L]CRIT1 += "&[F:XST]BPCNUM=[M:CST0]BPCNUM"
Endif

# 3eme critere
If [M:CST0]BEGDAT <> [0/0/0] Then
    [L]CRIT2 += "&[F:XST]CREDAT>=[M:CST0]BEGDAT"
Endif
If [M:CST0]ENDDAT <> [0/0/0] Then
    [L]CRIT2 += "&[F:XST]CREDAT<=[M:CST0]ENDDAT"
Endif

# --> Si 2, on prend validé=oui
If [M:CST0]VLYFLG = 1 Then
    [L]CRIT3 += "&[F:XST]VLYFLG<>2"
Endif
If [M:CST0]VLYFLGN = 1 Then
    [L]CRIT3 += "&[F:XST]VLYFLG=2"
Endif
# --> Si 2, on prend annulé=oui
If [M:CST0]CANFLG = 1 Then
    [L]CRIT3 += "&[F:XST]CANFLG<>2"
Endif
If [M:CST0]CANFLGN = 1 Then
    [L]CRIT3 += "&[F:XST]CANFLG=2"
Endif


Case CHGPAG
    When 3 : #Rafraichissement
        CRIT1 += "&[F:XST]SITNUM>=DEBNUM"
    When 2 : #Suite
        CRIT1 += "&[F:XST]SITNUM>FINNUM"
    When -2 : #Retour
        CRIT1 += "&[F:XST]SITNUM<DEBNUM"
Endcase

Return

###################################################################
$FIN_CRIT
Return


#-----------------------------------------------------------------#
#    Gestion des étiquettes liées aux masques CST0, CST1 et CCST  #
#-----------------------------------------------------------------#
###################################################################
# Comme pas d'acces direct a la gestion des bordereaux, on passe
# soit par le contrat s'il existe, sinon par l'affaire si existe
Subprog IB_NBLIG

Raz GBOUT1, GBOUT2

If [M:CST1]OPPNUM(nolign-1) <> "" Then
    GBOUT1 = mess(162,[V]GXMSGPSA,1)        : # Affaire
Endif
If [M:CST1]SITNUM(nolign-1) <> "" Then
    GBOUT2 = mess(85,[V]GXMSGPSA,1)         : # Situation
Endif

End

######################################################################################
Subprog AS_OPPNUM(VALEUR)
Variable Char    VALEUR()
If [M]COPPTYP<>""
  GBIDC1="OPPTYP='"+[M]COPPTYP+"'"
Else
  Raz GBIDC1
Endif
End
