#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################
#* YA030
#* Evalua para un presupuesto si se supera el autorizado del cliente
#*
#* @param PS_SOH (Value) (Char) Código del pedido a realizar
#* @return Devuelve 2 si se cumple la condición y 1 si no.
###################################################################
Funprog SQH_OSTAUZ(PS_SQH)
Value Char PS_SQH

Local Integer I_SQH_OSTAUZ

If clalev ([F:ZSQH])  = 0 : Local File  SQUOTE [ZSQH] : Endif

# Inicializamos la variable
[L]I_SQH_OSTAUZ = 1

Read [F:ZSQH]SQH0 = PS_SQH
If fstat = 0 Then

  Local Integer WCDTSTA
  Local Decimal WOST, WOSTAUZ
  Local Integer WOK

  Call SDCDTSTA('', [F:ZSQH]BPCORD, [F:ZSQH]CHGTYP, 0, [F:ZSQH]CUR, [F:ZSQH]QUODAT, 0, 1, WCDTSTA, WOST, WOSTAUZ) From TRTVENCDT

  If ([F:ZSQH]QUOINVATI + WOST > WOSTAUZ)

     [L]I_SQH_OSTAUZ = 2

  Endif

Endif
End [L]I_SQH_OSTAUZ
###################################################################

