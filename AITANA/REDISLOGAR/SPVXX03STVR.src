GBIDC1=""
GBIDC2=""
GFONC1="GESXX03STVR"
GFLAG="#"
Call OBJET("XX03STVR",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

Gosub ACTION From SPVXX03STVRA

Return

