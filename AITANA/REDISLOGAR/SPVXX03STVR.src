Subprog AM_CODTVR(VALEUR)
Variable Char    VALEUR

WXX03STRVREQ.CODTVR=VALEUR
Call RECOVERS_ERROR_IN_CLASSIC(WXX03STRVREQ) From SPVXX03STVRA
If GERR=1
  WXX03STRVREQ.CODTVR=WXX03STRVREQ.snapshot.CODTVR
  GERR=1
  mkstat=2
  End
Else
  Call SHOW_HEADER() From SPVXX03STVRA
Endif

End

