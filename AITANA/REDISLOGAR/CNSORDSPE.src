#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "AV_AFFICHE" : Gosub AV_AFFICHE
  When "CUSSELFLT"  : Gosub CUSSELFLT
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$AV_AFFICHE
Local Integer LCON
If !clalev([ZSOQ]) : Local File SORDERQ [ZSOQ] : Endif
For LCON=0 To NBLIG-1
  Read [ZSOQ]SOQ0 =  [M:ORD2]VCRNUM(LCON);[M:ORD2]VCRLIN(LCON);[M:ORD2]VCRSEQ(LCON)
  If !fstat
    [M:ORD2]YCONFIRMADAT(LCON) = [F:ZSOQ]YCONFIRMADAT
    Affzo [M:ORD2]YCONFIRMADAT(LCON)
  Endif
Next

Return

##############################################################
# punto de entrada para añadir más criterios de búsqueda
$CUSSELFLT
  If [M:ORD1]YSOHNUM <> "" Then
    CUSFLT = "[F:ORD]VCRNUM=[M:ORD1]YSOHNUM"
  Endif
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################

