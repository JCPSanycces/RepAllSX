#===============================================================================
# SECTION CONTENANT LES SOUS-PROGRAMMES DE CONTROLE SUR CHAMPS  : Ecran REQ0 (Général)
#===============================================================================

########################################
Subprog AS_REQNUM(VALEUR)
Variable Char     VALEUR
If find(GREP,"C","D") & GMANCOU <> 2 Then mkstat=2 Endif
End

########################################
Subprog C_REQNUM(VALEUR)
Variable Char    VALEUR()
#----- Vérif si un enregistrement existe -----#
If VALEUR<>"" & GMANCOU <> 2 Then
   Look [REQ]REQ0=VALEUR
   If fstat GMESSAGE=mess(178,199,1) : mkstat=1 : End : Endif
Endif
End

########################################
Subprog AS_REQTYP(VALEUR)
Variable Char    VALEUR()
If !find(GREP, "C", "M") & ![V]GIMPORT
  mkstat=2
Endif
End

########################################
Subprog AM_REQTYP(VALEUR)
Variable Char    VALEUR()

[M:REQ0]ACS=[F:PRT]ACS
If !GIMPORT Then Affzo [M:REQ0]ACS Endif

If [V]GXOPTSAV
  Raz [M:REQ2]OPEROU
Endif

End

########################################
Subprog D_FCY(VALEUR)
Variable Char     VALEUR
VALEUR=[V]GFCYDEF(16)
End

########################################
Subprog AV_CMP(VALEUR)
Variable Char     VALEUR

VALEUR=[V]GSOCIETE
End

########################################
Subprog C_REQTYP(VALEUR)
Variable Char    VALEUR()

If [F:PRT]ACS<>""
   # Vérification droit de modification
    Call CTLACS([F:PRT]ACS,"M")From CONTX3
Endif
End

#===============================================================================
# SECTION CONTENANT LES SOUS-PROGRAMMES DE CONTROLE SUR CHAMPS  : Ecran REQ1 (Général)
#===============================================================================



########################################
Subprog C_CONREV(VALEUR)
Variable Char    VALEUR()

If VALEUR="" Then End Endif

Local Integer OK

Call CONTROLE_CONTRACT([M:REQ1]BPCNUM,[M:REQ0]REQTYP, VALEUR,mkstat) From SPVOBJREQ

If !mkstat & [F:XON]FLGCONVAL<>2
  [V]GMESSAGE=mess(67,[V]GXMSGPSA,1)-mess(143,[V]GXMSGPSA,1)
  [L]OK=1 : Call AVERTIR([V]GMESSAGE,[L]OK) From GESECRAN
  If [L]OK=1
    [V]GMESSAGE=""
    mkstat=1
  Endif
Endif
End


########################################
Subprog AS_COPNUM(VALEUR)
Variable Char    VALEUR()

If [M:REQ1]CONREV = "" Then
  mkstat = 1
Endif

End

########################################
Subprog AM_COPNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR = "" Then
  End
Endif

Read [F:XCG]COP0 = VALEUR
If !fstat Then
  # Chargement des infos du COP sur article et numéro de série
  [M:REQ1]ARTICLE = [F:XCG]ITMREF
  [M:REQ1]SERNUM  = [F:XCG]SERNUM

  Call AM_ARTICLE([M:REQ1]ARTICLE)
  Call AM_SERNUM([M:REQ1]SERNUM)

  If !GIMPORT Then
    Affzo [M:REQ1]ARTICLE, SERNUM
  Endif
Else
  Call RSTA("XCG",VALEUR) From GLOCK
  mkstat = 2
Endif

End


########################################
Subprog AS_LOTPJT(VALEUR)
Variable Char    VALEUR()

If GUSER="FMUYS" Then
#FM Cf AV_LOTPJT
### If [M:REQ1]OPPNUM="" Then Raz VALEUR : mkstat=2 Endif
Endif
End


########################################
Subprog C_LOTPJT(VALEUR)
Variable Char    VALEUR()

# Contrôle des infos d'identifications obligatoires
If [M:REQ1]BPCNUM="" Then
    Call ERREUR(mess(52,[V]GXMSGPSA,1)+"\"+mess(239,[V]GXMSGPSA,1)) From GESECRAN
    mkstat=2
Endif
End


########################################
Subprog AM_LOTPJT(VALEUR)
Variable Char    VALEUR()

# Chargement des infos lots (LOTPJT)
Call LECTURE("LPJ",VALEUR, "") From CONTOBJ
End


########################################
Subprog AS_REQSTA(VALEUR)
Variable Char     VALEUR
Local Integer FLGMOD

#saisisable si création, duplication ou aucune inter de valide ratachées à la DS

[L]FLGMOD=1

If !find([V]GREP,"C","D")
    Local File ITVREQ [XITR]
    For [XITR]ITR1 Where REQNUM=[M:REQ0]REQNUM & FLGITVCAN<>2
        [L]FLGMOD=0
        Break 1
    Next
    Close Local File [XITR]
Endif

If ![L]FLGMOD
   mkstat=2
Endif
End


########################################
Subprog AM_ARTICLE(VALEUR)
Variable Char    VALEUR()

Local Char CLI(30),CON(30)

Raz CLI, CON

CLI=[M:REQ1]BPCNUM
If dim([M:REQ1]CONREV)>=0 Then CON=[M:REQ1]CONREV Endif

# Chargement des infos produits (ITMSALES & ITMMASTER)
Call LECTURE("ITM",VALEUR, "") From CONTOBJ
Call LECTURE("ITS",VALEUR, "") From CONTOBJ

# Recherche d'un contrat potentiel
If dim([M:REQ1]CONREV)>=0 & [M:REQ1]CONREV="" Then
   Call CNTARTSER([M:REQ1]BPCNUM,VALEUR,[M:REQ1]SERNUM,[M:REQ1]CONREV)From SPVOBJREQ
Endif

# Rafraichissement des infos tiers
If CLI<>[M:REQ1]BPCNUM Then
   Call AM_BPCNUM([M:REQ1]BPCNUM) From SPVREQ
Endif

# Rafraichissement des infos contrat
If dim([M:REQ1]CONREV)>=0 & CON<>[M:REQ1]CONREV Then
   Call AM_CONREV([M:REQ1]CONREV) From SPVREQ
Endif

# LBORN 13/02/2012
[M:REQ1]ARTICLE=VALEUR
Raz [M:REQ1]MACNUM

If !GIMPORT
  Affzo [M:REQ1]BPCNUM, BPRNAM, SERNUM, MACNUM
Endif
If !GIMPORT & dim([M:REQ1]CONREV)>=0
  Affzo [M:REQ1]CONREV
Endif
If !GIMPORT & dim([M:REQ1]COPNUM)>=0
  Affzo [M:REQ1]COPNUM
Endif

If [V]GXOPTSAV
  Raz [M:REQ2]OPEROU
Endif

End


########################################
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Char    CON
Local    Integer XSTAT

# LBORN 20/12/2012 - Mantis 17136
# If [M:REQ1]ARTICLE<>"" Then
If [M:REQ1]ARTICLE<>"" & VALEUR<>""
  Raz CON, XSTAT
  If dim([M:REQ1]CONREV)>=0 Then CON=[M:REQ1]CONREV Endif
  Call C_ITMSER([M:REQ0]REQTYP,[M:REQ1]ARTICLE,VALEUR,[M:REQ1]BPCNUM,CON,XSTAT) From SPVOBJREQ2
  If !XSTAT Then GERR=1 : mkstat=1 Endif
Endif
End


########################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Char    CLI(30)

CLI=[M:REQ1]BPCNUM

# Recherche d'un contrat potentiel
If dim([M:REQ1]CONREV)>=0 & [M:REQ1]CONREV="" Then
   Call CNTARTSER([M:REQ1]BPCNUM,[M:REQ1]ARTICLE,VALEUR,[M:REQ1]CONREV) From SPVOBJREQ
Endif

# Rafraichissement systématique des infos tiers
Call AM_BPCNUM([M:REQ1]BPCNUM) From SPVREQ

# Rafraichissement systématique des infos contrat
If dim([M:REQ1]CONREV)>=0 & [M:REQ1]CONREV<>"" Then
   Call AM_CONREV([M:REQ1]CONREV) From SPVREQ
Endif

# LBORN 13/02/2012
[M:REQ1]SERNUM=VALEUR

If !GIMPORT
  Affzo [M:REQ1]BPCNUM, BPRNAM, ARTICLE, MACNUM
Endif
If !GIMPORT & dim([M:REQ1]CONREV)>=0
  Affzo [M:REQ1]CONREV
Endif
If !GIMPORT & dim([M:REQ1]COPNUM)>=0
  Affzo [M:REQ1]COPNUM
Endif

End

########################################
Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()

# LBORN 26/10/2011 - On raffraichi le contact
Local Char ZCNT
Raz [L]ZCNT
Read [F:BPR]BPR0=[M:REQ1]BPCNUM
If !fstat & [F:BPR]CNTNAM<>""
  # Si le contact par défaut utilise la même adresse, on le prend
  Read [F:CNT]CNT0=1;[F:BPR]BPRNUM;[F:BPR]CNTNAM
  If !fstat & ([F:CNT]BPAADD="" | [F:CNT]BPAADD=VALEUR)
    [L]ZCNT=[F:BPR]CNTNAM
  Endif
Endif
If [L]ZCNT=""
  # Sinon, on prend le contact de la même adresse si un seul trouvé
  For [F:CNT]CNT0 Where [F:CNT]BPATYP=1 & [F:CNT]BPANUM=[F:BPR]BPRNUM
    If [F:CNT]BPAADD<>"" & [F:CNT]BPAADD=VALEUR
      If [L]ZCNT=""
        [L]ZCNT=[F:CNT]CCNCRM
      Else
        Raz [L]ZCNT : Break
      Endif
    Endif
  Next
Endif
If [L]ZCNT<>""
  [M:REQ1]CNTNAM=[L]ZCNT

  # LBORN 01/08/2013 - Mantis 20670
  If !fstat
    If !clalev([F:AIN]) : Local File CONTACTCRM : Endif
    Read [F:AIN]AIN0=[L]ZCNT
    If !fstat & [F:AIN]CRY<>""
      [M:REQ1]BPACRY=[F:AIN]CRY
    Endif
  Endif

Endif

# Lecture info adresse
If [M:REQ1]CNTNAM=""
   Call COORD_BPA(1,[M:REQ1]BPCNUM,VALEUR,[M:REQ1]TEL,[M:REQ1]FAX,[M:REQ1]WEB) From SPVOBJREQ
Endif
End

########################################
Subprog C_CNTNAM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
    Read [CNT] CNT0=1;[M:REQ1]BPCNUM;VALEUR
    If fstat GMESSAGE = mess(23,100,1) : mkstat=2 : Endif
Endif
End

########################################
Subprog AM_CNTNAM(VALEUR)
Variable Char    VALEUR()
# Lecture info contact
Call COORD_CNT(1,[M:REQ1]BPCNUM,VALEUR,[M:REQ1]TEL,[M:REQ1]FAX,[M:REQ1]WEB,[M:REQ1]BPACRY) From SPVOBJREQ
If VALEUR=""  or [M:REQ1]TEL = ""
   # Lecture info adresse
   Call COORD_BPA(1,[M:REQ1]BPCNUM,[M:REQ1]BPAADD,[M:REQ1]TEL,[M:REQ1]FAX,[M:REQ1]WEB) From SPVOBJREQ
Endif
End

########################################
Subprog D_CREADAT(VALEUR)
Variable Date    VALEUR
VALEUR=datesyst
End

########################################
Subprog D_CREATIM(VALEUR)
Variable Char    VALEUR()
VALEUR=left$(time$,2)+mid$(time$,4,2)
End

########################################
Subprog AM_CREADAT(VALEUR)
Variable Date    VALEUR
Call CALC_DELAI(VALEUR, [M:REQ1]CREATIM, [M:REQ1]COVCOD, [M:REQ1]CODCALREQ, [M:REQ1]MAXDAT,[M:REQ1]MAXTIM) From SPVOBJREQ2
If !GIMPORT Then Affzo [M:REQ1]MAXDAT, MAXTIM Endif
End

########################################
Subprog AM_CREATIM(VALEUR)
Variable Char    VALEUR()
Call CALC_DELAI([M:REQ1]CREADAT, VALEUR, [M:REQ1]COVCOD, [M:REQ1]CODCALREQ, [M:REQ1]MAXDAT ,[M:REQ1]MAXTIM) From SPVOBJREQ2
If !GIMPORT Then Affzo [M:REQ1]MAXDAT, MAXTIM Endif
End

########################################
Subprog AM_COVCOD(VALEUR)
Variable Char    VALEUR()
Call CALC_DELAI([M:REQ1]CREADAT, [M:REQ1]CREATIM, VALEUR, [M:REQ1]CODCALREQ, [M:REQ1]MAXDAT, [M:REQ1]MAXTIM) From SPVOBJREQ2
If !GIMPORT Then Affzo [M:REQ1]MAXDAT, MAXTIM Endif
End

########################################
Subprog D_MAXDAT(VALEUR)
Variable Date    VALEUR
Call CALC_DELAI([M:REQ1]CREADAT, [M:REQ1]CREATIM, [M:REQ1]COVCOD, [M:REQ1]CODCALREQ, VALEUR,[M:REQ1]MAXTIM) From SPVOBJREQ2
If !GIMPORT Then Affzo [M:REQ1]MAXTIM Endif
End

########################################
Subprog AM_QUEUE(VALEUR)
Variable Char    VALEUR()

If GIMPORT & [M:REQ1]RESINT<>"" : End : Endif

If clalev([F:XQU])=0 : Local File XQUEUE : Endif

Call LECTURE("XQU",VALEUR,"") From CONTOBJ
If !fstat & [F:XQU]QUERES<>""
  [M:REQ1]RESINT=[F:XQU]QUERES
  If !GIMPORT

    # LBORN 04/04/2016 - Mantis 32454
    Call AM_RESINT([M:REQ1]RESINT)

    Affzo [M:REQ1]RESINT
    If dim([M:REQ1]ZRESINT)>=0
      Affzo [M:REQ1]ZRESINT
    Endif
  Endif
Endif
End

########################################
Subprog AS_RESINT(VALEUR)
Variable Char     VALEUR
If [M:REQ1]ORESINT=""
   [M:REQ1]ORESINT=[M:REQ1]RESINT
Endif
End

