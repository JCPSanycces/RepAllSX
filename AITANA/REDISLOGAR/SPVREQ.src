################################################################################
## Etiquette ajoutée par le superviseur (écran REQUEST3) 02/05/2006 15:22:44 (FMUYS)
################################################################################

########################################
Subprog AM_BPCNUM(VALEUR)
Variable Char    VALEUR()

# Chargement des infos du tiers (BPPARTNER)
Call LECTURE("BPR",VALEUR,"") From CONTOBJ
If fstat=0 Then
   [M:REQ1] = [F:BPR]
   Call INIT_BPA(VALEUR,[M:REQ1]BPAADD) From XTRTBPA
   [M:REQ1]BPRNAM=[F:BPR]BPRNAM(0)
   [M:REQ2] = [F:BPR]
   [M:REQ3] = [F:BPR]

   If [F:BPR]BPCFLG=2 Then
      [M:REQ3]BPCINV=VALEUR
   Endif
   [M:REQ3]CURINV=[F:BPR]CUR

   # LBORN 01/03/2010 - Ré-init en fonction des exceptions Tiers/Société
   Call INIPTE ([M:REQ3]BPCPYR,[M:REQ3]BPCINV,"C",[M:REQ3]PTE) From TRTX3
   If !GIMPORT : Affzo [M:REQ3]PTE : Endif
   Call INIT_REGIME([M:REQ3]BPCINV,GSOCIETE,"C",[M:REQ3]VACBPR) From CPTSUB
   If !GIMPORT : Affzo [M:REQ3]VACBPR : Endif

   # Chargement des infos clients facturé (BPCUSTOMER)
   If [F:BPR]BPCFLG=2 Then
      # Remarque LBORN 01/10/2008 - La devise de facturation sera réinitialisée / Client facturé car ajout init en AM_BPCINV
      Call AM_BPCINV([M:REQ3]BPCINV) From SPVREQ
   Endif

   # Lecture info contact
   [M:REQ1]BPCNUM=VALEUR
   Call AM_CNTNAM([M:REQ1]CNTNAM)

   #*FMV6ANA
   Effzo [M:REQ3]30 : Affzo [M:REQ3]30

   If [V]GINTRA : #CGUES
        Affzo [M:REQ1]BPAADD,CNTNAM
        Affzo [M:REQ2]
        Affzo [M:REQ3]
   Endif

Endif

#FM le 02.05.06
Gosub EFFZO_REP
End

########################################
Subprog AM_CONREV(VALEUR)
Variable Char    VALEUR()

If VALEUR="" Then Goto FIN1 Endif

Local Integer STAT

# Chargement des infos contrat (CONTRACT)
Call LECTURE("XON",VALEUR, "") From CONTOBJ
If fstat=0
   # Initialisation du Tiers/contrat
   If [M:REQ1]BPCNUM<>[F:XON]BPCNUM Then
      [M:REQ1]BPCNUM=[F:XON]BPCNUM
      Call AM_BPCNUM([M:REQ1]BPCNUM) From SPVREQ
      If !GIMPORT
         Affzo [M:REQ1]BPCNUM : Affzo [M:REQ1]BPRNAM
      Endif
   Endif

   # Initialisation du clients facturé/contrat
   If [M:REQ3]BPCINV<>[F:XON]BPCINV Then
      [M:REQ3]BPCINV=[F:XON]BPCINV
      Call AM_BPCINV([M:REQ3]BPCINV) From SPVREQ
   Endif

#Le contrat est prioritaire sur le tiers

   [M:REQ1] = [F:XON]
   [M:REQ2]QUESTION = [F:XON]QUESTION
   [M:REQ3] = [F:XON]
   [M:REQ3]CURINV = [F:XON]CURCON
   [M:REQ3]RGPCOD = [F:XON]RGPCODCON

   # Lecture info contact
   Call AM_CNTNAM([M:REQ1]CNTNAM)

   #*FMV6ANA
   [M]CONREV=VALEUR
   Effzo [M:REQ3]30 : Affzo [M:REQ3]30

Endif

$FIN1
#FM le 02.05.06
Gosub EFFZO_REP
End

########################################
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()

# Chargement des infos affaires (OPPOR)
Call LECTURE("OPP",VALEUR, "") From CONTOBJ

#FM le 02.05.06
Gosub EFFZO_REP

# Raffraichissement de l'analytique
[M:REQ1]OPPNUM=VALEUR
Effzo [M:REQ3]30 : Affzo [M:REQ3]30

End

########################################
$EFFZO_REP
#FM le 02.05.06
For I=1 To dim([M:REQ3]REP)
  Effzo [M:REQ3]REP(I-1)
  If dim([M:REQ3]ZREP(I-1))>0 Then Effzo [M:REQ3]ZREP(I-1) Endif
Next
Return

########################################
Subprog D_REP(VALEUR)
Variable Char    VALEUR()

#FM le 02.05.06
Local Char XPAR(30)(10) : Raz XPAR

[L]XPAR(0)=[M:REQ1]BPCNUM
[L]XPAR(1)=[M:REQ1]BPAADD
[L]XPAR(2)=[M:REQ1]OPPNUM

If GXOPTCON Then [L]XPAR(3)=[M:REQ1]CONREV Endif

Call INIREP(VALEUR,indice,[L]XPAR)From SPVOBJREQ

End

########################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
###
#*FMV6ANA le 05.01.10
GFCY=VALEUR
Gosub CHARG_PARAM From SPVOBJREQ : Raz GERR : Raz GMESSAGE

# LBORN 01/03/2010 - Ré-init en fonction des exceptions Tiers/Société
Call INIPTE ([M:REQ3]BPCPYR,[M:REQ3]BPCINV,"C",[M:REQ3]PTE) From TRTX3
If !GIMPORT : Affzo [M:REQ3]PTE : Endif
Call INIT_REGIME([M:REQ3]BPCINV,GSOCIETE,"C",[M:REQ3]VACBPR) From CPTSUB
If !GIMPORT : Affzo [M:REQ3]VACBPR : Endif

If dim([M:REQ3]NBAXE)>0 Then
    [M]FCY=VALEUR
    Effzo [M:REQ3]30 : Affzo [M:REQ3]30
Endif
End

########################################
Subprog AS_NBAXE
###
#*FMV6ANA le 05.01.10
Local Char     SECTION
Local Integer  NN, II
Local Shortint RR
###
[M]NBAXE=GNBDIE
NN=nolign
For [L]II=1 To GNBDIE
    nolign=[L]II
    indice=nolign-1
    If [M]CCE(nolign-1)="" Then
        Call INISEC(SECTION,"XREQ",[M]DIE(nolign-1))From SUBCDE
        indice=[L]II-1
        If SECTION<>"" Then
           Call CONTROLE("CCE","#",SECTION,[M]DIE(nolign-1),RR)From CONTOBJ
           indice=[L]II-1
           If RR Then
                Raz GMESSAGE
            Else
                Call AM_CCE(SECTION)From W1REQUEST3
                [M]CCE(nolign-1)=SECTION
                If !GIMPORT Then Affzo [M]CCE(nolign-1) Endif
            Endif
        Endif
    Endif
Next
nolign=NN
indice=nolign-1
End

########################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
###
Local File FACILITY [FCYY]
&        , ITVREQ   [ITRY]
Read [F:FCYY]FCY0=[M]FCY
If !fstat Then
    Look [ITRY]ITR1(1)=[M]REQNUM
    If !fstat Then
        Call CONTFCYCPY(VALEUR,[F:FCYY]LEGCPY)From EXEFNC
        If mkstat Then End Endif
    Endif
Endif
Close Local File [FCYY],[ITRY]
End

