######################################################################################
Subprog AS_FLGREGUL(VALEUR)
Variable Integer VALEUR
# LBORN 02/01/2013 - Mise à jour du Flag interdite si du réalisé a déjà été généré
If ![V]GXOPTOPP | find(GREP,"C","D") : End : Endif
If !clalev([F:VGS]) : Local File VALGASSIT : Endif
Read [F:VGS]VGA4(1)=[M:REQ0]REQNUM
If !fstat
  mkstat=2
Endif
End

######################################################################################
Subprog AM_FLGREGUL(VALEUR)
Variable Integer VALEUR
If GIMPORT : End : Endif
If !clalev([F:ITR]) : Local File ITVREQ : Endif
For [F:ITR]ITR1 Hint Key ITR1 Where [F:ITR]REQNUM=[M:REQ0]REQNUM & [F:ITR]FLGREGUL=2 & [F:ITR]FLGITVCAN<>2
  [V]GERR=3
  If VALEUR=2
    [V]GMESSAGE=mess(52,[V]GXMSGPSA(1),1)
    Break
  Else
    [V]GMESSAGE=mess(53,[V]GXMSGPSA(1),1)
    Break
  Endif
Next
End

######################################################################################
Subprog AV_MACNUM(VALEUR)
Variable Char    VALEUR()

Actzo [M:REQ1]MACNUM

If !func AFNC.ACTIV("HDK") | [M:REQ1]ARTICLE="" | [M:REQ1]SERNUM="" : End : Endif

If !clalev([F:MAC]) : Local File MACHINES : Endif

Raz VALEUR

Read [F:MAC]MAC5=[M:REQ1]ARTICLE;[M:REQ1]SERNUM
If !fstat
  VALEUR=[F:MAC]MACNUM
Endif

End

######################################################################################
Subprog AS_MACNUM(VALEUR)
Variable Char    VALEUR()

[V]GBIDC1="1"

If [M:REQ1]BPCNUM<>""
  [V]GBIDC1-="& [F:MAC]MACCUTBPC='"+[M:REQ1]BPCNUM+"'"
Endif
If [M:REQ1]ARTICLE<>""
  [V]GBIDC1-="& [F:MAC]MACPDTCOD='"+[M:REQ1]ARTICLE+"'"
Endif
If [M:REQ1]SERNUM<>""
  [V]GBIDC1-="& [F:MAC]MACSERNUM='"+[M:REQ1]SERNUM+"'"
Endif

End

######################################################################################
Subprog AM_MACNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR="" : End : Endif

If !clalev([F:MAC]) : Local File MACHINES : Endif

Read [F:MAC]MAC0=VALEUR
If !fstat
  [M:REQ1]ARTICLE =[F:MAC]MACPDTCOD
  [M:REQ1]SERNUM  =[F:MAC]MACSERNUM
Endif

If [V]GXOPTSAV
  Raz [M:REQ2]OPEROU
Endif

Affzo [M:REQ1]ARTICLE,SERNUM

End

