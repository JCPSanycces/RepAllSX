Subprog AV_BPCNUM(VALEUR)
Variable Char    VALEUR()
#FM le 14.03.06
Actzo [M]BPCNUM
If GREP<>"C" & [M:REQ0]REQNUM<>"" Then
  If !clalev([F:ITR]) Then Local File ITVREQ Endif
  Local Integer XNBITV : XNBITV=0
  For [F:ITR]ITR1 Where [F:ITR]REQNUM=[M:REQ0]REQNUM
&                     & [F:ITR]FLGITVCAN<>2
    XNBITV+=1 : Break
  Next
  If XNBITV Then Diszo [M]BPCNUM Endif
Endif
End

