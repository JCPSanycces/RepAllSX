#=========================================================================================================================
# SECTION CONTENANT LES SOUS-PROGRAMMES DE CONTROLE SUR CHAMPS  : Ecran REQ3 (Facturation)
#=========================================================================================================================

########################################
Subprog AM_BPCINV(VALEUR)
Variable Char    VALEUR()

Local Char SVG_VALNUM, SVG_IMPNUM

# Chargement des infos clients facturé (BPCUSTOMER)
Call LECTURE("BPC",VALEUR,"") From CONTOBJ
If fstat=0

   #sauvegarde sinon trans class efface [m:req2]
   [L]SVG_VALNUM=[M:REQ2]VALNUM
   [L]SVG_IMPNUM=[M:REQ2]IMPNUM

   # LBORN 25/02/2013 - Mantis 18105 - Recalcul de RGPCOD uniquement si changement de client facturé
   Local Char XRGPCOD
   If [F:BPC]BPCINV<>[M:REQ3]BPCINV & [F:BPC]RGPCOD<>""
     [L]XRGPCOD=[F:BPC]RGPCOD
   Else
     [L]XRGPCOD=[M:REQ3]RGPCOD
   Endif

   [M:REQ2]=[F:BPC]
   [M:REQ3]=[F:BPC]
   [M:REQ3]CURTYP=[F:BPC]CHGTYP

   # LBORN 13/03/2014 - Mantis 24214
   [M:REQ3]PRCTYP=[F:BPC]PRITYP

   # LBORN 25/02/2013 - Mantis 18105
   [M:REQ3]RGPCOD=[L]XRGPCOD
   If !GIMPORT : Affzo [M:REQ3]RGPCOD : Endif

   [M:REQ2]VALNUM=[L]SVG_VALNUM

   # LBORN 03/03/2014 - Mantis 23952 (cas où IMPNUM est ajouté en SPE dans BPCUSTOMER)
   [M:REQ2]IMPNUM=[L]SVG_IMPNUM

   # Ajout LBORN 01/10/2008
   Read [F:BPR]BPR0=VALEUR
   If !fstat
     [M:REQ3]CURINV=[F:BPR]CUR
     If !GIMPORT
       Affzo [M:REQ3]CURINV
       If dim([M:REQ3]ZCURINV)>0 : Affzo [M:REQ3]ZCURINV : Endif
     Endif
   Endif

   # LBORN 01/03/2010 - Ré-init en fonction des exceptions Tiers/Société
   Call INIPTE ([M:REQ3]BPCPYR,VALEUR,"C",[M:REQ3]PTE) From TRTX3
   If !GIMPORT : Affzo [M:REQ3]PTE : Endif
   Call INIT_REGIME(VALEUR,GSOCIETE,"C",[M:REQ3]VACBPR) From CPTSUB
   If !GIMPORT : Affzo [M:REQ3]VACBPR : Endif

   #*FMV6ANA
   [M]BPCINV=VALEUR
   Effzo [M:REQ3]30 : Affzo [M:REQ3]30
Endif

# Affichage des observations du client facture
If !GIMPORT
   If len(vireblc([F:BPC]BPCREM,2)) Then
      Call MESSAGE([F:BPC]BPCREM) From GESECRAN
   Endif
Endif
End

