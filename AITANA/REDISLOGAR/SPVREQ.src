#=========================================================================================================================
# SECTION CONTENANT LES SOUS-PROGRAMMES DE CONTROLE SUR CHAMPS  : Ecran REQ4 (Calendrier)
#=========================================================================================================================


########################################
Subprog D_UVYDAY(VALEUR)
Variable Integer VALEUR

Local Char AZC

# LBORN 06/11/2015
Local Integer ZNOL : [L]ZNOL=indice

If dim([M:REQ1]CONREV)>=0 & [M:REQ1]CONREV<>"" Then
    Call LECTURE("XON",[M:REQ1]CONREV,"")From CONTOBJ
    # LBORN 06/11/2015
    # VALEUR=[F:XON]UVYDAY(indice)
    VALEUR=[F:XON]UVYDAY([L]ZNOL)
Elsif [M:REQ1]OPPNUM<>""
   If GXOPTOPP
     If !clalev([F:XOP]) : Local File OPPORX3S : Endif
     Read [F:XOP]XOP0=[M:REQ1]OPPNUM
     If !fstat
       # LBORN 06/11/2015
       # VALEUR=[F:XOP]UVYDAY(indice)
       VALEUR=[F:XOP]UVYDAY([L]ZNOL)
     Endif
   Endif
Else

    # LBORN 06/11/2015
    # Call CALEND_FCY([M:REQ0]FCY,1,AZC,indice)From SPVOBJHCI
    Call CALEND_FCY([M:REQ0]FCY,1,AZC,[L]ZNOL)From SPVOBJHCI

    VALEUR=val(AZC)
Endif
End

########################################
Subprog D_HOUWKDDAY(VALEUR)
Variable Decimal VALEUR

# LBORN 06/11/2015
Local Integer ZNOL : [L]ZNOL=indice

Local Char AZC
If dim([M:REQ1]CONREV)>=0 & [M:REQ1]CONREV<>"" Then
    Call LECTURE("XON",[M:REQ1]CONREV,"")From CONTOBJ
    # LBORN 06/11/2015
    # VALEUR=[F:XON]HOUWKDDAY(indice)
    VALEUR=[F:XON]HOUWKDDAY([L]ZNOL)
Elsif [M:REQ1]OPPNUM<>""
    If GXOPTOPP
      If !clalev([F:XOP]) : Local File OPPORX3S : Endif
      Read [F:XOP]XOP0=[M:REQ1]OPPNUM
      If !fstat
        # LBORN 06/11/2015
        # VALEUR=[F:XOP]HOUWKDDAY(indice)
        VALEUR=[F:XOP]HOUWKDDAY([L]ZNOL)
      Endif
    Endif
Else
    # LBORN 06/11/2015
    # Call CALEND_FCY([M:REQ0]FCY,2,AZC,indice)From SPVOBJHCI
    Call CALEND_FCY([M:REQ0]FCY,2,AZC,[L]ZNOL)From SPVOBJHCI
    VALEUR=val(AZC)
Endif
End

########################################
Subprog D_UVYCOD(VALEUR)
Variable Char    VALEUR()

# LBORN 06/11/2015
Local Integer ZNOL : [L]ZNOL=indice

If dim([M:REQ1]CONREV)>=0 & [M:REQ1]CONREV<>"" Then
    Call LECTURE("XON",[M:REQ1]CONREV,"")From CONTOBJ
    VALEUR=[F:XON]UVYCOD
Elsif [M:REQ1]OPPNUM<>""
    If GXOPTOPP
      If !clalev([F:XOP]) : Local File OPPORX3S : Endif
      Read [F:XOP]XOP0=[M:REQ1]OPPNUM
      If !fstat
        # LBORN 06/11/2015
        # VALEUR=[F:XOP]UVYCOD(indice)
        VALEUR=[F:XOP]UVYCOD([L]ZNOL)
      Endif
    Endif
Else
    Call CALEND_FCY([M:REQ0]FCY,3,VALEUR,0)From SPVOBJHCI
Endif
End


########################################
Subprog D_HHMMWKDDAY(VALEUR)
Variable Char    VALEUR()

# LBORN 06/11/2015
Local Integer ZNOL : [L]ZNOL=indice

Local Char     AZC
Local Decimal  AZCD(7)

If dim([M:REQ1]CONREV)>=0 & [M:REQ1]CONREV<>"" Then

    Call LECTURE("XON",[M:REQ1]CONREV,"")From CONTOBJ
    # LBORN 06/11/2015
    # AZCD(indice)=[F:XON]HOUWKDDAY(indice)
    AZCD([L]ZNOL)=[F:XON]HOUWKDDAY([L]ZNOL)

Elsif [M:REQ1]OPPNUM<>""
    If GXOPTOPP
      If !clalev([F:XOP]) : Local File OPPORX3S : Endif
      Read [F:XOP]XOP0=[M:REQ1]OPPNUM
      If !fstat
        # LBORN 06/11/2015
        # AZCD(indice)=[F:XOP]HOUWKDDAY(indice)
        AZCD([L]ZNOL)=[F:XOP]HOUWKDDAY([L]ZNOL)
      Endif
    Endif
Else
    # LBORN 06/11/2015
    # Call CALEND_FCY([M:REQ0]FCY,2,AZC,indice)From SPVOBJHCI
    # AZCD(indice)=val(AZC)
    Call CALEND_FCY([M:REQ0]FCY,2,AZC,[L]ZNOL)From SPVOBJHCI
    AZCD([L]ZNOL)=val(AZC)
Endif

Gosub AV_WKDDAY From SPVOBJHCI
VALEUR=AZC

End

