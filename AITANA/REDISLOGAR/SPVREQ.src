GBIDC1=""
GBIDC2=""
GFONC1="GESREQ"
Call OBJET("REQ",[V]GBIDC1,[V]GBIDC2)From GOBJET
End

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$ACTION

# Appel fonctions complémentaires GFI pour l'objet REQ
Gosub ACTION From XOBJSPE
If GPE=1 Then Return Endif

Case ACTION
When "DEFTRANS"        : Gosub DEFTRANS     From SPVOBJREQ
When "VARIANTE"        : Gosub VARIANTE     From SPVOBJREQ
When "SETTRANS"        : Gosub SETTRANS     From SPVOBJREQ

When "AV_IMPRIME"      : Gosub AV_IMPRIME   From SPVOBJREQ
When "AP_IMPRIME"      : Gosub AP_IMPRIME   From SPVOBJREQ
When "AV_LISTE"        : Gosub AV_LISTE     From SPVOBJREQ
When "AP_LISTE"        : Gosub AP_LISTE     From SPVOBJREQ

When "AVANT_OUVRE"     : Gosub AVANT_OUVRE  From SPVOBJREQ
When "OUVRE"           : Gosub OUVRE        From SPVOBJREQ
When "FERME"           : Gosub FERME        From SPVOBJREQ
When "STATUT"          : Gosub STATUT       From SPVOBJREQ
When "FILTRE"          : Gosub FILTRE       From SPVOBJREQ
When "LIENS"           : Gosub LIENS        From SPVOBJREQ
When "SETBOUT"         : Gosub SETBOUT      From SPVOBJREQ
When "AVANTBOUT"       : Gosub AVANTBOUT    From SPVOBJREQ
When "EXEBOUT"         : Gosub EXEBOUT      From SPVOBJREQ
When "RAZCRE"          : Gosub RAZCRE       From SPVOBJREQ
When "RAZDUP"          : Gosub RAZDUP       From SPVOBJREQ
When "INICRE"          : Gosub INICRE       From SPVOBJREQ
When "CREATION"        : Gosub CREATION     From SPVOBJREQ
When "MODIF"           : Gosub MODIF        From SPVOBJREQ
When "INIMOD"          : Gosub INIMOD       From SPVOBJREQ
When "APRES_CRE"       : Gosub APRES_CRE    From SPVOBJREQ
When "APRES_MOD"       : Gosub APRES_MOD    From SPVOBJREQ
When "FIN_MOD"         : Gosub FIN_MOD      From SPVOBJREQ
When "AVANT_MODFIC"    : Gosub AVANT_MODFIC From SPVOBJREQ
When "ABANDON"         : Gosub ABANDON      From SPVOBJREQ
When "VERF_ANU"        : Gosub VERF_ANU     From SPVOBJREQ
When "ANNULE"          : Gosub ANNULE       From SPVOBJREQ
When "AP_ANNULE"       : Gosub AP_ANNULE    From SPVOBJREQ
When "SEL_TABLE"       : Gosub SEL_TABLE    From SPVOBJREQ
Endcase

#===== Actions scénario
#===============================================================================
Case GACTION
When "SELMESREQ"       : # Sélection dans liste
                         Case ACTION
                         When "SEL_LISTE"  : Gosub SEL_SELMESREQ  From SPVOBJREQ3
                         When "VERF_LISTE" : Gosub VERF_SELMESREQ From SPVOBJREQ3
                         Endcase
When "XRQ5CRIT"        : # Traitement standard
                         Case ACTION
                         When "INIT"       : Gosub CREQ5_INIT  From SPVOBJREQ
                         When Default      : Gosub CREQ5_DEBUT From SPVOBJREQ
                         Endcase
Endcase

#===== Actions AV/AP sur champs
#===============================================================================
Case ACTION
When "ACL_ZICOTEX1"    : Gosub ACL_ZICOTEX1
When "BCL_ZICOTEX1"    : Gosub BCL_ZICOTEX1
When "ACL_ZICOTEX2"    : Gosub ACL_ZICOTEX2
When "BCL_ZICOTEX2"    : Gosub BCL_ZICOTEX2
Endcase
Return




