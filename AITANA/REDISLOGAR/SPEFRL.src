#<AdxTL>@(#)0.0.0.0 $Revision$

$ACTION
  Case ACTION
    When "LIENS" : Gosub LIENS
    When "MODIF" : Gosub MODIF
  Endcase
Return

#------------------------------------------------------------------------------#

$LIENS
  Gosub ACTION From SPVFRL
  GPV = 1
  Gosub LOAD_SPE_FIELDS
Return

#------------------------------------------------------------------------------#

$MODIF
  Gosub ACTION From SPVFRL
  If GOK : Gosub PRORRATEO : Endif
  GPV = 1
Return

#------------------------------------------------------------------------------#

Subprog AS_NBLIG
  Gosub LOAD_SPE_FIELDS
End

#------------------------------------------------------------------------------#

Subprog AS_XYINSPRR(VALEUR)
Variable Integer VALEUR
  If [M:FRL1]ITMREF<>""
    mkstat = 2
  Else
    Read [F:PFM]PFM0=[M:FRL0]TYPFRM
    If fstat : Raz [F:PFM] : Endif

    If [F:PFM]YMATLINE=2 : mkstat = 2 : Endif
  Endif
  If !mkstat and [M:FRL1]YDTOPRR=2
    GERR = 1 : GMESSAGE = mess(9,6100,1) : mkstat = 2
  Endif
  If mkstat
    VALEUR = 1           : [M:FRL2]YINSPRR([M:FRL2]XNUMLIG-1) = VALEUR
    Raz [M:FRL2]XYINSPRC : Raz [M:FRL2]YINSPRC([M:FRL2]XNUMLIG-1)
    Raz [M:FRL2]XYINSEST : Raz [M:FRL2]YINSEST([M:FRL2]XNUMLIG-1)

    Affzo [M:FRL2]XYINSPRC, XYINSEST
  Endif
End

#------------------------------------------------------------------------------#

Subprog AM_XYINSPRR(VALEUR)
Variable Integer VALEUR

  [M:FRL2]YINSPRR([M:FRL2]XNUMLIG-1) = VALEUR
  If VALEUR<>2
    Raz [M:FRL2]XYINSPRC : Raz [M:FRL2]YINSPRC([M:FRL2]XNUMLIG-1)
    Raz [M:FRL2]XYINSEST : Raz [M:FRL2]YINSEST([M:FRL2]XNUMLIG-1)

    Affzo [M:FRL2]XYINSPRC, XYINSEST
  Endif
End

#------------------------------------------------------------------------------#

Subprog AS_XYINSPRC(VALEUR)
Variable Decimal VALEUR
  If [M:FRL2]XYINSPRR<>2
    Raz VALEUR : Raz [M:FRL2]YINSPRC([M:FRL2]XNUMLIG-1)
    mkstat = 2
  Endif
End

#------------------------------------------------------------------------------#

Subprog AM_XYINSPRC(VALEUR)
Variable Decimal VALEUR
  [M:FRL2]YINSPRC([M:FRL2]XNUMLIG-1) = VALEUR
End

#------------------------------------------------------------------------------#

Subprog AS_XYINSEST(VALEUR)
Variable Decimal VALEUR
  If [M:FRL2]XYINSPRR<>2
    Raz VALEUR : Raz [M:FRL2]YINSEST([M:FRL2]XNUMLIG-1)
    mkstat = 2
  Endif
End

#------------------------------------------------------------------------------#

Subprog AM_XYINSEST(VALEUR)
Variable Decimal VALEUR
  [M:FRL2]YINSEST([M:FRL2]XNUMLIG-1) = VALEUR
End

#------------------------------------------------------------------------------#

$LOAD_SPE_FIELDS
  [M:FRL2]XYINSEST = [M:FRL2]YINSEST([M:FRL2]XNUMLIG-1)
  [M:FRL2]XYINSPRC = [M:FRL2]YINSPRC([M:FRL2]XNUMLIG-1)
  [M:FRL2]XYINSPRR = [M:FRL2]YINSPRR([M:FRL2]XNUMLIG-1)

  Affzo [M:FRL2]XYINSEST, XYINSPRC, XYINSPRR
Return

#------------------------------------------------------------------------------#

Subprog AS_YDTOPRR(VALEUR)
Variable Integer VALEUR
Local    Integer I

  If [M:FRL1]ITMREF<>""
    mkstat = 2
  Else
    Read [F:PFM]PFM0=[M:FRL0]TYPFRM
    If fstat : Raz [F:PFM] : Endif

    If [F:PFM]YMATLINE=2 : mkstat = 2 : Endif
  Endif
  If !mkstat
    I = find(2,[M:FRL2]YINSPRR(0..[M:FRL2]NBLIG-1))
    If I>0
      GERR = 1 : GMESSAGE = mess(8,6100,1) : mkstat = 2
    Endif
  Endif
  If mkstat
    VALEUR = 1
    Raz [M:FRL1]YDTOPRC : Affzo [M:FRL1]YDTOPRC
  Endif
End

#------------------------------------------------------------------------------#

Subprog AM_YDTOPRR(VALEUR)
Variable Integer VALEUR
  If VALEUR<>2
    Raz [M:FRL1]YDTOPRC : Affzo [M:FRL1]YDTOPRC
  Endif
End

#------------------------------------------------------------------------------#

Subprog AS_YDTOPRC(VALEUR)
Variable Decimal VALEUR
  If [M:FRL1]YDTOPRR<>2
    Raz VALEUR : mkstat = 2
  Endif
End

#------------------------------------------------------------------------------#

$PRORRATEO
  Local Char    CRITSQL(255), WVCRNUM(GLONFRL)(1..500)
  Local Integer NBRPRORR, WVCRLIN(1..500)
  Local Decimal INSIMPORT, INSTPORCENT, DTO

  If clalev([F:YFRL])=0 : Local File FORMSL      [YFRL] : Endif
  If clalev([F:YFRA])=0 : Local File FORMSLA     [YFRA] : Endif
  If clalev([F:YVTA])=0 : Local File YVTOTMATPRJ [YVTA] : Endif

  Gosub PUR_PRORR
  If GOK<1 : Return : Endif
  Gosub SAL_PRORR
Return

#------------------------------------------------------------------------------#

$PUR_PRORR
  # Identificar las líneas de compra del proyecto con prorrateo
  Raz NBRPRORR, WVCRNUM, WVCRLIN

  CRITSQL  = "SELECT FRA.FRMNUMLIG_0,FRA.NUMLIGFRL2_0"
  CRITSQL -= "FROM FORMSLA AS FRA INNER JOIN FORMSL AS FRL ON FRA.FRMNUMLIG_0=FRL.FRMNUMLIG_0"
  CRITSQL -= "WHERE FRA.YINSPRR_0=2 AND FRL.OPPNUM_0='" + [F:FRL]OPPNUM +"'"

  For (Char    FRMNUMLIG(GLONFRL),
&      Decimal NUMLIGFRL2) From num$((GTYPDBA*2)+1) Sql CRITSQL As [YSQL]
          NBRPRORR += 1
          WVCRNUM(NBRPRORR)  = [F:YSQL]FRMNUMLIG
          WVCRLIN(NBRPRORR) = [F:YSQL]NUMLIGFRL2
  Next YSQL

  If NBRPRORR>0
    # Inicializar: Recargo Instalación % (DISCRGVAL3)
    CRITSQL  = "UPDATE FORMSL"
    CRITSQL -= "SET DISCRGVAL3_0=0"
    CRITSQL -= "FROM FORMSL AS FRL INNER JOIN PARFRMTYP AS PFM ON FRL.TYPFRM_0=PFM.TYPFRM_0"
    CRITSQL -= "WHERE PFM.YMATLINE_0=2 AND FRL.OPPNUM_0='" + [F:FRL]OPPNUM + "'"

    Onerrgo ERR_SQL
    Execsql From num$(GTYPDBA*2+1) Sql CRITSQL
    Onerrgo

    If GOK
      Read [F:YVTA]YVTA0=[F:FRL]OPPNUM
      If fstat : Raz [F:YVTA] : Endif

      For I=1 To NBRPRORR
        Raz INSIMPORT, INSTPORCENT, DTO
        Read [F:YFRA]FRA0=WVCRNUM(I);WVCRLIN(I)
        If !fstat
          If [F:YFRA]COSPRIPUR<>0
            If [F:YVTA]SUMGROPRIMAT<>0
              INSTPORCENT = arr(([F:YFRA]COSPRIPUR/[F:YVTA]SUMGROPRIMAT)*100, 0.01)
            Endif
          Elsif [F:YFRA]YINSPRC<>0
            INSTPORCENT = [F:YFRA]YINSPRC
          Endif

          CRITSQL  = "UPDATE FORMSL"
          CRITSQL -= "SET DISCRGVAL3_0=DISCRGVAL3_0+" + num$(INSTPORCENT)
          CRITSQL -= "FROM FORMSL AS FRL INNER JOIN PARFRMTYP AS PFM ON FRL.TYPFRM_0=PFM.TYPFRM_0"
          CRITSQL -= "WHERE PFM.YMATLINE_0=2 AND FRL.OPPNUM_0='" + [F:FRL]OPPNUM + "'"

          Onerrgo ERR_SQL
          Execsql From num$(GTYPDBA*2+1) Sql CRITSQL
          Onerrgo

          If GOK<1 : Break : Endif
        Endif
      Next
    Endif
  Endif
Return

#------------------------------------------------------------------------------#

$SAL_PRORR
  # Identificar las líneas de venta del proyecto con prorrateo
  Raz NBRPRORR, WVCRNUM

  CRITSQL  = "SELECT FRMNUMLIG_0"
  CRITSQL -= "FROM FORMSL"
  CRITSQL -= "WHERE YDTOPRR_0=2 AND OPPNUM_0='" + [F:FRL]OPPNUM +"'"

  For (Char FRMNUMLIG(GLONFRL)) From num$((GTYPDBA*2)+1) Sql CRITSQL As [YSQL]
    NBRPRORR += 1
    WVCRNUM(NBRPRORR) = [F:YSQL]FRMNUMLIG
  Next YSQL

  If NBRPRORR>0
    # Inicializar: Descuento 1 (DIS)
    CRITSQL  = "UPDATE FORMSL"
    CRITSQL -= "SET DIS_0=0"
    CRITSQL -= "FROM FORMSL AS FRL INNER JOIN PARFRMTYP AS PFM ON FRL.TYPFRM_0=PFM.TYPFRM_0"
    CRITSQL -= "WHERE PFM.YMATLINE_0=2 AND FRL.OPPNUM_0='" + [F:FRL]OPPNUM + "'"

    Onerrgo ERR_SQL
    Execsql From num$(GTYPDBA*2+1) Sql CRITSQL
    Onerrgo

    If GOK
      For I=1 To NBRPRORR
        Read [F:YFRL]FRL0=WVCRNUM(I)
        If fstat : Raz [F:YFRL] : Endif
        DTO = [F:YFRL]YDTOPRC

        CRITSQL  = "UPDATE FORMSL"
        CRITSQL -= "SET DIS_0=DIS_0+" + num$(DTO)
        CRITSQL -= "FROM FORMSL AS FRL INNER JOIN PARFRMTYP AS PFM ON FRL.TYPFRM_0=PFM.TYPFRM_0"
        CRITSQL -= "WHERE PFM.YMATLINE_0=2 AND FRL.OPPNUM_0='" + [F:FRL]OPPNUM + "'"

        Onerrgo ERR_SQL
        Execsql From num$(GTYPDBA*2+1) Sql CRITSQL
        Onerrgo

        If GOK<1 : Break : Endif
      Next
    Endif
  Endif

Return

#------------------------------------------------------------------------------#

$ERR_SQL
  GMESSAGE  = errp - "(" + num$(errl) + ")\"
  GMESSAGE += mess(6,123,1) - num$(errn) - ":" - errmes$(errn)
  GERR = 1 : GOK = 0
Resume

