######################################################################################
# Program Name: YSPESDH
# Description : Specific Processing - Sales Delivery
# Author      :
# Date        : AUG 22nd, 2018
######################################################################################

$ACTION
Case ACTION
 When "SETBOUT"       : Gosub SETBOUT
 When "RAZDUP"        : Gosub RAZDUP
 When Default
Endcase
Return
######################################################################################

$SETBOUT
If func AFNC.PARAM("ZAPPSDH",[F:SDH]STOFCY)<>"1"
 Gosub SETBOUT From SUBSDHA :  GPE = 1
 If [F:SDH]ZAPPFLG<3
  Call VIREBOUT(CHAINE,"1") From GOBJET
 Endif
Endif
Return
######################################################################################

$RAZDUP
If func AFNC.PARAM("ZAPPSDH",[F:SDH]STOFCY)<>"1"
 [M:SDH1]ZAPPFLG = 1
 Affzo [M:SDH1]ZAPPFLG
Endif
Return






