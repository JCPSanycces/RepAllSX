#<AdxTL>@(#)0.0.0.0 $Revision$ 

$ACTION
  Case ACTION
    When "TRT_DIV" : Gosub TRT_DIV
  Endcase
Return

#------------------------------------------------------------------------------#

$TRT_DIV
  Local Char    WOBJET(GLONAOB), WVCRNUM(GLONVCR), WRPT(GLONARP), WCODAIM(GLONADI),
&               WMSG(255), PATH_FILE(255)
  Local Integer STAT, AUXINT

  WOBJET = PARAM(1)
  If WOBJET=""
    GMESSAGE = mess(1,6050,1)
    GERR = 1 : Return
  Endif

  WVCRNUM = PARAM(2)
  If WVCRNUM=""
    GMESSAGE = mess(2,6050,1)
    GERR = 1 : Return
  Endif

  WRPT = PARAM(3)
  If WRPT=""
    GMESSAGE = mess(3,6050,1)
    GERR = 1 : Return
  Endif

  WCODAIM = PARAM(4)

  Call TEMPON("R") From GESECRAN
  Call GEN_PDF(WOBJET, WVCRNUM, WRPT, WCODAIM, STAT, WMSG)
  If STAT
    GERR = 1 : [V]GMESSAGE = [L]WMSG
  Else
    Case WOBJET
      When "SIH"
        If dim([V]GYWNOMFIC)>0 and [V]GYWNOMFIC<>""
          Gosub SIH
          If [F:BPC]YSENDINVOICE=2
            AUXINT = [F:SIV]YNBRINVSENT
            Call WORKFLOW(1,"YED","","") From AWRK
            Read [F:SIV]SIV0=WVCRNUM
            If fstat : Raz [F:SIV] : Endif
            If [F:SIV]YNBRINVSENT<=AUXINT
              GERR = 1
              [V]GMESSAGE  = mess(8,6050,1) + ".\"
              [V]GMESSAGE += mess(9,6050,1)
            Endif
          Endif
        Endif
    Endcase
  Endif
  Call TEMPOFF From GESECRAN
Return

#------------------------------------------------------------------------------#

Subprog GEN_PDF(WOBJET, WVCRNUM, WRPT, WCODAIM, STAT, WMSG)
Value    Char    WOBJET
Value    Char    WVCRNUM
Value    Char    WRPT
Value    Char    WCODAIM
Variable Integer STAT
Variable Char    WMSG

  Local Char    WFONCTION(GLONAFC), TBPAR(10)(1..100), TBVAL(30)(1..100),
&               AUXCHAR(250), WPARAM(50), WSUFIX(3), WVOL(GLONAVL), WNAMVOL(255),
&               PATH_FILE(255)
  Local Integer I, J, WTYP
  Local Date    WDAT

  If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif
  If clalev([F:ARV])=0 : Local File AREPORTV [ARV] : Endif
  If clalev([F:ARD])=0 : Local File AREPORTD [ARD] : Endif
  If clalev([F:ATY])=0 : Local File ATYPE    [ATY] : Endif
  If clalev([F:AVL])=0 : Local File AVOLUME  [AVL] : Endif
  If clalev([F:AOX])=0 : Local File AOBJTXT  [AOX] : Endif


  WFONCTION = "YSENDPDF"
  Raz STAT
  Case WOBJET
    When "SIH"   : Gosub SIH
    When Default : STAT = 1 : WMSG = mess(5,6050,1) - WOBJET
  Endcase
  If STAT : End : Endif

  If WCODAIM=""
    Filter [F:AIM] Where PRT=4 and PRTFMT=29 and ENAFLG=2
    Read [F:AIM]AIM0 First
    Filter [F:AIM]
    WCODAIM = [F:AIM]COD
    If WCODAIM=""
      STAT = 1 : WMSG = mess(6,6050,1)
    Endif
  Endif

  Raz I
  Filter [F:ARV] Where FONCTION=WFONCTION and TYPCOD=1 and ETAT=WRPT
  For [F:ARV]ARV0
    Read [F:ARD]ARD1=[F:ARV]PARAM;[F:ARV]ETAT
    If !fstat
      WPARAM = [F:ARD]PARCOD
      I += 1
      Read [F:ATY]CODTYP=[F:ARD]PARTYP
      If fstat : Raz [F:ATY] : Endif
      WYPT = [F:ATY]TYPTYP
      Call EVALE([F:ARV]VALDEF1, AUXCHAR, WYPT) From AIMP1
      Gosub ADD_PAR
      If find(tolower(right$(WPARAM, len(WPARAM)-2)), "deb", "str") and [F:ARD]PARSTREND=2
        I += 1
        AUXCHAR = ""
        Case right$(WPARAM,len(WPARAM)-2)
          When "deb" : SUFIX = "fin"
          When "str" : SUFIX = "end"
          When "DEB" : SUFIX = "FIN"
          When "STR" : SUFIX = "END"
        Endcase
        WPARAM = left$(WPARAM, len(WPARAM)-3) + SUFIX
        Call EVALE([F:ARV]VALDEF2, AUXCHAR, WYPT) From AIMP1
        Gosub ADD_PAR
      Endif
    Endif
  Next
  Filter [F:ARV]

  If dim([V]GYWNOMFIC)>0 : Kill [V]GYWNOMFIC : Endif
  Global Char GYWNOMFIC(255)
  [V]GYWNOMFIC = func AFNC.PARAM("YPATHPDF", "")
  If [V]GYWNOMFIC<>""
    If right$([V]GYWNOMFIC, len([V]GYWNOMFIC))<>"\"
      [V]GYWNOMFIC += "\"
    Endif
  Else
    [V]GYWNOMFIC = filpath("tmp", "", "") + "\"
  Endif
  [V]GYWNOMFIC += PATH_FILE

  #Call EFFACE([V]GYWNOMFIC, I) From ORDSYS
  Call BORRAR([V]GYWNOMFIC, I)
  Call ETAT(WRPT, WCODAIM, GLANGUE, 0, "", TBPAR, TBVAL) From AIMP3

  Raz I, J
  Repeat
    I = func CHECK_FILE([V]GYWNOMFIC)
    If I>0 : Break : Endif
    Sleep 1
    J += 1
  Until J=10
  If I=0
    STAT = 1 : WMSG = mess(7,6050,1)
  Endif

  If !STAT
    Gosub INSERT_ADJ
  Endif
End

#------------------------------------------------------------------------------#

$ADD_PAR
  Case WYPT
    When 1
      If val(AUXCHAR)=0
        AUXCHAR = "1"
      Endif
    When 2,3,4,5,6
      If AUXCHAR=""
        AUXCHAR = "0"
      Endif
    When 8
      WDAT = gdat$(left$(AUXCHAR + "00000000", 8))
      If WDAT=[0/0/0] : WDAT += 1 : Endif
      AUXCHAR = format$("D:YYYYMMDD", WDAT)
  Endcase
  TBPAR(I) = WPARAM : TBVAL(I) = AUXCHAR
Return

#------------------------------------------------------------------------------#

$INSERT_ADJ
  WVOL = func AFNC.PARAM("YVOLJOINT", "")
  If WVOL="" : Return : Endif
  Read [F:AVL]CODE=WVOL
  If fstat : Return : Endif

  Case WOBJET
    When "SIH" : WNAMVOL = [F:SIV]CPY + "/"
  Endcase
  WNAMVOL += func GET_FILENAME([V]GYWNOMFIC)
  AUXCHAR = func ASYRSTO.GETFULLPATH(WVOL, WNAMVOL)
  #Call COPIE([V]GYWNOMFIC, AUXCHAR, I) From ORDSYS
  Call COPIAR([V]GYWNOMFIC, AUXCHAR, I)
  WNAMVOL = "[" + WVOL + "]/" + WNAMVOL
  Trbegin [F:AOX]
  Filter [F:AOX] Where ABREV=WOBJET and IDENT1=WVCRNUM and pat(NAM,"*" + WVCRNUM + "*")
  Read [F:AOX]AOX0 First
  If fstat
    Filter [F:AOX] Where ABREV=WOBJET and IDENT1=WVCRNUM
    Read [F:AOX]AOX0 Last
    If fstat
      Raz [F:AOX]
      [F:AOX]ABREV = WOBJET
      [F:AOX]IDENT1 = WVCRNUM
    Endif
    [F:AOX]IDENT3 = format$("N0:3#", val([F:AOX]IDENT3)+1)
    [F:AOX]CAT = 1
    [F:AOX]NAM = WNAMVOL
    [F:AOX]TYPDOC = "PDF"

    Write [F:AOX]
  Else
    [F:AOX]CAT = 1
    [F:AOX]NAM = WNAMVOL
    [F:AOX]TYPDOC = "PDF"

    Rewrite [F:AOX]
  Endif
  Filter [F:AOX]
  If fstat
    Rollback
  Else
    Commit
  Endif
Return

#------------------------------------------------------------------------------#

$SIH
  If clalev([F:SIV])=0 : Local File SINVOICEV  [SIV] : Endif
  If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
  If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif

  If [F:SIV]NUM<>WVCRNUM
    Read [F:SIV]SIV0=WVCRNUM
    If fstat
      WMSG = WVCRNUM + ":" - mess(23,100,1)
      STAT = 1 : Return
    Endif
  Endif
  If [F:BPR]BPRNUM<>[F:SIV]BPCINV
    Read [F:BPR]BPR0=[F:SIV]BPCINV
    If fstat : Raz [F:BPR] : Endif
  Endif
  If [F:BPC]BPCNUM<>[F:SIV]BPCINV
    Read [F:BPC]BPC0=[F:SIV]BPCINV
    If fstat : Raz [F:BPC] : Endif
  Endif

  PATH_FILE = toupper([F:SIV]NUM)
  If [F:BPR]BPRNAM<>""
    PATH_FILE +=  "_" + func REMOVE_FILENAME_CHARS([F:BPR]BPRNAM, "")
    If right$(PATH_FILE, len(PATH_FILE))<>"."
      PATH_FILE += "."
    Endif
    PATH_FILE += "pdf"
  Endif
Return

#------------------------------------------------------------------------------#
# MS-DOS mode (no sandbox)
Funprog CHECK_FILE(PATH_FILE)
Value    Char    PATH_FILE

  Local Char    ORDSYS(255), WFILE(90)
  Local Integer I, COUNT
  #
  Raz COUNT
  ORDSYS = 'dir /a:-d /b "' + PATH_FILE + '"'  # Excluir los directorios
  Call SYSTEME2(adxmac(0), ORDSYS, "", I, WFILE) From ORDSYS
  If pat(PATH_FILE, "*" + WFILE + "*")
    COUNT = 1
  Else
    COUNT = 0
  Endif
  #
End COUNT

#------------------------------------------------------------------------------#

Funprog REMOVE_FILENAME_CHARS(WNOMDIR,WREPLACE)
Value Char    WNOMDIR
Value Char    WREPLACE
Local Char    WCHAR(255), SPE_CHAR(20)
Local Integer I
  SPE_CHAR = '\/:*?"<>|'
  WCHAR = WNOMDIR
  WCHAR = ctrans(WCHAR)
  For I=1 To len(SPE_CHAR)
    WCHAR = ctrans(WCHAR, mid$(SPE_CHAR,I,1), WREPLACE)
  Next I
End WCHAR

#------------------------------------------------------------------------------#

Funprog GET_FILENAME(WFILE)
Value Char    WFILE()
Local Char    WFILENAME(250)
Local Integer I

  For I=len(WFILE) To 1 Step -1
    If mid$(WFILE, I, 1)="/" or mid$(WFILE, I, 1)="\"
      WFILENAME = right$(WFILE, I+1)
      Break
    Endif
  Next I
End WFILENAME

#------------------------------------------------------------------------------#
# MS-DOS mode (no sandbox)
Subprog COPIAR(FICORI, FICDES, STAT)
Value    Char    FICORI
Value    Char    FICDES
Variable Integer STAT

Local    Char    ORDSYS(255)

  ORDSYS = 'COPY "' + FICORI + '" "' + FICDES + '"'
  Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
  Call EXISTE(FICDES, STAT) From ORDSYS
  If STAT=1 : STAT = 0 : Endif
End

#------------------------------------------------------------------------------#
# MS-DOS mode (no sandbox)
Subprog BORRAR(FICHERO, STAT)
Value Char       FICHERO
Variable Integer STAT

Local    Char    ORDSYS(255)

  ORDSYS = 'DEL /Q "' + FICHERO + '"'
  Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
End

