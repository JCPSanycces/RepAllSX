#<AdxTL>@(#)0.0.0.0 $Revision$
#ACV#X12
#TIT#Gestion de l'objet X75 (Clôture périodes X3S)

#==========================================================================================
# Gestion de l'objet   : Gestion spécifiques de l'objet X75 (Clôture périodes X3S)
# Auteur               : Laurent Bornes
# Date de création     : 08/10/2012
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

GBIDC1=""
GBIDC2=""
GFONC1="GESX75"
GFLAG="#"
Call OBJET("X75",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet X75
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "OUVRE_BOITE" : Gosub OUVRE_BOITE From SPVOBJX75
  When "FILGAUCHE"   : Gosub FILGAUCHE   From SPVOBJX75
  When "LIENS"       : Gosub LIENS       From SPVOBJX75
Endcase

Return

######################################################################################
Subprog AM_USR(VALEUR)
Variable Char    VALEUR()

Look [F:X75]X751(2)=[M:XPE1]TYP;VALEUR
If fstat
  Effzo [M:XPE1]10-99
Else
  [M:XPE1]USR=VALEUR
  Gosub LIENS From SPVOBJX75
  Affzo [M:XPE1]NBLIG
Endif

End
