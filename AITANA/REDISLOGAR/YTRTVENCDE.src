#####################################################################################
# CodAct: YA039 - Campos específicos
#####################################################################################

$ACTION

Case ACTION
  When "ALISQDSOH"  : Gosub ALISQDSOH
  When "ALISQHSOH"  : Gosub ALISQHSOH

Endcase

Return

$ALISQDSOH
  If [F:SQD]DDEMDLVDAT<>[0/0/0]
    [M:SOH4]DDEMDLVDAT(NOL) = [F:SQD]DDEMDLVDAT
  Endif

Return

$ALISQHSOH
  If [F:SQH]DEMDLVDAT <> [0/0/0]
    [M:SOH2]DEMDLVDAT = [F:SQH]DEMDLVDAT
  Endif
######YA032 - Tratamiento de la cabecera traspasable ########

  If [M:SOH0]YSOHTEX<>"" | [F:SQH]YSQHTEX <> ""
   [M:SOH0]YSOHTEX = [F:SQH]YSQHTEX
   [F:SOH]YSOHTEX = [M:SOH0]YSOHTEX
  Endif
#############################################################
Return

