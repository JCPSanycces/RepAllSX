########################################
Subprog D_UNTPRI(VALEUR)
Variable Decimal VALEUR

# Attention, appel aussi à partir du Trt XIMPREQ2

Local Integer NBREM, I, NOL
Local Char ACTION

[L]NOL=nolign-1

If !clalev([F:ACV]) : Local File ACTIV : Endif
Call LECTURE("ACV","SPR","") From CONTOBJ
If [F:ACV]FLACT=2
  [L]NBREM=[F:ACV]DIME
Endif

Gosub INIT_PARAM From SPVOBJFNE
[L]DEVISE=[M:FNE1]CURINV(nolign-1)
[L]CURTYP=1
Call RECH_PRIX([L]PARAMC,[L]PARAMD,[L]PRIX,[L]REMISE,[L]DEVISE,[L]CURTYP,1) From SPVOBJITV2

# Actions spécifiques : renseigner las variables PRIX et REMISE() en se servant de la devise de calcul DEVISE
GPOINT="D_UNTPRI" : Gosub ENTREE From EXEFNC

VALEUR=[L]PRIX

# Répartition des remises
For [L]I=1 To [L]NBREM
  Assign "[M:FNE1]DISCRGVAL"+num$([L]I)+"([L]NOL)" With [L]REMISE([L]I-1)
  If ![V]GIMPORT
    Affzo ="[M:FNE1]DISCRGVAL"+num$([L]I)+"([L]NOL)"
  Endif
Next

End

########################################
Subprog D_PRIPUR(VALEUR)
Variable Decimal VALEUR

# Attention, appel aussi à partir du Trt XIMPREQ2

Local Char ZCODEXP
[L]ZCODEXP=func SPVOBJITL.CODEXP_FRAIS([M:FNE1]CODOPE(nolign-1),[M:FNE1]AUTINTTYP(nolign-1))
If [L]ZCODEXP<>""
  Case [M:FNE1]OPETYP(nolign-1)
    When 1 : Call INIT_FRAIS([F:REQ]FCY, [L]ZCODEXP, [M]ASSPRD(nolign-1), [M]CURPUR(nolign-1), [M]QTY(nolign-1), VALEUR) From SPVOBJITL
    When 2 : Call INIT_FRAIS([F:REQ]FCY, [L]ZCODEXP, [M]ASSINT(nolign-1), [M]CURPUR(nolign-1), [M]QTY(nolign-1), VALEUR) From SPVOBJITL
    When 3 : Call INIT_FRAIS([F:REQ]FCY, [L]ZCODEXP, [M]RESCOD(nolign-1), [M]CURPUR(nolign-1), [M]QTY(nolign-1), VALEUR) From SPVOBJITL
  Endcase
  If VALEUR<>0 : End : Endif
Endif

Local Integer NBREM, I, NOL
Local Char ACTION

[L]NOL=nolign-1

# Récupération du nb de remises
If !clalev([F:ACV]) : Local File ACTIV : Endif
Call LECTURE("ACV","PPR","") From CONTOBJ
If [F:ACV]FLACT=2
  [L]NBREM=[F:ACV]DIME
Endif

Gosub INIT_PARAM From SPVOBJFNE
[L]DEVISE=[M:FNE1]CURPUR(nolign-1)
[L]CURTYP=1
Call RECH_PRIX([L]PARAMC,[L]PARAMD,[L]PRIX,[L]REMISE,[L]DEVISE,[L]CURTYP,2) From SPVOBJITV2

# Actions spécifiques : renseigner las variables PRIX et REMISE() en se servant de la devise de calcul DEVISE
GPOINT="D_PRIPUR" : Gosub ENTREE From EXEFNC

VALEUR=[L]PRIX

# Répartition des remises
For [L]I=1 To [L]NBREM
  Assign "[M:FNE1]DISPUR"+num$([L]I)+"([L]NOL)" With [L]REMISE([L]I-1)
  If ![V]GIMPORT
    Affzo ="[M:FNE1]DISPUR"+num$([L]I)+"([L]NOL)"
  Endif
Next

End

######################################################################################
Subprog AV_CPRPRI(VALEUR)
Variable Decimal VALEUR

If GREP<>"M" & !GIMPORT : End : Endif

# Attention, appel aussi à partir du Trt XIMPREQ2

Raz VALEUR

Local Decimal DISPUR(9), DISCRGVAL(9), NBDAY, ITVLEN
Local Integer I

Raz [L]NBDAY, [L]ITVLEN
If [M:FNE1]UOM(nolign-1)=[V]XUOMHOU
  [L]ITVLEN=[M:FNE1]QTY(nolign-1)
Elsif [M:FNE1]UOM(nolign-1)=[V]XUOMDAY
  [L]NBDAY=[M:FNE1]QTY(nolign-1)
Endif

For [L]I=1 To 9
  If evalue("dim([M:FNE1]DISCRGVAL"+num$([L]I)+")")>0
    [L]DISCRGVAL([L]I-1)=evalue("[M:FNE1]DISCRGVAL"+num$([L]I)+"(nolign-1)")
  Endif
  If evalue("dim([M:FNE1]DISPUR"+num$([L]I)+")")>0
    [L]DISPUR([L]I-1)=evalue("[M:FNE1]DISPUR"+num$([L]I)+"(nolign-1)")
  Endif
Next

Call CAL_CPRPRI(VALEUR,[M:FNE1]CODOPE(nolign-1),[M:FNE1]AUTINTTYP(nolign-1),[M:FNE1]ASSPRD(nolign-1),[F:REQ]FCY,datesyst
&             ,[M:FNE1]BEGDAT(nolign-1),"",[M:FNE1]CURINV(nolign-1),[M:FNE1]CATPRIINT(nolign-1),[M:FNE1]ASSINT(nolign-1)
&             ,[M:FNE1]CATPRIRES(nolign-1),[M:FNE1]RESCOD(nolign-1),[M:FNE1]PRIPUR(nolign-1)
&             ,[L]DISPUR,[M:FNE1]UNTPRI(nolign-1),[L]DISCRGVAL,[L]NBDAY,[L]ITVLEN,[M:FNE1]QTY(nolign-1)
&             ,[M:FNE1]UOM(nolign-1)) From SPVOBJFNE

End

