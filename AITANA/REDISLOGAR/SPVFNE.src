#<AdxTL>@(#)0.0.0.0 $Revision$
#ACV#X12
#TIT#Gestion des besoins

TUNNEL=0
Call OBJET("FNE", GBIDC1, GBIDC2) From GOBJET
End

# 25/05/2013    SOUCH        Gestion des classifications pour Planner

$ACTION

# Appel fonctions complémentaires GFI pour l'objet FNE
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Gosub ACTION From SPVOBJFNE

Return

########################################
Subprog AS_REQNUM(VALEUR)
Variable Char    VALEUR()
If [V]GXTUNNEL
   VALEUR=[F:REQ]REQNUM
   [M]REQNUM=VALEUR
   If !GIMPORT
      Affzo REQNUM
      mkstat=2
   Endif
Endif

# Classifications pour Planner
#--------------------------------------
If dim([V]GXOPTAGE)>0 & [V]GXOPTAGE
  Local Integer ZI
  For [L]ZI=0 To [M:FNE1]NBLIG
      Chgstl [M:FNE1]NBLIG([L]ZI) With ""
  Next
  Gosub CHARGE_HIE From SPVOBJFNE
  Raz [M:FNE1]XGRPLIG

  # LBORN 09/08/2013 - Mantis 19587 - Ne pas faire un Affzo des lignes sinon plus d'init sur champs
  # Affzo [M:FNE1]
  Affzo [M:FNE1]15-99

Endif
#--------------------------------------

End

########################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M]BEGDAT(nolign-1)
  mkstat=1
Endif
End

########################################
Subprog IB_NBLIG
Raz [V]GBOUT1, [V]GBOUT5
If [M:FNE1]VALNUM(nolign-1)<>""
  [V]GBOUT1=mess(68,[V]GXMSGPSA,1)
Endif
If [M:FNE1]CMMNUM(nolign-1)<>""
  If !clalev([F:CMM]) : Local File GCOMMIT : Endif
  Read [F:CMM]CMM0=[M:FNE1]CMMNUM(nolign-1)
  If !fstat
    [V]GBOUT5=mess(160,198,1)
  Endif
Endif

Raz [V]GBOUT6
If GREP="" & [M:FNE1]REQNUM<>"" & instr(1,GCHAINE,"M") & [M:FNE1]ITMSCO(nolign-1)<>""
  Read [F:REQ]REQ0=[M:FNE1]REQNUM
  If !fstat & [F:REQ]FLGREQCLO<>2 & [F:REQ]FLGREQCAN<>2
    Local Integer ZTROUV
    Raz [L]ZTROUV
    If !clalev([F:POQ]) : Local File PORDERQ : Endif
    # LBORN 30/09/2013
    # For [F:POQ]XPQ1 Hint Key XPQ1 Where [F:POQ]REQNUM=[M:FNE1]REQNUM
    #&                                     & [F:POQ]BPSNUM=[M:FNE1]BPSNUM(nolign-1)
    #&                                     & [F:POQ]ITMREF=[M:FNE1]ITMSCO(nolign-1)
    # LBORN 28/09/2017 - Mantis 34569
    #For [F:POQ]XPQ1 Hint Key XPQ1 Where [F:POQ]REQNUM=[M:FNE1]REQNUM & [F:POQ]ITMREF=[M:FNE1]ITMSCO(nolign-1)
    #  [L]ZTROUV=1 : Break
    #Next
    For [F:POQ]XPQ1 Hint Key XPQ1 Where [F:POQ]REQNUM=[M:FNE1]REQNUM & ([F:POQ]FNELIG=[M:FNE1]FNELIG(nolign-1) | [F:POQ]FNELIG=0) & [F:POQ]ITMREF=[M:FNE1]ITMSCO(nolign-1)
      [L]ZTROUV=1 : Break
    Next
    GPOINT="FILTRE_POQ" : Gosub ENTREE From EXEFNC

    If ![L]ZTROUV
      [V]GBOUT6=mess(363,198,1)
    Endif
  Endif
Endif

# LBORN 18/09/2017
If [M:FNE1]ASSPRD(nolign-1)=""
  Raz [V]GBOUT7, [V]GBOUT8
Endif

End

########################################
Subprog C_UOM(VALEUR)
Variable Char VALEUR
If !clalev([F:OPE]) : Local File OPERATION : Endif
Read [F:OPE]OPE0=[M]CODOPE(nolign-1)
If !fstat & find([F:OPE]OPETYP,2,3)
  Local File TABUNIT
  Filter [TUN] Where find([TUN]UOMTYP,5,7)
  Call CONTROLE("TUN","",VALEUR,"",mkstat) From CONTOBJ
  Filter [TUN]
Endif
End

########################################
Subprog C_BEGDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
  If !clalev([F:ACV]) : Local File ACTIV : Endif
  Read [F:ACV]CODACT="X13"
  If !fstat & [F:ACV]FLACT=2
    If !clalev([F:OPE]) : Local File OPERATION : Endif
    Read [F:OPE]OPE0=[M]CODOPE(nolign-1)
    If !fstat & find([F:OPE]OPETYP,2,3) & dim([F:OPE]UPDAGE)>0 & [F:OPE]UPDAGE=2
      If !clalev([F:REQ]) : Local File REQUEST : Endif
      Read [F:REQ]REQ0=[M]REQNUM
      If !fstat
        If !clalev([F:PRT]) : Local File PARRQTTYP : Endif
        Read [F:PRT]PRT0=[F:REQ]REQTYP
        If !fstat & dim([F:PRT]UPDAGE)>0 & [F:PRT]UPDAGE=2
          [V]GMESSAGE=mess(10,123,1)
          mkstat=1
        Endif
      Endif
    Endif
  Endif
Else
  If !clalev([F:REQ]) : Local File REQUEST : Endif
  Read [F:REQ]REQ0=[M]REQNUM
  If !fstat & VALEUR<[F:REQ]CREADAT
    [V]GMESSAGE="DS au"-format$("D:DD[/]MM[/]YYYY",[F:REQ]CREADAT)
    mkstat=1
  Elsif [M]VALNUM(nolign-1)<>""
    # A cause Filtre dans XVALGAS2
    Local File VALGAS [YGA]
    Read [F:YGA]VGA1=[M]VALNUM(nolign-1)
    If !fstat & [F:YGA]SITNUM<>""
      If !clalev([F:XST]) : Local File SITUATION : Endif
      Read [F:XST]XST0=[F:YGA]SITNUM
      If !fstat & VALEUR<[F:XST]CALDAT
        [V]GMESSAGE="Situation au"-format$("D:DD[/]MM[/]YYYY",[F:XST]CALDAT)
        mkstat=1
      Endif
    Endif
  Endif
Endif
End

########################################
Subprog D_BEGDAT(VALEUR)
Variable Date    VALEUR
VALEUR=datesyst
End

########################################
Subprog C_REQNUM(VALEUR)
Variable Char    VALEUR()

Local Char SYMBREQ(50)

Read [F:FNE]FNE0(1)=VALEUR
If fstat
  # Création / Duplication
  Read [F:REQ]REQ0=VALEUR
  If !fstat
    If [F:REQ]FLGREQCLO=2
      [V]GMESSAGE="DS clôturée\Création impossible"
      mkstat=1
    Elsif [F:REQ]FLGREQCAN=2
      [V]GMESSAGE="DS annulée\Création impossible"
      mkstat=1
    Else
      [L]SYMBREQ="REQ"+[F:REQ]REQNUM
      Lock =[L]SYMBREQ With lockwait=0
      If fstat
        [V]GMESSAGE="DS"-VALEUR+"\"+mess(10,100,1)+"\Création impossible"
        mkstat=1
      Endif
    Endif
    If mkstat
      VALEUR=[M:FNE1]REQNUM
    Endif
  Endif
Endif

If !mkstat
  Gosub CHARG_PARAM From SPVOBJFNE
Endif

End

########################################
Subprog AS_BEGHOU(VALEUR)
Variable Char    VALEUR()
If [M:FNE1]BEGDAT(nolign-1)=[0/0/0]
  mkstat=1
Endif
End

########################################
Subprog C_BEGHOU(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,".")
  mkstat=1
Endif
End

########################################
Subprog AS_ENDHOU(VALEUR)
Variable Char    VALEUR()
If [M:FNE1]ENDDAT(nolign-1)=[0/0/0]
  mkstat=1
Endif
End

########################################
Subprog C_ENDHOU(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,".")
&     | (val(VALEUR)<val([M:FNE1]BEGHOU(nolign-1)) & val([M:FNE1]BEGHOU(nolign-1))<>0 & [M:FNE1]BEGDAT(nolign-1)<>[0/0/0]
&     & [M:FNE1]BEGDAT(nolign-1)=[M:FNE1]ENDDAT(nolign-1))
  mkstat=1
Endif
End

