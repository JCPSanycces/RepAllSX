######################################################################################
Subprog IB_XNBGRP
Local Char XGBOUT5
Local Char XGBOUT7

# LBORN 12/07/2017 - Mantis 34363
# [L]XGBOUT5 = GBOUT5
# [L]XGBOUT7 = GBOUT7
[L]XGBOUT5=mess(39,147,1)             : # Ajouter
[L]XGBOUT7=mess(145,[V]GXMSGPSA(1),1) : # Enlever

If [M:FNE1]XGRPLIG=0
  Raz GBOUT5
  Raz GBOUT7
Else
  GBOUT5 = [L]XGBOUT5
  GBOUT7 = [L]XGBOUT7
Endif

End

######################################################################################
Subprog AS_ASSINT(VALEUR)
Variable Char    VALEUR()
#SOUCH 10/10/2013 M21268
If VALEUR<>"" & GREP="M" & GXOPTAGE=1 & GXAPPNAMPLA<>""
    mkstat=2
Endif
End

######################################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR

# LBORN 26/07/2017
If GXOPTAGE

  #M32225 11/05/2016 09:48:09 (SOUCH)
  #------
  If [F:REQ]OPPNUM="" & [M:FNE1]XKEYPLA(nolign-1)<>""
    Local Integer I,S
    For [L]I=0 To [M:FNE1]NBLIG-1
      If [L]I<>nolign-1 & [M:FNE1]CODOPE([L]I)=[M:FNE1]CODOPE(nolign-1) & [M:FNE1]XKEYPLA([L]I)<>""
        [L]S=1
        Break
      Endif
    Next
    If [L]S=1
      [M:FNE1]QTYAREA(nolign-1) += VALEUR-[M:FNE1]QTY(nolign-1)
    Else
      [M:FNE1]QTYAREA(nolign-1)=VALEUR
    Endif
  Endif

Endif

End

######################################################################################
Subprog AS_QTY(VALEUR)
Variable Decimal VALEUR

# LBORN 26/07/2017
If GXOPTAGE

  #M32225 18/05/2016 09:54:11 (SOUCH)
  #------
  Local Integer I,S
  For [L]I=0 To [M:FNE1]NBLIG-1
    If [L]I<>nolign-1 & [M:FNE1]CODOPE([L]I)=[M:FNE1]CODOPE(nolign-1) & [M:FNE1]XKEYPLA([L]I)<>""
      [L]S=1
      Break
    Endif
  Next
  If [M:FNE1]XKEYPLA(nolign-1)<>"" & [M:FNE1]QTY(nolign-1)=0 & [L]S=1
    mkstat=2
  Endif

Endif

End

######################################################################################
# LBORN 18/09/2017
######################################################################################
Subprog IB_QTY
If [M:FNE1]ASSPRD(nolign-1)=""
  Raz [V]GBOUT5, [V]GBOUT6
Endif
End

