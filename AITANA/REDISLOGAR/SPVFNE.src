######################################################################################
Subprog AS_NBLIG

# Controler code activité X13 actif
If dim([V]GXOPTAGE)>0 & [V]GXOPTAGE
  [M:FNE1]XGRPLIG = nolign
  Local Char XGRPU(250)
  [L]XGRPU = [M:FNE1]XGRPUTIL(nolign-1)
  Raz [M:FNE1]XNBGRP
  Gosub CHARGE_HIE From SPVOBJOPR

  # LBORN 09/08/2013 - Mantis 19587 - Ne pas faire un Affzo des lignes sinon plus d'init sur champs
  # Affzo [M:FNE1]
  Affzo [M:FNE1]15-99

  If [M:FNE1]CODOPE(nolign-1)="" | [M:FNE1]OPETYP(nolign-1)=1
    Raz [M:FNE1]XGRPLIG
  Endif
  # Surbrillance de la ligne
  Local Integer ZI
  For [L]ZI=0 To [M:FNE1]NBLIG
    If [L]ZI<>nolign-1 | [M:FNE1]NBLIG=0
      Chgstl [M:FNE1]NBLIG([L]ZI) With ""
    Else
      Chgstl [M:FNE1]NBLIG([L]ZI) With "AMKCUR"
    Endif
  Next
Endif

End

