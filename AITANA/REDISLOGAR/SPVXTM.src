#<AdxTL>@(#)12.0.0.0 $Revision$
#ACV#X11
#TIT#Gestion de l'objet XTM (Paramètres type de machine)

#==========================================================================================
# Gestion de l'objet   : Gestion de l'objet XTM (Paramètres type de machine)
#                        
# Auteur               : Laurent Bornes
# Date de création     : 03/08/2011      
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
#==========================================================================================

GBIDC1=""
GBIDC2=""
GFONC1="TYPMAC"
Call OBJET("XTM",GBIDC1,GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires GFI pour l'objet PPT
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "OUVRE"     : Gosub OUVRE     From SPVOBJXTM
  When "INICRE"    : Gosub INICRE    From SPVOBJXTM
  When "INIMOD"    : Gosub INIMOD    From SPVOBJXTM
  When "CHANGE"    : Gosub CHANGE    From SPVOBJXTM
  When "ANNULE"    : Gosub ANNULE    From SPVOBJXTM
  When "MODIF"     : Gosub MODIF     From SPVOBJXTM
  When "CREATION"  : Gosub CREATION  From SPVOBJXTM
  When "LIENS"     : Gosub LIENS     From SPVOBJXTM
  When "RAZCRE"    : Gosub RAZCRE    From SPVOBJXTM
Endcase

Return

#==========================================================================================
Subprog AS_NBLIG

If status<>71 & find(GREP,"C","D") : End : Endif

Local Integer ZLIG, ZI

[L]ZLIG=nolign-1

If [L]ZLIG<=[M:XTM2]NBLIG-1
  Effzo [M:XTM2]10
  Gosub AFFECT_XTM From SPVOBJXTM
  Affzo [M:XTM2]10
Endif

nolign=[L]ZLIG+1

Affzo [M:XTM2]STATITM

End

#==========================================================================================
Subprog AM_XFLGSTA(VALEUR)
Variable Integer VALEUR
[M:XTM2]FLGSTA([M:XTM2]XNUMLIG-1)=VALEUR
End

#==========================================================================================
Subprog AM_XFLGMAC(VALEUR)
Variable Integer VALEUR
[M:XTM2]FLGMAC([M:XTM2]XNUMLIG-1)=VALEUR
End

#==========================================================================================
Subprog AM_XFLGUTI(VALEUR)
Variable Integer VALEUR
[M:XTM2]FLGUTI([M:XTM2]XNUMLIG-1)=VALEUR
End

#==========================================================================================
Subprog AM_XFLGEMP(VALEUR)
Variable Integer VALEUR
[M:XTM2]FLGEMP([M:XTM2]XNUMLIG-1)=VALEUR
End

#==========================================================================================
Subprog AV_VGADIFTEM(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=2 : Endif
End

#==========================================================================================
Subprog AV_VGADIFQUA(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=2 : Endif
End

#==========================================================================================
Subprog AV_STATITM(VALEUR)
Variable Char    VALEUR()
Local Integer ZI
For [L]ZI=1 To [M:XTM2]NBLIG+1
  If [L]ZI<>[M:XTM2]XNUMLIG
    Chgstl [M:XTM2]NBLIG([L]ZI-1) With ""
  Else
    Chgstl [M:XTM2]NBLIG([L]ZI-1) With "AMKCUR"
  Endif
Next
End

#==========================================================================================
Subprog AV_XFLGSTA(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=2 : Endif
End

#==========================================================================================
Subprog AV_XFLGMAC(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=2 : Endif
End

#==========================================================================================
Subprog AV_XFLGUTI(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=2 : Endif
End

#==========================================================================================
Subprog AV_XFLGEMP(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=2 : Endif
End

