#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque VGHTRF
#ACV#X11
#TIT#Gestion de la table VALGASHIS

GBIDC1=""
GBIDC2=""
Call OBJET("VGH",[V]GBIDC1,[V]GBIDC2) From GOBJET
End


$ACTION
    # Appel fonctions complémentaires GFI pour l'objet VGH
    Gosub ACTION From XOBJSPE
    If GPE=1 : Return : Endif

    Case ACTION
        When "OUVRE"       : Gosub OUVRE        From SPVOBJVGH
    Endcase

Return

########################################
Subprog AP_TSCODVAL(VALEUR)
    Variable Integer VALEUR
End

########################################
Subprog C_CODVALBEG(VALEUR)
    Variable Char    VALEUR()
End

########################################
Subprog AP_TSSITE(VALEUR)
    Variable Integer VALEUR
End

########################################
Subprog D_FCYBEG(VALEUR)
    Variable Char    VALEUR()
End

########################################
Subprog C_FCYBEG(VALEUR)
    Variable Char    VALEUR()
End

########################################
Subprog AV_PCEDATEND(VALEUR)
    Variable Date    VALEUR
End

########################################
Subprog AV_INITZON(VALEUR)
    Variable Decimal VALEUR
End

