#TIT#Zoom sur qtés situations

GBIDC1=""
GBIDC2=""
Call OBJET("OPP",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When Default
Endcase
Return

########################################
Subprog AV_CALDAT(VALEUR)
Variable Date    VALEUR
If [M:DIA]CALDAT(nolign-1)>[M:DIA]DATREF | ([M:DIA]CALDAT(nolign-1)=[M:DIA]DATREF & [M:DIA]SITNUM(NOLIGN-1)>=[M:DIA]SITREF)
  pcolor=GCOUL(1)
Else
  pcolor=GCOUL(0)
Endif
End
