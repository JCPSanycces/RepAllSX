#<AdxTL>@(#)0.0.0.0 $Revision$ 
#####################################################################################
# CODACT: YA041 - Cambio automatico estado parque cliente JEL
#####################################################################################
$ACTION
Case ACTION
  When "MAJPNHEND"       : Gosub MAJPNHEND
Endcase
Return
#####################################################################################

$MAJPNHEND
  Local Char RETTYP : Raz RETTYP
  Local Integer ERRORNUMSER
  #abrimos las tablas
#  If !clalev ([ZPNH]) : Local File PRETURN [ZPNH] : Endif
#  If !clalev ([ZPND]) : Local File PRETURND [ZPND] : Endif
  [L]RETTYP = [F:PNH]PNHTYP
  If [F:PNH]PNHTYP = "FAB"
    Filter [F:PND] Where [F:PND]PNHNUM = [F:PND]PNHNUM
    For [PND]
      Filter [F:STJ] Where [F:STJ]VCRNUM = [PNH]PNHNUM & [F:STJ]VCRLIN = [PND]PNDLIN
&                        & [F:STJ]TRSTYP = 11 & [F:STJ]UPDCOD = 2
      For [STJ]
        If !clalev ([ZITM]) : Local File ITMMASTER [ZITM] : Endif
        Read [F:ZITM]ITM0 = [F:STJ]ITMREF
        If fstat = 0
          If [F:ZITM]CREMAC = 2
            If [STJ]SERNUM <>''
              If !clalev ([ZMAC]) : Local File MACHINES [ZMAC] : Endif
              Read [ZMAC]MAC5 = [STJ]ITMREF;[STJ]SERNUM
              If fstat = 0
			  #cambiamos el campo estado de la pantalla MAC1
                If !clalev ([ZXMA]) : Local File MACHINEFL [ZXMA] : Endif
                Trbegin [ZXMA]
                Readlock [ZXMA]XMA0 = [ZMAC]MACNUM
                If fstat=0
                  [F:ZXMA]STATITM = "FAB"
                  Rewrite [ZXMA]
                  Commit
				#encontramos MAC, rellenamos la tabla YHISSTAMAC
				If !clalev ([YHSM]) : Local File YHISSTAMAC [YHSM] : Endif
                #añadimos los datos a la tabla
                  Read [YHSM]YHSM0(1)= [ZMAC]MACNUM
                  Read [YHSM] Last
                  [YHSM]LINNUM +=1000
                  [YHSM]BPRNUM = num$([F:PNH]BPSNUM)
                  [YHSM]YCAMSTADAT = date$
                  [YHSM]MACNUM = [ZMAC]MACNUM
				  [YHSM]STATITM = [ZXMA]STATITM
                #grabamos la tabla
                  Trbegin [YHSM]
                  Write [YHSM]
                  If fstat
                    Rollback
                  Else
                    Commit
                  Endif
              
              Endif
                  Unlock [ZXMA]
                Else
                  Rollback
                Endif
              
            Else
              #error, damos mensaje diciendo que el articulo no tiene numero de serie
              ERRORNUMSER = 1
            Endif
          Endif
        Endif
      Next
      Filter[STJ]
    Next
    Filter [PND]
    If ERRORNUMSER = 1
      #mostramnos el mensaje
      GERR = 2
      GMESSAGE = "Algún articulo no tiene numero de serie y no se pudo añadir histórico de parque" : Return
    Endif
  Endif
GPE=1
Return



