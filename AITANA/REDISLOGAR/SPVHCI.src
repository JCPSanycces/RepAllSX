#<AdxTL>@(#)9.0.0.0 $Revision$
#ACV#X12
#TIT#Gestion historique cout intervenants
#Othyr 08/2002 : ajout des actions PSG


Call OBJET("HCI",GBIDC1,GBIDC2)From GOBJET
End

#################################################
$ACTION
Case ACTION
    When "OUVRE"   : Gosub OUVRE   From SPVOBJHCI
    When "FERME"   : Gosub FERME   From SPVOBJHCI
Endcase
Return

######################################################
Subprog C_UOM(VALEUR)
Variable Char VALEUR
Local Integer I,POS
Local Char SITE

[L]SITE = [M:HCI0]FCY(nolign-1)
[L]POS  = nolign-1

For I = 0 To [M:HCI0]NBLIG-1
    If [M:HCI0]FCY(I) = [L]SITE & [L]POS<>I & VALEUR = [M]UOM(I) Then
        If ([M:HCI0]DATBEG([L]POS)<=[M:HCI0]DATBEG(I) & [M:HCI0]DATEND([L]POS)>=[M:HCI0]DATBEG(I))
&    | ([M:HCI0]DATBEG([L]POS)>=[M:HCI0]DATBEG(I) & [M:HCI0]DATEND([L]POS)<=[M:HCI0]DATEND(I))
&    | ([M:HCI0]DATBEG([L]POS)<=[M:HCI0]DATEND(I) & [M:HCI0]DATEND([L]POS)>=[M:HCI0]DATEND(I)) Then
            [V]GMESSAGE = mess(155,[V]GXMSGPSA,1)-num$(I+1)
            mkstat = 2
            Break 1
        Endif
    Endif
Next I

End

######################################################################################
Subprog C_FCY(VALEUR)
Variable Char VALEUR

If [M:HCI0]CUR(nolign-1)="" | VALEUR<>[M:HCI0]FCY(nolign-1)
  If VALEUR<>""
    Call GETDEV(VALEUR) From DEVSUB
    [M:HCI0]CUR(nolign-1) = [V]GLOCALDEV

    If ![V]GIMPORT Then
      Affzo [M]CUR 
    Endif
  Else
    [M:HCI0]CUR(nolign-1)=GSYSCUR
  Endif
Endif

End
