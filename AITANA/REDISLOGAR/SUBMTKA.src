#<AdxTL>@(#)0.0.0.0 $Revision$ 
#<AdxTL>@(#)7.0.0.0 $Revision$
####################################################################
#Actions du GOBJET pour objet "MTK"
#                                                   sr Novembre 1998
####################################################################
$DEFTRANS
#--------------------------------------------------------#
# Avant lecture des transactions de saisie disponibles : #
# Si GFLAG est renseigné la transaction est déja choisie #
# par le menu. Vérifier si elle est valide               #
#--------------------------------------------------------#
Local Shortint OUVFICFLG

# Issue 82475 - 2018-07-30 by STLIG : from work orders (via bookmark) - save [F:MTS]
If (clalev([F:MTS])<>0 & [F:MTS]MTSNUM<>"")
  If (clalev([F:MTS1])=0)
    Local File MFGTRS [MTS1]
  Endif
  [F:MTS1]=[F:MTS]
Endif

If clalev ([F:MTS])=0 Local File MFGTRS [MTS] : Endif
If GFLAG<>""
  Read [MTS] MTS0=2;GFLAG
  If fstat | [F:MTS]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:MTS]ACSCOD<>"" & GPROFIL<>GSUPER
    If clalev ([F:ACC])=0 Local File ACCES  [ACC] : OUVFICFLG=1 : Endif
    Read [ACC] CODACC=GUSER;[F:MTS]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1 Close File [ACC] : Raz OUVFICFLG : Endif
Return

$VARIANTE
#---------------------------------------#
# Après lecture de chaque transaction : #
# La transaction est-elle valide ?      #
# VARCOD contient le code transaction.  #
# Mettre OK à zéro si non valide.       #
#---------------------------------------#
Read [MTS] MTS0=2;VARCOD
If fstat | [F:MTS]ENAFLG=1 OK=0 : Endif
Return

$SETTRANS
If dim(GSVGWRHOBY)<0 Global Integer GSVGWRHOBY Endif
#-------------------------------------#
# Après sélection de la transaction : #
# GFLAG = code transaction choisie    #
#-------------------------------------#
If clalev ([F:MTS])=0 Local File MFGTRS [MTS] : Endif
Read [MTS] MTS0=2;GFLAG : If fstat Raz [F:MTS] : Endif

#MAE, le 30/01/08, evol GRP_SITE
GGRPFCY = [F:MTS]GFY
# Dépôt entête obligatoire ou non
If GWRHACT=2
  GWRHOBY = [F:MTS]WRHOBY
Else
  GWRHOBY = 1
Endif
GSVGWRHOBY = GWRHOBY

Return

$OUVRE
#--- Lignes suivantes à activer si besoin
If dim(GSVGWRHOBY)<0 Global Integer GSVGWRHOBY Endif
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----

# JAMCC - Nov 22ns 2018
# Re-factored Jira ticket X3-63085
# Jira ticket X3-116485
Global Integer G_RUN_RE_CALCULATE_CPLQTY
# Run subprogram RE_CALCULATE_CPLQTY() -- (2) Yes, (1)No
G_RUN_RE_CALCULATE_CPLQTY = 2 # YES

Local Integer   RETOUR
Global Char     GMTSNUM(GLONTRS) : GMTSNUM = GFLAG
Global Decimal  GTOTQTY
Global Decimal  GQQQQTY
Global Decimal  GRRRQTY
Global Integer  GTITRE
Global Date     GWIPTDAT
Global Shortint GRELITMTK   : # 1 = Pour éxécuter Gosub RELIT après modif mvt stock
Global Shortint GMFGTRACE         : # affichage d'une trace en gestion
Global Integer  GCONSLCT : GCONSLCT = GCONSULT
Global Integer  GUNVERROU
Global Char     GSAVMFGNUM(GLONVCR) # Issue 90462 - 2013-06-13 by CCC
Local  Integer  WPICK
Raz    GRELITMTK
Raz GSOC_ACTIVE

If !clalev([ENTW]) : Local Mask STOENTW [ENTW] : Endif
Raz [M:ENTW]
[M:ENTW]WZONPCU = "UOM"
[M:ENTW]WZONQUC = "UOMCPLQTY"
[M:ENTW]WZONCCS = "UOMSTUCOE"
[M:ENTW]WZONSTU = "STU"
[M:ENTW]WZONQUS = "CPLQTY"
[M:ENTW]WZONSTOUPD = ""

If !clalev([STW]) : Local Mask STOWORK [STW] : Endif
Gosub STK_INILOC From STKLOC
If !clalev([M:VALW]): Local Mask STOVALW   [VALW] : Endif
If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif
Raz [M:VALW]


If !clalev([M:ALP]) :  Local Mask ALLPAR     [ALP]  : Endif
If !clalev([M:SOW]) :  Local Mask STOSORW    [SOW]  : Endif
If !clalev([M:MTMK]):  Local Mask MTMK       [MTMK] : Endif

Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218

# CCC (2010-05-03) Bug 64403 : GMFGCLOSE doit être initialisée au lancement de la fonction
## (LLC) pour la fenêtre sélection OF ou tunnel vers clôture/solde ...
#GMFGCLOSE  = "2"
#
If GMODU(2)=2 : # Si module compta actif
  If !clalev([F:GCM])   Local File GACM       [GCM] : Endif
Endif

Gosub CHARG_PARAM
#Récupération de la valeur du code activité titre
Call LECACT("TIT",GTITRE) From TRTX3
#------------------------------------------------#
#   Choix éventuel de la transaction de saisie   #
# et ouverture des masques écrans correspondants #
#------------------------------------------------#
#----- masque encours
If !clalev([M:ORDK]):  Local Mask ORDK [ORDK] : Endif
#----- masque encours charge
If !clalev([M:OPSK]):  Local Mask OPSK [OPSK] : Endif
# --- Déclaration classe ecran pour jalonnement --- #
If !clalev([M:JALK]):  Local Mask JALK   [JALK] : Endif
# ouverture PARJAL
If !clalev([F:PJA]):  Local File PARJAL  [PJA]  : Endif
# ouverture WEIGHING                                           #47883 47884
If filinfo(filpath("FIL","WEIGHING","fde",0),0)>=0
   If !clalev([F:WGG]):  Local File WEIGHING [WGG]  : Endif    #47883 47884
Endif
GORITITCOL = 1

# affectations
Gosub OPEN_MTO From MTOLINKLIB
Return


##########################################################################################
$OUVRE_BOITE
#-------------------------------#
# Après ouverture de la fenêtre #
#-------------------------------#
#----- Chargement des noms des Currbox de chaque tiroir -----#

Global Char     GBOXMFG(10)
GBOXMFG="GAU_CHE"+num$(find("MFG",OBJLIS(1..8))) : # Picking des of
Return

##########################################################################################
$HINTCLE
#-----------------------------------------------------------#
# Clé pour optimisation du remplissage des listes de gauche #
#-----------------------------------------------------------#
Case currbox
  When GBOXMFG : HINTLIS(val(right$(GBOXMFG,8)))="MFG0"
Endcase
Return

##########################################################################################
$TIROIR
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
WPICK=2
Gosub RAFFRAICHI

Return

###########################################################################################
$FILGAUCHE
Raz FILGAUSUP(0)                                                       # llc 12.01 11803
Case currbox
    When GBOXMFG :
        FILGAUSUP(0) = '[F:MFG]TYPMOD = 2'                             # llc 12.01 11803
        If [F:MTS]OPETRKFLG <> 2 & [F:MTS]ITMTRKFLG <> 2               # llc 12.01 11803
            FILGAUSUP(0)  += '&[F:MFG]MFGMOD <> 3'                     # llc 12.01 11803
        Endif                                                          # llc 12.01 11803
        If [F:MTS]MATTRKFLG <> 2  & [F:MTS]ITMTRKFLG <> 2              # llc 12.01 11803
            FILGAUSUP(0)  += '&[F:MFG]MFGMOD <> 2'                     # llc 12.01 11803
        Endif
        FILGAUSUP(0) += '& [F:MFG]MFGSTA = 1'
        If GDOSFAB = 2 : FILGAUSUP(0) += '& [F:MFG]MFGTRKFLG >= 3' : Endif
        FILGAUSUP(0) += '&[F:MFG]SUSFLG=1'    # Issue 65082 - 2010-06-10 by CCC : N'autoriser que les OF actifs
# 02.05 28405
#       If COUZON="MFGFCY"
#           If CZ<>""        FILGAUSUP(0)+='&[F:MFG]MFGFCY=CZ'        Endif
#        Else
#                            FILGAUSUP(0)+='&[F:MFG]MFGFCY=[M:MTK0]MFGFCY'
#        Endif

#        If [M:MTK0]MFGFCY <> "" : FILGAUSUP(0)+='&[F:MFG]MFGFCY=[M:MTK0]MFGFCY' : Endif
        FILGAUSUP(0)+='&[F:MFG]MFGFCY=[M:MTK0]MFGFCY'
        # Si pas de clé courante(sauf si création) rien dans la liste de picking
        If (GREP="" & !CLECUR) :  FILGAUSUP(1)=' & [F:MFG]MFGNUM=""' : Endif
        GBIDC3="" : Call FILROLE("MFG",GBIDC3) From SUBARL
        FILGAUSUP(1) += "&" + GBIDC3
   When Default :
Endcase

Return

#########################################################################
$DEB_PICK
Local Integer I, J, WOK, SVGSTODIS, FUNCTION, WRETOUR
Local Decimal WQTY, WQTYSTU, WSTUDIS, WQTYPCE, WALLQTYPCE
Local Char    WNUMTEX(12)

Return

#########################################################################
$PICKE
Local Char WMFGNUM(GLONVCR) : WMFGNUM = [F:MFG]MFGNUM

Case currbox
 When GBOXMFG :
       If [M:MTK0]MFGNUM <> "" : GMESSAGE = mess(166,193,1) : OK = 0 : Return : Endif
       If GREP <> "C" : Return : Endif
       Read [F:MFG]MFG0 = WMFGNUM
       If fstat : Raz [F:MFG] : Endif
       #Selon paramètre général l'OF doit être alloué complètement
       If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
                GMESSAGE = mess(18,190,1)
                OK = 0
                Return
       Endif
       #BOUCLE d'analyse des matières bloquantes si rupture
       # 10.02 Performances
        For [MFM]MFM0 Where MFGNUM = [F:MFG]MFGNUM
            If [F:MFM]SHTQTY <> 0
                Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
                If !fstat & [F:ITF]MFGSHTCOD = 1
                    GMESSAGE = mess(105,193,1)+" ("+[F:MFM]ITMREF+")"
                    OK = 0
                    Break
                Endif
            Endif
        Next
        If OK = 0 : Return : Endif                # llc 12.01 11804
        [M:MTK0]MFGNUM    = [F:MFG]MFGNUM
        [M:MTK0]MFGTRKFLG = [F:MFG]MFGTRKFLG
        [M:MTK0]MFGTRKDAT = date$
        Call AM_MFGNUM([F:MFG]MFGNUM) From SUBMTK
        Diszo [M:MTK0]MFGNUM    # Pour empêcher la modification de la zone : il faut depicker
        Affzo [M:MTK0]1-99
        Affzo [M:MTK1]1-99
        Affzo [M:MTK2]1-99
        Affzo [M:MTK3]1-99
 When Default
Endcase
Return

#########################################################################
$DEPICK
Case currbox
 When GBOXMFG : Gosub DESEL1
 When Default
Endcase
Actzo [M:MTK0]MFGNUM
Affzo [M:MTK0]1-99
Affzo [M:MTK1]1-99
Affzo [M:MTK2]1-99
Affzo [M:MTK3]1-99
Return

#########################################################################
$FIN_PICK
Local Integer WRETOUR, I
For I=0 To [M:MTK2]NBITM-1
    Call STJSTOENTW("MTK2",3,5,[M:MTK0]MFGTRKDAT,I,NBITM,"MTS",3,WRETOUR) From STKENT
Next
Return

#########################################################################
$DESEL1
Raz [M:MTK0]MFGNUM
Effzo [M:MTK1]
Effzo [M:MTK2]
Effzo [M:MTK3]
Gosub RAZCRE
Return

#########################################################################
$REMPBOX
#-----------------------------------------------------------------------#
# Remplissage des boites de picking                                     #
#-----------------------------------------------------------------------#
Case currbox
 When GBOXMFG : Gosub FILGAUCHE
                   Gosub REMPLIT_1 From WOMTK
 When Default :
Endcase
Return


#########################################################################
$RAFFRAICHI
Return


#########################################################################
$CHX_TABLE
Case COUZON
 When "MFGNUM" : # No d'OF
   Default File [MFG]
Endcase
Return


###########################################################################################
$FILTRE
FILTSUP = "1=1"
Case GFONC1
    When"FUNLBEIMP" :    FILTSUP -= " & [F:MTK]ITMTRKFLG = 2" : Return
    When"CONSMKO"   :    FILTSUP -= " & [F:MTK]OPETRKFLG = 2" : Return     # MM 09.01
    When"CONSMKM"   :    FILTSUP -= " & [F:MTK]MATTRKFLG = 2" : Return     # MM 09.01
    When"CONSMKI"   :    FILTSUP -= " & [F:MTK]ITMTRKFLG = 2" : Return     # MM 09.01
Endcase

Case GFONCTION
    When "GEXPOBJ"   :  # FQ 65989 GA 07/2010 filtre selon type d'export
        If dim([M:DIA]ABREV)>0
            If find("MKI",[M:DIA]ABREV(0..dim([M:DIA]ABREV)-1))
              FILTSUP -= " & [F:MTK]ITMTRKFLG = 2" : Return
            Elsif find("MKO",[M:DIA]ABREV(0..dim([M:DIA]ABREV)-1))
              FILTSUP -= " & [F:MTK]OPETRKFLG = 2" : Return
            Elsif find("MKM",[M:DIA]ABREV(0..dim([M:DIA]ABREV)-1))
              FILTSUP -= " & [F:MTK]MATTRKFLG = 2" : Return
            Endif
        Endif
    # Issue 69606 - 2010-12-02 by CCC : La sélection de mouvements pour changer la date d'imputation
    #                                   doit se faire uniquement sur les déclarations de prod
    When "FUNIPTD"   :    FILTSUP -= " & [F:MTK]ITMTRKFLG = 2" : Return
Endcase

# FQ 65989 GA 07/2010 pb en liste de sélection sur l'objet MTK
If clalev ([F:MTS])=0 Local File MFGTRS [MTS] : Endif
If GFLAG<>"" & [F:MTS]MTSNUM<>GFLAG
   Read [MTS] MTS0=2;GFLAG : If fstat Raz [F:MTS] : Endif
Endif

If [F:MTS]OPETRKFLG = 2 & [F:MTS]ITMTRKFLG = 1 & [F:MTS]MATTRKFLG = 1
   FILTSUP -= " & [F:MTK]OPETRKFLG = 2"
Endif
If [F:MTS]ITMTRKFLG = 2 & [F:MTS]OPETRKFLG = 1 & [F:MTS]MATTRKFLG = 1
   FILTSUP -= " & [F:MTK]ITMTRKFLG = 2"
Endif
If [F:MTS]MATTRKFLG = 2 & [F:MTS]OPETRKFLG = 1 & [F:MTS]ITMTRKFLG = 1
   FILTSUP -= " & [F:MTK]MATTRKFLG = 2"
Endif
Return

###########################################################################################
$STATUT
If mkstat=4 & GREP=""
   Trbegin [MTK]
   Call  DEBTRANS From GLOCK
   Gosub UPDATE_TEXTE
   If GOK = 1 : Commit : Else : Rollback : Endif
   Raz mkstat
Endif
If [M:MTK0]MTKTEX <> "" & !GIMPORT
    Call SET_IMAGE (4) From GESECRAN
Elsif !GIMPORT
    Call RESET_IMAGE (4) From GESECRAN
Endif

Return

########################################################################
$UPDATE_TEXTE
Local Integer WRET
# on a viré le texte en modif
If [M:MTK0]MTKTEX = "" & [F:MTK]MTKTEX <> "" & left$([F:MTK]MTKTEX,3) = "MTK"
   Call SUP_CLOB([F:MTK]MTKTEX,WRET) From TRTX3TEX
Else
    If    [M:MTK0]MTKTEX <> ""
          [F:MTK]MTKTEX  = [M:MTK0]MTKTEX
           If left$([F:MTK]MTKTEX,3)="MTK"
                  Call CRE_CLOB([F:MTK]MTKTEX,GOK) From TRTX3TEX
                  If GOK<1 Return Endif
           Elsif !find(left$([F:MTK]MTKTEX,3),"ITM","ROH")
                  Call DUP_CLOB("MTK",[F:MTK]MTKTEX,GOK) From TRTX3TEX
                  If GOK<1 Return Endif
           Endif
    Endif
Endif
Readlock [F:MTK]MTK0 = [M:MTK0]MFGTRKNUM
If fstat=1  GOK=-1 : GLOCK="$MFGHEADTRK"-[M:MTK0]MFGTRKNUM :  Return
Elsif fstat GOK=0  : Call RSTA("MTK",[M:MTK0]MFGTRKNUM) From GLOCK :  Return
Endif
[F:MTK]MTKTEX = [M:MTK0]MTKTEX
Rewrite [F:MTK]
If fstat
   GOK = 0 : Call FSTA("MTK") From GLOCK :  Return
Endif

Return

########################################################################
#Impression des étiquettes
$PRNMFGLBE
Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
WPARAM(1) = [M:MTK0]MFGFCY
WPARAM(2) = "15"
WPARAM(3) = [M:MTK0]MFGTRKNUM
WPARAM(4) = [M:MTK0]MFGTRKNUM
If [M:MTK0]ITMTRKFLG <> 2 : Return : Endif
Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
Return

####################################################################
$CHARG_PARAM
Local  Char     PARAM(10)
If dim(OK)  < 1    : Local Integer OK     : Endif


Call GETCPY(GFCY,"MTS",2,GMTSNUM) From TRTX3CPT
#----- Variables société
Call GETDEV(GFCY) From DEVSUB : If GFINRSP="" GFINRSP=GFCY : Endif
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA

# Issue 72699 - 2011-03-28 by CCC : Lecture du compteur déplacée pour recherche suite à modif site
#----- Récupération compteur suivi
If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
Call LECTCA(8,OK) From SUBTCA
If OK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
GCODNUM    = [F:TCA]CODNUM(2)   # compteur suivi
GMANCOU    = [F:TCA]MANCOU(2)
GOPS       = [F:TCA]CODNUM(4)   # compteur encours opérations

Return

####################################################################
$RAZCRE

Call RAZ_CLOB From ACLOB

Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
Gosub CHARG_PARAM
[M:MTK0]MFGFCY  = GFCY
[M:MTK0]TRSCOD  = [F:MTS]TRSCOD
[M:MTK0]TRSCODS = [F:MTS]TRSCODS
[M:MTK0]CCECODS = [F:DTR]STOCCECOD
Raz [M:MTK0]MTKTEX
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL

#----- Relecture transaction de saisie si nécessaire -----#
If [F:MTS]MTSTYP<>2 | [F:MTS]MTSNUM<>GMTSNUM
   Read [MTS] MTS0=2;GMTSNUM : If fstat Raz [F:MTS] : Endif
Endif
If [F:MTS]OPETRKFLG = 2 : Raz [M:MTK1]MKOTEX : Endif
If [F:MTS]MATTRKFLG = 2 : Raz [M:MTK3]MKMTEX : Endif
Call RESET_IMAGE (4) From GESECRAN
#
If [F:MTS]OPETRKFLG = 2 : Actzo [M:MTK1]5 : Endif
If [F:MTS]ITMTRKFLG = 2 : Actzo [M:MTK2]5 : Endif
If [F:MTS]MATTRKFLG = 2 : Actzo [M:MTK3]5,10 : Call RAZSTOSORW From STKSOR : Endif
If[F:MTS]OPETRKFLG = 2 & [F:MTS]ITMTRKFLG = 1 & [F:MTS]MATTRKFLG = 1
    [M:MTK0]OPETRKFLG = 2
    Grizo [M:MTK0]OPETRKFLG
Else Actzo [M:MTK0]OPETRKFLG
Endif
If[F:MTS]ITMTRKFLG = 2 & [F:MTS]OPETRKFLG = 1 & [F:MTS]MATTRKFLG = 1
    [M:MTK0]ITMTRKFLG = 2
    Grizo [M:MTK0]ITMTRKFLG
Else Actzo [M:MTK0]ITMTRKFLG
Endif
If[F:MTS]MATTRKFLG = 2 & [F:MTS]OPETRKFLG = 1 & [F:MTS]ITMTRKFLG = 1
    [M:MTK0]MATTRKFLG = 2
    Grizo [M:MTK0]MATTRKFLG
Else Actzo [M:MTK0]MATTRKFLG
Endif
#If [F:MTS]FILTDEF <> 3 : Actzo [M:MTK1]QTESUIVOPE,UOM : Endif
#If [F:MTS]FILTFLG =  1 : Actzo [M:MTK1]FILTOPE : Endif
Local File ACTIV [AV1]
Read [AV1]CODACT="EMP"
If fstat : Raz [F:AV1] : Endif
If [F:AV1]FLACT = 1  & [F:MTS]MATTRKFLG = 2
    Grizo [M:MTK3]10
Endif
Close Local File [AV1]
Gosub DEFAUT From WOMTK

If dim([M:MTK0]WRHE)>0
    Effzo [M:MTK0]WRHE
    If [M:MTK0]ITMTRKFLG=2
        Call WRHINIT([M:MTK0]WRHE,[M:MTK0]MFGFCY,2) From STKWRH
    Elsif [M:MTK0]MATTRKFLG=2
        Call WRHINIT([M:MTK0]WRHE,[M:MTK0]MFGFCY,8) From STKWRH
    Endif
    Affzo [M:MTK0]WRHE
Endif
# Actzo ou Grizo des dépôts selon le site
Gosub WRH_ETAT

#----- Mise à jour des listes de gauche picking -----#
If !GIMPORT Gosub TIROIR : Endif
Return

##################################################################
$SETBOUT

GUNVERROU=VERROU

# Mouvements en attente
If GREP <> "C" & [M:MTK0]MATTRKFLG = 2 : CHMEN += "Am" : Endif

#Calcul qté productible si création
If [M:MTK0]MFGTRKNUM = "" : CHMEN += "Aq" : Endif

#Etiquettes de production
If [M:MTK0]MFGNUM <> ""  & [M:MTK0]ITMTRKFLG = 2 : CHMEN += "Ae" : Endif

#Etiquettes de stock
If [M:MTK0]ITMTRKFLG = 2  : CHMEN += "As" : Endif

#visu de la transaction
CHMEN += "At"

#---------------------------------------------------------------------------------#
# Activation / Désactivation menu "Texte entête" dans la ToolBar                  #
#---------------------------------------------------------------------------------#
If GREP="C" | CLECUR
   CHMEN += "Tx"   # v 140
Endif

If CLECUR
   Call VIREBOUT(CHAINE,"HMD") From GOBJET
Endif
# si situation OF pas encore ouverte et suivi sur OF
If clalev ([M:MFS0]) > 0 | [M:MTK0]MFGNUM = "" :    Call VIREBOUT(CHAINE,"a") From GOBJET : Endif

Gosub CTR_WEIGHING                         #47883 47884
If WPESE = "E"                             #47883 47884
   Call VIREBOUT(CHAINE,"A") From GOBJET   #47883 47884
Endif                                      #47883 47884

Return

###################################################################
$EXEBOUT
#--------------------------------#
# Exécution des boutons          #
#--------------------------------#
Case REP
     When "a" :  Read [MTS] MTS0=2;GMTSNUM : If fstat Raz [F:MTS] : Endif
                 # CCC (2010-05-03) Bug 64403 : GMFGCLOSE doit être initialisée au lancement de la fonction
                 #GMFGCLOSE = "2"
Endcase
Return

##########################################
$LIENS

Local Integer I,M,N,WI, LRET
Local Decimal WCOEFF,WVALEUR
Local Char    WCCE(15) :# pour sections ana de CHARG_SCREEN (TB)22/03/00
Local Decimal WUNTTIM                    # 12.05 34019

Call RAZ_CLOB From ACLOB
Call DELSTOENTW(-1,-1,"MTK2",0,0,[M:MTK0]MFGFCY,1,"") From STKENT

If GFCY<>[F:MTK]MFGFCY : GFCY=[F:MTK]MFGFCY : Gosub CHARG_PARAM From SUBMTKA
Else Call ACTUALIS_FMTDIE([F:MTK]MFGFCY,"MTS",2,GMTSNUM)From TRTX3CPT
Endif
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL

If [M:MTK0]MFGNUM <> ""
    Read [F:MFG]MFG0 = [M:MTK0]MFGNUM
    If fstat : Raz [F:MFG] : Endif
Endif
#----- Relecture transaction de saisie si nécessaire -----#
If [F:MTS]MTSTYP<>2 | [F:MTS]MTSNUM<>GMTSNUM
   Read [MTS] MTS0=2;GMTSNUM : If fstat Raz [F:MTS] : Endif
Endif
#
[M:MTK0]TRSCOD  = [F:MTS]TRSCOD
[M:MTK0]TRSCODS = [F:MTS]TRSCODS
[M:MTK0]CCECODS = [F:DTR]STOCCECOD
If [F:MTS]OPETRKFLG = 2 & [M:MTK0]OPETRKFLG = 2
    Default Mask [MTK1]
    Effzo [M:MTK1]10
    nolign = 0
    Filter [F:MKO] Where MFGTRKNUM = [M:MTK0]MFGTRKNUM
    For [F:MKO]
         nolign += 1
          If nolign>=dim([M:MTK1]OPENUM)
              GMESSAGE=mess(275,193,1)
              Break
          Endif
         If [F:MKO]ROUOPENUM <> 0
             If [F:MKO]TIMTYP < 2
                 Read [F:MFO]MFO0 = [F:MKO]MFGNUM;[F:MKO]OPENUM;[F:MKO]OPESPLNUM
                 I = nolign-1
                 Default File [F:MFO]
                 Gosub CHARG_SCREEN From SUBMTKB
             Elsif [F:MKO]TIMTYP = 2
                 Read [F:ROO]ROO0 = [F:MKO]MFGFCY;[F:MKO]ITMREF;[F:MKO]ROUALT;[F:MKO]OPENUM;[F:MKO]RPLIND
                 [M:MTK1] = [F:ROO]
             Endif
         Else
             If [F:MKO]TIMTYP < 2
                [M:MTK1]MFGNUMOP(nolign-1) = [F:MKO]MFGNUM
             Endif
             [M:MTK1]XOPEUOM(nolign-1)  = [F:MKO]OPEUOM
             [M:MTK1]CLEFLG(nolign-1)   = 2
         Endif
         Default File [F:MKO]
         [M:MTK1] = [F:MKO]

         Local Integer WORK_NOLIGN : WORK_NOLIGN = nolign-1

         # 01.07 Demande 39261
         # En chargement d'un suivi existant, on travaille avec les données du suivi
         If [F:MKO]CPLQTY <> 0
             [M:MTK1]CPLUNTTIM(nolign-1)   = [F:MKO]CPLOPETIM / [F:MKO]CPLQTY
         Endif
#
#         If [M:MTK1]OPEUOM(nolign-1) <> [M:MTK1]XOPEUOM(nolign-1) & [F:MTS]OPEUOMMOD = 1
#            [M:MTK1]CPLUNTTIM(nolign-1) = [M:MTK1]CPLUNTTIM(nolign-1) * [M:MTK1]OPESTUCOE(nolign-1)
#             # 11.06 demande 38402
#            [M:MTK1]CPLUNTTIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLUNTTIM(nolign-1))
#         Endif
         # 01.07 fin Demande 39261
         For WI = 1 To 15
             Assign "[M:MTK1]SCANUM"+num$(WI)+"(nolign-1)"   With [F:MKO]SCANUM(WI-1)
             Assign "[M:MTK1]TAREJQTY"+num$(WI)+"(nolign-1)" With [F:MKO]TABREJQTY(WI-1)
         Next
         If [M:MTK1]TIMTYP(nolign-1) = 0 : [M:MTK1]TIMTYP(nolign-1) = 1 : Endif
         # 06.06 demande 36551
         If [M:MTK1]OPEWORCOE(nolign-1) = 0 : [M:MTK1]OPEWORCOE(nolign-1) = 1 : Endif
         If [M:MTK1]TIMTYP(nolign-1) = 1   & [F:MFO]MFOTRKFLG <> 5
            [M:MTK1]EXTQTY(nolign-1)  = ([F:MFO]EXTQTY-[F:MFO]CPLQTY) / [M:MTK1]OPEWORCOE(nolign-1)
         Endif
         If [M:MTK1]EXTQTY(nolign-1) < 0  : [M:MTK1]EXTQTY(nolign-1) = 0 : Endif
         Read [MWS]WST0=[M:MTK1]CPLWST(nolign-1);[M:MTK0]MFGFCY
         If !fstat
             [M:MTK1]WSTTYP(nolign-1)     = [F:MWS]WSTTYP
             [M:MTK1]XWSTTYP(nolign-1)    = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
             # [M:MTK1]WSTSHO(nolign-1)     = [F:MWS]WSTSHO : # GH 28/02/2014 bug 95952
             Call LECTEXTRA([M:MTK1]WSTSHO(nolign-1),"WORKSTATIO","WSTSHOAXX",[M:MTK1]CPLWST(nolign-1),[M:MTK0]MFGFCY) From ATEXTRA
         Endif
         [M:MTK1]OKQTY(nolign-1) = [M:MTK1]CPLQTY(nolign-1) - [M:MTK1]REJCPLQTY(nolign-1)
         If [F:MKO]TIMTYP < 2
            If [M:MTK0]MFGNUM = ""
                Read [F:MFG]MFG0 =[M:MTK1]MFGNUMOP(nolign-1)
                If fstat : Raz [F:MFG] : Endif
            Endif
            [M:MTK1]ITMREF(nolign-1) = [F:MFG]ROUNUM
            [M:MTK1]ROUALT(nolign-1) = [F:MFG]ROUALT
         Endif
        # 74403
        [M:MTK1]CPLUNTTIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLUNTTIM(nolign-1))
        [M:MTK1]CPLOPETIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLOPETIM(nolign-1))
        [M:MTK1]CPLSETTIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MTK1]CPLSETTIM(nolign-1))
        #----- Chargement sections analytiques -----#
        Call CHARG_ACCCCE(nolign-1,"","","[M:MTK1]CCE","MKO",0,[F:MKO]MFGTRKNUM,[F:MKO]OPETRKLIN,0,[F:MKO]CPLWST) From TRTX3CPT
        Call CHARG_ACCCCE(nolign-1,"","","[M:MTK1]CCELAB","MKO",0,[F:MKO]MFGTRKNUM,[F:MKO]OPETRKLIN,0,[F:MKO]CPLLAB) From TRTX3CPT
    Next
    Filter [MKO]                    # MM 09.01
    [M:MTK1]NBOPE = nolign
    Grizo [M:MTK1]5
#Si le suivi ne porte pas sur un seul OF, il vaut mieux laisser les lignes dans l'ordre ou
#elles ont été crées sachant qu'elle sont triées par type de temps/OF
    If [M:MTK0]MFGNUM <> ""
        Sorta [M:MTK1]NBOPE [M:MTK1]NBOPE Order By [M:MTK1]OPENUM(indice)
    Endif
    Affzo [M:MTK1]
Elsif [F:MTS]OPETRKFLG = 2 & [M:MTK0]OPETRKFLG = 1
    Raz   [M:MTK1]
    Affzo [M:MTK1]
Endif
#
If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2
    Default Mask [MTK2]
    Effzo [M:MTK2]10
    nolign = 0
    Filter [F:MKI] Where MFGTRKNUM = [M:MTK0]MFGTRKNUM
    For [F:MKI]
            nolign += 1
            If nolign>=dim([M:MTK2]ITMREF)
                GMESSAGE=mess(274,193,1)
                Break
            Endif
            If [F:MKI]PRODTYP < 2
                Read [F:MFI]MFI0 = [F:MKI]MFGNUM;[F:MKI]MFGLIN
                If [F:ITM]ITMREF <> [F:MKI]ITMREF
                   Read [F:ITM]ITM0 = [F:MKI]ITMREF
                   If fstat : Raz [F:ITM]: Endif
                Endif
                If [F:ITF]STOFCY <> [M:MTK0]MFGFCY | [F:ITF]ITMREF <> [F:MKI]ITMREF
                  Read [F:ITF]ITF0 = [F:MKI]ITMREF;[M:MTK0]MFGFCY
                  If fstat : Raz [F:ITF] : Endif
                Endif
                N = nolign -1
                Gosub CHARG_MTK2 From SUBMTKB
            Else
                Read [F:ITM]ITM0 = [F:MKI]ITMREF
                If fstat : Raz [F:ITM] : Endif
                #[M:MTK2]ITMDES1(nolign-1)     = [F:ITM]ITMDES1
                Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MTK2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
                [M:MTK2]SERMGTCOD(nolign-1)   = [F:ITM]SERMGTCOD
                # 04.02 gestion des sous-produits demande 9469
                If clalev([F:BOH]) <= 0 : Local File BOM [BOH] : Endif
                Read [F:BOH]BOH0 = [F:MKI]ITMREF;[F:MKI]BOMALT;2
                If fstat
                   Raz [F:BOH]
                   [M:MTK2]ITMTYP(nolign-1) = 2
                Else
                   [M:MTK2]ITMTYP(nolign-1) = 1
                Endif
            Endif
            [M:MTK2] = [F:MKI]
            If [F:MKI]PRODTYP = 1 : [M:MTK2]BOMALT(nolign-1) = [F:MFI]BOMALT : Endif

            [M:MTK2]CREFLG(nolign-1) = 1
            [M:MTK2]UPDFLG(nolign-1) = 0
            If [M:MTK2]PRODTYP(nolign-1)      = 0 : [M:MTK2]PRODTYP(nolign-1) = 1 : Endif
            [M:MTK2]WSTOSAI(nolign-1)="222222222222222"
            Read [F:ITM]ITM0 = [M:MTK2]ITMREF(nolign-1)
            Call RECSTO_F ("MTK2", [M:MTK0]MFGFCY,15,
&                  [M:MTK0]MFGTRKNUM, [M:MTK2]ITMTRKLIN(nolign-1),nolign-1, "") From STKECR
            [M:MTK2]WSTOFLG(nolign-1)=1
            #----- Chargement sections analytiques -----#
            Call CHARG_ACCCCE(nolign-1,"","","[M:MTK2]CCE","MKI",0,[F:MKI]MFGTRKNUM,[F:MKI]ITMTRKLIN,0,"") From TRTX3CPT
     Next
     Filter [MKI]                    # MM 09.01
     [M:MTK2]NBITM = nolign
     Grizo [M:MTK2]5
     Affzo [M:MTK2]
Elsif [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 1
     Effzo [M:MTK2]10
     Affzo [M:MTK2]
Endif
#
If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2
    Default Mask [MTK3]
    Effzo [M:MTK3]15
    nolign = 0

    Call RAZSTOSORW From STKSOR

    Filter [F:MKM] Where MFGTRKNUM = [M:MTK0]MFGTRKNUM
    For [F:MKM]
            If [F:ITM]ITMREF <> [F:MKM]ITMREF
               Read [F:ITM]ITM0 = [F:MKM]ITMREF
               If fstat : Raz [F:ITM]: Endif
            Endif
            If [F:ITF]STOFCY <> [M:MTK0]MFGFCY | [F:ITF]ITMREF <> [F:MKM]ITMREF
              Read [F:ITF]ITF0 = [F:MKM]ITMREF;[M:MTK0]MFGFCY
              If fstat : Raz [F:ITF] : Endif
            Endif
            nolign += 1
            If nolign>=dim([M:MTK3]MATITMREF)
                GMESSAGE=mess(276,193,1)
                Break
            Endif
            If [F:MKM]MATTYP <> 2  &  [F:MKM]MFMITMREF <> ""
               If [F:MKM]CUMMATSUI = 0
                  Read [F:MFM]MFM0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN;[F:MKM]BOMSEQ;[F:MKM]MFMITMREF
               Else
                  Filter [F:MFM] Where MFGNUM = [F:MKM]MFGNUM & ITMREF = [F:MKM]MFMITMREF &
&                        BOMOPE = [F:MKM]OPENUM & MATSTA < 4
                  Read [F:MFM]MFM3 First                        # 10.02 Performances
               Endif
               If [F:MFO]OPENUM <> [F:MFM]BOMOPE | [F:MFO]MFGNUM <> [F:MFM]MFGNUM
                   Filter [F:MFO] Where MFGNUM = [F:MFM]MFGNUM & OPENUM = [F:MFM]BOMOPE
                   Read [F:MFO]MFO0 First
                   If fstat : Raz [F:MFO]: Endif
                   Filter [F:MFO]
               Endif
               M = nolign -1
               Gosub CHARG_MTK3 From SUBMTKB
               If [F:MKM]CUMMATSUI = 1
                   Filter [F:MFM] Where MFGNUM = [F:MKM]MFGNUM & ITMREF = [F:MKM]MFMITMREF &
&                                       BOMOPE = [F:MKM]OPENUM & MATSTA < 4
                   Local Decimal WRETQTY
                   Raz [M:MTK3]RETQTY(nolign-1),[M:MTK3]MFMEXTQTY(nolign-1),[M:MTK3]WANCQTY(nolign-1),
&                      [M:MTK3]MFMUSEQTY(nolign-1),[M:MTK3]MFMSHTQTY(nolign-1)
                   For [F:MFM]MFM3                                # 10.02 Performances
                       WRETQTY = [F:MFM]RETQTY - [F:MFM]USEQTY
                       If WRETQTY < 0 : WRETQTY = 0 : Endif
                       Call QTEARR(WRETQTY,[F:MFM]STU) From TRTDIV
                       [M:MTK3]RETQTY(nolign-1)     += WRETQTY
                       [M:MTK3]MFMEXTQTY(nolign-1)  += [F:MFM]RETQTY
                       [M:MTK3]WANCQTY(nolign-1)     = [M:MTK3]USEQTY(nolign-1)
                       [M:MTK3]MFMUSEQTY(nolign-1)  += [F:MFM]USEQTY
                       [M:MTK3]MFMALLQTY(nolign-1)  += [F:MFM]ALLQTY
                       [M:MTK3]MFMSHTQTY(nolign-1)  += [F:MFM]SHTQTY
                       If [M:MTK3]ALLSTA(nolign-1)  <>  [F:MFM]ALLSTA
                          Raz [M:MTK3]ALLSTA(nolign-1)
                       Endif
                   Next
               Endif
               Filter [F:MFM]
            Endif
            If [F:MKM]MATTYP = 2
                 Read [F:BOD]BOD0 = [F:MKM]BOMNUM;[F:MKM]BOMALT;[F:MKM]BOMSEQ;[F:MKM]ITMREF;2
                 If fstat : Raz [F:BOD] : Endif
                 [M:MTK3] = [F:BOD]
            Endif
            [M:MTK3] = [F:MKM]
            [M:MTK3]MATITMREF(nolign-1) = [F:MKM]ITMREF
#            Read [F:ITM]ITM0 = [F:MKM]ITMREF
#            If fstat : Raz [F:ITM] : Endif
            #[M:MTK3]ITMDES1(nolign-1)     = [F:ITM]ITMDES1
            # 119189 mm 11.2016
            Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:MKM]ITMREF,[M:MTK3]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
            [M:MTK3]SERMGTCOD(nolign-1)   = [F:ITM]SERMGTCOD
            [M:MTK3]NEGSTO(nolign-1)      = [F:ITM]NEGSTO
            [M:MTK3]STOCODL(nolign-1)     = [F:ITF]STOCOD
            If [M:MTK3]MATTYP(nolign-1) = 0 : [M:MTK3]MATTYP(nolign-1) = 1 : Endif
            If [M:MTK3]MATTYP(nolign-1) = 1 : [M:MTK3]MFGNUMMA(nolign-1)= [F:MKM]MFGNUM : Endif
            If dim([M:MTK3]LOC) > 0   # hcb 78971
               Raz [M:MTK3]LOC(nolign-1)
            Endif
            If [F:MWS]WST <> [F:MKM]CPLWST
               Read [MWS]WST0=[F:MKM]CPLWST;[F:MKM]MFGFCY
               If fstat : Raz [F:MWS] : Endif
            Endif
            #[M:MTK3]WSTSHO(nolign-1)     = [F:MWS]WSTSHO : # GH 28/02/2014 bug 95952
            Call LECTEXTRA([M:MTK3]WSTSHO(nolign-1),"WORKSTATIO","WSTSHOAXX",[F:MKM]CPLWST,[F:MKM]MFGFCY) From ATEXTRA
            ##
           [M:MTK3]CREFLG(nolign-1)     = 1
           [M:MTK3]UPDFLG(nolign-1)     = 0

           If dim([M:MTK3]TYPQTY(nolign-1)) > 0 & [M:MTK3]TYPQTY(nolign-1) = 0
              If [F:ITF]STOMGTCOD <> 3 : [M:MTK3]TYPQTY(nolign-1) = 2
              Else                     : [M:MTK3]TYPQTY(nolign-1) = 1
              Endif
           Endif
           If [F:MKM]MATTYP = 1
              If [F:MKM]MFGLIN <> 0
                 Read [F:MFI]MFI0 = [F:MKM]MFGNUM;[F:MKM]MFGLIN
                 If fstat : Raz [F:MFI] : Endif
              Else
                 Filter [F:MFI] Where MFGNUM = [F:MKM]MFGNUM
                 Read [F:MFI]MFI0 First
                 If fstat : Raz [F:MFI] : Endif
              Endif
              [M:MTK3]BOMNUM(nolign-1) = [F:MFI]ITMREF
              [M:MTK3]BOMALT(nolign-1) = [F:MFI]BOMALT
              Filter [F:MFI]
            Endif

#          Read [F:ITM]ITM0 = [M:MTK3]MATITMREF(nolign-1)
          Call RECSTOSOR(1,"MTK3",nolign-1,[M:MTK0]MFGFCY,[M:MTK3]MATITMREF(nolign-1),12,[M:MTK0]MFGTRKNUM,
&                        [M:MTK3]MATTRKLIN(nolign-1),"",LRET) From STKECR
            #----- Chargement sections analytiques -----#
            Call CHARG_ACCCCE(nolign-1,"","","[M:MTK3]CCE","MKM",0,[F:MKM]MFGTRKNUM,[F:MKM]MATTRKLIN,0,"") From TRTX3CPT
    Next
    Filter [MKM]                    # MM 09.01
    [M:MTK3]NBMAT = nolign

    Call ETAZONSOR("MTK3") From STKECR

    Grizo [M:MTK3]5,10
    #----------------------------------------#
    # Tri du tableau sur                     #
    #                             Article    #
    #    ou             Opération/article    #
    #    ou   date de réservation/article    #
    #----------------------------------------#
    # FQ 54968 idem sr 03.05 demande 29069 point d'entrée tri spécifique
    # Positionner GPE à 1 si on ne veut pas du tri standard
    GPE = 0
    GPOINT = "CUSSRT" : Gosub ENTREE From EXEFNC
    If GPE = 0
      # llc 12.01 ajout du tri séquence/article 11591
      Case [F:MTS]SORTITM
        When 1 : Sorta [M:MTK3]NBMAT [M:MTK3]NBMAT Order By [M:MTK3]MATITMREF(indice),
&                                                           [M:MTK3]BOMSEQ(indice)
        When 2 : Sorta [M:MTK3]NBMAT [M:MTK3]NBMAT Order By [M:MTK3]OPENUM(indice),
&                                                           [M:MTK3]MATITMREF(indice)
        When 3 : Sorta [M:MTK3]NBMAT [M:MTK3]NBMAT Order By [M:MTK3]RETDAT(indice),
&                                                           [M:MTK3]MATITMREF(indice)
        When 4 : Sorta [M:MTK3]NBMAT [M:MTK3]NBMAT Order By [M:MTK3]BOMSEQ(indice),
&                                                           [M:MTK3]MATITMREF(indice)
      Endcase
    Endif

    Affzo [M:MTK3]


Elsif [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 1
    Effzo [M:MTK3]10
Endif

# Actzo ou Grizo des dépôts selon le site
GWRHOBY = GSVGWRHOBY
Gosub WRH_ETAT

#------------------------#
# affichage icone texte  #
#------------------------#
If [M:MTK0]MTKTEX <> ""
    Call SET_IMAGE (4) From GESECRAN
Else
    Call RESET_IMAGE (4) From GESECRAN
Endif

# Issue 83491 - 2012-08-21 by CCC
Call STKCTRIPT( [M:MTK0]MFGTRKDAT,[M:MTK0]MFGFCY, "1") From STKLIB
If GERR=1
    Call ERREUR(GMESSAGE) From GESECRAN
    Raz GERR
    Raz GMESSAGE
Elsif GERR=2
    Call MESSAGE(GMESSAGE) From GESECRAN
    Raz GERR
    Raz GMESSAGE
Endif
Return

##########################################
$ABANDON
Local Integer SAVGOK : SAVGOK = GOK
Local Integer WRET

If GREP = "C"
    If [M:MTK0]OPETRKFLG = 2
        Gosub DEL_QLYWRK From MTKLIB
    Endif
    # Suppression des sorties stockées dans écran de travail STOSORW
    If [M:MTK0]MATTRKFLG = 2
        Call DELSTOSORW(-1,0,"MTK3",[M:MTK0]MFGFCY,WRET) From STKSOR
    Endif

    # Suppression des entrées stockées dans écran de travail STOSORW
    If [M:MTK0]ITMTRKFLG = 2
        Call DELSTOENTW(-1,-1,"MTK2",1,1,[M:MTK0]MFGFCY,1,"") From STKENT
    Endif
Endif

If GREP="C" & !GIMPORT : Raz [M:MTK0] : Actzo [MTK0] : Gosub TIROIR : Endif
GOK = SAVGOK
Return

########################################################################
$APRES_MODIF

# On vient de modifier un suivi
If GRELITMTK = 1
   Raz GRELITMTK
   Gosub RELIT From GOBJSUB
   Gosub SETBOUT From GOBJSUB : # GH 07/02/2014 bug 94071
   OK = 0
   Return
Endif
If COUZON = "MFGFCY"
    Gosub TIROIR
Endif

OMODIF=1
Return

##########################################
$VERIF_CRE
Local Integer WNBROPE,WNBRITM,WNBRMAT,WOK,WNBSER,WRETOUR, WINDIC_REJQTY, I, J, LRET, WCTLFICTEC, CTL

# JAMCC - Nov 22ns 2018
# Re-factored Jira ticket X3-63085
# Jira ticket X3-116485
For CTL = 0 To [M:MTK1]NBOPE-1
   # Prevent tracking from being created if a Total Actual Qty value is negative
    If [M:MTK1]CPLQTY(CTL) < 0
       GMESSAGE = mess(249,190,1) + " - " + mess(258,190,1)
       OK = 0
       Break
    Endif
Next
If !OK : Return : Endif

# CCC (2010-04-28) Bug 54558 : Vérifier que l'OF n'est pas en cours de modif
If func MFGLIB.CHKMFGLOCK([M:MTK0]MFGNUM,0)
    GMESSAGE=mess(280,193,1)
    OK = 0
    Return
Endif
#
#----- Relecture transaction de saisie si nécessaire -----#
If [F:MTS]MTSTYP<>2 | [F:MTS]MTSNUM<>GMTSNUM
   Read [MTS] MTS0=2;GMTSNUM : If fstat Raz [F:MTS] : Endif
Endif
#
#------Contrôle de la période-----------------------------#
If ([F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2) | ([F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2)
    GMESSAGE = ""
    Call STKCTRIPT([M:MTK0]MFGTRKDAT, [M:MTK0]MFGFCY,"1") From STKLIB
    If GMESSAGE <> "": OK = 0 : Return : Endif
Endif
#
Raz WINDIC_REJQTY
#----------------------------Si suivi opération----------------------------#
Raz WNBROPE
If [F:MTS]OPETRKFLG = 2 & [M:MTK0]OPETRKFLG = 2 & [M:MTK1]NBOPE > 0
    If clalev([F:QLW]) <= 0 : Local File QLYWRK [QLW] : Endif
    For I = 1 To [M:MTK1]NBOPE
           If [M:MTK1]MODIFLG(I-1) = 0 &
&             ([M:MTK1]CPLQTY(I-1) <> 0 | [M:MTK1]CPLOPETIM(I-1) <> 0 | [M:MTK1]CPLSETTIM(I-1) <> 0)
            WNBROPE += 1
            #contrôle que l'opération précédente de chaque opé suivie a bien été suivie
            #si opé de porduction et qté en statut "R" positionnement d'un indicateur
            If [M:MTK1]MFGMST(I-1) = 2 & [M:MTK1]REJCPLQTY(I-1) <> 0 : WINDIC_REJQTY = 1 : Endif
            If [M:MTK1]OPEPREC(I-1) <> 0
                Filter [MFO] Where MFGNUM = [M:MTK0]MFGNUM & OPENUM = [M:MTK1]OPEPREC(I-1)
                Read [MFO]MFO0 First
                If fstat : Raz [F:MFO] : Endif
                Filter [MFO]
                If [F:MFO]TRKFIRST = [0/0/0] & [F:MFO]OPESTA <> 6
                  # GH 05/12/2013 bug 90095 test que l'opération précédente peut être suivie
                  Read [SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
                  If fstat : Raz [F:SCH] : Endif
                  If [F:SCH]DACMST <> 1
                  #
                    If I > 1
                        J = find([M:MTK1]OPEPREC(I-1),[M:MTK1]OPENUM(0..I-2))
                    Endif
                    If !J | [M:MTK1]MODIFLG(J-1) = 1 | I = 1 |
&                      ([M:MTK1]CPLQTY(J-1)=0 & [M:MTK1]CPLOPETIM(J-1)=0 & [M:MTK1]CPLSETTIM(J-1)=0)
                        Case GCTLOPEPRE
                            When 2 : Call AVERTIR(mess(22,190,1)+num$([M:MTK1]OPENUM(I-1)),WOK) From GESECRAN
                                    If WOK <> 2 : OK = 0 : Break : Endif
                            When 3 : Call ERREUR(mess(22,190,1)+num$([M:MTK1]OPENUM(I-1))) From GESECRAN
                                    OK = 0  : Break
                        Endcase
                    Endif
                  Endif
                Endif
            Endif
            #Contrôle que les fiches techniques ont bien été renseignées
            If [M:MTK1]TECCRD(I-1) <> "" & GCTLFICTEC <> 1
               WCTLFICTEC = GCTLFICTEC
               If find(WCTLFICTEC,4,5)
                  # si on est sur le premier suivi alors fonctionnement selon valeur 2 ou 3
                  # Si on est sur le Xieme suivi, alors pas de contrôle
                  Filter [F:MKO] Where MFGNUM = [M:MTK0]MFGNUM & OPENUM = [M:MTK1]OPENUM(I-1)
                  Look [F:MKO]MKO1(1) First
                  If fstat : WCTLFICTEC -= 2
                  Else     : WCTLFICTEC  = 1
                  Endif
                  Filter [F:MKO]
               Endif
               Filter [F:QLW] Where PRONUM = adxuid(1) & LINNUM = [M:MTK1]OPETRKLIN(I-1)
               Look [F:QLW]QLW0 First
               If fstat
                  Case WCTLFICTEC
                      When 2 : Call AVERTIR(mess(23,190,1)+num$([M:MTK1]OPENUM(I-1)),WOK) From GESECRAN
                               If WOK <> 2 : Filter [F:QLW] : OK = 0 : zonsui = "NBOPE" : Break : Endif
                      When 3 : Call ERREUR(mess(23,190,1)-num$([M:MTK1]OPENUM(I-1))) From GESECRAN
                               Filter [F:QLW]
                               OK = 0
                               Break
                   Endcase
               Endif
               Filter [F:QLW]
             Endif
            Endif
            #If [F:MTS]MATRICULE = 1 & [M:MTK1]EMPNUM(I-1)=0 & 1=2 # Suite Issue 85671 GA 08/2013 à revoir
            If [F:MTS]MATRICULE = 1 & [M:MTK1]EMPNUM(I-1)=0        # Issue 85671 GA 09/2014 1=Mandatory
               #  Saisie matricule : Obligatoire
               Call ERREUR(mess(2103,200,1)-":"-mess([F:MTS]MATRICULE,2303,1)-num$([M:MTK1]OPENUM(I-1))) From GESECRAN
               OK = 0
               Break
            Endif
    Next I
    If OK = 0 : Return : Endif
# llc 08.03 19014
#    Close Local File [QLW]
Endif
#----------------------------Si suivi matière----------------------------#
# <GON - Importaciones>
If !GIMPORT
#Contrôle de la transaction de stock,des numéros de série ...
Raz WNBRMAT, LRET
If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 & [M:MTK3]NBMAT > 0
    Call CTLSTOSOR("MTK3","USEQTY",[M:MTK3]NBMAT,LRET) From STKECR
    If LRET<>0
       OK=0 : Return
    Endif
    # 05.05 demande 30321
    For I = 1 To [M:MTK3]NBMAT
        If [F:MTS]STOCODMAN = 2 & [M:MTK3]STOCODL(I-1) = 1 & [M:MTK3]WSTODET(I-1) <> 2 & [M:MTK3]USEQTY(I-1) <> 0
            Call ERREUR(mess(217,190,1)-num$([M:MTK3]MATITMREF(I-1))) From GESECRAN
            OK = 0
            Break
        Endif
        If [M:MTK3]USEQTY(I-1) <> 0 | ([M:MTK3]CLEFLG(I-1) = 2 & [M:MTK3]WEXCMAT(I-1) <> 2)
           # Issue 103013 - 2015-03-02 by CCC : If this component has already been produced on the same WO
           #                                    and issue price adjusment activated => error
           If func MFGLIB.CTLMATISS([M:MTK0]MFGFCY,[M:MTK0]MFGNUM,[M:MTK0]MFGTRKDAT,[M:MTK3]MATITMREF(I-1),1,GMESSAGE)
               Call ERREUR(GMESSAGE) From GESECRAN
               Raz GMESSAGE
               OK = 0
               Break
           Endif
           WNBRMAT += 1
        Endif
    Next
    If OK = 0 : Return : Endif
Endif
#----------------------------Si déclaration de production ----------------------------#
Raz WNBRITM
If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2 & [M:MTK2]NBITM > 0
    Call CTLSTOENT( "MTK2", "CPLQTY",[M:MTK2]NBITM, OK ) From STKECR
    If OK = 0 : Return : Endif

     For I = 1 To [M:MTK2]NBITM
        # 07.02 message d'avertissement si pas de décl prod demande 15041
        If [M:MTK2]UOMCPLQTY(I-1) = 0 | [M:MTK2]WSTOFLG(I-1) =0
            Call AVERTIR(mess(90,193,1)+num$([M:MTK2]ITMTRKLIN(I-1)),WOK) From GESECRAN
            If WOK <> 2 : OK = 0 : zonsui = "NBITM" :  Break : Else : Goto NEXTI : Endif
        Endif
        If [F:ITM]ITMREF <> [M:MTK2]ITMREF (I -1)
            Read [ITM]ITM0 = [M:MTK2]ITMREF (I -1)
            If fstat : Raz [F:ITM] : Endif
        Endif
        If [F:ITF]ITMREF <> [M:MTK2]ITMREF(I-1) | [F:ITF]STOFCY <> [M:MTK0]MFGFCY
            Read [ITF]ITF0 = [M:MTK2]ITMREF(I-1);[M:MTK0]MFGFCY
            If fstat : Raz [F:ITF] : Endif
        Endif
        If [F:MFI]MFGNUM <> [M:MTK0]MFGNUM | [F:MFI]MFGLIN <> [M:MTK2]MFGLIN(I-1)
            Read [F:MFI]MFI0 = [M:MTK0]MFGNUM;[M:MTK2]MFGLIN(I-1)
            If fstat : Raz [F:MFI] : Endif
        Endif
        # Issue 103013 - 2015-03-02 by CCC : If this product has already been issued on the same WO
        #                                    and issue price adjusment activated => error
        If func MFGLIB.CTLMATISS([M:MTK0]MFGFCY,[M:MTK0]MFGNUM,[M:MTK0]MFGTRKDAT,[M:MTK1]ITMREF(I-1),0,GMESSAGE)
            Call ERREUR(GMESSAGE) From GESECRAN
            Raz GMESSAGE
            OK = 0
            Break
        Endif
# de la quantité en statut "R" a été déclarée au niveau de l'opé de production.
# on vérifie qu'il en est de même au niveau de l'article produit
        If WINDIC_REJQTY = 1
            For J = 0 To [M:ENTW]NBLIG
                If [M:ENTW]WSTOSEQ(J)=[M:MTK2]WSTOSEQ(I-1) & left$([M:ENTW]STA(J),1) = "R"
                    WINDIC_REJQTY = 0
                    Break
                Endif
             Next
             If WINDIC_REJQTY = 1
# Issue 81657 - 2012-08-10 by CCC
#                Call AVERTIR(mess(133,190,1)+num$([M:MTK2]ITMTRKLIN(I-1)),WOK) From GESECRAN
#                If WOK <> 2 : OK = 0 : zonsui = "NBITM" :  Break : Endif
                Call OUINON(mess(253,190,1),WOK) From GESECRAN
                If WOK = 2 : OK = 0 : zonsui = "NBITM" :  Break : Endif
             Endif
        Endif
        If [M:MTK2]UOMCPLQTY(I-1) <> 0 & [M:MTK2]WSTOFLG(I-1) = 1
            WNBRITM += 1
        Endif
        $NEXTI
     Next I
     If OK = 0 : Return : Endif
Endif

Endif
#Si aucune opé suivie , ni qté produite,ni conso matière  alors erreur
If WNBROPE = 0 & WNBRMAT = 0 & WNBRITM = 0
   Call ERREUR(mess(28,190,1)) From GESECRAN : OK = 0
   Return
Else
    If WNBROPE = 0  : [M:MTK0]OPETRKFLG = 1 : Endif
    If WNBRMAT = 0  : [M:MTK0]MATTRKFLG = 1 : Endif
    If WNBRITM = 0  : [M:MTK0]ITMTRKFLG = 1 : Endif
    [M:MTK0]NBROPE = WNBROPE
    [M:MTK0]NBRITM = WNBRITM
    [M:MTK0]NBRMAT = WNBRMAT
Endif

TIT = mess(133,195,1)
TRA=0
If GSTOTRACE > 1
    Call OUVRE_TRACE(TIT) From LECFIC
Endif
Return

########################################################################
#Récupération du compteur
########################################################################
$INICRE
Local Integer STAT
Local Integer WRETOUR
Local Char    WNUMTEX(12)
[F:MTK]MFGMOD = [F:MFG]MFGMOD
If GMANCOU <> 2
   Call NUMERO(GCODNUM,[M:MTK0]MFGFCY,[M:MTK0]MFGTRKDAT,"",[F:MTK]MFGTRKNUM,STAT) From SUBANM
   # 01.03 demande 17219
   If GOK < 0 : Return : Endif
   If STAT = 0
      [M:MTK0]MFGTRKNUM = [F:MTK]MFGTRKNUM
   Else
      Call ERREUR(mess(60,199,1)-GCODNUM-num$([L]STAT)) From GESECRAN
      GOK = 0
      Return
   Endif
Endif

# Alimentation dépôt entête si mono-dépôt
If dim([M:MTK0]WRHE)>0 & GWRHOBY=2
  [F:MTK]WRHE = [M:MTK0]WRHE
Else
  [F:MTK]WRHE = ""
Endif

#-- texte
If [M:MTK0]MTKTEX <> ""
   [F:MTK]MTKTEX  = [M:MTK0]MTKTEX
    If left$([F:MTK]MTKTEX,3) = "MTK"
       Call CRE_CLOB([F:MTK]MTKTEX,GOK) From TRTX3TEX
    Elsif !find(left$([F:MTK]MTKTEX,3),"ITM","ROH")
       Call DUP_CLOB("MTK",[F:MTK]MTKTEX,GOK) From TRTX3TEX
    Endif
Endif
Return

########################################################################
#Maj de tous les fichiers liés au suivi
$CREATION
Local Integer WOPECLENBR, WITMCLENBR, WMATCLENBR
Local Decimal WCPLQTY, WREJQTY, WQUAQTY
Local Integer WPRN
Local  Char     TIT(80)

WPRN = 1
Local File MFGPRN [MFP]
Read [F:MFP]MFP0 = [F:MTK]MFGNUM
If !fstat WPRN = [F:MFP]MFGFDRFLG : Endif
Close File [F:MFP]

#----- Relecture transaction de saisie si nécessaire -----#
If [F:MTS]MTSTYP<>2 | [F:MTS]MTSNUM<>GMTSNUM
   Read [MTS] MTS0=2;GMTSNUM : If fstat Raz [F:MTS] : Endif
Endif
If [F:MTS]OPETRKFLG = 2 & [M:MTK0]OPETRKFLG = 2 : Gosub MAJOPE From SUBMTKC: Endif
If GOK < 1 : Raz [M:MTK0]MFGTRKNUM : Endif

# Issue 103013 - 2015-03-02 by CCC : track materials before products
If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 : Gosub MAJMAT From SUBMTKC: Endif
If GOK < 1 : Raz [M:MTK0]MFGTRKNUM  : Endif

If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2 : Gosub MAJITM From SUBMTKC: Endif
If GOK < 1 : Raz [M:MTK0]MFGTRKNUM : Endif

# Issue 103013 - 2015-03-02 by CCC : track materials before products
#If [F:MTS]MATTRKFLG = 2 & [M:MTK0]MATTRKFLG = 2 : Gosub MAJMAT From SUBMTKC: Endif
#If GOK < 1 : Raz [M:MTK0]MFGTRKNUM  : Endif

Call MAJMFGHEAD([F:MTK]MFGNUM,WOPECLENBR,WITMCLENBR,WMATCLENBR,WCPLQTY,WREJQTY,WQUAQTY,WPRN)
&              From SUBMTKC
If GOK < 1 : Raz [M:MTK0]MFGTRKNUM :  Endif
If GTRACE <> ""
    Call ECR_TRACE(mess(79,190,1)+" : "+[F:MTK]MFGTRKNUM,0) From GESECRAN
Endif


Return

########################################################################
$AB_CREATION
Gosub LECTRA
Return

########################################################################
#Affichage du numero de pièce
$APRES_CRE
Local Char WGREP(1) : WGREP = GREP
Affzo [M:MTK0]MFGTRKNUM
#Appel au traitement de visu des allocs en rupture si pas de contremarque et régul
#des mvts en attente
# 09.02 demande 12805
Local Integer I, WRUP, WSOP, WMFG, WMOD, WLIV,WRET
Raz WRUP, WSOP, WMFG, WMOD, WLIV
If [F:MTS]ITMTRKFLG = 2 & [M:MTK0]ITMTRKFLG = 2
    Call STKDELRES(0,[M:MTK0]MFGFCY,"",WRET) From STKLOC
    #Appel au traitement des étiquettes
    If clalev([F:MFP])<=0 : Local File MFGPRN [MFP] : Endif
    If [F:MFP]MFGNUM <> [M:MTK0]MFGNUM
       Read [F:MFP]MFP0 = [M:MTK0]MFGNUM
        If fstat : Raz [F:MFP] : Endif
    Endif

    If [F:MFP]LBEMOD = 2 & !GIMPORT & !GWEBSERV & !GVTMOD           : # Lot V01
            Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
            WPARAM(1) = [M:MTK0]MFGFCY
            WPARAM(2) = "10"
            WPARAM(3) = [M:MTK0]MFGNUM
            WPARAM(4) = [M:MTK0]MFGNUM
            Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
    Endif
    If [F:MTS]PRNCOD1 > 1 & !GIMPORT & !GWEBSERV & !GVTMOD          : # Lot V01
            Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
            WPARAM(1) = [M:MTK0]MFGFCY
            WPARAM(2) = "15"
            WPARAM(3) = [M:MTK0]MFGTRKNUM
            WPARAM(4) = [M:MTK0]MFGTRKNUM
            Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
    Endif

  #---- Régularisation des mouvements et alloc -----#
  For I = 0 To [M:MTK2]NBITM-1
        Call REGFROMENT( 0, "MTK2", "[M:MTK2]CREFLG(I)=0", "ITMREF", [M:MTK0]MFGFCY ) From TRTSHTCOM
  Next
  # Issue 68896 - 2010-11-05 by CCC : La table MTK a pu être relue dans la régul des manquants
  Read [MTK]MTK0=[M:MTK0]MFGTRKNUM
Endif
#Gosub LECTRA
Raz GPE
GPOINT="UPDSCD"
Gosub ENTREE From EXEFNC
If !GPE
    # 08.02 si besoin maj de WORKLOAD demande 15029
    If [F:MTK]OPETRKFLG = 2
        Read [F:MFG]MFG0 = [F:MTK]MFGNUM
        If !fstat & find([F:MFG]SCDFLG,2,4)
            [M:JALK]CODORI = 1
            [M:JALK]CODMAJ = 0
            [M:JALK]CODTRS = 3
            [M:JALK]MFGFCY = [F:MFG]MFGFCY
            [M:JALK]MFGNUM = [F:MFG]MFGNUM
            [M:JALK]MFGSTA = [F:MFG]MFGSTA
            # llc 12.02 16779
            If [F:PJA]MFGFCY <> [M:JALK]MFGFCY
                Read [PJA]PJA0=[M:JALK]MFGFCY
                If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
            Endif
            # Issue X3-23527 - 2017-02-02 by ALSHE : No reschedule of WO when it is being optimized
            If (func AFNC.ACTIV("POPS") = 0 | ([F:MFG]OPTFLG <> 2 & [F:MFG]SCDFLG <> 4))

                Call DEJALONNE From JALLIBA
                If [M:JALK]CODRET = 0
                    Call JALONNE From JALLIB
                Endif
            Endif
        Endif
    Endif
Endif
Gosub LECTRA
Gosub RELIT From GOBJSUB
Raz GREP
Gosub LIENS
GREP = WGREP
#  #----- Affichage icone texte -----#
If [M:MTK0]MTKTEX<>""
     Call SET_IMAGE(4)   From GESECRAN
Else
     Call RESET_IMAGE(4) From GESECRAN
Endif
Return

########################################################################
$LECTRA
If GTRACE <> ""  & GSTOTRACE > 1
   Call FERME_TRACE From LECFIC
   GPE = 1
   # Mettre GPE = 0 pour inhiber l'action standard
   GPOINT = "AFFTRA"
   Gosub  ENTREE From EXEFNC
   If GPE <> 0
      Call LEC_TRACE From LECFIC
   Endif
Endif
Return

########################################################################
$AVANT_MODFIC
# Réalimenter [M]WRHE avec [F]WRHE pour ne pas écraser le mono-dépôt
If dim([M:MTK0]WRHE)>0
   [M:MTK0]WRHE = [F:MTK]WRHE
Endif
Return

########################################################################
$VERF_ANU
Local Date    WDATE
# 11.01 demande 10310
Local Integer WOK
Local Char    WMSG(250)
Local Integer I, J
If clalev ([F:MKM2])=0 : Local File MFGMATTRK [MKM2] : Endif
#Local File MFGMATTRK [MKM2]
# CCC (2010-04-28) Bug 54558 : Vérifier que l'OF n'est pas en cours de modif
# 66152
If [F:MFG]MFGNUM<>""
    If func MFGLIB.CHKMFGLOCK([F:MFG]MFGNUM,0)
        Call ERREUR(mess(280,193,1)) From GESECRAN
        OK = 0 : Return
    Endif
Else
    If dim([M:MTK1]NBOPE)>0
        For GBIDI1=0 To [M:MTK1]NBOPE-1
            If func MFGLIB.CHKMFGLOCK([M:MTK1]MFGNUMOP(GBIDI1),0)
                Call ERREUR([M:MTK1]MFGNUMOP(GBIDI1)-":"-mess(280,193,1)) From GESECRAN
                OK = 0 : Return
            Endif
        Next
    Endif
    If dim([M:MTK2]NBITM)>0
        For GBIDI1=0 To [M:MTK2]NBITM-1
            If func MFGLIB.CHKMFGLOCK([M:MTK2]MFGNUMIT(GBIDI1),0)
                Call ERREUR([M:MTK2]MFGNUMIT(GBIDI1)-":"-mess(280,193,1)) From GESECRAN
                OK = 0 : Return
            Endif
        Next
    Endif
    If dim([M:MTK3]NBMAT)>0
        For GBIDI1=0 To [M:MTK3]NBMAT-1
            If func MFGLIB.CHKMFGLOCK([M:MTK3]MFGNUMMA(GBIDI1),0)
                Call ERREUR([M:MTK3]MFGNUMMA(GBIDI1)-":"-mess(280,193,1)) From GESECRAN
                OK = 0 : Return
            Endif
        Next
    Endif
Endif

#On ne peut pas supprimer un suivi portant sur un OF clos
# 07.02 demande 15172 contrôle ligne à ligne si besoin
If [F:MTK]MFGNUM <> "" & [F:MFG]MFGSTA = 4
   Call ERREUR(mess(81,193,1)) From GESECRAN : OK = 0 : Return
Endif

# Selon la transaction utilisée on ne peut pas supprimer le suivi
Raz WOK
If ([F:MTK]OPETRKFLG = 2 & [F:MTS]OPETRKFLG = 1) : WOK = 1 : Goto ERRTRS : Endif
If ([F:MTK]ITMTRKFLG = 2 & [F:MTS]ITMTRKFLG = 1) : WOK = 2 : Goto ERRTRS : Endif
If ([F:MTK]MATTRKFLG = 2 & [F:MTS]MATTRKFLG = 1) : WOK = 3 : Goto ERRTRS : Endif
$ERRTRS
If WOK <> 0
   WMSG = mess(223,190,1)
   Case WOK
        When 1 : WMSG += mess(224,190,1)
        When 2 : WMSG += mess(225,190,1)
        When 3 : WMSG += mess(226,190,1)
   Endcase
   Call ERREUR(WMSG) From GESECRAN : OK = 0 : Return
Endif

If [F:MTK]OPETRKFLG = 2
   For [F:MKO] Where  MFGTRKNUM = [F:MTK]MFGTRKNUM & TIMTYP = 1
       Read [F:MFG]MFG0 = [F:MKO]MFGNUM
       If fstat : Raz [F:MFG] : Endif
       If [F:MFG]MFGSTA = 4
          Call ERREUR(mess(81,193,1) - [F:MKO]MFGNUM) From GESECRAN
          OK = 0
          Break
       Endif
   Next
   If OK = 0 : Return : Endif
Endif
If [F:MTK]ITMTRKFLG = 2
   Gosub VERIF_QTEALL From MTKLIB
   If GMESSAGE<>""  OK=0 : Return : Endif
   I=0
   For [F:MKI] Where  MFGTRKNUM = [F:MTK]MFGTRKNUM
        # message d'erreur si le OF clos
        If [F:MKI]PRODTYP = 1
           Read [F:MFG]MFG0 = [F:MKI]MFGNUM
           If fstat : Raz [F:MFG] : Endif
           If [F:MFG]MFGSTA = 4
              Call ERREUR(mess(81,193,1) - [F:MKI]MFGNUM) From GESECRAN
              OK = 0
              Break
           Endif
       Endif
        # message d'erreur si le contrôle qualité a été fait
        If [F:MKI]QUARTNFLG = 2
           Call ERREUR(mess(91,199,1))  From GESECRAN
           OK=0
           Break
        Endif
        # message d'avertissement si article en inventaire
        Raz WOK
        Read [F:ITF]ITF0 = [F:MKI]ITMREF;[F:MKI]MFGFCY
        If fstat : Raz [F:ITF] : Endif
        If [F:ITF]CUNFLG = 2
           WOK=2 : Call AVERTIR(mess(162,190,1),WOK)  From GESECRAN
           If WOK=1 : OK=0 : Endif
           Break
        Endif
        I+=1
   Next
   If OK = 0 : Return : Endif
Endif
If [F:MTK]MATTRKFLG = 2
   J=0
   For [F:MKM] Where  MFGTRKNUM = [F:MTK]MFGTRKNUM
     If [F:MKM]MATTYP = 1
       Read [F:MFG]MFG0 = [F:MKM]MFGNUM
       If fstat : Raz [F:MFG] : Endif
       If [F:MFG]MFGSTA = 4
          Call ERREUR(mess(81,193,1) - [F:MKM]MFGNUM) From GESECRAN
          OK = 0
          Break
       Endif
     Endif
     # Issue 128395 GH 08/04/2019 - Addition of needed conditions for active button Stock txn modification
     If find([F:MKM]MATTYP,1,2) & [F:MKM]USEQTY<>0
        J+=1
     Endif
   Next
   If OK = 0 : Return : Endif
Endif

#On ne peut pas supprimer un suivi issu d'une réception de sous-traitance
If [F:MTK]PTHNUM <> "" & GFONC1 = "GESMTK"
    Call ERREUR(mess(102,193,1)) From GESECRAN
    OK = 0 : Return
Endif

GPE = 0
#CHECK IGNORE_BEGIN
GPOINT = "ANUACT" : Gosub ENTREE From EXEFNC : # GH 20/11/2014 dm 103682

#CHECK IGNORE_END
If GPE = 0
  # GH 03/02/2014 bug 94071
  # Issue 137291 GH 16/04/2019 - Error not to display for deletion of SST receipt (GESPTH)
  If (([F:MTK]MATTRKFLG = 2 & J) | ([F:MTK]ITMTRKFLG = 2 & I)) & left$(GFONCTION1,6)<>"GESPTH"
   # Suppression à faire ligne par ligne via la modification des mvts de stock
   Call MESSAGE(mess(297,193,1)) From GESECRAN
   OK=0 : Return
  Endif
Endif

#contrôle que la période est ouverte
# On essaie d'abord sur la date de création du suivi et si pas possible on essaie avec date$
GMESSAGE = ""
WDATE = [F:MTK]MFGTRKDAT
Call STKCTRIPT(WDATE, [F:MTK]MFGFCY,"1") From STKLIB
If GMESSAGE <> ""
    Raz GMESSAGE
    Call STKCTRIPT(date$, [F:MTK]MFGFCY,"1") From STKLIB
    If GMESSAGE <> "" : OK = 0 : Return
    Else GWIPTDAT = date$
    Endif
Else GWIPTDAT = [F:MTK]MFGTRKDAT
Endif
If left$(GFONCTION1,6)="GESPTH"  : Return : Endif
Gosub OUVERTURE_TRACE From MTKLIB
Return

########################################################################
$ANNULE
Local Integer WOPECLENBR, WITMCLENBR, WMATCLENBR
Local Decimal WCPLQTY,WREJQTY,WQUAQTY
Local  Char   TIT(80)
Local Integer WRET
If !clalev([SOM]) : Local Mask STOSORM [SOM] : Endif
If !clalev([ENM]) : Local Mask STOENTM [ENM] : Endif
#------------------------------------#
# supression des textes associées    #
If [F:MTK]MTKTEX  <> "" & left$([F:MTK]MTKTEX,3) = "MTK"
    Call SUP_CLOB([F:MTK]MTKTEX,WRET) From TRTX3TEX
Endif
Gosub ANNULE_SUIV From SUBMTKC
Return

########################################################################
$AP_ANNULE
Gosub LECTRA
Return

########################################################################
$FERME
Local Integer WRET

#-- effacement icone texte
Call RESET_IMAGE (4) From GESECRAN

#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
If dim(GBOXMFG)>0      Kill GBOXMFG      : Endif

#Rajouté le 16/04/99 pour géréer les impressions écran
Call IMPSCR From ATRTX3
Raz GORITITCOL

# Issue 82475 - 2018-07-30 by STLIG : from work orders (via bookmark) - restore [F:MTS]
If (clalev([F:MTS1])<>0)
  [F:MTS]=[F:MTS1]
Endif

# JAMCC - Nov 22ns 2018
# Re-factored Jira ticket X3-63085
# Jira ticket X3-116485
Kill G_RUN_RE_CALCULATE_CPLQTY

Return

#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables ( sections analytiques)           #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT
  Local Char BASPAG(10)
  If (dim([M:MTK1]CCE1)>0) & [F:MTS]OPETRKFLG=2
      BASPAG="NBOPE" : Gosub TIT_COL From ="W1WR2"+GMTSNUM+"1"
      If [M:MTK1]NBOPE = 0 : [M:MTK1]NBOPE = 1 : Affzo [M:MTK1]10 : Effzo [M:MTK1]10 : Endif
  Endif
  If (dim([M:MTK2]CCE1)>0) & [F:MTS]ITMTRKFLG=2
      BASPAG="NBITM" : Gosub TIT_COL From ="W1WR2"+GMTSNUM+"2"
      If [M:MTK2]NBITM = 0 : [M:MTK2]NBITM = 1 : Affzo [M:MTK2]10 : Effzo [M:MTK2]10 : Endif
  Endif
  If (dim([M:MTK3]CCE1)>0) & [F:MTS]MATTRKFLG=2
      BASPAG="NBMAT" : Gosub TIT_COL From ="W1WR2"+GMTSNUM+"3"
      If [M:MTK3]NBMAT = 0 : [M:MTK3]NBMAT = 1 : Affzo [M:MTK3]15 : Effzo [M:MTK3]15 : Endif
  Endif
Endif
Raz GSOC_UPDFLG
Return

####################################################################  #47883 47884
#Controle si origine du suivi est une pesée                        #
####################################################################
$CTR_WEIGHING
Local  Char WPESE(1)
Raz WPESE

If filinfo(filpath("FIL","WEIGHING","fde",0),0)>=0
   Filter [WGG] Where MFGTRKNUM = [M:MTK0]MFGTRKNUM
   Look [WGG]WGG0 First
   Filter [WGG]
   If fstat
      Raz WPESE
   Else
      WPESE = "E"
   Endif
Endif
Return

#########################################
$GRISE
# Accès à un document créé en multi-dépôt avec une transaction mono-dépôt
# --> pas d'application du mono-dépôt
If [F:MTK]WRHE="" & GWRHOBY=2
   GWRHOBY=1
   If [M]MFGFCY<>[F:FCY]FCY : Read [FCY]FCY0=[M]MFGFCY : Endif
   If [F:FCY]WRHGES=2 : Call MESSAGE(mess(351,184,1)) From GESECRAN : Endif
Endif
Return

#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M]MFGFCY<>[F:FCY]FCY
   Read [FCY]FCY0=[M]MFGFCY
Endif
If [F:FCY]WRHGES=2
   If find(GREP,"C","D")
      Actzo [M:MTK0]WRHE
      If GWRHOBY=2
         Diszo [M:MTK2]WRH
         Diszo [M:MTK3]WRH
      Else
         Actzo [M:MTK2]WRH
         Actzo [M:MTK3]WRH
      Endif
   Elsif [M:MTK0]WRHE<>""
      Diszo [M:MTK0]WRHE
      Diszo [M:MTK2]WRH
      Diszo [M:MTK3]WRH
   Else
      Actzo [M:MTK0]WRHE
      Actzo [M:MTK2]WRH
      Actzo [M:MTK3]WRH
   Endif
Else
  Raz   [M:MTK0]WRHE
  Grizo [M:MTK0]WRHE
  Grizo [M:MTK2]WRH
  Grizo [M:MTK3]WRH
Endif
Return




