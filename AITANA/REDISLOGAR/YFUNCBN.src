#####################################################################################
# CODACT: YA028 - Filtrar por fam. estadistica
#####################################################################################
$ACTION
Case ACTION
  When "REPLANNING"     : Gosub REPLANNING
Endcase
Return
#####################################################################################
$REPLANNING

If [M:DIA]YTSICOD <> ''
  If find(FORMULE_S,"[F:ITM]TSICOD(0) = [M:DIA]YTSICOD") = 0
    FORMULE_S += " & [F:ITM]TSICOD(0) = [M:DIA]YTSICOD"
  Endif
Endif

#Infbox(FORMULE_S)
Return

