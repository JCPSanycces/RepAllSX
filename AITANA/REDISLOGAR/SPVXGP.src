######################################################################################
$ACTION
    #Infbox ACTION
    Case ACTION
        When "DEBUT" : Gosub DEBUT
        When "OK"    : Gosub OK
        When "EXEC"  : Gosub EXEC
    Endcase
Return

######################################################################################
$EXEC
    # Bouton suppression (le ctr a deja eu lieu sur l affichage du bouton)
    If GACTION="XGRPSUP"
        If !clalev([XXGR]) : Local File XGRPUSR [XXGR] : Endif
        If !clalev([XAUS]) : Local File AUTILIS [XAUS] : Endif
        Local Integer PEUTSUP

        If dim(PARAM(1))>0 & PARAM(1)<>""
            [L]PEUTSUP = 2
            For [F:XAUS] Where [F:XAUS]XGRPUTIL<>""

               # LBORN 02/10/2017 - Mantis 34537
               # If instr(1,[F:XAUS]XGRPUTIL,PARAM(1))
               #     If instr(1,[F:XAUS]XGRPUTIL,PARAM(1))+len(PARAM(1)) = len([F:XAUS]XGRPUTIL)-1
               #     &  | seg$([F:XAUS]XGRPUTIL,instr(1,[F:XAUS]XGRPUTIL,PARAM(1))+len(PARAM(1)),instr(1,[F:XAUS]XGRPUTIL,PARAM(1))+len(PARAM(1))) = ";"
               #        [L]PEUTSUP = 0
               #          Break
               #      Endif
               # Endif
               If func TROUVCH([F:XAUS]XGRPUTIL,PARAM(1),";")
                 [L]PEUTSUP=0 : Break
               Endif

            Next
            If ![L]PEUTSUP
                Infbox(mess(4,1824,1))
            Else
                Trbegin [F:XXGR]
                Delete [F:XXGR] Where XCODE = PARAM(1)
                If !fstat
                    Commit
                    Gosub LIENS From SPVOBJXGR : Affzo [M:XGR]
                Else
                    Call FSTA("XXGR") From GLOCK : Rollback
                Endif
            Endif
        Endif
    Endif
Return

######################################################################################
# LBORN 02/10/2017 - Mantis 34537
######################################################################################
Funprog TROUVCH(CHAINE,SCH,SEP)
Value Char CHAINE, SCH, SEP

Local Integer ZTROUV, ZI
Local Char ZCAR, ZAUX

Raz [L]ZTROUV, [L]ZAUX

For [L]ZI=0 To len([L]CHAINE)-1
  [L]ZCAR=mid$([L]CHAINE,[L]ZI+1,1)
  If [L]ZCAR=[L]SEP
    If [L]ZAUX=[L]SCH
      [L]ZTROUV=1 : Break
    Else
      Raz [L]ZAUX
    Endif
  Else
    [L]ZAUX+=[L]ZCAR
    If [L]ZI=len([L]CHAINE)-1
      If [L]ZAUX=[L]SCH
        [L]ZTROUV=1
      Endif
    Endif
  Endif
Next

End [L]ZTROUV

######################################################################################
$OK
    # PARAM(1) = code pere

    #On cree ou on modifie le groupe
    Local Integer ENMODIF
    Local Integer TOUTSELEC

    If !clalev([XXGR]) : Local File XGRPUSR [XXGR] : Endif

    Trbegin [F:XXGR]

    [L]ENMODIF = 0
    Read [F:XXGR]XGR0 = [M:XGP]XCODE
    If !fstat
        [L]ENMODIF = 2
    Endif

    [F:XXGR] = [M:XGP]
    If dim(PARAM(1))>0 & GACTION="XGRPPAR" : [F:XXGR]XCODEP = PARAM(1) : Endif

    If [L]ENMODIF
        Rewrite [F:XXGR]
        If fstat : Call FSTA("XXGR") From GLOCK : Rollback : Return : Endif
    Else
        #M16765
        If dim([F:XXGR]XKEYPLA)>0
            Raz [F:XXGR]XKEYPLA
        Endif
        Write [F:XXGR]
        If fstat : Call FSTA("XXGR") From GLOCK : Rollback : Return : Endif
    Endif

    Commit

    Raz [M:XGR]
    Call CHERCHEFILS([F:XGR]XCODEP,1,TOUTSELEC) From SPVOBJXGR
    Affzo [M:XGR]

Return

######################################################################################
$DEBUT

    If !clalev([XXGR]) : Local File XGRPUSR [XXGR] : Endif
    If !clalev([XAUS]) : Local File AUTILIS [XAUS] : Endif

    # Si on vient depuis l action pour creer un sous groupe, on raz
    If GACTION="XGRPPAR" : Raz [M:XGP] : Endif

    # Si on vient depuis l action pour modifier un groupe, on le charge
    If GACTION="XGRPMOD" & dim(PARAM(1))>0 & PARAM(1)<>""
        Grizo [M:XGP]XCODE

        If !clalev([XXGR]) : Local File XGRPUSR [XXGR] : Endif
        Read [F:XXGR]XGR0 = PARAM(1)
        If !fstat
            Raz [M:XGP]
            [M:XGP] = [F:XXGR]
        Endif
    Endif

    Call AM_XRUBRIQUE([M:XGP]XRUBRIQUE)
    Affzo [M:XGP]
Return

######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran XGRPPAR) 27/04/2011 15:22:45 (GPELE)
######################################################################################
Subprog AM_XRUBRIQUE(VALEUR)
Variable Integer VALEUR
    If VALEUR<>2
        Grizo [M:XGP]XALPHA1I
        Grizo [M:XGP]XALPHA1T
        Grizo [M:XGP]XALPHA1D
        Grizo [M:XGP]XALPHA1M
        Grizo [M:XGP]XALPHA2I
        Grizo [M:XGP]XALPHA2T
        Grizo [M:XGP]XALPHA2D
        Grizo [M:XGP]XALPHA2M
        Grizo [M:XGP]XNUM1I
        Grizo [M:XGP]XNUM1T
        Grizo [M:XGP]XNUM1D
        Grizo [M:XGP]XNUM2I
        Grizo [M:XGP]XNUM2T
        Grizo [M:XGP]XNUM2D
        Grizo [M:XGP]XDATE1I
        Grizo [M:XGP]XDATE1T
        Grizo [M:XGP]XDATE1D
        Grizo [M:XGP]XDATE2I
        Grizo [M:XGP]XDATE2T
        Grizo [M:XGP]XDATE2D
        Affzo [M:XGP]
    Else
        Actzo [M:XGP]XALPHA1I
        Actzo [M:XGP]XALPHA1T
        Actzo [M:XGP]XALPHA1D
        Actzo [M:XGP]XALPHA1M
        Actzo [M:XGP]XALPHA2I
        Actzo [M:XGP]XALPHA2T
        Actzo [M:XGP]XALPHA2D
        Actzo [M:XGP]XALPHA2M
        Actzo [M:XGP]XNUM1I
        Actzo [M:XGP]XNUM1T
        Actzo [M:XGP]XNUM1D
        Actzo [M:XGP]XNUM2I
        Actzo [M:XGP]XNUM2T
        Actzo [M:XGP]XNUM2D
        Actzo [M:XGP]XDATE1I
        Actzo [M:XGP]XDATE1T
        Actzo [M:XGP]XDATE1D
        Actzo [M:XGP]XDATE2I
        Actzo [M:XGP]XDATE2T
        Actzo [M:XGP]XDATE2D
        Affzo [M:XGP]
    Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran XGRPPAR) 27/04/2011 17:14:47 (GPELE)
######################################################################################
Subprog C_XRUBRIQUE(VALEUR)
Variable Integer VALEUR
    Local Integer AGROUPEFILS
    # Si le groupe devient rubrique, il faut verifier qu il n a pas de sous groupe
    If VALEUR=2
        [L]AGROUPEFILS = 0
        If !clalev([XXGR]) : Local File XGRPUSR [XXGR] : Endif
        For [F:XXGR] Where [F:XXGR]XCODEP = [M:XGP]XCODE
            [L]AGROUPEFILS = 2
        Next
        If [L]AGROUPEFILS
            mkstat=2 : GMESSAGE=mess(2,1824,1) : GERR=1
        Endif
    Else

    Endif
End


