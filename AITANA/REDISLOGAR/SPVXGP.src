Subprog AS_XALPHA1T(VALEUR)
Variable Char    VALEUR()
    If XALPHA1I = "" : mkstat=2 : Endif
End

Subprog C_XALPHA1T(VALEUR)
Variable Char    VALEUR()
    If XALPHA1D <> "" & VALEUR <> "ADI" & VALEUR <> "M"
        Call CONTSEL(VALEUR,"!",[M:XGP]XALPHA1D,"",mkstat) From CONTOBJ
        If mkstat : GERR = 1 : GZONE = "XALPHA1T" : GZNUM = 680 : Endif
    Endif
End

