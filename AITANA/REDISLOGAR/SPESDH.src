#<AdxTL>@(#)0.0.0.0 $Revision$ Entregas
######################################################################################
$ACTION
##b/- GT NDEV 27AUG2018 Customization for ACTIVITY Code YPOC
If func AFNC.ACTIV("YPOC"): Gosub ACTION From YSPESDH : Endif
##e/- GT NDEV 27AUG2018 Customization for ACTIVITY Code YPOC
Case ACTION
  When "SETBOUT"   : Gosub SETBOUT
  When "TRT_DIV"   : Gosub TRT_DIV
  When "SETBOUT"   : Gosub SETBOUT
  When "INIMOD"    : Gosub INIMOD
  When "INICRE"    : Gosub INICRE
  When "STATUT"    : Gosub STATUT
  When "RAZCRE"    : Gosub RAZCRE
  When "RAZDUP"    : Gosub RAZDUP
  When "ANNULE"    : Gosub ANNULE
  When "ABANDON"   : Gosub ABANDON
 When Default
Endcase
Return

######################################################################################
## YA029 - Retención fac en entregas
######################################################################################
$SETBOUT
##Infbox(CHAINE)
Gosub ACTION From SUBSDH
##Infbox(CHAINE)
Global Char TABLETEX
#Desactivar boton retener factura si no esta validado
If ([M:SDH1]INVFLG = 2 and [M:SDH1]SIHNUM <> '') or
&  [M:SDH1]CFMFLG < 2 or
&  GREP<>""
   Call VIREBOUT(CHAINE,"7") From GOBJET
   Call VIREBOUT(CHAINE,"8") From GOBJET
   ## YA035 - Saldar entregas
   Call VIREBOUT(CHAINE,"6") From GOBJET
   ##
Endif

If [M:SDH0]YRETFAC = 2
  Call VIREBOUT(CHAINE,"7") From GOBJET
Endif

#Desactivar boton retener factura si esta facturado y no retenido
If [M:SDH1]CFMFLG = 2 and [M:SDH0]YRETFAC <> 2
  Call VIREBOUT(CHAINE,"8") From GOBJET
Endif

## YA035 - Saldar entregas
 #Desactivar el boton saldar si ya está facturado
  If [M:SDH1]INVFLG = 2
    Call VIREBOUT(CHAINE,"6") From GOBJET
  Endif
##

##### YA032 - Activar botón "Z" cabecera traspasable
CHMEN += "Z"
Gosub SET_BOUT_SPE From GSAISIE
###############
#
GPE = 1
Return
######################################################################################
## YA029 - Retención fac en entregas
######################################################################################
$TRT_DIV
#Infbox('TRT_DIV: GACTION = ' + GACTION )
  Case GACTION
    When "YLIBFAC"  :  Gosub YLIBFAC
    When "YSALENT"  :  Gosub YSALENT
  Endcase
Return
######################################################################################
## YA029 - Retención fac en entregas
######################################################################################
$YLIBFAC
If !clalev ([F:YSDH]) : Local File SDELIVERY  [YSDH] : Endif
Read [F:YSDH]SDH0=[M:SDH0]SDHNUM
#
If fstat <> 0
  Infbox('No existe esta entrega')
  Return
Elsif [F:YSDH]CFMFLG < 2
  Infbox('Entrega no validada, no se puede retener/liberar factuación')
  Return
Elsif [F:YSDH]YRETFAC = 2
  [F:YSDH]YRETFAC = 1
  [F:YSDH]INVFLG = 1
  Rewrite [F:YSDH]
  Infbox('Entrega liberada para facturación')
  [M:SDH0]YRETFAC = 1
  [M:SDH1]INVFLG = 1
  Affzo [M:SDH0]1-99
  Affzo [M:SDH1]1-99
Elsif [F:ZSDH]YRETFAC < 2
  [F:YSDH]YRETFAC = 2
  [F:YSDH]INVFLG = 2
  Rewrite [F:YSDH]
  Infbox('Entrega retenida para facturación')
  [M:SDH0]YRETFAC = 2
  [M:SDH1]INVFLG = 2
  Affzo [M:SDH0]1-99
  Affzo [M:SDH1]1-99
Endif
Return
######################################################################################
## YA035 - Saldar entregas
######################################################################################
$YSALENT
Local Integer WOK
Call AVERTIR ("Esta acción no se puede deshacer. \¿Desea marcar la entrega como saldada?", WOK) From GESECRAN
#Si se pulsa OK
If WOK = 2
  If !clalev ([F:YSDH]) : Local File SDELIVERY  [YSDH] : Endif
  Read [F:YSDH]SDH0=[M:SDH0]SDHNUM
  If [F:YSDH]CFMFLG < 2
    Infbox('Entrega no validada, no se puede saldar')
  Else
    [F:YSDH]YSALENT = 2
    [F:YSDH]INVFLG  = 2
    Rewrite [YSDH]
  Endif
  [M:SDH0]YSALENT = [F:YSDH]YSALENT
  [M:SDH1]INVFLG  = [F:YSDH]INVFLG

  Affzo [M:SDH0]1-99
  Affzo [M:SDH1]1-99

  #Infbox('Entrega saldada')
Endif
Return
######################################################################################
## YA037 - Traer el código de articulo para el cliente
######################################################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()

If clalev ([F:ZITU])  = 0 : Local File ITMBPC  [ZITU] : Endif

Read [F:ZITU]ITU0 = VALEUR;[M:SDH0]BPCORD
If fstat = 0

  [M:SDH1]YITMCLI(nolign -1) = [F:ZITU]ITMDESBPC

  Affzo [M:SDH1]YITMCLI(nolign -1)

Endif
End
######################################################################################

######################################################################################
## YA039 accion campor BPCORD para alimentar check Albaran Valorado
######################################################################################
Subprog AM_BPCORD(VALEUR)
  Variable Char VALEUR()

  If !clalev ([F:YBPC]) : Local File BPCUSTOMER [YBPC] : Endif

  Read [F:YBPC]BPC0 = VALEUR
  If fstat =0

    [M:SDH0]YDLVPRI = [F:YBPC]YDLVPRI
    [M:SDH1]YDLVPRI = [F:YBPC]YDLVPRI

    Affzo [M:SDH0]YDLVPRI
    Affzo [M:SDH1]YDLVPRI

  Endif
End


######################################################################################
######YA032 - Textos de cabecera traspasables JEL ############
#####################################################################################

$INIMOD
Gosub ACTION From SUBSDH
If [M:SDH0]YSDHTEX<>""
      #si no existe creamos el clob
    Call CRE_CLOB([M:SDH0]YSDHTEX,GOK) From TRTX3TEX
    If GOK<1 Return Endif
    [F:SDH]YSDHTEX = [M:SDH0]YSDHTEX
Else
   #borra la cabecera traspasable vacia
   If left$(TABLETEX,3)="SDH"
      Call SUP_CLOB(TABLETEX,WRET) From TRTX3TEX
   Endif
Endif
GPE=1
Return

$INICRE
Gosub ACTION From SUBSDH
If [M:SDH0]YSDHTEX<>""

      #si no existe creamos el clob
      Call CRE_CLOB([M:SDH0]YSDHTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
      #si viene de del Presupuesto lo duplicamos
#   Elsif left$([F:SQH]YSQHTEX,3)="SQH"
#      [M:SOH0]YSOHTEX = [F:SQH]YSQHTEX
#      Call DUP_CLOB("SOH",[M:SOH0]YSOHTEX,GOK) From TRTX3TEX
#      If GOK<1 Return Endif

   [F:SDH]YSDHTEX = [M:SDH0]YSDHTEX
Else
   #borra la cabecera traspasable vacia
  If dim (TABLETEX) >= 0
    Call SUP_CLOB(TABLETEX,WRET) From TRTX3TEX
  Endif
Endif
GPE=1
Return

$STATUT
TABLETEX = [F:SDH]YSDHTEX
Gosub ACTION From SUBSDH
Case BOUT
    When "Z"  :   If mkstat=4 & GREP=""
#                      GREP="M" : REP="M"
#                      Gosub SETBOUT From GOBJSUB
                       Gosub ENTRE_MODIF From GOBJSUB
                   Endif
                   If [M]YSDHTEX <> "" & !GIMPORT
                       Call SET_IMAGE (4) From GESECRAN
                   Elsif !GIMPORT
                       Call RESET_IMAGE (4) From GESECRAN
                   Endif

Endcase
GPE=1
Return

$RAZCRE
Gosub ACTION From SUBSDH
Raz [M:SDH0]YSDHTEX

GPE=1
Return

$RAZDUP
Gosub ACTION From SUBSDH
If left$([M:SDH0]YSDHTEX,3)="SDH"
  Call DUP_CLOB("SDH",[M:SDH0]YSDHTEX,WRET) From TRTX3TEX
  If WRET<1 Raz [M:SDH0]YSDHTEX Endif
Endif

GPE=1
Return

$ANNULE
Gosub ACTION From SUBSDH

If left$([F:SDH]YSDHTEX,3)="SDH"
   Call SUP_CLOB([F:SDH]YSDHTEX,WRET) From TRTX3TEX
Endif

GPE=1
Return

$ABANDON
Gosub ACTION From SUBSDH
If GREP = "D" & GREP <> "M"
  If left$([M:SDH0]YSDHTEX,3)="SDH"
        Call SUP_CLOB([M:SDH0]YSDHTEX,WRET) From TRTX3TEX
  Endif
Endif
GPE=1
Return
#########YA032###############################################################

######################################################################################
## YA034 - Tipo precio en Ventas
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
Read [F:ZITM]ITM0 = VALEUR
If fstat = 0
  [M:SDH1]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
  Affzo [M:SDH1]YTIPPRI(nolign -1)
Endif

 Case [M:SDH1]YTIPPRI(nolign -1)
  When 1 : [M:SDH1]YGROPRI(nolign -1) = [M:SDH1]GROPRI(nolign -1)
  When 2 : [M:SDH1]YGROPRI(nolign -1) = [M:SDH1]GROPRI(nolign -1) * 10
  When 3 : [M:SDH1]YGROPRI(nolign -1) = [M:SDH1]GROPRI(nolign -1) * 100
  When 4 : [M:SDH1]YGROPRI(nolign -1) = [M:SDH1]GROPRI(nolign -1) * 1000
Endcase
Affzo [M:SDH1]YGROPRI(nolign -1)

End
######################################################################################
## YA034 - Tipo precio en Ventas
######################################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR

Case [M:SDH1]YTIPPRI(nolign -1)
  When 1 : [M:SDH1]YGROPRI(nolign -1) = [M:SDH1]GROPRI(nolign -1)
  When 2 : [M:SDH1]YGROPRI(nolign -1) = [M:SDH1]GROPRI(nolign -1) * 10
  When 3 : [M:SDH1]YGROPRI(nolign -1) = [M:SDH1]GROPRI(nolign -1) * 100
  When 4 : [M:SDH1]YGROPRI(nolign -1) = [M:SDH1]GROPRI(nolign -1) * 1000
Endcase
Affzo [M:SDH1]YGROPRI(nolign -1)

End
######################################################################################
## YA034 - Tipo precio en Ventas
######################################################################################
Subprog AM_YGROPRI(VALEUR)
Variable Decimal VALEUR
Variable Decimal PRECIO

  Case [M:SDH1]YTIPPRI(nolign -1)
    When 1 : PRECIO  = VALEUR
    When 2 : PRECIO  = VALEUR / 10
    When 3 : PRECIO  = VALEUR / 100
    When 4 : PRECIO  = VALEUR / 1000
  Endcase

  # Actualizamos el campo standard
  [M:SDH1]GROPRI(nolign -1) = PRECIO
  Affzo [M:SDH1]GROPRI(nolign -1)


  # Llamamos a las funciones del campo GROPRI, como si se hubiese modificdo en pantalla
  # Como no hay funciones, tengo que replicar el código

  #La acción es DIVDISCRG, pero llama al punto D_DISCRG
      Local Char    WABMSK    :    WABMSK="SDH1"
      Local Integer DISCRGNUM :    DISCRGNUM = 0
      Local Integer NOLIG     :    NOLIG=nolign-1

      If DISCRGNUM > 0 & DISCRGNUM < 10
         Assign "[M:"+WABMSK+"]DISCRGREN"+num$(DISCRGNUM)+"(NOLIG)" With GDACMANSAL
      Elsif DISCRGNUM = 0
         Assign "[M:"+WABMSK+"]PRIREN(NOLIG)" With GDACMANSAL
      Endif



  #Para suplir la acción DIVPRIPFM, llamamos a los siguientes subprogramas
  # --> Calcul du prix net
  Call CLCNETPRI([M]QTY(nolign-1),[M]CUR,nolign-1) From TRTVENPRI
  If GDACLOK = 1
      Call CTLNETPRI([M]BPCORD,[M]CHGTYP,[M]SHIDAT,[M]CUR,nolign-1) From TRTVENPRI
      If mkstat=2 [M]SAUSTUCOE(NOL)=WANC_SAUSTUCOE : End : Endif
  Endif
  # --> Calcul de la marge
  Call CLCPFM([M]STOFCY,[M]PRITYP,[M]CHGTYP,[M]SHIDAT,[M]CUR,nolign-1,2) From TRTVENPRI
  If GDACLOK = 1
      Call CTLPFM([M]CUR,[M]CPRPRI(nolign-1), nolign-1) From TRTVENPRI
      If mkstat=2 [M]SAUSTUCOE(nolign-1)=WANC_SAUSTUCOE : End : Endif
  Endif

  Affzo [M:SDH1]GROPRI(nolign-1)
  If dim([M]DISCRGVAL1(nolign-1))>0 Affzo [M:SDH1]DISCRGVAL1(nolign-1) Endif
  If dim([M]DISCRGVAL2(nolign-1))>0 Affzo [M:SDH1]DISCRGVAL2(nolign-1) Endif
  If dim([M]DISCRGVAL3(nolign-1))>0 Affzo [M:SDH1]DISCRGVAL3(nolign-1) Endif
  If dim([M]DISCRGVAL4(nolign-1))>0 Affzo [M:SDH1]DISCRGVAL4(nolign-1) Endif
  If dim([M]DISCRGVAL5(nolign-1))>0 Affzo [M:SDH1]DISCRGVAL5(nolign-1) Endif
  If dim([M]DISCRGVAL6(nolign-1))>0 Affzo [M:SDH1]DISCRGVAL6(nolign-1) Endif
  If dim([M]DISCRGVAL7(nolign-1))>0 Affzo [M:SDH1]DISCRGVAL7(nolign-1) Endif
  If dim([M]DISCRGVAL8(nolign-1))>0 Affzo [M:SDH1]DISCRGVAL8(nolign-1) Endif
  If dim([M]DISCRGVAL9(nolign-1))>0 Affzo [M:SDH1]DISCRGVAL9(nolign-1) Endif
  Affzo [M:SDH1]NETPRI(nolign-1), CPRPRI(nolign-1), PFM(nolign-1)


End
######################################################################################







