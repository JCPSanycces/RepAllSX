#<AdxTL>@(#)0.0.0.0 $Revision:   1.11  $ Gestion du masque CALGAS
#ACV#X11
#TIT#Gestion objet CAS

GBIDC1=""
GBIDC2=""
Call OBJET("CAS",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires CAS
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
 When "SETBOUT"     : Gosub SETBOUT      From SPVOBJCAS
 When "EXEBOUT"     : Gosub EXEBOUT      From SPVOBJCAS
 When "SEL_LISTE"   : Gosub SEL_LISTE    From SPVOBJCAS
Endcase

Return


########################################
Subprog C_HFIN(VALEUR)
Variable Char    VALEUR()
Local Integer I,NUMERO

[L]NUMERO=nolign-1

If VALEUR < [M]HDEB(nolign-1) : GMESSAGE = mess(44,199,1) : mkstat = 1 : End : Endif

For I=0 To [M:CAS1]BASTAB-1
    If I<>[L]NUMERO & [M:CAS1]CALDAT([L]NUMERO)=[M:CAS1]CALDAT(I) 
&      & ((VALEUR>[M:CAS1]HDEB(I) & VALEUR<=[M:CAS1]HFIN(I)) | ([M:CAS1]HDEB([L]NUMERO)<[M:CAS1]HDEB(I) & VALEUR>[M:CAS1]HFIN(I)))
        GMESSAGE=("Chevauchement d'horaire pour cette date")
        mkstat=2
        Break
    Endif
Next

End


########################################
Subprog C_CALDAT(VALEUR)
Variable Date    VALEUR

If VALEUR<[M:CAS1]STRDAT | VALEUR>[M:CAS1]ENDDAT
    GMESSAGE="Date non comprise dans la semaine"
    mkstat=2
Endif

End

########################################
Subprog C_HDEB(VALEUR)
Variable Char    VALEUR()
Local Integer I,NUMERO

[L]NUMERO=nolign-1

For I=0 To [M:CAS1]BASTAB-1
    If I<>[L]NUMERO & [M:CAS1]CALDAT([L]NUMERO)=[M:CAS1]CALDAT(I) & VALEUR>=[M:CAS1]HDEB(I) & VALEUR<[M:CAS1]HFIN(I)
        GMESSAGE=("Heure de début impossible pour cette date")
        mkstat=2
        Break
    Endif
Next
End

########################################
Subprog AV_PERTIM(VALEUR)
Variable Char VALEUR
Local Decimal NBMINUTE

[L]NBMINUTE=(int(val([M:CAS1]HFIN(nolign-1))/100)*60+mod(val([M:CAS1]HFIN(nolign-1)),100))
&           -(int(val([M:CAS1]HDEB(nolign-1))/100)*60+mod(val([M:CAS1]HDEB(nolign-1)),100))

VALEUR=num$(format$("N0:4#",int([L]NBMINUTE/60)*100+mod([L]NBMINUTE,60)))
End

########################################
Subprog D_CALDESSHO(VALEUR)
Variable Char     VALEUR
VALEUR=[M:CAS1]CALDES
End


########################################
Subprog D_WEENUM(VALEUR)
Variable Char    VALEUR()

VALEUR=num$(week(date$))
End

########################################
Subprog D_YEANUM(VALEUR)
Variable Decimal VALEUR

VALEUR=year(date$)
End

########################################
Subprog AP_YEANUM(VALEUR)
Variable Decimal VALEUR

[M]STRDAT=aweek(val([M]WEENUM),VALEUR)
[M]ENDDAT=[M]STRDAT+6
If ![V]GIMPORT
    Affzo [M]STRDAT,ENDDAT
Endif
End

