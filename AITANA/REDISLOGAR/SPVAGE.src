#---------------------------------------
Subprog AS_WEE(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
  VALEUR=week(date$)
Endif
End


#---------------------------------------
Subprog C_WEE(VALEUR)
Variable Decimal VALEUR

Local Char ZCH(200)

If VALEUR<1 | VALEUR>53
  mkstat=1
Elsif VALEUR=53 & dayn(1,1,[M]YEA+1)<5
  [V]GMESSAGE="Saisir en semaine 1"-num$([M]YEA+1)
  [V]GERR=1
  mkstat=1
Else
  # LBORN 22/10/2004 - Pb lecture Sem 53
  [M:AGE0]DATBEG=aweek(VALEUR,[M:AGE0]YEA)
  [M:AGE0]DATEND=aweek(VALEUR+1,[M:AGE0]YEA)-1
  # Stockage de la date dans chaque onglet
  Local Integer I
  For [L]I=0 To 6
    Assign "[M:AGE"+num$([L]I+2)+"]ZDAY" With [M:AGE0]DATBEG+[L]I
    Call DESIGDAY([L]ZCH,[M:AGE0]DATBEG+[L]I) From SPVOBJAGE
    Assign "[M:AGE"+num$([L]I+2)+"]DESIGDAY" With [L]ZCH
  Next
  Gosub TIT_ONGLET From SPVOBJAGE
  Affzo [M:AGE2]10
  Affzo [M:AGE3]10
  Affzo [M:AGE4]10
  Affzo [M:AGE5]10
  Affzo [M:AGE6]10
  Affzo [M:AGE7]10
  Affzo [M:AGE8]10
Endif

End


#---------------------------------------
Subprog AS_YEA(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
  VALEUR=year(date$)
Endif
End


