#--------------------------------------------------------------------------------------
# Etiquettes/Subprog divers
#--------------------------------------------------------------------------------------
Subprog AV_VS(VALEUR,ZNUM)
Variable Char    VALEUR()
Value Integer ZNUM
If [L]ZNUM>[V]GXNBRS
  VALEUR=""
Else
  Read [F:SHL]SHL1=[V]GXPLAN;[M:AGE0]VP1;[M:AGE0]VP2;[M:AGE0]VP3
  If !fstat
    VALEUR=evalue("[F:SHL]VS"+num$([L]ZNUM))
  Else
    VALEUR=""
  Endif
Endif
End

Subprog AV_VD(VALEUR,ZNUM)
Value Integer ZNUM
Variable Char    VALEUR()
If [L]ZNUM>[V]GXNBR
  VALEUR=""
Else
  Case [L]ZNUM
    When 1 : Read [F:SHL]SHL1(2)=[V]GXPLAN;[M:AGE0]VP1
    When 2 : Read [F:SHL]SHL1(3)=[V]GXPLAN;[M:AGE0]VP1;[M:AGE0]VP2
    When 3 : Read [F:SHL]SHL1=[V]GXPLAN;[M:AGE0]VP1;[M:AGE0]VP2;[M:AGE0]VP3
  Endcase
  If !fstat
    VALEUR=evalue("[F:SHL]VD"+num$([L]ZNUM))
  Else
    VALEUR=""
  Endif
Endif
End


$DEF_MSK
Local Integer ZMSK, ZNBLIG, ZNBLIG1, ZNBLIG2, ZNBLIG3, ZNBLIG4, ZNBLIG5, ZNBLIG6, ZNBLIG7
[L]ZMSK=[L]ZM-[M:AGE0]DATBEG+2
Case [L]ZMSK
  When 2 : [L]ZNBLIG=[M:AGE2]NBLUN 
  When 3 : [L]ZNBLIG=[M:AGE3]NBMAR 
  When 4 : [L]ZNBLIG=[M:AGE4]NBMER 
  When 5 : [L]ZNBLIG=[M:AGE5]NBJEU 
  When 6 : [L]ZNBLIG=[M:AGE6]NBVEN 
  When 7 : [L]ZNBLIG=[M:AGE7]NBSAM 
  When 8 : [L]ZNBLIG=[M:AGE8]NBDIM 
Endcase
[L]ZNBLIG1=[M:AGE2]NBLUN
[L]ZNBLIG2=[M:AGE3]NBMAR
[L]ZNBLIG3=[M:AGE4]NBMER
[L]ZNBLIG4=[M:AGE5]NBJEU
[L]ZNBLIG5=[M:AGE6]NBVEN
[L]ZNBLIG6=[M:AGE7]NBSAM
[L]ZNBLIG7=[M:AGE8]NBDIM
Return


Subprog AVANT_NBLIG(ZJ)
Value Integer ZJ

Gosub REFRAICH

Local Integer I, J, ZL
Local Date ZM
If status=75
  [M]BEGDATO(nolign-1)=[M]BEGDAT(nolign-1)
  [M]ENDDATO(nolign-1)=[M]ENDDAT(nolign-1)
  [M]FLGM(nolign-1)=0
Elsif status=65 & [M]BEGDAT(nolign-1)<>[M]ENDDAT(nolign-1)
  [L]ZL=nolign-1
  [L]ZM=[M]ZDAY
  Gosub DEF_MSK
  For [L]I=1 To 7
    If [L]I<>[L]ZMSK-1
      For [L]J=1 To evalue("[L]ZNBLIG"+num$([L]I))
        If evalue("[M:AGE"+num$([L]I+1)+"]CHRONO([L]J-1)")=[M]CHRONO([L]ZL)
          Case [L]I
            When 1 : Dela [L]J-1,1 [M:AGE2]NBLUN : [M:AGE2]NBLUN-=1 : If !GIMPORT : Affzo [M:AGE2] : Endif
            When 2 : Dela [L]J-1,1 [M:AGE3]NBMAR : [M:AGE3]NBMAR-=1 : If !GIMPORT : Affzo [M:AGE3] : Endif 
            When 3 : Dela [L]J-1,1 [M:AGE4]NBMER : [M:AGE4]NBMER-=1 : If !GIMPORT : Affzo [M:AGE4] : Endif
            When 4 : Dela [L]J-1,1 [M:AGE5]NBJEU : [M:AGE5]NBJEU-=1 : If !GIMPORT : Affzo [M:AGE5] : Endif
            When 5 : Dela [L]J-1,1 [M:AGE6]NBVEN : [M:AGE6]NBVEN-=1 : If !GIMPORT : Affzo [M:AGE6] : Endif
            When 6 : Dela [L]J-1,1 [M:AGE7]NBSAM : [M:AGE7]NBSAM-=1 : If !GIMPORT : Affzo [M:AGE7] : Endif
            When 7 : Dela [L]J-1,1 [M:AGE8]NBDIM : [M:AGE8]NBDIM-=1 : If !GIMPORT : Affzo [M:AGE8] : Endif
          Endcase
          [L]J-=1
        Endif
      Next
    Endif
  Next
Else
  Raz [M]BEGDATO(nolign-1),[M]ENDDATO(nolign-1),[M]FLGM(nolign-1)
Endif
End

$REFRAICH
# Suite déclenchement auto des init après Gosub RELIT
Local Integer ZNBLIG
Case [L]ZJ
  When 1 : [L]ZNBLIG=[M:AGE2]NBLUN 
  When 2 : [L]ZNBLIG=[M:AGE3]NBMAR 
  When 3 : [L]ZNBLIG=[M:AGE4]NBMER 
  When 4 : [L]ZNBLIG=[M:AGE5]NBJEU 
  When 5 : [L]ZNBLIG=[M:AGE6]NBVEN 
  When 6 : [L]ZNBLIG=[M:AGE7]NBSAM 
  When 7 : [L]ZNBLIG=[M:AGE8]NBDIM 
Endcase
If nolign>[L]ZNBLIG
  If [M]BEGHOUJ(nolign-1)<>"" : Effzo [M]BEGHOUJ(nolign-1) : Endif
  If [M]ENDHOUJ(nolign-1)<>"" : Effzo [M]ENDHOUJ(nolign-1) : Endif
  If [M]CODICO(nolign-1)<>""  : Effzo [M]CODICO(nolign-1)  : Endif
  If [M]CODCOL(nolign-1)<>""  : Effzo [M]CODCOL(nolign-1)  : Endif
  If [M]COMMENT(nolign-1)<>"" : Effzo [M]COMMENT(nolign-1) : Endif
  Raz [F:OPE]
Endif
Return


Subprog C_NBLIG
If status=65
  If [M]BEGDAT(nolign-1)<>[M]ENDDAT(nolign-1)
    Gosub MSG_ANNUL
  Endif
Endif
End

$MSG_ANNUL

[V]GMESSAGE="Attention !\Cet évènement est présent dans d'autres onglets.\Annulation des lignes du"-format$("D:DD[/]MM[/]YYYY",[M]BEGDAT(nolign-1))
[V]GMESSAGE-="au"-format$("D:DD[/]MM[/]YYYY",[M]ENDDAT(nolign-1))-"dans les autres onglets."

# Point d'entrée pour modifier éventuellement le message
GPOINT="AMZ_AVBLIG" : Gosub ENTREE From EXEFNC
If [V]GMESSAGE<>""
  GSTATUS=1 : Call AVERTIR([V]GMESSAGE,GSTATUS) From GESECRAN
  [V]GMESSAGE=""
  If GSTATUS<>2 : mkstat=1 : Endif
Endif
Return



Subprog APRES_NBLIG
If status<>65 : End : Endif
Local Integer I, J, ZMSK, ZLIG, ZNBLIG
[L]ZMSK=[M]ZDAY-[M:AGE0]DATBEG+2
[L]ZLIG=nolign
Raz [M:AGE1]
Case [L]ZMSK-2
  When 0 : [M:AGE2]NBLUN-=1
  When 1 : [M:AGE3]NBMAR-=1
  When 2 : [M:AGE4]NBMER-=1
  When 3 : [M:AGE5]NBJEU-=1
  When 4 : [M:AGE6]NBVEN-=1
  When 5 : [M:AGE7]NBSAM-=1
  When 6 : [M:AGE8]NBDIM-=1
Endcase
For [L]I=0 To 6
  Case [L]I
    When 0 : [L]ZNBLIG=[M:AGE2]NBLUN : Default Mask [M:AGE2]
    When 1 : [L]ZNBLIG=[M:AGE3]NBMAR : Default Mask [M:AGE3]
    When 2 : [L]ZNBLIG=[M:AGE4]NBMER : Default Mask [M:AGE4]
    When 3 : [L]ZNBLIG=[M:AGE5]NBJEU : Default Mask [M:AGE5]
    When 4 : [L]ZNBLIG=[M:AGE6]NBVEN : Default Mask [M:AGE6]
    When 5 : [L]ZNBLIG=[M:AGE7]NBSAM : Default Mask [M:AGE7]
    When 6 : [L]ZNBLIG=[M:AGE8]NBDIM : Default Mask [M:AGE8]
  Endcase
  For [L]J=0 To [L]ZNBLIG-1
    nolign=[L]J+1
    [F:AGD]=[M]
    nolign=[M:AGE1]NBSEM+1
    [M:AGE1]DATSEM([M:AGE1]NBSEM)=[M:AGE0]DATBEG+[L]I
    [M:AGE1]DAYSEM([M:AGE1]NBSEM)=day$([M:AGE0]DATBEG+[L]I)-num$(day([M:AGE0]DATBEG+[L]I))
    [M:AGE1]=[F:AGD]
    [M:AGE1]BEGHOUJ(nolign-1)=[M]BEGHOUJ([L]J)
    [M:AGE1]ENDHOUJ(nolign-1)=[M]ENDHOUJ([L]J)
    [M:AGE1]NBSEM+=1
  Next
Next
Case [L]ZMSK-2
  When 0 : Default Mask [M:AGE2]
  When 1 : Default Mask [M:AGE3]
  When 2 : Default Mask [M:AGE4]
  When 3 : Default Mask [M:AGE5]
  When 4 : Default Mask [M:AGE6]
  When 5 : Default Mask [M:AGE7]
  When 6 : Default Mask [M:AGE8]
Endcase

# Zone fichier RTF
nolign=0
Call GENRTF([L]ZMSK-1) From SPVOBJAGE

Case [L]ZMSK-2
  When 0 : [M:AGE2]NBLUN+=1
  When 1 : [M:AGE3]NBMAR+=1
  When 2 : [M:AGE4]NBMER+=1
  When 3 : [M:AGE5]NBJEU+=1
  When 4 : [M:AGE6]NBVEN+=1
  When 5 : [M:AGE7]NBSAM+=1
  When 6 : [M:AGE8]NBDIM+=1
Endcase
nolign=[L]ZLIG

Affzo [M:AGE1]
End

Subprog IB_NBLIG
If nolign<1
  Raz [V]GBOUT1,[V]GBOUT5
Else
  If [M]REQNUM(nolign-1)=""
    [V]GBOUT1=""
  Endif
  If [M]ICOTYP(nolign-1)=0
    [V]GBOUT5=""
  Endif
Endif
End


