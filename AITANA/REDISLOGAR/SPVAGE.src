#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du masque SCHGAS0
#ACV#X13
#TIT#Gestion de l'objet AGE

#LBO 09/2002

#--------------------------------------------------------------------------------------------
# Pour info, si la même modificaction est à faire dans chaque onglet (tous les jours de la semaine)
# l'ajouter seulement dans l'écran SCHAGE2 et lancer le traitement XMAJMSKVP pour mettre à jour automatiquement
# les autres onglets.
# Les zones spécifiques ajoutées doivent également être présentes dans l'écran SCHGASTMP.
#--------------------------------------------------------------------------------------------


GBIDC1=""
GBIDC2=""
Call OBJET("AGE",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION

# Appel fonctions complémentaires AGE
Gosub ACTION From XOBJSPE
If GPE=1 : Return : Endif

Case ACTION
  When "AVANT_MOD"   : Gosub AVANT_MOD   From SPVOBJAGE
  When "VERROU"      : Gosub VERROU      From SPVOBJAGE
  When "TITRE"       : Gosub TIT         From SPVOBJAGE
  When "AVANT_OUVRE" : Gosub AVANT_OUVRE From SPVOBJAGE
  When "OUVRE"       : Gosub OUVRE       From SPVOBJAGE
  When "OUVRE_BOITE" : Gosub OUVRE_BOITE From SPVOBJAGE
  When "SETBOUT"     : Gosub SETBOUT     From SPVOBJAGE
  When "EXEBOUT"     : Gosub EXEBOUT     From SPVOBJAGE
  When "FILTRE"      : Gosub FILTRE      From SPVOBJAGE
  When "FILGAUCHE"   : Gosub FILGAUCHE   From SPVOBJAGE
  When "RAZCRE"      : Gosub RAZCRE      From SPVOBJAGE
  When "RAZDUP"      : Gosub RAZDUP      From SPVOBJAGE
  When "LIENS"       : Gosub LIENS       From SPVOBJAGE
  When "CREATION"    : Gosub CREATION    From SPVOBJAGE
  When "MODIF"       : Gosub MODIF       From SPVOBJAGE
  When "APRES_CRE"   : Gosub APRES_CRE   From SPVOBJAGE
  When "APRES_MOD"   : Gosub APRES_MOD   From SPVOBJAGE
  When "FERME"       : Gosub FERME       From SPVOBJAGE
  When "SEL_LISTE"   : Gosub SEL_LISTE   From SPVOBJAGE
  When "VERF_LISTE"  : Gosub VERF_LISTE  From SPVOBJAGE
  When "SEL_TABLE"   : Gosub SEL_TABLE   From SPVOBJAGE
  When "FIN_TABLE"   : Gosub FIN_TABLE   From SPVOBJAGE
Endcase

Return


#####################################################################################
# Ecran SCHAGE0 [AGE0]
#####################################################################################

#---------------------------------------
Subprog AV_SVPRUB(VALEUR)
Variable Decimal VALEUR
Read [F:SHL]SHL1=[V]GXPLAN;[M:AGE0]VP1;[M:AGE0]VP2;[M:AGE0]VP3
If !fstat
  VALEUR=[F:SHL]NUMSVP
Else
  VALEUR=0
Endif
End

#---------------------------------------
Subprog AV_CODCHO(VALEUR)
Variable Char    VALEUR()
Read [F:SHL]SHL1=[V]GXPLAN;[M:AGE0]VP1;[M:AGE0]VP2;[M:AGE0]VP3
If !fstat
  Read [F:SRC]SRC1=[V]GXPLAN;[F:SHL]CODCHO
  If fstat
    Call ERREUR("Pb lecture SCHPARGASC dans Subprog AV_CODCHO du Trt SPEAGE") From GESECRAN
    Raz [F:SRC]
  Else
    VALEUR=[F:SRC]CODCHO
  Endif
Else
  Call ERREUR("Pb lecture SCHLIGGAS dans Subprog AV_CODCHO du Trt SPEAGE") From GESECRAN
Endif
End


