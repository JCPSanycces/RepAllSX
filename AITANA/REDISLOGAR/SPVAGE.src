#---------------------------------------
Subprog IB_NBSEM
If [M:AGE1]REQNUM(nolign-1)=""
  [V]GBOUT1=""
Endif
End

#---------------------------------------
Subprog AV_SEMFIC(VALEUR)
Variable Char    VALEUR()
Call FICNAM([M:AGE0]PLANCOD,VALEUR) From SPVOBJAGE
End


#---------------------------------------
Subprog AV_DAYSEM(VALEUR)
Variable Char    VALEUR()
If [M:AGE1]DATSEM(nolign-1)=date$
  pcolor=GCOUL(1)
Else
  pcolor=GCOUL(0)
Endif
End




#####################################################################################
# Ecrans [AGE2],[AGE3],[AGE4],[AGE5],[AGE6],[AGE7] et [AGE8]
#####################################################################################

#---------------------------------------
Subprog AS_BEGHOUJ(VALEUR)
Variable Char    VALEUR()
If ([M]ZDAY<>[M]BEGDAT(nolign-1) & [M]BEGDAT(nolign-1)<>[0/0/0])
& | ([M]ICOTYP(nolign-1)=1 & [M]CODICO(nolign-1)<>"")
  mkstat=2
Elsif VALEUR=""
  Gosub LEC_CODCHO From SPVOBJAGE
  If [F:SRC]DAYTRA(dayn([M]ZDAY)-1)=2
    VALEUR=[F:SRC]HDAM(dayn([M]ZDAY)-1)
  Elsif [V]XMORBEG<>""
    VALEUR=ctrans([V]XMORBEG,":","")
  Endif
Endif
End



#---------------------------------------
Subprog AS_ENDHOUJ(VALEUR)
Variable Char    VALEUR()
If ([M]ZDAY<>[M]ENDDAT(nolign-1) & [M]ENDDAT(nolign-1)<>[0/0/0])
& | ([M]ICOTYP(nolign-1)=1 & [M]CODICO(nolign-1)<>"")
  mkstat=2
Elsif VALEUR=""
  Gosub LEC_CODCHO From SPVOBJAGE
  If [F:SRC]DAYTRA(dayn([M]ZDAY)-1)=2 & [F:SRC]HFPM(dayn([M]ZDAY)-1)>[M]BEGHOUJ(nolign-1) 
    VALEUR=[F:SRC]HFPM(dayn([M]ZDAY)-1)
  Else
    If [V]XAFTEND<>"" & ctrans([V]XAFTEND,":","")>[M]BEGHOUJ(nolign-1)
      VALEUR=ctrans([V]XAFTEND,":","")
    Endif
  Endif
Endif
End

#---------------------------------------
Subprog C_BEGHOUJ(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,".")
  mkstat=1 : End
Elsif VALEUR=""
  Gosub LEC_CODCHO From SPVOBJAGE
  If [F:SRC]DAYTRA(dayn([M]ZDAY)-1)=2 & [F:SRC]HDAM(dayn([M]ZDAY)-1)<>""
    VALEUR=[F:SRC]HDAM(dayn([M]ZDAY)-1)
  Elsif [V]XMORBEG<>""
    VALEUR=ctrans([V]XMORBEG,":","")
  Endif
Endif
If val(VALEUR)>=val([M]ENDHOUJ(nolign-1)) & val(VALEUR)<>0 & val([M]ENDHOUJ(nolign-1))<>0
& & (([M]ZDAY<>[M]ENDDAT(nolign-1) & [M]ENDDAT(nolign-1)<>[0/0/0])
& |  ([M]ICOTYP(nolign-1)=1 & [M]CODICO(nolign-1)<>""))
  [V]GMESSAGE="Heure de début > Heure de fin"
  [V]GERR=3
Endif
End

#---------------------------------------
Subprog AM_BEGHOUJ(VALEUR)
Variable Char    VALEUR()
[M]BEGHOU(nolign-1)=VALEUR
If !GIMPORT : Affzo [M]BEGHOU(nolign-1) : Endif
Call ZONMODIF From SPVOBJAGE
End


#---------------------------------------
Subprog C_ENDHOUJ(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,".") : mkstat=1 : End : Endif
If val(VALEUR)<=val([M]BEGHOUJ(nolign-1)) & VALEUR<>""
  [V]GMESSAGE="Heure de début > Heure de fin"
  [V]GERR=3
Elsif VALEUR=""
  Gosub LEC_CODCHO From SPVOBJAGE
  If [F:SRC]DAYTRA(dayn([M]ZDAY)-1)=2 & [F:SRC]HFPM(dayn([M]ZDAY)-1)>[M]BEGHOUJ(nolign-1) 
    VALEUR=[F:SRC]HFPM(dayn([M]ZDAY)-1)
  Else
    If [V]XAFTEND<>"" & ctrans([V]XAFTEND,":","")>[M]BEGHOUJ(nolign-1)
      VALEUR=ctrans([V]XAFTEND,":","")
    Else
      VALEUR="2359"
    Endif
  Endif
Endif
End


#---------------------------------------
Subprog AM_ENDHOUJ(VALEUR)
Variable Char    VALEUR()
[M]ENDHOU(nolign-1)=VALEUR
If !GIMPORT : Affzo [M]ENDHOU(nolign-1) : Endif
Call ZONMODIF From SPVOBJAGE
End


#---------------------------------------
Subprog AS_BEGDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
VALEUR=[M]ZDAY
End

#---------------------------------------
Subprog C_BEGDAT(VALEUR)
Variable Date    VALEUR
If VALEUR>[M]ZDAY
  mkstat=1
Elsif [M]CODICO(nolign-1)=""
  Gosub DEF_ICO
Endif
End


#---------------------------------------
Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
VALEUR=[M]ZDAY
End

#---------------------------------------
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]BEGDAT(nolign-1)
  mkstat=1
Elsif VALEUR=[M]BEGDAT(nolign-1) & [M]ZDAY<>VALEUR
  [V]GMESSAGE="Evènement à saisir au"-format$("DD:DD[/]MM[/]YYYY",VALEUR)
  mkstat=1
Elsif VALEUR<[M]ZDAY
  mkstat=1
Else
  If [M]CODICO(nolign-1)=""
    Gosub DEF_ICO
  Endif
  Gosub MSG_MODIF
Endif
End

$MSG_MODIF
# Message d'avertissement pour prévenir l'utilisateur que l'évènement de plusieurs jours a été modifié
If [M]BEGDATO(nolign-1)<>[0/0/0] & (VALEUR<>[M]ZDAY | [M]BEGDAT(nolign-1)<>[M]ZDAY)
& & ([M]FLGM(nolign-1)=2
& | [M]ENDDAT(nolign-1)<>VALEUR 
& | [M]BEGDATO(nolign-1)<>[M]BEGDAT(nolign-1)
& | [M]ENDDATO(nolign-1)<>VALEUR)

  [V]GMESSAGE="Attention !\Cet évènement a été modifié.\Mise à jour des lignes du"-format$("D:DD[/]MM[/]YYYY",[M]BEGDAT(nolign-1))
  [V]GMESSAGE-="au"-format$("D:DD[/]MM[/]YYYY",VALEUR)-"dans les autres onglets."

  # Point d'entrée pour modifier éventuellement le message
  GPOINT="AMZ_APNBLIG" : Gosub ENTREE From EXEFNC
  If [V]GMESSAGE<>"" & !mkstat
    GSTATUS=1 : Call AVERTIR([V]GMESSAGE,GSTATUS) From GESECRAN
    [V]GMESSAGE=""
    If GSTATUS<>2 : mkstat=2 : Endif
  Endif
Endif
Return

#---------------------------------------
Subprog AM_CODICO(VALEUR)
Variable Char    VALEUR()
Local Integer SVGICOTYP
If VALEUR<>""
  Filter [F:SHI] Where [F:SHI]PLANCOD=[M:AGE0]PLANCOD & ([F:SHI]NUMSVP<>0 | [F:SHP]SYNFLG<>2) & [F:SHI]ICOSTA<=1
  Read [F:SHI]SHI0(2)=[M:AGE0]PLANCOD;VALEUR
  If fstat
    [V]GMESSAGE=mess(23,100,1)
    mkstat=1
  Else
    [L]SVGICOTYP=[M]ICOTYP(nolign-1)
    [M]SVPICO(nolign-1)=[F:SHI]NUMSVP
    [M]ICOTYP(nolign-1)=[F:SHI]ICOTYP
    [M]ICOWKD(nolign-1)=[F:SHI]ICOWKD
    Call ZONMODIF From SPVOBJAGE
    Case [F:SHI]ICOTYP
      When 1 : # Jour
        [M]BEGHOU(nolign-1)="0000"
        [M]ENDHOU(nolign-1)="2359"
        [M]BEGHOUJ(nolign-1)="0000"
        [M]ENDHOUJ(nolign-1)="2359"
        If [F:SHI]ICOWKD=2
          Gosub LEC_CODCHO From SPVOBJAGE
          If [F:SRC]DAYTRA(dayn([M]ZDAY)-1)=2
            [M]BEGHOUJ(nolign-1)=[F:SRC]HDAM(dayn([M]ZDAY)-1)
            [M]ENDHOUJ(nolign-1)=[F:SRC]HFPM(dayn([M]ZDAY)-1)
          Else
            If [V]XMORBEG<>""
              [M]BEGHOUJ(nolign-1)=ctrans([V]XMORBEG,":","")
            Endif
            If [V]XAFTEND<>"" & ctrans([V]XAFTEND,":","")>[M]BEGHOUJ(nolign-1)
              [M]ENDHOUJ(nolign-1)=ctrans([V]XAFTEND,":","")
            Endif
          Endif
        Endif
        Affzo [M]BEGHOUJ(nolign-1),ENDHOUJ(nolign-1), BEGHOU(nolign-1), ENDHOU(nolign-1)
    Endcase
  Endif
  Filter [F:SHI]
Else
  Gosub DEF_ICO
  Call ZONMODIF From SPVOBJAGE
Endif
End

$DEF_ICO
[M]SVPICO(nolign-1)=0
[M]ICOWKD(nolign-1)=1 : # Non travaillé
[M]ICOTYP(nolign-1)=3
Return

#---------------------------------------
Subprog C_CODICO(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  If [F:SHP]SYNFLG=2
    [V]GMESSAGE=mess(10,123,1)
    mkstat=1
  Else
    Gosub DEF_ICO
  Endif
Endif
End


#---------------------------------------
Subprog C_CODCOL(VALEUR)
Variable Char    VALEUR()
Filter [F:SHC] Where [F:SHC]PLANCOD=[M:AGE0]PLANCOD & ([F:SHC]SYNFLG<2 | [F:SHP]SYNFLG<>2 | [F:SHC]NUMSVP<>0) & [F:SHC]COLSTA<=1
Read [F:SHC]SHC0(2)=[M:AGE0]PLANCOD;VALEUR
If fstat
  # Ne devrait jamais se produire, contrôlé par type donnée
  [V]GMESSAGE=mess(23,100,1)
  mkstat=1
Else
  [M]SVPCOL(nolign-1)=[F:SHC]NUMSVP
  [M]OPECOD(nolign-1)=[F:SHC]OPECOD
  [M]SYNFLG(nolign-1)=[F:SHC]SYNFLG
  Read [F:OPE]OPE0=[F:SHC]OPECOD
  If fstat : Raz [F:OPE] : Endif
Endif
Filter [F:SHC]
End


#---------------------------------------
Subprog AM_CODCOL(VALEUR)
Variable Char    VALEUR()
If [F:SHP]OPENOT<>""
  Raz [M]COMMENT(nolign-1)
Endif
Call ZONMODIF From SPVOBJAGE
End

#---------------------------------------
Subprog D_COMMENT(VALEUR)
Variable Char    VALEUR()
If instr(1,[F:SHP]OPENOT,"OPEDES")
  Read [F:AXX]AXX0="OPERATION";"OPEDES";GLANGUE;[F:OPE]OPECOD;""
  If !fstat & [F:AXX]TEXTE<>""
    VALEUR=[F:AXX]TEXTE
  Endif
Elsif instr(1,[F:SHP]OPENOT,chr$(34)) | instr(1,[F:SHP]OPENOT,"'") | instr(1,[F:SHP]OPENOT,"[")
  Onerrgo PB_COMMENT
  VALEUR=num$(evalue([F:SHP]OPENOT))
  Onerrgo
Else
  VALEUR=[F:SHP]OPENOT
Endif
End

$PB_COMMENT
[V]GMESSAGE="Initialisation de la note"
[V]GMESSAGE+="\Pb évaluation expression"-[F:SHP]OPENOT
Call ECR_TRACE([V]GMESSAGE,1) From GESECRAN
End


#---------------------------------------
Subprog AV_ZDUR(VALEUR)
Variable Char    VALEUR()

Local Shortint XSTAT
Local Integer  ZDJDEB, ZDJFIN
Local Decimal  ZDUR, ZDUR2

Case [M]ICOTYP(nolign-1)
  When 1 : Call CAL_DURJOU([M:AGE0]PLANCOD,[M:AGE0]CODCHO,[M]BEGDAT(nolign-1),[M]ENDDAT(nolign-1),[M]ICOWKD(nolign-1),[F:SHP]UVYCOD
&                         ,[M]DURDAY(nolign-1),[M]DURHOU(nolign-1),[M]DURMIN(nolign-1)) From XSCHSAIEVT
           VALEUR=num$([M]DURDAY(nolign-1))-"Jr(s)"

  When 2 : Call INIT_HDJ([M]BEGDAT(nolign-1),[M]BEGHOU(nolign-1),[M]ENDDAT(nolign-1),[M]ENDHOU(nolign-1),[L]ZDJDEB,[L]ZDJFIN,[M:AGE0]PLANCOD,[M:AGE0]CODCHO,[L]XSTAT) From XSCHSAIEVT
           If ![L]XSTAT
             Call CAL_DURDJ([M:AGE0]PLANCOD,[M:AGE0]CODCHO,[M]BEGDAT(nolign-1),[L]ZDJDEB,[M]ENDDAT(nolign-1),[L]ZDJFIN,[M]ICOWKD(nolign-1),[F:SHP]UVYCOD
&                          ,[L]ZDUR,[M]DURHOU(nolign-1),[M]DURMIN(nolign-1)) From XSCHSAIEVT
             [M]DURDAY(nolign-1)=[L]ZDUR/2
             VALEUR=num$([M]DURDAY(nolign-1))-"Jr(s)"
           Else
             Raz [M]DURDAY(nolign-1),DURHOU(nolign-1),DURMIN(nolign-1),[L]VALEUR
           Endif
  When 3 : Call CAL_DURH([M:AGE0]PLANCOD,[M:AGE0]CODCHO,[M]BEGDAT(nolign-1),[M]BEGHOU(nolign-1),[M]ENDDAT(nolign-1)
&                       ,[M]ENDHOU(nolign-1),[M]ICOWKD(nolign-1),[F:SHP]UVYCOD,[L]ZDUR,[L]ZDUR2) From XSCHSAIEVT
           VALEUR=num$(ar2([L]ZDUR+[L]ZDUR2/60))-"Hr(s)"
Endcase

End


