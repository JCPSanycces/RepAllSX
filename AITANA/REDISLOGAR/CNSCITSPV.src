#<AdxTL>@(#)3.0.0.0 $Revision$
#ACV#X12
#TIT#Consultation Intervention

#==========================================================================================
# Gestion de la consultation :CIT -- Intervention
#
# Auteur                     : ABRAN
# Date de création           : 26/04/2003
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#------------------------------------------------------------------------------------------
# 15/09/2003    CGUES        Modif appel fonction recherche de texte
#==========================================================================================

    Local Char PARAM(30)(2)
    Call GCONSULT("CIT","",PARAM)From GCONSULT
End


###################################################################
$ACTION

Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
Endcase

Return

#-----------------------------------------------------------------#
#    Gestion des étiquettes liées a ACTION                        #
#-----------------------------------------------------------------#
###################################################################
$AUTORIS
Return

###################################################################
$SETBOUT
Return

###################################################################
$OUVRE
    Local Char CRIT_DS_1(250) , CRIT_DS_2(250) , CRIT_DS_3(250) , CRIT_DS_4(250)
&            , CRIT_ITV_1(250) , CRIT_ITV_4(250)
&            , X_FIC_RETOUR(250) , X_CRIT_ITV_MOT(30)(4)
&            , X_DS_MOT(15)(30000) , X_ITV_MOT(15)(30000) , VIDE
&            , DEBNUM , FINNUM , KEYWORD1(20) , KEYWORD2(20)

    Local Char TYPOBJ :#CGUES
    [L]TYPOBJ="ITV"
    Local Integer TYPTXT(30000)
    Local Date X_CRIT_ITV_DATE(3)

    Local Integer LIGNE , NB_MOT , II
    Local Date X_REQDAT_DEB , X_ITVDAT_DEB , X_DAT_MOT(30000)


    Gosub DEFCRIT
Return


###################################################################
$DEFCRIT

For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre Site
      If PARAM(I) <> "" Then
        If [F:FCY]FCY <> PARAM(I) Then
          Read [F:FCY]FCY0 = PARAM(I)
          If fstat  Raz [F:FCY] : Endif
        Endif
#       If !fstat & ((PARAM(I) = GFCYDEF & GUSRACC(1) <> 0) | (PARAM(I) <> GFCYDEF & GUSRACC(2) <> 0)) Then
          [M:CIT0]FCY = PARAM(I)
          Call GETDEV([M:CIT0]FCY) From DEVSUB
#       Endif
      Endif
    When 2 : # Tiers
      If PARAM(2)<>""
        [M:CIT0]BPCNUM=PARAM(2)
      Endif
  Endcase
Next

If !find([M:CIT0]FLGREQCAN,1,2)  : [M:CIT0]FLGREQCAN  = 2 : Endif
If !find([M:CIT0]FLGREQCANN,1,2) : [M:CIT0]FLGREQCANN = 2 : Endif
If !find([M:CIT0]FLGREQCLO,1,2)  : [M:CIT0]FLGREQCLO  = 2 : Endif
If !find([M:CIT0]FLGREQCLON,1,2) : [M:CIT0]FLGREQCLON = 2 : Endif

If !find([M:CIT0]FLGREQPRN,1,2)  : [M:CIT0]FLGREQPRN  = 2 : Endif
If !find([M:CIT0]FLGREQPRNN,1,2) : [M:CIT0]FLGREQPRNN = 2 : Endif
If !find([M:CIT0]FLGDIR,1,2)     : [M:CIT0]FLGDIR     = 2 : Endif
If !find([M:CIT0]FLGCON,1,2)     : [M:CIT0]FLGCON     = 2 : Endif
If !find([M:CIT0]FLGSIT,1,2)     : [M:CIT0]FLGSIT     = 2 : Endif
If !find([M:CIT0]FLGMAT,1,2)     : [M:CIT0]FLGMAT     = 2 : Endif
If !find([M:CIT0]FLGEXT,1,2)     : [M:CIT0]FLGEXT     = 2 : Endif

# Copie de l'écran critère (CCIT) vers la masque 0 d'entete (CIT0)
Gosub CRITENT From =PROGCNS

Return

###################################################################
$LECTURE
    If [M:CIT0]BEGDAT=[0/0/0]

      NBLU=0

      # LBORN 01/10/2013 - Mantis 20503 - On fait l'init à cet endroit pour ne pas déclencher la lecture au lancement de la consultation (sinon trop de lignes)
      [M:CIT0]BEGDAT=[V]GDATEDEB
      If [V]GDATEFIN>=[M:CIT0]BEGDAT
        [M:CIT0]ENDDAT=[V]GDATEFIN
      Endif

      Return

    Endif

    Gosub CHANGE_MSK From GCONSULT
    If CHGPAG < 0 Then
        NOL = MAXLIG
    Endif

    Call TEMPON("R") From GESECRAN

    # Positionnement des filtres
    Gosub LOAD_FILTER
    # Appel au filtre spécifique client
    ACTION = "FILTRE"
    Gosub ACTION From XOBJCNS
    ACTION = "LECTURE"


    #***********************************#
    # RAPPEL : valeur CHGPAG :          #
    #    1 : Recherche                  #
    #    2 : Suite                      #
    #    3 : F5 (Rafraichissement)      #
    #   -1  : Dernier                   #
    #   -2  : Retour (Page précédente)  #
    #***********************************#
    # Application des filtres
    If CHGPAG > 0 Then
        SUITE = 1
        If CHGPAG = 1 Then
            RETOUR = 1
        Elsif CHGPAG = 2 Then
            RETOUR = 2
        Endif
        Filter [REQ] Where evalue([L]CRIT_DS_1) & evalue([L]CRIT_DS_2) & evalue([L]CRIT_DS_3) & evalue([L]CRIT_DS_4)
&                    Order By Key REQ0 Desc
    Else
        RETOUR = 1
        If CHGPAG = -1 Then
            SUITE = 1
        Else
            SUITE = 2
        Endif
        Filter [REQ] Where evalue([L]CRIT_DS_1) & evalue([L]CRIT_DS_2) & evalue([L]CRIT_DS_3) & evalue([L]CRIT_DS_4)
&                    Order By Key REQ0
    Endif

    # RAZ du masque
    If CHGPAG <> 2 & CHGPAG <> -2 Then
        Raz [M:CIT1]
        Raz [M:CIT2]
    Endif

    If CRIT_MOT<>0
        #--------------------------------------------------------------- partie avec recherche mot
        ## recherche dans la table oracle
        Call RECH_TXT_ORA([L]TYPOBJ,"",X_ITVDAT_DEB,0,X_CRIT_ITV_MOT,X_CRIT_ITV_DATE
&                        ,[L]KEYWORD1,[L]KEYWORD2,X_FIC_RETOUR) From XMAJTXTORA

        ## récup des N°  de DS & d'inter
        adxifs=" "
        adxirs=chr$(10)
        Openi X_FIC_RETOUR Using [RESX]

        NB_MOT=0
        Repeat
            Rdseq [L]TYPOBJ, X_DAT_MOT(NB_MOT) , X_ITV_MOT(NB_MOT), VIDE ,[L]TYPTXT(NB_MOT), VIDE Using [RESX]
            If X_ITV_MOT(NB_MOT)<>""
                Read [ITR]ITR0=X_ITV_MOT(NB_MOT)
                If !fstat
                    X_DS_MOT(NB_MOT)=[F:ITR]REQNUM
                    NB_MOT+=1
                Endif
            Endif
        Until fstat<>0
        Openi Using [RESX]
    Endif
    #--------------------------------------------------------------- recoupement entre mot et les critères
    [M:CIT2]NBLIG2 = 0
    [L]LIGNE = -1

    # Lecture
    For [REQ]
        If (CRIT_MOT<>0 & find([F:REQ]REQNUM,X_DS_MOT(0..[L]NB_MOT))) | CRIT_MOT=0 Then
            NEW_DS=1
            For [ITR]ITR1 Where REQNUM=[F:REQ]REQNUM
&                                &  evalue([L]CRIT_ITV_1)
&                                &  evalue([L]CRIT_ITV_4)
                If (CRIT_MOT<>0 & find([F:ITR]ITVNUM,X_ITV_MOT(0..[L]NB_MOT))) | CRIT_MOT = 0 Then
                    If NBLU = 1 Then
                        If CHGPAG = 2 | CHGPAG = -2 Then
                            Raz [M:CIT1]
                            Raz [M:CIT2]
                        Endif
                        NBLU = 2
                    Endif
                    If CHGPAG > 0 Then
                        If NOL >= MAXLIG-1 Then
                            SUITE = 2
                            Break
                        Endif
                        If NEW_DS=1
                            NOL += 1
                        Endif
                        If NOL = 0 Then
                            DEBNUM = [F:REQ]REQNUM
                        Endif
                        FINNUM = [F:REQ]REQNUM
                    Else
                        If NOL <= 0 Then
                            RETOUR = 2
                            Break
                        Endif
                        If NEW_DS=1
                            NOL -= 1
                        Endif
                        If NOL = MAXLIG-1 Then
                            FINNUM = [F:REQ]REQNUM
                        Endif
                        DEBNUM = [F:REQ]REQNUM
                    Endif


                    If NEW_DS=1
                        NEW_DS=2
                        nolign = NOL+1

                        # Contôle de nolign avec la dimension de la zone à renseigner pour l'onglet détail de la DS
                        If nolign > dim([M:CIT2]REQNUM) Then Break Endif

                        [M:CIT1] = [F:REQ]
                        Read [F:BPR]BPR0 = [F:REQ]BPCNUM
                        If !fstat Then
                            [M:CIT1]BPRNAM(nolign-1) = [F:BPR]BPRNAM     :# Raison sociale
                        Endif

                    Endif

                    #2ème onglet
                    [L]LIGNE += 1

                    [M:CIT2]REQNUM([L]LIGNE)  = [F:REQ]REQNUM
                    [M:CIT2]REQTYP([L]LIGNE)  = [F:REQ]REQTYP
                    [M:CIT2]BPCNUM([L]LIGNE)  = [F:REQ]BPCNUM
                    [M:CIT2]CREADAT([L]LIGNE) = [F:ITR]ITVDAT

                    [M:CIT2]ITVNUM([L]LIGNE)  = [F:ITR]ITVNUM

                    [M:CIT2]NBLIG2 = [L]LIGNE+1
                Endif :# ctrl itvnum % recherche mot
            Next :#itv

        Endif :# ctrl reqnum % recherche mot
    Next :# req

    Affzo [M:CIT2]

    Filter [REQ]

    Call TEMPOFF From GESECRAN
Return


###################################################################
$LOAD_FILTER
    # 1er critere -------------------------------------------------
    [L]CRIT_DS_1    = "1"            :# Critere sur tiers, NumDS, Type DS, Stade DS, File d'attente
    [L]CRIT_ITV_1   = "1"            :# Critere sur Type Inter
    If [M:CIT0]REQNUM<>"" Then
        [L]CRIT_DS_1 += "&[F:REQ]REQNUM=[M:CIT0]REQNUM"
    Endif
    If [M:CIT0]REQTYP<>"" Then
        [L]CRIT_DS_1 += "&[F:REQ]REQTYP=[M:CIT0]REQTYP"
    Endif
    If [M:CIT0]REQSTA<>"" Then
        [L]CRIT_DS_1 += "&[F:REQ]REQSTA=[M:CIT0]REQSTA"
    Endif
    If [M:CIT0]QUEUE<>"" Then
        [L]CRIT_DS_1 += "&[F:REQ]QUEUE=[M:CIT0]QUEUE"
    Endif
    If [M:CIT0]BPCNUM<>"" Then
        [L]CRIT_DS_1 += "&[F:REQ]BPCNUM=[M:CIT0]BPCNUM"
    Endif

    If [M:CIT0]ITVTYP<>"" Then
        [L]CRIT_ITV_1 += "&[F:ITR]ITVTYP=[M:CIT0]ITVTYP"
    Endif
    If [M:CIT0]BEGDAT <> [0/0/0] Then
        [L]CRIT_ITV_1 += "&[F:ITR]ITVDAT>=[M:CIT0]BEGDAT"
    Endif
    If [M:CIT0]ENDDAT <> [0/0/0] Then
        [L]CRIT_ITV_1 += "&[F:ITR]ITVDAT<=[M:CIT0]ENDDAT"
    Endif

    # 2eme critere ----------------------------------------------------
    [L]CRIT_DS_2    = "1"            :# Critere sur bornes de date, Resp DS, Site
    If [M:CIT0]RESINT<>"" Then
        [L]CRIT_DS_2 += "&[F:REQ]RESINT=[M:CIT0]RESINT"
    Endif
    If [M:CIT0]FCY<>"" Then
        [L]CRIT_DS_2 += "&[F:REQ]FCY=[M:CIT0]FCY"
    Endif

    # 3eme critere ----------------------------------------------------
    # Prise en compte de l'origine
    [L]CRIT_DS_3    = "1"            :# Critere sur flag Origine : Directe, Externe, Contrat, Contrat(matériel) ou Situation
    # --> Si 1, on prend origine<>directe
    If [M:CIT0]FLGDIR = 1 Then
        [L]CRIT_DS_3 += "&[F:REQ]ORIREQ<>1"
    Endif
    # --> Si 1, on prend origine<>contrat
    If [M:CIT0]FLGCON = 1 Then
        [L]CRIT_DS_3 += "&[F:REQ]ORIREQ<>2"
    Endif
    # --> Si 1, on prend origine<>situation
    If [M:CIT0]FLGSIT = 1 Then
        [L]CRIT_DS_3 += "&[F:REQ]ORIREQ<>3"
    Endif
    # --> Si 1, on prend origine<>contrat(matériel)
    If [M:CIT0]FLGMAT = 1 Then
        [L]CRIT_DS_3 += "&[F:REQ]ORIREQ<>4"
    Endif
    # --> Si 1, on prend origine<>externe
    If [M:CIT0]FLGEXT = 1 Then
        [L]CRIT_DS_3 += "&[F:REQ]ORIREQ<>5"
    Endif

    # 4eme critere -----------------------------------------------------
    # Prise en compte des flag Annulé, clotûré et imprimé
    [L]CRIT_DS_4    = "1"            :# Critere sur flag Imprimé, Annulé ou Clotûré
    [L]CRIT_ITV_4   = "1"            :# Critere sur flag Imprimé, Annulé des inters
    If [M:CIT0]FLGREQPRN = 1 Then
        [L]CRIT_DS_4 += "&[F:REQ]FLGREQPRN<>2"
        [L]CRIT_ITV_4 += "&[F:ITR]FLGITVPRN<>2"
    Endif
    If [M:CIT0]FLGREQPRNN = 1 Then
        [L]CRIT_DS_4 += "&[F:REQ]FLGREQPRN=2"
        [L]CRIT_ITV_4 += "&[F:ITR]FLGITVPRN=2"
    Endif

    If [M:CIT0]FLGREQCLO = 1 Then
        [L]CRIT_DS_4 += "&[F:REQ]FLGREQCLO<>2"
    Endif
    If [M:CIT0]FLGREQCLON = 1 Then
        [L]CRIT_DS_4 += "&[F:REQ]FLGREQCLO=2"
    Endif

    If [M:CIT0]FLGREQCAN = 1 Then
        [L]CRIT_DS_4 += "&[F:REQ]FLGREQCAN<>2"
        [L]CRIT_ITV_4 += "&[F:ITR]FLGITVCAN<>2"
    Endif
    If [M:CIT0]FLGREQCANN = 1 Then
        [L]CRIT_DS_4 += "&[F:REQ]FLGREQCAN=2"
        [L]CRIT_ITV_4 += "&[F:ITR]FLGITVCAN=2"
    Endif

    # Mot-clé --------------------------------------------------------
    [L]KEYWORD1 = ""       :# Mot-clé 1
    [L]KEYWORD2 = ""       :# Mot-clé 2
    CRIT_MOT=0
    If [M:CIT0]KEYWORD1 <> "" Then
        [L]KEYWORD1 = [M:CIT0]KEYWORD1
        CRIT_MOT+=1
    Endif
    If [M:CIT0]KEYWORD2 <> "" Then
        [L]KEYWORD2 = [M:CIT0]KEYWORD2
        CRIT_MOT+=1
    Endif

    X_CRIT_ITV_MOT(0)  =num$([M:CIT0]REQNUM)        :# N° DS
    X_CRIT_ITV_MOT(1)  =num$([M:CIT0]BPCNUM)        :# Tiers
    X_CRIT_ITV_MOT(2)  =""                          :# Type inter
    X_CRIT_ITV_MOT(3)  =num$([M:CIT0]REQTYP)        :# Type Ds
    Raz [L]X_CRIT_ITV_DATE
    X_REQDAT_DEB =[M:CIT0]BEGDAT               :# date Ds (début)
    X_ITVDAT_DEB =[00/00/0000]                :# Date inter (début)
    # Fichiers des réponses
    X_FIC_RETOUR =filpath("tmp","abran","txt")

    Case CHGPAG
        When 3 : #Rafraichissement
            [L]CRIT_DS_1 += "&[F:REQ]REQNUM>=DEBNUM"
        When 2 : #Suite
            [L]CRIT_DS_1 += "&[F:REQ]REQNUM>FINNUM"
        When -2 : #Retour
            [L]CRIT_DS_1 += "&[F:REQ]REQNUM<DEBNUM"
    Endcase
Return


###################################################################
$FIN_CRIT
Return



    #-----------------------------------------------------------------#
    #    Gestion des étiquettes liées aux masques CRQ0, CRQ1 et CCRQ  #
    #-----------------------------------------------------------------#
                    #-------------------#
                    #        CRQ0       #
                    #-------------------#
###################################################################
Subprog C_KEYWORD1(VALEUR)
    Variable Char     VALEUR
    VALEUR = toupper(VALEUR)
End

###################################################################
Subprog C_KEYWORD2(VALEUR)
    Variable Char     VALEUR
    VALEUR = toupper(VALEUR)
End

                    #-------------------#
                    #        CRQ1       #
                    #-------------------#
###################################################################
Subprog IB_NBLIG
    Raz GBOUT1

    If [M:CIT1]NBLIG <> 0 Then
        GBOUT1 = mess(41,[V]GXMSGPSA,1)    : # DS
    Endif
End

                    #-------------------#
                    #        CRQ2       #
                    #-------------------#
###################################################################
Subprog IB_NBLIG2
    Raz GBOUT1, GBOUT2

    If [M:CIT2]NBLIG2 <> 0 Then
        GBOUT1 = mess(41,[V]GXMSGPSA,1)    : # DS
        GBOUT2 = mess(3,[V]GXMSGPSA,1)     : # Inter
    Endif
End

###################################################################
Subprog AS_NBLIG2
    If [M:CIT2]NBLIG2 <> 0 Then
        Gosub AFF_SUM
        Gosub AFF_ITV
    Endif
End

###################################################################
Subprog C_CREADAT(VALEUR)
    Variable Char     VALEUR

    If [M:CIT2]NBLIG2 <> 0 Then
        Gosub AFF_SUM
        Gosub AFF_ITV
    Endif
End

###################################################################
Subprog AS_REQSUM(VALEUR)
    Variable Char     VALEUR
    mkstat = 2
End

###################################################################
Subprog AS_ITVSUMEXT(VALEUR)
    Variable Char     VALEUR
    mkstat = 2
End

###################################################################
Subprog AS_ITVSUMINT(VALEUR)
    Variable Char     VALEUR
    mkstat = 2
End

###################################################################
$AFF_SUM
    Read [F:REQ]REQ0 = [M:CIT2]REQNUM(nolign - 1)
    If fstat : Raz [F:REQ] : Endif

    [M:CIT2]REQSUM = [F:REQ]REQSUM
    Affzo [M:CIT2]REQSUM
Return

###################################################################
$AFF_ITV
    Read [F:ITR]ITR0 = [M:CIT2]ITVNUM(nolign - 1)
    If fstat : Raz [F:ITR] : Endif

    [M:CIT2]ITVSUMEXT = [F:ITR]ITVTEX1
    [M:CIT2]ITVSUMINT = [F:ITR]ITVTEX2
    Affzo [M:CIT2]ITVSUMEXT , ITVSUMINT
Return
