#<AdxTL>@(#)7.0.0.0 $Revision$
#ACV#X12
#TIT#Validation C.R.A en Lot

Call OBJET("ITL",GBIDC1,GBIDC2)From GOBJET
End

$ACTION
#--- Actions liées au scénarion GTRAITE
Case ACTION
When "INIT"       : Gosub INIT
When "AVANT_PAR"  : Gosub AVANT_PAR
When "CONTROLE"   : Gosub CONTROLE
When "EXEC"       : Gosub EXEC
When "OK"         : Gosub A_OK
When "END"        : Gosub A_END
When "DEBUT"      : Gosub A_DEBUT
Endcase
Return

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$A_OK
FIN = 1
GOK = 1
Return

################################################################################
$A_END
FIN = 1
GOK = 0
Return

################################################################################
$A_DEBUT
Affzo [M]
Return

################################################################################
$INIT
If GSERVEUR
   Onerrgo ERR_BATCH
Endif

Gosub OUVRE

Return

################################################################################
$AVANT_PAR

[L]FLGLOT=val(PARAM(4))
If find(PARAM(4),"0","3")
    TYPPRG=0
Endif
Raz [M]

If PARAM(1)=""
    [M]ALLFCY=2
    [M]FCYBEG=""
Else
    [M]ALLFCY=1
    [M]FCYBEG=PARAM(1)
Endif
[M]ALLCPY=1
[M]ALLOPP=2

If PARAM(2)<>""
    [M]TYPBEG=PARAM(2)
    [M]TYPEND=PARAM(2)
    [M]ALLTYP=1
Else
    [M]ALLTYP=2
Endif

If PARAM(3)<>""
    [M]CRABEG=PARAM(3)
    [M]CRAEND=PARAM(3)
    [M]ALLCRA=1
Else
    [M]ALLCRA=2
Endif

Return

################################################################################
$CONTROLE
If [L]FLGLOT=0
    If GINTRA
        FIN=1 : # car pb de contexte en direct
        Return
    Endif
    [L]OK=2
    Call OUINON(mess(141,[V]GXMSGPSA,1), OK) From GESECRAN
    If OK<>2
        FIN=1
        Return
    Endif
Endif

GPOINT="CONTROLE" : Gosub ENTREE From EXEFNC

If GOK<1
    FIN = 1
Else
    If [M]ALLFCY<>2 & [M]FCYBEG=""
        GERR=1
        GMESSAGE=mess(165,[V]GXMSGPSA,1)
        SAI=1
    Endif
    TMP = 1
Endif
Return

################################################################################
$EXEC
Local Integer XTRASPE : XTRASPE=0
If GTRACE="" Then
    Call OUVRE_TRACE(TIT) From LECFIC
    XTRASPE=1
Endif
[L]XTRACE=filpath("TRA",[V]GTRACE,"tra","","",adxmac(0))

#-- Ecriture des critères de lancements
Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call PRTSCR("XVALLOTCRA","DIA","",0,1) From ATRTX3
Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

###
Gosub VERROU : If FIN=1 Then Call ECR_TRACE([V]GMESSAGE,1)From GESECRAN : Goto FIN_EXEC Endif
Gosub VALIDATION
Gosub DEVERROU
###
If XTRASPE Then
    Call FERME_TRACE From LECFIC
Endif
$FIN_EXEC
TRA=1
Return

#-------------------------------------------------------------------------------
$OUVRE
# Ouverture des tables

Local File ITVLOT [XCRA]
If !clalev([ITL]) : Local File ITVLOT    : Endif
If !clalev([ILD]) : Local File ITVLOTD   : Endif
If !clalev([REQ]) : Local File REQUEST   : Endif
If !clalev([OTI]) : Local File OPETIT    : Endif
If !clalev([ALK]) : Local File APLLCK    : Endif
If !clalev([FCY]) : Local File FACILITY  : Endif
If !clalev([PLT]) : Local File PARITLTYP : Endif

Global Char CRABEG,CRAEND,FCYBEG,FCYEND
Global Char TYPBEG,TYPEND,OPPBEG,OPPEND,CPYBEG
Global Integer ALLFCY

Local Char CRITERE(250),CRITILD(250),LASTCRA, NUMCRA, XCLE(100), SVGPROG
Local Char ITLNUM,XTRACE(250),ZIDENT
Local Char ITLFCY,AUZFCY
Local Decimal LIGCRA
Local Integer OK,I,FLTRA,LASTENREG,NBCRA,FLGLOT,LECTRA
Local Char ACTION,NOMMOD,FICCRA(250)
Local Char SVGADXIRS,SVGADXIFS,ZIDENT
Local Shortint XERR

Local Char XSYMBOLE(35)

Local Integer XSTAT: [L]XSTAT=0

Local Mask XVALLOTCRA [DIA]

TIT=mess(141,[V]GXMSGPSA,1)
TMP=1 # Affichage d'un message de temporisation
Return

#-------------------------------------------------------------------------------
$VERROU
# Positionnement d'un verrou

SYMBOLE = "XVALLOTCRA"
OK=1

If [M]ALLFCY=2
    For [ALK]LCKCLE Where left$(LCKSYM,len(SYMBOLE))=SYMBOLE
        [L]OK=0
        Break 1
    Next
Else
    Read [ALK]LCKCLE(1)=SYMBOLE
    If !fstat
        [L]OK=0
    Else
        SYMBOLE+="\"+[M]FCYBEG
    Endif
Endif

If [L]OK
    Lock = SYMBOLE With lockwait = 0
    If fstat
        GMESSAGE=mess(30,100,1)
        GERR=1
        FIN=1
    Endif
Else
    GERR=1
    FIN=1
    GMESSAGE=mess(30,100,1)
Endif
Return

#-------------------------------------------------------------------------------
$DEVERROU
# Suppression du verrou

Unlock=SYMBOLE
Return

#-------------------------------------------------------------------------------
$ERR_BATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm-[M:ITV3]ORINUM,1) From GESECRAN
GERR=1
End

################################################################################
################################################################################
################################################################################
################################################################################

################################################################################
$VALIDATION

GPOINT="AV_VALIDATION" : Gosub ENTREE From EXEFNC

CRABEG=[M]CRABEG
CRAEND=[M]CRAEND
FCYBEG=[M]FCYBEG
TYPBEG=[M]TYPBEG
TYPEND=[M]TYPEND
ALLFCY=[M]ALLFCY
CPYBEG=[M]CPYBEG
OPPBEG=[M]OPPBEG
OPPEND=[M]OPPEND

Close Local Mask [DIA]

Gosub CRA_FILTRE

#Génération du modéle et construction du nom de fichier
Gosub FIC_MOD
If [L]XERR
    Call ECR_TRACE(mess(139,[V]GXMSGPSA,1)-[L]NOMMOD,1)From GESCERAN
Else
    [L]NBCRA=0
    Case [L]FLGLOT
      When 0 : # Validation directe
        [L]NBCRA+=1
        Call B_VALID(CRABEG,[L]CRITILD,0,[L]NOMMOD,[L]FICCRA)From SPVOBJITL2

      When 1,2 : # Validation en lot

        #Génération du fichier ASCII
        For [F:XCRA]ITL1(3) Where evalue([L]CRITERE)
            [L]XSTAT=1
#           If ALLFCY=2 & [F:XCRA]FCYDEF<>""
#               [L]ITLFCY=[F:XCRA]FCYDEF
#               Gosub VERF_AUZFCY
#           Endif
            If [L]XSTAT
                #la 2 éme paramétre : 1 en lot et tout site coché , 2 en lot un site particulier
                If ALLFCY=2
                    Call B_VALID([F:XCRA]ITLNUM,[L]CRITILD,1,[L]NOMMOD,[L]FICCRA)From SPVOBJITL2
                Else :# ctrl deja effectué
                    Call B_VALID([F:XCRA]ITLNUM,[L]CRITILD,2,[L]NOMMOD,[L]FICCRA)From SPVOBJITL2
                Endif
                [L]NBCRA+=1
            Endif
        Next

      When 3 : # Validation à partir des visas CRA

        Raz [L]XCLE, [V]XITLLIG, [V]XITLLNB

        For [L]I=0 To [V]XNBCLE-1

          [L]NUMCRA =left$([V]XLISTCLE([L]I),instr(1,[V]XLISTCLE([L]I),"~")-1)

          If [L]NUMCRA<>[L]XCLE & [L]I>0
            Call B_VALID([L]XCLE,[L]CRITILD,3,[L]NOMMOD,[L]FICCRA) From SPVOBJITL2
            [L]NBCRA+=1
            Raz [V]XITLLIG,[V]XITLLNB
          Endif

          [L]LIGCRA =val(right$([V]XLISTCLE([L]I),instr(1,[V]XLISTCLE([L]I),"~")+1))
          [V]XITLLIG([V]XITLLNB)=[L]LIGCRA
          [V]XITLLNB+=1
          [L]XCLE=[L]NUMCRA

        Next

        If [V]XNBCLE>0
          Call B_VALID([L]NUMCRA,[L]CRITILD,3,[L]NOMMOD,[L]FICCRA) From SPVOBJITL2
          [L]NBCRA+=1
        Endif

    Endcase

    If [L]NBCRA

        # LBORN 21/11/2013 - Sinon bug à partir des consultations (Appel Trt SPEITV inexistant !)
        If dim(GPROGRAMME)>0
          [L]SVGPROG=GPROGRAMME
          Raz GPROGRAMME
        Endif

        # A REVOIR, correction provisoire, sinon le fichier trace est ouvert pendant l'import dans certains cas
        XSVGSERV=GSERVEUR : GSERVEUR=1
        Call IMPORTSIL([L]NOMMOD,[L]FICCRA)From GIMPOBJ
        GSERVEUR=XSVGSERV
    #   Call EFFACE([L]FICCRA,GSTATUS) From ORDSYS

        # LBORN 21/11/2013
        GPROGRAMME=[L]SVGPROG

        #Cloture bordereau si necessaire et validation inter correspondante
        [L]ITLNUM=""
        Gosub MAJCRA_VALITV

        # LBORN 17/08/2010 - Génération des documents en direct / GIDENT
        Call GENDOC_DIR From XVALGAS2
        If ![L]FLGLOT
          If [V]GERRTRACE
            [L]LECTRA=1
          Else
            Read [F:XCRA]ITL0=CRABEG
            If fstat : Raz [F:XCRA] : Endif
            Read [F:PLT]PLT0=[F:XCRA]TYPITL
            If !fstat & [F:PLT]NOTRA=2
              [L]LECTRA=0
            Else
              [L]LECTRA=1
            Endif
            GPOINT="AV_LECTRA" : Gosub ENTREE From EXEFNC
          Endif
          Call FERME_TRACE From LECFIC
          If [L]LECTRA | [V]GERRTRACE
            Call TEMPOFF From GESECRAN
            Call LEC_TRACE From LECFIC
          Endif
        Endif
    Endif
Endif
Return

#-------------------------------------------------------------------------------
$CRA_FILTRE

[L]CRITERE="[F:XCRA]FLGITLCLO<>2"
[L]CRITILD="1"

###########################
# Critères en-tête
###########################
If TYPBEG<>""
  If TYPEND=TYPBEG
    [L]CRITERE-="& [F:XCRA]TYPITL=TYPBEG"
  Else
    [L]CRITERE-="& [F:XCRA]TYPITL>=TYPBEG"
  Endif
Elsif TYPEND<>""
  [L]CRITERE-="& [F:XCRA]TYPITL<=TYPEND"
Endif

If CRABEG<>""
  If CRAEND=CRABEG
    [L]CRITERE-="& [F:XCRA]ITLNUM=CRABEG"
  Else
    [L]CRITERE-="& [F:XCRA]ITLNUM>=CRABEG"
  Endif
Elsif CRAEND<>""
  [L]CRITERE-="& [F:XCRA]ITLNUM<=CRAEND"
Endif

# LBORN 21/11/2013 - Mantis 22238
If [L]FLGLOT=3
  [L]CRITERE-="& find([F:XCRA]ITLNUM,[V]XLISTCRA(0..[V]XNBLCRA-1))<>0"
Endif

###########################
# Critères lignes
###########################
If FCYBEG<>""
  [L]CRITILD-="& [F:ILD]FCY='"+FCYBEG+"'"
Endif

If OPPBEG<>""
  If OPPEND=OPPBEG
    [L]CRITILD-="& [F:ILD]OPPNUMLIG='"+OPPBEG+"'"
  Else
    [L]CRITILD-="& [F:ILD]OPPNUMLIG>='"+OPPBEG+"'"
  Endif
Elsif OPPEND<>""
  [L]CRITILD-="& [F:ILD]OPPNUMLIG<='"+OPPEND+"'"
Endif

# LBORN 15/10/2012
If [V]XCTRLCLO=2
  [L]CRITILD-="& ([F:ILD]OPETYP<>2 | [F:ILD]CLOPER=2)"
Endif

# LBORN 21/11/2013 - Mantis 22238
If [L]FLGLOT=3
  [L]CRITILD-="& find([F:ILD]NUMLIG,[V]XITLLIG(0..[V]XITLLNB-1))"
Endif

GPOINT="CRA_FILTRE" : Gosub ENTREE From EXEFNC
Return

#-------------------------------------------------------------------------------
$FIC_MOD

[L]NOMMOD="ITVX3S"

# LBORN 07/04/2014 - Mantis 24246 (en mode batch, GIDENT n'est pas toujours égal à GUSER+adxuid(1))
# [L]ZIDENT=[V]GIDENT
[L]ZIDENT=[V]GUSER+num$(adxuid(1))

Call ALPHANUM([L]ZIDENT) From XBIBCH

[L]ZIDENT+="_"+format$("D:hhmmss",date$)

[L]FICCRA=filpath("gasimp","CRALOT"+[L]ZIDENT,"txt")

Local Char ZZFIC(250)
[L]ZZFIC=filpath("gasimp","","")
If filinfo([L]ZZFIC,0)<0
  Call SYSTEME2("","ae_mkdir"-[L]ZZFIC,"",GSTATUS,GBIDC1)From ORDSYS
# System "ae_mkdir"-[L]ZZFIC
Endif
Call EFFACE([L]FICCRA,GSTATUS) From ORDSYS

[L]XERR=0
Call GEN_MODITV([L]NOMMOD,[L]FICCRA,[L]XERR)From XVALGAS215
Return

#-------------------------------------------------------------------------------
$MAJCRA_VALITV
#on cloture le C.R.A si toutes les lignes sont validées
Call DEBTRANS From GLOCK
[L]LASTENREG=1
[V]GOK=1
Trbegin [ITL]

For [F:XCRA]ITL0 Where ITLNUM>[L]ITLNUM & evalue([L]CRITERE)
    [L]ITLNUM=[F:XCRA]ITLNUM
    [L]LASTENREG=0
    For [ILD]ILD0 Where ITLNUM=[L]ITLNUM
      If [F:ILD]FLGVAL<>2 : [V]GOK=-2 : Break 2 : Endif
    Next
    Read [F:ITL]ITL0=[L]ITLNUM
    If !fstat
      [F:ITL]FLGITLCLO=2
      Rewrite [ITL]
      If fstat : [V]GOK=0 : Break : Endif
    Endif
    Break
Next

If ![L]LASTENREG
    If [V]GOK>0
        Call ECR_TRACE(mess(140,[V]GXMSGPSA,1)-[L]ITLNUM,0)From GESECRAN
        Commit
    Else
        If [V]GOK<>-2
            Call FSTA("ITL")From GLOCK
            Call ECR_TRACE("Erreur"-mess(140,[V]GXMSGPSA,1)-[L]ITLNUM,1) From GESECRAN
        Endif
        Rollback
    Endif

    Goto MAJCRA_VALITV
Else
    Commit
Endif
Return

#-------------------------------------------------------------------------------
$VERF_AUZFCY
[L]XSTAT=1
Call CTL_AUZFCY([F:ILD]FCY,"GESITL","V",[L]XSTAT) From XTRTFCY
Return

#-------------------------------------------------------------------------------
$VERF_CPY
GPE=0
GPOINT="VERF_CPY" : Gosub ENTREE From EXEFNC
If GPE=1 : Raz GPE : Return : Endif
###
Read [F:FCY]FCY0=[F:ILD]FCY
If !fstat & [F:FCY]LEGCPY<>"" & CPYBEG<>"" & [F:FCY]LEGCPY<>CPYBEG
  [L]XSTAT=0
Endif
Return

################################################################################
Subprog IMPORTSIL(NOMMOD,FICCRA)
Value Char NOMMOD,FICCRA

#Test pour le web

Local Char PARAM(10)(1..4),VALEUR(10)
If !clalev([M:IMP2]) : Local Mask IMPOBJ2 [IMP2] :Endif
[M:IMP2]MODIMP=[L]NOMMOD
[M:IMP2]NOMIMP=[L]FICCRA
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTIMPOBJ","",4) From GTRAITE
End


################################################################################
################################################################################
################################################################################
################################################################################

########################################
Subprog AV_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AP_ALLFCY(VALEUR)
End

########################################
Subprog AP_ALLFCY(VALEUR)
Variable Integer  VALEUR
If VALEUR=2 Then
    Effzo [M]FCYBEG
    Diszo [M]FCYBEG
Else
    Actzo [M]FCYBEG
Endif
End

########################################
Subprog AV_ALLCPY(VALEUR)
Variable Integer VALEUR
Call AP_ALLCPY(VALEUR)
End


########################################
Subprog AP_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2 Then
    Effzo [M]CPYBEG
    Diszo [M]CPYBEG
Else
    Actzo [M]CPYBEG
Endif
End

########################################
Subprog AV_ALLTYP(VALEUR)
Variable Integer VALEUR
Call AP_ALLTYP(VALEUR)
End

########################################
Subprog AP_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2 Then
    Effzo [M]TYPBEG,TYPEND
    Diszo [M]TYPBEG,TYPEND
Else
    Actzo [M]TYPBEG,TYPEND
Endif
End

########################################
Subprog AV_ALLOPP(VALEUR)
Variable Integer VALEUR
Call AP_ALLOPP(VALEUR)
End

########################################
Subprog AP_ALLOPP(VALEUR)
Variable Integer VALEUR
If VALEUR=2 Then
    Effzo [M]OPPBEG,OPPEND
    Diszo [M]OPPBEG,OPPEND
Else
    Actzo [M]OPPBEG,OPPEND
Endif
End

########################################
Subprog AV_ALLCRA(VALEUR)
Variable Integer VALEUR
Call AP_ALLCRA(VALEUR)
End

########################################
Subprog AP_ALLCRA(VALEUR)
Variable Integer VALEUR
If VALEUR=2 Then
    Effzo [M]CRABEG,CRAEND
    Diszo [M]CRABEG,CRAEND
Else
    Actzo [M]CRABEG,CRAEND
Endif
End
