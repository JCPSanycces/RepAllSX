# --------------------------------------- VACITM1 --------------------------------
Subprog C_VACITM1(VALEUR)
Variable Char    VALEUR()

# 101874 : V9 : Taxe code control
# 107978 : Import niveau de taxe
# En import, VALEUR contient déja la nouvelle valeur, il faut faire la recherche et pas le controle
#If [M:SQH2]VACITM1(nolign-1)=VALEUR
If [M:SQH2]VACITM1(nolign-1)=VALEUR & !GIMPORT
# 101874
# 107978
    Call CTLVAT([M]VAT1(nolign-1)) From TRTVENCTL
Else
    Raz [M:SQH2]VAT1(nolign-1)        : # Bug 78972
    Call ALIVAT(VALEUR,11,1,[M:SQH0]BPCORD,[M:SQH2]ITMREF(nolign-1),"SQH2",nolign-1,[M:SQH2]VAT1(nolign-1)) From TRTX3
Endif
End
########################################
# --------------------------------------- REP1 --------------------------------
Subprog AM_REP1(VALEUR)
Variable Char    VALEUR()
# --> Initialisation taux commission 1
If [M]CREFLG(nolign-1) <> 0 End : Endif
If VALEUR = "" [M:SQH2]REPRAT1 (nolign-1) = 0: End : Endif
If [F:BPC]BPCNUM<>[M:SQH0]BPCORD
    Read [F:BPC]BPC0 = [M:SQH0]BPCORD
    If fstat Raz [F:BPC] :Endif
Endif
Read [F:REP]REP0 = VALEUR
If fstat=0
    If [F:BPC]COMCAT <> 0
        [M:SQH2]REPRAT1(nolign-1) = [F:REP]COMRAT1([F:BPC]COMCAT-1)
    Endif
Endif
End
########################################
# --------------------------------------- REPRAT1 --------------------------------
Subprog AS_REPRAT1(VALEUR)
Variable Decimal VALEUR
# --> Pas de saisie si rep1 non renseigne
If [M]REP1(nolign-1) = "" VALEUR = 0 : mkstat=2 Endif
End
########################################
# --------------------------------------- REP2 --------------------------------
Subprog AM_REP2(VALEUR)
Variable Char    VALEUR()
# --> Initialisation taux commission 2
If [M]CREFLG(nolign-1) <> 0 End : Endif
If VALEUR = "" : [M:SQH2]REPRAT2 (nolign-1) = 0 : End : Endif
If [F:BPC]BPCNUM<>[M:SQH0]BPCORD
    Read [F:BPC]BPC0 = [M:SQH0]BPCORD
    If fstat Raz [F:BPC] :Endif
Endif
Read [F:REP]REP0 = VALEUR
If fstat=0
    If [F:BPC]COMCAT <> 0
        [M:SQH2]REPRAT2(nolign-1) = [F:REP]COMRAT2([F:BPC]COMCAT-1)
    Endif
Endif
End
########################################
# --------------------------------------- REPRAT2 --------------------------------
Subprog AS_REPRAT2(VALEUR)
Variable Decimal VALEUR
# --> Pas de saisie si rep2 non renseigne
If [M]REP2(nolign-1) = "" VALEUR = 0 : mkstat=2 Endif
End
# -------------------------------------- DBPAADD ------------------------
########################################
Subprog IB_DBPAADD

If [F:BPC]BPCNUM <> [M:SQH0]BPCORD
   Read [F:BPC]BPC0=[M:SQH0]BPCORD
   If fstat Raz [F:BPC] : Endif
Endif
If [F:BPC]BPCTYP=4
    Raz GBOUTS
    Raz GBOUT3
Else
    Raz GBOUT2
Endif
End
########################################
Subprog AS_DBPAADD(VALEUR)
Variable Char    VALEUR()
If GLINBPD <> 2 mkstat=2 Endif
End
########################################
Subprog C_DBPAADD(VALEUR)
Variable Char    VALEUR()

If VALEUR = "" End Endif

If [F:BPC]BPCNUM<>[M:SQH0]BPCORD
   Read [F:BPC]BPC0=[M:SQH0]BPCORD
   If fstat Raz [F:BPC] : Endif
Endif

# 79705 : SAT in SPRICLINK : Step 2
# Recherche interdit suite modification de l'adresse
Local    Integer NOL    :    NOL=nolign-1
Local    Char    WREP (GLONREP)
Local    Char    WBPAADD (GLONBPD)
If dim([M:SQH2]REP1) > 0
  WREP= [M:SQH2]REP1(0)
  If GLINREP=2
    # Alimentation des représentants s'ils n'ont pas été alimentés par le client
    If [F:BPC]BPCTYP=1
        # Alimentation du 1er représentant
        If [F:BPC]REP(0) = ""
          If [F:BPD]BPCNUM <> [M:SQH0]BPCORD | [F:BPD]BPAADD <> VALEUR
              Read [F:BPD]BPD0 = [M:SQH0]BPCORD;VALEUR
              If fstat Raz [F:BPD] Endif
          Endif
          WREP= [F:BPD]REP(0)
        Endif
    Endif
  Endif
Endif
WBPAADD=[M:SQH2]DBPAADD(NOL)
[M:SQH2]DBPAADD(NOL)=VALEUR : # Il faut affecter le champ pour que la recherche tarif ait la bonne valeur
Call RECH_INTERDIT ([M:SQH2]ITMREF(NOL), VALEUR, WREP, 1) From TRTVENTAR
If mkstat=2 & GDACLOK=2
    Local Integer WOK
    WOK=2 : Call AVERTIR (mess(27,192,1)-":"-mess(205,100,1), WOK) From GESECRAN
    If WOK=2 mkstat=0 Endif
    Raz GMESSAGE
Endif
If mkstat = 2 [M:SQH2]DBPAADD(NOL)=WBPAADD : End : Endif
# 79705 : SAT in SPRICLINK : Step 2

If [F:BPC]BPCTYP=4
    # Prospect : Il n'y a pas de client livré, on vérifie juste que l'adresse existe dans le fichier des adresses
    If [F:BPA]BPATYP <> 1 | [F:BPA]BPANUM <> [M:SQH0]BPCORD | [F:BPA]BPAADD <> VALEUR
        Read [F:BPA]BPA0 = 1;[M:SQH0]BPCORD;VALEUR
        If fstat
            mkstat = 2 : GMESSAGE = VALEUR-":"-mess(23,100,1) : End : # Fiche inexistante
        Endif
    Endif
Else
    If [F:BPD]BPCNUM <> [M:SQH0]BPCORD | [F:BPD]BPAADD <> VALEUR
        # Client
        Read [F:BPD]BPD0 = [M:SQH0]BPCORD;VALEUR
        If fstat
            mkstat = 2 : GMESSAGE = VALEUR-":"-mess(23,100,1) : End : # Fiche inexistante
        Endif
    Endif
    If [F:BPD]ENAFLG=1 mkstat = 2 : GMESSAGE = mess(13,15,1)-":"-VALEUR-"\"-mess(2,126,1) : End  : Endif : # Fiche inactive
Endif
If mkstat=2 End Endif

# Vérif.cohérence entre l'entête devis et le client livré concernant les infos douanières et le régime de taxe
If [F:BPC]BPCTYP<>4 & VALEUR<>[M:SQH1]BPAADD
    If [M:SQH1]VACBPR<>[F:BPD]VACBPR & [F:BPD]VACBPR<>""
        # Régime de taxe client livré XXX différent du régime de taxe entête devis YYY
        # A la dde de CH, le ctrl n'est plus bloquant
        GMESSAGE=mess(620,197,1)-mess(42,191,1)-"("-[F:BPD]VACBPR-")"-mess(621,197,1)-mess(620,197,1)-mess(622,197,1)-mess(121,198,1)-"("-[M:SQH1]VACBPR-")"
        Local Integer OK : OK=2 : Call AVERTIR(GMESSAGE, OK) From GESECRAN : Raz GMESSAGE : If OK=1 mkstat=2 Endif
    #--- CPO 72237 Le champ BPIEECNUM est soumis à code activité
    #Elsif [M:SQH0]BPIEECNUM<>[F:BPD]EECNUM & [F:BPD]EECNUM<>""
    Elsif dim([M:SQH0]BPIEECNUM)>0 & [M:SQH0]BPIEECNUM<>[F:BPD]EECNUM & [F:BPD]EECNUM<>""
        #FQ 55836 - Le ctrl ne doit plus être bloquant
        #mkstat=2 : # N°identification CEE client livré XXX différent du N°identification CEE entête devis
        GMESSAGE=mess(629,197,1)-mess(42,191,1)-"("-[F:BPD]EECNUM-")"-mess(621,197,1)-mess(629,197,1)-mess(622,197,1)-mess(121,198,1)-"("-[M:SQH0]BPIEECNUM-")"
        Local Integer OK : OK=2 : Call AVERTIR (GMESSAGE,OK) From GESECRAN : Raz GMESSAGE : If OK=1 mkstat=2 Endif
        #fin FQ 55836
    Elsif [M:SQH0]EECICT<>[F:BPD]EECICT & [F:BPD]EECICT<>""
        #FQ 55836 - Le ctrl ne doit plus être bloquant
        #mkstat=2 : # Code incoterm client livré XXX différent du code incoterm entête devis
        GMESSAGE=mess(630,197,1)-mess(42,191,1)-"("-[F:BPD]EECICT-")"-mess(621,197,1)-mess(630,197,1)-mess(622,197,1)-mess(121,198,1)-"("-[M:SQH0]EECICT-")"
        Local Integer OK : OK=2 : Call AVERTIR (GMESSAGE,OK) From GESECRAN : Raz GMESSAGE : If OK=1 mkstat=2 Endif
        #fin FQ 55836
    Elsif dim([M:SQH0]EECLOC)>0 & [M:SQH0]EECLOC<>[F:BPD]EECLOC & [F:BPD]EECLOC<>0
        #FQ 55836 - Le ctrl ne doit plus être bloquant
        #mkstat=2 : # Lieu transport CEE client livré XXX différent du Lieu transport CEE entête devis
        GMESSAGE=mess(631,197,1)-mess(42,191,1)-"("-mess([F:BPD]EECLOC,236,1)-")"-mess(621,197,1)-mess(631,197,1)-mess(622,197,1)-mess(121,198,1)-"("-mess([M:SQH0]EECLOC,236,1)-")"
        Local Integer OK : OK=2 : Call AVERTIR (GMESSAGE,OK) From GESECRAN : Raz GMESSAGE : If OK=1 mkstat=2 Endif
        #fin FQ 55836
    Endif
Endif
End

########################################
Subprog AM_DBPAADD(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1

If [F:BPC]BPCTYP=1
    [M:SQH2]DDAYLTI(NOL) = [F:BPD]DAYLTI
    Affzo [M:SQH2]DDAYLTI(NOL)
    If GLINREP=2
        # Alimentation des représentants s'ils n'ont pas été alimentés par le client
        If [F:BPC]BPCNUM<>[M:SQH0]BPCORD
            Read [BPC]BPC0 = [M:SQH0]BPCORD
            If fstat <> 0 Raz [F:BPC] : Endif
        Endif
        # Alimentation du 1er représentant
        If dim([M:SQH2]REP1) > 0 & [F:BPC]REP(0) = ""
            [M:SQH2]REP1(NOL)= [F:BPD]REP(0)
            If [F:REP]REPNUM <> [F:BPD]REP(0)
                Read [F:REP]REP0 = [F:BPD]REP(0)
                If fstat Raz [F:REP] : Endif
            Endif
            If [F:BPC]COMCAT <> 0 [M:SQH2]REPRAT1(NOL)=[F:REP]COMRAT1([F:BPC]COMCAT-1) : Endif
            Affzo [M:SQH2]REP1(NOL), REPRAT1(NOL)
        Endif
        # Alimentation du 2eme représentant
        If dim([M:SQH2]REP2) > 0
            If [M:SQH2]REP1(NOL)<>"" & [F:BPC]REP(1) = ""
                [M:SQH2]REP2(NOL) = [F:BPD]REP(1)
                If [F:REP]REPNUM <> [F:BPD]REP(1)
                    Read [F:REP]REP0 = [F:BPD]REP(1)
                    If fstat Raz [F:REP] : Endif
                Endif
                If [F:BPC]COMCAT <> 0 [M:SQH2]REPRAT2(NOL)=[F:REP]COMRAT2([F:BPC]COMCAT-1) : Endif
                Affzo [M:SQH2]REP2(NOL), REPRAT2(NOL)
            Endif
        Endif
    Endif
Endif
# Recherche s'il y a un contact pour l'adresse de livraison
Call RECH_CNTNAM([M:SQH0]BPCORD, VALEUR, [M:SQH2]CNDNAM(NOL)) From TRTVENDIV
Affzo [M:SQH2]CNDNAM(NOL)
#LTA.sn
# If GLOCUSATAX   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
  If [F:BPA]BPATYP <> 1 | [F:BPA]BPANUM <> [M:SQH0]BPCORD | [F:BPA]BPAADD <> VALEUR
    Read [F:BPA]BPA0 = 1;[M:SQH0]BPCORD;VALEUR
  Endif
  If [F:BPA]ADRVAL <> 2 and func TRTADRLIB.CHKADR_CRY([F:BPA]CRY)
    GMESSAGE = mess(366,192,1)  # Address has not been validated
    If func TRTADRLIB.CHKADR_MANDATORY()
      GERR=1
      mkstat = 2
      End
    Else
      GERR=2
    Endif
  Endif
Endif
#LTA.en
End

# -------------------------------------- CNDNAM ------------------------
########################################
Subprog C_CNDNAM(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
        If clalev([F:CNT]) = 0 Local File CONTACT    [CNT] : Endif
    Read [CNT] CNT0=1;[M]BPCORD;VALEUR
    If fstat GMESSAGE = mess(23,100,1) : mkstat=2 : Endif
Endif
End
