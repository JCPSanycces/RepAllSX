######################################################################################
## Etiquette ajoutée par le superviseur (écran SQH3) 06/07/2006 16:44:52 (LD)
######################################################################################
Subprog C_NBAXE
#----------------#
# Contrôle NBAXE #
#----------------#
If !find(status,1,4,5,20,21,26,92,93) | GIMPORT End : Endif
#----- Contrôle Sections d'entête obligatoires si saisissables -----#
If [M:SQH3]NBAXE>0 & GHEADIE=1
  Local Integer I
  For I=1 To [M:SQH3]NBAXE
    If CCE(I-1)="" & GOBLDIE(I)=2
      mkstat=1 : GMESSAGE= mess(46,106,1)-GDIE(I) : Break
    Endif
  Next I
Endif

End
# -------------------------------------- NBFAC ---------------------------
########################################
Subprog C_NBFAC
# --- Si l'on sort du tableau, calcul de la valeur TTC (calcul facture complet)
If GIMPORT         : End : Endif
If [M:SQH2]NBLIG=0 : End : Endif
If status >= 65 & status <=  100 End Endif
If find(status,7,27,28) | status >= 1792 End Endif
   If dim(G_MOD_DTAAMT)>0 & G_MOD_DTAAMT>0
     # 101874 : V9 : Taxe code control
     # Valuation is always done in this case
     #If dim(GVALTTCSQH)>0 & dim(GVALTTC)>0 : GVALTTC=GVALTTCSQH : Endif
     GVALTTC=2
     #---- Paramètres complementaires appel valorisation
     # PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
     # PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non/2=Oui)
     # PARAM_T(2) : Flag retour                         (1=KO/2=OK)
     Local    Char     PARAM_T (25) (0..10)
     PARAM_T(0)="1"      : # Pas de contrôle des taxes
     PARAM_T(1)="1"      : # Pas de lecture de la trace
     PARAM_T(2)="0"
     Call VALTTC ("GESSQH", PARAM_T) From TRTVENFACR
     Raz G_MOD_DTAAMT
     If PARAM_T(2)="1" mkstat=2 : End Endif
     # 101874
   Endif
End

Subprog AP_NBFAC
End
# -------------------------------------- INVDTAAMT -----------------------
########################################
Subprog AM_INVDTAAMT(VALEUR)
Variable Decimal VALEUR
If dim(G_MOD_DTAAMT)<=0 : Global Integer G_MOD_DTAAMT : Endif
G_MOD_DTAAMT +=1

    #--CPO 102340 Avenants lignes mis à jour si modification en-tête
    #--Il faut enrichir la correction 90362 qui met à 1 les UPDFLG si pas d'éléments répartis
    #--Mettre le flag à 1 uniquement si passage d'un élément réparti à 0
    If [M:SQH3]INVDTAAMT(nolign-1)<>0 and VALEUR = 0
      #--Vérifier que l'élément est réparti sur lignes
      If clalev([F:SFI])=0 : Local File SFOOTINV [SFI] : Endif

      If [M:SQH3]INVDTA(nolign-1)<>[F:SFI]SFINUM
        Read [F:SFI]SFI0 = [M:SQH3]INVDTA(nolign-1)
        If fstat : Raz [F:SFI] : Endif
      Endif

      If find([F:SFI]DSPLIN,2,3,4)>0
        If dim(G_PREV_DSPLIN)<0 : Global Integer G_PREV_DSPLIN : Endif
        G_PREV_DSPLIN = 1
      Endif
    Endif
    #--/102340
End
##########################################################################
#####################################################################
#               LES ACTIONS SUR LES ZONES ECRAN DETAIL SQH2         #
#####################################################################
# --------------------------------------- NBLIG --------------------------------
Subprog IB_NBLIG
Local Integer NOL : NOL=nolign-1

# Bouton   2 : Calcul tarif
# Bouton   3 : Stock par site
# Bouton   4 : Détail valorisation
# Bouton   5 : Saisie texte ligne
# Bouton   6 : Explication du prix
# Bouton   7 : Configurateur
#MAE, le 04/04/08, ajout de la consultation des articles commandés
# Bouton   8 : visualisation article
# SEGAY 05/12/2008 : branchement traçabilité pièces
# Bouton   9 : traçabilité pièces
# Bouton  11 : Product information - DF 79831

If nolign > [M]NBLIG Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6 : Endif
# Pas de calcul tarif si ligne transformée en commande ou si gratuit
If [M]DSOHNUM(NOL)<>"" | [M]FOCFLG(NOL)=3 Raz GBOUT2 Endif
# Pas de stock par site si article non géré en stock
If [M]STOMGTCOD(NOL)=1 Raz GBOUT3 Endif
# Pas d'explication du prix pour les gratuits
If [M]FOCFLG(NOL)=3 Raz GBOUT6 : Endif
# Pas de configurateur si devis transformé totalement en cde ou ligne gratuite (pb insertion)
If [M:SQH1]QUOSTA=3 | [M:SQH2]FOCFLG(NOL)=3 Raz GBOUT7 : Endif
# Pas de configurateur si composant (pb insertion)
If find([M:SQH2]LINTYP(NOL),3,4,5,7,8,9,11,12,13) Raz GBOUT7 : Endif

# FGR 14/01/2014 : X3SUIVI91103 : il manque NOL : If [M:SQH2]ITMREF = ""
#MAE, 04/04/08
If [M:SQH2]ITMREF(NOL) = ""
    Raz GBOUT8
Endif
# SEGAY 05/12/2008 : branchement traçabilité pièces
If find(GREP,"C","D") or find("CONSPIV",GNAVIG(1..GPILNAV)) Then Raz GBOUT9 Endif
Call IB_PRDINF([M:SQH2]ITMREF(NOL),11) From PRDINFLIB  # DF 79831
Call IB_NOTECHECK([M:SQH2]ITMREF(NOL),"ITMREF",12)  From TRTNTSCTL # product notes

End

########################################
Subprog C_NBLIG
Local Integer NOL

GMODIF=2

If [M:SQH2]NBLIG <> 0
    Diszo [M:SQH0]SALFCY
    If GREP <> "D" Diszo [M:SQH0]BPCORD Endif
Else
    Actzo [M:SQH0]SALFCY
    Actzo [M:SQH0]BPCORD
Endif

# --> CONTRôLE D'INSERTION DE LIGNES
If   status = 73 | status = 82 :NOL=nolign-1 :Gosub TEST_INS From SUBSQHB : Endif

# --> CONTRôLE DE SUPPRESSION DE LIGNES
If   status = 65
     NOL=nolign-1
     GMODIF = 1
     Gosub TEST_ANU From SUBSQHB
     If mkstat End Endif
     GUPDAPPFLG=2 : # Raz signatures si suppression d'une ligne
Endif
If   status = 68 | status = 83
     GMODIF = 1
     For NOL=nolign-1 To nolign1-1
         Gosub TEST_ANU From SUBSQHB
         If mkstat : Break : Endif
     Next NOL
     If mkstat End Endif
     GUPDAPPFLG=2 : # Raz signatures si suppression d'une ligne
Endif
# --> CONTRôLE DE MODIFICATION DE LIGNES
If   status = 75
     NOL=nolign-1
     GMODIF=0
     Gosub TEST_MOD From SUBSQHB
Endif

End
#############################################################################
#    APRES_NBLIG     :    Web                                               #
#                                                                           #
#        Décomposée en 2 actions                                            #
#                                                                           #
#        1 - Traitement si fin sans validation                              #
#          - Traitement de validation                                       #
#            Suppression d'un gratuit lié à une ligne                       #
#            Suppression d'une nomenclature                                 #
#            Modification d'une nomenclature si suppression du composé seul #
#            Modification d'une nomenclature si modification du composé     #
#        2 - Création d'un gratuit                                          #
#                                                                           #
#############################################################################
$P1_NBLIG
Local Integer  NOL      : NOL=nolign-1
Local Integer  ORI      : ORI=nolign-1
Local Integer  NL       : NL=nolign
Local Integer  FUNCTION : FUNCTION = 1
Local Integer  SAVNOL, RET, OK

# Bug 82658 : Recherche tarif si changement de référence article
# Globale utilisée pour flagger les erreurs suite à la recherche tarif
If dim(GERRITMREF)>0 Kill GERRITMREF Endif

#---------------------------------------------------------------------------#
# Fin sans validation : Réhabilitation des totaux et c'est tout             #
#---------------------------------------------------------------------------#
If status = 6 | status = 7 | status = 27 | status = 28  | status >= 1792
    Call ADD_TOT(NOL) From SUBSQHB
    mkstat=2
    Return
Endif

#---------------------------------------------------------------------------#
# Validation d'une ligne                                                    #
#---------------------------------------------------------------------------#
If GMODIF = 2 | GMODIF = 0
    GNETMAR = 1
    Call VERIF_VATCOD(NOL) From SUBSQHB
    Call APRES_LIGNE (NOL,1) From SUBSQHB
Endif

# Raz signatures si ajout d'une ligne
If GREP="M" & [M]CREFLG(NOL)=0 GUPDAPPFLG=2 Endif

# Bug 84030
#--------------------------------------------------------------------------------------#
# Suppression d'une ligne de gratuit : Modification de la ligne à l'origine du gratuit #
#--------------------------------------------------------------------------------------#
If GMODIF = 1 & GFOCFLG = 3
  Call RAZORIGRA(NOL) From TRTVENBOM
Endif
#--------------------------------------------------------------------------------------#
# Insertion d'une ligne : Maj des lignes de gratuit qui suivent la ligne insérée       #
# Maj du n° de ligne à l'origine du gratuit car les lignes ont été renumérotées        #
#--------------------------------------------------------------------------------------#
If GMODIF=2 & NOL<[M]NBLIG-2
  Call MAJORIGRA(NOL,"SQDLIN") From TRTVENBOM
Endif
# Bug 84030

#---------------------------------------------------------------------------#
# Suppression d'un gratuit lié à une ligne supprimée                        #
#---------------------------------------------------------------------------#
#If (status = 65 | status = 68 | status = 83) & GFOCFLG = 2
If (GMODIF = 1 | GMODIF = 3 | GMODIF = 4) & GFOCFLG = 2
   Call SUPGRA(NOL, FUNCTION, RET) From TRTVENBOM
   # Pb en import en suppression de ligne : affzo remet la variable status qui valait 65 à 1
   If !GIMPORT : Affzo [M:SQH2]1-99 : Endif
Endif

#---------------------------------------------------------------------------#
#        Suppression d'une nomenclature                                     #
#---------------------------------------------------------------------------#
OK=1
#If GMODIF=4 & (([M:SQH2]LINTYP(NOL) = 6  & find([M:SQH2]LINTYP(NL), 7,8,9)))    : # Bug 71161
If GMODIF=4 & find([M:SQH2]LINTYP(NL), 7,8,9)                                    : # Bug 71161
    If !GIMPORT Call OUINON(mess(13,191,1),OK) From GESECRAN : Endif
    If OK<>2
#     ----------------------------------------------------------------------#
#     Modification d'une nomenclature si suppression du composé seul        #
#     ----------------------------------------------------------------------#
      Gosub MODNOM From TRTVENBOM
      GMODIF=1
      Affzo [M:SQH2]1-99
      Return
    Endif
Endif
If GMODIF=3 | OK=2
  Gosub SUPNOM From TRTVENBOM
  GMODIF=1
  Affzo [M:SQH2]1-99
  Return
Endif

#---------------------------------------------------------------------------#
#        Modification d'une nomenclature                                    #
#---------------------------------------------------------------------------#
# --> Modification
OK=1
If GMODIF = 0
    If !GIMPORT & (([M:SQH2]LINTYP(NOL) = 6  & find([M:SQH2]LINTYP(NL), 7,8,9)))
        Call OUINON(mess(14,191,1),OK) From GESECRAN
#       MSG=Repercussion sur les composants ?
    Endif
    If find([M:SQH2]LINTYP(NOL),2,10) | OK = 2
        SAVNOL=nolign
        Gosub MODNOM From TRTVENBOM
        nolign=SAVNOL
        Affzo [M:SQH2]1-99
    Endif
    Raz GTARFLG : # Bug 62571
    # Sauvegarde nouvelle quantité pour calcul qté nomenclature
    [M]CQTY(NOL) = [M]QTY(NOL)
Endif

Return
#############################################################################
$P2_NBLIG
Local Integer  ORI        : ORI=nolign-1
Local Integer  NL         : NL=nolign
Local Integer  FUNCTION   : FUNCTION=1
Local Integer  RET

#---------------------------------------------------------------------------#
# Création d'une ligne                                                      #
# --> Génération des gratuits                                               #
#---------------------------------------------------------------------------#
If GMODIF = 2 & GFOCITMREF <> ""
    If !GIMPORT | (GIMPORT & ((dim(G_FOCFLG)>0 & G_FOCFLG=0) | (dim(G_FOCFLG)<=0)))
    #   Recherche de l'article origine si on est positionné sur un composant
        If !find([M]LINTYP(ORI),1,2,6,10)
            While !find([M]LINTYP(ORI),1,2,6,10) & ORI >= 0
                ORI-=1
            Wend
        Endif
        If !GIMPORT & ORI = [M]NBLIG [M]NBLIG +=1 : Endif
        Call CREGRA("G",1, ORI, [M:SQH0]QUODAT, FUNCTION, NL, RET) From TRTVENBOM

        If !GIMPORT & ORI = NL-1 & ORI = [M]NBLIG - 1 :[M]NBLIG-=1:Endif
        If GIMPORT VALEUR=[M]NBLIG Endif

        Affzo [M:SQH2]5
        If GIMPORT Return Endif : # Bug 72428
    Endif
Endif

# 101874 : V9 : Taxe code control
# Valuation depends on SQHVALLIG parameter
#If dim(GVALTTCSQH)>0 & dim(GVALTTC)>0 : GVALTTC=GVALTTCSQH : Endif
GVALTTC=GSQHVALLIG
#If !GIMPORT : Call VALTTC ("GESSQH") From TRTVENFACR : Endif
If !GIMPORT
    #If GUSER="LD" Infbox ("P2NBLIG") Endif
    #---- Paramètres complementaires appel valorisation
    # PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
    # PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non/2=Oui)
    # PARAM_T(2) : Flag retour                         (1=KO/2=OK)
    Local    Char     PARAM_T (25) (0..10)
    PARAM_T(0)="1"      : # Pas de contrôle des taxes
    PARAM_T(1)="1"      : # Pas de lecture de la trace
    PARAM_T(2)="0"
    Call VALTTC ("GESSQH", PARAM_T) From TRTVENFACR
Endif
# 101874

# Pb en import en suppression de ligne : affzo remet la variable status qui valait 65 à 1
If !GIMPORT : Affzo [M:SQH2]10,15,20 : Endif

Return

########################################
Subprog B2_NBLIG
# -------- Bouton recalcul tarif -----------------
Local Integer NOL, TYPRECH
NOL=nolign-1
# --> PAS D'EXéCUTION DU BOUTON
If  nolign > [M]NBLIG    : End : Endif
If  [M]DSOHNUM(NOL) <> "" : End : Endif
#   --> Ctrl autorisation modification
If !find (GREP, "C", "D")
    GBIDC2="M": GFCY=[M]SALFCY : Gosub AUTORIS_OPT From CONTX3
    If !GBIDI2  GZNUM=0:GERR = 1:GMESSAGE = mess(2,104,1): End : Endif
Endif
If  [M]FOCFLG(NOL) <> 3
    Call LECT_FIC(NOL) From SUBSQHB
    Call SUB_TOT(NOL) From SUBSQHB
    If   find([M]LINTYP(NOL),1,2,6,10)
         TYPRECH = 1
    Else
        Local Integer ORI : ORI=NOL
        While !find([M]LINTYP(ORI),2,6,10) & ORI >= 0 ORI-=1 Wend
        If find([M]LINTYP(ORI),2,6,10) GPNTITMREF=[M]ITMREF(ORI) Endif
        TYPRECH=4
    Endif
    Call ALICLCAMT([M:SQH2]ITMREF(NOL), [M]QTY(NOL), NOL, "SQH2", [M:SQH2]CLCAMT1(NOL), [M:SQH2]CLCAMT2(NOL)) From TRTX3
    Call RECH_TARIF(TYPRECH,[M]ITMREF(NOL),NOL,[M]QTY(NOL),"SQH",[M]GROPRI(NOL)) From TRTVENTAR
    Call CLCNETPRI([M]QTY(NOL), [M:SQH0]CUR, NOL) From TRTVENPRI
    Call CLCPFM([M]DSTOFCY(NOL), [M]PRITYP, [M]CHGTYP, [M]QUODAT, [M]CUR, NOL,1) From TRTVENPRI
    Call APRES_LIGNE (NOL,1) From SUBSQHB
    [M]UPDFLG(NOL) = 1
    [M]WUPDAPPFLG(NOL) = 2
    Affzo [M:SQH2]5,10,15
    mkstat=4
Endif
nolign=NOL+1
End
########################################
Subprog AVANT_NBLIG
Local Integer NOL : NOL=nolign-1
Local Integer WRETOUR
Local Char    WNUMTEX(12)

# --> LECTURE DES FICHIERS ARTICLE MAîTRE ET SITE (CAS AUTRE QUE CRéATION)
If GMODIF = 2
# --> Création d'une ligne : Alimentation des zones venant de l'entête
   Call INIT_SQH(NOL) From SUBSQHB
Else
   Call LECT_FIC(NOL) From SUBSQHB
Endif
If GMODIF = 1
   # --> Si GMODIF = 3 ou 4 suppression d'un compose
   If find([M:SQH2]LINTYP(NOL),2,10)    : GMODIF=3 : Endif
   If find([M:SQH2]LINTYP(NOL),6) : GMODIF=4 : Endif
   GFOCFLG = [M:SQH2]FOCFLG(NOL)
Endif

Call SUB_TOT(NOL) From SUBSQHB

End
# --------------------------------------- ITMREF --------------------------------
########################################
#Subprog IB_ITMREF
# Déf. bouton article
#GBOUT1=mess(22,198,1)
#If [M]ITMREF(nolign-1) = "" Raz GBOUT4 Endif
#End
########################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
If GMODIF <> 2 mkstat=2 Endif
End
########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()

Local    Integer NOL    :    NOL=nolign-1
Local    Integer RET
Local    Char    REP

#--> REMPLACEMENT PAR ARTICLE DE SUBSTITUTION
Call CTLSBSITM(VALEUR, [M:SQH0]QUODAT, RET) From TRTVENCTL
If RET = 1
    GMESSAGE = mess(40,192,1) : mkstat=2 : End
Elsif RET = 2
    VALEUR = [F:ITS]ITMREF
    GMESSAGE = mess(10,191,1) - VALEUR : GERR=2
Endif

#--> TEST PRéSENCE DE L'ARTICLE MAîTRE
Read [ITM]ITM0=VALEUR : #Call LECTURE("ITM", VALEUR, "") From CONTOBJ
If  fstat <> 0 GMESSAGE = mess(8,192,1) : mkstat=2: End : Endif
# --> Contrôle du statut de l'article
If [F:ITM]ITMSTA > 1
   If GERR = 2 GMESSAGE += " \ " Endif
   GMESSAGE += mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")"
   If [F:ITM]ITMSTA = 6
      mkstat=2 : End
   Else
      GERR=3
   Endif
Endif
# On vérifie que la date du devis est bien >= la date de début de vie de l'article
If [F:ITM]LIFSTRDAT<>[0/0/0] & [M:SQH0]QUODAT<[F:ITM]LIFSTRDAT
   mkstat=2 : GMESSAGE=mess(331,199,1)-":"-format$(GFMDAT,[F:ITM]LIFSTRDAT) : End
Endif
# On vérifie que l'article est toujours vendu
If clalev([F:ITG])= 0 Local File ITMCATEG [ITG] : Endif
If [F:ITG]TCLCOD <> [F:ITM]TCLCOD
    Read [ITG]ITG1=[F:ITM]TCLCOD;""
    If fstat GMESSAGE = [F:ITM]TCLCOD-":"-mess(338,199,1) : mkstat=2 : End : Endif
Endif
If [F:ITG]SALFLG<>2 GMESSAGE = mess(221,199,1)-"("-[F:ITM]TCLCOD-")" : mkstat=2 : End : Endif

# Issue 107888 - 2016-09-09 by CPO : US155 Kit & flexible kit scheduled invoices
If [F:ITM]DLVFLG<>2
  If    [F:ITS]ITMTYP = 3 # Undeliverable kit are not allowed
    GMESSAGE=mess(647,199,1) : mkstat=2 : End
  Elsif [F:ITS]ITMTYP = 2 # Flexible kits are allowed
    #TODO
  Endif
Endif
# 107890 : Scheduled invoices : (LD:08/12/15)

#--> RECHERCHE DES INTERDITS
If dim([M]REP1(NOL)) > 0 REP = [M]REP1(NOL): Endif
Call RECH_INTERDIT (VALEUR, [M]DBPAADD(NOL), REP,1) From TRTVENTAR
If mkstat=2 End : Endif

# Bug 82658 : Recherche tarif si changement de référence article
# Erreur suite à la recherche tarif effectuée en AM_
If dim(GERRITMREF)>0 & GERRITMREF=2
  # Si on resaisit l'article initial
  # --> Il faut redéclencher l'AM_ pour recharger les champs avec l'article initial
  If VALEUR=[M]ITMREF(NOL) Call AM_ITMREF(VALEUR) Endif
  Kill GERRITMREF
Endif
# Bug 82658
# FGR 10/04/2015 : X3SUIVI105605
If VALEUR <> [M]ITMREF (NOL)
   If dim([M]ECCVALMAJ) > 0
      Raz [M]ECCVALMAJ(NOL)
      Raz [M]ECCVALMIN(NOL)
   Endif
Endif

End
########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL    :    NOL=nolign-1

#--> IL FAUT FORCER LA RECHERCHE TARIF
#MAE, le 14/04/08, pas de Raz de la quantité si on vient des articles commandés
If GPILNAV > 1
    If find (GNAVIG(GPILNAV -1),"VISUITM")
        Raz [M:SQH2]QTY(NOL)
    Endif
Endif
[M]LINTYP(NOL) = 1
[M]FOCFLG(NOL) = 1
If  [F:ITS]ITMTYP = 2 : [M]LINTYP(NOL) = 6 : Endif
If  [F:ITS]ITMTYP = 3 : [M]LINTYP(NOL) = 2 : Endif

#--> INIT. ZONES ISSUES DE L'ARTICLE
Call INIT_ITM (NOL, VALEUR) From SUBSQHB

# Bug 82658 : Recherche tarif si changement de référence article
# Si ce n'est pas un gratuit et qté non nulle
If [M]QTY(NOL)<>0 & [M]FOCFLG(NOL) <> 3
    # --> Calcul des montants de base calcul de taxe
    Call ALICLCAMT(VALEUR, [M:SQH2]QTY(NOL), NOL, "SQH2", [M:SQH2]CLCAMT1(NOL), [M:SQH2]CLCAMT2(NOL)) From TRTX3
    # ----- Recherche tarif -------
    Local Integer TYP
    Local Char    WSVG_ITMREF(GLONITM)
    # Article normal ou composé
    TYP=1
    # Composant
    If find([M:SQH2]LINTYP(NOL),3,4,5,7,8,9,11,12,13)
        Local Integer ORI : ORI=NOL
        While !find([M]LINTYP(ORI),2,6,10) & ORI >= 0 ORI-=1 Wend
        If find([M]LINTYP(ORI),2,6,10) GPNTITMREF=VALEUR Endif
        TYP=4
    Endif
    # --> Recherche tarif
    Call RECH_TARIF(TYP,VALEUR,NOL,[M]QTY(NOL),"SQH",[M]GROPRI(NOL)) From TRTVENTAR
    # --> Calcul du prix net
    Call CLCNETPRI([M]QTY(NOL), [M:SQH0]CUR, NOL) From TRTVENPRI
    # Le ctrl du prix net et le calcul de marge utilise la classe [M]
    WSVG_ITMREF=[M]ITMREF(NOL) : [M]ITMREF(NOL)=VALEUR
    If GDACLOK = 1
        Call CTLNETPRI([M:SQH0]BPCORD,[M:SQH0]CHGTYP,[M:SQH0]QUODAT,[M:SQH0]CUR,NOL) From TRTVENPRI
        If mkstat=2
          [M]ITMREF(NOL)=WSVG_ITMREF
          # Déclaration d'une globale signalant l'erreur sur le champ, globale testée en C_
          If dim(GERRITMREF)<0 Global Integer GERRITMREF : GERRITMREF=2 Endif
          End
        Endif
    Endif
    # --> Calcul de la marge
    Call CLCPFM([M]DSTOFCY(NOL), [M]PRITYP, [M]CHGTYP, [M:SQH0]QUODAT, [M:SQH0]CUR, NOL, 2) From TRTVENPRI
    If GDACLOK = 1
        Call CTLPFM([M:SQH0]CUR,[M:SQH2]CPRPRI(NOL), NOL) From TRTVENPRI
        If mkstat=2
          [M]ITMREF(NOL)=WSVG_ITMREF
          # Déclaration d'une globale signalant l'erreur sur le champ, globale testée en C_
          If dim(GERRITMREF)<0 Global Integer GERRITMREF : GERRITMREF=2 Endif
          End
        Endif
    Endif
    Affzo [M:SQH2]GROPRI(NOL)
    If dim([M:SQH2]DISCRGVAL1(NOL))>0 Affzo [M:SQH2]DISCRGVAL1(NOL) Endif
    If dim([M:SQH2]DISCRGVAL2(NOL))>0 Affzo [M:SQH2]DISCRGVAL2(NOL) Endif
    If dim([M:SQH2]DISCRGVAL3(NOL))>0 Affzo [M:SQH2]DISCRGVAL3(NOL) Endif
    If dim([M:SQH2]DISCRGVAL4(NOL))>0 Affzo [M:SQH2]DISCRGVAL4(NOL) Endif
    If dim([M:SQH2]DISCRGVAL5(NOL))>0 Affzo [M:SQH2]DISCRGVAL5(NOL) Endif
    If dim([M:SQH2]DISCRGVAL6(NOL))>0 Affzo [M:SQH2]DISCRGVAL6(NOL) Endif
    If dim([M:SQH2]DISCRGVAL7(NOL))>0 Affzo [M:SQH2]DISCRGVAL7(NOL) Endif
    If dim([M:SQH2]DISCRGVAL8(NOL))>0 Affzo [M:SQH2]DISCRGVAL8(NOL) Endif
    If dim([M:SQH2]DISCRGVAL9(NOL))>0 Affzo [M:SQH2]DISCRGVAL9(NOL) Endif
    Affzo [M:SQH2]REPCOE(NOL)
    Affzo [M:SQH2]NETPRI(NOL), CPRPRI(NOL), PFM(NOL)
Endif
# Bug 82658

Affzo [M]ITMDES(NOL), ITMDES1(NOL), SAU(NOL), SAUSTUCOE(NOL), STU(NOL), LINTYP(NOL), FOCFLG(NOL)
Affzo [M]VACITM1(NOL), VACITM2(NOL), VACITM3(NOL)

If [M:SQH2]DACSAUCOE(NOL) < 2
    Diszo [M:SQH2]SAUSTUCOE(NOL)
Else
    Actzo [M:SQH2]SAUSTUCOE(NOL)
Endif

#      Si import des composants : le type de ligne doit etre garni dans [M]
#      notamment pour la recherche des tarifs composants
If GIMPORT & (dim(G_LINTYP)>0 & G_LINTYP=1)
   If find([F:SQD]LINTYP,3,4,5,7,8,9,11,12,13) : [M]LINTYP(NOL)=[F:SQD]LINTYP : Endif
Endif

##      Si import des gratuits : le flag gratuit doit etre garni dans [M]
If GIMPORT & (dim(G_FOCFLG)>0 & G_FOCFLG=1)
    # Garnissage du flag gratuit dans [M]
    If find([F:SQD]FOCFLG, 1,2,3) [M]FOCFLG(NOL)=[F:SQD]FOCFLG Else [M]FOCFLG(NOL)=1 Endif
    # Sur la ligne du gratuit il faut rechercher l'article origine
    If [M]FOCFLG(NOL)=3 and NOL>0 # Issue 112809 - 2016-01-25 by CPO : added "and NOL>0" Imported free item on first order line
        Local Integer WNOLCPE : WNOLCPE=NOL-1
        If WNOLCPE>=0 & !find([M]LINTYP(WNOLCPE),1,2,6,10)
            While !find([M]LINTYP(WNOLCPE),1,2,6,10) & WNOLCPE >= 0
                WNOLCPE-=1
            Wend
        Endif
        If WNOLCPE>=0 # Issue 112809 - 2016-01-25 by CPO : "ceinture-bretelles" (si 2 et plus premières lignes de gratuits...)
          [M]ORILIN(NOL)=[M]SQDLIN(WNOLCPE)
        Endif
    Endif
Endif

End
########################################
Subprog IB_ITMDES
Global   Char    GITMREF
# Définition bouton article
GBOUT1=mess(22,198,1)
# Alimentation GITMREF pour appel GOBJETC
GITMREF=[M]ITMREF(nolign-1)
End
########################################
Subprog IB_ITMDES1
Global   Char    GITMREF
# Définition bouton article
GBOUT1=mess(22,198,1)
# Alimentation GITMREF pour appel GOBJETC
GITMREF=[M]ITMREF(nolign-1)
End
########################################
# --------------------------------------- SAU --------------------------------
########################################
Subprog AS_SAU(VALEUR)    : # --- Web - Obligatoire - Synchrone
Variable Char    VALEUR()
If GMODIF <> 2 | [M]LINTYP(nolign-1) <> 1 mkstat=2 : Endif

#LSE 05/12/2006 FQ38520
Local Integer NOL : NOL=nolign-1
If [F:ITM]ITMREF <> [M:SQH2]ITMREF(NOL)
    Read [ITM]ITM0=[M:SQH2]ITMREF(NOL)
    If fstat Raz [F:ITM] Endif
Endif
If [F:ITM]HDKITMTYP=5
    mkstat=2
Endif

End
########################################

########################################
Subprog AM_SAU(VALEUR)
Variable Char    VALEUR()

Local Integer  NOL     : NOL=nolign-1
Local Shortint TYP
Local Char WANC_SAU(GLONUOM)

Affzo [M]SAUSTUCOE(NOL)
If [M:SQH2]DACSAUCOE(NOL) < 2
    Diszo [M:SQH2]SAUSTUCOE(NOL)
Else
    Actzo [M:SQH2]SAUSTUCOE(NOL)
Endif

# La modif. de l'unité entraîne une nvelle recherche tarif (utile s'il existe un tarif dans cette nvlle unité)
# Recherche tarif ssi elle a déjà eu lieu
If [M:SQH2]QTY(NOL) = 0 End : Endif
# Pas de recherche tarif pour les gratuits
If [M:SQH2]FOCFLG(NOL) = 3 End : Endif
# ----- Recherche tarif -------
# Article normal ou composé
TYP=1
# Composant
If find([M:SQH2]LINTYP(NOL),3,4,5,7,8,9,11,12,13) TYP=4 Endif
WANC_SAU=[M]SAU(NOL)
[M]SAU(NOL)=VALEUR
# --> Recherche tarif
Call RECH_TARIF(TYP,[M]ITMREF(NOL),NOL,[M]QTY(NOL),"SQH",[M]GROPRI(NOL)) From TRTVENTAR
# --> Calcul du prix net
Call CLCNETPRI([M]QTY(NOL), [M:SQH0]CUR, NOL) From TRTVENPRI
If GDACLOK = 1
    Call CTLNETPRI([M:SQH0]BPCORD,[M:SQH0]CHGTYP,[M:SQH0]QUODAT,[M:SQH0]CUR,NOL) From TRTVENPRI
# içi impossible d'abandonner [M]SAUSTUCOE et [M]DACSAUCOE sont déjà maj par l'action CTLUOM !!
#    If mkstat=2 [M]SAU(NOL)=WANC_SAU : End : Endif
Endif
# --> Calcul de la marge
Call CLCPFM([M]DSTOFCY(NOL), [M]PRITYP, [M]CHGTYP, [M:SQH0]QUODAT, [M:SQH0]CUR, NOL, 2) From TRTVENPRI
If GDACLOK = 1
    Call CTLPFM([M:SQH0]CUR,[M:SQH2]CPRPRI(NOL), NOL) From TRTVENPRI
# içi impossible d'abandonner [M]SAUSTUCOE et [M]DACSAUCOE sont déjà maj par l'action CTLUOM !!
#    If mkstat=2 [M]SAU(NOL)=WANC_SAU : End : Endif
Endif
Affzo [M:SQH2]GROPRI(NOL)
If dim([M:SQH2]DISCRGVAL1(NOL))>0 Affzo [M:SQH2]DISCRGVAL1(NOL) Endif
If dim([M:SQH2]DISCRGVAL2(NOL))>0 Affzo [M:SQH2]DISCRGVAL2(NOL) Endif
If dim([M:SQH2]DISCRGVAL3(NOL))>0 Affzo [M:SQH2]DISCRGVAL3(NOL) Endif
If dim([M:SQH2]DISCRGVAL4(NOL))>0 Affzo [M:SQH2]DISCRGVAL4(NOL) Endif
If dim([M:SQH2]DISCRGVAL5(NOL))>0 Affzo [M:SQH2]DISCRGVAL5(NOL) Endif
If dim([M:SQH2]DISCRGVAL6(NOL))>0 Affzo [M:SQH2]DISCRGVAL6(NOL) Endif
If dim([M:SQH2]DISCRGVAL7(NOL))>0 Affzo [M:SQH2]DISCRGVAL7(NOL) Endif
If dim([M:SQH2]DISCRGVAL8(NOL))>0 Affzo [M:SQH2]DISCRGVAL8(NOL) Endif
If dim([M:SQH2]DISCRGVAL9(NOL))>0 Affzo [M:SQH2]DISCRGVAL9(NOL) Endif
Affzo [M:SQH2]NETPRI(NOL), CPRPRI(NOL), PFM(NOL)
nolign=NOL+1

End
# --------------------------------------- QTY --------------------------------
########################################
Subprog IB_QTY
# Pas de consultation par site si article non géré en stock
If [M:SQH2]STOMGTCOD(nolign-1) = 1
     Raz GBOUT3
Endif
End
########################################
Subprog AS_QTY(VALEUR)
Variable Decimal VALEUR
If !GIMPORT
   If ([M]LINTYP(nolign-1)>2 & [M]LINTYP(nolign-1)<6) | ([M]LINTYP(nolign-1)>10 & [M]LINTYP(nolign-1)<14) mkstat=2 : Endif
Endif
End
########################################
Subprog C_QTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL        : NOL=nolign-1

# test pour import
If GIMPORT & VALEUR <0  : GMESSAGE=mess(33,105,1)+" < 0" : mkstat=2 : End : Endif

#-----------------------------------------------------------#
# Ctr par rapport qte mini et qte maxi                      #
# --> En retour GMESSAGE et mkstat à 2 ou GERR=2            #
#---------------------------------------------------------- #
Gosub CTR_QTY From SUBSQHB
If mkstat=2 End : Endif
End
########################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR

Local    Integer  WRECH_TAR
Local    Integer  NOL     : NOL=nolign-1
Local    Shortint TYP
Local    Decimal  WSNETPRI, WSNETPRINOT, WSNETPRIATI : # Bug 70861

# --> Calcul des montants de base calcul de taxe
Local    Decimal WUNTCLCAMT1, WUNTCLCAMT2 : Raz WUNTCLCAMT1, WUNTCLCAMT2
If [M]QTY(NOL) <> 0
    WUNTCLCAMT1=[M]CLCAMT1(NOL)/[M]QTY(NOL) : WUNTCLCAMT2=[M]CLCAMT2(NOL)/[M]QTY(NOL)
Endif
Call ALICLCAMT([M:SQH2]ITMREF(NOL), VALEUR, NOL, "SQH2", [M:SQH2]CLCAMT1(NOL), [M:SQH2]CLCAMT2(NOL)) From TRTX3

# Pas de recherche tarif pour les gratuits
If [M:SQH2]FOCFLG(NOL) = 3 End : Endif

Goto $END_MODIF   #Y011

#-------------------------------------------#
# Recherche tarif si modif qte ou creation  #
#-------------------------------------------#
If GMODIF = 0
    WRECH_TAR = 1
    If [M:SQH2]FOCFLG(NOL) = 2
        GMESSAGE = mess(7,191,1)+"\"+mess(21,191,1)
    Else
        GMESSAGE = mess(21,191,1)
    Endif
    Call OUINON(GMESSAGE,WRECH_TAR) From GESECRAN
    Raz GMESSAGE
    If WRECH_TAR=2 & find([M:SQH2]LINTYP(NOL),2,6,10) GTARFLG="1" Endif : # Bug 62571
Else
    WRECH_TAR = 2
Endif
If WRECH_TAR = 2
    # ----- Recherche tarif -------
    # Article normal ou composé
    TYP=1
    # Composant
    If find([M:SQH2]LINTYP(NOL),3,4,5,7,8,9,11,12,13)
        Local Integer ORI : ORI=NOL
        While !find([M]LINTYP(ORI),2,6,10) & ORI >= 0 ORI-=1 Wend
        If find([M]LINTYP(ORI),2,6,10) GPNTITMREF=[M]ITMREF(ORI) Endif
        TYP=4
    Endif
    # --> Recherche tarif
    Call RECH_TARIF(TYP,[M]ITMREF(NOL),NOL,VALEUR,"SQH",[M]GROPRI(NOL)) From TRTVENTAR
Endif

# Bug 70861 : Recalcul prix net si recherche tarif ou si ligne directe (car impact des frais/remise par ligne sur le prix net)
WSNETPRI=[M]NETPRI(NOL) : WSNETPRINOT=[M]NETPRINOT(NOL) : WSNETPRIATI=[M]NETPRIATI(NOL)
# --> Calcul du prix net
Call CLCNETPRI(VALEUR, [M:SQH0]CUR, NOL) From TRTVENPRI
If GDACLOK = 1
    Call CTLNETPRI([M:SQH0]BPCORD,[M:SQH0]CHGTYP,[M:SQH0]QUODAT,[M:SQH0]CUR,NOL) From TRTVENPRI
    If mkstat=2 End Endif
Endif
# Bug 70861

# --> Calcul de la marge (Si recherche tarif ou Si chgnt montant base calcul taxe)
If WRECH_TAR=2 | [M]CLCAMT1(NOL)/VALEUR<>WUNTCLCAMT1 | [M]CLCAMT2(NOL)/VALEUR<>WUNTCLCAMT2
&              | [M]NETPRI(NOL)<>WSNETPRI | [M]NETPRINOT(NOL)<>WSNETPRINOT | [M]NETPRIATI(NOL)<>WSNETPRIATI : # Bug 70861
    [M]QTY(NOL)=VALEUR
    Call CLCPFM([M]DSTOFCY(NOL), [M]PRITYP, [M]CHGTYP, [M:SQH0]QUODAT, [M:SQH0]CUR, NOL, 2) From TRTVENPRI
    If GDACLOK = 1
        Call CTLPFM([M:SQH0]CUR,[M:SQH2]CPRPRI(NOL), NOL) From TRTVENPRI
        If mkstat=2 End Endif
    Endif
    Affzo [M:SQH2]CPRPRI(NOL)
    Affzo [M:SQH2]PFM(NOL)
Endif

#If WRECH_TAR = 2         : # Bug 70861
    Affzo [M:SQH2]GROPRI(NOL)
    If dim([M:SQH2]DISCRGVAL1(NOL))>0 Affzo [M:SQH2]DISCRGVAL1(NOL) Endif
    If dim([M:SQH2]DISCRGVAL2(NOL))>0 Affzo [M:SQH2]DISCRGVAL2(NOL) Endif
    If dim([M:SQH2]DISCRGVAL3(NOL))>0 Affzo [M:SQH2]DISCRGVAL3(NOL) Endif
    If dim([M:SQH2]DISCRGVAL4(NOL))>0 Affzo [M:SQH2]DISCRGVAL4(NOL) Endif
    If dim([M:SQH2]DISCRGVAL5(NOL))>0 Affzo [M:SQH2]DISCRGVAL5(NOL) Endif
    If dim([M:SQH2]DISCRGVAL6(NOL))>0 Affzo [M:SQH2]DISCRGVAL6(NOL) Endif
    If dim([M:SQH2]DISCRGVAL7(NOL))>0 Affzo [M:SQH2]DISCRGVAL7(NOL) Endif
    If dim([M:SQH2]DISCRGVAL8(NOL))>0 Affzo [M:SQH2]DISCRGVAL8(NOL) Endif
    If dim([M:SQH2]DISCRGVAL9(NOL))>0 Affzo [M:SQH2]DISCRGVAL9(NOL) Endif
    Affzo [M:SQH2]NETPRI(NOL)
# bug 15688 : Ctrl reporté en action ctrl du prix
#    If [M]LINTYP(NOL) = 1 | [M]LINTYP(NOL) = 2 | [M]LINTYP(NOL) = 6
#        If [M]FOCFLG(nolign-1) <> 3 & [M]GROPRI(NOL)=0 & !GIMPORT
#            GERR=3:GMESSAGE=mess(62,194,1)
#        Endif
#    Endif
#Endif                    : # Bug 70861

$END_MODIF  #Y011
nolign=NOL+1
End
########################################
# --------------------------------------- SAUSTUCOE --------------------------------
########################################
Subprog AS_SAUSTUCOE(VALEUR)
Variable Decimal VALEUR
If GMODIF<>2 | [M]LINTYP(nolign-1)<>1 | [M]SAU(nolign-1)=[M]STU(nolign-1)
    mkstat=2
Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 12/06/2003 10:48:52 (LD)
##########################################################################
Subprog AM_SAUSTUCOE(VALEUR)
Variable Decimal VALEUR

Local    Integer  NOL     : NOL=nolign-1
Local    Shortint TYP
Local    Decimal  WANC_SAUSTUCOE

# La modif. du coef de conversion UV_US entraîne une nvelle recherche tarif (utile si tarif en US)
# Pas de recherche tarif pour les gratuits
If [M:SQH2]FOCFLG(NOL) = 3 End : Endif
# ----- Recherche tarif -------
# Article normal ou composé
TYP=1
# Composant
If find([M:SQH2]LINTYP(NOL),3,4,5,7,8,9,11,12,13) TYP=4 Endif
# --> Recherche tarif
WANC_SAUSTUCOE=[M]SAUSTUCOE(NOL)
[M]SAUSTUCOE(NOL)=VALEUR
Call RECH_TARIF(TYP,[M]ITMREF(NOL),NOL,[M]QTY(NOL),"SQH",[M]GROPRI(NOL)) From TRTVENTAR
# --> Calcul du prix net
Call CLCNETPRI([M]QTY(NOL), [M:SQH0]CUR, NOL) From TRTVENPRI
If GDACLOK = 1
    Call CTLNETPRI([M:SQH0]BPCORD,[M:SQH0]CHGTYP,[M:SQH0]QUODAT,[M:SQH0]CUR,NOL) From TRTVENPRI
    If mkstat=2 [M]SAUSTUCOE(NOL)=WANC_SAUSTUCOE : End : Endif
Endif
# --> Calcul de la marge
Call CLCPFM([M]DSTOFCY(NOL), [M]PRITYP, [M]CHGTYP, [M:SQH0]QUODAT, [M:SQH0]CUR, NOL, 2) From TRTVENPRI
If GDACLOK = 1
    Call CTLPFM([M:SQH0]CUR,[M:SQH2]CPRPRI(NOL), NOL) From TRTVENPRI
    If mkstat=2 [M]SAUSTUCOE(NOL)=WANC_SAUSTUCOE : End : Endif
Endif
Affzo [M:SQH2]GROPRI(NOL)
If dim([M:SQH2]DISCRGVAL1(NOL))>0 Affzo [M:SQH2]DISCRGVAL1(NOL) Endif
If dim([M:SQH2]DISCRGVAL2(NOL))>0 Affzo [M:SQH2]DISCRGVAL2(NOL) Endif
If dim([M:SQH2]DISCRGVAL3(NOL))>0 Affzo [M:SQH2]DISCRGVAL3(NOL) Endif
If dim([M:SQH2]DISCRGVAL4(NOL))>0 Affzo [M:SQH2]DISCRGVAL4(NOL) Endif
If dim([M:SQH2]DISCRGVAL5(NOL))>0 Affzo [M:SQH2]DISCRGVAL5(NOL) Endif
If dim([M:SQH2]DISCRGVAL6(NOL))>0 Affzo [M:SQH2]DISCRGVAL6(NOL) Endif
If dim([M:SQH2]DISCRGVAL7(NOL))>0 Affzo [M:SQH2]DISCRGVAL7(NOL) Endif
If dim([M:SQH2]DISCRGVAL8(NOL))>0 Affzo [M:SQH2]DISCRGVAL8(NOL) Endif
If dim([M:SQH2]DISCRGVAL9(NOL))>0 Affzo [M:SQH2]DISCRGVAL9(NOL) Endif
Affzo [M:SQH2]NETPRI(NOL), CPRPRI(NOL), PFM(NOL)
nolign=NOL+1
End
# --------------------------------------- GROPRI --------------------------------
########################################
Subprog AS_GROPRI(VALEUR)
Variable Decimal VALEUR
If [M:SQH2]FOCFLG(nolign-1)<>3 End Endif
# Article gratuit :
# Non saisissable en modification de la ligne (création ou modif de cde)
# Bug 49093 : On ne laisse ainsi saisissable en création de la ligne pour l'import
If [M]UPDFLG(nolign-1)<>0 | [M]CREFLG(nolign-1)<>0 mkstat=2 Endif
End
########################################
Subprog C_GROPRI(VALEUR)
Variable Decimal VALEUR
# En création d'une ligne ou si modification du prix
If ([M]CREFLG(nolign-1)=0 & [M]UPDFLG(nolign-1)=0) | [M]GROPRI(nolign-1)<>VALEUR
    # Pas de message si import de composants kit ou nomenclature
    # important : test sur la classe [F] du buffer import
    If GIMPORT & find([F:SQD]LINTYP,3,4,5,7,8,9,11,12,13) : End : Endif
    # Si article normal non gratuit, avertissement si prix à 0
    If find([M]LINTYP(nolign-1),1,2,6,10) & [M]FOCFLG(nolign-1) <> 3 & VALEUR =0
        Local Integer OK : OK=2     : # ok=2 bug 15663 autoriser import prix nul
        Call AVERTIR(mess(62,194,1),OK) From GESECRAN
        If OK <> 2 mkstat=2 : Endif
    Endif
Endif
End
########################################
Subprog AM_GROPRI(VALEUR)
Variable Decimal VALEUR
# Le prix ne peut être à 0 pour les articles normaux non gratuits
#If [M]LINTYP(nolign-1) = 1 | [M]LINTYP(nolign-1) = 2 | [M]LINTYP(nolign-1) = 6
#    If [M]FOCFLG(nolign-1) <> 3 & VALEUR =0
#        Local Integer OK : OK=2    : # ok=2 bug 15663 autoriser import prix nul
#        Call AVERTIR(mess(62,194,1),OK) From GESECRAN
#        If OK <> 2 mkstat=2 : Endif
#    Endif
#Endif
End
