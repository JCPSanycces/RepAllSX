#######################################################################
# SUBSQH : GESTION DES DEVIS                           EB - MARS 1998 #
#######################################################################
# IL CONTIENT LES ACTIONS SUR LES CHAMPS                              #
# LES ACTIONS SUR L'OBJET SE TROUVENT DANS LE TRAITEMENT SUBSQHA      #
#######################################################################
# Issue X3-134504 - 2019-04-11 by SR : if LEG is changed : Control and intialization of SQHTYP
# Issue X3-148035 - 20190731 by LD : Amending currency on a quote gives incorrect values
# Y011 - Cuando modifico cantidad, no pregunto al usuario si quiere actualizar percios por tarifa; directamente es NO
$ACTION
#--- Dem 74959
# Entry point reserved for ETO
GPOINT=ACTION
GPE=0
Gosub ENTREE From EXEFNC
If GPE=1 : Return : Endif
#---------------------------------------
# FGR 09/08/2018 : X3SUIVI117717 (début)
  If GWEBSERV = 1 and dim(ALIAS) >= 0 Then
    If !clalev([F:WAWY]) : Local File AWEBSERDES [WAWY] : Endif  # Optimisation si besoin
    Call DETECT_LINTYP(ALIAS, ACTION, "LINTYP") From TRTVENBOM
  Endif
# FGR 09/08/2018 : X3SUIVI117717 (fin)
#---------------------------------------
#---
Case ACTION
 When "BUREAU"        : Gosub ENTRE_MODIF From GOBJSUB
 When "VARIANTE"      : Gosub VARIANTE      From SUBSQHA
 When "SETTRANS"      : Gosub SETTRANS      From SUBSQHA
 When "OUVRE"         : Gosub OUVRE         From SUBSQHA
 When "FERME"         : Gosub FERME         From SUBSQHA
 When "ABANDON"       : Gosub ABANDON       From SUBSQHA
 When "SETBOUT"       : Gosub SETBOUT       From SUBSQHA
 When "AVANTBOUT"     : Gosub AVANTBOUT     From SUBSQHA
 When "EXEBOUT"       : Gosub EXEBOUT       From SUBSQHA
 When "STATUT"        : Gosub STATUT        From SUBSQHA
 When "AV_IMPRIME"    : Gosub AV_IMPRIME    From SUBSQHA
 When "AP_IMPRIME"    : Gosub AP_IMPRIME    From SUBSQHA
 When "RAZCRE"        : Gosub RAZCRE        From SUBSQHA
 When "RAZDUP"        : Gosub RAZDUP        From SUBSQHA
 When "VERIF_CRE"     : Gosub VERIF_CRE     From SUBSQHA
 When "INICRE"        : Gosub INICRE        From SUBSQHA
 When "CREATION"      : Gosub CREATION      From SUBSQHA
 When "APRES_CRE"     : Gosub APRES_CRE     From SUBSQHA
 When "LIENS"         : Gosub LIENS         From SUBSQHA
 When "AVANT_MOD"     : Gosub AVANT_MOD     From SUBSQHA
 When "AVANT_MODFIC"  : Gosub AVANT_MODFIC  From SUBSQHA
 When "VERIF_MOD"     : Gosub VERIF_MOD     From SUBSQHA
 When "INIMOD"        : Gosub INIMOD        From SUBSQHA
 When "MODIF"         : Gosub MODIF         From SUBSQHA
 When "APRES_MOD"     : Gosub APRES_MOD     From SUBSQHA
 When "APRES_MODIF"   : Gosub APRES_MODIF   From SUBSQHA
 When "VERF_ANU"      : Gosub VERF_ANU      From SUBSQHA
 When "ANNULE"        : Gosub ANNULE        From SUBSQHA
 When "BOITE"         : Gosub BOITE         From SUBSQHA
 When "DEFLIG"        : Gosub DEFLIG        From SUBSQHA
 When "LIENS_LIG"     : Gosub LIENS_LIG     From SUBSQHA
 When "INICRE_LIG"    : Gosub INICRE_LIG    From SUBSQHA
 When "INIMOD_LIG"    : Gosub INIMOD_LIG    From SUBSQHA
 When "VALLIG"        : Gosub VALLIG        From SUBSQHA
 When "FILTRE"        : Gosub FILTRE        From SUBSQHA
 When "REMP_DERLU"    : Gosub REMP_DERLU    From SUBSQHA
 When "FILGAUCHE"     : Gosub FILGAUCHE     From SUBSQHA
 When "FIN_ACTION"    : Gosub FIN_ACTION    From SUBSQHA
 When "AVANT_CHOI"    : Gosub AVANT_CHOI    From SUBSQHA
 When "DEFTRANS"      : Gosub DEFTRANS      From SUBSQHA
 When "AVANT_SUITE"   : Gosub AVANT_SUITE   From SUBSQHA  : # 79705 : V7 : SAT in SPRICLINK
 When Default
Endcase


### TS Bureautique ###

#########################################################################
#    Débranchements d'actions                                           #
#########################################################################
Case ACTION
 When "AB3_BPCORD"    : Gosub AB3_BPCORD     # FGR 10/11/2009 : X3SUIVI57700
 When "BB3_BPCORD"    : Gosub BB3_BPCORD     # FGR 10/11/2009 : X3SUIVI57700
 When "AB4_BPAADD"    : Gosub AB4_BPAADD     # FGR 10/11/2009 : X3SUIVI57700
 When "BB4_BPAADD"    : Gosub BB4_BPAADD     # FGR 10/11/2009 : X3SUIVI57700
 When Default
Endcase

#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################
Case ACTION
 When "TRT_DIV"       : Gosub TRT_DIV
 When Default
Endcase
Return

#########################################################################
# FGR 10/11/2009 : X3SUIVI57700 (début)
#######################################
#######################################
$AB3_BPCORD
Local Integer IMODCHAMP

  IMODCHAMP = varmode([M:SQH0]BPCORD)
  If IMODCHAMP = 1 or IMODCHAMP = 2 Then
    Actzo [M:SQH0]BPCORD
  Endif
Return

#######################################
$BB3_BPCORD
  If IMODCHAMP = 1 Then
    Grizo [M:SQH0]BPCORD
  Elsif IMODCHAMP = 2 Then
    Diszo [M:SQH0]BPCORD
  Endif
Return

#######################################
$AB4_BPAADD
Local Integer IMODCHAMP

  IMODCHAMP = varmode([M:SQH1]BPAADD)
  If IMODCHAMP = 1 or IMODCHAMP = 2 Then
    Actzo [M:SQH1]BPAADD
  Endif
Return

#######################################
$BB4_BPAADD
  If IMODCHAMP = 1 Then
    Grizo [M:SQH1]BPAADD
  Elsif IMODCHAMP = 2 Then
    Diszo [M:SQH1]BPAADD
  Endif
Return
# FGR 10/11/2009 : X3SUIVI57700 (fin)
#########################################################################

$TRT_DIV
Case TRAIT
    When "P1NBLIG"    :    Gosub P1_NBLIG
    When "P2NBLIG"    :    Gosub P2_NBLIG
Endcase
Return
#########################################################################
#####################################################################
#               LES ACTIONS SUR LES ZONES ECRAN entete SQH0         #
#####################################################################
# --------------------------------------- SALFCY --------------------------------
########################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()
Local    Char    WLEGCPY(GLONCPY)

# Issue X3-145701 by ANKUL - drives visibility of fields for PT Signature
Read [FCY2]FCY0= VALEUR
If !fstat
  [F:SQH]CPY=[F:FCY2]LEGCPY
  Gosub SQHNUMEND_SET_VISIBILITY From SUBSQHA
Endif
# Issue X3-145701 end

# Si le site de stockage est déjà renseigné revérifier la société juridique
If [M:SQH1]STOFCY<>"" & [M:SQH1]STOFCY <> VALEUR
    If [F:FCY]FCY <> VALEUR
        Read [FCY]FCY0=VALEUR
    Endif
#   Nouvelle société juridique
    WLEGCPY=[F:FCY]LEGCPY
    Read [FCY]FCY0=[M:SQH1]STOFCY
    If [F:FCY]LEGCPY <> WLEGCPY
       Raz [M:SQH1]STOFCY
       Affzo [M:SQH1]STOFCY
    Endif
Endif

End
########################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

Local Integer IRET # FGR 20/02/2015 : X3SUIVI104383

# Chargement des globales référenciels, comptes et sections de la société
GFCY=VALEUR : Gosub CHARG_PARAM From SUBSQHA : If GERR=1 mkstat=2 : End Endif

# Issue X3-134504 - 2019-04-11 by SR : if LEG is changed : Control and intialization of SQHTYP
## FGR 20/02/2015 : X3SUIVI104383 (début)
#If GSQHTYP <> "" Then
#  [M:SQH0]SQHTYP = GSQHTYP
#  Affzo [M:SQH0]SQHTYP
#  Call LEC_TSQ_LEG(GCURLEG, [M:SQH0]SQHTYP, IRET) From TRTLECLEG
#  Call AM_SQHTYP([M:SQH0]SQHTYP) From W1SQH0
#Endif
## FGR 20/02/2015 : X3SUIVI104383 (fin)
If [M:SQH0]SQHTYP <> ""
  If !clalev([F:TSQ]) : Local File TABSQHTYP [TSQ] : Endif
  #
  # is the existing SQHTYP value still OK with the new LEG ?
  Call CONTTSQ([M:SQH0]SQHTYP,GCURLEG,"SQH0","SQHTYP",VALEUR,"",GSOCIETE) From SUBTSQ
  If mkstat : Raz [M:SQH0]SQHTYP : Endif
Endif
# If SQHTYP empty
If [M:SQH0]SQHTYP = ""
   Raz GMESSAGE
   Raz mkstat
   Raz [M:SQH1]SOHTYP
   If GSQHTYP <> "" Then
      [M:SQH0]SQHTYP = GSQHTYP
      Raz IRET
      Call LEC_TSQ_LEG(GCURLEG, [M:SQH0]SQHTYP, IRET) From TRTLECLEG
      If IRET <> 0 : Raz [M:SQH0]SQHTYP : Raz [F:TSQ] : Endif
   Endif
Endif
# If SQHTYP not empty
If [M:SQH0]SQHTYP <> ""
   Call AM_SQHTYP([M:SQH0]SQHTYP)
   If mkstat : End : Endif
Endif
# End issue X3-134504
#If GACTMUL=2
# Alimentation concernant les colonnes frais/remises en fonction de la structure tarif de la société
Local Char WSVG_PLISTC : WSVG_PLISTC=[M:SQH0]PLISTC
Call ALICOLREM (1,1,GFLAG,"SQH2", [M:SQH1]CUR, 1,[M:SQH0]PLISTC) From TRTPRICE
#Endif
# Affichage entêtes colonnes variables (sections analytiques) en cas de changement de société
If WSVG_PLISTC=GPLISTC
    # (A faire ssi la structure tarif n'a pas changé, sinon cela a déjà été fait dans ALICOLREM)
    Gosub AFF_TITCOL From SUBSQHA
Else
  # Affzo nécessaire si sections invisibles pour faire disparaitre les colonnes
  If [M:SQH2]NBLIG=0
      [M:SQH2]NBLIG=1 : Affzo [SQH2]5 : Effzo [SQH2]5
  Endif
Endif
# Effacement tableau des sections entête si changement société
If dim([M:SQH3]NBAXE)>0 & [M:SQH3]NBAXE>0
  [M:SQH0]SALFCY=VALEUR
  Effzo [SQH3]15 : Affzo [SQH3]15
Endif

#----- Effacement tableau des sections entête -----#
If dim([M:POH1]NBAXE)>0 & [M:POH1]NBAXE>0
  [M:POH0]POHFCY=VALEUR
  Effzo [POH1]20 : Affzo [POH1]20
Endif


If GUPDCUR=1
    Diszo [M:SQH1]CUR
Else
    Actzo [M:SQH1]CUR
Endif
If GNOTATI=1
    Diszo [M:SQH1]PRITYP
Else
    Actzo [M:SQH1]PRITYP
Endif
If GLINREP=1
    If dim([M:SQH2]REP1) > 0 Diszo [M:SQH2]REP1, REPRAT1 Endif
    If dim([M:SQH2]REP2) > 0 Diszo [M:SQH2]REP2, REPRAT2 Endif
Else
    If dim([M:SQH2]REP1) > 0 Actzo [M:SQH2]REP1, REPRAT1 Endif
    If dim([M:SQH2]REP2) > 0 Actzo [M:SQH2]REP2, REPRAT2 Endif
Endif

If GLINBPD=1
    Diszo [M:SQH2]DBPAADD
Else
    Actzo [M:SQH2]DBPAADD
Endif

# JPGA : Traitement des exceptions Société : MAJ des informations au cas ou on changerait de Société
If [M:SQH0]BPCORD <> ""
    If dim([M:SQH1]VACBPR) > 0
        #Gbn-79727-Ajouter alim à partir du client livré
        # JPGA : Initialisation du Régime taxe
        If [F:BPD]VACBPR<>""
        # Alimentation régime de taxe à partir du client livré
            If [F:BPD]VACBPR<>[M:SQH1]VACBPR
                [M:SQH1]VACBPR = [F:BPD]VACBPR
            Endif
        Else
            Call INIT_REGIME([M:SQH0]BPCORD, GSOCIETE, "C", [M:SQH1]VACBPR) From CPTSUB
        Endif
        Affzo [M:SQH1]VACBPR
    Endif
    If dim([M:SQH3]PTE) > 0
        # JPGA : Initialisation du code condition de paiement
        Call INIPTE ([F:BPC]BPCPYR, [F:BPC]BPCINV, "C", [M:SQH3]PTE) From TRTX3
        Affzo [M:SQH3]PTE
    Endif
    If dim([M:SQH3]DEP) > 0
        # JPGA : Initialisation des escomptes et agios
        Call INIT_ESCOMPTE([M:SQH0]BPCORD, GSOCIETE, "C", [M:SQH3]DEP) From CPTSUB
        Affzo [M:SQH3]DEP
    Endif
Endif

# ACA - On recharge la liste des éléments de facturation, pour gérer le flag "remise sur taxe"
Local Integer NBPOSTE : NBPOSTE=dim([M:SQH3]INVDTA)
Call STRUFOOT (3,"SQH3",NBPOSTE,[F:SQH]CHGTYP,[F:BPC]CUR,[F:SQH]CUR,"NON") From SUBSFIT
[M:SQH3]NBFAC = NBPOSTE
Affzo [M:SQH3]20

# 101380
Call SETUP_SSTFIELDS From SUBSQHA

# Issue 120236 - Shippment site by default -> Stock site by default of the customer or user
If [M:SQH1]STOFCY=""
   If [F:BPD]STOFCY="" or [M:SQH0]BPCORD=""
      Read [FCY]FCY0=GFCYDEF(7)
      If fstat: Raz [F:FCY]: Endif
   Else
      Read [FCY]FCY0=[F:BPD]STOFCY
   Endif
   If [F:FCY]LEGCPY = GSOCIETE:
      [M:SQH1]STOFCY=[F:FCY]FCY: Affzo [M:SQH1]STOFCY
   Endif
Endif
# End issue 120236

End

#------------------------------------------------------------#
# Renseignement des unités de répartition                    #
#------------------------------------------------------------#
[M:SQH0]DSPWEU = GSALDSPWEU
[M:SQH0]DSPVOU = GSALDSPVOU

########################################
########################################
# --------------------------------------- BPCORD --------------------------------
########################################
Subprog C_BPCORD(VALEUR)
Variable Char    VALEUR()

Local Integer WOSTCTL

  # FGR 21/11/2013 : X3SUIVI94616 (début)
  If [F:BPC]BPCNUM <> VALEUR Then
    Read [BPC]BPC0=VALEUR
  Endif
  # FGR 21/11/2013 : X3SUIVI94616 (fin)
  If [F:BPC]BPCRSK<>VALEUR
    Local File BPCUSTOMER [BPC1] : # Lecture du tiers risque ss une autre abrev pour ne pas casser [F:BPC] du clt cde
    If [F:BPC1]BPCNUM<>[F:BPC]BPCRSK
        Read [F:BPC1]BPC0 = GSOCIETE;[F:BPC]BPCRSK
        If fstat Raz [F:BPC1] : Endif
    Endif
    WOSTCTL=[F:BPC1]OSTCTL
  Else
    WOSTCTL=[F:BPC]OSTCTL
  Endif
  If WOSTCTL = 3
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(151,199,1), WOK) From GESECRAN
    If WOK=1 mkstat=2 : End : Endif
  Endif
End

######################################################################################
Subprog IB_BPCORD
  #FGR 12/03/2014 : X3SUIVI69847 (début)
  If [F:BPC]BPCTYP = 4 Then
    # Si c'est un prospect on ne peut pas aller directement sur le client
    Raz GBOUT1
  Else
    # Si c'est un client pas de bouton "Prospect" et "Transformer en client"
    Raz GBOUT2
    Raz GBOUT6
  Endif
  #FGR 12/03/2014 : X3SUIVI69847 (fin)
  Call IB_NOTECHECK([M:SQH0]BPCORD,"BPCNUM",5)  From TRTNTSCTL # customer notes
End

######################################################################################
Subprog B6_BPCORD(VALEUR)
Variable Char    VALEUR()

Local Char SVALEUR(type(VALEUR)-10)

  # Transformer en client
  #FGR 12/03/2014 : X3SUIVI69847
  SVALEUR = VALEUR
  GORITRFBPP = "GESSQH"
  Call OBJET("BPC", VALEUR, "") From GOBJET
  Raz GORITRFBPP
  Gosub _AFF From W1SQH0
  Gosub AFFICHE_BCK_TIERS From SUBSQHA
End

########################################
Subprog AP_BPCORD(VALEUR)
Variable Char    VALEUR()

  # FGR 21/11/2013 : X3SUIVI94616 (début)
  If [F:BPC]BPCNUM <> VALEUR Then
    Read [BPC]BPC0=VALEUR
  Endif
  # FGR 21/11/2013 : X3SUIVI94616 (fin)
  # --> AFFICHAGE NOM SI ADRESSE MANUELLE
  If  [M:ADB1]BPRNAM(0) <> ""
    [M]BPCNAM = [M:ADB1]BPRNAM(0)
  Else
    [M]BPCNAM = [F:BPC]BPCNAM
  Endif
  Affzo [M:SQH0]BPCNAM
  # FGR 25/01/2010 : X3SUIVI60671
  Look [SQH]SQH0=[M:SQH0]SQHNUM
  If !fstat Then
    mkstat = 4
  Endif
End

########################################
Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()

# 101874 : V9 : Taxe code control
Local Char WANCBPCORD(GLONBPC):WANCBPCORD=[M:SQH0]BPCORD
# 101874

  # FGR 21/11/2013 : X3SUIVI94616 (début)
  If [F:BPC]BPCNUM <> VALEUR Then
    Read [BPC]BPC0=VALEUR
  Endif
  # FGR 21/11/2013 : X3SUIVI94616 (fin)
  Gosub AFFICHE_BCK_TIERS From SUBSQHA  # FGR 12/03/2014 : X3SUIVI69847
  # --> Si utilisation du bouton adresse, il ne faut pas passer en AM_
  #MAE, on doit passer en AM_ si le devis est créé depuis la fiche client(GCREFONC=1)
  If !GIMPORT & VALEUR = [M]BPCORD & GCREFONC = 0 End : Endif
  #--/
  # --- Changement de client en dupplication de devis
  # --> Sauvegarde devise, régime, type de prix
  If GREP="D"
    Local    Char    WANCVACBPR(GLONTVB)
    Local    Integer WANCPRITYP
    Local    Char    WANCLAN    : WANCLAN=[M:SQH0]LAN
    WANCVACBPR = [M:SQH1]VACBPR
    WANCPRITYP = [M:SQH1]PRITYP
    Call OUVRE_TRACE(mess(172,123,1)) From LECFIC
  Endif
  Local Char WANCCUR(GLONCUR) : WANCCUR    = [M:SQH1]CUR
  # --> INITIALISATION DES MASQUES PAR LE CLIENT
  Call ALIQUO(VALEUR) From SUBSQHB
  GFLTBPC = VALEUR
  GBPCNUM = VALEUR

  # GRNA 20/05/2011
  Local Char CUSSEAORI : CUSSEAORI = "SQH1"
  Gosub AM_BPRNUM From CUSSEALIB

  If WANCCUR<>[M:SQH1]CUR
    # Alimentation du format des colonnes frais/remise
    Call ALIFORREM (1, GFLAG, "SQH2", 0, [M:SQH1]CUR) From TRTPRICE
  Endif

  If GREP="D"
    Raz [M:SQH1]PJT
    Raz [M:SQH2]DPJT  : # 71065 : PJT
    #   --> Recalcul des lignes de devis
# 101874 : V9 : Taxe code control
#      Local Char WANCBPCORD(GLONBPC):WANCBPCORD=[M:SQH0]BPCORD
# 101874
    Local Char WZONCOU:WZONCOU="BPCORD"
    Local Char FFLGMOD
    Local Integer OK
    Call OUINON (mess(21,191,1),OK) From GESECRAN
    If OK=2 GTARFLG="1" Endif
    Gosub RECALC_LIGNE From SUBSQHB
    If mkstat = 2 [M:SQH0]BPCORD=WANCBPCORD: End Endif
    Raz GMESSAGE
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
  # --> AFFICHAGE DES OBSERVATIONS DU CLIENT COMMANDE
  If !GIMPORT
   If len(vireblc([F:BPC]BPCREM,2)) & GERR=0 GMESSAGE = [F:BPC]BPCREM : GERR=2 : Endif
  Endif
  # --> Réalimentation de la raison sociale en fonction de la saisie adresse
  If  [M:ADB1]BPRNAM(0) <> ""
    [M]BPCNAM = [M:ADB1]BPRNAM(0)
  Else
    [M]BPCNAM = [F:BPC]BPCNAM
  Endif
  Affzo [M:SQH0]CUR, BPCNAM
  Affzo [M:SQH1] 5,10,15,20
  Affzo [M:SQH3] 5,15,20

  # Pour le client facture, on récupère le client facture du client commande (car non présent sur l'écran devis)
  #--CPO 82369 Duplication avec changement du client
  #Call NEW_SFIT ("M","SQH3",[M:SQH0]CUR,[F:BPC]BPCINV,VALEUR,[M:SQH0]QUODAT) From SUBSFIT
  If GREP="D"
    GREP="C"
    Local Char SFIT_OBJ : SFIT_OBJ="SQH"
    Gosub INIT_SFIT From SUBSFIT
    Call NEW_SFIT ("M","SQH3",[M:SQH0]CUR,[F:BPC]BPCINV,VALEUR,[M:SQH0]QUODAT) From SUBSFIT
    GREP="D"
  Else
    Call NEW_SFIT ("M","SQH3",[M:SQH0]CUR,[F:BPC]BPCINV,VALEUR,[M:SQH0]QUODAT) From SUBSFIT
  Endif
  #--/CPO
End

#####################################################################
#               LES ACTIONS SUR LES ZONES ECRAN entete SQH1         #
#####################################################################

# --------------------------------------- BPAADD --------------------------------
Subprog IB_BPAADD

If [F:BPC]BPCNUM<>[M:SQH0]BPCORD
   Read [F:BPC]BPC0=[M:SQH0]BPCORD
   If fstat Raz [F:BPC] : Endif
Endif

If [F:BPC]BPCTYP=4
    Raz GBOUTS
    Raz GBOUT3
Else
    Raz GBOUT2
Endif
End
########################################
Subprog C_BPAADD(VALEUR)
Variable Char    VALEUR()

If VALEUR = "" End Endif

If [F:BPC]BPCNUM<>[M:SQH0]BPCORD
   Read [F:BPC]BPC0 = [M:SQH0]BPCORD
   If fstat Raz [F:BPC] : Endif
Endif
If [F:BPC]BPCTYP=4
    # Prospect : Il n'y a pas de client livré, on vérifie juste que l'adresse existe dans le fichier des adresses
    If [F:BPA]BPATYP <> 1 | [F:BPA]BPANUM <> [M:SQH0]BPCORD | [F:BPA]BPAADD <> VALEUR
        Read [F:BPA]BPA0 = 1;[M:SQH0]BPCORD;VALEUR
        If fstat
            mkstat = 2 : GMESSAGE = VALEUR-":"-mess(23,100,1) : End : # Fiche inexistante
        Endif
    Endif
Else
    If [F:BPD]BPCNUM <> [M:SQH0]BPCORD | [F:BPD]BPAADD <> VALEUR
        # Client livre
        Read [F:BPD]BPD0 = [M:SQH0]BPCORD;VALEUR
        If fstat
            mkstat = 2 : GMESSAGE = VALEUR-":"-mess(23,100,1) : End : # Fiche inexistante
        Endif
    Endif
    If [F:BPD]ENAFLG=1 mkstat = 2 : GMESSAGE = mess(13,15,1)-":"-VALEUR-"\"-mess(2,126,1) : End : Endif :# Fiche inactive
Endif

End
########################################
Subprog AP_BPAADD(VALEUR)
Variable Char    VALEUR()
# --> Si modif de l'adresse raz adresse avant de passer dans le bouton adresse
If !GIMPORT & VALEUR <> [M]BPAADD Raz [M:ADB2] : Endif
#LTA.sn
If dim([M:SQH1]SSTENTCOD)>0 & [M:ADB2]ADBFLG = 2
  #Delivery address was manually edited ; could have new country (AM_BPADD will handle just ID changes)
  Gosub SHOW_HIDE_ENTCOD From TRTADRLIB
Endif
#LTA.en
# --> Alimentation de la raison sociale
If [M:ADB2]BPRNAM(0) <> ""
   [M]BPDNAM = [M:ADB2]BPRNAM(0)
Elsif [F:BPC]BPCTYP = 1 & VALEUR <> ""
   [M]BPDNAM = [F:BPD]BPDNAM(0)
Elsif VALEUR <> ""                   : # Prospect et adresse de livraison renseignée
    [M]BPDNAM = [M:SQH0]BPCNAM
Else                               : # Adresse de livraison non renseignée
    Raz [M]BPDNAM
Endif
Affzo [M]BPDNAM
End
########################################
Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()

Local    Integer OK
Local    Integer NOL : NOL=nolign-1
Local    Char    TYPCLI : TYPCLI ="L"

# Particularité zone BPAADD : Si W_ALICDE= 1 : Pas de réalimentation des zones d'entête avec la nvelle adresse
#                             Si W_ALICDE= 2 : On a ddé de réalimenter des zones d'entête avec la nvelle adresse
#                             --> On répercutera tous les champs concernés
#                             Si W_ALICDE=21 : Il faut forcer la répercution sur les lignes (pour ne pas avoir d'incohérences)
Local    Integer W_ALICDE : W_ALICDE=1


# --> Si utilisation du bouton adresse, il ne faut pas passer en AM_
If !GIMPORT & VALEUR = [M]BPAADD End : Endif
If VALEUR<>""
    OK=2
    If !GIMPORT & GREP <> "C" & GREP <> "D" & [F:BPC]BPCTYP = 1
        Call OUINON (mess(129,191,1),OK) From GESECRAN
    Endif
    If (GREP = "C" | OK=2) & [F:BPC]BPCTYP = 1
        W_ALICDE=2
        If [M:SQH2]NBLIG<>0
            # On affiche plus les msgs d'avertissement si infos douanières ou régime de taxes différents sur les lignes
            #Gosub CTR_COHERENCE_LIGNE
            If mkstat=2
                # Restauration de la raison sociale
                If [M]BPDNAM = [F:BPD]BPDNAM(0)
                    If [M:ADB2]BPRNAM(0) <> ""
                       [M]BPDNAM = [M:ADB2]BPRNAM(0)
                    Else
                        If [F:BPD]BPCNUM<>[M:SQH0]BPCORD | [F:BPD]BPAADD<>[M:SQH1]BPAADD
                            Read [F:BPD]BPD0 = [M:SQH0]BPCORD;[M:SQH1]BPAADD : If fstat Raz [BPD] Endif
                        Endif
                        [M]BPDNAM = [F:BPD]BPDNAM(0)
                    Endif
                    Affzo [M]BPDNAM : mkstat=2 : # (cassé par l'affzo)
                Endif
                End
            Endif
        Endif
    #   --> ALIMENTATION ZONES PAR CLIENT LIVRé
        #103379 move this line of code out of GLOCUSATAX if statement that was added in version 7.
        Gosub TRTBPD From SUBSQHB               #103379 n
        # If GLOCUSATAX   # 106867.o
        If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
          #Gosub TRTBPD From SUBSQHB #LTA.n     #103379 o
          If [M:ADB2]ADRVAL <> 2 and func TRTADRLIB.CHKADR_CRY([M:ADB2]CRY)
            GMESSAGE = mess(366,192,1)  # Address has not been validated
            If func TRTADRLIB.CHKADR_MANDATORY()
              GERR=1
              mkstat = 2
              End
            Else
              GERR=2
            Endif
          Endif
        Endif
        Affzo [M:SQH1]10, 15, 20
    #Elsif GREP = "D" | [F:BPC]BPCTYP = 4
    Else
    #   Réalimentation du code adresse dans [M:ADB2] pour saisie adresse libre
        If dim([M:ADB2]BPAADD) > 0
            [M:ADB2]BPAADD    = VALEUR
            Call RECH_CNTNAM([M:SQH0]BPCORD, VALEUR, [M:ADB2]CNTNAM) From TRTVENDIV
        Endif
        #LTA.sn
        # If GLOCUSATAX and dim([M:SQH1]SSTENTCOD)>0   # 106867.o
        If func AFNC.ACTIV("LTA") and [F:CPY]SSTTAXACT = 2 and dim([M:SQH1]SSTENTCOD)>0   # 106867.n
          #Order where we have not loaded [M:ADB2]; need default ship to country to display SSTENTCOD
          If [F:BPD]BPAADD<>"" & [M:ADB2]CRY =""
              Call CHARGE_ADRMSK("ADB2", [M:SQH0]BPCORD) From TRTVENDIV
          Endif
          Gosub SHOW_HIDE_ENTCOD From TRTADRLIB
          If [M:ADB2]ADRVAL <> 2
            GMESSAGE = mess(366,192,1)  # Address has not been validated
            If func TRTADRLIB.CHKADR_MANDATORY()
              GERR=1
              mkstat = 2
              End
            Else
              GERR=2
            Endif
          Endif
        Endif
        #LTA.en
#---
    Endif
Endif
# --> Réalimentation de la raison sociale
If [M:ADB2]BPRNAM(0) <> ""
   [M]BPDNAM = [M:ADB2]BPRNAM(0)
Elsif [F:BPC]BPCTYP=1 & VALEUR<>"" : # Client et adresse de livraison renseignée
   [M]BPDNAM = [F:BPD]BPDNAM(0)
Elsif VALEUR<>""                   : # Prospect et adresse de livraison renseignée
   [M]BPDNAM = [M:SQH0]BPCNAM
Else                               : # Adresse de livraison non renseignée
   Raz [M]BPDNAM
Endif
GBIDI1=W_ALICDE : # Paramètre passé à l'action TRTMAJDET
Affzo [M:SQH1]BPDNAM
End
# -------------------------------------------------------------------------------
# Contrôle de cohérence entre le client livré entête et les clients livrés lignes
# -------------------------------------------------------------------------------
$CTR_COHERENCE_LIGNE

# Gestion des adresses de livraison à la ligne
If [F:BPC]BPCTYP<>4 & [M:SQH2]NBLIG<>0 & GLINBPD=2
    # Si adresses de livraison à la ligne différentes de celle de l'entête
    # Vérif.cohérence entre l'adresse entête et adresses à la ligne concernant les infos douanières et le régime de taxe
    Local Char WVACBPR(GLONTVB), WDETVACBPR(GLONTVB), WENTVACBPR(GLONTVB)
    Local Integer WI, WJ, WOK
    WJ=sigma(WI=0,[M]NBLIG-1,[M:SQH2]DBPAADD(WI)<>VALEUR)
    If WJ<>0
        If clalev([F:BPD1]) = 0 Local File BPDLVCUST [BPD1] : Endif
        For WI=0 To [M]NBLIG-1
            If [M]DBPAADD(WI)<>VALEUR
                If [F:BPD1]BPCNUM<>[M:SQH0]BPCORD | [F:BPD1]BPAADD<>[M:SQH2]DBPAADD(WI)
                    Read [F:BPD1]BPD0 = [M:SQH0]BPCORD;[M:SQH2]DBPAADD(WI)
                    If fstat Raz [F:BPD1] Endif
                Endif
                If [F:BPD]VACBPR="" | [F:BPD1]VACBPR=""
                    Call INIT_REGIME([M:SQH0]BPCORD, GSOCIETE, "C", WVACBPR) From CPTSUB
                Endif
                If [F:BPD1]VACBPR<>"" WDETVACBPR=[F:BPD1]VACBPR Else WDETVACBPR=WVACBPR Endif
                If [F:BPD]VACBPR <>"" WENTVACBPR=[F:BPD]VACBPR  Else WENTVACBPR=WVACBPR Endif
                WOK=2
                If (WDETVACBPR<>WENTVACBPR)
                    # Régime de taxe client livré XXX différent du régime de taxe client livré ligne YYY
                    # A la dde de CH : Le ctrl ne doit plus être bloquant
                    GMESSAGE=mess(620,197,1)-mess(42,191,1)-"("+WENTVACBPR+")"-mess(621,197,1)-mess(620,197,1)-mess(42,191,1)-mess(18,197,1)-[M:SQH2]DBPAADD(WI)-"("+WDETVACBPR+")"
                    WOK=1
                Elsif ([F:BPD]EECNUM<>[F:BPD1]EECNUM & [F:BPD1]EECNUM<>"")
                    #FQ 55836 - Le ctrl ne doit plus être bloquant
                    #mkstat=2 : # N°Identification CEE client livré XXX différent du N°identification CEE client livré ligne YYY
                    GMESSAGE=mess(629,197,1)-mess(42,191,1)-"("+[F:BPD]EECNUM+")"-mess(621,197,1)-mess(629,197,1)-mess(42,191,1)-mess(18,197,1)-[M:SQH2]DBPAADD(WI)-"("+[F:BPD1]EECNUM+")"
                    WOK=1
                    #fin FQ 55836
                Elsif ([F:BPD]EECICT<>[F:BPD1]EECICT & [F:BPD1]EECICT<>"")
                    #FQ 55836 - Le ctrl ne doit plus être bloquant
                    #mkstat=2 : # Code incoterm client livré XXX différent du code incoterm client livré ligne YYY
                    GMESSAGE=mess(630,197,1)-mess(42,191,1)-"("+[F:BPD]EECICT+")"-mess(621,197,1)-mess(630,197,1)-mess(42,191,1)-mess(18,197,1)-[M:SQH2]DBPAADD(WI)-"("+[F:BPD1]EECICT+")"
                    WOK=1
                    #fin FQ 55836
                Elsif dim([M:SQH0]EECLOC)>0 & ([F:BPD]EECLOC<>[F:BPD1]EECLOC & [F:BPD1]EECLOC<>0)
                    #FQ 55836 - Le ctrl ne doit plus être bloquant
                    #mkstat=2 : # Lieu transport CEE client livré XXX différent du Lieu transport CEE client livré ligne YYY
                    GMESSAGE=mess(631,197,1)-mess(42,191,1)-"("+mess([F:BPD]EECLOC,236,1)+")"-mess(621,197,1)-mess(631,197,1)-mess(42,191,1)-mess(18,197,1)-[M:SQH2]DBPAADD(WI)-"("+mess([F:BPD1]EECLOC,
& 236,1)+")"
                    WOK=1
                    #fin FQ 55836
                Endif
                # Si incohérence, on prévient l'utilisateur, s'il décide de continuer on force la répercution sur les lignes
                If WOK=1
                    Call AVERTIR (GMESSAGE, WOK) From GESECRAN
                    Raz GMESSAGE : If WOK=2 W_ALICDE=21 Else mkstat=2 : Break : Endif
                Endif
            Endif
        Next
    Endif
    If mkstat=2 Return Endif
    # Il y a des incohérences entre le clt livré entête et les clts livrés lignes
    # --> Répercution automatique obligatoire sur les lignes détails
    If W_ALICDE=21 Call MESSAGE (mess(204,191,1)-":\"-mess(205,191,1)) From GESECRAN Endif
Endif
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran SQH1) 15/09/2009 09:01:05 (LD)
######################################################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
Local Integer WOK
Local Char    WFCY(GLONFCY)
If [M:SQH2]NBLIG<>0 & VALEUR<>[M]STOFCY
    WFCY=VALEUR
    Gosub VERIF_LIGNE_ITF From SUBSQHB
    If WOK=0
        GMESSAGE =GMESSAGE-mess(25,192,1)-WFCY-"\"-mess(205,100,1)
        WOK=2 : Call AVERTIR (GMESSAGE, WOK) From GESECRAN : Raz GMESSAGE
        If WOK=1 mkstat=2 : Endif
    Endif
Endif
End
