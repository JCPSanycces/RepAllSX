# --------------------------------------- VACBPR --------------------------------
########################################
Subprog AM_VACBPR(VALEUR)
Variable Char    VALEUR()
Local    Integer NLIG
Local    Char    VAT(GLONVAT)(3)
Local    Char    WVACITM(GLONTVI)(3)
Local    Char    WANCVACBPR(GLONTVB) : WANCVACBPR=[M]VACBPR     : # Bug 75162

# Il n'y a pas de détail, on ne fait rien
If [M:SQH2]NBLIG = 0 End Endif
# On redescend la modification sur tous les détails
Raz [M]QUONOT, QUOATI, PFMTOT
# Issue X3-148035 - 20190731 by LD
Raz [M:SQH0]DSPTOTQTY,DSPTOTVOL,DSPTOTWEI
# Issue X3-148035 - 20190731 by LD
Raz NLIG
While NLIG < [M]NBLIG
   Call LECT_FIC(NLIG) From SUBSQHB
#  Réalimentation des codes taxes
   WVACITM(0) = [M]VACITM1(NLIG)
   WVACITM(1) = [M]VACITM2(NLIG)
   WVACITM(2) = [M]VACITM3(NLIG)
   #Call ALITAXEV(VALEUR,WVACITM,VAT) From TRTX3
   [M:SQH1]VACBPR=VALEUR
   Call RECHVATCOD(1,1,[M:SQH0]BPCORD,[M:SQH2]ITMREF(NLIG),"SQH2",NLIG,VAT) From TRTX3
   # Bug 75162 : Contrôle que le code taxe1 est bien renseigné
   Call CTLVAT(VAT(0)) From TRTVENCTL
   If mkstat=2
      [M:SQH1]VACBPR=WANCVACBPR
      GMESSAGE = [M:SQH2]ITMREF(NLIG)-" : "-GMESSAGE : Break
   Endif
   # Bug 75162
   [M]VAT1(NLIG) = VAT(0)
   [M]VAT2(NLIG) = VAT(1)
   [M]VAT3(NLIG) = VAT(2)
#  Recalcul des prix et des totaux
   Local Integer INICPRPRI : INICPRPRI=1
   # Issue X3-148035 - 20190731 by LD
   # Totals calculation
   # Margin is calculated only if WFLGTOT="O"
   WFLGTOT="O"
   # Issue X3-148035 - 20190731 by LD
   Gosub RECALC_TOT From SUBSQHB
   NLIG+=1
Wend
If mkstat End : Endif : # Bug 75162

# Issue X3-148035 - 20190731 by LD
# We have to do the valuation
If !GIMPORT
    # Valuation is always done in this case
    GVALTTC=2
    #---- Paramètres complementaires appel valorisation
    # PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
    # PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non/2=Oui)
    # PARAM_T(2) : Flag retour                         (1=KO/2=OK)
    #---- Additional parameters for the valuation call
    # PARAM_T(0) : Tax control flag                    (1=No/2=Yes)
    # PARAM_T(1) : Log reading by the subprog          (1=No/2=Yes)
    # PARAM_T(2) : Return flag                         (1=KO/2=OK)
    Local    Char     PARAM_T (25) (0..10)
    PARAM_T(0)="1"      : # Pas de contrôle des taxes   # No tax control
    PARAM_T(1)="1"      : # Pas de lecture de la trace  # No log reading
    PARAM_T(2)="0"
    Call VALTTC ("GESSQH", PARAM_T) From TRTVENFACR
    If PARAM_T(2)="1" mkstat=2 : End Endif
Endif
# Issue X3-148035 - 20190731 by LD

Affzo [M:SQH2]5,10,15
End
########################################
# --------------------------------------- CUR --------------------------------
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()
Local    Integer  NLIG
Local    Char     WANCCUR(GLONCUR) : WANCCUR=[M:SQH0]CUR

Gosub CONV_INVDTAAMT From SUBSQHB

# Alimentation du format des colonnes frais/remise
Call ALIFORREM (1, GFLAG, "SQH2", 0, VALEUR) From TRTPRICE

[M:SQH0]CUR = VALEUR
# Il n'y a pas de détail, on ne fait rien
If [M:SQH2]NBLIG <> 0 & GTARFLG=""
# On redescend la modification sur tous les détails
    Raz NLIG
    Raz [M]QUONOT,QUOATI,PFMTOT
    # Issue X3-148035 - 20190731 by LD
    Raz [M:SQH0]DSPTOTQTY,DSPTOTVOL,DSPTOTWEI
    # Issue X3-148035 - 20190731 by LD
    [M:SQH1]CUR=VALEUR
    While NLIG < [M]NBLIG
       Call LECT_FIC(NLIG) From SUBSQHB
#      PAs de recherche tarif : on fera une conversion
       If GTARFLG = ""
          Local Integer INICPRPRI : INICPRPRI=1
          Gosub CONV_LIGNE From SUBSQHB
          # Issue X3-148035 - 20190731 by LD
          # Totals calculation
          # Margin is calculated only if WFLGTOT="O"
          WFLGTOT="O"
          # Issue X3-148035 - 20190731 by LD
          Gosub RECALC_TOT From SUBSQHB
       Endif
       NLIG+=1
    Wend
Endif
Raz GTARFLG

# Issue X3-148035 - 20190731 by LD
# We have to do the valuation
If !GIMPORT
    # Valuation is always done in this case
    GVALTTC=2
    #---- Paramètres complementaires appel valorisation
    # PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
    # PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non/2=Oui)
    # PARAM_T(2) : Flag retour                         (1=KO/2=OK)
    #---- Additional parameters for the valuation call
    # PARAM_T(0) : Tax control flag                    (1=No/2=Yes)
    # PARAM_T(1) : Log reading by the subprog          (1=No/2=Yes)
    # PARAM_T(2) : Return flag                         (1=KO/2=OK)
    Local    Char     PARAM_T (25) (0..10)
    PARAM_T(0)="1"      : # Pas de contrôle des taxes   # No tax control
    PARAM_T(1)="1"      : # Pas de lecture de la trace  # No log reading
    PARAM_T(2)="0"
    Call VALTTC ("GESSQH", PARAM_T) From TRTVENFACR
    If PARAM_T(2)="1" mkstat=2 : End Endif
Endif
# Issue X3-148035 - 20190731 by LD

Affzo [M:SQH0]1-99
Affzo [M:SQH2]5,10,15

End
# --------------------------------------- PRITYP --------------------------------
########################################
Subprog AM_PRITYP(VALEUR)
Variable Integer VALEUR
Local    Integer NLIG

# Il n'y a pas de détail, on ne fait rien
If [M:SQH2]NBLIG <> 0 & GTARFLG = ""
# On redescend la modification sur tous les détails
    [M]PRITYP = VALEUR
    Raz NLIG
    While NLIG < [M]NBLIG
       Call LECT_FIC(NLIG) From SUBSQHB
#      Pas de recherche tarif : On se contente de réalimenter le prix net
       If GTARFLG = ""
          If VALEUR = 1
             [M]NETPRI(NLIG) = [M]NETPRINOT(NLIG)
          Else
             [M]NETPRI(NLIG) = [M]NETPRIATI(NLIG)
          Endif
       Endif
       NLIG+=1
    Wend
Endif
Raz GTARFLG
Affzo [M:SQH2]5, 10, 15
End
