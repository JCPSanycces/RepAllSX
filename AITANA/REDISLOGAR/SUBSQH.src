Subprog AM_PJT(VALEUR)
Variable Char    VALEUR()
#
#If GMODU(13) = 2
#    If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
#    Read [OPP] OPP0 = VALEUR
#    If fstat
#        [M:SQH1]PJTCLA = ""
#        Grizo [M:SQH1]PJTCLA
#    Else
#        Actzo [M:SQH1]PJTCLA
#        [M:SQH1]PJTCLA = left$([F:OPP]OPPDES, 45)
#    Endif
