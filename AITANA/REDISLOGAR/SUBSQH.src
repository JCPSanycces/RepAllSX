## Etiquette ajoutée par le superviseur (écran SQH2) 14/09/2005 15:31:41 (LD)
######################################################################################
# -------------------------------------- DSTOFCY ------------------------
Subprog IB_DSTOFCY
# Activation du bouton article-site
If [M:SQH2]STOMGTCOD(nolign-1) = 1 Raz GBOUT1 Endif
End
########################################
Subprog C_DSTOFCY(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL : NOL=nolign-1
Local Integer LRET                       # FGR 10/04/2015 : X3SUIVI105605

If ([M]CREFLG(NOL)=0 & [M]UPDFLG(NOL)=0) | [M]DSTOFCY(NOL)<>VALEUR
    Call CONTITF([M:SQH2]ITMREF(NOL),VALEUR,[M:SQH2]STOMGTCOD(NOL)) From TRTVENCTL
    If mkstat=2
        Local Integer WOK : WOK=2
        Call AVERTIR (GMESSAGE, WOK) From GESECRAN : Raz GMESSAGE
        If WOK=1 End Else mkstat=0 Endif
    Endif
Endif
  # FGR 10/04/2015 : X3SUIVI105605 (début)
  If dim([M:SQH2]ECCVALMAJ) >= 0 Then
    Call CTLECCVAL([M:SQH2]ECCVALMAJ(NOL), VALEUR, [M:SQH2]ITMREF(NOL), 4, "", [M:SQH0]QUODAT, LRET) From STKSOR
    If LRET > 1 Then
      mkstat = 2
    Endif
  Endif
  # FGR 10/04/2015 : X3SUIVI105605 (fin)
End
