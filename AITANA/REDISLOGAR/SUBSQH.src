$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE Return : Endif
Call INIT_CCE(VALEUR,AXE,"SQD","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:SQH0]QUODAT) From TRTX3CPT
#--CPO 74669 Import des devis et contrôle sections (+modif obj SQH)
If GIMPORT & mkstat
  GMESSAGE-="-"-mess(18,197,1)-num$(nolign)-mess(80,197,1)-[M:SQH2]ITMREF(nolign-1)
Endif
#--CPO
Return

