## Etiquette ajoutée par le superviseur (écran SQH0) 23/02/2015 11:07:09 (FGR)
######################################################################################
Subprog AP_SQHTYP(VALEUR)
Variable Char    VALEUR()

Local Integer WRET

  # FGR 20/02/2015 : X3SUIVI104383
  If [F:TSQ]CODNUM <> "" Then
    GMANCOU = [F:TSQ]MANCOU
    GCPT = [F:TSQ]CODNUM
  Else
    #-- Aucun compteur associé au type de devis
    If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
    Call LECTCA(5, WRET) From SUBTCA
    If fstat or !WRET Then
      GERR = 1
      GMESSAGE = mess(58,105,1) - mess(5,14,1) - mess(250,199,1)
      End
    Endif
    GMANCOU = [F:TCA]MANCOU(0)
    GCPT = [F:TCA]CODNUM(0)
  Endif
  If GREP = "C" and GMANCOU = 1 and (dim(GWEBSERV)>1 and GWEBSERV=1) Then
    Effzo [M:SQH0]SQHNUM
  Endif
  If GREP = "C" & GMANCOU = 1 Then
    Diszo [M:SQH0]SQHNUM
  Else
    Actzo [M:SQH0]SQHNUM
  Endif
End

######################################################################################
Subprog AM_SQHTYP(VALEUR)
Variable Char    VALEUR()

  # FGR 20/02/2015 : X3SUIVI104383
  If GMANCOU = 1 & [M:SQH0]SQHNUM <> "" Then
    Effzo [M:SQH0]SQHNUM
  Endif
  [M:SQH1]SOHTYP = [F:TSQ]SOHTYP
  Affzo [M:SQH1]SOHTYP
End

######################################################################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

  # FGR 01/04/2015 : X3SUIVI105605
  Gosub ECCVALMAJMIN_ENABLE
End

######################################################################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET
Local Integer NOL
Local Integer IOK

  # FGR 10/04/2015 : X3SUIVI105605
  NOL = nolign-1
  Call CTLECCVAL(VALEUR, [M:SQH2]DSTOFCY(NOL), [M:SQH2]ITMREF(NOL), 4, "", [M:SQH0]QUODAT, LRET) From STKSOR
  If LRET > 1 Then
    mkstat = 2
    End
  Elsif LRET = 1 Then
    IOK = [V]CST_AYES
    Call AVERTIR (GMESSAGE, IOK) From GESECRAN
    Raz GMESSAGE
    If IOK = 1 Then
      mkstat = 2
      End
    Endif
  Endif
End

######################################################################################
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Char WECCVALMAJ(GLONECS)
Local Char WECCVALMIN(GLONICVVAL)
Local Char PITM(GLONITM)

  # FGR 10/04/2015 : X3SUIVI105605
  Raz WECCVALMAJ
  Raz WECCVALMIN
  Raz PITM
  # si version majeure trouvée et si article gere la version mineure : recherche derniere version mineure
  If [F:ITM]ITMREF <> [M:SQH2]ITMREF(nolign-1) Then
    Read [ITM]ITM0=[M:SQH2]ITMREF(nolign-1)
  Endif
  If VALEUR  <> "" and [F:ITM]ECCSTO = 3 Then
    WECCVALMAJ = VALEUR
    PITM = [F:ITM]ITMREF
    Gosub READECCMIN From STKACT
    [M:SQH2]ECCVALMIN(nolign-1) = WECCVALMIN
    Affzo [M:SQH2]ECCVALMIN(nolign-1)
  Elsif VALEUR = "" and [M:SQH2]ECCVALMIN(nolign-1) <> "" Then
    Raz [M:SQH2]ECCVALMIN(nolign-1)
    Affzo [M:SQH2]ECCVALMIN(nolign-1)
  Endif
End

######################################################################################
Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

  # FGR 01/04/2015 : X3SUIVI105605
  Gosub ECCVALMAJMIN_ENABLE
End

######################################################################################
$ECCVALMAJMIN_ENABLE
  # FGR 01/04/2015 : X3SUIVI105605
  If [M:SQH2]ORDQTY(nolign-1) > 0 Then
    mkstat = 2
  Endif
  If find([M:SQH2]LINTYP(nolign-1),3,4,5,11,12,13) Then
    mkstat = 2
  Endif
Return

