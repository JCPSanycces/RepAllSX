#<AdxTL>@(#)7.0.0.0 $Revision$
#ACV#X12
#TIT#Consultation "Test génération de DS"

#==========================================================================================
# Gestion du test de la génération des DS (objet de consultation)
#                        
# Auteur                     : LBORN
# Date de création           : 12/09/2003
#==========================================================================================
# Modifications significatives
#------------------------------------------------------------------------------------------
# Date          Auteur       Description
#==========================================================================================

Local Char PARAM(30)(1..6)

PARAM(1)=""
PARAM(2)=""
PARAM(3)=""
PARAM(4)=""
PARAM(5)=""
PARAM(6)=""
Call GCONSULT("XGD","",PARAM)From GCONSULT
End


###################################################################
# Actions objet de consultation
###################################################################

$ACTION

Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
Endcase
Return


#-----------------------------------------
$OUVRE
#-----------------------------------------

# LBORN 25/03/2013 - Mantis 18788 - Suite Bug validation différée
If !clalev([F:XCG]) : Local File CONTRACTMP : Endif

Local Char FCYDEB(10), FCYFIN(10), BPCDEB(30), BPCFIN(30), RUPDEB(30), RUPFIN(30), VGADEB(20), VGAFIN(20)
Local Char CRITVGT1(255), CRITVGT2(255), ZIDENT(100)
Local Integer ZF, ZSTAT

[L]CRITVGT2="1=1"

# Lancement automatique de la recherche
CHARGMT=0

# Initialisation de ZIDENT
[L]ZIDENT=[V]GIDENT
Call ALPHANUM([L]ZIDENT) From XBIBCH

# Préchargement masque / Paramètres envoyés
Gosub PRECH_MSK

Return

#-----------------------------------------
$SETBOUT
#-----------------------------------------
Call VIREBOUT(CHAINE,"D-") From GOBJET
Return

#-----------------------------------------
$LECTURE
#-----------------------------------------
# On ne gère pas le bouton <Dernier>
If CHGPAG=(-1) : Return : Endif

Gosub CHANGE_MSK From GCONSULT 
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
# Appel au filtre spécifique client
ACTION = "FILTRE"
Gosub ACTION From XOBJCNS
ACTION = "LECTURE"

# -------------------------------------------------------
# CHGPAG = 1    :    Recherche                           
# ------ = 2    :    Suite                               
#        = 3    :    F5 (Rafraichissement page courante) 
# CHGPAG = -1   :    Dernier                             
# ------ = -2   :    Retour (Page précédente)            
# -------------------------------------------------------

#-- Application des Filtres
If CHGPAG>0
  SUITE=1
  If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
  Filter [VGT] Where evalue([L]CRITVGT1) & evalue([L]CRITVGT2) Order By Key VGA5
Else
  RETOUR=1
  If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
  Filter [VGT] Where evalue([L]CRITVGT1) & evalue([L]CRITVGT2) Order By Key VGA5 Desc
Endif

#-- Raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:XGD2] : Endif

# Remplissage du détail
Call TEMPON("L") From GESECRAN
Gosub REMP_TAB
Call TEMPOFF From GESECRAN

RETOUR=1

Return



###################################################################
# Divers
###################################################################

#------------------------------------------------------------------
# Préparation du filtre                                 
#------------------------------------------------------------------
$LOAD_FILTER

[L]CRITVGT1="[F:VGT]IDENT='"+[L]ZIDENT+"' & [F:VGT]ORIVAL=8"
[L]CRITVGT2="1=1"

If [M:CXGD]CORGFCY<>""
  [L]CRITVGT1-="& [F:VGT]ORGFCY='"+[M:CXGD]CORGFCY+"'"
Endif
If [M:CXGD]CBPCINV<>""
  [L]CRITVGT1-="& [F:VGT]BPCINV='"+[M:CXGD]CBPCINV+"'"
Endif
If [M:CXGD]PCEDEB<>[0/0/0]
  [L]CRITVGT1-="& [F:VGT]PCEDAT>=[M:CXGD]PCEDEB"
Endif
If [M:CXGD]PCEFIN<>[0/0/0]
  [L]CRITVGT1-="& [F:VGT]PCEDAT<=[M:CXGD]PCEFIN"
Endif
If [M:CXGD]ORICON<>[M:CXGD]ORIMAC
  If [M:CXGD]ORICON=2
    [L]CRITVGT1-="& [F:VGT]COPNUM=''"
  Elsif [M:CXGD]ORIMAC=2
    [L]CRITVGT1-="& [F:VGT]COPNUM<>''"
  Endif
Endif
If [M:CXGD]RESINTC<>""
  [L]CRITVGT1-="& [F:VGT]RESINT='"+[M:CXGD]RESINTC+"'"
Endif
If [M:CXGD]REQTYP<>""
  [L]CRITVGT1-="& [F:VGT]PARDOCGEN='"+[M:CXGD]REQTYP+"'"
Endif

If [M:CXGD]ITMREF <> "" Then
    [L]CRITVGT1 -= "& [F:VGT]ITMREF='"+[M:CXGD]ITMREF+"'"
Endif
If [M:CXGD]SERNUM <> "" Then
    [L]CRITVGT1 -= "& [F:VGT]SERNUM='"+[M:CXGD]SERNUM+"'"
Endif


# Critères debut/fin de page
Case CHGPAG
  When 3 : # rafraichissement
    [L]CRITVGT2-="& [F:VGT]ORGFCY>'"+[L]FCYDEB+"' | ([F:VGT]ORGFCY='"+[L]FCYDEB+"' & ("
    [L]CRITVGT2+="[F:VGT]BPCINV>'"+[L]BPCDEB+"' | ([F:VGT]BPCINV='"+[L]BPCDEB+"' & ("
    [L]CRITVGT2+="[F:VGT]RUPNUM>'"+[L]RUPDEB+"' | ([F:VGT]RUPNUM='"+[L]RUPDEB+"'"
    [L]CRITVGT2-="& [F:VGT]VALNUM>='"+[L]VGADEB+"')))))"
   When 2 : # suite
    [L]CRITVGT2-="& [F:VGT]ORGFCY>'"+[L]FCYFIN+"' | ([F:VGT]ORGFCY='"+[L]FCYFIN+"' & ("
    [L]CRITVGT2+="[F:VGT]BPCINV>'"+[L]BPCFIN+"' | ([F:VGT]BPCINV='"+[L]BPCFIN+"' & ("
    [L]CRITVGT2+="[F:VGT]RUPNUM>'"+[L]RUPFIN+"' | ([F:VGT]RUPNUM='"+[L]RUPFIN+"'"
    [L]CRITVGT2-="& [F:VGT]VALNUM>'"+[L]VGAFIN+"')))))"
   When -2 : # retour
    [L]CRITVGT2-="& [F:VGT]ORGFCY<'"+[L]FCYDEB+"' | ([F:VGT]ORGFCY='"+[L]FCYDEB+"' & ("
    [L]CRITVGT2+="[F:VGT]BPCINV<'"+[L]BPCDEB+"' | ([F:VGT]BPCINV='"+[L]BPCDEB+"' & ("
    [L]CRITVGT2+="[F:VGT]RUPNUM<'"+[L]RUPDEB+"' | ([F:VGT]RUPNUM='"+[L]RUPDEB+"'"
    [L]CRITVGT2-="& [F:VGT]VALNUM<'"+[L]VGADEB+"')))))"
Endcase
Return


#------------------------------------------------------------------
# Remplissage des lignes (détail)
#------------------------------------------------------------------
$REMP_TAB

[L]ZF=0

For [F:VGT]

  Gosub SETNOLIG
  If [L]ZF=1 : Break : Endif
  Read [F:XON]XON0=[F:VGT]CONREV
  If fstat : Raz [F:XON] : Endif
  [M:XGD2]=[F:VGT]
  If [F:VGT]COPNUM <> "" Then
    [M:XGD2]FLGMATFOR(nolign-1)=mess(55,[V]GXMSGPSA,1)
    Read [F:XCG]COP0 = [F:VGT]COPNUM
    If fstat : Raz [F:XCG] : Endif
    If [F:XCG]FASNUM<>""
      [M:XGD2]FASNUM(nolign-1)=[F:XCG]FASNUM
    Else
      [M:XGD2]FASNUM(nolign-1)=[F:XON]FASNUM
    Endif
    If [F:XCG]RESMAC<>""
      [M:XGD2]RESINT(nolign-1)=[F:XCG]RESMAC
    Else
      [M:XGD2]RESINT(nolign-1)=[F:XON]RESINT
    Endif
    If [F:XCG]REFDAT<>[0/0/0]
      [M:XGD2]REFDAT(nolign-1)=[F:XCG]REFDAT
    Else
      [M:XGD2]REFDAT(nolign-1)=[F:XON]REFDAT
    Endif
    If [F:XCG]REFNEXDAT<>[0/0/0]
      [M:XGD2]REFNEXDAT(nolign-1)=[F:XCG]REFNEXDAT
    Elsif [F:XON]REFNEXDAT>[M:XGD2]REFDAT(nolign-1)
      [M:XGD2]REFNEXDAT(nolign-1)=[F:XON]REFNEXDAT
    Endif
  Else
    [M:XGD2]FLGMATFOR(nolign-1)=mess(67,[V]GXMSGPSA,1)
    [M:XGD2]FASNUM(nolign-1)=[F:XON]FASNUM
    [M:XGD2]RESINT(nolign-1)=[F:XON]RESINT
    [M:XGD2]REFDAT(nolign-1)=[F:XON]REFDAT
    [M:XGD2]REFNEXDAT(nolign-1)=[F:XON]REFNEXDAT
  Endif
  [M:XGD2]DAYDAT(nolign-1)=day$([F:VGT]PCEDAT)
  [M:XGD2]BPCINV(nolign-1)=[F:VGT]BPSNUM
  [M:XGD2]ORGFCY(nolign-1)=[F:VGT]FINRSPFCY
    
 Next

Filter [VGT]
Return


$SETNOLIG
If NBLU=1
  If CHGPAG=2 | CHGPAG=-2 : Raz [M:XGD2] : Endif
  NBLU=2
Endif
If CHGPAG>0
  If NOL>=MAXLIG-1 : SUITE=2 : [L]ZF=1 : Return : Endif
  NOL+=1 
  If NOL=0 
    [L]FCYDEB=[F:VGT]ORGFCY 
    [L]BPCDEB=[F:VGT]BPCINV 
  Else
    [L]RUPDEB=[F:VGT]RUPNUM 
    [L]VGADEB=[F:VGT]VALNUM 
  Endif
  [L]FCYFIN=[F:VGT]ORGFCY 
  [L]BPCFIN=[F:VGT]BPCINV 
  [L]RUPFIN=[F:VGT]RUPNUM 
  [L]VGAFIN=[F:VGT]VALNUM 
Else
  If NOL<=0 : RETOUR=2 : [L]ZF=1 : Return : Endif
  NOL-=1 
  If NOL=MAXLIG-1 
    [L]FCYFIN=[F:VGT]ORGFCY 
    [L]BPCFIN=[F:VGT]BPCINV 
    [L]RUPFIN=[F:VGT]RUPNUM 
    [L]VGAFIN=[F:VGT]VALNUM
  Endif
  [L]FCYDEB=[F:VGT]ORGFCY 
  [L]BPCDEB=[F:VGT]BPCINV 
  [L]RUPDEB=[F:VGT]RUPNUM 
  [L]VGADEB=[F:VGT]VALNUM 
Endif

nolign=NOL+1
Return


#------------------------------------------------------------------
# Préchargement écran
#------------------------------------------------------------------
$PRECH_MSK

For I = 1 To dim(PARAM)
    Case I
        When 1 :    : # Parametre Site
            If PARAM(I) <> "" Then
                If [F:FCY]FCY <> PARAM(I) Then   
                    Read [F:FCY]FCY0 = PARAM(I)
                    If fstat  Raz [F:FCY] : Endif
                Endif
                [M:XGD1]CORGFCY = PARAM(I) 
                Call GETDEV([M:XGD1]CORGFCY) From DEVSUB
            Endif
   Endcase
Next

[M:XGD1]ORICON=2
[M:XGD1]ORIMAC=2

# Copie de l'écran d'entête vers l'écran critère
Gosub CRITENT From =PROGCNS

Return



###################################################################
# Ecran CONSXGD2
###################################################################

#-------------------------------
Subprog IB_NBLIG
If [M:XGD2]CONREV(nolign-1)="" | clalev([M:XON0])
  Raz [V]GBOUT6
Endif
If [M:XGD2]BPCINV(nolign-1)=""
  Raz [V]GBOUT7
Endif
End

