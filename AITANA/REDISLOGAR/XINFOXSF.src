Local Char VALBOUT(250) , PARBOUT(250)(1..20)
PARBOUT(1) = "AFF1002SAL00001"
PARBOUT(1)="AFF1001LYO00001"
PARBOUT(1)="AFF1004LYO00003"
PARBOUT(1)="AFF1002SFR00001"
PARBOUT(1)="AFF1006LYO00006"
#Raz PARBOUT
GACTION = "XSITFIN"
Call SAISIE_CHAR(VALBOUT,PARBOUT,"XSITFIN","XSITFIN","YSITFIN") From GSAISIE
End

#########################################################################################

$ACTION

Case ACTION
  When "INIT"       : Gosub INIT      From XINFOXSF2
  When "AVANT_PAR"  : Gosub AVANT_PAR From XINFOXSF2
  When "OK"         : Gosub OK        From XINFOXSF2
  When "DEBUT"      : Gosub DEBUT     From XINFOXSF2
Endcase

Return

######################################################################################
Subprog CL_ICO3(VALEUR)
Variable Char    VALEUR()
[M:XIF]EXTDAT=date$
Affzo [M:XIF]EXTDAT
End

######################################################################################
Subprog CL_ICO4(VALEUR)
Variable Char    VALEUR()
[M:XIF]EXTDAT=eomonth(addmonth(date$,-1))
Affzo [M:XIF]EXTDAT
End

######################################################################################
Subprog CL_ICO5(VALEUR)
Variable Char    VALEUR()
[M:XIF]PCEDAT=date$
Affzo [M:XIF]PCEDAT
End

######################################################################################
Subprog CL_ICO6(VALEUR)
Variable Char    VALEUR()
[M:XIF]PCEDAT=eomonth(addmonth(date$,-1))
Affzo [M:XIF]PCEDAT
End
