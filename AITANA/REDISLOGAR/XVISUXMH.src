## Action XVISUXMH
Local Char    PARMSK(250)(1..20) , SAVACT(20), VALEUR
SAVACT = GACTION : GACTION = "XVISUXMH"
PARMSK(1) = ""
Call SAISIE_CHAR(VALEUR,PARMSK,"XVISUXMH","XVISUXMH","") From GSAISIE
GACTION = SAVACT
End


$ACTION

Gosub ACTION From XVISUXMH2

Return

#==========================================================================================
Subprog AV_BOMALT(VALEUR)
Variable Decimal VALEUR

Raz VALEUR

If [M:XVMH]PARMACNUM<>""
  Read [F:MAC]MAC0=[M:XVMH]PARMACNUM
  If !fstat
    Read [F:ITM]ITM0=[F:MAC]MACPDTCOD
    If !fstat
      VALEUR=[F:ITM]XBOMALT
    Endif
  Endif
Endif

End

#==========================================================================================
Subprog IB_NBMAC

If [M:XVMH]XMAC(nolign-1)=""
  Raz [V]GBOUT5
Else
  [V]GBOUT5=func XVISUXMH2.DESOBJ("MAC")
Endif

End

#==========================================================================================
Subprog AS_NBMAC

If status=71 & nolign>0 & [M:XVMH]XNUMLIG<>0
  [M:XVMH]XNUMLIG=nolign
  Call AFF_TAB From XVISUXMH2
Endif

End

#==========================================================================================
Subprog AM_PARMACNUM(VALEUR)
Variable Char    VALEUR()

Call RAFFRAICHI(VALEUR) From XVISUXMH2

End

#==========================================================================================
Subprog IB_NBCON

If [M:XVMH]CONREV(nolign-1)<>""
  [V]GBOUT5=func XVISUXMH2.DESOBJ("XON")
Else
  Raz [V]GBOUT5
Endif

If [M:XVMH]COVCOD(nolign-1)<>""
  [V]GBOUT6=func XVISUXMH2.DESOBJ("COU")
Else
  Raz [V]GBOUT6
Endif

End
