#<AdxTL>@(#)6.0.0.0 $Revision:   1.11  $ Gestion du masque PARREPGAS1
#ACV#X00
#TIT#Paramètres répertoire GAS

GBIDC1=""
GBIDC2=""
Call OBJET("PRG",[V]GBIDC1,[V]GBIDC2) From GOBJET
End

$ACTION
Return

########################################
Subprog C_DIR(VALEUR)
Variable Char    VALEUR()

If right$(VALEUR,1+len(VALEUR)-1) = "/" Then
  VALEUR = left$(VALEUR,len(VALEUR)-1)
Endif
End

########################################
Subprog C_AFTDIR(VALEUR)
Variable Char    VALEUR()

If right$(VALEUR,1+len(VALEUR)-1) = "/" Then
  VALEUR = left$(VALEUR,len(VALEUR)-1)
Endif
End

########################################
Subprog C_CODPRG(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR, [M:PRG1]CODPRG) From OBJDIV
End

