#<AdxTL>@(#)8.0.0.0 $Revision$
#ACV#X11
#TIT#Action de recherche avancée sur le parc matériel

## Action SELMACADV
Local Char    PARMSK(250)(1..20) , SAVACT(20), VALEUR
Raz VALEUR
SAVACT = GACTION : GACTION = "SELMACADV"
PARMSK(1) = ""
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELMACADV","XTRTMACADV","XWDSELMACADV") From GSAISIE
[M:REQ1]SERNUM = PARMSK(1)
GACTION = SAVACT

End

#############################################
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "FIN"        : Gosub FIN
 When "SETBOUT"    : Gosub SETBOUT
 When "BOUTON"     : Gosub BOUTON
 When "AVANT_OK"   : Gosub AVANT_OK
 When "OK"         : Gosub OK
 When "SEL_TABLE"  : Gosub SEL_TABLE
 When "FIN_TABLE"  : Gosub FIN_TABLE
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "VERF_LISTE" : Gosub VERF_LISTE
Endcase
Return

######
$OUVRE
######
If TYPARG<>1 : FIN=1 : Endif : # Séléction avancée sur zone alpha uniquement
Return

######
$DEBUT
######
Local Char     OPTIONS(10), MEMO(10)
Local Char     ZONSEL(30),ZONSELSUP(30)
Local Char     ABREV : [L]ABREV="MAC"
Local Integer  OUVRE, RELIT, FILT, SAVMXL 
Local Integer  I, J, K, OK, NOL

NOL=nolign-1

If filinfo(filpath("TRT","WOMAC","adx"),0)<0
 GERR=1 : GMESSAGE=[L]ABREV-mess(11,123,1) : # Sélection non disponible
 FIN=1 : Return
Endif

# Ouverture masque et fichier
Onerrgo ERREUR From CONTROLE
If !clalev([ATB]) : Local File ATABLE  [ATB] : Endif
If !clalev([AOT]) : Local File AOBJTAB [AOT] : Endif
If !clalev([ATZ]) : Local File ATABZON [ATZ] : Endif
If !clalev([ATY]) : Local File ATYPE   [ATY] : Endif
If !clalev([ATX]) : Local File ATEXTE  [ATX] : Endif

If !clalev([AOB]) : Local File AOBJET  [AOB] : Endif
If !clalev([AWI]) : Local File AWINDOW [AWI] : Endif
If !clalev([AMZ]) : Local File AMSKZON [AMZ] : Endif
If !clalev([AMP]) : Local File AMSKPAR [AMP] : Endif

Gosub NOMFIC From WOMAC
Read [ATB]CODFIC = NOMFIC
I = instr(1,OPTIONS,"$")
If I
 OUVRE = 1
 OPTIONS = left$(OPTIONS,I-1)+right$(OPTIONS,I+1)
Endif
I = instr(1,OPTIONS,"#")
If I
 FILT = 0
Else
 FILT = 1
Endif
If OUVRE | evalue("clalev([F:"+ABFIC+"])")=0
 If NOMFIC=""
  GERR=1 : GMESSAGE=[L]ABREV-mess(11,123,1) : # Sélection non disponible
  GERREUR=1
 Else
  Local File =NOMFIC
 Endif
 RELIT = 0
Else
 RELIT = 1
Endif
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

Onerrgo CHUT From CONTROLE
Onerrgo
If GERREUR : GERREUR=0 : Endif

Gosub DEFAUT From WOMAC
Gosub SETCLE From WOMAC
Gosub OUVRE_LISTE From WOMAC
Gosub TIT From WOMAC

MEMO = [L]ABREV+"~SEL2"

Raz [M:SMV]
Gosub PARMSK
For I=0 To dim([M:SMV]FMT)-1
    [M:SMV]FMT(I) = "Kf:15X"
Next I
[M:SMV]NOMFIC = [L]NOMFIC
I = 0

For [F:AMZ]CODE Where find([F:AMZ]CODMSK,[F:AWI]NOMMSK,[F:AWI]MSKENT)<>0
&                   & [F:AMZ]SAIAFF=1

 OK = 1
 If OK
     Call TEXTE([F:AMZ]INTIT,[M:SMV]LIBZONE(I)) From OBJDIV
     If [M:SMV]LIBZONE(I)<>""
          [M:SMV]ZONSEL(I)    = [F:AMZ]CODZON
          [M:SMV]ZONE(I)    = "[F:MAC]"+[F:AMZ]CODZON           
          [M:SMV]OPE(I)     = 1
          [M:SMV]TRIZON(I)= [F:AMZ]CODZON 
          [M:SMV]TRILIB(I) = [M:SMV]LIBZONE(I) 
          [M:SMV]TYPX3(I)    = [F:AMZ]CODTYP

          Call TYP([M:SMV]TYPX3(I),[M:SMV]TYP(I))
          
          [M:SMV]TBL(I) = NOMFIC
          [M:SMV]NOLIB(I)=[F:AMZ]NOLIB

          If [M:SMV]TYPX3(I)  ="ADI"
              Read [F:AMP]CODPAR=1;[F:AMZ]CODMSK;[F:AMZ]CODZON;"ADI"
              [M:SMV]NOTAB(I)=[F:AMP]VALPAR 
          Else
              [M:SMV]NOTAB(I)="0"
          Endif  
           
          Call CHARGE([M:SMV]VALEUR(I),[M:SMV]TYPX3(I),[M:SMV]NOLIB(I),0,[M:SMV]VALINT(I)) From FMTVAR
          Call CHARGE([M:SMV]VALEURSUP(I),[M:SMV]TYPX3(I),[M:SMV]NOLIB(I),0,[M:SMV]VALINTSUP(I)) From FMTVAR
          
          # Affichage des zones par défaut
          [M:SMV]ENAFLG(I)=evalue("find([M:SMV]ZONE(I),SELZON)<>0")+1

          I+=1 # ZONE SUIVANTE
      Endif  
    Endif
Next 

[M:SMV]NBZONE = I
[M:SMV]ORDTRI = 1
[M:SMV]TRI=1
[M:SMV]NBTRI=I

[M:SMV]ZONTRI=[M:SMV]TRIZON(0)
If [M:SMV]NBTRI>1
 [M:SMV]LIBTRI = [M:SMV]TRILIB(0)
Endif

[M:SMV]NBREC  = GNBSEL
Affzo [SMV]
Return

######################################
$PARMSK
If [F:AWI]WIN<>"O"+[L]ABREV # Ouvre la fenêtre
    Read [AWI]AWI0="O"+[L]ABREV
Endif
If [F:AOB]ABREV<>[L]ABREV # Ouvre l'objet
    Read [AOB]=[L]ABREV
Endif
[M:SMV]NBTBL=0
For [F:AOT]ABREV Where [F:AOT]ABREV=[L]ABREV
    [M:SMV]TBTBL([M:SMV]NBTBL)=[F:AOT]TABFIC
    [M:SMV]NBTBL+=1
Next I
Return

####
$FIN
####
Return

########
$SETBOUT
########
If [L]MEMO="" : # pas de mémo
 For [L]MEMO="M","R","E"
  Case find(MEMO,CBOUT(1..NBTEX))
   When 1 : # ETABOU(GSPE1)=0
   When 2 : # ETABOU(GSPE2)=0
   When 3 : # ETABOU(GSPE3)=0
   When 4 : # ETABOU(GSPE4)=0
   When 5 : # ETABOU(GSPE5)=0
  Endcase
 Next : # [L]MEMO
 MEMO=""
Endif
If [M:SMV]NBTRI<2
 Case find("T",CBOUT(1..NBTEX))
  When 1 : # ETABOU(GSPE1)=0
  When 2 : # ETABOU(GSPE2)=0
  When 3 : # ETABOU(GSPE3)=0
  When 4 : # ETABOU(GSPE4)=0
  When 5 : # ETABOU(GSPE5)=0
 Endcase
Endif
Return

#######
$BOUTON
#######
Case BOUT
 When "T" : # Tri
  [M:SMV]LIBTRI = [M:SMV]TRILIB([M:SMV]TRI-1)
  [M:SMV]ZONTRI = [M:SMV]TRIZON([M:SMV]TRI-1)
  Affzo [SMV]LIBTRI

 When "R" : # Rappel mémo
  Gosub PARMSK
  If [M:SMV]NBTRI>0
   I=max(find([M:SMV]ZONTRI,[M:SMV]TRIZON(1..[M:SMV]NBTRI)),1)
   [M:SMV]TRI = I
   [M:SMV]LIBTRI = [M:SMV]TRILIB(I)
  Else
   [M:SIB]LIBTRI = ""
  Endif
  Affzo [SMV]
Endcase
Return

#########
$AVANT_OK
#########
#[M:SMV]ITMREF =VALEUR
#[M:SMV]SERNUM =PARAM(1)
Return

##########
$SEL_TABLE
##########

Local Integer I, J, K, ICRI
Local Char    ZONSEL(30),ZONSELSUP(30), SUBCRIT(80)

SUPP=[M:SMV]SERNUM

NBCOL=0
TIT(0)=[M:SMV]LIBTRI
START="ITMREF"

If [M:SMV]NBTRI>0 
    ORDRE=[M:SMV]ZONTRI
Endif

SENS   =[M:SMV]ORDTRI
SAVMXL = adxmxl
adxmxl = [M:SMV]NBREC
# Critères saisis dans la fenêtre
For I=0 To [M:SMV]NBZONE-1
 If NBCOL <20 & [M:SMV]ENAFLG(I)=2 # Actif  
     NBCOL+=1   
     TIT(NBCOL)=[M:SMV]LIBZONE(I)
     COL(NBCOL)=[M:SMV]ZONE(I)
 Endif
 If [M:SMV]OPE(I)>1
  Case [M:SMV]TYP(I)
   When 1,2,3,4,5,6 : # Numérique
    ZONSEL = [M:SMV]VALINT(I)
    ZONSELSUP=[M:SMV]VALINTSUP(I)
   When 7 : # Alpha
    ZONSEL = '"'+[M:SMV]VALINT(I)+'"'
    ZONSELSUP = '"'+[M:SMV]VALINTSUP(I)+'"'
   When 8 : # Date
    If gdat$([M:SMV]VALINT(I))=[0/0/0]
     ZONSEL = "[0/0/0]"
    Else
     ZONSEL = "["+format$(GFMD,gdat$([M:SMV]VALINT(I)))+"]"
    Endif

    If gdat$([M:SMV]VALINTSUP(I))=[0/0/0]
     ZONSELSUP = "[0/0/0]"
    Else
     ZONSELSUP = "["+format$(GFMD,gdat$([M:SMV]VALINTSUP(I)))+"]"
    Endif
  Endcase

  Case [M:SMV]OPE(I)
   When 2 : SUBCRIT = [M:SMV]ZONE(I)+"="+ZONSEL
   When 3 : SUBCRIT = [M:SMV]ZONE(I)+"<>"+ZONSEL
   When 4 : SUBCRIT = [M:SMV]ZONE(I)+">"+ZONSEL
   When 5 : SUBCRIT = [M:SMV]ZONE(I)+">="+ZONSEL
   When 6 : SUBCRIT = [M:SMV]ZONE(I)+"<"+ZONSEL
   When 7 : SUBCRIT = [M:SMV]ZONE(I)+"<="+ZONSEL
   When 8
    ZONSEL = [M:SMV]VALINT(I)
    J = instr(1,ZONSEL,"*")
    K = instr(1,ZONSEL,"?")
    If J or K
     If K or J<>len(ZONSEL)
      If !instr(1,[M:SMV]ZONE(I),"(")
       SUBCRIT = 'pat('+[M:SMV]ZONE(I)+'(0),"'+ZONSEL+'")=1'
      Else
       SUBCRIT = 'pat('+[M:SMV]ZONE(I)+',"'+ZONSEL+'")=1'
      Endif
     Else
      SUBCRIT = ""
     Endif
     If     J & K : J = min(J,K)
     Elsif !J & K : J = K
     Endif
     If J>1
      If SUBCRIT<>"" : SUBCRIT -= '&' : Endif
      SUBCRIT -= [M:SMV]ZONE(I)+'>="'+left$(ZONSEL,J-1)+'"'
      SUBCRIT -= '&'
      SUBCRIT -= [M:SMV]ZONE(I)+'<"'+left$(ZONSEL,J-2)+chr$(ascii(mid$(ZONSEL,J-1,1))+1)+'"'
     Endif
    Else
     SUBCRIT = [M:SMV]ZONE(I)+'="'+ZONSEL+'"'
    Endif

    When 9 : # Borne
        If vireblc(ZONSEL,4) <>"" & ZONSEL<>'""'
            SUBCRIT = [M:SMV]ZONE(I)+">="+ZONSEL
            Call ADD_SCRIT(SUBCRIT,ICRI,CRITERE)
        Endif

        If ZONSELSUP <>"" & ZONSELSUP<>'""'
            SUBCRIT = [M:SMV]ZONE(I)+"<="+ZONSELSUP
            Call ADD_SCRIT(SUBCRIT,ICRI,CRITERE)
        Endif
        
  Endcase
  If [M:SMV]OPE(I)<>9   
      Call ADD_SCRIT(SUBCRIT,ICRI,CRITERE)
  Endif  
    
 Endif

Next I

Return

##################################
Subprog ADD_SCRIT(SUBCRIT,ICRI,CRITERE)
Variable Char    CRITERE()()
Variable Integer ICRI
Value    Char    SUBCRIT()
If len(CRITERE(ICRI))+len(SUBCRIT)+3>250
 ICRI += 1
Endif
If CRITERE(ICRI)<>"" : CRITERE(ICRI) -= '&' : Endif
CRITERE(ICRI) -= SUBCRIT
End

###################################
Subprog TYPX3(TYP1,TYP2)
Value    Integer TYP1
Variable Char    TYP2()
Case TYP1
 When 1 : TYP2 = "M"
 When 2 : TYP2 = "C"
 When 3 : TYP2 = "L"
 When 4 : TYP2 = "DCB"
 When 7 : TYP2 = "A"
 When 8 : TYP2 = "D"
Endcase
End

###################################
Subprog TYP(TYP1,TYP2)
Value    Char TYP1()
Variable Decimal    TYP2

Read [F:ATY]CODTYP=TYP1
If !fstat
    TYP2=[F:ATY]TYPTYP
Endif
End

##########
$FIN_TABLE
##########

adxmxl = SAVMXL
[M:SMV]SERNUM=[F:MAC]MACSERNUM
[M:SMV]MACNUM=[F:MAC]MACNUM
Return

###
$OK
###
If mkstat=2 : FIN=0 : Return : Endif
VALEUR=VALBOUT
PARAM(1)=[M:SMV]SERNUM
Return

##################################
## Etiquettes de l'écran SELOBJ ##
##################################
$SEL_LISTE
Case COUZON
 When "TBL" : # Table
  Read [ATB]CODFIC = [M]NOMFIC
  NBTEX += 1
  TEX(NBTEX) = [F:ATB]CODFIC
  Call TEXTE([F:ATB]INTITFIC,TEXTE(NBTEX)) From OBJDIV
  TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
  For I=1 To [M]NBTBL
   Read [ATB]CODFIC = [M]TBTBL(I)
   NBTEX += 1
   TEX(NBTEX) = [F:ATB]CODFIC
   Call TEXTE([F:ATB]INTITFIC,TEXTE(NBTEX)) From OBJDIV
   TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
  Next I
 
 When "TRI" : # Bouton tri
  VALEUR = num$([M]TRI)
  TIT=mess(2,109,1) : # Critères
  For I=1 To [M]NBTRI
   NBTEX += 1
   TEX(NBTEX) = num$(NBTEX)
   TEXTE(NBTEX) = [M]TRILIB(I-1)
  Next I

Endcase
Return
#--------------------------------
$VERF_LISTE
Case COUZON
 When "TRI" : # Bouton tri
  [M:SMV]TRI = val(VALEUR)
Endcase
Return

##########################################
Subprog AV_VALEUR(VALEUR)
Variable Char    VALEUR()
If [M]OPE(nolign-1)=1 : mkstat = 1 : Endif
End

##########################################
Subprog C_VALEUR(VALEUR)
Variable Char    VALEUR()
If [M:SMV]TYP(nolign-1)=7 & instr(1,VALEUR,'"') : # Alpha
 GMESSAGE = '" :'-mess(94,123,1) : mkstat = 2 
 # Caractère interdit
Endif
End

##########################################
Subprog C_ZONSEL(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL = nolign-1
Local Integer K , DIME
Local Char    ZONE(15)
If !clalev([ATB]) : Local File ATABLE  [ATB] : Endif
If !clalev([ATZ]) : Local File ATABZON [ATZ] : Endif
If !clalev([ATY]) : Local File ATYPE   [ATY] : Endif
If !clalev([ACV]) : Local File ACTIV   [ACV] : Endif
VALEUR = toupper(VALEUR)
K = instr(1,VALEUR,"(")
If K
 ZONE = left$(VALEUR,K-1)
 DIME = val(right$(VALEUR,K+1))
Else
 ZONE = VALEUR
 DIME = 0
Endif
Read [ATZ]CODZONE = [M]TBL(NOL);ZONE
If fstat
 GMESSAGE = mess(9,124,1) : mkstat = 2 : End
# Champ inexistant
Endif
If [F:ATZ]CODACT<>""
 Read [ACV]CODACT = [F:ATZ]CODACT
 DIMMAX = [F:ACV]DIMFIL
Else
 DIMMAX = [F:ATZ]DIME
Endif
If (DIME<>0 | DIMMAX<>0) & DIME>DIMMAX-1
 GMESSAGE = mess(46,105,1) : # Indice incorrect
 mkstat = 2 : End
Endif
VALEUR = ZONE
If DIME>0
 VALEUR += "("+num$(DIME)+")"
Endif
Read [ATB]CODFIC  = [M]TBL(NOL)
Local Char    FORMA(30) , CAR(1) , OPTION(10)
Local Integer NOLIB , LONG
Read [ATY]CODTYP = [F:ATZ]CODTYP
NOLIB = 0
If [F:ATY]CODTYP="ATX" & ZONE=[F:ATB]INTIT
 [M]FMT(NOL)   = "Kf:15X>15X"
 [M]TYP(NOL)   = 7
 [M]NOLIB(NOL) = 0
 [M]ZONE(NOL)  = "[F:ATX]TEXTE"
Else
 Case [F:ATY]TYPTYP
  When 1
   If [F:ATY]NOLIB<>0
    NOLIB = [F:ATY]NOLIB
   Else
    NOLIB = [F:ATZ]NOLIB
   Endif
   FORMA = "Nf:2#"
  When 7
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   If LONG>15 : LONG = 15 : Endif
   OPTION = [F:ATY]OPTION+[F:ATZ]OPTION
   If instr(1,OPTION,"C")
    CAR = "c"
   Elsif instr(1,OPTION,"A")
    CAR = "B"
   Else
    CAR = "X"
   Endif
   FORMA = "Kf:"+num$(LONG)+CAR
  When 8
   FORMA = "Df:"+GFMDAT
  When 2,3
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   FORMA = "Nf:"+num$(LONG)+"#"
  When 4
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   FORMA = "Nf:"+num$(LONG)+"#"
 Endcase
 [M]FMT(NOL)   = FORMA
 [M]TYP(NOL)   = [F:ATY]TYPTYP
 Call TYPX3([M:SMV]TYP(NOL),[M]TYPX3(NOL))
 [M]NOLIB(NOL) = NOLIB
 [M]ZONE(NOL)  = "[F:"+[F:ATB]ABRFIC+"]"+VALEUR
Endif
Call TEXTE([F:ATZ]NOCOURT,[M]LIBZONE(NOL)) From OBJDIV
End

##########################################
Subprog AS_TBL(VALEUR)
Variable Char    VALEUR()
If [M]NBTBL=0
 VALEUR = [M]NOMFIC : mkstat = 2 : End
Endif
End

##########################################
Subprog C_TBL(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
     Call CONTROLE("ATB","",VALEUR,"",mkstat) From CONTOBJ
     If mkstat : End : Endif
     If !find(VALEUR,[M]NOMFIC,[M]TBTBL(1..[M]NBTBL))
         GMESSAGE = mess(5,124,1) : mkstat = 2 : End : # Table non accessible
     Endif
Endif
End

########################################
Subprog AV_VALEURSUP(VALEUR)
Variable Char    VALEUR()
    If [M]OPE(nolign-1)<>9: mkstat = 1 : Endif
End

########################################
Subprog C_VALEURSUP(VALEUR)
Variable Char    VALEUR()
    Call C_VALEUR(VALEUR)
End

