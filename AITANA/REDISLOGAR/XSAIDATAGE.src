#<AdxTL>@(#)1.0.0.0 $Revision:   1.20  $ Gestion du masque SCHSAIDAT
#ACV#X13
#TIT#Gestion de l'action SAIDATAGE

#LBO 02/2003

Chain SPEAGE

Local Char PARAM(30)(1..16),VALEUR(10) 

PARAM(1)="LBO5"
PARAM(2)="CIMENT"
PARAM(3)="DECO"
PARAM(4)="" 
Call TRAITE_CHAR(VALEUR,PARAM,"","XSAIDATAGE2","SCHSAIDAT",4) From GTRAITE    :# Appel avec ouverture de la fenetre
End


#-----------------------------------------------------------------------
# Ecran SCHSAIDAT
#-----------------------------------------------------------------------

#---------------------------------------
Subprog AV_ZGRIZ(VALEUR)
Variable Char    VALEUR()
Case [V]GXNBR
 When 1 : Actzo [M:DIA]VP1
          Effzo [M:DIA]VP2
          Grizo [M:DIA]VP2
          Effzo [M:DIA]VP3
          Grizo [M:DIA]VP3
 When 2 : Actzo [M:DIA]VP1
          Actzo [M:DIA]VP2
          Effzo [M:DIA]VP3
          Grizo [M:DIA]VP3
 When 3 : Actzo [M:DIA]VP1
          Actzo [M:DIA]VP2
          Actzo [M:DIA]VP3
Endcase
End

#---------------------------------------
Subprog AV_VD1(VALEUR)
Variable Char    VALEUR()
Call AVVD(VALEUR,1)
End

#---------------------------------------
Subprog AV_VD2(VALEUR)
Variable Char    VALEUR()
Call AVVD(VALEUR,2)
End

#---------------------------------------
Subprog AV_VD3(VALEUR)
Variable Char    VALEUR()
Call AVVD(VALEUR,3)
End

#---------------------------------------
Subprog AVVD(VALEUR,ZNUM)
Value Integer ZNUM
Variable Char    VALEUR()
If [L]ZNUM>[V]GXNBR
  VALEUR=""
Else
  Case [L]ZNUM
    When 1 : Read [F:SHL]SHL1(2)=[V]GXPLAN;[M:DIA]VP1
    When 2 : Read [F:SHL]SHL1(3)=[V]GXPLAN;[M:DIA]VP1;[M:DIA]VP2
    When 3 : Read [F:SHL]SHL1=[V]GXPLAN;[M:DIA]VP1;[M:DIA]VP2;[M:DIA]VP3
  Endcase
  If !fstat
    VALEUR=evalue("[F:SHL]VD"+num$([L]ZNUM))
  Else
    VALEUR=""
  Endif
Endif
End

