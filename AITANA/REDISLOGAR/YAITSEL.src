#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER = "ADMIN" : Infbox ACTION: Endif
Case ACTION
  When "SEL_TABLE" : Gosub SEL_TABLE
  When "VERF_TABLE": Gosub VERF_TABLE
  When "FIN_TABLE" : Gosub FIN_TABLE
  When Default
Endcase
Return


######################################################################################
$SEL_TABLE
  Case TABLE
    When "YSELITMBPC"  : Gosub S_YSELITMBPC       # selección paletizado lote
  Endcase
Return

######################################################################################
$VERF_TABLE
  Case TABLE
    When "YSELITMBPC"  : Gosub V_YSELITMBPC
  Endcase
Return

######################################################################################
$FIN_TABLE
  Case TABLE
    When "YSELITMBPC"  : Gosub F_YSELITMBPC
  Endcase
Return


######################################################################################
$S_YSELITMBPC
Local Char CLI        : CLI=PARAM(1)

If clalev([F:ITU])=0 : Local File ITMBPC    : Endif
If clalev([F:ZITM])=0 : Local File ITMMASTER [F:ZITM]: Endif
If clalev([F:ATZ])=0 : Local File ATABZON   : Endif
Local Char CODFIC    : CODFIC = "ITMBPC"

#Link [ITU] With [ZITM]ITM0=[ITU]ITMREF As [KITU]
#Default File [KITU]

If !clalev([ZVITBPC]) : Local File YVITMBPC [ZVITBPC] : Endif
Default File [ZVITBPC]

ORDRE   = 'ITMREFBPC'
START   = 'ITMREF'
SENS = 1
DEFPAG = 5
SIZCOL = 100
SIZLIG = 150

CRITERE = '[ZVITBPC]BPCNUM="'+CLI+'"'

TIT(0) = mess(12,123,1)

NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "ITMREFBPC" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ITMDESBPC" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "BPCNUM"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ITMREF"    : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ITMDES1"   : TIT(NBCOL)="Descripción del Artículo"

#DEFPAG=1

Return

######################################################################################
$ V_YSELITMBPC
Return

######################################################################################
$F_YSELITMBPC
Return

