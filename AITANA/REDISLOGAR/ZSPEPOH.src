#<AdxTL>@(#)0.0.0.0 $Revision$ YA007- Specific file for Purch
####################################################################################
# Program Name: ZSPEPOH
# Description : YA007 - Specific Processing - Purchase Orders
# Author      : GT NDEV
# Date        : Jul 4th, 2018
####################################################################################
## NOTES ##
# Comment code between tag -
# "Update Custom Flag YRCPDAT for testing in internal system"
####################################################################################

$ACTION
 Case ACTION
  When "APRES_MOD" : Gosub APRES_MOD
  When "VERIF_MOD" : Gosub VERIF_MOD
  When "SETBOUT"   : Gosub SETBOUT
  When "ABANDON"   : Gosub ABANDON
  When "RAZDUP"   : Gosub RAZDUP
  When Default
 Endcase
Return
#####################################################################################################

$ABANDON
 If dim(ZSPLFLG) > 0 : Kill ZSPLFLG : Endif
Return
#####################################################################################################

$APRES_MOD_SPL
Local Integer ZMLKOPENEDHERE : ZMLKOPENEDHERE = 0
Local Integer ZZSOQOPENEDHERE : ZZSOQOPENEDHERE = 0
Local Integer ZORDOPENEDHERE : ZORDOPENEDHERE = 0
Local Integer ZMKOPENEDHERE : ZMKOPENEDHERE = 0
If !clalev([F:ZMK])   : Local File ZMTOLINK [F:ZMK] : ZMKOPENEDHERE = 1 : Endif
If !clalev([F:MLK]) : Local File MTOLINK [F:MLK] : ZMLKOPENEDHERE = 1 : Endif
If !clalev([F:ZORD]) : Local File ORDERS [F:ZORD] : ZORDOPENEDHERE = 1 :Endif
If !clalev([F:ZSOQ]) : Local File SORDERQ [F:ZSOQ] : ZZSOQOPENEDHERE = 1 : Endif

Local Char ZORDR
Local Char ZORDCPY
Local Char ZORDFCY
Local Integer ZORDLINE
Local Decimal ZORDQTY
Local Integer ZN : ZN = 0
Local Integer ZCURLINE : ZCURLINE = 0
Local Integer ZPRELINE : ZPRELINE = 0
Local Integer ZCOUNT : ZCOUNT = 0
Local Integer ZQTYLIST(200)
Local Integer ZLINLIST(200)
Local Char ZSOHNUM(250) : ZSOHNUM = ""
Local Integer ZSOPLIN : ZSOPLIN = 0
Local Char ZPATH(250) : ZPATH = ""
Local Integer ZFLG : ZFLG = 0
Local Integer ZSTA : ZSTA = 0
Local Char REQUETE(250)(0..)
Local Integer ZSAMELNFLG : ZSAMELNFLG = 0
If dim(ZARLNLIST)> 0 : Kill ZARLNLIST : Endif
If dim(ZARLNLISTCNT)> 0 : Kill ZARLNLISTCNT : Endif
Global Char ZARLNLIST(250)(0..) : Raz ZARLNLIST           # Array counter to store updated SO lines
Global Integer ZARLNLISTCNT : ZARLNLISTCNT = 0            # Array counter to store updated SO lines
Local Integer ZLINCLOSED : ZLINCLOSED = 0                 # Flag updated once closed line is added to template
Local Integer ZPREVSOLIN : ZPREVSOLIN = 0
Local Char ZOTHSODET(250)(0..) : Raz ZOTHSODET
Local Char ZOTHSODET1(250)(0..) : Raz ZOTHSODET1
Local Integer ZOTHSODETCNT : ZOTHSODETCNT = 0
Local Integer ZOTHSODETCNT1 : ZOTHSODETCNT1 = 0
Local Char ZLASTSOHNUM(250) : ZLASTSOHNUM = ""
If dim(ZGWEBSERV) <> 1 : Local Integer ZGWEBSERV : ZGWEBSERV = GWEBSERV : Endif

#---------------------------------------- Logic to create template ----------------------------------#
Local Decimal ZCURQTY                         ## Current Quiantity
Local Decimal ZTOTQTY : ZTOTQTY = 0           ## Total Quantity
Local Decimal ZLNKQTY : ZLNKQTY = 0           ## Linked Quantity
Local Decimal ZACSOLQTY : ZACSOLQTY = 0       ## Actual SO line Quantity
Local Decimal ZQTYCOUNT : ZQTYCOUNT = 0       ## Total line quantity for which template has been created
Local Decimal ZDLSOLQTY : ZDLSOLQTY = 0       ## Delivered Quantity
Local Integer ZFLG : ZFLG = 0
Local Integer ZCREHEADER: ZCREHEADER = 0
Local Decimal ZOTHQTY: ZOTHQTY = 0
Local Char ZSNUM1 : ZSNUM1 = ""
Local Char ZSLIN1 : ZSLIN1 = ""

For I = 0 To [M:POH2]NBLIG - 1
 If [M:POH2]ZOGLIN(I) <> 0 and [M:POH2]ZOGLIN(I) <> ZFLG
  If ZPREVSOLIN = 0 : ZPREVSOLIN = [M:POH2]ZSOPLIN(I) : Endif
  If ZPREVSOLIN <> [M:POH2]ZSOPLIN(I) : ZLINCLOSED = 0 : Endif
  ZLNKQTY = [M:POH2]ZLIKQTY(I)
  ZCURQTY = [M:POH2]QTYUOM(I)
  ZACSOLQTY = [M:POH2]ZACTSOLQTY(I)
  ZDLSOLQTY = [M:POH2]ZSOLDLVQTY(I)
  If [M:POH2]ZOGLIN(I) = [M:POH2]POPLIN(I) Then ZSAMELNFLG = 1 Else ZSAMELNFLG = 0 Endif

  ZSONUM = [M:POH2]ZSOHNUM(I) + "|" + num$([M:POH2]ZSOPLIN(I))

  If find(ZSONUM,ZOTHSODET) = 0
   ZOTHSODET(ZOTHSODETCNT) = ZSONUM
   ZOTHSODETCNT = ZOTHSODETCNT + 1
  Endif

  If  [M:POH2]ZSOHNUM(I) <> ZLASTSOHNUM
    ZCREHEADER = 1
  Else
    ZCREHEADER = 0
  Endif
  ZLASTSOHNUM = [M:POH2]ZSOHNUM(I)

  If ZCURQTY + ZTOTQTY >= ZLNKQTY
   ZORDR = [M:POH2]ZSOHNUM(I)
   ZORDCPY = [F:POH]CPY
   ZORDFCY = [M:POH2]PRHFCY(I)
   ZORDLINE = [M:POH2]ZSOPLIN(I)
   ZORDQTY  = ZLNKQTY
   Gosub EXEC From ZDEALLOC
   Call ZCREATETEMPLATE([M:POH2]ZSOHNUM(I),[M:POH2]ZSOPLIN(I),(ZLNKQTY- ZTOTQTY),
&   [M:POH0]POHNUM,[M:POH2]POPLIN(I),ZPATH,ZLINCLOSED,ZQTYCOUNT,ZCREHEADER) From ZUPDTEMPLATE
   If (ZACSOLQTY-ZDLSOLQTY) > ZQTYCOUNT
    Call ZCREATETEMPLATE([M:POH2]ZSOHNUM(I),[M:POH2]ZSOPLIN(I),(ZACSOLQTY-ZDLSOLQTY - ZQTYCOUNT),
&    "",0,ZPATH,ZLINCLOSED,ZQTYCOUNT,ZCREHEADER) From ZUPDTEMPLATE
   Endif
   If (ZACSOLQTY-ZDLSOLQTY) = ZQTYCOUNT
    ZFLG = [M:POH2]ZOGLIN(I) : ZQTYCOUNT = 0 : ZTOTQTY = 0
   Endif
  Else
   ZORDR = [M:POH2]ZSOHNUM(I)
   ZORDCPY = [F:POH]CPY
   ZORDFCY = [M:POH2]PRHFCY(I)
   ZORDLINE = [M:POH2]ZSOPLIN(I)
   ZORDQTY  = ZLNKQTY
   Gosub EXEC From ZDEALLOC
   Call ZCREATETEMPLATE([M:POH2]ZSOHNUM(I),[M:POH2]ZSOPLIN(I),ZCURQTY,[M:POH0]POHNUM,
&   [M:POH2]POPLIN(I),ZPATH,ZLINCLOSED,ZQTYCOUNT,ZCREHEADER) From ZUPDTEMPLATE
   ZTOTQTY = ZTOTQTY + ZCURQTY
  Endif
 Endif
Next
#---------------------------------------- Logic to create template ----------------------------------#

#-------------------------------- Logic to check for pending lines ----------------------------------#
For H = 0 To dim(ZOTHSODET)-1
 If ZOTHSODET(H) <> ""

  ZSLIN1  = num$(right$(ZOTHSODET(H),instr(1,ZOTHSODET(H),"|")+1))
  ZSNUM1= num$(left$(ZOTHSODET(H),instr(1,ZOTHSODET(H),"|")-1))
  If ZSNUM1 <> ""
   For [F:ZMK] Where DEMNUM = ZSNUM1 and DEMLIN = val(ZSLIN1) and RESSNUM <> [M:POH0]POHNUM
    ZOTHQTY+=[F:ZMK]LIKQTY
   Next
   ZLINCLOSED = 0
   ZQTYCOUNT = 0
   ZCREHEADER = 1

   If ZOTHQTY > 0
    Call ZCREATETEMPLATE(ZSNUM1,val(ZSLIN1),ZOTHQTY,"",0,ZPATH,ZLINCLOSED,ZQTYCOUNT,ZCREHEADER) From ZUPDTEMPLATE
    Local Char ZPNUM1
    Local Integer ZPLIN1
    For [F:MLK] Where DEMNUM = ZSNUM1 and DEMLIN = val(ZSLIN1) and RESSNUM <> [M:POH0]POHNUM
     For [F:ZORD] Where [F:ZORD]VCRNUM = [F:MLK]DEMNUM and [F:ZORD]VCRLIN = [F:MLK]DEMLIN
      If [F:ZORD]MTOQTY <> 0 : [F:ZORD]MTOQTY = [F:ZORD]MTOQTY - [F:MLK]LIKQTY : Endif
       Rewrite [F:ZORD]
      Next
     For [F:ZORD] Where [F:ZORD]VCRNUM = [M:POH0]POHNUM and [F:ZORD]VCRLIN = [F:MLK]RESSLIN
      If [F:ZORD]MTOQTY <> 0 : [F:ZORD]MTOQTY = [F:ZORD]MTOQTY - [F:MLK]LIKQTY : Endif
       Rewrite [F:ZORD]
     Next
    Next
    Delete [F:MLK] Where DEMNUM = ZSNUM1 and DEMLIN = val(ZSLIN1) and RESSNUM <> [M:POH0]POHNUM
   Endif
   ZOTHQTY = 0
  Endif
 Else
  Break
 Endif
Next
#-------------------------------- Logic to check for pending lines ----------------------------------#

#------------------------------------Skip logic for PO Confirmation----------------------------------#

If dim(ZIMPFLG)>0
 If ZIMPFLG = 1
  If dim(ZGPATH)>0 : Kill ZGPATH : Endif
  Global Char ZGPATH(250) : ZGPATH = ZPATH
  If ZMKOPENEDHERE = 1 : Close File [F:ZMK] : Endif
  If ZMLKOPENEDHERE = 1 : Close File [F:MLK] : Endif
  If ZZSOQOPENEDHERE = 1 : Close File [F:ZSOQ] : Endif
  If ZORDOPENEDHERE = 1 : Close File [F:ZORD] : Endif
  Default Mask [M:POH0]

  For V = 0 To [M:POH2]NBLIG-1
   [M:POH2]ZOGLIN(V) = 0
   [M:POH2]ZSOHNUM(V) = ""
   [M:POH2]ZSOPLIN(V) = 0
   [M:POH2]ZLIKQTY(V) = 0
   [M:POH2]ZACTSOLQTY(V) = 0
   [M:POH2]ZSOLDLVQTY(V) = 0
   Affzo [M:POH2]ZOGLIN(V)
   Affzo [M:POH2]ZSOHNUM(V)
   Affzo [M:POH2]ZSOPLIN(V)
   Affzo [M:POH2]ZLIKQTY(V)
   Affzo [M:POH2]ZACTSOLQTY(V)
   Affzo [M:POH2]ZSOLDLVQTY(V)
  Next

  If dim(ZARLNLIST)> 0 : Kill ZARLNLIST : Endif
  If dim(ZARLNLISTCNT)> 0 : Kill ZARLNLISTCNT : Endif
  If dim(ZSYMBOLE2) = 1 :  Unlock = ZSYMBOLE2 : Endif
  Return
 Endif
Endif
#------------------------------------Skip logic for PO Confirmation----------------------------------#

#------------------------------------------Call the import template----------------------------------#
If ZPATH <> ""
 GWEBSERV = 1
 Call IMPORTSIL("ZSOH1",ZPATH) From GIMPOBJ
 If dim(ZSTAT) < 0 : Local Integer ZSTAT : Endif :  ZSTAT = 0
 Call SYSTEME(adxmac(1),'ae_rm ' + ZPATH, "",ZSTAT) From ORDSYS
 GWEBSERV = ZGWEBSERV
 ZPATH = ""
 Local Integer STAT
 TMPOUTFILE1= ZPATH
 STAT = Delfile(TMPOUTFILE1)
Endif
#------------------------------------------Call the import template----------------------------------#

#------------------------------------------Deallocate SO line----------------------------------------#
For [F:ZSOQ] Where [F:ZSOQ]ZPOHNUM = [M:POH0]POHNUM
  ZORDR = [F:ZSOQ]SOHNUM
  ZORDCPY = [F:ZSOQ]CPY
  ZORDFCY = [F:ZSOQ]STOFCY
  ZORDLINE = [F:ZSOQ]SOPLIN
  ZORDQTY  = [F:ZSOQ]QTY
  Gosub EXEC From ZDEALLOC
Next
#------------------------------------------Deallocate SO line----------------------------------------#

#------------------------------------------Create MTOLINK record-------------------------------------#
For [F:MLK] Where RESSNUM = [M:POH0]POHNUM
 For [F:ZORD] Where [F:ZORD]VCRNUM = [F:MLK]DEMNUM and [F:ZORD]VCRLIN = [F:MLK]DEMLIN
  If [F:ZORD]MTOQTY <> 0 : [F:ZORD]MTOQTY = [F:ZORD]MTOQTY - [F:MLK]LIKQTY : Endif
  Rewrite [F:ZORD]
 Next
 For [F:ZORD] Where [F:ZORD]VCRNUM = [M:POH0]POHNUM and [F:ZORD]VCRLIN = [F:MLK]RESSLIN
  If [F:ZORD]MTOQTY <> 0 : [F:ZORD]MTOQTY = [F:ZORD]MTOQTY - [F:MLK]LIKQTY : Endif
  Rewrite [F:ZORD]
 Next
Next

Delete [F:MLK] Where RESSNUM = [M:POH0]POHNUM

Filter [F:ZSOQ]
For [F:ZSOQ] Where [F:ZSOQ]ZPOHNUM = [M:POH0]POHNUM
 Read [F:MLK]MLK0 = [F:ZSOQ]STOFCY;[F:ZSOQ]ITMREF;2;[F:ZSOQ]SOHNUM;[F:ZSOQ]SOPLIN;[F:ZSOQ]SOPLIN
 If fstat
  [F:MLK]STOFCY = [F:ZSOQ]STOFCY
  [F:MLK]DEMLIN = [F:ZSOQ]SOPLIN
  [F:MLK]DEMNUM = [F:ZSOQ]SOHNUM
  [F:MLK]DEMSEQ = [F:ZSOQ]SOPLIN
  [F:MLK]DEMTYP = 2
  [F:MLK]DWIPSTA = 1
  [F:MLK]DWIPTYP = 1
  [F:MLK]EXPNUM = 33
  [F:MLK]FMIFLG = 1
  [F:MLK]FRCFLG = 1
  [F:MLK]ITMREF = [F:ZSOQ]ITMREF
  [F:MLK]LIKQTY = [F:ZSOQ]QTYSTU
  [F:MLK]RESSLIN = [F:ZSOQ]ZPOHLIN
  [F:MLK]RESSNUM = [F:ZSOQ]ZPOHNUM

  For [F:POQ] Where [F:POQ]POHNUM = [M:POH0]POHNUM & [F:POQ]POPLIN = [F:ZSOQ]ZPOHLIN
   [F:MLK]RESSSEQ = [F:POQ]POQSEQ
   Break
  Next
  [F:MLK]RESSTYP = 14
  [F:MLK]RWIPSTA = 1
  [F:MLK]RWIPTYP = 2
  Write [F:MLK]
 Endif
Next
#------------------------------------------Create MTOLINK record-------------------------------------#

#----------------------------------------Update Orders data------------------------------------------#
For [F:ZSOQ] Where [F:ZSOQ]ZPOHNUM = [M:POH0]POHNUM
 For [F:ZORD] Where [F:ZORD]VCRNUM = [F:ZSOQ]SOHNUM and [F:ZORD]VCRLIN = [F:ZSOQ]SOPLIN
  [F:ZORD]MTOQTY = [F:ZORD]EXTQTY
  Rewrite [F:ZORD]
 Next
 For [F:ZORD] Where [F:ZORD]VCRNUM = [F:ZSOQ]ZPOHNUM and [F:ZORD]VCRLIN = [F:ZSOQ]ZPOHLIN
  [F:ZORD]MTOQTY = [F:ZORD]EXTQTY
  Rewrite [F:ZORD]
 Next
Next
#----------------------------------------Update Orders data------------------------------------------#

#---------------------------Clear memory and reset screen custom fields------------------------------#
Default Mask [M:POH0]
For V = 0 To [M:POH2]NBLIG-1
 [M:POH2]ZOGLIN(V) = 0
 [M:POH2]ZSOHNUM(V) = ""
 [M:POH2]ZSOPLIN(V) = 0
 [M:POH2]ZLIKQTY(V) = 0
 [M:POH2]ZACTSOLQTY(V) = 0
 [M:POH2]ZSOLDLVQTY(V) = 0
 Affzo [M:POH2]ZOGLIN(V)
 Affzo [M:POH2]ZSOHNUM(V)
 Affzo [M:POH2]ZSOPLIN(V)
 Affzo [M:POH2]ZLIKQTY(V)
 Affzo [M:POH2]ZACTSOLQTY(V)
 Affzo [M:POH2]ZSOLDLVQTY(V)
Next

If ZMKOPENEDHERE = 1 : Close File [F:ZMK] : Endif
If ZMLKOPENEDHERE = 1 : Close File [F:MLK] : Endif
If ZZSOQOPENEDHERE = 1 : Close File [F:ZSOQ] : Endif
If ZORDOPENEDHERE = 1 : Close File [F:ZORD] : Endif
If dim(ZARLNLIST)> 0 : Kill ZARLNLIST : Endif
If dim(ZARLNLISTCNT)> 0 : Kill ZARLNLISTCNT : Endif
If dim(ZSYMBOLE2) = 1 :  Unlock = ZSYMBOLE2 : Endif
#---------------------------Clear memory and reset screen custom fields------------------------------#
Return
#####################################################################################################

$APRES_MOD
Local Integer ZGWEBSERV : ZGWEBSERV = GWEBSERV
#---------------------------------Call logic to split linked SO line --------------------------------#
If dim(ZSPLFLG) > 0
 If ZSPLFLG = 1 : Gosub APRES_MOD_SPL : Kill ZSPLFLG : Endif
Endif
#---------------------------------Call logic to split linked SO line --------------------------------#

#------------------Update Custom Flag YRCPDAT for testing in internal system-------------------------#
# <GON - Mayo/19 - Comento estas líneas, parecen para testeo

##For K= 0 To [M:POH2]NBLIG-1
##For [F:POQ] Where [F:POQ]POHNUM = [M:POH0]POHNUM and [F:POQ]POPLIN = [M:POH2]POPLIN(K)
## [F:POQ]YRCPDAT = [M:POH2]YRCPDAT(K)
## Rewrite [F:POQ]
##Next
##Next

# </GON>
#------------------Update Custom Flag YRCPDAT for testing in internal system-------------------------#

#---------------Changes to update Delivery shipdate on change of Expected Delivery Date -------------#
Local Char ZREQ(250)(0..3)
Local Char HEADER(200)
Local Char DETAIL(254)
Local Char PATH1(150)
Local Char ZPATH(250)
Local Char URL

Call SET_FICNAM(PATH1,ZPATH,URL) From ORDSYS
Openo ZPATH Using [FACS]

ZREQ(0) = " select T1.DEMNUM_0,T1.DEMSEQ_0,T3.SHIDAT_0,T2.EXTRCPDAT_0,T1.ITMREF_0,T1.RESSLIN_0 from "+nomap+".MTOLINK T1  "
ZREQ(1) = " Left join "+nomap+".PORDERQ T2 on T1.RESSNUM_0 = T2.POHNUM_0 and T1.RESSLIN_0 = T2.POPLIN_0 "
ZREQ(2) = " Left join "+nomap+".SORDERQ T3 on T1.DEMNUM_0 = T3.SOHNUM_0 and T1.DEMSEQ_0 = T3.SOPLIN_0 "
ZREQ(3) = " where RESSNUM_0 = '"+[M:POH0]POHNUM+"' "

For (Char ZDEMNUM,Integer DEMSEQ,Date ZSHIDAT,Date ZEXTRCPDAT,Char ZITMREF,Integer ZRESSLIN)
& From "5" Sql ZREQ(0..3) As [YST]
 HEADER = "E;"+[YST]ZDEMNUM
 HEADER += chr$(13)
 Wrseq HEADER  Using [FACS]
 For I= 0 To [M:POH2]NBLIG-1
  If [M:POH2]UPDFLG(I) =1 and [M:POH2]POPLIN(I) = [YST]ZRESSLIN
   If [YST]ZEXTRCPDAT > [YST]ZSHIDAT
    DETAIL  =  "L"
    DETAIL += ";" + [YST]ZITMREF+";"+[YST]ZEXTRCPDAT+";"+num$([YST]DEMSEQ)
    DETAIL + =chr$(13)
    Wrseq DETAIL Using [FACS]
   Endif
  Endif
 Next
Next

Openo Using [FACS]
GWEBSERV = 1
#-----Execute after PO conf transaction
If dim(ZEXPDATIMPPATH)> 0
 ZEXPDATIMPPATH = ZPATH
Endif
#-----Execute after PO conf transaction
If !GIMPORT
Call IMPORTSIL("ZSOH2",ZPATH) From GIMPOBJ
If dim(ZSTAT) < 0 : Local Integer ZSTAT : Endif :  ZSTAT = 0
Call SYSTEME(adxmac(1),'ae_rm ' + ZPATH, "",ZSTAT) From ORDSYS
Endif
GWEBSERV = ZGWEBSERV
#Local Integer STAT
#TMPOUTFILE1= ZPATH
#STAT = Delfile(TMPOUTFILE1)
#---------------Changes to update Delivery shipdate on change of Expected Delivery Date -------------#
#GMESSAGE  = ZEXPDATIMPPATH
Return
#####################################################################################################

Subprog ZVALID(ZSTA,ZMSG)
Variable Integer ZSTA
Variable Char ZMSG
# STA = 0 -> Failed, Error = ZMSG

Local Integer ZSOQOPENEDHERE :  ZSOQOPENEDHERE = 0
If dim(ZSYMBOLE2) = 1 : Kill ZSYMBOLE2 : Endif
Global Char ZSYMBOLE2
Local Char ZSOHDET(250)(0..)
For I = 0 To [M:POH2]NBLIG - 1
  If [M:POH2]ZOGLIN(I)=0
   Call GETSOHDETAILS([M:POH0]POHNUM, [M:POH2]POPLIN(I), ZSOHDET) From ZXWIPSPLQTY1
  Else
   Call GETSOHDETAILS([M:POH0]POHNUM, [M:POH2]ZOGLIN(I), ZSOHDET) From ZXWIPSPLQTY1
  Endif
  If ZSOHDET(0) <> ""
   ZSYMBOLE2 = "SOH" + ZSOHDET(0)
   Lock = ZSYMBOLE2
   If fstat
    ZMSG = ZSOHDET(0) + " - " + mess(10,100,1)                                         ##Change in progress in another workstation
    ZSTA = 0
   Endif
   Raz ZSOHDET
  Endif
Next

If !clalev([F:ZSOQ]) : Local File SORDERQ [F:ZSOQ] : ZSOQOPENEDHERE = 1 : Endif
For I = 0 To [M:POH2]NBLIG - 1
 If [M:POH2]ZOGLIN(I) <> 0
  For [F:ZSOQ] Where [F:ZSOQ]SOHNUM = [M:POH2]ZSOHNUM(I) & [F:ZSOQ]SOPLIN = [M:POH2]ZSOPLIN(I)
   If [M:POH2]PRHFCY(I) <> [F:ZSOQ]STOFCY
    ZMSG = "Line: " + num$([M:POH2]ZOGLIN(I)) + " - " + mess(1,6002,1)
    ZSTA = 0 : Break
   Endif
   If [F:ZSOQ]ALLQTY <> 0
    ZMSG = "Line: " + num$([M:POH2]ZOGLIN(I)) + " - " + mess(2,6002,1) + " " + mess(1,6002,1)
    ZSTA = 0 : Break
   Endif
  Next
  If [M:POH2]ZSOHNUM(I) = "MULTI"
   ZMSG = "Line: " + num$([M:POH2]ZOGLIN(I)) + " - " + mess(1,6002,1)
   ZSTA = 0 : Break
  Endif
 Endif
Next
If ZSOQOPENEDHERE = 1 : Close File [F:ZSOQ] : Endif
End
#####################################################################################################

$VERIF_MOD
Local Integer ZSTA : ZSTA = 1
Local Char ZMSG(250) : ZMSG = ""

Call ZVALID(ZSTA,ZMSG)

If ZSTA = 0 : Infbox ZMSG : OK = 0 : Endif
If ZSTA = 0 & dim(GMESSAGE)>0 : GMESSAGE =  ZMSG : GERR = 1 : OK = 0 : Endif
If ZSTA <> 0
 Local Char REQUETE(250)(0..)
 REQUETE(0) = " Delete From " + nomap + ".ZMTOLINK; "
 REQUETE(1) = " INSERT INTO " + nomap + ".ZMTOLINK(UPDTICK_0,STOFCY_0,ITMREF_0,DEMTYP_0,DEMNUM_0," +
& "DEMLIN_0,DEMSEQ_0,DWIPTYP_0,DWIPSTA_0,RESSTYP_0,"
 REQUETE(2) = " RESSNUM_0,RESSLIN_0,RESSSEQ_0,RWIPTYP_0,RWIPSTA_0,LIKQTY_0,FRCFLG_0,FMIFLG_0,MTOREF_0,"
 REQUETE(3) = " EXPNUM_0,CREUSR_0,CREDAT_0,UPDUSR_0,UPDDAT_0,CREDATTIM_0,UPDDATTIM_0,AUUID_0)"
 REQUETE(4) = " SELECT UPDTICK_0,STOFCY_0,ITMREF_0,DEMTYP_0,DEMNUM_0,DEMLIN_0,DEMSEQ_0,DWIPTYP_0,DWIPSTA_0,RESSTYP_0,"
 REQUETE(5) = " RESSNUM_0,RESSLIN_0,RESSSEQ_0,RWIPTYP_0,RWIPSTA_0,LIKQTY_0,FRCFLG_0,FMIFLG_0,MTOREF_0,"
 REQUETE(6) = " EXPNUM_0,CREUSR_0,CREDAT_0,UPDUSR_0,UPDDAT_0,CREDATTIM_0,UPDDATTIM_0,AUUID_0"
 REQUETE(7) = " FROM " + nomap + ".MTOLINK"
 Execsql From "5" Sql REQUETE(0..7)
 Raz REQUETE
Endif
Return
#####################################################################################################

$SETBOUT

Local Integer ZINCNOL :  ZINCNOL = 0
If !GIMPORT
 Diszo [M:POH2]YPOCNUM
 Diszo [M:POH2]YPOCUPDTICK
Else
 Actzo [M:POH2]YPOCNUM
 Actzo [M:POH2]YPOCUPDTICK
Endif
If dim(ZNDFLG) > 0
#GMESSAGE+= "ZNDFLG=" + num$(ZNDFLG)
 If ZNDFLG = 1
  Local Char ZPOLIST(250)(0..,8) : Raz ZPOLIST
  Local Char ZCURLN : ZCURLN = ""
  Local Char ZOLDLN : ZOLDLN = ""
  Local Integer ZCNT : ZCNT = 0
  Sorta [M:YPOC1]NBLIG [M:YPOC1]NBLIG Order By [M:YPOC1]YPOHNUM(indice),[M:YPOC1]YPOPLIN(indice)
  For I = 0 To [M:YPOC1]NBLIG-1
   If I = 0 : ZOLDLN = [M:YPOC1]YPOHNUM(I) + num$([M:YPOC1]YPOPLIN(I)) : Endif
   If [M:YPOC1]YLNVALIDATED(I) = 2 : Goto SKIPNEXTI : Endif
   ZCURLN = [M:YPOC1]YPOHNUM(I) + num$([M:YPOC1]YPOPLIN(I))
   If ZCURLN = ZOLDLN
    ZPOLIST(ZCNT,0) = [M:YPOC1]YPOHNUM(I)
    ZPOLIST(ZCNT,1) = num$([M:YPOC1]YPOPLIN(I))
    ZPOLIST(ZCNT,2) = [M:YPOC1]YITMREF(I)
    ZPOLIST(ZCNT,3) = num$([M:YPOC1]YQTY(I))
    ZPOLIST(ZCNT,4) = num$([M:YPOC1]YPRICE(I))
    ZPOLIST(ZCNT,5) = "0"                            #num$([M:YPOC1]YDISCRGAMT(I))
    ZPOLIST(ZCNT,6) = [M:YPOC1]YCNFRCPDAT(I)
    ZPOLIST(ZCNT,7) = num$([M:YPOC1]YPOCLIN(I))
    ZCNT+=1
   Else
    #GMESSAGE += "PND " + [M:POH0]POHNUM + "/" +  ZPOLIST(0,0) + "/" +  ZPOLIST(0,1) + "/ ZCNT" + num$(ZCNT)
    If [M:POH0]POHNUM = ZPOLIST(0,0) and ZCNT > 1: Call ZUPDPO(ZPOLIST,ZCNT,ZINCNOL) : Endif
    ZCNT = 0
    Raz ZPOLIST
    ZPOLIST(ZCNT,0) = [M:YPOC1]YPOHNUM(I)
    ZPOLIST(ZCNT,1) = num$([M:YPOC1]YPOPLIN(I))
    ZPOLIST(ZCNT,2) = [M:YPOC1]YITMREF(I)
    ZPOLIST(ZCNT,3) = num$([M:YPOC1]YQTY(I))
    ZPOLIST(ZCNT,4) = num$([M:YPOC1]YPRICE(I))
    ZPOLIST(ZCNT,5) = "0"                            #num$([M:YPOC1]YDISCRGAMT(I))
    ZPOLIST(ZCNT,6) = [M:YPOC1]YCNFRCPDAT(I)
    ZPOLIST(ZCNT,7) = num$([M:YPOC1]YPOCLIN(I))
    ZCNT+=1
    ZOLDLN = ZCURLN
   Endif
   SKIPNEXTI
   If I = [M:YPOC1]NBLIG-1 : If [M:POH0]POHNUM = ZPOLIST(0,0) and ZCNT > 1 : Call ZUPDPO(ZPOLIST,ZCNT,ZINCNOL) : Endif : Endif
    #GMESSAGE += " PND1 " + [M:POH0]POHNUM + "/" +  ZPOLIST(0,0) + "/" +  ZPOLIST(0,1) + "/ ZCNT" + num$(ZCNT) + " : "  + ZCURLN + " : " + ZOLDLN
  Next
  ZNDFLG = 0
 Endif
Endif

Return
#####################################################################################################

Subprog ZUPDPO(ZPOLIST,ZCNT,ZINCNOL)
Value Char ZPOLIST()(0..,0..)
Value Integer ZCNT
Variable Integer ZINCNOL
GMESSAGE += " ZUPDPO called "
Local Integer NOL : NOL = 0                      ##NOL should have the PO line number which needs to be split
Call ZGETNOL(ZPOLIST(0,0),ZPOLIST(0,1),NOL)
GMESSAGE += " NOL= " + num$(NOL)
If NOL  = 0 : End :Endif
NOL = ZINCNOL + NOL - 1
ZINCNOL = ZINCNOL + ZCNT - 1

Call TEMPON("O") From GESECRAN

#b/- GT NDEV YA007 customization
Local Integer ZOGPOPLIN
If [M:POH2]ZOGLIN(NOL) = 0 : ZOGPOPLIN = [M:POH2]POPLIN(NOL) : Else ZOGPOPLIN = [M:POH2]ZOGLIN(NOL) : Endif
#[M:POH2]WTOTLINAMT = 0 : Affzo [M:POH2]WTOTLINAMT
Local Char ZSODETAILS(250)(0..)
#---------------------------------------------------Update existing links
For K = 0 To [M:POH2]NBLIG-1
 If K <> NOL and [M:POH2]ZOGLIN(K)=0
  Call GETSOHDETAILS([M:POH0]POHNUM, [M:POH2]POPLIN(K), ZSODETAILS)
  [M:POH2]ZSOHNUM(K) = ZSODETAILS(0)
  [M:POH2]ZSOPLIN(K) = val(ZSODETAILS(1))
  [M:POH2]ZLIKQTY(K) = val(ZSODETAILS(3))
  If [M:POH2]ZSOHNUM(K) <> ""
   [M:POH2]ZACTSOLQTY(K) = val(ZSODETAILS(5)) - val(ZSODETAILS(4))
   [M:POH2]ZSOLDLVQTY(K) = val(ZSODETAILS(6))
   [M:POH2]ZOGLIN(K) = [M:POH2]POPLIN(K)
  Endif
  Raz ZSODETAILS
 Endif
Next

#---------------------------------------------------Update existing links
#e/- GT NDEV YA007 customization

Local File PWRKORDERS [PW2]
Default Mask [POH2]

If NOL+1<[M:POH2]NBLIG &
&  [M:POH2]POPLIN(NOL)+ZCNT>=[M:POH2]POPLIN(NOL+1)                            ##Add number of split lines instead of "2"
      GMESSAGE=mess(72,194,1) : GERR=1 : Return : Endif
status=73 : nolign=NOL+1 : RETQTY=[M:POH2]RETQTYSTU(NOL)

Insa NOL+1,ZCNT,[M:POH2]NBLIG+ZCNT-1 [M:POH2]NBLIG                            ##Add number of split lines instead of "2"
[M:POH2]NBLIG+=ZCNT                                                           ##Add number of split lines instead of "2"
Local    Decimal  WOLDQTYSTU

#For I=1 To [M:PSQ1]NBLIG
For I=1 To ZCNT                                                               ##Add number of split lines instead of "2"
    J=NOL+I : nolign=J+1 : L=NOL : Gosub COPIE_LIG From SUBPOHA
#----- Chargement des nouvelles valeurs de la ligne -----#
    [M:POH2]PRHFCY(J)    = [M:POH2]PRHFCY(NOL)                                ##Add site from grid
    [M:POH2]FCYADD(J)    = [M:POH2]FCYADD(NOL)                                ##Get Address from original line
    [M:POH2]EXTRCPDAT(J) = ZPOLIST((I-1),6)                                   ##Get Receipt date from new mask
#    [M:POH2]GROPRI(J) = val(ZPOLIST((I-1),4))                                 ##Get Gross price from new mask
#    [M:POH2]DISCRGVAL1(J) = val(ZPOLIST((I-1),5))                             ##Get DISCRGAMT price from new mask
    [M:POH2]YPOCNUM(J) = [M:YPOC0]YPOCNUM
    [M:POH2]YPOCLIN(J) = val(ZPOLIST((I-1),7))
#    GMESSAGE += "POLIST " +  ZPOLIST((I-1),0) + ZPOLIST((I-1),1) + ZPOLIST((I-1),2) + ZPOLIST((I-1),3) + ZPOLIST((I-1),4) + ZPOLIST((I-1),5) + ZPOLIST((I-1),6) + ZPOLIST((I-1),7) + "/ NOL" +
# num$(NOL)
    [M:POH2]YPOCUPDTICK(J) = [M:POH2]YPOCUPDTICK(NOL)
    If [M:POH2]YPOCNUM(NOL) = ""
     [M:POH2]YRCPDAT(J)= 2
    #Else
    # [M:POH2]YRCPDAT(J)= 1
    Endif
#Call APRES_SPENBLIG
#----- Chargement des quantités -----#

#Case [M:PSQ1]QTYFLG
    Local Integer ZT : ZT = 1                                                 ##Hardcoded to 1
    Local Integer ZQTY(2) : ZQTY(0) = 3 : ZQTY(1) = 2                         ## Array ZQTY should have the split quantities
      #When 1 : [M:POH2]QTYUOM(J)=[M:PSQ1]QTY(I-1)
    Case ZT
    When 1 : [M:POH2]QTYUOM(J)=val(ZPOLIST((I-1),3))
               [M:POH2]QTYPUU(J)=[M:POH2]QTYUOM(J)*[M:POH2]UOMPUUCOE(J)
               # Issue 100120 - 2014-05-19 by MUARN : poids et volume
               WOLDQTYSTU = [M:POH2]QTYSTU(NOL)
               Call QTEARR([M:POH2]QTYPUU(J),[M:POH2]PUU(J)) From TRTDIV
               Call PCAL_QTY([M:POH2]QTYPUU(J),[M:POH2]PUU(J),
&                            [M:POH2]QTYSTU(J),[M:POH2]STU(J),
&                            [M:POH2]ITMREF(J),[M:POH0]BPSNUM,1,GBIDD1) From TRTACHQTE1
    Endcase
    Call CONVERT_VOUWEU("POH2",J,[M:POH2]LINWEU(J),[M:POH2]LINVOU(J),[M:POH2]QTYSTU(J),WOLDQTYSTU) From STCLIB
    If RETQTY>[M:POH2]QTYSTU(J) [M:POH2]RETQTYSTU(J)=[M:POH2]QTYSTU(J)
                                RETQTY-=[M:POH2]QTYSTU(J)
                           Else [M:POH2]RETQTYSTU(J)=RETQTY
                                Raz RETQTY : Endif
#----- Mise à jour fichier de travail picking des "POS","POP","TRS","TRP" & "SCF" -----#
    If [M:POH2]RETQTYSTU(J)<>0 & [M:POH2]SOHNUM(J)="" Gosub ECLATE_PWO From SUBPOHB : Endif
#----- Chargement numéro d'appel d'offre sur 1ère ligne uniquement -----#
    If I=1 [M:POH2]PQHNUM(J) = [M:POH2]PQHNUM(NOL)
           [M:POH2]PPDLIN(J) = [M:POH2]PPDLIN(NOL)
    Else Raz [M:POH2]PQHNUM(J),[M:POH2]PPDLIN(J) : Endif

##------------------------------------------------------------------------ GT NDEV  YA007 customization begin
Call GETSOHDETAILS([M:POH0]POHNUM, ZOGPOPLIN, ZSODETAILS)
If ZSODETAILS(0) <> "" : [M:POH2]ZOGLIN(J) = ZOGPOPLIN : Endif
[M:POH2]ZSOHNUM(J) = ZSODETAILS(0)
[M:POH2]ZSOPLIN(J) = val(ZSODETAILS(1))
[M:POH2]ZLIKQTY(J) = val(ZSODETAILS(3))
[M:POH2]ZACTSOLQTY(J) = val(ZSODETAILS(5)) - val(ZSODETAILS(4))
[M:POH2]ZSOLDLVQTY(J) = val(ZSODETAILS(6))
Raz ZSODETAILS

##------------------------------------------------------------------------ GT NDEV  YA007 customization end
    status=0 : Call LINNUM("POPLIN") From TABLEAUX
    Call APRES_NBLIG From SUBPOH
    #Gosub RECALCUL_TARLIG From SUBPOHB
Next I

#----- Affichage pour initialisation des sections analytique à cause du Dela -----#
Affzo [POH2]5
#----- Suppression du texte associé à la ligne d'origine -----#
If [M:POH2]CREFLG(NOL)=0 & left$([M:POH2]LINTEX(NOL),3)="POQ"
  Call SUP_CLOB([M:POH2]LINTEX(NOL),GBIDI1) From TRTX3TEX
Endif
#----- Suppression de la ligne d'origine -----#
status=65 : nolign=NOL+1 : Call AVANT_NBLIG From SUBPOH
Dela NOL,1,[M:POH2]NBLIG-1 [M:POH2]NBLIG : [M:POH2]NBLIG-=1
Call TEMPOFF From GESECRAN
Close Local File [PW2]
Affzo [POH2]5-15

## To set the split flag to true to call the customization to link split PO lines with assigned SO lines
If dim(ZSPLFLG) = 1 : Kill ZSPLFLG : Endif
Global Integer ZSPLFLG : ZSPLFLG = 1

End
####################################################################################

Subprog ZGETNOL(ZPONM,ZPOLN,ZNOL)
 Value Char ZPONM()
 Value Char ZPOLN
 Variable Integer ZNOL

 Local Char ZREQ(250)(0..)
 ZREQ(0) = " select cast(RN as int) from (select ROW_NUMBER() over (Order by POHNUM_0,POPLIN_0) RN ,POPLIN_0 "
 ZREQ(1) = " from " + nomap + ".PORDERQ WHERE POHNUM_0 = '" + ZPONM + "') v Where POPLIN_0 = " + ZPOLN

 For (Integer ZLINNUM) From "5" Sql ZREQ(0..2) As [YLN]
  ZNOL = [YLN]ZLINNUM
 Next
End
####################################################################################

Subprog GETSOHDETAILS(ZPOHNUM,ZLIN,ZSOHDETAILS)
Value Char ZPOHNUM
Value Integer ZLIN
Variable Char ZSOHDETAILS()()
Local Decimal ZSOMLKQTY : ZSOMLKQTY = 0
Local Integer ZMLKOPENEDHERE : ZMLKOPENEDHERE = 0
Local Integer ZSQ2OPENEDHERE : ZSQ2OPENEDHERE = 0

ZSOHDETAILS(0) = "" : ZSOHDETAILS(1) = "0" : ZSOHDETAILS(2) ="0"
If !clalev([F:MLK]) : Local File MTOLINK [MLK] : ZMLKOPENEDHERE = 1 : Endif
If !clalev([F:ZSQ2]) : Local File SORDERQ [F:ZSQ2] : ZSQ2OPENEDHERE = 1 : Endif
Filter [F:ZSQ2]
Filter [F:MLK]

For [F:MLK] Where [F:MLK]RESSNUM = ZPOHNUM and [F:MLK]RESSLIN = ZLIN
 If ZSOHDETAILS(0) <> ""
  ZSOHDETAILS(0) = "MULTI"
 Else
  ZSOHDETAILS(0) = [F:MLK]DEMNUM
 Endif
 ZSOHDETAILS(1) = num$([F:MLK]DEMLIN)
 ZSOHDETAILS(2) = "1"
 ZSOHDETAILS(3) = num$([F:MLK]LIKQTY)
Next

For [F:MLK] Where [F:MLK]DEMNUM = ZSOHDETAILS(0) and [F:MLK]DEMLIN = val(ZSOHDETAILS(1)) and (([F:MLK]RESSNUM = ZPOHNUM and [F:MLK]RESSLIN <> ZLIN) or [F:MLK]RESSNUM <> ZPOHNUM)
 ZSOMLKQTY = ZSOMLKQTY + [F:MLK]LIKQTY
Next
ZSOHDETAILS(4) = num$(ZSOMLKQTY)

For [F:ZSQ2] Where [F:ZSQ2]SOPLIN = val(ZSOHDETAILS(1)) and [F:ZSQ2]SOHNUM = ZSOHDETAILS(0)
 ZSOHDETAILS(5) = num$([F:ZSQ2]QTY)
 ZSOHDETAILS(6) = num$([F:ZSQ2]DLVQTY + [F:ZSQ2]ODLQTY)
Next

If ZMLKOPENEDHERE = 1 : Close File [F:MLK] : Endif
If ZSQ2OPENEDHERE = 1 : Close File [F:ZSQ2] : Endif

End
####################################################################################

$RAZDUP
For J = 0 To [M:POH2]NBLIG-1
 Raz [M:POH2]YPOCNUM(J)
 Raz [M:POH2]YPOCLIN(J)
 Raz [M:POH2]YPOCUPDTICK(J)
Next
Return


Subprog APRES_SPENBLIG
#-------------------------------------------#
# Après ligne : Màj et affichage totaux cde #
#-------------------------------------------#
[M:POH2]GROPRI(0) = 20
[M:POH2]DISCRGVAL1(0) = 2
Local Shortint NOL : NOL=0
# Issue 84130 - 2012-11-29 by SR
Local Integer  WRET
Local Integer  SIGN
#----- Si suppression ligne, affichage totaux et fin -----#
If status=65 | status=68 | status=83
  #----- Suppression des lignes liées au composé (produit fini) -----#
  If NOL<[M:POH2]NBLIG-1 & [M:POH2]LINTYP(NOL+1)>2
    Local Shortint I : I=NOL+1
    While [M:POH2]LINTYP(I)>2
      nolign=I+1 : Call AVANT_NBLIG From SUBPOH
      Dela I,1,[M:POH2]NBLIG-1 [M:POH2]NBLIG : [M:POH2]NBLIG-=1
    Wend
    Affzo [POH2]5
    nolign=NOL+1
  Endif
  #-----
  If !GIMPORT
    Affzo [POH2]10,15
    Affzo [POH3]5
    nolign=NOL+1
  Endif
  [M:POH2]CLCFLG=2
  End
Endif
#----- Abandon de la saisie ligne par escape ou click sur listes de gauche -----#
If status=6 | status=7 | status=27 | status=28 | [M:POH2]ITMREF(NOL)=""
  If [M:POH2]POHLIN(NOL)=0 & [M:POH2]CTLPOHCOU<>0
    [M:POH2]POHLIN(NOL)=[M:POH2]CTLPOHCOU
    Gosub EFFAC_LIG_PWRKORDERS From SUBPOHB
    Raz [M:POH2]POHLIN(NOL), [M:POH2]CTLPOHCOU
  Endif
  Call MAJ_BASTAX_LIG(NOL,+1) From SUBPOHC : # Màj bases et mts taxe
  Call MAJ_CUMULS_LIG(NOL,+1) From SUBPOHC : # Màj cumuls et éléments
  If !GIMPORT
    Affzo [POH2]10,15
    Affzo [POH3]5
  Endif
  End
Endif

#----- Si modif du composé, répercution sur les composants ? -----#
If [M:POH2]LINTYP(NOL)=2
  #----- Répercussion site réception, code adresse et date réception prévue -----#
  Local Integer I : I=NOL+1
  While [M:POH2]LINTYP(I)>2 & I<[M:POH2]NBLIG
    #-----
    # Issue X3-38719 - 2017-11-13 by MUARN : ajout adresse sous-traitant
    If [M:POH2]PRHFCY(I)<>[M:POH2]PRHFCY(NOL) | [M:POH2]FCYADD(I)<>[M:POH2]FCYADD(NOL) | [M:POH2]SCOADD(I)<>[M:POH2]SCOADD(NOL)
      [M:POH2]PRHFCY(I)=[M:POH2]PRHFCY(NOL)
      [M:POH2]FCYADD(I)=[M:POH2]FCYADD(NOL)
      # Issue X3-38719 - 2017-11-13 by MUARN : ajout adresse sous-traitant
      [M:POH2]SCOADD(I)=[M:POH2]SCOADD(NOL)
      [M:POH2]UPDFLG(I)=1
      #If func AFNC.ACTIV("PTX") # Issue 93038 GA 10/2013
        Call ALIVATCOD(2,[M:POH0]BPSNUM,[M:POH2]ITMREF(I),"POH2",I) From TRTX3
      #Endif
      # Issue X3-38719 - 2017-11-13 by MUARN : ajout adresse sous-traitant
      If !GIMPORT  Affzo [POH2]PRHFCY(I), FCYADD(I), SCOADD(I) : Endif
    Endif
    #-----
    If [M:POH2]EXTRCPDAT(I)<>[M:POH2]EXTRCPDAT(NOL)
      [M:POH2]EXTRCPDAT(I)=[M:POH2]EXTRCPDAT(NOL)
      [M:POH2]UPDFLG(I)=1
      If !GIMPORT  Affzo [POH2]EXTRCPDAT(I) : Endif
    Endif
    #-----
    I+=1
  Wend
  # Issue 71069 - 2015-12-15 by MUARN : pjt
  #----- Si modif qté -----#
  If [M:POH2]PREQTYPUU(NOL)<>[M:POH2]QTYPUU(NOL) | [M:POH2]PJT(NOL+1)<>[M:POH2]PJT(NOL)
    Local Integer OK : OK=2
    # Issue 71069 - 2015-12-15 by MUARN : pjt
    Local Integer UPD_PJT : UPD_PJT = 1
    Local Integer UPD_QTY : UPD_QTY = 1
    If [M:POH2]PJT(NOL+1)<>[M:POH2]PJT(NOL) : UPD_PJT = 2 : Endif
    If [M:POH2]PREQTYPUU(NOL)<>[M:POH2]QTYPUU(NOL)
      Call OUINON(mess(14,191,1),OK) From GESECRAN
      UPD_QTY = OK
    Endif
    # Issue 71069 - 2015-12-15 by MUARN : pjt
    If OK=2 | UPD_PJT = 2
      Local Libelle WTARFLG
      Local Decimal WQTE
      Local Integer I : I=NOL+1
      While [M:POH2]LINTYP(I)>2 & I<[M:POH2]NBLIG
        # Issue 71069 - 2015-12-15 by MUARN : pjt
        If [M:POH2]LIKQTYCOE(I)<>0 | UPD_PJT = 2
          # Issue 71069 - 2015-12-15 by MUARN : pjt
          If [M:POH2]LIKQTYCOE(I)<>0 & UPD_QTY = 2
            WQTE=[M:POH2]QTYSTU(NOL)*[M:POH2]LIKQTYCOE(I)
            Call QTEARR(WQTE,[M:POH2]STU(I)) From TRTDIV
          Endif
          nolign=I+1
          Call AVANT_NBLIG     From SUBPOH
          #----- Si autres lignes, calcul tarif en conséquence sans question -----#
          If I>NOL+1
            If WTARFLG=2  [M:POH2]LINFLG(I)=0  Else  [M:POH2]LINFLG(I)=3 : Endif
          Endif
          #-----
          # Issue 71069 - 2015-12-15 by MUARN : pjt
          If [M:POH2]LIKQTYCOE(I)<>0 & UPD_QTY = 2
            If UPD_PJT = 2 : [M:POH2]PJT(I)=[M:POH2]PJT(NOL) : Endif
            Call AM_QTYSTU(WQTE) From SUBPOH
          Else
            Call AM_PJT([M:POH2]PJT(NOL)) From SUBPOH
          Endif
          #----- Si 1ère ligne traitée, indicateur pour calcul tarif autres lignes -----#
          If I=NOL+1
            WTARFLG=[M:POH2]LINFLG(I) : # 1=REAJUST_TARIF, 2=INI_TARIF
            # Issue 103023 - 2014-09-29 by MUARN : recalcul taxe ligne service
            If WTARFLG=2  [M:POH2]LINFLG(I)=0  Else  [M:POH2]LINFLG(I)=3 : Endif
          Endif
          #-----
          Call APRES_NBLIG     From SUBPOH
          [M:POH2]UPDFLG(I)=1
        Endif
        I+=1
      Wend
      Affzo [POH2]5
      nolign=NOL+1
    Endif
  Endif
  #-----
# Issue X3-38719 - 2017-11-13 by MUARN : si SST avec OF et pas d'adresse SST
Elsif [M:POH2]VCRTYPORI(NOL)=10 & [M:POH2]SCOADD(NOL) = ""
  Look [BPD] BPD0=[M:POH0]BPSNUM;[M:AD61]BPAADD
  If !fstat
    [M:POH2]SCOADD(NOL)=[M:AD61]BPAADD
  Else
    Filter [BPD] Where BPCNUM=[M:POH0]BPSNUM & ENAFLG=2
    Read [BPD] BPD0 First
    If !fstat
      [M:POH2]SCOADD(NOL) = [F:BPD]BPAADD
    Else
      Raz [M:POH2]SCOADD(NOL)
    Endif
    Filter [BPD]
  Endif
  If !GIMPORT  Affzo [POH2]SCOADD(NOL) : Endif
Endif
[M:POH2]PREQTYPUU(NOL)=[M:POH2]QTYPUU(NOL)
#----- Ajout de ligne en modif de cde --> Raz signatures -----#
If GREP="M" & [M:POH2]CREFLG(NOL)=0 [M:POH2]WAPPFLG(NOL)=2 : Endif
#-----
Raz [M:POH2]CTLPOHCOU
#----- Calcul ligne -----#
If [M:POH2]LINTYP(NOL)<>2 : # Si ce n'est pas le composé (produit fini)
  [M:POH2]LINAMT(NOL)=[M:POH2]NETPRI(NOL)*[M:POH2]QTYUOM(NOL)
  Call ARRDEV([M:POH2]LINAMT(NOL),GCUR) From TRTDIV
  #------------------------------------------------------------------#
  # Point d'entrée CLCMNTPOH pour recalcul Montant HT ligne commande #
  # ---------------------------------------------------------------- #
  # Variables utilisables par le point d'entrée                      #
  #                                                                  #
  # WLINAMT : Montant HT ligne commande à recalculer                 #
  # WCUR    : Devise dans laquelle est exprimé le montant            #
  # WABRMSK : Abréviation du masque contenant les lignes de commande #
  # NOL     : Indice de la ligne courante                            #
  #------------------------------------------------------------------#
  Local Decimal  WLINAMT       : WLINAMT =[M:POH2]LINAMT(NOL)
  Local Char     WCUR(GLONCUR) : WCUR    =GCUR
  Local Char     WABRMSK(4)    : WABRMSK ="POH2"
  Local Shortint SAVXZSNOL
  SAVXZSNOL=NOL
  Gosub POINT_CLCMNTPOH From TRTACHCDE1
  NOL=SAVXZSNOL
  If [M:POH2]LINAMT(NOL)<>WLINAMT
    [M:POH2]LINAMT(NOL)=WLINAMT
    Call ARRDEV([M:POH2]LINAMT(NOL),GCUR) From TRTDIV
    [M:POH2]LINFLG(NOL)=2
  Endif
Endif

If [M:POH2]LINFLG(NOL)<>1
  Call MAJ_CALTAX_LIG("POH2",NOL)  From TRTACHDIV1
Endif
Call MAJ_BASTAX_LIG(NOL,+1) From SUBPOHC : # Màj bases et mts taxe
Call MAJ_CUMULS_LIG(NOL,+1) From SUBPOHC : # Màj cumuls et éléments

#--- Issue 84130
If [M:POH2]STCNUM(NOL)<>"" & [M:POH2]WSTCUPD(NOL)=2
  Gosub ALIM_STCP From SUBPOH
  Call GES_STCDW("POH2",NOL,WRET) From STCCLC
Endif
#---

# Issue 71069 - 2013-08-23 by MUARN : PJT
# Issue 71069-51 - 2016-08-25 by SR : Import PJT
# Si première ligne & pas de code affaire à l'entête on alimente le code affaire à l'entête
#If [M:POH2]NBLIG <1 & [M:POH1]PJTH = "" & GPJTSNGDOC = 2
If ([M:POH2]NBLIG <1 | (GIMPORT & [M:POH2]NBLIG=1)) & [M:POH1]PJTH = "" & GPJTSNGDOC = 2
  [M:POH1]PJTH = [M:POH2]PJT(NOL)
  Affzo [POH1]PJTH
Endif

[M:POH2]LINFLG(NOL)=1
#-----
If GREVFLG=2  [M:POH2]LINREVNUM(NOL)=[M:POH0]REVNUM : Endif
[M:POH2]FBUFLG(NOL)=1
If clalev([M:PSQ1])>0 End : Endif : # Test après éclatement ligne
#----- Affichage totaux et si nécessaire numéro d'avenant -----#
If !GIMPORT
  #----- Désactivation du site entête commande -----#
  If [M:POH2]NBLIG=0
    Diszo [POH0]POHFCY
    #----- Désactivation fournisseur et site d'expédition si inter-sites -----#
    If [M:POH0]BETFCY=2
      Diszo [POH0]BPSNUM
      If [M:POH0]DME=3  Diszo [POH1]STOFCY : Endif
    Endif
  Endif
  #-----
  Affzo [POH2]EXTRCPDAT(NOL), LINAMT(NOL), VAT1(NOL), VAT2(NOL), VAT3(NOL)
  Affzo [POH2]10,15
  Affzo [POH3]5
  nolign=NOL+1 : # Le nolign peut être perdu à cause de l'Affzo !
Endif
If GREVFLG=2 & !GIMPORT Affzo [POH2]LINREVNUM(NOL) : nolign=NOL+1 : Endif
#-----
If [M:POH2]NBLIG=0 & [M:POH0]SALFCY<>"" & ([M:POH0]DME=3 | GLINBPD<>2)
  If GRCPFCY<>[M:POH2]PRHFCY(0)
    GRCPFCY=[M:POH2]PRHFCY(0)
    [M:POH1]PRHFCYLIB=space$(max(22-(len(mess(605,197,1))+GLONFCY),0))+mess(605,197,1)-GRCPFCY
    Affzo [POH1]PRHFCYLIB
  Endif
Endif

# GH 22/11/13 bug 94672 à faire dans en chgt article ou site
# Issue 79939 - 2012-02-13 by MUARN : affectation avant contrôle intersite
# V6 Règle affectation
# [M:POH2]PTOCOD(NOL) = func ITMLIB.GET_PTOCOD([M:POH2]ITMREF(NOL), [M:POH2]PRHFCY(NOL))

#----- Pas de budget si inter-sites ou ligne composé (produit fini) -----#
If ([M:POH0]BETFCY=2 & [M:POH0]BETCPY=1) | [M:POH2]LINTYP(NOL)=2  End : Endif
#----- Pré-contrôle du budget si nouvelle ligne et pas import -----#
If GBUDCTLPOL=2 & GCNTBUD>1 & [M:POH2]CREFLG(NOL)=0 & GMODU(2)=2 & !GIMPORT & GNBDIE>0
  # Issue 84130 - 2012-11-16 by MUARN : landed cost - déplacé de SUBPOHA à SUBPOHC, trop de lignes
  Call CTRL_BUDLIN(NOL) From SUBPOHC
Endif
#-----
# Issue 79939 - 2012-02-13 by MUARN : affectation avant contrôle intersite
# V6 Règle affectation
#[M:POH2]PTOCOD(NOL) = func ITMLIB.GET_PTOCOD([M:POH2]ITMREF(NOL), [M:POH2]PRHFCY(NOL))

End

