Funprog GET_PRICECO (ITM)
Value Char ITM ()

Local Decimal PRICE, PESOCU, BASPRI, PRICU
Local Date FECHADOC

If !clalev([F:YITM])  : Local File ITMMASTER [F:YITM]  : Endif
If !clalev([F:YPCUD]) : Local File YPRICUDIA [F:YPCUD] : Endif

Case GFONCTION
  When "GESPOH"
    FECHADOC = [M:POH0]ORDDAT
  When "GESPTH"
    FECHADOC = [M:PTH0]RCPDAT
  When "GESPIH"
    FECHADOC = [M:PIH0]ACCDAT
  When Default
Endcase

Read [F:YPCUD]YPCUD0 = FECHADOC
If !fstat

  Read [F:YITM]ITM0 = [L]ITM
  If !fstat
    BASPRI = [F:YITM]PURBASPRI
    PESOCU = [F:YITM]YKGCU100M
  Endif

  PRICU = [F:YPCUD]YPRICUEUR

  # Precio en EUR
  PRICE = (PESOCU * PRICU / 100) + BASPRI

  ##Infbox num$(PESOCU)
  ##Infbox num$(PRICU)
  ##Infbox num$(BASPRI)

Endif

End PRICE

#####################################################################################

Funprog TIENE_ADJ (ABR, ID1, ID2, ID3)
Value Char ABR()
Value Char ID1()
Value Char ID2()
Value Char ID3()

Local Integer ENC
Local Char WCRIT (250)
If !clalev([F:YAOB]) : Local File AOBJTXT [F:YAOB] : Endif

WCRIT = "1=1"
If [L]ABR <> ''
  WCRIT += "&ABREV=[L]ABR"
Endif

If [L]ID1 <> ''
  WCRIT += "&IDENT1=[L]ID1"
Endif

If [L]ID2 <> ''
  WCRIT += "&IDENT1=[L]ID2"
Endif

If [L]ID3 <> ''
  WCRIT += "&IDENT3=[L]ID3"
Endif


ENC = 1
Filter [F:YAOB] Where evalue (WCRIT)
Read [F:YAOB]AOX0 First
If !fstat
  ENC = 2
Endif
Filter [F:YAOB]

End ENC

#####################################################################################

Funprog	CONVERT_CUR (DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG)

Value Char DEVORG #Divisa Origen (Divisa Sociedad si cambio multiplicador / Divisa Documento si cambio divisor)
Value Char DEVDES #Divisa Destino (Divisa Documento si cambio multiplicador / Divisa Sociedad si cambio divisor)
Value Char DEVSOC #Divisa de la sociedad
Value Integer TYPCOURS #Tipo de cambio (Menú Local 202)
Value Date DATCOURS #Fecha de cambio
Value Decimal MTORG #Importe Origen (En divisa documento)

Local Decimal MTDES #Importe destino (En divisa sociedad)
Local Integer STAT #Estado de retorno (0 = OK)

Call CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT) From TRTDEV

End MTDES

#####################################################################################


Funprog CREDIT (CLIENTE, SOCIEDAD)
Value Char CLIENTE()
Value Char SOCIEDAD ()

Local Integer OK

OK=1

If !clalev([F:YBPC]) : Local File BPCUSTOMER [F:YBPC] : Endif

# Calculo del en-curso. Supongo misma divisa Cliente=Sociedad

Local Decimal ENCOURS
GSOCIETE = SOCIEDAD

Read [F:YBPC]BPC0 = CLIENTE
If !fstat
If [F:YBPC]OSTCTL = 1
  Call CALENC([F:YBPC]BPCRSK, date$, ENCOURS) From TRTBPMVT

  # si el encurso supera riesgo, devuelvo M = Mal
  If   ENCOURS> [F:YBPC]OSTAUZ  : OK = 2 : Endif
Elsif [F:YBPC]OSTCTL = 3
  OK = 2
Endif

Endif

End OK


#<YA055>
Subprog GET_GDECPRI
  # Lecture nombre décimales prix (max des types de donnée MD5/MD6/MD8)
If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
Read [ATY]CODTYP="MD5"
If fstat = 0
 GDECPRI = mod([F:ATY]LNGTYP,1)*10
Else
 GDECPRI = 4
Endif
Read [ATY]CODTYP="MD6"
If fstat = 0
 If mod([F:ATY]LNGTYP,1)*10 > GDECPRI
  GDECPRI = mod([F:ATY]LNGTYP,1)*10
 Endif
Endif
Read [ATY]CODTYP="MD8"
If fstat = 0
 If mod([F:ATY]LNGTYP,1)*10 > GDECPRI
  GDECPRI = mod([F:ATY]LNGTYP,1)*10
 Endif
Endif
End
#<\YA055>

