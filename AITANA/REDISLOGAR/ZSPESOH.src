####################################################################################
# Program Name: ZSPESOH
# Description : YA007 - Specific Processing - Sales Orders
# Author      : GT NDEV
# Date        : Jul 4th, 2018
####################################################################################

$ACTION
 Case ACTION
  When "RAZDUP" : Gosub RAZDUP
  When Default
 Endcase
Return
#####################################################################################################

$RAZDUP
For I = 0 To [M:SOH4]NBLIG-1
 Raz [M:SOH4]ZPOHNUM(I)
 Raz [M:SOH4]ZPOHLIN(I)
 Affzo [M:SOH4]ZPOHNUM(I)
 Affzo [M:SOH4]ZPOHLIN(I)
Next
Return

#####################################################################################################
Subprog AM_EXTDLVDAT(VALEUR)
Variable Date    VALEUR

Local Char REQUETE(250)(0..)
#REQUETE(0) = " select (CASE P.YRCPDAT_0 WHEN 2 "
#REQUETE(1) = " THEN 'The confirmed receipt date for this line is '+CONVERT(varchar(12), P.EXTRCPDAT_0,1) "
#REQUETE(2) = " ELSE 'The expected receipt date for this line is '+CONVERT(varchar(12), P.EXTRCPDAT_0,1) END) MSG"

REQUETE(0) = " select P.YRCPDAT_0, CONVERT(varchar(12), P.EXTRCPDAT_0,1) EXTRCPDAT_0 "
REQUETE(1) = " FROM " + nomap + ".SORDERQ S "
REQUETE(2) = " INNER JOIN " + nomap + ".MTOLINK M ON  S.SOHNUM_0 = M.DEMNUM_0 AND S.SOPLIN_0 = M.DEMLIN_0 "
REQUETE(3) = " INNER JOIN " + nomap + ".PORDERQ P ON  P.POHNUM_0 = M.RESSNUM_0 AND P.POPLIN_0 = M.RESSLIN_0 "
REQUETE(4) = " WHERE S.SOHNUM_0 = '" + [M:SOH0]SOHNUM + "' AND S.SOPLIN_0 = " + num$([M:SOH4]SOPLIN(nolign-1))

#For (Char EXTRCPDAT_0 (255)) From "5" Sql REQUETE(0..6) As [ZMSG]

For (Integer YRCPDAT,Char EXTRCPDAT(255)) From "5" Sql REQUETE(0..4) As [ZMSG]
 #Infbox num$([F:ZMSG]ZMSG)
 If YRCPDAT = 2
  infbox mess(3,6002,1) + " " + EXTRCPDAT 
 Else
  infbox mess(4,6002,1) + " " + EXTRCPDAT 
 Endif
Next
End
#####################################################################################################






