Subprog AV_LIGITV(VALEUR)
Variable Decimal VALEUR
pcolor=GCOUL(0)
Case [M:XVRF]ERR(nolign-1)
When "A" : pcolor=GCOUL(2)
When "X" : pcolor=GCOUL(1)
Endcase
End

Subprog AV_WDES(VALEUR)
Variable Char    VALEUR()
Local File ITMMASTER [ITM9]
Read [ITM9]ITM0=[M]ITMREF(nolign-1)
If !fstat Then VALEUR=[F:ITM9]ITMDES1 Endif
Close Local File [F:ITM9]
End


