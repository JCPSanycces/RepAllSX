######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return

######################################################################################
Subprog IB_XNBGRP

If [M:XGU]XPAR(nolign-1)<>"" | [M:XGU]XCLE(nolign-1)<>""
  [V]GBOUT5=mess(39,147,1)
Else
  Raz [V]GBOUT5
Endif

If [M:XGU]XPAR(nolign-1)<>"" & [M:XGU]XCLE(nolign-1)<>""
  [V]GBOUT7=mess(145,[V]GXMSGPSA(1),1)
Else
  Raz [V]GBOUT7
Endif

End


######################################################################################
Subprog AV_XNBGRP

    If !clalev([XXGR]) : Local File XGRPUSR  [XXGR] : Endif
    If !clalev([XXGD]) : Local File XGRPUSRD [XXGD] : Endif

    # Si on est sur un element de dernier niveau on affiche les elements details
    Read [F:XXGR]XGR0 = [M:XGU]XCLE(nolign-1)
    If !fstat
        Raz [M:XGU]XALPHA1 : Raz [M:XGU]XALPHA2
        Raz [M:XGU]XNUM1   : Raz [M:XGU]XNUM2
        Raz [M:XGU]XDATE1  : Raz [M:XGU]XDATE2 : Raz [M:XGU]XRUBRIQUE

        If [F:XXGR]XRUBRIQUE = 2
            If [F:XXGR]XALPHA1I <> "" : Chgtzn[M:XGU]XALPHA1 With [F:XXGR]XALPHA1I : Actzo [M:XGU]XALPHA1
            Else                      : Chgtzn[M:XGU]XALPHA1 With "Non renseigné"  : Diszo [M:XGU]XALPHA1 : Endif

            If [F:XXGR]XALPHA2I <> "" : Chgtzn[M:XGU]XALPHA2 With [F:XXGR]XALPHA2I : Actzo [M:XGU]XALPHA2
            Else                      : Chgtzn[M:XGU]XALPHA2 With "Non renseigné"  : Diszo [M:XGU]XALPHA2 : Endif

            If [F:XXGR]XNUM1I <> "" : Chgtzn[M:XGU]XNUM1   With [F:XXGR]XNUM1I  : Actzo [M:XGU]XNUM1
            Else                    : Chgtzn[M:XGU]XNUM1   With "Non renseigné" : Diszo [M:XGU]XNUM1 : Endif

            If [F:XXGR]XNUM2I <> "" : Chgtzn[M:XGU]XNUM2   With [F:XXGR]XNUM2I  : Actzo [M:XGU]XNUM2
            Else                    : Chgtzn[M:XGU]XNUM2   With "Non renseigné" : Diszo [M:XGU]XNUM2 : Endif

            If [F:XXGR]XDATE1I <> "" : Chgtzn[M:XGU]XDATE1  With [F:XXGR]XDATE1I : Actzo [M:XGU]XDATE1
            Else                     : Chgtzn[M:XGU]XDATE1  With "Non renseigné" : Diszo [M:XGU]XDATE1 : Endif

            If [F:XXGR]XDATE2I <> "" : Chgtzn[M:XGU]XDATE2  With [F:XXGR]XDATE2I : Actzo [M:XGU]XDATE2
            Else                     : Chgtzn[M:XGU]XDATE2  With "Non renseigné" : Diszo [M:XGU]XDATE2 : Endif

            Read [F:XXGD]XGD0 = [F:XXGR]XCODE;[F:AUS]USR
            If !fstat
                [M:XGU]XALPHA1   = [F:XXGD]XALPHA1
                [M:XGU]XALPHA2   = [F:XXGD]XALPHA2
                [M:XGU]XALPHA1V  = [F:XXGD]XALPHA1V
                [M:XGU]XALPHA2V  = [F:XXGD]XALPHA2V
                [M:XGU]XNUM1     = [F:XXGD]XNUM1
                [M:XGU]XNUM2     = [F:XXGD]XNUM2
                [M:XGU]XDATE1    = [F:XXGD]XDATE1
                [M:XGU]XDATE2    = [F:XXGD]XDATE2


                Actzo [M:XGU]XRUBRIQUE : [M:XGU]XRUBRIQUE = 2
                Actzo [M:XGU]XICODEF

                If [M:XGU]XALPHA1="" & [M:XGU]XALPHA2="" & [M:XGU]XNUM1=0 & [M:XGU]XNUM2=0 & [M:XGU]XDATE1=[00/00/0000] & [M:XGU]XDATE2=[00/00/0000]
                    [M:XGU]XALPHA1   = [F:XXGR]XALPHA1D : [M:XGU]XALPHA2   = [F:XXGR]XALPHA2D
                    [M:XGU]XNUM1     = [F:XXGR]XNUM1D   : [M:XGU]XNUM2     = [F:XXGR]XNUM2D
                    [M:XGU]XDATE1    = [F:XXGR]XDATE1D  : [M:XGU]XDATE2    = [F:XXGR]XDATE2D
                Endif
            Endif
        Else
           : Diszo [M:XGU]XALPHA1 : Chgtzn[M:XGU]XALPHA1 With "Non renseigné"
           : Diszo [M:XGU]XALPHA2 : Chgtzn[M:XGU]XALPHA2 With "Non renseigné"
           : Diszo [M:XGU]XNUM1   : Chgtzn[M:XGU]XNUM1   With "Non renseigné"
           : Diszo [M:XGU]XNUM2   : Chgtzn[M:XGU]XNUM2   With "Non renseigné"
           : Diszo [M:XGU]XDATE1  : Chgtzn[M:XGU]XDATE1  With "Non renseigné"
           : Diszo [M:XGU]XDATE2  : Chgtzn[M:XGU]XDATE2  With "Non renseigné"
           : Diszo [M:XGU]XRUBRIQUE
            Grizo [M:XGU]XICODEF
        Endif

        Affzo [M:XGU]XALPHA1 : Affzo [M:XGU]XALPHA2
        Affzo [M:XGU]XNUM1   : Affzo [M:XGU]XNUM2
        Affzo [M:XGU]XDATE1  : Affzo [M:XGU]XDATE2

        [M:XGU]XCODE = [F:XXGR]XCODE : Grizo [M:XGU]XCODE : Affzo [M:XGU]XCODE

    Endif

End

Subprog CL_XICODEF(VALEUR)
Variable Char    VALEUR()
    If !clalev([XXGR]) : Local File XGRPUSR [XXGR] : Endif

    # Si on est sur un element de dernier niveau on affiche les elements details
    Read [F:XXGR]XGR0 = [M:XGU]XCLE(nolign-1)
    If !fstat
        If [F:XXGR]XRUBRIQUE=2
            [M:XGU]XALPHA1  = [F:XXGR]XALPHA1D : [M:XGU]XALPHA2  = [F:XXGR]XALPHA2D
            [M:XGU]XALPHA1V = [F:XXGR]XALPHA1V : [M:XGU]XALPHA2V = [F:XXGR]XALPHA2V
            [M:XGU]XNUM1    = [F:XXGR]XNUM1D   : [M:XGU]XNUM2    = [F:XXGR]XNUM2D
            [M:XGU]XDATE1   = [F:XXGR]XDATE1D  : [M:XGU]XDATE2   = [F:XXGR]XDATE2D
            Affzo [M:XGU]XALPHA1 : Affzo [M:XGU]XALPHA2
            Affzo [M:XGU]XNUM1   : Affzo [M:XGU]XNUM2
            Affzo [M:XGU]XDATE1  : Affzo [M:XGU]XDATE2
            mkstat = 4
        Endif
    Endif
End



######################################################################################
Subprog B5_XNBGRP
    Local Char XCODE
    For [F:XGR] Where XCODEP = ""
        [L]XCODE = [F:XGR]XCODE : Break
    Next
    If [L]XCODE <> ""
        Local Char CLE2
        GCONSULT = 2
        #[L]CLE2 = ""
        #Call OBJET("XGR",[L]XCODE,[L]CLE2) From GOBJET

        Local Decimal BASPAG
        If !GWEBSERV
         ## Action XGRPALO
         Local Char    PARMSK(250)(1..20) , SAVACT(20)
         SAVACT = GACTION : GACTION = "XGRPALO"
         Call TRAITE_NUM(BASPAG,PARMSK,"XGRPUSRALO","SPVXGR","",1,"") From GTRAITE
         GACTION = SAVACT
        Endif

        GCONSULT = 0

        # Si on a modifié les groupes de l'utilisateur, on passe en modif de l utilisateur

        # LBORN 23/02/2015 - Mantis 28519 (on ne détecte pas toujours les modifs, on relit par précaution)
        Read [F:AUS]CODUSR=[M:AUS0]USR
        If fstat : Raz [F:AUS] : Endif

        If [F:AUS]XGRPUTIL <> [M:XGU]XGRPUTIL
            [F:AUS]XGRPUTIL = [M:XGU]XGRPUTIL

            Gosub LIENS From XOBJAUSX11
            Affzo [M:XGU]

            mkstat=4

        Endif

    Endif
End


######################################################################################
Subprog B7_XNBGRP
    Local File XGRPUSR [XXGR]

    Read [F:XXGR]XGR0 = [M:XGU]XCLE(nolign-1)
    If !fstat
        Local Integer XI
        Local Integer YI
        If[F:XXGR]XRUBRIQUE = 2
            If instr(1,[M:XGU]XGRPUTIL,[F:XXGR]XCODE)
                XI = instr(1,[M:XGU]XGRPUTIL,[F:XXGR]XCODE)-2
                # On vire la rubrique de la liste des rubriques utilisateur
                [M:XGU]XGRPUTIL = seg$([M:XGU]XGRPUTIL,1,XI)+seg$([M:XGU]XGRPUTIL,instr(XI+2,[M:XGU]XGRPUTIL,";"),len([M:XGU]XGRPUTIL))
            Endif
        Else
            Call CHERCHEFILSSUP([F:XXGR]XCODE,0)
        Endif

        [F:AUS]XGRPUTIL = [M:XGU]XGRPUTIL
        # On raz la hierarchie puis on la reconstruit
        For I=0 To [M:XGU]XNBGRP
            Raz [M:XGU]XPAR(I),[M:XGU]XPAR2(I),[M:XGU]XCLE(I),[M:XGU]XCLE2(I),[M:XGU]XDES(I),[M:XGU]XDESSHO(I),[M:XGU]XNIV(I),[M:XGU]XIMG1(I),
&               [M:XGU]XICO1(I),[M:XGU]XLIGSG(I),[M:XGU]XRANGG(I),[M:XGU]XFRMG(I),[M:XGU]XEXP(I),[M:XGU]XINFO1(I),[M:XGU]XINFO2(I),[M:XGU]XINFO3(I)
        Next
        Raz [M:XGU]XNBGRP

        Gosub LIENS From XOBJAUSX11
        Affzo [M:XGU]

        mkstat = 4
    Endif


End

######################################################################################
Subprog CHERCHEFILSSUP(PERE,NIVEAU)
    Value Char    PERE
    Value Integer NIVEAU

    Local File XGRPUSR [XGR]
    For [F:XGR] Where [F:XGR]XCODEP=[L]PERE
        Local Integer XI
        Local Integer YI
        If[F:XGR]XRUBRIQUE = 2
            If instr(1,[M:XGU]XGRPUTIL,[F:XGR]XCODE)
                XI = instr(1,[M:XGU]XGRPUTIL,[F:XGR]XCODE)-2
                # On vire la rubrique de la liste des rubriques utilisateur
                [M:XGU]XGRPUTIL = seg$([M:XGU]XGRPUTIL,1,XI)+seg$([M:XGU]XGRPUTIL,instr(XI+2,[M:XGU]XGRPUTIL,";"),len([M:XGU]XGRPUTIL))
            Endif
        Else
            Call CHERCHEFILSSUP([F:XGR]XCODE,0)
        Endif
    Next
End

######################################################################################
Subprog AM_XALPHA1(VALEUR)
Variable Char    VALEUR()
    [V]ENMODIF = 2
End

Subprog AM_XALPHA2(VALEUR)
Variable Char    VALEUR()
    [V]ENMODIF = 2
End

Subprog AM_XNUM1(VALEUR)
Variable Decimal VALEUR
    [V]ENMODIF = 2
End

Subprog AM_XNUM2(VALEUR)
Variable Decimal VALEUR
    [V]ENMODIF = 2
End

Subprog AM_XDATE1(VALEUR)
Variable Date    VALEUR
    [V]ENMODIF = 2
End

Subprog AM_XDATE2(VALEUR)
Variable Date    VALEUR
    [V]ENMODIF = 2
End
